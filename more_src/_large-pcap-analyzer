#compdef large-pcap-analyzer
# Documentation: https://github.com/f18m/large-pcap-analyzer/blob/master/README.md
# Fast command-line utility for operations on very large PCAP files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-q --quiet)'{-q,--quiet}'[suppress normal output for scripting]' \
  '(-w --write)'{-w,--write}'+[save processed results to output file]:output pcap:_files' \
  '(-a --append)'{-a,--append}'[open output file in append mode]' \
  '(-Y --display-filter)'{-Y,--display-filter}'+[apply BPF filter on outer IP frames]:filter:' \
  '(-G --inner-filter)'{-G,--inner-filter}'+[apply BPF filter on encapsulated GTPu frames]:filter:' \
  '(-C --connection-filter)'{-C,--connection-filter}'+[filter by 4-tuple connection]:conn filter:' \
  '(-S --string-filter)'{-S,--string-filter}'+[search for text within packets]:string:' \
  '(-T --tcp-filter)'{-T,--tcp-filter}'+[filter valid TCP connections]:mode:(syn full3way full3way-data)' \
  '(-t --timing)'{-t,--timing}'[analyze packet timestamps]' \
  '--set-duration=[reset PCAP duration with equal inter-frame gaps]:duration HH\:MM\:SS:' \
  '--set-duration-preserve-ifg=[adjust duration while preserving frame spacing]:duration HH\:MM\:SS:' \
  '--set-timestamps-from=[apply Unix timestamps from text file]:file:_files' \
  '(-p --stats)'{-p,--stats}'[display parsing statistics]' \
  '--report=[generate traffic report]:report name:' \
  '--report-write=[save report to CSV file]:csv file:_files' \
  '*:pcap file:_files' && ret=0

return ret
