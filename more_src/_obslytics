#compdef obslytics
# Export observability series data into popular analytics formats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--help-long[show long help]' \
  '--help-man[show man-page help]' \
  '--version[show application version]' \
  '--log.level=[log filtering level]:level:(error warn info debug)' \
  '--log.format=[log format to use]:format:(logfmt json)' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    if (( CURRENT == 1 )); then
      _values 'obslytics command' \
        'export[export observability series into analytics formats]'
    else
      case $words[1] in
        export)
          _arguments -s -S \
            '--match=[series selector to export]:match' \
            '--min-time=[start of time range to export]:time' \
            '--max-time=[end of time range to export]:time' \
            '--resolution=[resolution of exported data]:resolution' && ret=0
          ;;
      esac
    fi
    ;;
esac

return ret
