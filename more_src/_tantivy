#compdef tantivy
# Documentation: upstream src/main.rs at
# github.com/quickwit-oss/tantivy-cli
# Reference accessed: 2026-05-30 via gh api inspection of every
# clap Command::new(...) + Arg::new(...) declaration in main.rs.
# Tantivy CLI R110 — command-line interface for the tantivy
# full-text search engine (Rust, Quickwit). 7 top-level
# subcommands.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'new:create a new index (interactive schema wizard)'
  'serve:start a search server (default port 3000) with web API'
  'index:index JSON documents (one per line) into an existing index'
  'search:search the index from the command line'
  'inspect:inspect an existing index'
  'bench:run a benchmark on your index against a query file'
  'merge:merge all segments of an index'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'tantivy subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      new)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'=[index directory]:dir:_directories' \
          '--infer-from-ndjson=[infer root-level field types from a ndjson file]:file:_files -g "*.ndjson"' \
          '--sample-size=[JSON documents to sample for inference (default 10000; 0 = no limit)]:N:' \
          && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'=[index directory]:dir:_directories' \
          '--host=[host to listen on (default localhost)]:host:_hosts' \
          '(-p --port)'{-p,--port}'=[port (default 3000)]:port:' \
          && ret=0
        ;;
      index)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'=[index directory]:dir:_directories' \
          '(-f --file)'{-f,--file}'=[file containing documents to index]:file:_files -g "*.(ndjson|json|jsonl)"' \
          '(-t --num_threads)'{-t,--num_threads}'=[indexing threads (default num cores - 1)]:N:' \
          '(-m --memory_size)'{-m,--memory_size}'=[total memory in bytes (default 1000000000)]:bytes:' \
          '--forcemerge[merge all segments at end of indexing]' \
          '--nomerge[do not merge segments]' \
          && ret=0
        ;;
      search)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'=[index directory]:dir:_directories' \
          '(-q --query)'{-q,--query}'=[search query (required)]:query:' \
          '(-a --agg)'{-a,--agg}'=[aggregation request as JSON]:json:' \
          && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'=[index directory]:dir:_directories' \
          && ret=0
        ;;
      bench)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'=[index directory]:dir:_directories' \
          '(-q --queries)'{-q,--queries}'=[file containing queries (one per line) - required]:file:_files' \
          '(-n --num_repeat)'{-n,--num_repeat}'=[number of times to repeat the benchmark (default 1)]:N:' \
          && ret=0
        ;;
      merge)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'=[index directory]:dir:_directories' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
