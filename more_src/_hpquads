#compdef hpquads
# Documentation: http://astrometry.net/doc/build-index.html
# build quads from a star kdtree, one healpix at a time

local ret=1

_arguments -s \
  '-h[show help]' \
  '-i+[input star kdtree (skdt.fits) file]:input:_files' \
  '-c+[codes file (code.fits) output file]:codes:_files' \
  '-q+[quads file (quad.fits) output file]:quads:_files' \
  '-n+[healpix nside]:nside:' \
  '-u+[upper bound of quad scale (arcmin)]:scale:' \
  '-l+[lower bound of quad scale (arcmin)]:scale:' \
  '-d+[number of stars in a quad]:dimquads:' \
  '-p+[number of rounds of quad-building (default 1)]:passes:' \
  '-r+[number of times a star can be used]:reuse times:' \
  '-L+[max reuses, increasing the -r limit each pass]:max reuses:' \
  '-I+[set the unique ID of this index]:unique id:' \
  '-E[scan catalog, checking which healpixes are occupied]' \
  '-v[verbose]' && ret=0

return ret
