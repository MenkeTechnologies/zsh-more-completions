#compdef qutebrowser

# completions for qutebrowser - keyboard-driven web browser

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)'{-V,--version}'[show version and exit]' \
  '(-B --basedir)'{-B,--basedir}'[base directory for data/config/cache]:directory:_directories' \
  '(-C --config-py)'{-C,--config-py}'[path to config.py]:config file:_files -g "*.py"' \
  '--qt-arg[additional Qt argument]:Qt argument' \
  '(-T --target)'{-T,--target}'[how URLs should be opened]:target:(auto tab tab-bg tab-silent tab-bg-silent window private-window)' \
  '--backend[backend to use]:backend:(webengine webkit)' \
  '(-l --loglevel)'{-l,--loglevel}'[log level]:level:(vdebug debug info warning error critical)' \
  '--logfilter[filter for log messages]:filter' \
  '--loglines[number of log lines for crash log]:lines' \
  '(-d --debug-flag)'{-d,--debug-flag}'[set debug flags]:flag' \
  '--json-logging[output log data as JSON]' \
  '--temp-basedir[use a temporary basedir]' \
  '--no-err-windows[suppress error windows]' \
  '(-r --restore)'{-r,--restore}'[restore a named session]:session name' \
  '--override-restore[override the restore session page]' \
  '(-e --enable)'{-e,--enable}'[enable a feature flag]:flag' \
  '*:URL or file:_urls'
