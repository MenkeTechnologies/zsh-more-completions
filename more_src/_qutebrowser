#compdef qutebrowser
# Documentation: https://www.qutebrowser.org/doc/qutebrowser.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for qutebrowser - keyboard-driven web browser

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-B --basedir)'{-B,--basedir}'[set base directory]:base dir:_files -/' \
  '(-C --config-py)'{-C,--config-py}'[specify config.py file]:config file:_files' \
  '(-s --set)'{-s,--set}'[set a temporary setting]:option:: :value' \
  '(-r --restore)'{-r,--restore}'[restore a named session]:session' \
  '(-R --override-restore)'{-R,--override-restore}'[do not restore session on startup]' \
  '--target=[open pages in target]:target:(auto tab tab-bg tab-silent tab-bg-silent window private-window)' \
  '--backend=[set backend]:backend:(webengine webkit)' \
  '--qt-wrapper=[Qt wrapper]:wrapper:(PyQt6 PyQt5)' \
  '--desktop-file-name=[desktop entry base name]:name' \
  '--untrusted-args[treat remaining args as untrusted]' \
  '(-l --loglevel)'{-l,--loglevel}'[set log level]:level:(critical error warning info debug vdebug)' \
  '--logfilter=[restrict log output]:filter' \
  '--loglines=[log lines retained in RAM]:lines' \
  '(-d --debug)'{-d,--debug}'[enable debugging options]' \
  '--json-logging[output log data as JSON]' \
  '--nocolor[disable colored logging]' \
  '--force-color[force colored logging]' \
  '--nowindow[hide main window]' \
  '(-T --temp-basedir)'{-T,--temp-basedir}'[use temporary base directory]' \
  '--no-err-windows[suppress error dialogs]' \
  '*--qt-arg[pass argument to Qt]:Qt argument' \
  '*--qt-flag[pass flag to Qt]:Qt flag' \
  '*'{-D,--debug-flag}'[set a debug flag]:flag' \
  '*:URL:_urls'
