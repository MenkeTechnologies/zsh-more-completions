#compdef qutebrowser

# Zsh completion for qutebrowser - keyboard-driven web browser

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-B --basedir)'{-B,--basedir}'[set base directory]:base dir:_files -/' \
  '(-C --config-py)'{-C,--config-py}'[specify config.py file]:config file:_files' \
  '*--qt-arg[pass an argument to Qt]:Qt argument' \
  '(-T --target)'{-T,--target}'[open pages in target]:target:(auto tab tab-bg tab-silent tab-bg-silent window private-window)' \
  '--backend[set backend]:backend:(webengine webkit)' \
  '(-l --loglevel)'{-l,--loglevel}'[set log level]:level:(vdebug debug info warning error critical)' \
  '--logfilter[restrict log output to specified categories]:filter' \
  '--loglines[set number of log lines to keep in RAM]:lines' \
  '*'{-d,--debug-flag}'[set a debug flag]:flag' \
  '--json-logging[output log data as JSON]' \
  '--temp-basedir[use a temporary base directory]' \
  '--no-err-windows[suppress error dialogs]' \
  '(-r --restore)'{-r,--restore}'[restore a named session]:session' \
  '--override-restore[do not restore a session on startup]' \
  '*'{-e,--enable}'[enable a feature flag]:feature' \
  '*:URL:'
