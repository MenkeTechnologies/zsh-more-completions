#compdef n

# Zsh completion for n (Node.js version manager)

_n() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'install:install Node.js version (default command)'
    'run:execute downloaded Node.js with args'
    'which:output path for downloaded Node.js version'
    'exec:execute command with modified PATH'
    'rm:remove some downloaded versions'
    'prune:remove all downloaded versions except the installed version'
    'ls:output downloaded versions'
    'ls-remote:output available remote versions'
    'uninstall:uninstall the installed Node.js'
  )

  _arguments -s -S \
    '(-V --version)'{-V,--version}'[output version of n]' \
    '(-h --help)'{-h,--help}'[display help]' \
    '(-p --preserve)'{-p,--preserve}'[preserve npm and npx during install]' \
    '--no-preserve[do not preserve npm and npx during install]' \
    '(-q --quiet)'{-q,--quiet}'[disable curl output]' \
    '(-d --download)'{-d,--download}'[download only, do not install]' \
    '(-a --arch)'{-a,--arch}'[override system architecture]:architecture:(x64 x86 arm64 armv7l)' \
    '--insecure[turn off certificate checking for https requests]' \
    '1:command or version:->cmd_or_version' \
    '*:: :->args' \
    && ret=0

  case $state in
    (cmd_or_version)
      _alternative \
        'commands:command:_describe -t commands command commands' \
        'versions:version:(lts latest stable auto)' \
        && ret=0
      ;;
    (args)
      case ${words[1]} in
        run|exec)
          _arguments -s -S \
            '1:version:(lts latest stable auto)' \
            '*:args:' \
            && ret=0
          ;;
        which)
          _arguments -s -S \
            '1:version:(lts latest stable auto)' \
            && ret=0
          ;;
        rm)
          _arguments -s -S \
            '*:version:' \
            && ret=0
          ;;
        ls-remote)
          _arguments -s -S \
            '1:version filter:' \
            && ret=0
          ;;
        install)
          _arguments -s -S \
            '1:version:(lts latest stable auto)' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_n "$@"
