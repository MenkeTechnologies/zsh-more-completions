#compdef designer designer6
# _designer — Qt Designer (RAD UI editor for Qt Widgets .ui XML files; --server starts external editor mode, --client connects to server, --resourcedir picks resource search path, --enableinternaldynamicproperties exposes hidden props)
# upstream: https://github.com/qt/qttools (src/designer)
# Flags from qttools src/designer/src/designer on tip.

_designer() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--server[start in server mode]' \
        '--client+[server port]:port:' \
        '--resourcedir+[resource search dir]:dir:_files -/' \
        '--enableinternaldynamicproperties[show internal dyn properties]' \
        '*:ui file:_files -g "*.ui"'
}

_designer "$@"
