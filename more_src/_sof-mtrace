#compdef sof-mtrace mtrace-reader
# _sof-mtrace — read SOF DSP memory-trace via debugfs (thesofproject/sof)
# upstream: https://github.com/thesofproject/sof
# Flags from tools/mtrace/mtrace-reader.py (argparse).

_sof-mtrace() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-m --mark-chunks)'{-m,--mark-chunks}'[mark chunk boundaries in the output]'
}

_sof-mtrace "$@"
