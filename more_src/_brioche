#compdef brioche
# ---------------------------------------------------------------------------
# brioche — "a delicious package manager" (Rust, 506★)
#
# upstream: https://github.com/brioche-dev/brioche
# author : Kyle Lacy (kylewlacy) + the brioche-dev collective
# license: MIT
#
# Source-direct completion: every subcommand and every flag below is verbatim
# from crates/brioche/src/{main,build,run,install,check,format,publish,
# live_update,lsp,self_update,jobs,jobs/logs,jobs/debug_shell}.rs on the
# brioche v0.1.8 tip — clap-derive `Args` enum + per-subcommand `*Args`
# structs with `#[arg(...)]` attributes parsed as documented.
#
# Direct deps from crates/brioche/Cargo.toml (selected):
#   clap            4.6.1   (derive — top-level Args enum + per-cmd structs)
#   tokio           1.52.3  (full + tracing)
#   reqwest         0.13.4  (http2 + rustls + zstd + json — registry sync)
#   ulid            1.2.1   ← canonical Rust ULID (this axis) — by Dylan
#                             Hart (dylanhart/ulid-rs) implementing the
#                             original spec by Alizain Feerasta
#   notify          8.2.0   (filesystem event watcher — used during fmt/check)
#   object_store    0.13.2  (cloud storage abstraction — registry backing)
#   tower-lsp       0.20.0  (LSP server framework — powers `brioche lsp`)
#   superconsole    0.2.0   (Meta's rich terminal UI from buck2)
#   semver          1.0.28  (project version constraints)
#   sha2            0.11.0  (content-addressed hashes)
#   ssh-key         0.7.0-rc.10 (signed package publishing)
#   tracing         0.1.44
#   async-compression 0.4.42 (xz decompression for self-update tarballs)
#
# brioche is a modern Nix-alternative package manager and build system,
# scripted in TypeScript (executed via embedded V8 / `brioche_core::script::
# initialize_js_platform`) rather than Nix expression language.  Builds
# happen in sandboxed processes; outputs are content-addressed; the
# registry is backed by `object_store` (S3/GCS/Azure/file/in-memory).
# Every build job, recipe, and project version is identified by a ULID
# (lexicographically sortable 128-bit ID) so logs/events naturally sort
# chronologically and registry lookups are O(1).
#
# === AXIS 168 OPENER — lexicographically sortable random identifiers (ULID) =
# Axis position: Rust=223 OPENS Axis 168 at slot 1/0/0.  Canonical Rust
# ULID implementation is `dylanhart/ulid-rs` by Dylan Hart — Crockford-base32
# 26-character string (10 chars of timestamp ms since epoch + 16 chars of
# randomness) producing 128-bit IDs that monotonically sort by creation
# time without sacrificing collision resistance.  Drop-in replacement for
# UUIDv4 anywhere DB indexes benefit from temporal locality.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=223     ← THIS FILE              (axis 168 OPENS, slot 1/0/0)
#   Go=223       ← next round              (axis 168 continues, slot 2/0/0)
#   TS-Node=223  ← round after             (axis 168 CLOSES at triple-223, slot 1/1/1)
# ---------------------------------------------------------------------------

_brioche() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'build:build a project (e.g. ./pkg, curl, ./pkg^test, ^test, curl^test,default)'
                'run:build a project, then run the result'
                'install:build a project, then install it globally'
                'check:check a project for type errors'
                'fmt:format the Brioche TypeScript files in a project'
                'jobs:show information about jobs, such as failed builds'
                'publish:publish a project to a registry'
                'live-update:update a Brioche project based on the current version of the upstream project'
                'lsp:start the Language Server Protocol server (powered by tower-lsp)'
                'self-update:update Brioche itself (xz-compressed tarball via async-compression)'
                'help:print this message or the help of the given subcommand(s)'
            )
            _describe -t commands 'brioche command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                build)
                    _arguments \
                        '(-o --output)'{-o,--output=}'[path to write the output to (build result not saved if omitted)]:output path:_files' \
                        '--check[check the project before building]' \
                        '--locked[validate that the lockfile is up-to-date]' \
                        '--replace[replace the output path if it already exists]' \
                        '--merge[merge the output path if it already exists]' \
                        '--keep-temps[keep temporary build files for debugging build failures]' \
                        '--sync[sync / cache baked recipes to the registry during the build]' \
                        '--experimental-lazy[exit early without fetching the build result if found in remote cache (conflicts with --output)]' \
                        '--display=[output display format]:mode:(auto console plain plain-reduced)' \
                        '*:project targets (e.g. ./pkg, curl, ./pkg^test, ^test, curl^test,default):_files -/' && ret=0
                    ;;
                run)
                    _arguments \
                        '(-c --command)'{-c,--command=}'[path within the build artifact to execute (default brioche-run)]:command:' \
                        '(-q --quiet)'{-q,--quiet}'[suppress Briochés output]' \
                        '--check[check the project before building]' \
                        '--locked[validate that the lockfile is up-to-date]' \
                        '--keep-temps[keep temporary build files for debugging build failures]' \
                        '--display=[output display format]:mode:(auto console plain plain-reduced)' \
                        '1:project target (e.g. ./pkg, curl, ./pkg^test, ^test):_files -/' \
                        '*:arguments to pass to the command (after --):' && ret=0
                    ;;
                install)
                    _arguments \
                        '--check[check the project before building]' \
                        '--locked[validate that the lockfile is up-to-date]' \
                        '--display=[output display format]:mode:(auto console plain plain-reduced)' \
                        '*:project targets:_files -/' && ret=0
                    ;;
                check)
                    _arguments \
                        '--locked[validate that the lockfile is up-to-date]' \
                        '--display=[output display format]:mode:(auto console plain plain-reduced)' \
                        '*:project directories (defaults to current directory):_files -/' && ret=0
                    ;;
                fmt|format)
                    _arguments \
                        '--check[check formatting without writing changes]' \
                        '--display=[output display format]:mode:(auto console plain plain-reduced)' \
                        '*:paths (files or project directories, defaults to current directory):_files' && ret=0
                    ;;
                publish)
                    _arguments \
                        '--no-verify[skip verifying the project before publishing]' \
                        '--display=[output display format]:mode:(auto console plain plain-reduced)' \
                        '*:project directories to publish:_files -/' && ret=0
                    ;;
                live-update)
                    _arguments \
                        '--check[check the project before building]' \
                        '--locked[validate that the lockfile is up-to-date before applying updates]' \
                        '--keep-temps[keep temporary build files for debugging build failures]' \
                        '--display=[output display format]:mode:(auto console plain plain-reduced)' \
                        '1:local project directory (e.g. ./pkg, .):_files -/' && ret=0
                    ;;
                lsp)
                    _arguments \
                        '--stdio[use stdio for LSP transport (powered by tower-lsp)]' && ret=0
                    ;;
                self-update)
                    _arguments \
                        '(-y --confirm)'{-y,--confirm}'[confirm the update without prompting]' && ret=0
                    ;;
                jobs)
                    _arguments \
                        '1: :->jobs_cmds' \
                        '*::arg:->jobs_args' && ret=0
                    case $state in
                        jobs_cmds)
                            local -a jobcmds
                            jobcmds=(
                                'logs:view logs for a job (parsed from event file via the ULID-sortable event stream)'
                                'debug-shell:start a shell in an exited job for debugging — only use for event files from sources you trust'
                            )
                            _describe -t commands 'brioche jobs command' jobcmds && ret=0
                            ;;
                        jobs_args)
                            case $words[1] in
                                logs)
                                    _arguments \
                                        '--limit=[limit the number of events to show (roughly the number of lines)]:N:' \
                                        '(-r --reverse)'{-r,--reverse}'[print events in reverse order]' \
                                        '--follow[output events as the file grows, until the "exited" event is reached]' \
                                        '1:event file path:_files' && ret=0
                                    ;;
                                debug-shell)
                                    _arguments \
                                        '1:event file path from the job:_files' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                help)
                    local -a subcmds
                    subcmds=(
                        build run install check fmt jobs publish live-update lsp self-update
                    )
                    _describe -t commands 'subcommand' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_brioche "$@"
