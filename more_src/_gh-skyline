#compdef gh-skyline gh-sub-issue gh-not gh-tidy
# Documentation: upstream READMEs at github.com/{github/gh-skyline,yahsan2/gh-sub-issue,nobe4/gh-not,HaywardMorihara/gh-tidy}
# Reference accessed: 2026-05-30
# gh-extension family round 1. Companion to the pre-existing more_src/_gh-poi
# / _gh-notify / _gh-dash / etc. gh extensions are real binaries that get
# invoked either as `gh <name>` or directly as `gh-<name>`.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-skyline)
    # github/gh-skyline — generate 3D-printable STL of contribution graph.
    _arguments -s -S \
      '(-h --help)-h[show help]' \
      '(-h --help)--help[show help]' \
      '(-d --debug)-d[enable debug logging]' \
      '(-d --debug)--debug[enable debug logging]' \
      '(-f --full)-f[generate from join year to current year]' \
      '(-f --full)--full[generate from join year to current year]' \
      '(-o --output)-o+[output filename (default {user}-{year}-github-skyline.stl)]:file:_files' \
      '(-o --output)--output=[output filename]:file:_files' \
      '(-u --user)-u+[GitHub username (default authenticated user)]:user:' \
      '(-u --user)--user=[GitHub username]:user:' \
      '(-y --year)-y+[year or year range (2008 - current)]:year:' \
      '(-y --year)--year=[year or year range (2008 - current)]:year:' \
      '(-w --web)-w[open the GitHub profile in the browser]' \
      '(-w --web)--web[open the GitHub profile in the browser]' \
      '(-a --art-only)-a[show ASCII art preview only, do not generate STL]' \
      '(-a --art-only)--art-only[show ASCII art preview only, do not generate STL]' \
      && ret=0
    ;;

  gh-sub-issue)
    # yahsan2/gh-sub-issue — manage parent ↔ sub-issue relationships.
    local -a _subcmds
    _subcmds=(
      'add:link an existing issue to a parent issue'
      'create:generate a new issue directly linked to a parent'
      'list:display all sub-issues connected to a parent'
      'remove:unlink sub-issues from their parent (no deletion)'
    )
    _arguments -C -s -S \
      '(- *)-h[show help]' \
      '(- *)--help[show help]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-sub-issue subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          add)
            _arguments \
              '(-R --repo)-R+[OWNER/REPO]:repo:' \
              '(-R --repo)--repo=[OWNER/REPO]:repo:' \
              '*:issue number or URL:' && ret=0
            ;;
          create)
            _arguments \
              '(-p --parent)-p+[parent issue (required)]:parent:' \
              '(-p --parent)--parent=[parent issue (required)]:parent:' \
              '(-t --title)-t+[issue title (required)]:title:' \
              '(-t --title)--title=[issue title (required)]:title:' \
              '(-b --body)-b+[issue body]:body:' \
              '(-b --body)--body=[issue body]:body:' \
              '*-l+[label]:label:' \
              '*--label=[label]:label:' \
              '*-a+[assignee]:assignee:' \
              '*--assignee=[assignee]:assignee:' \
              '(-m --milestone)-m+[milestone]:milestone:' \
              '(-m --milestone)--milestone=[milestone]:milestone:' \
              '--project=[project]:project:' \
              '(-R --repo)-R+[OWNER/REPO]:repo:' \
              '(-R --repo)--repo=[OWNER/REPO]:repo:' && ret=0
            ;;
          list)
            _arguments \
              '(-s --state)-s+[filter by state]:state:(open closed all)' \
              '(-s --state)--state=[filter by state]:state:(open closed all)' \
              '(-L --limit)-L+[result limit]:N:' \
              '(-L --limit)--limit=[result limit]:N:' \
              '--json=[output JSON fields]:fields:' \
              '(-w --web)-w[open in browser]' \
              '(-w --web)--web[open in browser]' \
              '(-R --repo)-R+[OWNER/REPO]:repo:' \
              '(-R --repo)--repo=[OWNER/REPO]:repo:' \
              '*:parent issue:' && ret=0
            ;;
          remove)
            _arguments \
              '(-f --force)-f[skip confirmation]' \
              '(-f --force)--force[skip confirmation]' \
              '(-R --repo)-R+[OWNER/REPO]:repo:' \
              '(-R --repo)--repo=[OWNER/REPO]:repo:' \
              '*:sub-issue:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-not)
    # nobe4/gh-not — rule-based GitHub notification manager.
    # Operates via YAML config + jq-syntax rules. Minimal CLI surface;
    # most behavior is config-file driven. Per upstream the project is
    # "mostly done" — no new features being added.
    _arguments -s -S \
      '(- *)-h[show help]' \
      '(- *)--help[show help]' \
      '--config=[YAML configuration file]:file:_files -g "*.(yml|yaml)"' \
      && ret=0
    ;;

  gh-tidy)
    # HaywardMorihara/gh-tidy — checkout main, gc, prune merged branches.
    _arguments -s -S \
      '--auto-delete-merged[non-interactive: auto-delete merged branches]' \
      '--trunk=[trunk branch name (default main/master)]:branch:__git_branch_names' \
      && ret=0
    ;;

esac

return ret
