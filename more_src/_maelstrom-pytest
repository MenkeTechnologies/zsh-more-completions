#compdef maelstrom-pytest
# Documentation: source-direct extraction from upstream
# maelstrom-software/maelstrom —
#   crates/maelstrom-pytest/src/config.rs lines 4-56
#     (Config struct flattening TestRunnerConfig + adding
#     PytestConfig with 4 extra pytest-specific flags)
# Reference accessed: 2026-05-30 via gh api.
#
# maelstrom-pytest is the **distributed-execution Python
# pytest runner** from maelstrom-software — sister to R238's
# cargo-maelstrom (Rust) and R239's maelstrom-go-test (Go).
# Runs pytest workloads across a fleet of broker + worker
# machines.  Inherits all 22 test-runner flags from R238 via
# the flattened `TestRunnerConfig` parent (at config.rs:6-7)
# and ADDS 4 pytest-specific flags at config.rs:14-42.
#
# Critical extraction note: maelstrom-pytest demonstrates
# the **`#[config(flatten)]` composition pattern** — Config
# at config.rs:5-11 flattens TWO sub-Configs:
#   parent: TestRunnerConfig  (the 22-flag base)
#   pytest: PytestConfig      (4 pytest-specific extras)
# This is the corpus's first documented `#[config(flatten)]`
# usage — the equivalent of clap-derive's `#[command(flatten)]`
# but for the custom #[derive(Config)] macro documented in
# R238.  All 4 binaries in the maelstrom family use this
# pattern to inherit the common ClientConfig + (where
# applicable) TestRunnerConfig.
#
# Critical extraction note: the 4 pytest-specific flags at
# lines 17-42 use 3 distinct config attribute patterns:
#   `option`     — Optional<T> field (--collect-from-module)
#   `list`       — Vec<String> with comma-separated parsing
#                  (--extra-pytest-args, --extra-pytest-
#                   collect-args)
#   `var_arg`    — Vec<String> as a TRAILING positional
#                  variadic (--extra-pytest-test-args at line
#                  37 — collects all remaining argv after the
#                  flag).  Corpus's first documented
#                  `var_arg` config attribute.
#
# Critical extraction note: ALL 22 R238 test-runner flags +
# 5 hidden flags apply here.  Completion lists them
# unconditionally since the installed binary's build features
# are opaque.  See R238 _cargo-maelstrom for the canonical
# documentation of the inherited flag set.

local -a log_levels=(error warn info debug trace)
local -a ui_styles=(auto simple quiet fancy)
local -a comm_strategies=(tcp github)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-L --log-level)'{-L+,--log-level=}'[(inherited from TestRunnerConfig) min log level]:level:(error warn info debug trace)' \
  '--ui=[(inherited) UI style]:style:(auto simple quiet fancy)' \
  '(-r --repeat --loop)'{-r+,--repeat=,--loop=}'[(inherited) repeat each test N times]:count:' \
  '(-s --stop-after)'{-s+,--stop-after=}'[(inherited) stop after N failures]:num:' \
  '(-t --timeout)'{-t+,--timeout=}'[(inherited) override timeout in seconds]:seconds:' \
  '(-b --broker)'{-b+,--broker=}'[(inherited from ClientConfig) broker socket addr (standalone if absent)]:sockaddr:' \
  '--cluster-communication-strategy=[(HIDDEN; inherited) tcp or github]:strategy:(tcp github)' \
  '--github-actions-token=[(HIDDEN; inherited) ACTIONS_RUNTIME_TOKEN]:token:' \
  '--github-actions-url=[(HIDDEN; inherited) ACTIONS_RESULTS_URL]:url:_urls' \
  '--cache-size=[(inherited) local worker cache size (SI/binary suffixes)]:bytes:' \
  '--inline-limit=[(inherited) max bytes returned inline for stdout/stderr]:bytes:' \
  '--slots=[(inherited) number of job slots]:n:' \
  '--container-image-depot-root=[(inherited) container image cache directory]:path:_files -/' \
  '--accept-invalid-remote-container-tls-certs[(inherited) accept invalid TLS for container images]' \
  \*{-i+,--include=}'[(inherited) include filter (repeatable; default "all")]:filter:' \
  \*{-x+,--exclude=}'[(inherited) exclude filter (repeatable)]:filter:' \
  '--init[(inherited) write starter test metadata file then exit]' \
  '(-w --watch)'{-w,--watch}'[(inherited) watch mode]' \
  '--client-process[(HIDDEN; inherited) internal testing flag]' \
  '--collect-from-module=[pytest --pyargs MODULE for collection (default: pytests default)]:module:' \
  \*'--extra-pytest-args=[extra args passed to pytest for BOTH collection AND running]:args:' \
  \*'--extra-pytest-collect-args=[extra args passed to pytest ONLY during collection]:args:' \
  '*::extra-pytest-test-args (var_arg; all remaining argv passed to pytest at run-time):'
