#compdef vtysh

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-b[boot startup configuration]' \
  '--boot[boot startup configuration]' \
  '-c+[execute command and exit]:command:' \
  '--command=[execute command and exit]:command:' \
  '-d+[connect to specified daemon]:daemon:(zebra ripd ripngd ospfd ospf6d bgpd isisd pimd ldpd nhrpd eigrpd babeld sharpd staticd pbrd bfdd fabricd vrrpd pathd)' \
  '--daemon=[connect to specified daemon]:daemon:(zebra ripd ripngd ospfd ospf6d bgpd isisd pimd ldpd nhrpd eigrpd babeld sharpd staticd pbrd bfdd fabricd vrrpd pathd)' \
  '-E[echo commands]' \
  '--echo[echo commands]' \
  '-C[check configuration and exit]' \
  '--dryrun[check configuration and exit]' \
  '-f+[configuration file]:config file:_files' \
  '--config_file=[configuration file]:config file:_files' \
  '-m[mark/unmark FRR configuration]' \
  '--markfile[mark/unmark FRR configuration]' \
  '-N+[namespace/VRF]:namespace:' \
  '--pathspace=[namespace/VRF]:namespace:' \
  '-u+[user to run as]:user:_users' \
  '--user=[user to run as]:user:_users' \
  '-w[write integrated configuration]' \
  '--writeconfig[write integrated configuration]' && ret=0

return ret
