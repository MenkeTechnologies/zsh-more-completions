#compdef freerouting
# freerouting - advanced PCB auto-router (Specctra DSN/SES board routing)
# Source: https://github.com/freerouting/freerouting/blob/master/docs/command_line_arguments.md
# Reference accessed: 2026-06-21

local ret=1

_arguments -s \
  '-help[display help and exit]' \
  '-de+[load design input file (.dsn[+.ses][+.rules])]:design file:_files -g "*.(dsn|ses|rules)"' \
  '-do+[save routing output file (.dsn/.ses/.scr)]:output file:_files' \
  '-di+[default folder for design open dialogs]:dir:_directories' \
  '-dr+[read design rules from a .rules file]:rules file:_files -g "*.rules"' \
  '-drc+[write design-rule-check report (KiCad JSON)]:drc file:_files' \
  '-mp+[max number of auto-router passes]:passes:' \
  '-mt+[thread pool size for route optimization]:threads:' \
  '-oit+[optimizer improvement threshold percent per pass]:percent:' \
  '-inc+[net classes to ignore during autorouting (comma-separated)]:classes:' \
  '-im[save intermediate steps in binary format]' \
  '-us+[board updating strategy]:strategy:(greedy global hybrid)' \
  '-hr+[hybrid ratio for optimization (m:n)]:ratio:' \
  '-is+[item selection strategy]:strategy:(sequential random prioritized)' \
  '-l+[UI language]:lang:(en de zh)' \
  '-host+[host application name and version]:host:' \
  '-dct+[dialog confirmation timeout in seconds]:seconds:' \
  '-da[disable anonymous analytics collection]' \
  '-dl[disable file logging (legacy)]' \
  '-ll+[console logging level (legacy)]:level:' \
  '*:design file:_files -g "*.(dsn|ses|rules)"' && ret=0

return ret
