#compdef w3af-console
# Documentation: https://man.archlinux.org/search?q=w3af-console
# Reference accessed: 2026-05-16

# w3af-console: terminal interface to w3af web application scanner
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-s[script]:file:_files -g "*.w3af"' \
  '--script=[script]:file:_files -g "*.w3af"' \
  '-p[profile name]:profile:' \
  '--profile=[profile name]:profile:' \
  '-n[no update check]' \
  '--no-update[no update check]' \
  '--force-update[force-update plugins]' \
  '--start[start scan automatically]' \
  '*::w3af-console args:_files' && ret=0
return ret
