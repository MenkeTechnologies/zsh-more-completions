#compdef pragha
# Documentation: https://github.com/pragha-music-player/pragha/blob/master/src/pragha-cmdline.c
# pragha - lightweight music player for GNU/Linux

local ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[version]' \
  '(-e --debug)'{-e,--debug=}'[enable debug, levels 1-4]:level:(1 2 3 4)' \
  '(-l --log-file)'{-l,--log-file=}'[redirect console warnings to file]:file:_files' \
  '(-p --play)'{-p,--play}'[play]' \
  '(-s --stop)'{-s,--stop}'[stop]' \
  '(-t --pause)'{-t,--pause}'[play/pause/resume]' \
  '(-r --prev)'{-r,--prev}'[previous track]' \
  '(-n --next)'{-n,--next}'[next track]' \
  '(-f --shuffle)'{-f,--shuffle}'[shuffle]' \
  '(-u --repeat)'{-u,--repeat}'[repeat]' \
  '(-i --inc_vol)'{-i,--inc_vol}'[increase volume by 1]' \
  '(-d --dec_vol)'{-d,--dec_vol}'[decrease volume by 1]' \
  '(-x --toggle_view)'{-x,--toggle_view}'[toggle player visibility]' \
  '(-c --current_state)'{-c,--current_state}'[get current player state]' \
  '(-a --audio_backend)'{-a,--audio_backend=}'[audio backend]:backend:(alsa oss)' \
  '(-g --audio_device)'{-g,--audio_device=}'[audio device]:device' \
  '(-m --audio_mixer)'{-m,--audio_mixer=}'[mixer element]:mixer' \
  '*:file:_files' && ret=0

return ret
