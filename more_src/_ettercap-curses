#compdef ettercap-curses

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --iface)'{-i,--iface}'+[interface]:iface:' \
  '(-I --iflist)'{-I,--iflist}'[list interfaces]' \
  '(-N --silent)'{-N,--silent}'[silent mode]' \
  '(-P --plugin)'{-P,--plugin}'+[plugin]:plugin:' \
  '(-F --filter)'{-F,--filter}'+[filter file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-w --write)'{-w,--write}'+[pcap output]:file:_files' \
  '(-r --read)'{-r,--read}'+[pcap input]:file:_files' \
  '(-m --log-msg)'{-m,--log-msg}'+[log msgs]:file:_files' \
  '(-l --log)'{-l,--log}'+[log file]:file:_files' \
  '(-M --mitm)'{-M,--mitm}'+[mitm method]:method:(arp icmp dhcp port ndp)' \
  '(-T --text)'{-T,--text}'[text mode]' \
  '(-C --curses)'{-C,--curses}'[curses mode]' \
  '(-G --gtk)'{-G,--gtk}'[gtk mode]' \
  '(-D --daemon)'{-D,--daemon}'[daemon mode]' \
  '(-B --bridge)'{-B,--bridge}'+[bridge mode]:iface:' \
  '*:target:' && ret=0

return ret
