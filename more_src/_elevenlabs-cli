#compdef elevenlabs-cli
# Documentation: https://github.com/elevenlabs/cli
# Reference accessed: 2026-05-23
# Verified: elevenlabs CLI docs (see also _elevenlabs).

# Zsh completion for elevenlabs-cli - ElevenLabs voice agent CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:authentication commands'
  'agents:manage voice agents'
  'tools:manage tools'
  'tests:manage tests'
  'components:UI components'
)

_arguments -C \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'elevenlabs command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      auth)
        _arguments '1:subcommand:(login logout whoami residency)' && ret=0
        ;;
      agents)
        _arguments '1:subcommand:(init add push pull list status delete test widget templates branches)' && ret=0
        ;;
      tools)
        _arguments '1:subcommand:(add-webhook add-client push pull delete)' && ret=0
        ;;
      tests)
        _arguments '1:subcommand:(add push pull delete)' && ret=0
        ;;
    esac
    ;;
esac

return ret
