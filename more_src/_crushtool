#compdef crushtool
# Documentation: https://docs.ceph.com/en/latest/man/8/crushtool/
# Ceph CRUSH map manipulation, compile/decompile, build, and test tool.

local ret=1

_arguments -s -S \
  '(-i)-i[input crush map file]:map:_files' \
  '(-o)-o[output file]:outfile:_files' \
  '(-c --compile)'{-c,--compile}'[compile plaintext map to binary]:map.txt:_files' \
  '(-d --decompile)'{-d,--decompile}'[decompile binary map to plaintext]:map:_files' \
  '--build[build a hierarchical map]' \
  '--num_osds=[number of devices]:numosds:' \
  '--test[perform a dry-run CRUSH mapping]' \
  '--show-statistics[display a summary of the distribution]' \
  '--show-mappings[show value to device mappings]' \
  '--show-bad-mappings[show failed mappings]' \
  '--show-utilization[show device utilization]' \
  '--show-utilization-all[show all device utilization including zero-weight]' \
  '--show-choose-tries[show retry attempt counts]' \
  '--show-retry-exhaustion[show retry limit violations]' \
  '--output-csv[output results as CSV files]' \
  '--output-name=[prepend name to CSV file names]:name:' \
  '--num-rep=[number of replicas]:n:' \
  '--min-rep=[minimum replicas]:n:' \
  '--max-rep=[maximum replicas]:n:' \
  '--min-x=[minimum test value]:n:' \
  '--max-x=[maximum test value]:n:' \
  '--simulate[enable random placement simulation]' \
  '--set-choose-total-tries=[set retry tunable]:n:' \
  '*:file:_files' && ret=0

return ret
