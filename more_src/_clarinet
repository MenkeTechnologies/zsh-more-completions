#compdef clarinet

# Zsh completion for clarinet (Clarity smart contract tooling)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '--manifest-path=[Path to Clarinet.toml]:file:_files' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'new:Create a new Clarinet project'
      'contract:Manage contracts in the project'
      'console:Open interactive Clarity REPL'
      'check:Check contracts for syntax errors'
      'test:Run project tests'
      'run:Run a script against simnet'
      'integrate:Start local devnet integration environment'
      'deploy:Deploy contracts to network'
      'devnet:Manage local devnet'
      'chainhook:Manage chainhook predicates'
      'completions:Generate shell completions'
      'lsp:Start Clarity language server'
      'requirements:Manage project requirements'
    )
    _describe -t commands 'clarinet command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      new)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--disable-telemetry[Disable telemetry]' \
          '1:project-name' && ret=0
        ;;
      contract)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:subcommand:(new rm)' \
          '2:contract-name' && ret=0
        ;;
      check)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--deployment-plan-path=[Path to deployment plan]:file:_files' \
          '*:contract-name' && ret=0
        ;;
      test)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--coverage[Generate code coverage report]' \
          '--costs[Generate cost report]' \
          '--watch[Watch for file changes]' \
          '--filter=[Filter tests by name]:pattern' \
          '--import-map=[Import map file]:file:_files' \
          '*:files:_files' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--devnet[Deploy to local devnet]' \
          '--testnet[Deploy to testnet]' \
          '--mainnet[Deploy to mainnet]' \
          '--no-dashboard[Disable deployment dashboard]' && ret=0
        ;;
      integrate)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--no-dashboard[Disable dashboard]' \
          '--deployment-plan-path=[Path to deployment plan]:file:_files' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:shell:(bash zsh fish elvish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
