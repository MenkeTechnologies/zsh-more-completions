#compdef snyk-ls
# Documentation: https://github.com/snyk/snyk-ls
# snyk-ls - Snyk Language Server

local ret=1

_arguments -s -S \
  '-c[specify a config file to load before all others]:file:_files' \
  '-f[specify a log file instead of logging to the console]:file:_files' \
  '-l[set logging verbosity level]:level:(trace debug info warn error fatal)' \
  '-o[output format for issue presentation]:format:(md html)' \
  '-licenses[display the licenses used by Language Server]' \
  '-v[print the version of the Language Server]' && ret=0

return ret
