#compdef wasm3
# Documentation: https://man.archlinux.org/search?q=wasm3
# Reference accessed: 2026-05-16

# Zsh completion for wasm3 WebAssembly interpreter

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--func[exported function to invoke]:name' \
  '*:wasm module:_files -g "*.wasm"' && ret=0

return ret
