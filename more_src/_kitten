#compdef kitten

# Zsh completion for kitty's kitten utility

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'icat:display images in the terminal'
      'diff:diff files with syntax highlighting'
      'clipboard:copy/paste with the system clipboard'
      'unicode-input:input Unicode characters'
      'themes:change kitty color themes'
      'ssh:SSH with kitty terminal features'
      'transfer:transfer files over SSH'
      'hyperlinked-grep:grep with clickable hyperlinks'
      'show-key:show key press information'
      'resize-window:resize OS windows'
      'broadcast:broadcast input to kitty windows'
      'panel:draw a desktop panel'
      'query-terminal:query terminal properties'
      'at:control kitty remotely'
    )
    _describe -t commands 'kitten command' commands && ret=0
    ;;
  args)
    case $line[1] in
      icat)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--align=[image alignment]:alignment:(left center right)' \
          '--place=[image placement geometry]:geometry' \
          '--scale-up[scale up images smaller than the window]' \
          '--background=[background color]:color' \
          '--mirror=[mirror the image]:mode:(none horizontal vertical both)' \
          '--clear[clear all images on screen]' \
          '--transfer-mode=[mode for transferring data]:mode:(detect file stream)' \
          '--detect-support[detect terminal support and exit]' \
          '--print-window-size[print window size and exit]' \
          '--stdin=[read image from stdin]:mode:(detect yes no)' \
          '--z-index=[z-index for image placement]:z-index' \
          '--hold[wait for key press before exiting]' \
          '*:image file:_files -g "*(#i).(png|jpg|jpeg|gif|bmp|svg|webp|tiff|ico)"' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--context=[number of context lines]:lines' \
          '--syntax-highlight[force syntax highlighting]' \
          '1:file:_files' \
          '2:file:_files' && ret=0
        ;;
      clipboard)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--get-clipboard[get clipboard contents]' \
          '--mime=[MIME type]:type' \
          '--use-primary[use primary selection]' \
          '*:file:_files' && ret=0
        ;;
      themes)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--reload-in=[reload config in kitty]:mode:(parent all none)' \
          '--dump-theme[dump theme to stdout]' \
          '*:theme name' && ret=0
        ;;
      ssh)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:ssh arguments' && ret=0
        ;;
      transfer)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--direction=[transfer direction]:direction:(send receive)' \
          '*:file:_files' && ret=0
        ;;
      hyperlinked-grep)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:grep arguments' && ret=0
        ;;
      show-key)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
