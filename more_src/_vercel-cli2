#compdef vercel-cli2 vc2
# _vercel-cli2 — Vercel vercel-cli2 CLI command-line frontend wrapping the Vercel CLI tool for the Vercel platform a serverless frontend cloud focused on Next.js and other modern frameworks open-source written in TypeScript Node deploy alias domains env init link unlink logs project secrets switch teams whoami login logout dev pull build certs dns rollback redeploy bisect git-integration secrets-cli inspect (Vercel team Guillermo Rauch, TypeScript); commander
# upstream: https://vercel.com/

_vercel-cli2() {
    local -a sub=(
        'alias:alias operations'
        'bisect:bisect deployments'
        'build:build project'
        'certs:certificate operations'
        'cli:meta CLI commands'
        'completion:generate shell completion'
        'deploy:deploy a project'
        'dev:run local dev server'
        'dns:DNS operations'
        'domains:domain operations'
        'env:env variable operations'
        'feature:feature flags'
        'flags:feature flag operations'
        'git:git integration'
        'help:show help'
        'init:initialize project'
        'inspect:inspect a deployment'
        'install:install integration'
        'link:link to a project'
        'list:list deployments'
        'login:authenticate'
        'logout:revoke session'
        'logs:show deployment logs'
        'project:project operations'
        'promote:promote deployment'
        'pull:pull env vars and project info'
        'redeploy:redeploy a deployment'
        'remove:remove a deployment'
        'rollback:rollback to a deployment'
        'secrets:secret operations'
        'switch:switch team'
        'teams:team operations'
        'telemetry:telemetry config'
        'whoami:show identity'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-Q+[global config]:_files' \
        '--global-config=+[dir]:dir:_files -/' \
        '-q+[local config]:_files' \
        '--local-config=+[file]:file:_files' \
        '-A+[token]:str:' \
        '--token=+[token]:str:' \
        '-t+[token]:str:' \
        '-S+[scope/team]:str:' \
        '--scope=+[name]:str:' \
        '--team=+[name]:str:' \
        '-c+[cwd]:dir:_files -/' \
        '--cwd=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '-y[yes]' \
        '--yes[yes]' \
        '-f[force]' \
        '--force[force]' \
        '--prod[production]' \
        '--preview[preview]' \
        '-p+[prebuilt]' \
        '--prebuilt[prebuilt]' \
        '--archive=+[fmt]:str:' \
        '-n+[name]:str:' \
        '--name=+[name]:str:' \
        '--build-env=+[k=v]:str:' \
        '*--build-env=+[k=v]:str:' \
        '-b+[build env]:str:' \
        '--env=+[k=v]:str:' \
        '*--env=+[k=v]:str:' \
        '-e+[env]:str:' \
        '--regions=+[regions]:str:' \
        '--public[public deployment]' \
        '--archive-mtime[archive mtime]' \
        '--git-message=+[text]:str:' \
        '--skip-domain[skip domain]' \
        '--no-wait[no wait]' \
        '--no-clipboard[no clipboard]' \
        '--meta=+[k=v]:str:' \
        '*--meta=+[k=v]:str:' \
        '-m+[meta]:str:' \
        '--target=+[t]:t:(production preview)' \
        '--listen=+[host:port]:_hosts' \
        '-l+[listen]:_hosts' \
        '--port=+[port]:n:' \
        '--upgrade[upgrade]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vercel subcommand' sub ;;
        args)
            case $words[1] in
                alias|domains|secrets|env|certs|teams|project|dns) _arguments '1:op:(list ls add remove rm rename inspect import buy transfer-in transfer-out)' '*:name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                pull) _arguments '*:dir:_files -/' ;;
            esac
            ;;
    esac
}

_vercel-cli2 "$@"
