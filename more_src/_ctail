#compdef ctail
# Documentation: https://github.com/brainexe/ctail
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Colorized version of tail (brainexe/ctail).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --lines)'{-n,--lines}'[output last K lines]:lines' \
  '(-p --fullpath)'{-p,--fullpath}'[show full path instead of basename]' \
  '(-q --quiet)'{-q,--quiet}'[suppress headers]' \
  '(-d --date)'{-d,--date}'[prefix lines with current timestamp]' \
  '(-e --exclude)'{-e,--exclude}'[exclude files (glob)]:pattern' \
  '(-v --verbose)'{-v,--verbose}'[verbose debug output]' \
  '--notify[show desktop notifications]' \
  '--style=[color style]:style:(rainbow zebra america random trap)' \
  '--no-color[disable colored output]' \
  '*:files:_files'
