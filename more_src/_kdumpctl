#compdef kdumpctl
# Documentation: https://man.archlinux.org/search?q=kdumpctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start kdump service'
  'stop:stop kdump service'
  'restart:restart kdump service'
  'reload:reload kdump kernel image and initramfs'
  'rebuild:rebuild kdump initramfs'
  'status:show kdump status'
  'propagate:setup ssh key authentication for SSH storage'
  'showmem:print reserved memory size in MB'
  'reset-crashkernel:reset crashkernel to default range'
  'estimate:estimate required memory size'
  'reset-crashkernel-after-update:reset crashkernel after update'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kdumpctl command' commands && ret=0 ;;
esac

return ret
