#compdef kdumpctl
# Documentation: https://www.mankier.com/8/kdumpctl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kdumpctl: control the kdump service. Corrected from prior file:
# removed invented reset-crashkernel-after-update command; added real
# restart, get-default-crashkernel, setup-crypttab, test commands;
# dropped undocumented -h/--help (kdumpctl has no documented options).
local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start the kdump service'
  'stop:stop the kdump service'
  'restart:equal to stop then start'
  'reload:reload the crash kernel image and initramfs without rebuild'
  'rebuild:rebuild the crash kernel initramfs'
  'status:print the current status of the kdump service'
  'propagate:setup ssh key authentication for SSH storage'
  'showmem:print reserved memory size for the crash kernel in MB'
  'estimate:estimate a suitable crashkernel value for this machine'
  'reset-crashkernel:reset crashkernel to the default value'
  'get-default-crashkernel:return the default crashkernel value'
  'setup-crypttab:add link-volume-key option to /etc/crypttab'
  'test:test kdump by triggering a system crash and dump'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kdumpctl command' commands && ret=0 ;;
esac

return ret
