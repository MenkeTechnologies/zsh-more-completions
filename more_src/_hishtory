#compdef hishtory

# Zsh completion for hishtory - your shell history: synced, queryable, and in context

local curcontext="$curcontext" state line ret=1

_hishtory_commands() {
  local -a commands=(
    'install:install hishtory'
    'init:initialize hishtory (with optional secret key)'
    'query:query hishtory'
    'tquery:interactive TUI query'
    'enable:enable hishtory recording'
    'disable:disable hishtory recording'
    'status:show hishtory status'
    'update:update hishtory to latest version'
    'config-get:get a config value'
    'config-set:set a config value'
    'config-add:add an entry to a list config value'
    'config-delete:remove an entry from a list config value'
    'redact:redact entries matching a query'
    'export:export hishtory entries'
    'import:import entries from file'
    'uninstall:uninstall hishtory'
    'reupload:reupload all entries to server'
    'start:start the background daemon'
    'syncStatus:show sync status'
    'version:show version'
    'help:show help'
  )
  _describe -t commands 'hishtory command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :_hishtory_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      config-get|config-set|config-add|config-delete)
        _arguments \
          '1:key:(enable-control-r displayed-columns custom-columns timestamp-format default-filter filter-duplicate-commands enable-presaving highlight-matches beta-mode)' \
          '*:value' && ret=0
        ;;
      query|tquery|redact|export)
        _arguments '*:query' && ret=0
        ;;
      import)
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
