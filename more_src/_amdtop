#compdef amdtop
# Documentation: https://github.com/HUSRCF/amdtop
# Reference accessed: 2026-05-16
# Verified: upstream HUSRCF/amdtop. Interactive TUI - no documented
# CLI flag matrix. F2 setup / F12 save inside the TUI.
# Removed from prior file: fabricated -V/--version (no upstream docs)
# and bogus man.archlinux.org search URL.

# amdtop: top-like AMD GPU monitor (interactive TUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' && ret=0
return ret
