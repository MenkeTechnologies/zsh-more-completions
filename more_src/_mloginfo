#compdef mloginfo
# mtools return information about a MongoDB log file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--verbose[show extra information]' \
  '--debug[show debug information]' \
  '--clients[show client information]' \
  '--connections[show opened/closed connection information]' \
  '--cursors[show cursor reaping information]' \
  '--distinct[group log lines by message type]' \
  '--queries[collect statistics for query patterns]' \
  '--rounding=[adjust rounding for calculated statistics]:digits:(0 1 2 3 4)' \
  '--sort=[sort query statistics results]:field:(namespace pattern count min max mean 95% sum)' \
  '--restarts[find all server restarts]' \
  '--rsstate[show replica set state changes]' \
  '--sharding[show sharding-related information]' \
  '--errors[show error/warning messages (with --sharding)]' \
  '--migrations[show chunk migrations and splits (with --sharding)]' \
  '--storagestats[show storage statistics for slow transactions]' \
  '--transactions[parse transaction information]' \
  '--tsort=[sort transaction results]:field:(duration)' \
  '*:logfile:_files' && ret=0

return ret
