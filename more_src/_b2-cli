#compdef b2-cli b2
# _b2-cli — Backblaze B2 cloud storage CLI alias (Backblaze team, Python); argparse
# upstream: https://github.com/Backblaze/B2_Command_Line_Tool

_b2-cli() {
    local -a sub=(
        'account:account commands'
        'account:authorize:save credentials'
        'account:clear:clear credentials'
        'account:get:get account info'
        'authorize-account:save credentials'
        'cancel-all-unfinished-large-files:cancel all unfinished'
        'cancel-large-file:cancel large file'
        'cat:cat file contents'
        'clear-account:clear credentials'
        'copy-file-by-id:copy file by id'
        'create-bucket:create bucket'
        'create-key:create application key'
        'create-rules:create lifecycle rules'
        'delete-bucket:delete bucket'
        'delete-file-version:delete file version'
        'delete-key:delete key'
        'download-file:download file'
        'download-file-by-id:download file by id'
        'download-file-by-name:download file by name'
        'file:file commands'
        'file:hide:hide file'
        'file:info:get file info'
        'file:large:large file commands'
        'file:large:parts:list parts'
        'file:large:cancel:cancel'
        'file:large:unfinished:list unfinished'
        'file:url:get download URL'
        'get-account-info:get account info'
        'get-bucket:get bucket info'
        'get-download-url-with-auth:get authed URL'
        'get-file-info:get file info'
        'get-url:get download URL'
        'hide-file:hide file'
        'install-autocomplete:install shell completion'
        'key:key commands'
        'key:create:create key'
        'key:delete:delete key'
        'key:list:list keys'
        'license:show license'
        'list-buckets:list buckets'
        'list-keys:list keys'
        'list-parts:list large file parts'
        'list-unfinished-large-files:list unfinished'
        'ls:list files'
        'make-friendly-url:make friendly URL'
        'make-url:make URL'
        'notification-rules:notification rule commands'
        'notification-rules:list:list rules'
        'notification-rules:create:create rule'
        'notification-rules:delete:delete rule'
        'notification-rules:update:update rule'
        'replication:replication commands'
        'replication:setup:setup replication'
        'replication:status:show status'
        'replication:pause:pause replication'
        'replication:unpause:unpause replication'
        'replication:delete:delete replication'
        'rm:remove file'
        'sync:sync directory to/from B2'
        'update-bucket:update bucket'
        'update-file-legal-hold:update legal hold'
        'update-file-retention:update retention'
        'upload-file:upload file'
        'upload-unbound-stream:upload unbound stream'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug-logs[debug logs]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--log-config=+[log config]:file:_files' \
        '--profile=+[profile name]:str:' \
        '--escape-control-characters[escape control characters]' \
        '--no-escape-control-characters[no escape]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'b2 subcommand' sub ;;
        args)
            case $words[1] in
                upload-file) _arguments \
                    '1:bucket:' \
                    '2:local file:_files' \
                    '3:b2 file name:' \
                    '--contentType=+[content type]:str:' \
                    '--noProgress[no progress]' \
                    '--quiet[quiet]' \
                    '--info=+[key=value]:str:' \
                    '-i+[key=value]:str:' \
                    '--threads=+[threads]:n:' \
                    '--sha1=+[sha1 hash]:str:' \
                    '--legalHold=+[hold]:h:(on off)' \
                    '--fileRetentionMode=+[mode]:m:(compliance governance)' \
                    '--retainUntil=+[timestamp]:n:' ;;
                download-file|download-file-by-name|download-file-by-id) _arguments \
                    '1:source:' \
                    '2:local file:_files' \
                    '--noProgress[no progress]' \
                    '--threads=+[threads]:n:' \
                    '--quiet[quiet]' ;;
                sync) _arguments \
                    '1:source:' \
                    '2:destination:' \
                    '--delete[delete files at destination]' \
                    '--dryRun[dry run]' \
                    '--keepDays=+[days]:n:' \
                    '--threads=+[threads]:n:' \
                    '--includeRegex=+[regex]:str:' \
                    '--excludeRegex=+[regex]:str:' \
                    '--excludeDirRegex=+[regex]:str:' \
                    '--noProgress[no progress]' \
                    '--quiet[quiet]' \
                    '--skipNewer[skip newer at destination]' \
                    '--replaceNewer[replace newer at destination]' \
                    '--compareVersions=+[mode]:m:(modTime size none)' ;;
                ls) _arguments \
                    '1:bucket:' \
                    '2:folder:' \
                    '--long[long format]' \
                    '--versions[show versions]' \
                    '--recursive[recursive]' \
                    '--json[json output]' \
                    '--withWildcard[wildcard support]' \
                    '--replication[show replication]' ;;
                ls|rm) _arguments \
                    '1:bucket:' \
                    '2:folder:' ;;
                install-autocomplete) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_b2-cli "$@"
