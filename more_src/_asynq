#compdef asynq

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--uri=[redis server URI]:uri:' \
  '--cluster[connect to Redis cluster]' \
  '--tls-server-name=[TLS server name]:name:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'dash:launch the dashboard'
      'stats:show queue statistics'
      'queue:manage queues'
      'task:manage tasks'
      'server:show server info'
      'group:manage task groups'
      'cron:manage cron entries'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (dash)
        _arguments \
          '--port=[dashboard port]:port:' \
          '--readonly[read-only mode]' && ret=0
        ;;
      (stats)
        _arguments '*:queue name:' && ret=0
        ;;
      (queue)
        _arguments \
          '1:action:(ls inspect rm pause unpause)' \
          '*:queue name:' && ret=0
        ;;
      (task)
        _arguments \
          '1:action:(ls cancel delete run archive kill)' \
          '--queue=[queue name]:queue:' \
          '--state=[task state]:state:(active pending scheduled retry archived completed aggregating)' \
          '--page=[page number]:page:' \
          '--size=[page size]:size:' \
          '--id=[task ID]:id:' && ret=0
        ;;
      (server)
        _arguments '1:action:(ls)' && ret=0
        ;;
      (group)
        _arguments \
          '1:action:(ls inspect)' \
          '--queue=[queue name]:queue:' \
          '*:group name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
