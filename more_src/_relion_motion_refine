#compdef relion_motion_refine
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: Bayesian polishing - per-particle motion correction and recombination

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input STAR file]:file:_files' \
  '--o=[output directory, e.g. MotionFit/job041/]:dir:_files -/' \
  '--first_frame=[first movie frame to process]:value' \
  '--last_frame=[last movie frame to process (default all)]:value' \
  '--verb=[verbosity]:value' \
  '--j=[number of (OMP) threads]:value' \
  '--B_parts=[number of particles for B-factor estimation (negative=all)]:value' \
  '--min_MG=[first micrograph index]:value' \
  '--max_MG=[last micrograph index (default all)]:value' \
  '--corr_mic=[list of uncorrected micrographs]:file:_files' \
  '--mps=[pixel size of input movies (A/pix)]:value' \
  '--cps=[pixel size of particle coordinates (A/pix)]:value' \
  '--hot=[clip hot pixels to this max value (-1=off, TIFF only)]:value' \
  '--mov_toReplace=[replace this string in micrograph names]:string' \
  '--mov_replaceBy=[replace by this string]:string' \
  '--eer_upsampling=[EER upsampling (1=physical, 2=2x super-resolution)]:value' \
  '--eer_grouping=[EER grouping]:value' \
  '*:file:_files' && ret=0

return ret
