#compdef sfk
# Documentation: https://stahlworks.com/dev/swiss-file-knife.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sfk - Swiss File Knife multi-tool

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'sfk command' \
      list filefind copy rename delete deltree touch index \
      zip unzip zipto \
      filter find xfind replace head tail sort snapto \
      detab entab split join encode decode hexdump \
      httpserv ftpserv wget web ping ip \
      echo batch alias help version && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
