#compdef sfk
# Documentation: https://man.archlinux.org/search?q=sfk
# Reference accessed: 2026-05-16

# Zsh completion for sfk — Swiss File Knife multi-tool

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'sfk command' \
      copy move rename delete mkdir md compare join split part toclip fromclip \
      md5 sha1 zip unzip scan find list run exec help version && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
