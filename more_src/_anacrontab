#compdef anacrontab
# Documentation: https://man7.org/linux/man-pages/man5/anacrontab.5.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '*:anacrontab file:_files' && ret=0

return ret
