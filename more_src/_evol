#compdef evol
# Documentation: https://prody.readthedocs.io/en/latest/apps/evol/
# ProDy Evol command line application for sequence evolution analysis

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --cite)'{-c,--cite}'[print citation details and exit]' \
  '(-v --version)'{-v,--version}'[print ProDy version and exit]' \
  '(-e --examples)'{-e,--examples}'[show usage examples]' \
  '1:command:(search fetch filter refine merge occupancy conserv coevol rankorder)' \
  '*::args:->args' && ret=0

return ret
