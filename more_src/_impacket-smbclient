#compdef impacket-smbclient smbclient.py
# _impacket-smbclient — Fortra SecureAuth Impacket impacket-smbclient CLI python interactive SMB CIFS client supporting NTLM Kerberos pass-the-hash pass-the-ticket authentication browsing remote shares uploading downloading deleting files mounting cifs SMB1 SMB2 SMB3 for AD pentest lateral-movement enumeration (Fortra team, Python); argparse
# upstream: https://github.com/fortra/impacket

_impacket-smbclient() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-debug[debug]' \
        '-target-ip+[ip]:_hosts' \
        '-port+[port]:n:(139 445)' \
        '-domain+[domain]:str:' \
        '-user+[user]:str:' \
        '-password+[password]:str:' \
        '-hashes+[lmhash:nthash]:str:' \
        '-no-pass[no password]' \
        '-k[use kerberos]' \
        '-aesKey+[key]:str:' \
        '-dc-ip+[dc ip]:_hosts' \
        '-codec+[codec]:str:' \
        '-file+[script file]:file:_files' \
        '*:target user/domain:'
}

_impacket-smbclient "$@"
