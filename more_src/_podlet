#compdef podlet

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--podman-path=[path to podman binary]:path:_files' \
  '--skip-services-check[skip systemd services check]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'compose:generate quadlet from compose file'
      'generate:generate quadlet from podman arguments'
      'install:install generated quadlet files'
    )
    _describe -t commands 'podlet command' commands && ret=0
    ;;
  args)
    case $line[1] in
      compose)
        _arguments \
          '--file=[compose file path]:file:_files -g "*.{yaml,yml}"' \
          '--pod[generate a pod quadlet]' \
          '--build[support build contexts]' \
          '--unit-dir=[output directory]:dir:_directories' \
          '*:compose file:_files -g "*.{yaml,yml}"' && ret=0
        ;;
      generate)
        _arguments '1:type:(container volume network kube image)' && ret=0
        ;;
      install)
        _arguments \
          '--user[install as user unit]' \
          '--unit-dir=[target directory]:dir:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
