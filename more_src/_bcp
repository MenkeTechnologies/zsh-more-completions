#compdef bcp
# Documentation: https://learn.microsoft.com/en-us/sql/tools/bcp-utility
# bcp - SQL Server bulk copy program utility

local ret=1

_arguments -s \
  '-m[max syntax errors before canceling]:max errors' \
  '-f[format file path]:format file:_files' \
  '-e[error file path]:err file:_files' \
  '-F[first row to copy]:first row' \
  '-L[last row to copy]:last row' \
  '-b[rows per batch]:batch size' \
  '-n[use native data types]' \
  '-c[use character data type]' \
  '-N[native types, Unicode for char data]' \
  '-w[use Unicode characters]' \
  '-V[bulk copy using earlier SQL Server data types]:version:(80 90 100 110 120 130 140 150 160 170)' \
  '-q[set QUOTED_IDENTIFIER ON]' \
  '-C[code page of data]:code page:(ACP OEM RAW)' \
  '-t[field terminator]:field term' \
  '-r[row terminator]:row term' \
  '-i[input response file]:input file:_files' \
  '-o[output file]:output file:_files' \
  '-a[network packet size in bytes]:packet size' \
  '-S[server name (\instance)]:server' \
  '-U[login id]:login' \
  '-P[password]:password' \
  '-T[trusted connection (integrated security)]' \
  '-k[keep null values]' \
  '-E[keep identity values]' \
  '-h[hints (ORDER, ROWS_PER_BATCH, TABLOCK...)]:hint' \
  '-R[use client regional format]' \
  '-K[application intent]:intent:(ReadOnly)' \
  '-d[database name]:database' \
  '-D[interpret -S value as DSN]' \
  '-G[Microsoft Entra authentication]' \
  '-l[login timeout in seconds]:timeout' \
  '-Y[TLS encryption mode]:mode:(s m o)' \
  '-u[trust server certificate]' \
  '-x[generate XML format file]' \
  '-z[enable vector data type (ODBC)]' \
  '-v[report version number]' \
  '*:argument:_files' && ret=0

return ret
