#compdef baml
# Documentation: https://github.com/BoundaryML/baml
# Reference accessed: 2026-05-23
# Verified: baml --help (baml-cli PyPI).

# Zsh completion for baml - BoundaryML BAML project CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--features[enable features]:feature:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'baml command' \
      'init[initialize new BAML project]' \
      'generate[run all generators in baml_src]' \
      'check[check baml_src for errors and warnings]' \
      'serve[start LLM translation server]' \
      'dev[start development server]' \
      'test[run BAML tests]' \
      'lsp[start language server]' \
      'optimize[optimize prompts with GEPA]' \
      'help[print help]' && ret=0
    ;;
  args)
    case $line[1] in
      test|check|generate|serve|dev)
        _arguments '--from[path to baml_src]:directory:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
