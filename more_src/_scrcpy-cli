#compdef scrcpy-cli
# _scrcpy-cli — Genymotion scrcpy display and control Android over USB CLI alias (Genymobile / Romain Vimont, C); custom argparse
# upstream: https://github.com/Genymobile/scrcpy

_scrcpy-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--always-on-top[always on top]' \
        '--audio-codec=+[audio codec]:c:(opus aac flac raw)' \
        '--audio-bit-rate=+[audio bit rate]:str:' \
        '--audio-buffer=+[audio buffer ms]:n:' \
        '--audio-output-buffer=+[audio output buffer ms]:n:' \
        '--audio-source=+[audio source]:s:(output mic playback voice_call voice_recognition voice_communication unprocessed voice_performance)' \
        '--audio-encoder=+[audio encoder]:str:' \
        '--audio-codec-options=+[audio codec options]:str:' \
        '--audio-buffer-target-delay=+[audio buffer target delay]:n:' \
        '--no-audio[no audio]' \
        '--no-audio-playback[no audio playback]' \
        '--no-video[no video]' \
        '--no-control[no control]' \
        '-n[no control]' \
        '--no-display[no display]' \
        '--no-key-repeat[no key repeat]' \
        '--no-mipmaps[no mipmaps]' \
        '--no-mouse-hover[no mouse hover]' \
        '--no-power-on[no power on]' \
        '--no-window[no window]' \
        '--no-clipboard-autosync[no clipboard autosync]' \
        '--no-downsize-on-error[no downsize on error]' \
        '--no-vd-destroy-content[no vd destroy content]' \
        '--no-vd-system-decorations[no vd system decorations]' \
        '--max-fps=+[max fps]:n:' \
        '--max-size=+[max size]:n:' \
        '-m+[max size]:n:' \
        '--bit-rate=+[video bit rate]:str:' \
        '-b+[video bit rate]:str:' \
        '--video-bit-rate=+[video bit rate]:str:' \
        '--video-codec=+[video codec]:c:(h264 h265 av1)' \
        '--video-encoder=+[video encoder]:str:' \
        '--video-codec-options=+[video codec options]:str:' \
        '--display-buffer=+[display buffer ms]:n:' \
        '--display-id=+[display id]:n:' \
        '--display-orientation=+[display orientation]:o:(0 90 180 270 flip0 flip90 flip180 flip270)' \
        '--render-driver=+[render driver]:str:' \
        '--rotation=+[device rotation]:r:(0 1 2 3)' \
        '--orientation=+[orientation]:o:(0 90 180 270 flip0 flip90 flip180 flip270)' \
        '--capture-orientation=+[capture orientation]:o:(0 90 180 270)' \
        '--print-fps[print fps]' \
        '--push-target=+[push target dir]:dir:_files -/' \
        '--require-audio[require audio]' \
        '--record=+[recording output file]:file:_files' \
        '-r+[recording output file]:file:_files' \
        '--record-format=+[record format]:f:(mp4 mkv m4a mka opus aac flac wav)' \
        '--record-orientation=+[record orientation]:o:(0 90 180 270 flip0 flip90 flip180 flip270)' \
        '--show-touches[show touches]' \
        '-t[show touches]' \
        '--shortcut-mod=+[shortcut modifier]:str:' \
        '--stay-awake[stay awake]' \
        '-w[stay awake]' \
        '--start-app=+[start app]:str:' \
        '--time-limit=+[time limit seconds]:n:' \
        '--turn-screen-off[turn screen off]' \
        '-S[turn screen off]' \
        '--tcpip=+[tcpip ip:port]:str:' \
        '--otg[OTG mode]' \
        '--mouse=+[mouse mode]:m:(disabled sdk uhid aoa)' \
        '-M+[mouse mode]:m:(disabled sdk uhid aoa)' \
        '--keyboard=+[keyboard mode]:k:(disabled sdk uhid aoa)' \
        '-K+[keyboard mode]:k:(disabled sdk uhid aoa)' \
        '--gamepad=+[gamepad mode]:g:(disabled sdk uhid aoa)' \
        '-G+[gamepad mode]:g:(disabled sdk uhid aoa)' \
        '--fullscreen[fullscreen]' \
        '-f[fullscreen]' \
        '--port=+[ports range]:str:' \
        '-p+[ports range]:str:' \
        '--tunnel-host=+[tunnel host]:host:_hosts' \
        '--tunnel-port=+[tunnel port]:port:' \
        '--window-borderless[window borderless]' \
        '--window-title=+[window title]:str:' \
        '--window-x=+[window x]:n:' \
        '--window-y=+[window y]:n:' \
        '--window-width=+[window width]:n:' \
        '--window-height=+[window height]:n:' \
        '--codec-options=+[video codec options]:str:' \
        '--encoder=+[video encoder]:str:' \
        '--prefer-text[prefer text input]' \
        '--list-encoders[list encoders]' \
        '--list-displays[list displays]' \
        '--list-cameras[list cameras]' \
        '--list-camera-sizes[list camera sizes]' \
        '--list-apps[list apps]' \
        '--legacy-paste[legacy paste]' \
        '--kill-adb-on-close[kill adb on close]' \
        '--select-tcpip[select tcpip device]' \
        '-e[select tcpip device]' \
        '--select-usb[select usb device]' \
        '-d[select usb device]' \
        '--serial=+[device serial]:str:' \
        '-s+[device serial]:str:' \
        '--verbosity=+[verbosity]:v:(debug info warn error)' \
        '*:arg:'
}

_scrcpy-cli "$@"
