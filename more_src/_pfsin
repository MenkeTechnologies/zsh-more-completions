#compdef pfsin
# Documentation: https://resources.mpi-inf.mpg.de/pfstools/man1/pfsin.1.html
# read an image in several formats and write a pfs stream to standard output

local ret=1

_arguments -s \
  '--frames=[frame range startframe:step:endframe]:range' \
  '--skip-missing[skip up to ten missing frames in a row]' \
  '(-l --linear)'{-l,--linear}'[convert pixel values to linear luminance (XYZ)]' \
  '(-a --absolute)'{-a+,--absolute=}'[convert to absolute linear luminance, map max to given Y]:max_lum' \
  '*:image file:_files' && ret=0

return ret
