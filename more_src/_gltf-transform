#compdef gltf-transform
# Documentation: https://gltf-transform.dev/cli
# Command-line interface for inspecting and optimizing glTF assets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help documentation]' \
  '(-V --version)'{-V,--version}'[display version information]' \
  '(-v --verbose)'{-v,--verbose}'[output debug messages]' \
  '--allow-net[enable network request reads]' \
  '--vertex-layout[set vertex buffer layout]:layout:(interleaved separate)' \
  '--config[install custom commands or extensions]:config:_files' \
  '1:command:(inspect validate copy optimize merge partition dedup prune gzip xmp center instance flatten join draco meshopt quantize dequantize weld unweld tangents unwrap reorder simplify metalrough palette unlit resize etc1s uastc ktxdecompress ktxfix avif webp png jpeg resample sequence sparse)' \
  '*::args:_files' && ret=0

return ret
