#compdef liquidsoap
# Documentation: https://man.archlinux.org/search?q=liquidsoap
# Reference accessed: 2026-05-16

_arguments -s \
  '(-r --request)'{-r,--request}'=[request file]:file:_files' \
  '-h[help on value]:name:' \
  '(-c --check)'{-c,--check}'[check only]' \
  '(-p --parse-only)'{-p,--parse-only}'[parse only]' \
  '--cache-stdlib[generate stdlib cache]' \
  '--cache-only[cache only]' \
  '--no-cache[no cache]' \
  '--no-external-plugins[no external plugins]' \
  '--dump-delay=[delay]:n:' \
  '--describe-sources[describe sources]' \
  '--describe-clocks[describe clocks]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-f --force-start)'{-f,--force-start}'[force start]' \
  '--debug[debug]' \
  '--debug-errors[show stacktrace]' \
  '--debug-subtyping[debug subtyping]' \
  '--debug-lang[debug language]' \
  '--debug-levels[debug typing levels]' \
  '--profile[profile execution]' \
  '--strict[strict mode]' \
  '--raw-errors[raw errors]' \
  '(-t --enable-telnet)'{-t,--enable-telnet}'[enable telnet]' \
  '(-T --disable-telnet)'{-T,--disable-telnet}'[disable telnet]' \
  '(-u --enable-unix-socket)'{-u,--enable-unix-socket}'[enable unix socket]' \
  '(-U --disable-unix-socket)'{-U,--disable-unix-socket}'[disable unix socket]' \
  '--list-plugins[list plugins]' \
  '--list-functions[list functions]' \
  '--list-functions-by-category[functions by category]' \
  '--list-functions-md[markdown docs]' \
  '--list-functions-json[JSON docs]' \
  '--list-extra-functions-md[extra md]' \
  '--list-deprecated-functions-md[deprecated md]' \
  '--list-protocols-md[protocols md]' \
  '--list-settings[list settings]' \
  '--no-stdlib[no stdlib]' \
  '--print-json-term[print as JSON]' \
  '--stdlib=[stdlib path]:dir:_files -/' \
  '--disable-deprecated[no deprecated]' \
  '--no-deprecated[no deprecated]' \
  '--enable-deprecated[load deprecated]' \
  '-i[show inferred types]' \
  '--version[show version]' \
  '--build-config[build config]' \
  '--opam-config[opam config]' \
  '--interactive[REPL]' \
  '--unsafe[unsafe features]' \
  '--safe[disable unsafe]' \
  '--no-fallible-check[ignore fallible]' \
  '*:script or expr:_files'
