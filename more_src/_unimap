#compdef unimap
# Documentation: https://github.com/Edu4rdSHL/unimap
# Scan only once by IP address and reduce scan times with Nmap.

local ret=1

_arguments -s -S \
  '(-t --target)'{-t,--target}'[target host]:host' \
  '(-f --files)'{-f,--files}'[use a list of targets from a file as input]:file:_files' \
  '(-o --output)'{-o,--output}'[write to an output file (unimap-log-date)]' \
  '(-u --unique-output)'{-u,--unique-output}'[write output in CSV format to filename]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[remove informative messages]' \
  '--threads[number of threads for resolution]:threads' \
  '--resolvers[file(s) with DNS IP addresses]:file:_files' \
  '--ports[ports to scan, e.g. "22, 80, 443, 1000-5000"]:ports' \
  '--min-rate[nmap --min-rate value for ports scan]:rate' \
  '--fast-scan[fast port scanning (no version detection)]' \
  '--logs-dir[path to save CSV/Nmap XML files (default logs/)]:dir:_files -/' \
  '(-k --no-keep-nmap-logs)'{-k,--no-keep-nmap-logs}'[keep Nmap XML files in logs/ for every scanned IP]' \
  '(-r --raw-output)'{-r,--raw-output}'[use raw output instead of a table]' \
  '--url-output[use HOST:IP output format]' \
  '--stdin[read from stdin instead of files or arguments]' && ret=0

return ret
