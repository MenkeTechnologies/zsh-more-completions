#compdef Zzz zzz
# Documentation: https://man.archlinux.org/search?q=Zzz
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-n[dry run, do not suspend]'
    '-s[suspend to disk (hibernate)]'
    '-S[suspend to RAM (sleep)]'
    '-z[suspend to RAM (default)]'
    '-Z[hibernate to disk]'
    '-H[hibernate to disk]'
    '-R[hybrid suspend]'
)

_arguments -s -S $arguments
