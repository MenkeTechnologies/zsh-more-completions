#compdef Zzz zzz
# Documentation: https://github.com/jirutka/zzz
# Reference accessed: 2026-05-21
# Verified: upstream docs at zzz.8.adoc.
# Fixes from prior file:
#   - -s/-S now correctly mean ACPI S1 freeze (was wrongly "suspend to disk")
#   - removed duplicate -H entry (was listed twice)
#   - added missing -X (hibernate to disk and shutdown)
#   - added -v, -V, -h
#   - -z is suspend to RAM (default for zzz)
#   - -Z is hibernate to disk and power off (default for ZZZ)
#   - -R is hibernate to disk and reboot

local -a arguments

arguments=(
    '(- *)-h[print help message and exit]'
    '(- *)-V[print program name and version and exit]'
    '-n[dry-run mode; sleep a few seconds instead of an ACPI action]'
    '(-s -S)'{-s,-S}'[enter low-power idle mode (ACPI S1 freeze)]'
    '-z[enter suspend to RAM (ACPI S3 mem); default for zzz]'
    '-Z[enter hibernate to disk (ACPI S4) and power off; default for ZZZ]'
    '-H[enter hibernate to disk and suspend (suspend-hybrid)]'
    '-X[enter hibernate to disk and shutdown]'
    '-R[enter hibernate to disk and reboot]'
    '-v[be verbose]'
)

_arguments -s -S $arguments
