#compdef agrep
# Documentation: https://man.archlinux.org/search?q=agrep
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-c[print only count of matching lines]' \
  '-d[set record delimiter]:delimiter' \
  '-D[set cost of a deletion]:cost' \
  '-e[specify pattern]:pattern' \
  '-i[case insensitive matching]' \
  '-I[set cost of an insertion]:cost' \
  '-k[set maximum number of errors]:errors' \
  '-l[list only filenames of matching files]' \
  '-n[prefix each line with line number]' \
  '-s[suppress error messages]' \
  '-S[set cost of a substitution]:cost' \
  '-v[invert match (select non-matching lines)]' \
  '-w[match only whole words]' \
  '-B[report only the best match]' \
  '-E[set maximum number of errors]:max errors' \
  '--color[use color to highlight matches]::when:(auto always never)' \
  '--count[print only count of matching lines]' \
  '1:pattern' \
  '*:file:_files' && ret=0

return ret
