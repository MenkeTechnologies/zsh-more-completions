#compdef cibadmin

# Pacemaker cibadmin: low-level CIB (Cluster Information Base) admin
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-Q --query)'{-Q,--query}'[query CIB]' \
  '(-E --erase)'{-E,--erase}'[erase the CIB]' \
  '(-B --bump)'{-B,--bump}'[bump epoch counter]' \
  '(-C --create)'{-C,--create}'[create new CIB]' \
  '(-D --delete)'{-D,--delete}'[delete first matching object]' \
  '(-d --delete-all)'{-d,--delete-all}'[delete all matching objects]' \
  '(-M --modify)'{-M,--modify}'[modify CIB]' \
  '(-P --patch)'{-P,--patch}'[apply patch]' \
  '(-R --replace)'{-R,--replace}'[replace CIB section]' \
  '(-U --update)'{-U,--update}'[update CIB section]' \
  '(-u --upgrade)'{-u,--upgrade}'[upgrade CIB to latest schema]' \
  '(-l --md5-sum)'{-l,--md5-sum}'[calculate MD5 sum]' \
  '(-5 --md5-sum-versioned)'{-5,--md5-sum-versioned}'[MD5 with version]' \
  '(-o --scope)'{-o,--scope=}'[CIB section]:section:(configuration nodes resources constraints crm_config rsc_defaults op_defaults status acls fencing-topology tags alerts)' \
  '(-A --xpath)'{-A,--xpath=}'[XPath query]:xpath:' \
  '(-x --xml-file)'{-x,--xml-file=}'[XML file]:file:_files' \
  '(-X --xml-text)'{-X,--xml-text=}'[XML text]:xml:' \
  '(-p --xml-pipe)'{-p,--xml-pipe}'[read XML from stdin]' \
  '(-t --timeout)'{-t,--timeout=}'[timeout (sec)]:sec:' \
  '(-N --node-only)'{-N,--node-only}'[query CIB from local node only]' \
  '(-s --sync-call)'{-s,--sync-call}'[wait until completion]' \
  '(-n --no-children)'{-n,--no-children}'[do not include child elements]' \
  '(-f --force)'{-f,--force}'[force operation]' \
  '*::cibadmin args:_files' && ret=0
return ret
