#compdef cibadmin
# Documentation: https://man.archlinux.org/search?q=cibadmin
# Reference accessed: 2026-05-16

# cibadmin: low-level Pacemaker CIB read/write tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '-Q[query CIB]' \
  '--query[query CIB]' \
  '-E[erase CIB]' \
  '--erase[erase CIB]' \
  '-B[bump epoch]' \
  '--bump[bump epoch]' \
  '-C[create object]' \
  '--create[create object]' \
  '-M[modify object (merge)]' \
  '--modify[modify object (merge)]' \
  '-P[patch CIB with diff]' \
  '--patch[patch CIB with diff]' \
  '-R[replace object]' \
  '--replace[replace object]' \
  '-D[delete object]' \
  '--delete[delete object]' \
  '--delete-all[delete all matching]' \
  '-U[upgrade CIB to latest schema]' \
  '--upgrade[upgrade CIB to latest schema]' \
  '-S[show schema for CIB]' \
  '--show-access=[show access (eff/intersect/diff)]:mode:(eff intersect diff)' \
  '-o[CIB scope (section)]:scope:(configuration nodes resources constraints crm_config rsc_defaults op_defaults status fencing-topology tags alerts)' \
  '--scope=[CIB scope (section)]:scope:(configuration nodes resources constraints crm_config rsc_defaults op_defaults status fencing-topology tags alerts)' \
  '-A[XPath expression]:xpath:' \
  '--xpath=[XPath expression]:xpath:' \
  '--node-path[show node path of matches]' \
  '-X[input XML on command line]:xml:' \
  '--xml-text=[input XML on command line]:xml:' \
  '-x[input XML from file]:file:_files' \
  '--xml-file=[input XML from file]:file:_files' \
  '-p[read XML from stdin]' \
  '--xml-pipe[read XML from stdin]' \
  '-l[local CIB (do not talk to remote)]' \
  '--local[local CIB (do not talk to remote)]' \
  '-N[execute on this node]:node:' \
  '--node=[execute on this node]:node:' \
  '-s[sync the CIB from a peer]' \
  '--sync-call[sync the CIB from a peer]' \
  '-n[do not call the CIB server (test)]' \
  '--no-cib[do not call the CIB server (test)]' \
  '-c[CIB digest verify]' \
  '-t[timeout in seconds]:seconds:' \
  '--timeout=[timeout in seconds]:seconds:' \
  '-f[force operation]' \
  '--force[force operation]' \
  '--output-as=[output format]:fmt:(text xml html)' \
  '*::cibadmin args:_files' && ret=0
return ret
