#compdef cibadmin
# Documentation: https://manpages.debian.org/testing/pacemaker-cli-utils/cibadmin.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cibadmin: low-level Pacemaker CIB read/write tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--help-all[show all options]' \
  '--help-commands[show command options]' \
  '--help-data[show data options]' \
  '--help-additional[show additional options]' \
  '(- *)'{-\$,--version}'[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '-Q[query CIB]' \
  '--query[query CIB]' \
  '-E[erase CIB]' \
  '--erase[erase CIB]' \
  '-B[bump epoch]' \
  '--bump[bump epoch]' \
  '-C[create object]' \
  '--create[create object]' \
  '-M[modify object (merge)]' \
  '--modify[modify object (merge)]' \
  '-P[patch CIB with diff]' \
  '--patch[patch CIB with diff]' \
  '-R[replace object]' \
  '--replace[replace object]' \
  '-D[delete first matching]' \
  '--delete[delete first matching]' \
  '-d[delete all matching]' \
  '--delete-all[delete all matching]' \
  '-u[upgrade CIB to latest schema]' \
  '--upgrade[upgrade CIB to latest schema]' \
  '-a[output empty CIB]:schema:' \
  '--empty=[output empty CIB]:schema:' \
  '-5[calculate CIB digest]' \
  '--md5-sum[calculate CIB digest]' \
  '-6[calculate versioned CIB digest]' \
  '--md5-sum-versioned[calculate versioned CIB digest]' \
  '-S[show access (eff/intersect/diff)]:mode:(eff intersect diff)' \
  '--show-access=[show access (eff/intersect/diff)]:mode:(eff intersect diff)' \
  '-o[CIB scope (section)]:scope:(configuration nodes resources constraints crm_config rsc_defaults op_defaults status fencing-topology tags alerts)' \
  '--scope=[CIB scope (section)]:scope:(configuration nodes resources constraints crm_config rsc_defaults op_defaults status fencing-topology tags alerts)' \
  '-A[XPath expression]:xpath:' \
  '--xpath=[XPath expression]:xpath:' \
  '-e[show node path of matches]' \
  '--node-path[show node path of matches]' \
  '-X[input XML on command line]:xml:' \
  '--xml-text=[input XML on command line]:xml:' \
  '-x[input XML from file]:file:_files' \
  '--xml-file=[input XML from file]:file:_files' \
  '-p[read XML from stdin]' \
  '--xml-pipe[read XML from stdin]' \
  '-N[execute on this node]:node:' \
  '--node=[execute on this node]:node:' \
  '-U[run as specified user]:user:_users' \
  '--user=[run as specified user]:user:_users' \
  '-c[allow create during modify]' \
  '--allow-create[allow create during modify]' \
  '-n[exclude children from query]' \
  '--no-children[exclude children from query]' \
  '--score[treat values as atomic score updates]' \
  '-t[timeout in seconds]:seconds:' \
  '--timeout=[timeout in seconds]:seconds:' \
  '-f[force operation]' \
  '--force[force operation]' \
  '--output-as=[output format]:fmt:(text xml html)' \
  '*::cibadmin args:_files' && ret=0
return ret
