#compdef coroot
# _coroot — Coroot coroot zero-instrumentation observability platform CLI for managing Prometheus-compatible metrics SLO tracing eBPF profiling alerting RCA Kubernetes service-map graph (coroot team, Go); flag
# upstream: https://github.com/coroot/coroot

_coroot() {
    local -a sub=(
        'serve:run the Coroot server'
        'check:run config check'
        'migrate:run database migrations'
        'generate:generate config templates'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--listen=+[addr]:str:' \
        '--url-base-path=+[path]:str:' \
        '--data-dir=+[dir]:dir:_files -/' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.toml *.ini"' \
        '--postgres=+[dsn]:str:' \
        '--clickhouse=+[dsn]:str:' \
        '--prometheus=+[url]:str:' \
        '--bootstrap-prometheus-url=+[url]:str:' \
        '--bootstrap-clickhouse-url=+[url]:str:' \
        '--developer-mode[developer mode]' \
        '--read-only[read-only mode]' \
        '--no-license[no license]' \
        '--admin-password=+[password]:str:' \
        '--admin-user=+[user]:str:' \
        '--auth-anonymous-role=+[role]:r:(admin editor viewer)' \
        '--auth-bootstrap-admin-password=+[password]:str:' \
        '--auth-bootstrap-admin-email=+[email]:str:' \
        '--global-prom-url=+[url]:str:' \
        '--global-prom-refresh-interval=+[d]:str:' \
        '--global-clickhouse-address=+[host:port]:str:' \
        '--global-clickhouse-database=+[name]:str:' \
        '--global-clickhouse-user=+[user]:str:' \
        '--global-clickhouse-password=+[password]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coroot subcommand' sub ;;
        args) ;;
    esac
}

_coroot "$@"
