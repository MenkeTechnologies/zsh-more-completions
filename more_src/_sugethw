#compdef sugethw
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/sugethw.c
# write the values of the selected key words

local ret=1

_arguments -s -S \
  'key=[comma-separated header key words]:key' \
  'output=[output format]:output:(ascii binary geom)' \
  'verbose=[=1 chatty mode]:verbose' \
  '*:file:_files' && ret=0


return ret
