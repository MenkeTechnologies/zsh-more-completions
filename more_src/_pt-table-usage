#compdef pt-table-usage
# Documentation: https://docs.percona.com/percona-toolkit/pt-table-usage.html
# Analyze how queries use tables

local ret=1

_arguments -s -S \
  '(--help)--help[show help and exit]' \
  '(--version)--version[show version and exit]' \
  '--ask-pass[prompt for password when connecting to MySQL]' \
  '--buffer-stdout[enable STDOUT buffering]' \
  '--no-buffer-stdout[disable STDOUT buffering]' \
  '(-A --charset)'{-A,--charset=}'[set default character set]:charset' \
  '--config=[read this comma-separated list of config files]:files:_files' \
  '--constant-data-value=[table name for constant data source]:table' \
  '--continue-on-error[continue on errors]' \
  '--no-continue-on-error[stop on errors]' \
  '--create-table-definitions=[read CREATE TABLE definitions from files]:files:_files' \
  '--daemonize[fork to background and detach from shell]' \
  '(-D --database)'{-D,--database=}'[specify default database]:database' \
  '(-F --defaults-file)'{-F,--defaults-file=}'[read MySQL options from specified file only]:file:_files' \
  '--explain-extended=[server for executing EXPLAIN EXTENDED queries]:dsn' \
  '--filter=[Perl code to filter events]:code' \
  '(-h --host)'{-h,--host=}'[connect to specified host]:host:_hosts' \
  '--id-attribute=[identify events using specified attribute]:attribute' \
  '--log=[print output to file when daemonized]:file:_files' \
  '(-s --mysql_ssl)'{-s,--mysql_ssl=}'[create SSL MySQL connection]:value' \
  '(-p --password)'{-p,--password=}'[password for connection]:password' \
  '--pid=[create PID file]:file:_files' \
  '(-P --port)'{-P,--port=}'[port number for connection]:port' \
  '--progress=[print progress reports to STDERR]:spec' \
  '--query=[analyze specified query instead of log file]:query' \
  '--read-timeout=[wait time for events]:seconds' \
  '--run-time=[duration to run before exiting]:time' \
  '--set-vars=[set MySQL variables as comma-separated pairs]:vars' \
  '(-S --socket)'{-S,--socket=}'[socket file for connection]:socket:_files' \
  '(-u --user)'{-u,--user=}'[user for login]:user:_users' \
  '*:log file:_files' && ret=0

return ret
