#compdef irw
# Documentation: https://manpages.debian.org/bookworm/lirc/irw.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm irw(1) manpage OPTIONS section.

# irw: print LIRC button presses
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:socket:_files' && ret=0
return ret
