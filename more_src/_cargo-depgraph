#compdef cargo-depgraph
# Documentation: https://github.com/jplatte/cargo-depgraph
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cargo-depgraph: graphviz dependency graphs for cargo projects.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '--all-deps[Include all dependencies, not just direct]' \
  '--build-deps[Include build dependencies]' \
  '--dev-deps[Include dev dependencies]' \
  '--no-regular-deps[Exclude regular dependencies]' \
  '--dedup-transitive-deps[Deduplicate transitive dependencies]' \
  '--workspace-only[Only show workspace members]' \
  '--focus=[Focus on specific packages]:packages' \
  '--exclude=[Exclude specific packages]:packages' \
  '--root=[Root package]:package' \
  '--target=[Filter by target platform]:target' \
  '--depth=[Maximum depth of dependency tree]:depth' \
  '*:args' && ret=0

return ret
