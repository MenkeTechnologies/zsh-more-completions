#compdef wimextract
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-extract.1.html
# wimextract — extract files or directories from a WIM image

local ret=1

_arguments -s -S \
  '--check[verify WIM integrity before extraction]' \
  '--ref=[reference additional WIMs or split parts]:glob' \
  '--dest-dir=[destination directory for extracted files]:dir:_files -/' \
  '--to-stdout[output extracted files to standard output]' \
  '--unix-data[preserve UNIX-specific metadata]' \
  '--no-acls[skip extraction of access control lists]' \
  '--strict-acls[enforce strict ACL validation]' \
  '--no-attributes[omit file attributes from extraction]' \
  '--include-invalid-names[extract files with non-conforming names]' \
  '--no-globs[treat all paths as literal strings]' \
  '--nullglob[warn instead of failing when a glob matches nothing]' \
  '--preserve-dir-structure[maintain archive directory hierarchy]' \
  '--wimboot[configure extraction for WIMBoot deployment]' \
  '--compact=[handle compact file format during extraction]:format:(xpress4k xpress8k xpress16k lzx)' \
  '--recover-data[attempt recovery of corrupted file data]' \
  '*:WIM file:_files' && ret=0

return ret
