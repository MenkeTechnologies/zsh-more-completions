#compdef sceptre
# Documentation: https://docs.sceptre-project.org/latest/docs/cli.html
# Reference accessed: 2026-05-21
# Verified: upstream CLI docs.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'new:initialize a Sceptre project / stack group'
  'create:create a stack or change set'
  'launch:create or update stacks as needed'
  'update:update a stack'
  'delete:delete a stack or change set'
  'execute:execute a change set'
  'validate:validate a CloudFormation template'
  'estimate-cost:estimate cost of a template'
  'generate:print the template (alias for dump template)'
  'set-policy:set stack policy'
  'status:print status of stack or stack group'
  'describe:describe stacks/change sets/policy'
  'list:list change sets/outputs/resources/stacks'
  'drift:drift detect/show'
  'diff:compare deployed vs configured stacks'
  'dump:dump config/template/all'
  'prune:delete all obsolete stacks'
  'fetch-remote-template:fetch the deployed template'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug logging]' \
  '--dir=[Sceptre project directory]:dir:_files -/' \
  '--output=[output format]:format:(text yaml json)' \
  '--no-colour[disable colored output]' \
  '*--var=[variable key=value]:var:' \
  '*--var-file=[YAML variables file]:file:_files -g "*.{yml,yaml}"' \
  '--merge-vars[deep merge successive var files]' \
  '--ignore-dependencies[skip dependency processing]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sceptre command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create|delete)
        _arguments \
          '(-y --yes)'{-y,--yes}'[skip confirmations]' \
          '--disable-rollback[disable CloudFormation rollback]' \
          '--enable-rollback[enable CloudFormation rollback]' \
          '--max-concurrency=[limit concurrent ops]:n:' \
          '*::stack_or_changeset:_files -/' && ret=0 ;;
      (launch)
        _arguments \
          '(-y --yes)'{-y,--yes}'[skip confirmations]' \
          '(-p --prune)'{-p,--prune}'[delete obsolete stacks first]' \
          '--disable-rollback[disable CloudFormation rollback]' \
          '--enable-rollback[enable CloudFormation rollback]' \
          '--max-concurrency=[limit concurrent ops]:n:' \
          '*::stack_or_stackgroup:_files -/' && ret=0 ;;
      (update)
        _arguments \
          '(-c --change-set)'{-c,--change-set}'[create change set before applying]' \
          '(-v --verbose)'{-v,--verbose}'[detailed output]' \
          '(-y --yes)'{-y,--yes}'[skip confirmations]' \
          '--disable-rollback[disable CloudFormation rollback]' \
          '--enable-rollback[enable CloudFormation rollback]' \
          '--max-concurrency=[limit concurrent ops]:n:' \
          '*::stack:_files -/' && ret=0 ;;
      (execute|validate|generate|estimate-cost|status|fetch-remote-template)
        _arguments '*::stack:_files -/' && ret=0 ;;
      (describe)
        _arguments '*::sub:(change-set policy)' && ret=0 ;;
      (list)
        _arguments '*::sub:(change-sets resources outputs stacks)' && ret=0 ;;
      (drift)
        _arguments \
          '(-D --drifted)'{-D,--drifted}'[only report drifted resources]' \
          '*::sub:(detect show)' && ret=0 ;;
      (diff)
        _arguments \
          '(-t --type)'{-t,--type}'[comparison method]:type:(deepdiff difflib)' \
          '(-s --show-no-echo)'{-s,--show-no-echo}'[display masked parameters]' \
          '(-n --no-placeholders)'{-n,--no-placeholders}'[omit unresolvable resolver values]' \
          '(-a --all)'{-a,--all}'[include all stacks]' \
          '*::stack:_files -/' && ret=0 ;;
      (dump)
        _arguments '*::sub:(all config template)' && ret=0 ;;
      (prune)
        _arguments \
          '(-y --yes)'{-y,--yes}'[skip confirmations]' && ret=0 ;;
      (new)
        _arguments '*::sub:(project group)' && ret=0 ;;
      (set-policy)
        _arguments \
          '(-b --built-in)'{-b,--built-in}'[use built-in policy]:policy:(deny-all allow-all)' \
          '*::stack:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
