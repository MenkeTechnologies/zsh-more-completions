#compdef sceptre
# Documentation: https://man.archlinux.org/search?q=sceptre
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'new:initialize a Sceptre project / config / template'
  'create:create a stack or change set'
  'launch:launch a stack or stack group'
  'update:update a stack'
  'delete:delete a stack or change set'
  'execute:execute a change set'
  'validate:validate a CloudFormation template'
  'estimate-cost:estimate cost of a template'
  'generate:print the template'
  'set-policy:set stack policy'
  'status:print status of stack or stack group'
  'describe:describe stacks/change sets/policy'
  'list:list change sets/outputs/resources'
  'drift:drift detect/show'
  'fetch-remote-template:fetch the deployed template'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[turn on debug logging]' \
  '--dir=[Sceptre project directory]:dir:_files -/' \
  '--output=[output format]:format:(text yaml json)' \
  '--no-colour[disable colored output]' \
  '*--var=[variable key=value]:var:' \
  '*--var-file=[YAML variables file]:file:_files -g "*.{yml,yaml}"' \
  '--ignore-dependencies[ignore dependencies]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sceptre command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create|update)
        _arguments \
          '(-y --yes)'{-y,--yes}'[skip prompts]' \
          '--no-rollback[disable CloudFormation rollback]' \
          '-c[create change set before applying]' \
          '*::stack_or_changeset:_files -/' && ret=0 ;;
      (launch|delete|execute)
        _arguments \
          '(-y --yes)'{-y,--yes}'[skip prompts]' \
          '*::stack_or_stackgroup:_files -/' && ret=0 ;;
      (validate|generate|estimate-cost|status|fetch-remote-template)
        _arguments '*::stack:_files -/' && ret=0 ;;
      (describe)
        _arguments '*::sub:(change-set policy)' && ret=0 ;;
      (list)
        _arguments '*::sub:(change-sets resources outputs)' && ret=0 ;;
      (drift)
        _arguments '*::sub:(detect show)' && ret=0 ;;
      (new)
        _arguments '*::sub:(project group config)' && ret=0 ;;
      (set-policy)
        _arguments \
          '*::stack:_files -/' \
          '--policy=[policy JSON file or builtin]:policy:(allow_all deny_all)' && ret=0 ;;
    esac ;;
esac

return ret
