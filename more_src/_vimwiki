#compdef vimwiki
# Documentation: https://github.com/sstallion/vimwiki-cli
# vimwiki - command-line interface to Vimwiki (vimwiki-cli)

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--editor=[editor command to launch]:editor:' \
  '--count=[index of wiki to open]:count:' \
  '--select[select wiki from interactive list]' \
  '--open-matches[open search results automatically]' \
  '--open-tabs[open pages in a new tab by default]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[show version and exit]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'all-html:convert all wiki pages to HTML'
      'check-links:check wiki links'
      'generate-links:generate links for a page'
      'goto:navigate to a specific page'
      'help:display Vimwiki documentation'
      'search:find content by pattern'
    )
    _describe -t commands 'vimwiki command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      all-html)
        _arguments -s '--all[convert all wikis]' && ret=0
        ;;
    esac
    ;;
esac

return ret
