#compdef cloudflare-cli2 wrangler2 cfctl
# _cloudflare-cli2 — Cloudflare cloudflare-cli2 CLI command-line frontend wrapping the Cloudflare Wrangler the official Cloudflare CLI for Workers Pages and platform features Workers KV R2 Durable Objects Hyperdrive D1 SQLite-database Vectorize Queues open-source written in TypeScript zone DNS purge cache rate-limit firewall WAF page-rules redirects access tunnels argo-tunnels cloudflared API-Token deploy dev publish init log tail kv r2 d1 vectorize queues hyperdrive workers analytics types secret types versions dispatch ai login logout whoami workers ai (Cloudflare team, TypeScript); commander
# upstream: https://developers.cloudflare.com/workers/wrangler/

_cloudflare-cli2() {
    local -a sub=(
        'ai:Workers AI operations'
        'analytics:analytics operations'
        'b2:R2 operations'
        'cert:certificate operations'
        'd1:D1 database operations'
        'deploy:deploy a Worker'
        'delete:delete a Worker'
        'deployments:deployment operations'
        'dev:run a local dev server'
        'dispatch:dispatch operations'
        'docs:open docs'
        'hyperdrive:Hyperdrive operations'
        'init:scaffold a new project'
        'kv:Workers KV operations'
        'login:authenticate'
        'logout:revoke session'
        'logs:show worker logs'
        'pages:Pages operations'
        'pipelines:Pipelines operations'
        'pubsub:Pub/Sub operations'
        'pull:pull a Worker'
        'queues:Queues operations'
        'r2:R2 operations'
        'rollback:rollback a Worker'
        'secret:secret operations'
        'tail:tail Worker logs'
        'types:generate types'
        'versions:Worker version operations'
        'whoami:show identity'
        'workers:Worker operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "wrangler.toml *.toml *.json *.jsonc"' \
        '--config=+[file]:file:_files -g "wrangler.toml *.toml *.json *.jsonc"' \
        '--cwd=+[dir]:dir:_files -/' \
        '--env=+[name]:str:' \
        '-e+[env]:str:' \
        '--name=+[name]:str:' \
        '--account-id=+[id]:str:' \
        '--api-token=+[token]:str:' \
        '--remote[remote mode]' \
        '--local[local mode]' \
        '-l[local mode]' \
        '--var=+[k=v]:str:' \
        '*--var=+[k=v]:str:' \
        '--binding=+[k=v]:str:' \
        '*--binding=+[k=v]:str:' \
        '--port=+[port]:n:' \
        '--inspector-port=+[port]:n:' \
        '--ip=+[address]:_hosts' \
        '--node-compat[node compat]' \
        '--latest[latest worker version]' \
        '--legacy-env[legacy environments]' \
        '--legacy-assets=+[dir]:dir:_files -/' \
        '--assets=+[dir]:dir:_files -/' \
        '--define=+[k=v]:str:' \
        '*--define=+[k=v]:str:' \
        '--routes=+[routes]:str:' \
        '*--routes=+[route]:str:' \
        '--route=+[route]:str:' \
        '--keep-vars[keep vars]' \
        '--minify[minify code]' \
        '--no-bundle[no bundling]' \
        '--bundle[bundle worker code]' \
        '--compatibility-date=+[d]:str:' \
        '--compatibility-flags=+[flag]:str:' \
        '*--compatibility-flag=+[flag]:str:' \
        '--dry-run[dry run]' \
        '--outdir=+[dir]:dir:_files -/' \
        '--workers-dev[publish to *.workers.dev]' \
        '--triggers=+[trigger]:str:' \
        '*--trigger=+[trigger]:str:' \
        '--persist-to=+[dir]:dir:_files -/' \
        '--logpush[enable logpush]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wrangler subcommand' sub ;;
        args)
            case $words[1] in
                kv) _arguments '1:op:(namespace key bulk)' '*:arg:' ;;
                r2) _arguments '1:op:(bucket object)' '*:arg:' ;;
                d1) _arguments '1:op:(list create delete info execute migrations backup)' '*:arg:' ;;
                queues) _arguments '1:op:(create delete info list update consumer)' '*:name:' ;;
                pages) _arguments '1:op:(deploy project upload list publish dev download functions)' '*:arg:' ;;
                hyperdrive) _arguments '1:op:(create delete update list get)' '*:name:' ;;
                vectorize) _arguments '1:op:(create delete get list query insert upsert get-vectors deletevectors get-by-ids deleteByIds metadata-index)' '*:arg:' ;;
                workers) _arguments '1:op:(deployments versions secret tail)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_cloudflare-cli2 "$@"
