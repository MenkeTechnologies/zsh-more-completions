#compdef pn
# Documentation: https://man.archlinux.org/search?q=pn
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

(( $+functions[_pnpm] )) || autoload -Uz _pnpm 2>/dev/null
if (( $+functions[_pnpm] )); then
  _pnpm "$@"
  return
fi

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*::pnpm command:_normal' && ret=0

return ret
