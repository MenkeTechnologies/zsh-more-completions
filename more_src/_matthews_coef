#compdef matthews_coef
# matthews_coef — estimate solvent content / molecules per ASU (Matthews coefficient) (CCP4)

local ret=1

_arguments -s -S \
  'CELL[unit cell parameters]:cell:' \
  'SYMMETRY[spacegroup number/name or operators]:sg:' \
  'NRES[number of residues]:n:' \
  'MOLWEIGHT[molecular weight in Daltons]:mw:' \
  'NMOL[molecules per ASU]:n:' \
  'AUTO[list incrementing molecules per ASU]' \
  'RESO[high resolution limit]:dmin:' \
  'MODE[calculation mode]:m:(Dna Comp Other)' \
  'XMLOUTPUT[generate XML output]' \
  '*:argument:_files' && ret=0

return ret
