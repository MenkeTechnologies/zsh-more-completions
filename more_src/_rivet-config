#compdef rivet-config
# Documentation: https://rivet.hepforge.org/
# rivet-config - query Rivet build/link configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--prefix[show the installation prefix]' \
  '--includedir[path to Rivet header files]' \
  '--libdir[path to Rivet library files]' \
  '--datadir[path to Rivet data directory]' \
  '--pythonpath[path to Rivet Python package]' \
  '--guess-prefix[use the runtime prefix instead of install-time prefix]' \
  '--cxx[compiler string used to build Rivet]' \
  '--cflags[compiler flags for header inclusion]' \
  '--cppflags[compiler flags for header inclusion]' \
  '--ldflags[linker flags for library paths and linking]' \
  '--libs[linker flags for library paths and linking]' \
  '--version[show the Rivet release version number]' && ret=0

return ret
