#compdef logmerger
# logmerger — merge and interleave multiple log files by timestamp (Python/Textual)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--inline[inline merged output to stdout]' \
  '(-o --output)'{-o,--output}'[output file]:output file:_files' \
  '--start=[start timestamp for filtering]:timestamp:' \
  '--end=[end timestamp for filtering]:timestamp:' \
  '--timestamp-format=[custom timestamp format string]:format:' \
  '--color=[colorize output]:when:(auto always never)' \
  '*:log file:_files'
