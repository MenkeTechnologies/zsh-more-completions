#compdef config-bootstrapper
# _config-bootstrapper — Prow bootstrapper that pushes initial Prow config (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/config-bootstrapper/main.go (flag).

_config-bootstrapper() {
    _arguments \
        '*-source-path=[root of source directory for config updates]:dir:_files -/' \
        '-dry-run=[whether to make mutating API calls to GitHub]:val:(true false)' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-plugin-config=[plugin config file]:file:_files' \
        '-github-token-path=[GitHub token file]:file:_files' \
        '-github-endpoint=[GitHub API endpoint]:url:_urls'
}

_config-bootstrapper "$@"
