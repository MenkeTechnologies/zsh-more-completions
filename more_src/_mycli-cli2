#compdef mycli-cli2
# Documentation: https://github.com/dbcli/mycli/blob/main/mycli/cli_args.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-h --hostname)'{-h+,--hostname=}'[host]:host:_hosts' \
  '-P+[port]:port:' \
  '(-u --user --username)'{-u+,--user=,--username=}'[user]:u:_users' \
  '-S+[socket]:file:_files' \
  '(-p --pass --password)'{-p+,--pass=,--password=}'[password]:p:' \
  '--password-file=[password file]:file:_files' \
  '--ssh-user=[ssh user]:u:_users' \
  '--ssh-host=[ssh host]:host:_hosts' \
  '--ssh-port=[ssh port]:port:' \
  '--ssh-password=[ssh password]:p:' \
  '--ssh-key-filename=[ssh key]:file:_files' \
  '--ssh-config-host=[ssh config host]:h:' \
  '--ssh-config-path=[ssh config path]:file:_files' \
  '--list-ssh-config[list ssh configurations]' \
  '--ssh-warning-off[suppress SSH deprecation notice]' \
  '--ssl-mode=[ssl mode]:mode:(DISABLED PREFERRED REQUIRED VERIFY_CA VERIFY_IDENTITY)' \
  '--ssl[enable SSL]' \
  '--no-ssl[disable SSL]' \
  '--ssl-ca=[CA cert]:file:_files' \
  '--ssl-capath=[CA path]:dir:_files -/' \
  '--ssl-cert=[cert file]:file:_files' \
  '--ssl-key=[key file]:file:_files' \
  '--ssl-cipher=[ciphers]:c:' \
  '--tls-version=[TLS version]:v:' \
  '--ssl-verify-server-cert[verify cert]' \
  '*'{-v,--verbose}'[verbose; repeatable]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-D --database)'{-D+,--database=}'[database]:db:' \
  '(-d --dsn)'{-d+,--dsn=}'[DSN alias]:dsn:' \
  '--list-dsn[list DSN aliases]' \
  '(-R --prompt)'{-R+,--prompt=}'[prompt format]:p:' \
  '--toolbar=[toolbar format]:fmt:' \
  '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
  '--checkpoint=[checkpoint file]:file:_files' \
  '--resume[resume after checkpoint]' \
  '--defaults-group-suffix=[group suffix]:suffix:' \
  '--defaults-file=[mysql defaults file]:file:_files' \
  '--myclirc=[myclirc file]:file:_files' \
  '--auto-vertical-output[auto vertical]' \
  '--show-warnings[show warnings]' \
  '--no-show-warnings[do not show warnings]' \
  '(-t --table)'{-t,--table}'[table format]' \
  '--csv[csv format]' \
  '--warn[warn before destructive query]' \
  '--no-warn[no warn]' \
  '--local-infile=[LOAD DATA LOCAL INFILE]:on:' \
  '(-g --login-path)'{-g+,--login-path=}'[login path]:p:' \
  '(-e --execute)'{-e+,--execute=}'[execute SQL]:sql:' \
  '--init-command=[init SQL]:sql:' \
  '--unbuffered[fetch rows as needed]' \
  '--charset=[default charset]:c:' \
  '--character-set=[default charset]:c:' \
  '--batch=[SQL script in batch mode]:file:_files' \
  '--noninteractive[do not prompt during batch input]' \
  '--format=[batch output format]:fmt:' \
  '--throttle=[seconds between queries]:s:' \
  '--progress[show progress]' \
  '--use-keyring=[keyring usage]:k:(true false reset)' \
  '--keepalive-ticks=[keepalive interval seconds]:s:' \
  '--checkup[run configuration checkup]' \
  '*: :' && ret=0

return ret
