#compdef mycli-cli2
# Documentation: https://man.archlinux.org/search?q=mycli-cli2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --host)'{-h+,--host=}'[host]:host:_hosts' \
  '(-P --port)'{-P+,--port=}'[port]:port:' \
  '(-u --user)'{-u+,--user=}'[user]:u:_users' \
  '(-S --socket)'{-S+,--socket=}'[socket]:file:_files' \
  '(-p --password)'{-p+,--password=}'[password]:p:' \
  '--pass=[password]:p:' \
  '--ssh-user=[ssh user]:u:_users' \
  '--ssh-host=[ssh host]:host:_hosts' \
  '--ssh-port=[ssh port]:port:' \
  '--ssh-password=[ssh password]:p:' \
  '--ssh-key-filename=[ssh key]:file:_files' \
  '--ssh-config-host=[ssh config host]:h:' \
  '--ssh-config-path=[ssh config path]:file:_files' \
  '(-D --database)'{-D+,--database=}'[database]:db:' \
  '(-d --dbname)'{-d+,--dbname=}'[database]:db:' \
  '(-R --prompt)'{-R+,--prompt=}'[prompt]:p:' \
  '-l[run as login]' \
  '--logfile=[log file]:file:_files' \
  '--login-path=[login path]:p:' \
  '--auto-vertical-output[auto vertical]' \
  '--row-limit=[row limit]:n:' \
  '(-t --table)'{-t,--table}'[table format]' \
  '--csv[csv format]' \
  '(-T --tsv)'{-T,--tsv}'[tsv format]' \
  '(-n --nopager)'{-n,--nopager}'[no pager]' \
  '--less-chatty[less chatty]' \
  '--myclirc=[config file]:file:_files' \
  '--auto-rehash[auto rehash]' \
  '--no-auto-rehash[no auto rehash]' \
  '--ssl-ca=[CA cert]:file:_files' \
  '--ssl-capath=[CA path]:dir:_files -/' \
  '--ssl-cert=[cert file]:file:_files' \
  '--ssl-key=[key file]:file:_files' \
  '--ssl-cipher=[ciphers]:c:' \
  '--ssl-verify-server-cert[verify cert]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '-e+[execute SQL]:sql:' \
  '--execute=[execute SQL]:sql:' \
  '--init-command=[init SQL]:sql:' \
  '--charset=[default charset]:c:' \
  '--no-warn[no warn]' \
  '--list-dsn[list dsn]' \
  '--list[list databases]' \
  '*: :' && ret=0

return ret
