#compdef karmadactl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'addons:enable or disable a Karmada addon'
  'annotate:update annotations on a resource'
  'api-resources:print supported API resources'
  'api-versions:print supported API versions'
  'apply:apply config and propagate to member clusters'
  'attach:attach to a running container'
  'completion:output shell completion code'
  'cordon:mark cluster as unschedulable'
  'create:create a resource from file or stdin'
  'deinit:remove Karmada control plane'
  'delete:delete resources'
  'describe:show details of a resource'
  'edit:edit a resource on the server'
  'exec:execute command in a container'
  'explain:get documentation for a resource'
  'get:display resources'
  'init:install Karmada control plane'
  'interpret:validate/test/edit interpreter customization'
  'join:register cluster (Push mode)'
  'label:update labels on a resource'
  'logs:print logs for a container'
  'options:print flags inherited by all commands'
  'patch:update fields of a resource'
  'promote:promote resources from legacy clusters'
  'register:register cluster (Pull mode)'
  'taint:update taints on clusters'
  'token:manage bootstrap tokens'
  'top:display CPU/memory usage of clusters'
  'uncordon:mark cluster as schedulable'
  'unjoin:remove cluster from control plane'
  'unregister:remove pull-mode cluster'
  'version:print version'
)

_arguments -C \
  '--add-dir-header[add directory header to log lines]' \
  '--alsologtostderr[log to stderr and files]' \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--log-backtrace-at=[backtrace at file:line]:loc:' \
  '--log-dir=[log directory]:dir:_files -/' \
  '--log-file=[log file]:file:_files' \
  '--log-file-max-size=[max log file size]:size:' \
  '--logtostderr[log to stderr]' \
  '--one-output[single output destination]' \
  '--skip-headers[skip log headers]' \
  '--skip-log-headers[skip log message headers]' \
  '--stderrthreshold=[stderr threshold]:severity:' \
  '(-v --v)'{-v,--v=}'[log level]:level:' \
  '--vmodule=[per-module verbosity]:spec:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'karmadactl subcommand' subcommands && ret=0
    ;;
esac

return ret
