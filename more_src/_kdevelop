#compdef kdevelop
# Documentation: https://github.com/KDE/kdevelop/blob/master/app/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (QCommandLineParser defs).

# KDevelop: KDE IDE (C++, Python, PHP, JS, ...)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --new-session)'{-n,--new-session}'=[create a new session with the given name]:name:' \
  '(-s --open-session)'{-s,--open-session}'=[open the session with the given name or UUID]:session:' \
  '--rm=[remove the session with the given name or UUID]:session:' \
  '--remove-session=[remove the session with the given name or UUID]:session:' \
  '(--ps --pick-session)'{--ps,--pick-session}'[shows a dialog that lets you select a session to open]' \
  '(--pss --pick-session-shell)'{--pss,--pick-session-shell}'[only shows a textual list of sessions to select from]' \
  '(-l --list-sessions)'{-l,--list-sessions}'[lists available sessions and quits]' \
  '(-f --fetch)'{-f,--fetch}'=[open KDevelop and fetch the project from the given repository URL]:url:' \
  '(-p --project)'{-p,--project}'=[open KDevelop and load the given project]:file:_files -g "*.kdev4"' \
  '(-d --debug)'{-d,--debug}'=[start debugging an application with the given debugger]:debugger:' \
  '--pid=[used to identify already running KDevelop instances]:pid:' \
  '*:file:_files' && ret=0
return ret
