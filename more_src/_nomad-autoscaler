#compdef nomad-autoscaler
# Documentation: https://man.archlinux.org/search?q=nomad-autoscaler
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'agent:run autoscaler agent'
      'config:validate or render config'
      'version:print version'
    )
    _describe -t commands 'nomad-autoscaler command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      agent)
        _arguments -s -S \
          '(-config)'-config'=[config file]:file:_files' \
          '(-http-bind-address)'-http-bind-address'=[HTTP bind address]:addr' \
          '(-log-level)'-log-level'=[log level]:level' \
          '*: : _default' \
          && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
