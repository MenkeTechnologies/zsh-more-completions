#compdef nomad-autoscaler
# Documentation: https://developer.hashicorp.com/nomad/tools/autoscaling/cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Per HashiCorp docs: top-level commands are `agent` and `version`.
# Agent flags grouped: Core, HTTP, Nomad connection, TLS, Policy,
# Telemetry, High Availability. Prior file used the wrong exclusion
# syntax for single-arg flags — corrected to plain `-flag=`.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'agent:run the Nomad Autoscaler agent'
      'version:print build version and revision'
    )
    _describe -t commands 'nomad-autoscaler command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      agent)
        _arguments -s -S \
          '-config=[path to a config file or directory of HCL/JSON files]:path:_files' \
          '-log-level=[log verbosity level]:level:(DEBUG INFO WARN)' \
          '-log-json[output logs in JSON format]' \
          '-plugin-dir=[directory for discovering plugins]:dir:_directories' \
          '-enable-debug[enable debugging HTTP endpoints]' \
          '-http-bind-address=[HTTP health server bind address]:addr' \
          '-http-bind-port=[HTTP health server bind port]:port' \
          '-nomad-address=[Nomad API address]:addr' \
          '-nomad-region=[Nomad region]:region' \
          '-nomad-namespace=[Nomad namespace]:namespace' \
          '-nomad-token=[Nomad ACL token]:token' \
          '-nomad-ca-cert=[path to Nomad CA cert]:file:_files' \
          '-nomad-client-cert=[path to Nomad client cert]:file:_files' \
          '-nomad-skip-verify[skip TLS verification of Nomad endpoints]' \
          '-policy-dir=[directory containing scaling policies]:dir:_directories' \
          '-policy-default-cooldown=[default policy cooldown]:duration' \
          '-policy-eval-workers=[policy eval worker counts]:count' \
          '-high-availability-enabled[enable high-availability mode]' \
          '-high-availability-lock-path=[HA lock path]:path' \
          '-high-availability-lock-ttl=[HA lock TTL]:duration' \
          '*: : _default' \
          && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
