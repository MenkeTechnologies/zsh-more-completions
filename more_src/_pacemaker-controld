#compdef pacemaker-controld
# Documentation: https://man.archlinux.org/search?q=pacemaker-controld
# Reference accessed: 2026-05-16

# Pacemaker CRM control subdaemon (DC election, state transitions)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-$,--version}'[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '*::pacemaker-controld args:_files' && ret=0
return ret
