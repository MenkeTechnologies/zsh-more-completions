#compdef faker

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-l --lang)'{-l,--lang}'[Locale for generated data]:locale:(en_US en_GB fr_FR de_DE es_ES it_IT ja_JP ko_KR pt_BR ru_RU zh_CN zh_TW nl_NL pl_PL sv_SE da_DK fi_FI nb_NO tr_TR ar_SA hi_IN)' \
  '(-r --repeat)'{-r,--repeat}'[Number of times to repeat]:count:' \
  '(-s --seed)'{-s,--seed}'[Random seed for reproducibility]:seed:' \
  '--sep[Separator between repeated outputs]:separator:' \
  '(-o --output)'{-o,--output}'[Output format]:format:(json csv txt)' \
  '(- *)--help[Show help message]' \
  '(- *)--version[Show version information]' \
  '*:provider:->providers' \
  && ret=0

case $state in
  providers)
    local -a providers=(
      'name:Generate a full name'
      'first_name:Generate a first name'
      'last_name:Generate a last name'
      'address:Generate an address'
      'street_address:Generate a street address'
      'city:Generate a city name'
      'state:Generate a state'
      'zipcode:Generate a zipcode'
      'country:Generate a country'
      'email:Generate an email address'
      'phone_number:Generate a phone number'
      'text:Generate text'
      'sentence:Generate a sentence'
      'paragraph:Generate a paragraph'
      'date:Generate a date'
      'date_of_birth:Generate a date of birth'
      'time:Generate a time'
      'company:Generate a company name'
      'job:Generate a job title'
      'url:Generate a URL'
      'ipv4:Generate an IPv4 address'
      'ipv6:Generate an IPv6 address'
      'user_agent:Generate a user agent string'
      'uuid4:Generate a UUID'
      'credit_card_number:Generate a credit card number'
      'iban:Generate an IBAN'
      'color_name:Generate a color name'
      'hex_color:Generate a hex color'
      'file_name:Generate a file name'
      'boolean:Generate a boolean'
      'md5:Generate an MD5 hash'
      'sha256:Generate a SHA256 hash'
      'password:Generate a password'
      'ssn:Generate a social security number'
      'license_plate:Generate a license plate'
    )
    _describe -t providers 'faker provider' providers && ret=0
    ;;
esac

return ret
