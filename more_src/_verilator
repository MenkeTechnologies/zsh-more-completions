#compdef verilator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--binary[create binary executable]' \
  '--cc[create C++ output]' \
  '--sc[create SystemC output]' \
  '--lint-only[lint the design only, do not create output]' \
  '--xml-only[emit XML, do not create output]' \
  '-E[preprocess but do not compile]' \
  '--build[build model after Verilating]' \
  '--build-jobs=[parallel build jobs]:jobs' \
  '-j+[parallel jobs for both Verilating and building]:jobs' \
  '-f+[read additional flags from file]:flag file:_files' \
  '-F+[read flags from file, relative to file location]:flag file:_files' \
  '--top-module=[name of top-level module]:module name' \
  '--prefix=[name of output class prefix]:prefix' \
  '--Mdir=[output directory for make files]:directory:_directories' \
  '-o+[output executable name]:output file:_files' \
  '-I+[include directory]:directory:_directories' \
  '+incdir+[include directory]:directory:_directories' \
  '-D+[set preprocessor define]:define' \
  '-U+[undefine preprocessor symbol]:symbol' \
  '-G+[overwrite toplevel parameter]:parameter=value' \
  '--exe[link to create executable]' \
  '--main[generate C++ main function]' \
  '--trace[enable waveform tracing]' \
  '--trace-fst[enable FST waveform tracing]' \
  '--trace-depth=[depth of tracing]:depth' \
  '--coverage[enable all coverage]' \
  '--coverage-line[enable line coverage]' \
  '--coverage-toggle[enable toggle coverage]' \
  '--coverage-user[enable user-inserted coverage]' \
  '--assert[enable assertions]' \
  '--x-assign=[assign Xs to]:mode:(0 1 fast unique)' \
  '--x-initial=[initial value for signals]:mode:(0 1 fast unique)' \
  '-Wall[enable all style warnings]' \
  '-Werror-[convert warning to error]:warning type' \
  '-Wno-[disable warning]:warning type' \
  '-Wfuture-[disable future deprecation warning]:warning type' \
  '--clk=[mark signal as clock]:signal' \
  '--no-clk=[mark signal as not clock]:signal' \
  '-O+[optimization level]:level:(0 1 2 3)' \
  '--output-split=[split output .cpp files]:lines' \
  '--output-split-cfuncs=[split output functions]:lines' \
  '--pins-bv=[use bit vectors for ports]:width' \
  '--stats[dump statistics]' \
  '--structs-packed[pack structure members]' \
  '--timing[enable timing support]' \
  '--threads=[enable multithreading]:thread count' \
  '--debug[enable debug mode]' \
  '--debugi=[debug verbosity level]:level' \
  '--dump-tree[dump parse tree as files]' \
  '--dump-treei=[dump tree level]:level' \
  '-v+[Verilog library file]:file:_files -g "*.(v|sv)"' \
  '-y+[Verilog library directory]:directory:_directories' \
  '--CFLAGS=[C++ compiler flags]:flags' \
  '--LDFLAGS=[linker flags]:flags' \
  '--lib-create=[create a library]:name' \
  '*:Verilog file:_files -g "*.(v|sv|vh|svh)"' && ret=0

return ret
