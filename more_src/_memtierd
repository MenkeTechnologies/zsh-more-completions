#compdef memtierd
# _memtierd — containers/nri-plugins NRI plugin that launches a per-container memtierd to manage page-tier movement (DRAM ↔ CXL/PMEM)
# upstream: https://github.com/containers/nri-plugins
# Flags from cmd/plugins/memtierd/main.go on tip.

_memtierd() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--name=[plugin name to register to NRI]:name:' \
        '--idx=[plugin index to register to NRI]:n:' \
        '--config=[configuration file]:file:_files' \
        '--cgroups-dir=[cgroups root directory]:dir:_files -/' \
        '--run-dir=[directory prefix for memtierd runtime environments]:dir:_files -/' \
        '-v[verbose output]' \
        '-vv[very verbose output]'
}

_memtierd "$@"
