#compdef adidnsdump

_arguments -s \
  '(-u --user)'{-u,--user}'=[username]:user:' \
  '(-p --password)'{-p,--password}'=[password or LM:NTLM]:pw:' \
  '--forest[search ForestDnsZones]' \
  '--legacy[search System partition]' \
  '--zone=[zone to search]:zone:' \
  '--print-zones[only query zones]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-r --resolve)'{-r,--resolve}'[resolve via DNS]' \
  '--dns-tcp[DNS over TCP]' \
  '--include-tombstoned[include tombstoned]' \
  '--ssl[LDAP over SSL]' \
  '--referralhosts[allow referral auth]' \
  '--dcfilter[alternate DNS filter]' \
  '--sslprotocol=[SSL protocol]:proto:(SSLv23 TLSv1 TLSv1_1 TLSv1_2)' \
  '--outfile=[output CSV]:file:_files' \
  '*:hostname:_hosts'
