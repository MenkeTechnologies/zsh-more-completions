#compdef kube-dns
# _kube-dns — classic Kubernetes kube-dns DNS server
# upstream: https://github.com/kubernetes/dns
# Flags from cmd/kube-dns/app/options/options.go on tip.

_kube-dns() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--domain=[DNS cluster domain (e.g. cluster.local)]:domain:' \
        '--nameservers=[upstream nameservers (csv)]:csv:' \
        '--kubecfg-file=[kubeconfig file]:file:_files' \
        '--kube-master-url=[Kubernetes master URL]:url:_urls' \
        '--healthz-port=[healthz bind port]:port:' \
        '--dns-bind-address=[DNS bind address]:host:' \
        '--dns-port=[DNS listen port]:port:' \
        '--config-map-namespace=[ConfigMap namespace]:ns:' \
        '--config-map=[ConfigMap name with stub-domain config]:name:' \
        '--initial-sync-timeout=[informer initial-sync timeout]:dur:' \
        '--config-dir=[directory with stub-domain configs]:dir:_files -/' \
        '--config-period=[ConfigMap re-read interval]:dur:' \
        '--profiling=[enable pprof endpoint]:bool:(true false)' \
        '-v[klog verbosity level]:n:'
}

_kube-dns "$@"
