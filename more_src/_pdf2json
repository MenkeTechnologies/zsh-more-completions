#compdef pdf2json
# Documentation: https://github.com/modesty/pdf2json
# pdf2json - convert PDF documents to JSON

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message and exit]' \
  '(-v --version)'{-v,--version}'[print the version number and exit]' \
  '(-f --file)'{-f,--file}'=[path to a PDF file or directory of PDF files]:path:_files' \
  '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
  '(-s --silent)'{-s,--silent}'[suppress informational output, only errors printed]' \
  '(-t --fieldTypes)'{-t,--fieldTypes}'[generate a .fields.json file with form field ids and types]' \
  '(-c --content)'{-c,--content}'[generate a .content.txt file with extracted text]' \
  '(-m --merge)'{-m,--merge}'[generate a .merged.json file with merged text blocks]' \
  '(-r --stream)'{-r,--stream}'[use stream-based parsing]' \
  '(-si --singleton)'{-si,--singleton}'[reuse a single PDFParser instance across files]' \
  '(-j --json)'{-j,--json}'[output a structured JSON summary to stdout]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all non-error output]' \
  '*:PDF file:_files -g "*.pdf"' && ret=0

return ret
