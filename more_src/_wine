#compdef wine

# Zsh completion for wine - Windows application compatibility layer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '*:Windows executable:->exefiles' && ret=0

case "$state" in
  exefiles)
    _files -g '*.(exe|msi|bat|cmd|com|lnk|EXE|MSI|BAT|CMD|COM|LNK)(-.)'
    ;;
esac

return ret
