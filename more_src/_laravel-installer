#compdef laravel-installer
# _laravel-installer — Laravel project installer CLI alias (laravel team, PHP); symfony console
# upstream: https://github.com/laravel/installer

_laravel-installer() {
    local -a sub=(
        'new:create new laravel project'
        'help:show help'
        'list:list commands'
        'completion:dump completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'laravel subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:name:_files -/' \
                    '--dev[install dev branch]' \
                    '--git[init git repo]' \
                    '--branch=+[branch]:b:(main master develop)' \
                    '--github=+[github repo]:str:' \
                    '--organization=+[github org]:str:' \
                    '--database=+[database]:db:(mysql mariadb pgsql sqlite sqlsrv)' \
                    '--stack=+[starter stack]:s:(blade livewire react vue)' \
                    '--breeze[install breeze]' \
                    '--jet[install jetstream]' \
                    '--dark[dark mode]' \
                    '--typescript[use typescript]' \
                    '--eslint[install eslint]' \
                    '--pest[use pest]' \
                    '--phpunit[use phpunit]' \
                    '--npm[run npm install]' \
                    '--no-interaction[no interaction]' \
                    '--force[force overwrite existing]' \
                    '-f[force overwrite existing]' \
                    '--api[install api scaffold]' \
                    '--ssr[server-side rendering]' \
                    '--inertia[install inertia]' \
                    '--workos[install workos]' \
                    '--volt[install volt]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_laravel-installer "$@"
