#compdef birdc

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-s+[path to BIRD control socket]:socket:_files' \
  '-r[do not read commands from rc file]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'show:show various information'
      'dump:dump internal state'
      'enable:enable a protocol'
      'disable:disable a protocol'
      'restart:restart a protocol'
      'reload:reload a protocol'
      'configure:re-read and apply configuration'
      'down:shut BIRD down'
      'debug:control protocol debugging'
      'mrtdump:control MRT dump'
      'restrict:restrict BIRD CLI to safe commands'
      'graceful:enable graceful restart recovery'
    )
    _describe -t commands 'birdc command' commands && ret=0
    ;;
  args)
    case $line[1] in
      show)
        local -a show_commands=(
          'status:show router status'
          'protocols:show protocol status'
          'interfaces:show network interfaces'
          'route:show routing table'
          'ospf:show OSPF information'
          'bgp:show BGP information'
          'bfd:show BFD information'
          'rip:show RIP information'
          'babel:show Babel information'
          'static:show static routes'
          'memory:show memory usage'
          'symbols:show symbol table'
        )
        _describe -t commands 'show command' show_commands && ret=0
        ;;
      enable|disable|restart|reload)
        _arguments -s -S \
          '1:protocol name:' && ret=0
        ;;
      configure)
        _arguments -s -S \
          '--soft[soft reconfiguration]' \
          '--check[check config only]' \
          '1:config file:_files' && ret=0
        ;;
      debug)
        _arguments -s -S \
          '1:protocol:' \
          '2:debug flags:(all off states routes filters events packets)' && ret=0
        ;;
    esac
    ;;
esac

return ret
