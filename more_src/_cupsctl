#compdef cupsctl
# Documentation: cupsctl --help (CUPS 26)
# Source: read or set CUPS server runtime parameters.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[encrypt connection to the server]' \
    '-h+[server[:port]]:server:_hosts' \
    '-U+[username for authentication]:user:_users' \
    '(--no-debug-logging)--debug-logging[turn debug logging on]' \
    '(--debug-logging)--no-debug-logging[turn debug logging off]' \
    '(--no-remote-admin)--remote-admin[allow remote administration]' \
    '(--remote-admin)--no-remote-admin[disallow remote administration]' \
    '(--no-remote-any)--remote-any[allow access from the Internet]' \
    '(--remote-any)--no-remote-any[deny access from the Internet]' \
    '(--no-share-printers)--share-printers[turn printer sharing on]' \
    '(--share-printers)--no-share-printers[turn printer sharing off]' \
    '(--no-user-cancel-any)--user-cancel-any[allow users to cancel any job]' \
    '(--user-cancel-any)--no-user-cancel-any[disallow users to cancel jobs]' \
    '*:param=value:' \
    && ret=0

return ret
