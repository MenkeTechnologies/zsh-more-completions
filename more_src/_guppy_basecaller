#compdef guppy_basecaller
# Documentation: https://wiki.gacrc.uga.edu/wiki/Ont-Guppy-Sapelo2
# Oxford Nanopore Guppy basecaller

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input_path)'{-i,--input_path}'=[path to input files]:dir:_files -/' \
  '(-s --save_path)'{-s,--save_path}'=[path to save output files]:dir:_files -/' \
  '(-c --config)'{-c,--config}'=[configuration file]:file:_files' \
  '(-r --recursive)'{-r,--recursive}'[search input files recursively]' \
  '--flowcell=[flowcell to find a configuration for]:flowcell' \
  '--kit=[kit to find a configuration for]:kit' \
  '--num_callers=[number of parallel basecallers]:n' \
  '--cpu_threads_per_caller=[CPU worker threads per basecaller]:n' \
  '--gpu_runners_per_device=[runners per GPU device]:n' \
  '(-x --device)'{-x,--device}'=[GPU device spec]:device' \
  '--compress_fastq[compress fastq output with gzip]' \
  '--min_qscore=[min qscore to filter into PASS folder]:q' \
  '--barcode_kits=[space separated barcoding kit(s)]:kits' \
  '--enable_trim_barcodes[trim barcodes from output sequences]' \
  '(-q --records_per_fastq)'{-q,--records_per_fastq}'=[max records per fastq file]:n' \
  '--chunk_size=[stride intervals per chunk]:n' \
  '--chunks_per_runner=[max chunks per runner]:n' && ret=0

return ret
