#compdef systemd-sysctl
# _systemd-sysctl (systemd kernel-runtime-setting applier reading /etc/sysctl.d/*.conf, /usr/lib/sysctl.d/*.conf, /run/sysctl.d/*.conf in conventional order; --prefix limits to specific sysctl name tree, --strict fails on errors, --cat-config prints all rendered configs; positional argument is an optional file list)
# upstream: https://github.com/systemd/systemd (src/sysctl)
# Flags from systemd src/sysctl/sysctl.c on tip.

_systemd-sysctl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--prefix=*[name prefix]:prefix:' \
        '--strict[fail on errors]' \
        '--cat-config[print rendered configs]' \
        '--tldr[brief output]' \
        '--no-pager[no pager]' \
        '*:file:_files'
}

_systemd-sysctl "$@"
