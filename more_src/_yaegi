#compdef yaegi

local curcontext="$curcontext" state line ret=1

_yaegi_commands() {
  local -a commands=(
    'run:run a Go program'
    'test:test a Go package'
    'extract:extract a Go package for use in yaegi'
    'help:show help'
  )
  _describe -t commands 'yaegi command' commands
}

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-i[start interactive mode]' \
  '-tags[build tags]:tags' \
  '-unsafe[allow use of unsafe package]' \
  '1:command:_yaegi_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments -s -S \
          '--help[show help]' \
          '-tags[build tags]:tags' \
          '-unsafe[allow use of unsafe package]' \
          '*:go file:_files -g "*.go"' && ret=0
        ;;
      test)
        _arguments -s -S \
          '--help[show help]' \
          '-tags[build tags]:tags' \
          '-unsafe[allow use of unsafe package]' \
          '*:go package:_files -/' && ret=0
        ;;
      extract)
        _arguments -s -S \
          '--help[show help]' \
          '*:go package' && ret=0
        ;;
    esac
    ;;
esac

return ret
