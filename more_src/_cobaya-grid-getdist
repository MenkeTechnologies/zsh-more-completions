#compdef cobaya-grid-getdist
# Documentation: https://cobaya.readthedocs.io/en/latest/grids.html
# cobaya: run getdist on the chains of a grid

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--update_only[only run getdist on chains updated since the last run]' \
  '--make_plots[run generated plot scripts to make PDFs]' \
  '--norun[just make the .ini files, do not run getdist]' \
  '--burn_removed[burn in has already been removed from chains]' \
  '--burn_remove=[fraction of chain to remove as burn in]:fraction' \
  '--no_plots[just make non-plot outputs]' \
  '--delay=[run after delay of some number of seconds]:seconds' \
  '--procs=[number of getdist instances to run in parallel]:procs' \
  '--base_ini=[default getdist settings .ini file]:ini:_files -g "*.ini"' \
  '--command=[program to run]:program:_command_names' \
  '--exist[silently skip all chains that do not exist]' \
  '--converge=[minimum R-1 convergence]:R-1' \
  '1:grid directory:_files -/' && ret=0

return ret
