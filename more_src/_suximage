#compdef suximage
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/graphics/xplot/suximage.c
# X-windows image plot of SU data via ximage

local ret=1

_arguments -s -S \
  'infile=[SU data to plot (default stdin)]:file:_files' \
  'ftr=[first trace to be plotted]:first trace' \
  'dtr=[trace increment to be plotted]:increment' \
  'n2=[max number of traces to be plotted]:ntraces' \
  'ntr=[alias for n2]:ntraces' \
  'd1=[sampling interval in the fast dimension]:d1' \
  'd2=[sampling interval in the slow dimension]:d2' \
  'key=[header key for annotating slow dimension]:key' \
  'f1=[first sample in the fast dimension]:f1' \
  'f2=[first sample in the slow dimension]:f2' \
  'verbose=[print useful information]:verbose:(0 1)' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
