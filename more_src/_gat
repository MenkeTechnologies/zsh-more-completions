#compdef gat

# Zsh completion for gat (cat alternative with syntax highlighting)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-l --language)'{-l,--language}'[set language for syntax highlighting]:language' \
  '(-t --theme)'{-t,--theme}'[set color theme]:theme' \
  '--list-languages[list available languages]' \
  '--list-themes[list available themes]' \
  '(-n --number)'{-n,--number}'[show line numbers]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:file:_files' && ret=0

return ret
