#compdef awsume

# Zsh completion for awsume (AWS assume role tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --output-profile)'{-o,--output-profile}'[output profile name]:profile' \
  '(-s --show-commands)'{-s,--show-commands}'[show export commands]' \
  '(-u --unset)'{-u,--unset}'[unset session variables]' \
  '(-a --auto-refresh)'{-a,--auto-refresh}'[auto-refresh credentials]' \
  '(-k --kill-refresher)'{-k,--kill-refresher}'[kill auto-refresher]' \
  '(-l --list-profiles)'{-l,--list-profiles}'[list available profiles]' \
  '(-m --mfa-token)'{-m,--mfa-token}'[MFA token]:token' \
  '(-r --region)'{-r,--region}'[AWS region]:region:(us-east-1 us-east-2 us-west-1 us-west-2 eu-west-1 eu-west-2 eu-west-3 eu-central-1 eu-north-1 ap-southeast-1 ap-southeast-2 ap-northeast-1 ap-northeast-2 ap-south-1 sa-east-1 ca-central-1)' \
  '--session-name[role session name]:name' \
  '--role-arn[ARN of role to assume]:arn' \
  '--source-profile[source profile]:profile' \
  '--external-id[external ID for role assumption]:id' \
  '--role-duration[role session duration in seconds]:seconds' \
  '--with-saml[authenticate with SAML]' \
  '--with-web-identity[authenticate with web identity]' \
  '--json[output as JSON]' \
  '--credentials-file[custom credentials file]:file:_files' \
  '--config-file[custom config file]:file:_files' \
  '--force-refresh[force credential refresh]' \
  '(-c --console)'{-c,--console}'[open AWS console]' \
  '(-cl --console-link)'{-cl,--console-link}'[get AWS console link]' \
  '(-cs --console-service)'{-cs,--console-service}'[AWS console service]:service' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:profile:->profiles' && ret=0

case $state in
  (profiles)
    local -a profiles
    profiles=(${(f)"$(awsume --list-profiles 2>/dev/null | tail -n +2 | awk '{print $1}')"})
    _describe -t profiles 'AWS profile' profiles && ret=0
    ;;
esac

return ret
