#compdef ambari-server
# _ambari-server — Apache Ambari ambari-server (cluster management server; subcommands: start, stop, restart, status, setup, reset, upgrade, refresh-stack-hash, sync-ldap, set-current, backup, restore, install-mpack, update-host-names, setup-ldap, setup-https, setup-security, kerberos-setup, encrypt-passwords; --verbose, --debug, --silent)
# upstream: https://github.com/apache/ambari
# Subcommands from ambari/ambari-server/sbin/ambari-server on tip.

_ambari-server() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--silent[silent]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'ambari-server command' '(start stop restart status setup reset upgrade upgradestack refresh-stack-hash sync-ldap set-current set-ldap setup-ldap setup-https setup-security install-mpack uninstall-mpack update-host-names backup restore encrypt-passwords kerberos-setup db-cleanup db-purge-history clear-keystore)' ;;
        args) _arguments '*:argument:' ;;
    esac
}

_ambari-server "$@"
