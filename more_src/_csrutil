#compdef csrutil
# Documentation: https://developer.apple.com/documentation/security/disabling_and_enabling_system_integrity_protection
# Reference accessed: 2026-05-17
# Verified: Apple SIP developer docs and macOS `man csrutil` output.
# csrutil(8) is Apple's macOS System Integrity Protection control tool.

local -a subcommands

subcommands=(
    'status:Display the current System Integrity Protection status'
    'enable:Enable System Integrity Protection'
    'disable:Disable System Integrity Protection'
    'clear:Clear the existing SIP configuration'
    'netboot:Set netboot status for next boot'
    'authenticated-root:Manage authenticated root settings'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*:: :->args' && return

case $state in
    subcmd)
        _describe 'csrutil subcommand' subcommands
        ;;
    args)
        case $words[1] in
            enable|disable)
                _arguments \
                    '--without[Disable SIP except for specified protections]:protection:(kext fs debug dtrace nvram basesystem)' \
                    '--no-internal[Disable Apple Internal]'
                ;;
            netboot)
                _arguments \
                    '1:netboot setting:(add remove)'
                ;;
            authenticated-root)
                _arguments \
                    '1:setting:(enable disable status)'
                ;;
        esac
        ;;
esac
