#compdef resto
# Documentation: https://github.com/abdfnx/resto
# resto - send pretty HTTP & API requests with a TUI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-H --headers)'{-H,--headers}'[just show the response headers]' \
  '(-j --just-body)'{-j,--just-body}'[just show the response body]' \
  '(-b --body)'{-b,--body}'=[the body of the request]:body' \
  '(-i --body-stdin)'{-i,--body-stdin}'[read the body from stdin]' \
  '--content-type=[the content type of the request body]:type:(json text xml yaml form)' \
  '--editor[open editor to compose the request body]' \
  '--username=[username for basic authentication]:username' \
  '--password=[password for basic authentication]:password' \
  '--token=[bearer token for authentication]:token' \
  '--save=[save the response body to a file]:file:_files' \
  '1:command:(get post put patch delete head install run get-latest)' \
  '*::arg:->args' && ret=0

return ret
