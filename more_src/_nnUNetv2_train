#compdef nnUNetv2_train
# Documentation: https://github.com/MIC-DKFZ/nnUNet/blob/master/documentation/how_to_use_nnunet.md
# nnU-Net v2 model training

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--npz[save softmax outputs for ensembling]' \
  '--val[run validation only]' \
  '--c[continue training from checkpoint]' \
  '-device[compute device]:device:(cpu cuda mps)' \
  '-num_gpus[number of GPUs for DDP]:num gpus:' \
  '-tr[trainer class]:trainer:' \
  '-p[plans identifier]:plans:' \
  '*:arg:' && ret=0

return ret
