#compdef locust
# Documentation: https://docs.locust.io/en/stable/configuration.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --locustfile)'{-f+,--locustfile=}'[locustfile]:file:_files -g "*.py"' \
  '--config=[config file]:file:_files' \
  '(-H --host)'{-H+,--host=}'[host URL]:url:' \
  '(-u --users)'{-u+,--users=}'[concurrent users]:n:' \
  '(-r --spawn-rate)'{-r+,--spawn-rate=}'[spawn rate]:n:' \
  '(-t --run-time)'{-t+,--run-time=}'[run time]:t:' \
  '(-l --list)'{-l,--list}'[list user classes]' \
  '--web-host=[web host]:host:' \
  '--web-port=[web port]:port:' \
  '(-P --port)'{-P+,--port=}'[port]:port:' \
  '--headless[no web UI]' \
  '--master[master mode]' \
  '--worker[worker mode]' \
  '--master-bind-host=[bind host]:host:' \
  '--master-bind-port=[bind port]:port:' \
  '--master-host=[master host]:host:' \
  '--master-port=[master port]:port:' \
  '--expect-workers=[expected workers]:n:' \
  '--expect-workers-max-wait=[max wait]:t:' \
  '--processes=[processes]:n:' \
  '--csv=[CSV prefix]:p:' \
  '--csv-full-history[full history]' \
  '--print-stats[print stats]' \
  '--only-summary[only summary]' \
  '--reset-stats[reset stats]' \
  '--html=[HTML report]:file:_files' \
  '--json[JSON output]' \
  '--loglevel=[log level]:l:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--logfile=[log file]:file:_files' \
  '--show-task-ratio[show task ratio]' \
  '--show-task-ratio-json[task ratio JSON]' \
  '(-s --stop-timeout)'{-s+,--stop-timeout=}'[stop timeout]:s:' \
  '--equal-weights[equal weights]' \
  '--enable-rebalancing[enable rebalancing]' \
  '--exit-code-on-error=[exit code]:n:' \
  '(-T --tags)'{-T+,--tags=}'[tags to include]:tags:' \
  '(-E --exclude-tags)'{-E+,--exclude-tags=}'[tags to exclude]:tags:' \
  '--profile=[profile]:p:' \
  '--web-auth=[user\:pass]:auth:' \
  '--tls-cert=[TLS cert]:file:_files' \
  '--tls-key=[TLS key]:file:_files' \
  '--class-picker[class picker]' \
  '--web-base-path=[base path]:p:' \
  '--legacy-ui[legacy UI]' \
  '--codegen[code generator]' \
  '--autostart[autostart]' \
  '--autoquit=[autoquit s]:s:' \
  '*:UserClass:' && ret=0

return ret
