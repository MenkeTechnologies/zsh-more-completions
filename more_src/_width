#compdef width
# Documentation: https://man.archlinux.org/search?q=width
# Reference accessed: 2026-05-16

# align formula (Homebrew) installs `width` — column filter; `width -h`

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-h[help]' \
  '-a[option]' -A[option] -p[option] -c[option] -w[option] -f[option] -n[option] -l[option] \
  '*:args:_default' && ret=0

return ret
