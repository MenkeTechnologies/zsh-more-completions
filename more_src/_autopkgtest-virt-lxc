#compdef autopkgtest-virt-lxc
# _autopkgtest-virt-lxc — LXC virtualisation backend for autopkgtest (Debian/autopkgtest)
# upstream: https://salsa.debian.org/ci-team/autopkgtest
# Flags from autopkgtest-virt-lxc(1) man page.

_autopkgtest-virt-lxc() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-e --ephemeral)'{-e,--ephemeral}'[use lxc-start-ephemeral overlay containers]' \
        '(-s --sudo)'{-s,--sudo}'[run lxc-* commands through sudo]' \
        '--name=[custom temporary container name]:name:' \
        '--disk-limit=[disk limit for container root]:size:' \
        '(-d --debug)'{-d,--debug}'[enable debugging output]' \
        '1:LXC container template:'
}

_autopkgtest-virt-lxc "$@"
