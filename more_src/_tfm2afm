#compdef tfm2afm
# Documentation: https://man.archlinux.org/search?q=tfm2afm
# Reference accessed: 2026-05-16

# tfm2afm: convert TeX Font Metric to Adobe Font Metric format
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[verbose]' \
  '-help[show help]' \
  '*:TFM file and output AFM file:_files -g "*.(tfm|afm)"' && ret=0
return ret
