#compdef ApplyBQSRSpark
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/spark/ApplyBQSRSpark.java
# Apply base quality score recalibration on Spark

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-I,--input}'=[BAM/SAM/CRAM read file]:bam:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '(-O --output)'{-O,--output}'=[the output bam]:output:_files' \
  '(-bqsr --bqsr-recal-file)'{-bqsr,--bqsr-recal-file}'=[input covariates table for recalibration]:table:_files' \
  '*--static-quantized-quals=[use static quantized quality scores to N levels]:n:' \
  '--round-down-quantized[round down quantized quality scores]' \
  '--preserve-qscores-less-than=[do not recalibrate bases below this quality]:q:' \
  '(-OQ --use-original-qualities)'{-OQ,--use-original-qualities}'[use base quality scores from the OQ tag]' \
  '*'{-L,--intervals}'=[genomic intervals to operate over]:intervals:' \
  '--spark-master=[URL of the Spark master to submit jobs to]:url:' \
  '--num-reducers=[number of reducers for Spark]:n:' \
  '*--conf=[Spark property name=value]:conf:' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam:_files' && ret=0

return ret
