#compdef vcfannotate
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfannotate.md
# Annotate VCF records with INFO fields from a BED file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bed)'{-b,--bed}'[use annotations provided by this BED file]:BED file:_files -g "*.bed"' \
  '(-k --key)'{-k,--key}'[use this INFO field key for the annotations]:key' \
  '(-d --default)'{-d,--default}'[INFO field key for records without annotations]:default' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
