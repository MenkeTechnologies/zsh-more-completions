#compdef tincd
# Documentation: https://man.archlinux.org/search?q=tincd
# Reference accessed: 2026-05-16

_arguments -s \
  '(-c --config)'{-c,--config}'=[config dir]:dir:_files -/' \
  '(-D --no-detach)'{-D,--no-detach}'[do not detach]' \
  '(-d --debug)'{-d,--debug}'=[debug level]:level:' \
  '(-k --kill)'{-k,--kill}'=[kill running daemon]:signal:' \
  '(-n --net)'{-n,--net}'=[network name]:name:' \
  '(-K --generate-keys)'{-K,--generate-keys}'=[generate RSA keys]:bits:' \
  '*'{-o,--option}'=[set option]:[host.]key=value:' \
  '(-L --mlock)'{-L,--mlock}'[lock memory]' \
  '--logfile=[log file]:file:_files' \
  '--pidfile=[PID file]:file:_files' \
  '--bypass-security[bypass security]' \
  '(-R --chroot)'{-R,--chroot}'[chroot]' \
  '(-U --user)'{-U,--user}'=[user]:user:_users' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]'
