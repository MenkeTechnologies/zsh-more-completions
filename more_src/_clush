#compdef clush

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-s[roles source]:source:' \
  '-w[target hosts]:host list:_hosts' \
  '-x[exclude hosts]:host list:_hosts' \
  '-a[target all hosts in default group]' \
  '-g[target hosts in group]:group:' \
  '-X[exclude hosts in group]:group:' \
  '-b[gather and display identical output]' \
  '-B[like -b but wait for all output before displaying]' \
  '-N[disable hostname prefixing on output]' \
  '-S[return max exit status of remote commands]' \
  '-q[quiet mode, print just results]' \
  '-v[verbose mode]' \
  '-d[debug mode]' \
  '-f[set fanout, max concurrent connections]:fanout:' \
  '-u[set command timeout]:seconds:' \
  '-t[set connect timeout]:seconds:' \
  '-l[remote username]:username:_users' \
  '-o[ssh options]:options:' \
  '-p[copy local file to remote hosts]:source:_files' \
  '--dest[destination path for -p]:destination:_files -/' \
  '-R[roles source]:source:' \
  '--color[colorize output]:when:(auto never always)' \
  '--diff[show diff between gathered outputs]' \
  '-L[disable header block output]' \
  '*:command:' && ret=0

return ret
