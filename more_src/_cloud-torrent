#compdef cloud-torrent
# =============================================================================
# cloud-torrent — Cloud Torrent: a self-hosted remote torrent client written
#                 in Go.  Runs as a server-side daemon that downloads torrent
#                 files to local disk on the server, exposes a web UI for
#                 magnet-link submission, search-engine integration, and
#                 download monitoring.  Designed to run on cheap VPS or
#                 seedbox hardware with limited resources — single Go binary,
#                 embedded React UI, no external dependencies beyond the
#                 Go runtime.
#
# Author:  Jaime Pillora (jpillora)
# Source:  https://github.com/jpillora/cloud-torrent
# CLI:     main.go + server/server.go (uses jpillora/opts)
# Library: jpillora/opts
#          ("Go package for building frictionless command-line interfaces")
# License: AGPL-3.0
# Status:  Stable — 6,226+ stars; one of the most-deployed seedbox
#          self-hosted apps; widely packaged across Docker Hub,
#          Unraid Community Apps, Synology DSM, and FreeNAS plugins.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 27 LIBRARIES
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 27TH Go CLI library variant.  Go climbs from 26 to 27 documented libraries
# (opts via cloud-torrent).  New leaderboard: Rust=27, Go=27 (TWO-WAY TIE),
# TypeScript-Node=26.  Taxonomy now spans 218 cross-language CLI library
# variants across 52 documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS jpillora/opts AND WHY IS IT A DISTINCT 27TH GO CLI LIBRARY VARIANT?
#
# opts (https://github.com/jpillora/opts, 170+ stars) is Jaime Pillora's
# command-line library for Go.  Jaime is also the author of **chisel**
# (16,063+ stars — fast TCP/UDP tunnel over HTTP), **cloud-torrent** (this
# completion, 6,226 stars), and many other well-known Go tools.  opts
# powers ALL of his CLIs and a substantial third-party ecosystem.
#
# opts's design philosophy is "FRICTIONLESS": minimize the boilerplate
# required to wire up a CLI to a Go struct.  Most Go CLI libraries require
# you to:
#   1. Define a struct with your config
#   2. Add tags or register flags with a library
#   3. Call a parse function
#   4. Wire defaults manually
# opts collapses steps 1-4 into a single pattern:
#
#   var cfg = MyStruct{
#       Port: 8080,                              // <-- default
#       ConfigPath: "myapp.json",                 // <-- default
#   }
#   opts.New(&cfg).Version(v).Parse()
#
# Defaults are READ FROM THE STRUCT'S INITIALIZED FIELDS.  No `default:""`
# tag, no separate Set call, no factory function — just initialize the
# struct as you normally would in Go.
#
# opts is DISTINCT from every other documented Go CLI library on SIX axes:
#
#   1. STRUCT-FIELD-INITIALIZER-AS-DEFAULT — the most distinctive feature.
#      opts reads the struct's PRE-PARSE field values and uses them as
#      flag defaults.  This is the FIRST documented Go CLI library where
#      defaults are EXPRESSED IN IDIOMATIC GO LITERAL SYNTAX rather than
#      in struct tags or builder calls.  Compare:
#        kong (R465):     `\`default:"main"\`` tag
#        go-arg (R475):   `\`default:"main"\`` tag
#        clap-derive:     `#[arg(default_value = "main")]` attribute
#        cobra/urfave:    `cli.StringFlag{Value: "main"}`
#      opts:             `var cfg = Cfg{Output: "main"}` (plain Go)
#
#   2. AUTOMATIC CamelCase-TO-kebab-case CONVERSION — `ConfigPath` field
#      becomes `--config-path` flag.  Same as Kong (R465) but DIFFERENT
#      from go-arg (R475) which uses lowercase concatenation
#      (`--configpath`).  opts produces the most Unix-conventional flag
#      names of any struct-tag Go CLI library.
#
#   3. MINIMAL TAG VOCABULARY — opts uses only THREE common struct tags:
#        help:"description"          — usage text
#        env:"VAR_NAME"              — env-var fallback
#        short:"x"                   — single-char short alias
#      Compare Kong's tag vocabulary (R465: ~15 tags), go-arg's (~8 tags).
#      opts intentionally limits its struct tag surface.
#
#   4. .PkgRepo() AUTO-DETECTS GitHub REPO — opts has a `.PkgRepo()`
#      method that uses Go's runtime caller introspection to find the
#      calling package's import path, then derives the GitHub URL from
#      it.  The URL is included in the --help output as a "Read more at"
#      footer.  This is UNIQUE among Go CLI libraries — no other one
#      auto-detects the GitHub repo.
#
#   5. EMBEDDED STRUCTS AS SUBCOMMANDS — opts treats embedded struct
#      fields as SUBCOMMAND groups.  If your top-level Args struct has
#      an embedded `Server struct { Port int }`, opts adds a `server`
#      subcommand that accepts `--port`.  Compare Kong's explicit
#      `cmd:""` tag; opts uses Go's struct embedding semantics directly.
#
#   6. .SetLineWidth() FOR --help FORMATTING — opts has explicit help-
#      output line-width control (default 96 chars).  This is unusual
#      detail-level control; most Go CLI libraries either hardcode 80
#      or auto-detect terminal width via golang.org/x/term.
#
# THE opts API SURFACE (from cloud-torrent usage)
#
#   import "github.com/jpillora/opts"
#
#   // Define struct (defaults from initialization)
#   type Server struct {
#       Title      string `help:"Title of this instance" env:"TITLE"`
#       Port       int    `help:"Listening port" env:"PORT"`
#       Host       string `help:"Listening interface (default all)"`
#       Auth       string `help:"Optional basic auth user:password" env:"AUTH"`
#       ConfigPath string `help:"Configuration file path"`
#       KeyPath    string `help:"TLS Key file path"`
#       CertPath   string `help:"TLS Certicate file path" short:"r"`
#       Log        bool   `help:"Enable request logging"`
#       Open       bool   `help:"Open now with your default browser"`
#   }
#
#   func main() {
#       s := Server{
#           Title:      "Cloud Torrent",    // default
#           Port:       3000,                // default
#           ConfigPath: "cloud-torrent.json", // default
#       }
#       o := opts.New(&s)        // construct parser, link to struct
#       o.Version(version)        // set --version output
#       o.PkgRepo()               // auto-detect GitHub repo, add to help
#       o.SetLineWidth(96)        // help output width
#       o.Parse()                 // parse argv into &s
#
#       s.Run(version)            // run with populated struct
#   }
#
# Method chain on the parser:
#   .New(&struct)             — link parser to a Go struct
#   .Name(string)             — override binary name
#   .Version(string)          — set --version
#   .Description(string)      — long description for --help
#   .PkgRepo()                — auto-detect GitHub repo URL
#   .SetLineWidth(int)        — --help line width
#   .Repo(url)                — manually set repo URL
#   .ConfigPath(path)         — load defaults from JSON file
#   .UseEnv()                 — enable env-var fallback for all flags
#   .Parse()                  — parse os.Args[1:]
#   .ParseArgs([]string)      — parse arbitrary slice
#
# Struct tag vocabulary:
#   help:"..."                — flag description
#   env:"VAR_NAME"            — environment variable fallback
#   short:"x"                 — single-character short alias
#   name:"..."                — override flag name (rare)
#
# CONTRAST WITH OTHER STRUCT-TAG-DRIVEN GO CLI LIBRARIES
#
#   * jessevdk/go-flags          — verbose tag vocabulary, POSIX-getopt
#   * alecthomas/kong (R465)     — extensive tag vocabulary, auto-Run()
#   * alexflint/go-arg (R475)    — minimal tag, lowercase concat names
#   * jpillora/opts (THIS)       — struct-initialization-as-default,
#                                  CamelCase-to-kebab, auto-repo-link
#
# opts is the SIMPLEST of these for the common case (small struct, a
# few flags, default values).  Where Kong is "feature-rich struct-tag
# parser" and go-arg is "MustParse-in-one-line", opts is "Go struct
# literal syntax becomes the CLI definition."
#
# REAL-WORLD opts USERS:
#
#   * jpillora/cloud-torrent — self-hosted torrent (THIS, 6226*)
#   * jpillora/chisel — TCP/UDP tunnel over HTTP (16063* — already in corpus)
#   * jpillora/media-sort — automatic movie/TV organizer (129*)
#   * reearth/reearth-visualizer — Re-earth visualizer
#   * theovassiliou/hc2-tools — Fibaro HC2 home automation
#   * CastawayEGR/traefik-certificate-manager — Traefik cert manager
#   * daaku/iosphotobackup — iOS photo backup
#   * gmwxio/wx, godna, lcmd — Walter Mendoza tooling
#   * Project-PLATEAU/PLATEAU-VIEW-2.0 — Japanese urban planning platform
#   * SR-G/sleep-on-lan (also a flaggy user)
#   * theovassiliou/base64url, doctrans
#   * many more — opts is one of the most-imported "alternative" Go CLI
#     libraries in the niche between cobra (huge) and flag (tiny).
#
# -----------------------------------------------------------------------------
# CLOUD-TORRENT'S CLI SURFACE (verbatim from server/server.go Server struct)
# -----------------------------------------------------------------------------
#
# USAGE:
#   cloud-torrent [OPTIONS]
#
# Server-listing:
#   --title <TITLE>             Title of this instance
#                               (default: "Cloud Torrent"; env: TITLE)
#   -p, --port <PORT>           Listening port
#                               (default: 3000; env: PORT)
#   -h, --host <HOST>           Listening interface (default: all interfaces)
#   --auth <USER:PASS>          Optional basic auth in form 'user:password'
#                               (env: AUTH)
#   --config-path <PATH>        Configuration file path
#                               (default: "cloud-torrent.json")
#
# TLS:
#   --key-path <PATH>           TLS Key file path
#   -r, --cert-path <PATH>      TLS Certificate file path
#
# Behavior:
#   --log                       Enable request logging
#   --open                      Open now with your default browser
#
# Standard:
#   --help                      Show help and exit
#   --version                   Show version and exit
#
# Configuration file (cloud-torrent.json):
#   {
#       "Title": "...",
#       "Port": 3000,
#       "Host": "",
#       "Auth": "user:pass",
#       "KeyPath": "/path/to/key.pem",
#       "CertPath": "/path/to/cert.pem",
#       "Log": true,
#       "Open": false
#   }
#
# Environment variables (auto-bound via env:""):
#   TITLE                       Server title
#   PORT                        Listening port
#   AUTH                        Basic auth user:password
#
# =============================================================================

_cloud-torrent() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s \
        '--title[title of this instance]:title:' \
        '(-p --port)'{-p,--port}'[listening port]:port:_ports' \
        '(-h --host)'{-h,--host}'[listening interface (default all)]:host:_hosts' \
        '--auth[basic auth user\:password]:user\:password:' \
        '--config-path[configuration file path]:config file:_files' \
        '--key-path[TLS Key file path]:key file:_files' \
        '(-r --cert-path)'{-r,--cert-path}'[TLS Certificate file path]:cert file:_files' \
        '--log[enable request logging]' \
        '--open[open in default browser]' \
        '--help[show help and exit]' \
        '--version[show version and exit]' \
        && ret=0

    return ret
}

_cloud-torrent "$@"
