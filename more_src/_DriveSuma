#compdef DriveSuma
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/DriveSuma.html
# Drive AFNI SUMA from the command line

local ret=1

_arguments -s \
  '*-com[send command to SUMA]:command' \
  '-echo_edu[echo the command line for education]' \
  '-echo_nel_stdout[echo NIML object to stdout]' \
  '-echo_nel_stderr[echo NIML object to stderr]' \
  '-echo_nel[write NIML elements to file]:file:_files' \
  '-examples[display sample commands and exit]' \
  '-help_nido[help for NIML displayable objects]' \
  '-C_demo[run preset demo commands]' \
  '-onestate[make all input surfaces share one state]' \
  '-anatomical[label surfaces as anatomically correct]' \
  '-novolreg[ignore transforms in surface volume]' \
  '-noxform[same as -novolreg]' \
  '-setenv[set environment variable]:var' \
  '-trace[enable debug and memory tracing]' \
  '-TRACE[extreme tracing]' \
  '-nomall[disable memory tracing]' \
  '-yesmall[enable memory tracing]' \
  '(-h -help)-h[condensed help]' \
  '(-h -help)-help[full help]' && ret=0

return ret
