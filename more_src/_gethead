#compdef gethead
# Documentation: http://tdc-www.harvard.edu/software/wcstools/
# gethead: print FITS and IRAF image header keyword values (WCSTools)

local ret=1

_arguments -s -S \
  '-a[list file name even if keywords are not found]' \
  '-d[root directory for input files]:directory:_files -/' \
  '-e[output keyword values as keyword=value, one line per file]' \
  '-f[never print filenames]' \
  '-h[print column headings in order]' \
  '-m[reset maximum number of keyword names read from command line]' \
  '-n[set number of decimal places in numeric output]:decimals' \
  '-p[print full pathnames of input files at start of each line]' \
  '-t[print output in tab-separated table format with column headers]' \
  '-u[print ___ if a keyword is not found or value is null]' \
  '-v[print more information about process]' \
  '*:FITS file or keyword:_files -g "*.(fits|fit|fts|FITS|FIT|FTS|imh)"' && ret=0

return ret
