#compdef susynlv
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/synthetics_waveforms_testpatterns/susynlv.c
# Synthetic seismograms for linear velocity function

local ret=1

_arguments -s -S \
  'nt=[number of time samples]:nt' \
  'dt=[time sampling interval (sec)]:dt' \
  'ft=[first time (sec)]:ft' \
  'kilounits=[input length units are km or kilo-feet; =0 for m or ft]:kilounits:(0 1)' \
  'nxo=[number of source-receiver offsets]:nxo' \
  'dxo=[offset sampling interval (kilounits)]:dxo' \
  'fxo=[first offset (kilounits)]:fxo' \
  'xo=[array of offsets for non-uniform offsets]:xo' \
  'nxm=[number of midpoints]:nxm' \
  'dxm=[midpoint sampling interval (kilounits)]:dxm' \
  'fxm=[first midpoint (kilounits)]:fxm' \
  'nxs=[number of shotpoints]:nxs' \
  'dxs=[shotpoint sampling interval (kilounits)]:dxs' \
  'fxs=[first shotpoint (kilounits)]:fxs' \
  'x0=[distance x at which v00 is specified]:x0' \
  'z0=[depth z at which v00 is specified]:z0' \
  'v00=[velocity at x0,z0 (kilounits/sec)]:v00' \
  'dvdx=[derivative of velocity with distance x]:dvdx' \
  'dvdz=[derivative of velocity with depth z]:dvdz' \
  'fpeak=[peak frequency of symmetric Ricker wavelet (Hz)]:fpeak' \
  'ref=[reflector(s): amplitude:x1,z1;x2,z2;...]:ref' \
  'smooth=[=1 for smooth (piecewise cubic spline) reflectors]:smooth:(0 1)' \
  'er=[=1 for exploding reflector amplitudes]:er:(0 1)' \
  'ls=[=1 for line source; default is point source]:ls:(0 1)' \
  'ob=[=1 to include obliquity factors]:ob:(0 1)' \
  'tmin=[minimum time of interest (sec)]:tmin' \
  'ndpfz=[number of diffractors per Fresnel zone]:ndpfz' \
  'verbose=[=1 to print some useful information]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
