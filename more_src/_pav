#compdef pav
# Documentation: http://psrchive.sourceforge.net/manuals/pav/
# PSRCHIVE: produce a wide variety of plots from archives.

local ret=1

_arguments -s -S \
  '-h[show full list of options]' \
  '-N+[partition view panel into a grid of panels]:rows,cols:' \
  '-D[display single integrated pulse profile]' \
  '-F[frequency scrunch before plotting]' \
  '-T[time scrunch before plotting]' \
  '-p[combine phase bins before plotting]' \
  '-S[view integrated profile with polarization]' \
  '--publn[format labels and headers for publication]' \
  '*:archive:_files' && ret=0

return ret
