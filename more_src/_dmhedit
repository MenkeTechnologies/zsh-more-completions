#compdef dmhedit
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmhedit.html
# Edit the header keywords of a Data Model file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input dataset]:infile:_files' \
  'filelist=[ASCII edit list file]:filelist:_files' \
  'operation=[add/change or delete the key]:operation:(add delete)' \
  'key=[keyword to change]:key:' \
  'value=[value of the keyword]:value:' \
  'datatype=[datatype of the keyword value]:datatype:(indef string real integer boolean)' \
  'unit=[unit of the value]:unit:' \
  'comment=[keyword comment]:comment:' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
