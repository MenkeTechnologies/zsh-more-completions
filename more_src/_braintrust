#compdef braintrust bt
# Documentation: https://www.braintrust.dev/docs/reference/cli/overview
# Reference accessed: 2026-05-22
# Verified: CLI overview command table and npm package bin braintrust.

# Zsh completion for braintrust / bt - Braintrust eval and data CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--json[JSON output]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'braintrust command' \
      'eval[run evaluation files]' \
      'sql[run SQL queries]' \
      'sync[sync logs experiments datasets]' \
      'functions[manage Braintrust functions]' \
      'projects[manage projects]' \
      'prompts[manage prompts]' \
      'tools[manage tools]' \
      'topics[manage Topics automations]' && ret=0
    ;;
  args)
    case $line[1] in
      eval)
        _arguments \
          '--watch[re-run on file changes]' \
          '--filter[evaluator name filter]:name:' \
          '--first[run first N examples]:n:' \
          '--sample[random sample N examples]:n:' \
          '--runner[runner binary]:runner:' \
          '--language[force language]:lang:(js py)' \
          '--no-input[non-interactive]' \
          '--dev[start local eval dev server]' \
          '*:path or glob:_files' && ret=0
        ;;
      sync)
        _values 'sync action' pull push status && ret=0
        ;;
      functions)
        _values 'functions action' list view invoke delete push pull && ret=0
        ;;
      projects|prompts|tools|topics)
        _arguments '*:subcommand:' && ret=0
        ;;
      sql)
        _arguments '*:query:' && ret=0
        ;;
    esac
    ;;
esac

return ret
