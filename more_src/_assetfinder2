#compdef assetfinder2
# _assetfinder2 — TomNomNom Tom Hudson assetfinder2 CLI command-line frontend wrapping the assetfinder find domains and subdomains potentially related to a given domain open-source written in Go DNS-DB DNSDumpster crt.sh ThreatCrowd CertSpotter HackerTarget AlienVault-OTX Wayback-Machine bevigil ipinfo subdomain-enumeration FB-CT-graph-api passive (TomNomNom team, Go); flag
# upstream: https://github.com/tomnomnom/assetfinder

_assetfinder2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-subs-only[subdomains only]' \
        '*:domain:'
}

_assetfinder2 "$@"
