#compdef aflnet-replay
# _aflnet-replay — replay AFLnet network testcases against a target server (aflnet/aflnet)
# upstream: https://github.com/aflnet/aflnet
# Args from aflnet-replay.c.

_aflnet-replay() {
    _arguments \
        '1:testcase file:_files' \
        '2:protocol:(RTSP FTP MQTT DNS DTLS12 DICOM SMTP SSH TLS SIP HTTP IPP SNMP TFTP NTP DAAP-MPD PJSIP)' \
        '3:port:'
}

_aflnet-replay "$@"
