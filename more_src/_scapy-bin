#compdef scapy
# _scapy-bin — Scapy interactive packet manipulation REPL (Philippe Biondi et al, Python); craft, dissect, send arbitrary packets
# upstream: https://github.com/secdev/scapy

_scapy-bin() {
    _arguments \
        '-h[show help]' \
        '-d[increase debug level]' \
        '-H[interactive mode]' \
        '-s+[session file]:file:_files' \
        '-c+[startup script]:file:_files' \
        '-P+[preload module]:module:' \
        '-C[disable colors]' \
        '-N[no use of /etc/scapy/preconf.py]' \
        '*::args:'
}

_scapy-bin "$@"
