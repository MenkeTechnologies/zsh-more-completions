#compdef amixer
# Documentation: https://manpages.debian.org/amixer.1
# Source: alsa-utils — CLI mixer control + scripting interface.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '-c[card number to control]:card:' \
    '-D[device name to control]:device:' \
    '(-s --stdin)'{-s,--stdin}'[read commands from stdin line-by-line]' \
    '(- *)-h[show syntax]' \
    '-q[quiet (do not show change results)]' \
    '(-R -M)-R[raw value for percentage representation]' \
    '(-R -M)-M[mapped volume for percentage representation]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'help:show syntax'
            'info:mixer device info'
            'scontrols:list simple mixer controls'
            'scontents:list simple mixer controls with contents'
            'set:set simple mixer control contents'
            'sset:set simple mixer control contents (alias)'
            'get:show simple mixer control contents'
            'sget:show simple mixer control contents (alias)'
            'controls:list card controls'
            'contents:list card controls with contents'
            'cset:set card control contents'
            'cget:show card control contents'
            'sevents:show events for simple mixer controls'
            'events:show events for mixer controls'
        )
        _describe -t subcmds 'amixer command' subcmds && ret=0
        ;;
    args)
        _default
        ;;
esac

return ret
