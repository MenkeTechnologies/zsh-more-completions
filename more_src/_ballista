#compdef ballista ballista-cli
# _ballista — Apache Arrow Ballista distributed SQL engine CLI (Apache Arrow team, Rust); clap-rs
# upstream: https://github.com/apache/arrow-ballista

_ballista() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--host=+[scheduler host]:host:_hosts' \
        '-c+[scheduler host]:host:_hosts' \
        '--port=+[scheduler port]:port:' \
        '-p+[scheduler port]:port:' \
        '--data-path=+[data path]:dir:_files -/' \
        '-d+[data path]:dir:_files -/' \
        '--file=+[file to execute]:file:_files -g "*.sql"' \
        '-f+[file to execute]:file:_files -g "*.sql"' \
        '--rc=+[rc file]:file:_files' \
        '--output-format=+[output format]:fmt:(table csv tsv json automatic)' \
        '--format=+[output format]:fmt:(table csv tsv json automatic)' \
        '--batch-size=+[batch size]:n:' \
        '-b+[batch size]:n:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '*:arg:'
}

_ballista "$@"
