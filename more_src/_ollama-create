#compdef ollama-create
# Documentation: https://github.com/ollama/ollama/blob/main/cmd/cmd.go
# Reference accessed: 2026-05-20
# Verified: upstream cobra source for `ollama create`.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --file)'{-f+,--file=}'[path to Modelfile]:file:_files' \
  '--quantize=[quantization level]:level:(q4_0 q4_1 q5_0 q5_1 q8_0 f16 f32)' \
  '--draft-quantize=[draft model quantization level]:level:(q4_0 q4_1 q5_0 q5_1 q8_0 f16 f32)' \
  '--experimental[enable experimental features]' \
  '1:model name:' && return 0
