#compdef PropPDB
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools PropPDB: propagate a unit cell to build a supercell

local ret=1

_arguments -s -S \
  '-p[input PDB file (unit cell)]:file:_files -g "*.pdb"' \
  '-o[output PDB file (expanded cell)]:file:_files -g "*.pdb"' \
  '-ix[number of cells in x direction]:n:' \
  '-iy[number of cells in y direction]:n:' \
  '-iz[number of cells in z direction]:n:' \
  '*:file:_files' && ret=0

return ret
