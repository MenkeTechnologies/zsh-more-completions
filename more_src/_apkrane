#compdef apkrane
# Documentation: https://github.com/jonjohnsonjr/apkrane
# List and inspect APK packages from an APKINDEX.tar.gz

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'apkrane command' \
      'ls[list the *.apk files in an APKINDEX.tar.gz]' \
      'version[print the apkrane version]' && ret=0
    ;;
  args)
    case $line[1] in
      ls)
        _arguments -s \
          '--full[produce full URLs]' \
          '--json[output in JSON format for use with jq]' \
          '--latest[show only the most recent version of each package]' \
          {-P,--package-name}'=[filter results for a specific package name]:package' \
          '--auth=[authentication credentials (basic:domain:user:token)]:auth' \
          '*:apkindex:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
