#compdef pam
# Documentation: http://psrchive.sourceforge.net/manuals/pam/
# PSRCHIVE: command line general purpose data reduction (scrunch, modify archives).

local ret=1

_arguments -s -S \
  '-h[show summary of all options]' \
  '-m[modify the original file in place]' \
  '-e+[write modified copies with this extension]:ext:' \
  '-u+[write new archives to this location]:dir:_files -/' \
  '-F[frequency scrunch (collapse channels)]' \
  '-T[time scrunch (collapse subints)]' \
  '-p[polarization scrunch]' \
  '*:archive:_files' && ret=0

return ret
