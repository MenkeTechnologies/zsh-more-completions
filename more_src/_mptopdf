#compdef mptopdf
# Documentation: mptopdf --help (TeX Live 2026)
# Source: ConTeXt mptopdf — convert MetaPost output files (or pattern) to PDF.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*:MetaPost output file or pattern:_files -g "*.{mp,mpx,*}"' \
    && ret=0

return ret
