#compdef contentful contentful-cli
# Documentation: https://github.com/contentful/contentful-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Contentful CLI: binary is `contentful` (npm package `contentful-cli`).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:get started with Contentful'
  'login:authenticate via OAuth'
  'logout:end the session'
  'config:configure proxy / host / settings'
  'space:manage spaces'
  'export:export a space to JSON'
  'import:import a space from JSON'
  'seed:seed a space with example data'
  'migration:execute migration scripts'
  'extension:manage UI extensions'
  'organization:organization-level operations'
  'app:manage Contentful apps'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--proxy=[HTTP proxy URL]:url:' \
  '--rawProxy[use raw proxy mode]' \
  '--host=[management API host]:host:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'contentful command' commands && ret=0 ;;
esac

return ret
