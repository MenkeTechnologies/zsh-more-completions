#compdef smath
# _smath — The Document Foundation LibreOffice smath CLI symlink launching LibreOffice Math the formula editor opening .odf .mml .smath documents for MathML scientific equation formula authoring inside or embedded as OLE objects in Writer Calc Impress documents with options for headless convert-to MML PDF export (LibreOffice team, C++); getopt
# upstream: https://www.libreoffice.org/

_smath() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--writer[start as Writer]' \
        '--calc[start as Calc]' \
        '--draw[start as Draw]' \
        '--impress[start as Impress]' \
        '--base[start as Base]' \
        '--math[start as Math]' \
        '--show=+[file]:file:_files' \
        '--view=+[file]:file:_files' \
        '--norestore[no restore]' \
        '--nologo[no logo]' \
        '--nodefault[no default doc]' \
        '--invisible[no UI window]' \
        '--headless[headless mode]' \
        '--accept=+[connection string]:str:' \
        '--language=+[lang]:str:' \
        '--safe-mode[safe mode]' \
        '--convert-to+[output filter]:str:' \
        '--outdir=+[dir]:dir:_files -/' \
        '*:formula:_files -g "*.odf *.mml *.smath *.fodf *.sxm"'
}

_smath "$@"
