#compdef cqp
# Documentation: https://cwb.sourceforge.io/documentation.php
# IMS Corpus Query Processor interactive query tool

local ret=1

_arguments -s -S \
  '-h[help]' \
  '-v[version and copyright information]' \
  '-r[use dir as default registry]:dir:_files -/' \
  '-l[store/load subcorpora in dir]:dir:_files -/' \
  '-I[read file as init file]:file:_files' \
  '-M[read macro definitions from file]:file:_files' \
  '-m[disable macro expansion]' \
  '-e[enable input line editing]' \
  '-C[enable ANSI colours]' \
  '-f[execute commands from file (batch mode)]:file:_files' \
  '-p[turn pager off]' \
  '-P[use program to display query results]:pager' \
  '-s[auto subquery mode]' \
  '-c[child process mode]' \
  '-i[print matching ranges only (binary output)]' \
  '-W[show num chars to the left and right of match]:n' \
  '-L[show num chars to the left of match]:n' \
  '-R[show num chars to the right of match]:n' \
  '-D[set default corpus to corpus]:corpus' \
  '-b[set hard boundary for kleene star to num tokens]:n' \
  '-x[insecure mode (when run SETUID)]' \
  '-d[activate/deactivate debug mode]:mode' \
  '*:corpus:' && ret=0

return ret
