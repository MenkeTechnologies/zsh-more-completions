#compdef paimon

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'compact:compact a Paimon table'
  'compact_database:compact all tables in a database'
  'clone:clone a Paimon table'
  'delete:delete rows matching a predicate'
  'drop_partition:drop partitions'
  'drop_database:drop a database'
  'expire_partitions:expire partitions older than threshold'
  'expire_snapshots:expire old snapshots'
  'expire_tags:expire tags'
  'create_tag:create a tag'
  'create_tag_from_timestamp:create a tag from a timestamp'
  'create_tag_from_watermark:create a tag from watermark'
  'delete_tag:delete a tag'
  'replace_tag:replace a tag'
  'create_branch:create a branch'
  'delete_branch:delete a branch'
  'fast_forward_branch:fast-forward a branch'
  'merge_branch:merge a branch'
  'merge_into:MERGE INTO a target table'
  'migrate_database:migrate a database'
  'migrate_table:migrate a table'
  'migrate_iceberg_table:migrate from an Iceberg table'
  'query_service:start a query service'
  'repair:repair table metadata'
  'rescale:rescale a table'
  'rewrite_file_index:rewrite the file index'
  'rollback_to:rollback to a snapshot or tag'
  'remove_orphan_files:remove orphan files'
  'mark_partition_done:mark partitions as done'
  'dispatcher:CDC dispatcher'
  'kafka_sync_table:sync a Kafka topic to a table'
  'kafka_sync_database:sync Kafka topics to a database'
  'mongodb_sync_table:sync MongoDB to a table'
  'mongodb_sync_database:sync MongoDB to a database'
  'mysql_sync_table:sync MySQL to a table'
  'mysql_sync_database:sync MySQL to a database'
  'postgres_sync_table:sync PostgreSQL to a table'
  'postgres_sync_database:sync PostgreSQL to a database'
  'pulsar_sync_table:sync Pulsar to a table'
  'pulsar_sync_database:sync Pulsar to a database'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--warehouse=[warehouse path]:path:_files -/' \
  '--database=[database name]:db:' \
  '--table=[table name]:tbl:' \
  '*--catalog_conf=[catalog config key=value]:conf:' \
  '*--table_conf=[table config key=value]:conf:' \
  '*--partition=[partition spec]:partition:' \
  '--force_start_flink_job[force start the Flink job]' \
  '1: :->action' \
  '*::arg:->args' && ret=0

case $state in
  (action)
    _describe -t actions 'paimon action' actions && ret=0
    ;;
esac

return ret
