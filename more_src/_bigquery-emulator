#compdef bigquery-emulator
# Documentation: https://github.com/goccy/bigquery-emulator
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for bigquery-emulator
# Upstream: Emulate a GCP BigQuery server on your local machine

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--project=[project name]:project' \
  '--dataset=[dataset name]:dataset' \
  '--port=[HTTP port for BigQuery API]:port' \
  '--grpc-port=[gRPC port for BigQuery Storage API]:port' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--log-format=[log format]:format:(console json)' \
  '--database=[persistent database file path]:file:_files' \
  '--data-from-yaml=[seed data YAML file]:file:_files' \
  '*::file:_files' && ret=0

return ret
