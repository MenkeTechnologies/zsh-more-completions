#compdef bigquery-emulator

# Zsh completion for bigquery-emulator
# Upstream: Emulate a GCP BigQuery server on your local machine
# Conservative fallback — run `bigquery-emulator --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
