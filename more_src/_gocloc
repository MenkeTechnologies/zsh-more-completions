#compdef gocloc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--by-file[report results for every source file]' \
  '--debug[dump debug log]' \
  '--skip-duplicated[skip duplicate files]' \
  '--show-lang[print recognized languages]' \
  '--output-type=[output type]:type:(default cloc-xml sloccount json)' \
  '--include-lang=[include only specified languages]:languages:' \
  '--exclude-dir=[exclude directories]:directories:' \
  '--exclude-ext=[exclude file extensions]:extensions:' \
  '--match=[include files matching pattern]:regexp:' \
  '--not-match=[exclude files matching pattern]:regexp:' \
  '--match-d=[include directories matching pattern]:regexp:' \
  '--not-match-d=[exclude directories matching pattern]:regexp:' \
  '--sort=[sort by column]:column:(name files blank comment code)' \
  '--order=[sort order]:order:(asc desc)' \
  '*:directories:_directories' && ret=0

return ret
