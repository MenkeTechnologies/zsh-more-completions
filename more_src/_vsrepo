#compdef vsrepo
# Documentation: https://github.com/vapoursynth/vsrepo
# VapourSynth plugin/script package manager. Subcommands and flags from upstream README.

local ret=1

_arguments -s -S \
  '-p[target a portable VapourSynth installation]' \
  '-t[override platform]:platform:(win32 win64)' \
  '1:command:(install update upgrade-all uninstall installed available)' \
  '*:package:' && ret=0

return ret
