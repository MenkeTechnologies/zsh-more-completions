#compdef xemacs21

# xemacs21: XEmacs 21 - fork of Emacs (similar but not identical CLI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-q[skip init file]' \
  '-no-init-file[skip init file]' \
  '-no-site-file[skip site-start]' \
  '-debug-init[debug init]' \
  '-u[user]:user:_users' \
  '-user[user]:user:_users' \
  '-l[load file]:file:_files -g "*.el"' \
  '-load[load file]:file:_files -g "*.el"' \
  '-f[call function]:fn:' \
  '-funcall[call function]:fn:' \
  '-eval[evaluate expression]:expr:' \
  '-batch[batch mode]' \
  '-vanilla[no init files, no resources]' \
  '-nw[terminal mode]' \
  '-d[X display]:display:' \
  '-display[X display]:display:' \
  '-name[X resource class name]:name:' \
  '-title[window title]:title:' \
  '-geometry[geometry]:geom:' \
  '-fg[foreground colour]:colour:' \
  '-bg[background colour]:colour:' \
  '-font[font spec]:font:' \
  '-fn[font spec]:font:' \
  '*:file to edit:_files' && ret=0
return ret
