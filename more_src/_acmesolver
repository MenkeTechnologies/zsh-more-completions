#compdef acmesolver
# _acmesolver — cert-manager in-cluster HTTP-01 challenge solver pod (cert-manager/cert-manager)
# upstream: https://github.com/cert-manager/cert-manager
# Flags from cmd/acmesolver/app/app.go on tip.

_acmesolver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--listen-port=[HTTP listen port for the challenge response]:port:' \
        '--domain=[domain name being verified]:domain:' \
        '--token=[challenge token to verify against]:token:' \
        '--key=[challenge key to respond with]:key:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr[log to stderr]' \
        '--stderrthreshold=[stderr klog severity threshold]:level:(INFO WARNING ERROR FATAL)'
}

_acmesolver "$@"
