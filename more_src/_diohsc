#compdef diohsc
# _diohsc — diohsc Gemini protocol client (Haskell); line-based TUI client supporting bookmarks, history, client certs
# upstream: https://tildegit.org/sloum/diohsc

_diohsc() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-c+[config file]:file:_files' \
        '-s+[start URL]:url:_urls' \
        '--no-tls-verify[skip cert verification]' \
        '--client-cert+[client cert]:file:_files' \
        '--client-key+[client key]:file:_files' \
        '*:URL:_urls'
}

_diohsc "$@"
