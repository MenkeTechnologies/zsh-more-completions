#compdef arduino-fwuploader

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'firmware:firmware operations'
  'certificates:certificate operations'
  'version:show version'
)

_arguments -C \
  '*'{-F,--additional-fw-index=}'[additional firmware index URL]:url:' \
  '*'{-P,--additional-packages-index=}'[additional packages index URL]:url:' \
  '--format=[output format]:fmt:(text json)' \
  '--log-file=[log file]:file:_files' \
  '--log-format=[log format]:fmt:(text json)' \
  '--log-level=[log level]:level:(trace debug info warn error fatal panic)' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'arduino-fwuploader subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (firmware)
        _values 'firmware action' 'flash' 'get-version' 'list' && ret=0
        ;;
      (certificates)
        _values 'certificates action' 'flash' && ret=0
        ;;
    esac
    ;;
esac

return ret
