#compdef blastdbcmd
# Documentation: https://www.ncbi.nlm.nih.gov/books/NBK279684/
# Documentation: https://ftp.ncbi.nlm.nih.gov/blast/executables/blast+/LATEST/ (ncbi-blast-2.17.0+-src)
# Reference accessed: 2026-05-27
# Verified: upstream c++/src/app/blastdb/blastdbcmd.cpp (BLAST+ 2.17.0)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-help[show detailed help]' \
  '-version[show version]' \
  '-db=[BLAST database name]:dbname:' \
  '-dbtype=[molecule type stored in BLAST database]:type:(nucl prot guess)' \
  '-entry=[comma-delimited search string of sequence identifiers or all]:identifier:' \
  '-entry_batch=[input file for batch processing of entries]:file:_files' \
  '-ipg=[IPG to retrieve]:integer:' \
  '-ipg_batch=[input file for batch processing of IPGs]:file:_files' \
  '-info[print BLAST database information]' \
  '-metadata[generate BLAST database metadata]' \
  '-metadata_output_prefix=[path prefix for database files in metadata]:prefix:' \
  '-tax_info[print taxonomic information contained in this database]' \
  '-range=[range of sequence to extract in 1-based offsets (start-stop)]:range:' \
  '-strand=[strand of nucleotide sequence to extract]:strand:(plus minus)' \
  '-mask_sequence_with=[produce lower-case masked FASTA using algorithm ID]:algo_id:' \
  '-taxids=[comma-delimited taxonomy identifiers]:taxids:' \
  '-taxidlist=[input file with taxonomy identifiers]:file:_files' \
  '-no_taxid_expansion[do not expand taxonomy IDs to descendant taxonomy IDs]' \
  '-out=[output file name]:file:_files' \
  '-outfmt=[output format specifiers]:format:' \
  '-target_only[definition line should contain target entry only]' \
  '-get_dups[retrieve duplicate accessions]' \
  '-line_length=[line length for output]:number:' \
  '-ctrl_a[use Ctrl-A as the non-redundant defline separator]' \
  '-show_blastdb_search_path[display the default BLAST database search paths]' \
  '-list=[list BLAST databases in the specified directory]:directory:_files -/' \
  '-remove_redundant_dbs[remove databases referenced by another alias file]' \
  '-recursive[recursively traverse directory structure to list databases]' \
  '-list_outfmt=[output format for the list option]:format:' \
  '-exact_length[get exact length for db info]' \
  '-long_seqids[use long seq id for fasta deflines]' && ret=0

return ret
