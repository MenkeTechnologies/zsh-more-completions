(( $+functions[_cartog_commands] )) ||
_cartog_commands() {
    local commands; commands=(
'index:Build or rebuild the code graph index' \
'outline:Show symbols and structure of a file' \
'callees:Find what a symbol calls' \
'impact:Transitive impact analysis — what breaks if this changes?' \
'refs:All references to a symbol (calls, imports, inherits, references, raises)' \
'hierarchy:Show inheritance hierarchy for a class' \
'deps:File-level import dependencies' \
'stats:Index statistics summary' \
'config:Display the current configuration' \
'doctor:Check that requirements are met and everything is working' \
'search:Search symbols by name (case-insensitive prefix + substring match)' \
'map:Token-budget-aware codebase summary (file tree + top symbols by centrality)' \
'changes:Show symbols affected by recent git changes' \
'watch:Watch for file changes and auto-re-index' \
'serve:Start MCP server over stdio (for Claude Code, Cursor, and other MCP clients)' \
'rag:Semantic code search (RAG pipeline)' \
'self:Manage the cartog installation\: upgrade, inspect, roll back' \
'completions:Generate shell completions for bash, zsh, fish, elvish, or powershell' \
'manpage:Emit a troff-formatted manpage for \`cartog\` on stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'cartog commands' commands "$@"
}
