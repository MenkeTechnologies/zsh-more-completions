#compdef esensmap
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/esensmap/node4.html
# XMM-Newton SAS: calculate EPIC sensitivity map

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--detmasksets=[names of detection masks]:files:_files' \
  '--expimagesets=[names of exposure images]:files:_files' \
  '--bkgimagesets=[names of background maps]:files:_files' \
  '--sensimageset=[name of sensitivity image(s)]:file:_files' \
  '--outunit=[output sensitivity units]:unit:(rate flux both)' \
  '--ecf=[normalised energy conversion factors]:ecf:' \
  '--mlmin=[detection likelihood for upper limit calc]:like:' \
  '--statistic=[statistic type]:stat:(poisson deltac)' \
  '--energies=[mid-band energies to read the PSF]:energies:' \
  '--doff=[PSF off-axis angle step size (arcsec)]:arcsec:' \
  '--ecut=[half side length of PSF eval area (pixels)]:pixels:' \
  '*:file:_files' && ret=0

return ret
