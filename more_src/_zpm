#compdef zpm
# Documentation: https://github.com/zpm-zsh/zpm
# zpm - Zsh Plugin Manager

local ret=1

_arguments -C \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'load:download and load plugins'
      'if:conditionally load plugins'
      'if-not:conditionally load plugins when condition is false'
      'upgrade:upgrade all or specified plugins'
      'clean:remove the zpm cache'
    )
    _describe -t commands 'zpm command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      if|if-not)
        local -a conds
        conds=( linux bsd openwrt macos termux ssh vte )
        _describe -t conditions 'condition' conds && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
