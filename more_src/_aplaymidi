#compdef aplaymidi
# Documentation: https://manpages.debian.org/aplaymidi.1
# Source: alsa-utils — play Standard MIDI File(s) to ALSA sequencer ports.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print options]' \
    '(- *)'{-V,--version}'[print version]' \
    '(- *)'{-l,--list}'[list possible output ports]' \
    '(-p --port)'{-p+,--port=}'[sequencer port(s) "client:port,..."]:port:' \
    '(-u --ump)'{-u+,--ump=}'[MIDI version (0=legacy / 1=UMP MIDI 1.0 / 2=UMP MIDI 2.0)]:ver:(0 1 2)' \
    '(-d --delay)'{-d+,--delay=}'[seconds to wait after each MIDI file]:seconds:' \
    '*:.mid file:_files' \
    && ret=0

return ret
