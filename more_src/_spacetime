#compdef spacetime
# Documentation: https://spacetimedb.com/docs/cli-reference
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--version[Show CLI version]' \
  '--no-color[Disable ANSI colors]' \
  '--token=[Auth token for SpacetimeDB clouds]:token:' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'publish:Upload a WASM module'
      'call:Invoke a reducer'
      'sql:Run SQL queries'
      'logs:Tail database logs'
      'energy:Inspect Energy usage'
      'publish-start:Start build + publish pipeline locally'
      'dump:Export snapshots'
      'delete:Drop a database'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
