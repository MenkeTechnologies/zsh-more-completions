#compdef nuitka nuitka3

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--module[create an extension module]' \
  '--standalone[enable standalone mode]' \
  '--onefile[create a single executable file]' \
  '--python-flag=[python flags to use]:flag:(no_site no_warnings no_asserts no_docstrings)' \
  '--python-debug[use debug version of Python]' \
  '--python-for-scons=[path to Python for Scons]:python:_files' \
  '--main=[main entry point]:file:_files -g "*.py"' \
  '*--include-package=[include a whole package]:package' \
  '*--include-module=[include a single module]:module' \
  '*--include-plugin-directory=[include plugin directory]:directory:_directories' \
  '*--include-plugin-files=[include plugin files by pattern]:pattern' \
  '*--include-data-files=[include data files]:spec' \
  '*--include-data-dir=[include data directory]:spec' \
  '*--include-package-data=[include package data]:package' \
  '*--nofollow-import-to=[do not follow imports to module]:module' \
  '--follow-imports[follow all imports]' \
  '--nofollow-imports[do not follow any imports]' \
  '--output-dir=[output directory]:directory:_directories' \
  '-o+[output filename]:filename:_files' \
  '--output-filename=[output filename]:filename:_files' \
  '--remove-output[remove build directory after compilation]' \
  '--no-pyi-file[do not create .pyi file]' \
  '-j+[number of parallel C compiler jobs]:jobs' \
  '--jobs=[number of parallel C compiler jobs]:jobs' \
  '--lto=[use link time optimization]:mode:(yes no auto)' \
  '--clang[enforce use of clang]' \
  '--mingw64[enforce use of MinGW64]' \
  '--msvc=[enforce use of specific MSVC version]:version' \
  '--static-libpython=[use static libpython]:mode:(yes no auto)' \
  '--disable-console[disable console window (Windows)]' \
  '--enable-console[enable console window (Windows)]' \
  '--windows-icon-from-ico=[icon for Windows]:icon:_files' \
  '--linux-icon=[icon for Linux]:icon:_files' \
  '--macos-app-icon=[icon for macOS app]:icon:_files' \
  '--macos-app-name=[name of macOS application]:name' \
  '--company-name=[company name for version info]:name' \
  '--product-name=[product name for version info]:name' \
  '--file-version=[file version]:version' \
  '--product-version=[product version]:version' \
  '--file-description=[file description]:description' \
  '--show-scons[show Scons output]' \
  '--show-progress[show compilation progress]' \
  '--show-memory[show memory usage]' \
  '--show-modules[show included modules]' \
  '--verbose[show verbose output]' \
  '--quiet[disable informational output]' \
  '*--enable-plugin=[enable plugins]:plugin:(anti-bloat pylint-warnings)' \
  '*--disable-plugin=[disable plugins]:plugin' \
  '*--user-plugin=[user plugin file]:file:_files -g "*.py"' \
  '*:script file:_files -g "*.py"' && ret=0

return ret
