#compdef toolbx-cli
# Documentation: https://github.com/containers/toolbox/blob/main/doc/toolbox.1.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a new toolbox container'
  'enter:enter a toolbox container'
  'help:show help'
  'init-container:initialize a running container'
  'list:list containers and images'
  'rm:remove containers'
  'rmi:remove images'
  'run:run a command in a container'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--log-level=[log level]:level:(panic fatal error warn info debug trace)' \
  '--log-podman[log podman calls]' \
  '(-y --assumeyes)'{-y,--assumeyes}'[assume yes]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'toolbox command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '--authfile=[auth credentials file]:file:_files' \
          '(-d --distro)'{-d+,--distro=}'[distro]:distro' \
          '(-i --image)'{-i+,--image=}'[image]:image' \
          '(-r --release)'{-r+,--release=}'[release]:release' \
          ':container name' && ret=0 ;;
      (enter)
        _arguments \
          '(-d --distro)'{-d+,--distro=}'[distro]:distro' \
          '(-r --release)'{-r+,--release=}'[release]:release' \
          ':container' && ret=0 ;;
      (run)
        _arguments \
          '(-c --container)'{-c+,--container=}'[container]:name' \
          '(-d --distro)'{-d+,--distro=}'[distro]:distro' \
          '--preserve-fds=[preserve fds]:n' \
          '(-r --release)'{-r+,--release=}'[release]:release' \
          '*:command:_command_names -e' && ret=0 ;;
      (rm)
        _arguments \
          '(--all -a)'{-a,--all}'[all]' \
          '(--force -f)'{-f,--force}'[force]' \
          '*:container' && ret=0 ;;
      (rmi)
        _arguments \
          '(--all -a)'{-a,--all}'[all]' \
          '(--force -f)'{-f,--force}'[force]' \
          '*:image' && ret=0 ;;
      (list)
        _arguments \
          '(--containers -c)'{-c,--containers}'[only containers]' \
          '(--images -i)'{-i,--images}'[only images]' && ret=0 ;;
      (init-container)
        _arguments \
          '--gid=[GID]:gid' \
          '--home=[home dir]:dir:_files -/' \
          '--home-link[symlink /home to /var/home]' \
          '--media-link[symlink /media to /run/media]' \
          '--mnt-link[symlink /mnt to /var/mnt]' \
          '--monitor-host[deprecated]' \
          '--shell=[login shell]:shell' \
          '--uid=[UID]:uid' \
          '--user=[login name]:user:_users' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
