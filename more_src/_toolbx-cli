#compdef toolbox toolbx
# Documentation: https://man.archlinux.org/search?q=toolbox
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a new toolbox container'
  'enter:enter a toolbox container'
  'help:show help'
  'init-container:initialize a running container'
  'list:list containers and images'
  'rm:remove containers'
  'rmi:remove images'
  'run:run a command in a container'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--log-level=[log level]:l:(panic fatal error warn info debug trace)' \
  '*--log-podman[log podman calls]' \
  '*--assumeyes -y[assume yes]' \
  '*-y[assume yes]' \
  '*--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'toolbox command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '(--container -c)'{-c+,--container=}'[name]:n:' \
          '(--distro -d)'{-d+,--distro=}'[distro]:d:(fedora rhel ubi ubuntu arch debian centos)' \
          '(--image -i)'{-i+,--image=}'[image]:img:' \
          '(--release -r)'{-r+,--release=}'[release]:r:' \
          '(--authfile -a)'{-a+,--authfile=}'[auth file]:file:_files' \
          '*: :' && ret=0 ;;
      (enter)
        _arguments \
          '(--container -c)'{-c+,--container=}'[name]:n:' \
          '(--distro -d)'{-d+,--distro=}'[distro]:d:(fedora rhel ubi ubuntu arch debian centos)' \
          '(--release -r)'{-r+,--release=}'[release]:r:' \
          '*: :' && ret=0 ;;
      (run)
        _arguments \
          '(--container -c)'{-c+,--container=}'[name]:n:' \
          '(--distro -d)'{-d+,--distro=}'[distro]:d:' \
          '(--release -r)'{-r+,--release=}'[release]:r:' \
          '(--preserve-fds)--preserve-fds=[preserve fds]:n:' \
          '*: :' && ret=0 ;;
      (rm)
        _arguments \
          '(--all -a)'{-a,--all}'[all]' \
          '(--force -f)'{-f,--force}'[force]' \
          '*: :' && ret=0 ;;
      (rmi)
        _arguments \
          '(--all -a)'{-a,--all}'[all]' \
          '(--force -f)'{-f,--force}'[force]' \
          '*: :' && ret=0 ;;
      (list|ls)
        _arguments \
          '(--containers -c)'{-c,--containers}'[only containers]' \
          '(--images -i)'{-i,--images}'[only images]' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
