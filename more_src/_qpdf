#compdef qpdf
# Documentation: https://qpdf.readthedocs.io/en/stable/cli.html
# Source: qpdf/qpdf — content-preserving PDF transformation library + CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--encrypt[encrypt with passwords + permissions]:user-pw owner-pw bits:' \
    '--decrypt[remove encryption]' \
    '--password=[password for encrypted input]:password:' \
    '--copy-encryption=[copy encryption from file]:file:_files' \
    '--show-encryption[show encryption details]' \
    '*--pages[select pages from input file(s)]:spec:' \
    '--split-pages=[split each N pages to output files]:n:' \
    '*--rotate=[rotate pages (angle:pages)]:spec:' \
    '*--overlay[place pages from another file on top]:file:_files' \
    '*--underlay[place pages from another file underneath]:file:_files' \
    '--linearize[create web-optimized (linearized) PDF]' \
    '--object-streams=[object-stream handling]:mode:(preserve disable generate)' \
    '--remove-page-labels[strip explicit page numbering]' \
    '--check[validate file structure]' \
    '--show-pages[show page count + dimensions]' \
    '--show-object=[examine a specific PDF object]:obj:' \
    '--show-attachments[list embedded files]' \
    '--json[output inspection as JSON]' \
    '--json-output=[JSON output spec]:spec:' \
    '(--no-warn --warn)--no-warn[suppress warnings]' \
    '(--no-warn --warn)--warn[allow warnings to print]' \
    '--suppress-recovery[fail on first error]' \
    '--stream-data=[stream-data handling]:mode:(preserve compress uncompress)' \
    '--compress-streams=[compress streams]:bool:(y n)' \
    '--decode-level=[decode level]:level:(none generalized specialized all)' \
    '--newline-before-endstream[insert newline before endstream]' \
    '--normalize-content=[normalize content streams]:bool:(y n)' \
    '--object-streams=[handle object streams]:mode:(preserve disable generate)' \
    '--keep-files-open=[keep files open]:bool:(y n)' \
    '--qdf[turn on QDF mode for streams + objects]' \
    '--allow-weak-crypto[allow weak crypto algorithms]' \
    '(- *)--version[show version]' \
    '(- *)--help[show help]' \
    '(- *)--copyright[show copyright]' \
    '*:input + output PDF:_files -g "*.pdf"' \
    && ret=0

return ret
