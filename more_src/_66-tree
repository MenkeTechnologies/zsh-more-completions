#compdef 66-tree

_arguments -s -S \
  '-h[show help]' \
  '-z[use color output]' \
  '-v[set verbosity level]:verbosity:(0 1 2 3 4)' \
  '-n[create a new tree]' \
  '-E[enable the tree]' \
  '-D[disable the tree]' \
  '-A[add a tree as dependency]:dependency tree:' \
  '-R[remove a tree dependency]:dependency tree:' \
  '-S[start the tree]' \
  '-c[set tree as current]' \
  '*:tree name:'
