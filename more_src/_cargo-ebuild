#compdef cargo-ebuild

# https://github.com/gentoo/cargo-ebuild — write Gentoo ebuilds from Cargo workspaces

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '--manifest-path=[path to Cargo.toml]:file:_files' \
  '--package-name=[workspace package to export]:package:' \
  '(-t --template-path)'{-t,--template-path}'=[custom ebuild template]:file:_files' \
  '--noaudit[skip QA checks during metadata extraction]' && return 0
