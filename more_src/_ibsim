#compdef ibsim

# ibsim: InfiniBand fabric simulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-N[number of nodes]:n:' \
  '-S[size]:n:' \
  '-d[debug level]:n:' \
  '-I[network include glob]:glob:' \
  '-f[topology file]:file:_files' \
  '*::ibsim args:_files' && ret=0
return ret
