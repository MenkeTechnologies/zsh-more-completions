#compdef omit
# Documentation: https://www.ccp4.ac.uk/html/omit.html
# CCP4 omit: calculate an omit map; logical-file keywords on command line

local ret=1

_arguments -s -S \
  '*:keyword or file:->kw' && ret=0

if [[ $state == kw ]]; then
  _alternative \
    'keywords:logical file:(HKLIN MAPOUT)' \
    'files:file:_files' && ret=0
fi

return ret
