#compdef openrouter
# Documentation: https://github.com/maxxie114/openrouter-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list all API keys'
  'create:create a new API key'
  'get:show details for a specific key'
  'update:modify key settings'
  'delete:permanently remove a key'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'openrouter command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (list)
        _arguments \
          '--all[include disabled keys]' && ret=0 ;;
      (create)
        _arguments \
          '(-l --limit)'{-l+,--limit=}'[spending cap in USD]:usd:' \
          '(-r --reset)'{-r+,--reset=}'[reset period]:period:(daily weekly monthly)' \
          '(-e --expires)'{-e+,--expires=}'[ISO 8601 expiry date]:date:' \
          '*::name:' && ret=0 ;;
      (get)
        _arguments '*::name_or_hash:' && ret=0 ;;
      (update)
        _arguments \
          '(-n --name)'{-n+,--name=}'[new name]:name:' \
          '(-l --limit)'{-l+,--limit=}'[new spending cap]:usd:' \
          '--no-limit[remove spending cap]' \
          '(-r --reset)'{-r+,--reset=}'[new reset period]:period:(daily weekly monthly)' \
          '--disable[disable the key]' \
          '--enable[re-enable the key]' \
          '*::name_or_hash:' && ret=0 ;;
      (delete)
        _arguments \
          '--force[skip confirmation prompt]' \
          '*::name_or_hash:' && ret=0 ;;
    esac ;;
esac

return ret
