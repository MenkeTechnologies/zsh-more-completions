#compdef termit
# _termit — termit (lightweight GTK+VTE terminal scripted in Lua via ~/.config/termit/rc.lua; -c picks an alternate config, -e runs a single command, -d initial working directory, -n window name; per-Lua callbacks may add custom shortcuts)
# upstream: https://github.com/nonstop/termit
# Flags from termit src/main.c on tip.

_termit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.lua"' \
        '-e+[command to execute]:command:_command_names -e' \
        '-d+[initial directory]:dir:_files -/' \
        '-n+[window name]:name:'
}

_termit "$@"
