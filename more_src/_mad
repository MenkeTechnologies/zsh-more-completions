#compdef mad
# Documentation: https://github.com/synrc/mad
# MAD: small and fast build and dependency tool for Erlang apps

local ret=1

_arguments -s \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'app:create a predefined sample application (zero|nitro)'
      'deps:fetch and display dependencies'
      'get:fetch dependencies'
      'up:update dependencies'
      'compile:compile Erlang source and OTP application files'
      'clean:clean build artifacts'
      'strip:strip build artifacts'
      'bundle:create a single-file escriptized bundle (beam|script)'
      'release:build a release'
      'deploy:deploy the application'
      'static:produce static output'
      'start:start the application'
      'stop:stop the application'
      'attach:attach to a running instance'
      'sh:start a shell'
      'eunit:run EUnit tests'
      'dia:run Dialyzer'
      'man:show the manual'
      'resolve:resolve dependencies'
      'rsa:RSA key operations'
      'ecc:ECC key operations'
    )
    _describe -t commands 'mad command' cmds && ret=0
    ;;
esac

return ret
