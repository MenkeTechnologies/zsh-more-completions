autoload -U is-at-least

_sagoin() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'*-f+[Additional key-value pairs to send to the submit server, this will not affect authentication]:KEY: :KEY: ' \
'*--field=[Additional key-value pairs to send to the submit server, this will not affect authentication]:KEY: :KEY: ' \
'--color=[Controls when to use color]:WHEN:(auto always never)' \
'-c+[Specify the path to the config file, looks for sagoin/config.toml under XDG configuration directories when unspecified]:FILE:_files' \
'--config=[Specify the path to the config file, looks for sagoin/config.toml under XDG configuration directories when unspecified]:FILE:_files' \
'-t+[Specify how to format the due date, ignored without the --info flag, defaults to "\[month repr\:short\] \[day padding\:none\], \[hour\]\:\[minute\]" when unspecified]:FORMAT: ' \
'--time-format=[Specify how to format the due date, ignored without the --info flag, defaults to "\[month repr\:short\] \[day padding\:none\], \[hour\]\:\[minute\]" when unspecified]:FORMAT: ' \
'-u+[Specify the username for authentication, see --username-type for more information]:USERNAME: ' \
'--username=[Specify the username for authentication, see --username-type for more information]:USERNAME: ' \
'-U+[Specify the type for the username, defaults to text when unspecified]:TYPE:(command file text)' \
'--username-type=[Specify the type for the username, defaults to text when unspecified]:TYPE:(command file text)' \
'-p+[Specify the password for authentication, see --password-type for more information]:PASSWORD: ' \
'--password=[Specify the password for authentication, see --password-type for more information]:PASSWORD: ' \
'-P+[Specify the type for the password, defaults to text when unspecified]:TYPE:(command file text)' \
'--password-type=[Specify the type for the password, defaults to text when unspecified]:TYPE:(command file text)' \
'-s+[Command to run before submission]:COMMAND: ' \
'--pre-submit-hook=[Command to run before submission]:COMMAND: ' \
'-S+[Command to run after successful submissions]:COMMAND: ' \
'--post-submit-hook=[Command to run after successful submissions]:COMMAND: ' \
'--client-name=[Change the client name used to submit the project]:NAME: ' \
'--client-version=[Change the client version used to submit the project]:VERSION: ' \
'-n[Don'\''t submit the project]' \
'--no-submit[Don'\''t submit the project]' \
'-l[List files without submitting them]' \
'--list-files[List files without submitting them]' \
'(-l --list-files)-i[Show information about the project and exit]' \
'(-l --list-files)--info[Show information about the project and exit]' \
'-o[Open the project page in a web browser]' \
'--open[Open the project page in a web browser]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::dir -- Set the working directory, all commands will be run under this directory:_files' \
&& ret=0
}

(( $+functions[_sagoin_commands] )) ||
_sagoin_commands() {
    local commands; commands=()
    _describe -t commands 'sagoin commands' commands "$@"
}

if [ "$funcstack[1]" = "_sagoin" ]; then
    _sagoin "$@"
else
    compdef _sagoin sagoin
fi
