#compdef struct
# Documentation: https://github.com/hypre-space/hypre/blob/master/src/test/struct.c
# hypre Struct (structured-grid) linear-system test driver

local ret=1

_arguments -s -S \
  '-help[print usage and exit]' \
  '-fromfile[read structured system from file prefix]:prefix:_files' \
  '-n[grid size per direction]:nx ny nz' \
  '-istart[lower index of grid]:ix iy iz' \
  '-P[processor topology]:Px Py Pz' \
  '-b[blocking per direction]:bx by bz' \
  '-p[periodicity per direction]:px py pz' \
  '-c[diffusion coefficients]:cx cy cz' \
  '-convect[convection coefficients]:cx cy cz' \
  '-d[problem dimension]:dim' \
  '-27pt[use 27-point stencil]' \
  '-solver[solver id]:id' \
  '-solver_type[solver type]:type' \
  '-tol[convergence tolerance]:tol' \
  '-relax[relaxation type]:type' \
  '-w[Jacobi relaxation weight]:weight' \
  '-skip[skip relaxation flag]:flag' \
  '-rap[RAP coarse-grid operator type]:type' \
  '-sym[symmetric storage flag]:flag' \
  '-itr[max iterations]:n' \
  '-rhsfromfile[read rhs from file]:file:_files' \
  '-rhsone[set rhs to all ones]' \
  '-rhsrand[generate random rhs]' \
  '-rhszero[set rhs to all zeros]' \
  '-x0one[initial guess all ones]' \
  '-x0rand[random initial guess]' \
  '-x0zero[zero initial guess]' \
  '-repeats[number of solve repeats]:n' \
  '-print[print system to file]' \
  '-pcgitr[PCG iterations per preconditioner]:n' \
  '-pcgtol[PCG tolerance]:tol' \
  '-seed[random seed]:seed' \
  '-v[verbosity level]:v' \
  '*:file:_files' && ret=0

return ret
