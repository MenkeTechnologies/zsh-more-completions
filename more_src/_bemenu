#compdef bemenu bemenu-run

# Zsh completion for bemenu - dynamic menu library and client

_arguments \
  '(-)'{-h,--help}'[display help information]' \
  '(-)'{-v,--version}'[display version information]' \
  {-b,--bottom}'[display menu at bottom of screen]' \
  {-c,--center}'[display menu at center of screen]' \
  {-f,--fork}'[fork to background]' \
  {-n,--no-cursor}'[hide cursor]' \
  {-i,--ignorecase}'[case insensitive matching]' \
  {-w,--wrap}'[wrap cursor selection]' \
  {-l,--list}'[set number of lines]:lines' \
  {-p,--prompt}'[set prompt string]:prompt' \
  {-P,--prefix}'[set prefix for highlighted item]:prefix' \
  {-I,--index}'[set initial index]:index' \
  '--fixed-height[use fixed height]' \
  '--scrollbar[set scrollbar mode]:mode:(none always autohide)' \
  {-e,--ifne}'[only display if input is not empty]' \
  {-s,--no-spacing}'[disable spacing]' \
  {-C,--no-cursor}'[hide cursor]' \
  {-W,--width-factor}'[set width factor]:factor' \
  {-B,--border}'[set border size]:border size' \
  {-R,--border-radius}'[set border radius]:border radius' \
  '--bdr[set border color]:color' \
  '--ch[set cursor height]:height' \
  {-H,--line-height}'[set line height]:height' \
  {-M,--margin}'[set margin]:margin' \
  '--cw[set cursor width]:width' \
  '--cursor-width[set cursor width]:width' \
  '--hb[set highlighted background color]:color' \
  '--hp[set highlighted padding]:padding' \
  '--fn[set font]:font' \
  '--tb[set title background color]:color' \
  '--tf[set title foreground color]:color' \
  '--fb[set filter background color]:color' \
  '--ff[set filter foreground color]:color' \
  '--cb[set cursor background color]:color' \
  '--cf[set cursor foreground color]:color' \
  '--nb[set normal background color]:color' \
  '--nf[set normal foreground color]:color' \
  '--hf[set highlighted foreground color]:color' \
  '--sb[set selected background color]:color' \
  '--sf[set selected foreground color]:color' \
  '--scb[set scrollbar background color]:color' \
  '--scf[set scrollbar foreground color]:color' \
  '--ab[set alternating background color]:color' \
  '--af[set alternating foreground color]:color' \
  '--single-instance[force single instance]' \
  '--binding[set key binding mode]:mode:(vim default)' \
  '--accept-single[accept immediately if only one item]' \
  {-m,--monitor}'[set monitor index]:monitor' \
  '--filter[set initial filter string]:filter' \
  '--grab[grab keyboard focus]'
