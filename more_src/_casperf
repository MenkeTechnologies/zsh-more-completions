#compdef casperf
# _casperf — Mayastor SPDK bdev micro-benchmark (drives random read/write IO against one or more bdev URIs and reports IOPS/throughput)
# upstream: https://github.com/openebs/mayastor
# Source: io-engine/src/bin/casperf.rs on tip; flag surface tracks the I/O engine's general CLI plus the perf-specific knobs (size/qd/io_type).

_casperf() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '*-b+[bdev URI to benchmark (may be specified multiple times)]:uri:' \
        '-s+[IO size in bytes per request]:n:' \
        '-q+[queue depth]:n:' \
        '-t+[run period (seconds)]:s:' \
        '-w+[workload type]:type:(read write randread randwrite)' \
        '-m+[SPDK reactor mask (hex)]:mask:' \
        '-r+[path to the SPDK rpc socket]:socket:_files'
}

_casperf "$@"
