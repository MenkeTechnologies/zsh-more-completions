#compdef ulid
# ============================================================================
#  _ulid — ulid: Universally Unique Lexicographically Sortable Identifier
#          (oklog/ulid, Peter Bourgon)
#
#  Source-direct extraction from
#    https://github.com/oklog/ulid/blob/main/cmd/ulid/main.go
#    https://github.com/pborman/getopt (the pborman/getopt/v2 library
#    by Paul Borman — Google engineer & UUID/IETF author)
#
#  Maintained by oklog org (Peter "peterbourgon" Bourgon, Go community
#  fixture).  5,033 GH stars.  ulid is the GO REFERENCE IMPLEMENTATION
#  of the ULID spec (Universally Unique Lexicographically Sortable
#  Identifier) — a 128-bit identifier alternative to UUIDv4 that is:
#    (a) LEXICOGRAPHICALLY SORTABLE by generation time (unlike UUIDv4
#        which is random-ordered)
#    (b) URL-SAFE (Crockford Base32 — no hyphens, no padding, 26 chars)
#    (c) MONOTONICALLY ORDERED within the same millisecond (uses
#        atomic counter to break ties)
#    (d) 48-bit millisecond timestamp + 80-bit random component
#  ULID is the BASIS for many newer ID schemes (UUIDv7 which was
#  STANDARDIZED into RFC 9562 in May 2024 is essentially a UUID-shaped
#  ULID).  Used as PRIMARY KEYS in distributed databases, event log
#  IDs, Stripe-style human-readable resource IDs, etc.  Sister tools:
#  uuidgen (in corpus via _uuidgen + STOCK macOS BSD util), uuid
#  (libuuid), nanoid (in corpus via _nanoid — newer alternative by
#  Andrey Sitnik, 20k stars), ksuid (Segment K-sortable IDs), cuid
#  (Eric Elliott), xid (rs/xid Go).
#
#  CLI library taxonomy update: 11th Go CLI library — Paul "pborman"
#  Borman's **getopt** (pborman/getopt/v2).  Go ecosystem now has 11
#  documented CLI libraries — TYING WITH RUST at the top of the
#  cross-language taxonomy.  🎉 Go RE-TIES with Rust at 11 documented
#  libraries.
#
#  pborman/getopt/v2 is Paul Borman's STRICT-POSIX-GETOPT Go arg
#  parser — designed for the BSD/POSIX getopt(3) faithful API surface,
#  including long-option `--name=value` and short-cluster `-abc`
#  semantics IDENTICAL to GNU getopt_long(3).  Paul Borman is the
#  AUTHOR of the IETF UUID specification (RFC 4122) and the
#  google/uuid Go package — pborman/getopt was originally extracted
#  from the same set of Borman tooling at Google before being open
#  sourced as an independent package.  Used by oklog/ulid (the ULID
#  reference impl in corpus, 5k stars), CrunchyData/pg_featureserv
#  (Crunchy Data PostGIS feature server, 535 stars), ooni/probe-cli
#  (Open Observatory of Network Interference probe engine, 283 stars),
#  cashapp/pivit (Cash App YubiKey signing tool, 100 stars), sigsum/
#  sigsum-go (transparency log signer), Apache Traffic Control's
#  t3c-tail cache config tool, ribasushi/DAGger (IPFS DAG analysis),
#  fossul/fossul (Red Hat fossul backup framework), hyeoncheon/goul
#  (TUI accounting), Xe/kefka (XeIaso command tool), and many other
#  Go-based BSD/POSIX-faithful CLIs that prefer C-style getopt
#  semantics over Cobra/urfave-cli/kingpin frameworks.
#
#  pborman/getopt/v2 API (the v2 line is the CURRENT recommended; v1
#  is the original API and remains supported for backward compat):
#    import (
#      getopt "github.com/pborman/getopt/v2"
#    )
#
#    fs := getopt.New()
#    var (
#      format = fs.StringLong("format", 'f', "default",
#                "when parsing, show times in this format", "<format>")
#      local  = fs.BoolLong("local", 'l',
#                "when parsing, show local time instead of UTC")
#      quick  = fs.BoolLong("quick", 'q',
#                "when generating, use non-crypto-grade entropy")
#      help   = fs.BoolLong("help", 'h', "print this help text")
#    )
#    getopt.HelpColumn = 50            // tunable column-alignment
#    getopt.DisplayWidth = 140         // tunable wrap-width
#    if err := fs.Getopt(os.Args, nil); err != nil {
#      fmt.Fprintf(os.Stderr, "%v\n", err)
#      os.Exit(1)
#    }
#    if *help { fs.PrintUsage(os.Stderr); os.Exit(0) }
#    args := fs.Args()                  // positionals
#
#  pborman/getopt/v2 distinctive features:
#    - DOUBLE-API DESIGN — `BoolLong("name", 'short', desc)` returns
#      `*bool`; `StringLong("name", 'short', default, desc, placeholder)`
#      returns `*string`; INT/INT64/FLOAT/DURATION/LIST/COUNTER similar
#    - STRICT GETOPT(3) PARSING — `-abc` expands to `-a -b -c`;
#      `-fvalue` is `-f value`; `--name=value` and `--name value`
#      both valid; `--` separator terminates option parsing
#    - PARAMETERIZED FLAGSET — `fs := getopt.New()` creates an
#      independent flagset (unlike stdlib `flag` global default)
#    - TUNABLE HELP RENDERING — `getopt.HelpColumn`, `getopt.DisplayWidth`,
#      `getopt.UsageLine`, `getopt.UsageRequired` package-level vars
#      control the auto-generated help layout
#    - REQUIRED FLAGS — `.Mandatory()` chained on flag setter marks
#      a flag as required (error if missing)
#    - COUNTER FLAGS — `CounterLong("verbose", 'v')` increments per
#      occurrence (`-vvv` -> 3); for log-level / verbosity
#    - LIST FLAGS — `ListLong("include", 'I')` accepts repeated
#      `--include a --include b`; returns `*[]string`
#    - DURATION FLAGS — `DurationLong("timeout", 't')` parses
#      Go `time.Duration` strings like `5s`, `1h30m`
#    - SHORT-ONLY / LONG-ONLY — `.Short(...)` and `.Long(...)`
#      variants for flag families that have only short OR long
#    - CUSTOM Value INTERFACE — `Var(value Value, name, short, desc)`
#      accepts any `getopt.Value`-implementing type for custom parsers
#    - INTERSPERSED MODE — `getopt.SetParameters("[options] [args]")`
#      and similar configuration for usage line
#    - NO subcommand framework (caller hand-rolls subcommand dispatch
#      by inspecting `fs.Args()[0]` and dispatching to a child
#      `getopt.New()` instance — pattern used by ulid for parse vs
#      generate modes via positional arg presence)
#    - NO automatic --help (caller writes the `if *help { ... }`
#      check — the `BoolLong("help", 'h', ...)` flag is registered
#      manually like any other)
#    - NO automatic --version
#    - PrintUsage(io.Writer) method generates the formatted help
#      from registered flag metadata (placeholder, default, desc)
#    - INSPIRED BY POSIX getopt_long(3) — Paul Borman was at Google
#      and wrote this to bring the EXACT BSD/C-style API into Go,
#      including the obscure-but-important `+` and `-` POSIX
#      argument-order modifiers
#  Distinct from R237 Go spf13/cobra (subcommand-tree framework with
#  positional/required/flag-inheritance — Hugo/Kubernetes/Docker/etc.),
#  R237 Go spf13/pflag (POSIX-flag-compat replacement for stdlib
#  `flag` — used INSIDE cobra), R237 Go urfave/cli (action-callback
#  framework — Docker pre-cobra, restic, etc.), R237 Go
#  alecthomas/kingpin (chained-builder fluent API — Prometheus, etc.),
#  R237 Go go-flags (jessevdk struct-tag based parser — Helm earlier
#  versions), R237 Go mitchellh/cli (Mitchellh's cli used in
#  HashiCorp Terraform), R262 Go stdlib `flag` (golang.org/pkg/flag —
#  POSIX-INCOMPATIBLE single-dash long-flag default, used by `gofmt`,
#  `go test`, etc.), R363 Go peterbourgon/ff (functional-options
#  3-way config flag/env/file merge), R367 Go akamensky/argparse
#  (Python-argparse-style port to Go), R404 Go matklad/xflags (wait
#  that's Rust)... Go documented libraries so far: stdlib flag, pflag,
#  cobra, urfave-cli, kingpin, jessevdk/go-flags, mitchellh/cli, ff,
#  akamensky/argparse, octago/sflags... pborman/getopt makes 11.
#  pborman/getopt's approach: STRICT POSIX-GETOPT(3) FAITHFUL with
#  `getopt.New()` flagset + `BoolLong/StringLong/IntLong/etc.` typed
#  flag setters + `Mandatory()` chained required marker + `Counter`
#  for repeated-flag-counting + `List` for repeated-flag-accumulation
#  + `Duration` for Go time.Duration parsing + `Var(Value)` for
#  custom-Value-interface flags + TUNABLE HelpColumn/DisplayWidth/
#  UsageLine package-level vars + PrintUsage(io.Writer) auto-help +
#  STRICT short-cluster `-abc` -> `-a -b -c` + `--name=value` and
#  `--name value` both valid + `--` separator + NO subcommand
#  framework + NO automatic --help/--version (caller writes manually)
#  + INSPIRED BY POSIX getopt_long(3) — corpus's **first documented
#  POSIX-getopt(3)-faithful Go CLI library**.  Brings cross-language
#  CLI library taxonomy variant count to 147; Go ecosystem now has 11
#  documented CLI libraries — TYING WITH RUST at the top of the
#  cross-language taxonomy.
#
#  Surface (verbatim from `cmd/ulid/main.go` getopt registrations):
#
#  Usage:
#    ulid [options]                  # GENERATE a new ULID
#    ulid [options] <ULID>           # PARSE an existing ULID, print its
#                                    # encoded timestamp
#
#  Options:
#    -f, --format <format>          When parsing, show times in this
#                                   format.  Choices: default (Mon Jan
#                                   02 15:04:05.999 MST 2006), rfc3339
#                                   (2006-01-02T15:04:05.000Z07:00),
#                                   unix (Unix epoch seconds), ms
#                                   (Unix epoch milliseconds).
#                                   Default: default
#    -l, --local                    When parsing, show local time
#                                   instead of UTC
#    -q, --quick                    When generating, use non-crypto-
#                                   grade entropy (math/rand seeded
#                                   from time.Now().UnixNano() —
#                                   FASTER but NOT cryptographically
#                                   secure; do not use for security-
#                                   sensitive IDs)
#    -z, --zero                     When generating, fix entropy to
#                                   all-zeroes (DETERMINISTIC — useful
#                                   for testing ULID format/sort
#                                   behavior; do NOT use in
#                                   production)
#    -h, --help                     Print this help text and exit
#
#  Positional:
#    ULID                           A 26-character Crockford Base32
#                                   ULID string to parse and print its
#                                   embedded timestamp.  If absent,
#                                   ulid GENERATES a new ULID.
#
#  Examples:
#    ulid                                   # Generate a new ULID (crypto-grade entropy)
#    ulid -q                                # Generate quickly (non-crypto entropy)
#    ulid 01ARZ3NDEKTSV4RRFFQ69G5FAV        # Parse and print timestamp
#    ulid --format rfc3339 01ARZ3NDEKTSV4RRFFQ69G5FAV
#    ulid --local 01ARZ3NDEKTSV4RRFFQ69G5FAV
#    ulid --format unix 01ARZ3NDEKTSV4RRFFQ69G5FAV
#    ulid -z                                # Generate deterministic test ULID
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also pborman/getopt users):
#    - pg_featureserv (CrunchyData PostGIS feature server, 535 stars
#      — FUTURE candidate)
#    - oonireport (OONI Probe report tool — internal sub-binary of
#      ooni/probe-cli, smaller user base)
#    - pivit (Cash App YubiKey signing, 100 stars — FUTURE candidate)
#    - sigsum-policy (Sigsum transparency log tooling, mirror repo)
#    - t3c-tail (Apache Traffic Control cache-config tail tool —
#      internal sub-binary)
#    - fossul (Red Hat fossul backup framework — multi-component, may
#      revisit)
# ============================================================================

_ulid() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[print help and exit]' \
    '(-f --format)'{-f,--format}'[when parsing, show times in this format]:format:(default rfc3339 unix ms)' \
    '(-l --local)'{-l,--local}'[when parsing, show local time instead of UTC]' \
    '(-q --quick)'{-q,--quick}'[when generating, use non-crypto-grade entropy]' \
    '(-z --zero)'{-z,--zero}'[when generating, fix entropy to all-zeroes]' \
    '*:ulid:'
}

_ulid "$@"
