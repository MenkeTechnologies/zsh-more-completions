#compdef orbdump
# Documentation: https://github.com/orbcode/orbuculum
# orbuculum orbdump — dump raw SWO/OFLOW trace data to a file for post-processing

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --length)'{-l,--length}'=[length of time in ms to record from sync]:ms:' \
  '(-M --no-colour --no-color)'{-M,--no-colour,--no-color}'[suppress colour in output]' \
  '(-n --itm-sync)'{-n,--itm-sync}'[enforce sync requirement for ITM]' \
  '(-o --output-file)'{-o,--output-file}'=[output filename for dump file]:file:_files' \
  '(-p --protocol)'{-p,--protocol}'=[protocol to communicate (OFLOW or ITM)]:protocol:(OFLOW ITM)' \
  '(-s --server)'{-s,--server}'=[server:port to use]:server:' \
  '(-t --tag)'{-t,--tag}'=[OFLOW tag to use (normally 1)]:tag:' \
  '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3)' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '(-w --sync-write)'{-w,--sync-write}'[write synchronously after every packet]' && ret=0

return ret
