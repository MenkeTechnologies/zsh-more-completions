#compdef mult
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss119.html
# KAPPA: multiply two NDF data structures

local ret=1

_arguments -s \
  'IN1=[first NDF to be multiplied]:NDF:_files' \
  'IN2=[second NDF to be multiplied]:NDF:_files' \
  'OUT=[output product NDF]:NDF:_files' \
  'TITLE=[title for the output NDF]:title' \
  '*:NDF:_files' && ret=0

return ret
