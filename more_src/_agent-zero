#compdef agent-zero
# _agent-zero — Jan Tomasek agent-zero open-source dynamic personal-agent framework with tools and memory (frdel team, Python); argparse
# upstream: https://github.com/frdel/agent-zero

_agent-zero() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.json *.yaml *.yml"' \
        '-c+[config file]:file:_files -g "*.json *.yaml *.yml"' \
        '--prompts-dir=+[prompts dir]:dir:_files -/' \
        '-p+[prompts dir]:dir:_files -/' \
        '--memory-dir=+[memory dir]:dir:_files -/' \
        '--model=+[model name]:str:' \
        '-m+[model name]:str:' \
        '--temperature=+[F]:f:' \
        '--max-tokens=+[N]:n:' \
        '--max-iterations=+[N]:n:' \
        '--api-key=+[API key]:str:' \
        '--base-url=+[base URL]:url:_urls' \
        '--no-streaming[no streaming]' \
        '--debug[debug logs]' \
        '--verbose[verbose]' \
        '--log-file=+[log file]:file:_files' \
        '--web[run web UI]' \
        '--port=+[port]:port:_ports' \
        '--host=+[bind host]:host:_hosts' \
        '--tools=+[enabled tools csv]:str:' \
        '*:initial prompt:'
}

_agent-zero "$@"
