#compdef markdown2tex
# Documentation: https://man.archlinux.org/search?q=markdown2tex
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-h[Show help]'
    '-o[Output file]:output file:_files -g "*.tex"'
    '-s[Standalone document]'
    '*:Markdown file:_files -g "*.{md,markdown,txt}"'
)

_arguments -s -S $arguments
