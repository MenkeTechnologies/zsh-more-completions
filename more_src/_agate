#compdef agate

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--content+[root directory for content]:directory:_files -/' \
  '--certs+[directory for TLS certificates]:directory:_files -/' \
  '--addr+[address to listen on]:address:' \
  '--hostname+[hostname(s) for the server]:hostname:_hosts' \
  '--lang+[default language code for text/gemini]:language:' \
  '--silent[do not output logging info]' \
  '--serve-secret[serve files/directories starting with a dot]' \
  '--log-ip[output IP addresses in log]' \
  '--only-tls12[only use TLSv1.2]' \
  '--only-tls13[only use TLSv1.3]' \
  '--central-conf[use a central .meta file]' \
  '--ed25519[generate Ed25519 certificates instead of ECDSA]' \
  '--skip-port-check[skip port in URL check]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
