#compdef ldak5
# Documentation: http://dougspeed.com/main-arguments/
# LDAK5 heritability, GWAS, and prediction analysis toolkit

local ret=1

_arguments -s -S \
  '--bfile=[PLINK binary file prefix]:prefix:_files' \
  '--linear[classical linear association test]' \
  '--logistic[classical logistic association test]' \
  '--calc-kins-direct=[compute kinship matrix directly]:dir:_files -/' \
  '--reml=[restricted maximum likelihood heritability]:dir:_files -/' \
  '--calc-blups=[compute BLUP predictors]:dir:_files -/' \
  '--he=[Haseman-Elston heritability]:dir:_files -/' \
  '--pcgc=[PCGC heritability]:dir:_files -/' \
  '--calc-tagging=[compute SNP tagging]:dir:_files -/' \
  '--sum-hers=[SumHer heritability from summary stats]:dir:_files -/' \
  '--sum-cors=[genetic correlations from summary stats]:dir:_files -/' \
  '--ridge=[ridge regression prediction]:dir:_files -/' \
  '--bolt=[BOLT prediction model]:dir:_files -/' \
  '--bayesr=[BayesR prediction model]:dir:_files -/' \
  '--elastic=[elastic net prediction]:dir:_files -/' \
  '--mega-prs=[MegaPRS polygenic scores]:dir:_files -/' \
  '--thin=[thin predictors]:dir:_files -/' \
  '--filter=[filter predictors]:dir:_files -/' \
  '--add-grm=[add kinship matrices]:dir:_files -/' \
  '--sub-grm=[subtract kinship matrices]:dir:_files -/' \
  '--pca=[principal components analysis]:dir:_files -/' \
  '--decompose=[eigen-decompose kinship matrix]:dir:_files -/' \
  '--calc-stats=[compute predictor statistics]:dir:_files -/' \
  '--calc-scores=[compute scores]:dir:_files -/' \
  '--make-phenos=[simulate phenotypes]:dir:_files -/' \
  '--make-bed=[output PLINK bed format]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
