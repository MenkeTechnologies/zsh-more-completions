#compdef rover
# Documentation: https://github.com/apollographql/rover
# Reference accessed: 2026-05-21
# Verified: upstream rover --help output captured from github.com/apollographql/rover.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-l --log)'{-l,--log}'=[log level]:level:(error warn info debug trace)' \
  '--format=[output format]:format:(plain json)' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '--insecure-accept-invalid-certs[accept invalid HTTPS certs]' \
  '--insecure-accept-invalid-hostnames[accept invalid HTTPS hostnames]' \
  '--client-timeout=[HTTP client timeout in seconds]:seconds' \
  '--skip-update-check[skip checking for new rover version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Initialize a federated graph in your current directory'
      'api-key:API key related commands'
      'cloud:Cloud configuration commands'
      'connector:Work with Apollo Connectors'
      'completion:Generate shell completion scripts'
      'config:Configuration profile commands'
      'contract:Contract configuration commands'
      'schema:Schema inspection commands'
      'dev:Run a supergraph locally to develop and test subgraph changes'
      'supergraph:Supergraph schema commands'
      'graph:Graph API schema commands'
      'template:Commands for working with templates'
      'readme:Readme commands'
      'subgraph:Subgraph schema commands'
      'docs:Interact with Rover documentation'
      'update:Commands related to updating rover'
      'persisted-queries:Commands for persisted queries'
      'install:Installs Rover'
      'explain:Explain error codes'
      'license:Commands for fetching offline licenses'
      'client:Client workflow commands'
      'help:Print help'
    )
    _describe -t commands 'rover command' commands && ret=0
    ;;
  args)
    case $line[1] in
      graph)
        _arguments '1:action:(check delete fetch introspect lint publish)' && ret=0
        ;;
      subgraph)
        _arguments '1:action:(check delete fetch introspect lint list publish)' && ret=0
        ;;
      supergraph)
        _arguments '1:action:(compose fetch)' && ret=0
        ;;
      dev)
        _arguments \
          '--name=[subgraph name]:name' \
          '--url=[subgraph URL]:url' \
          '--schema=[schema file]:file:_files -g "*.graphql"' \
          '--supergraph-config=[config file]:file:_files -g "*.{yaml,yml}"' \
          '--router-config=[router config]:file:_files -g "*.{yaml,yml}"' && ret=0
        ;;
      config)
        _arguments '1:action:(auth clear whoami)' && ret=0
        ;;
    esac
    ;;
esac

return ret
