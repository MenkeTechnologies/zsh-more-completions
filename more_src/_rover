#compdef rover

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--log=[log level]:level:(error warn info debug trace)' \
  '--format=[output format]:format:(plain json)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:manage configuration'
      'dev:start local development session'
      'docs:open documentation'
      'graph:graph commands for federated graphs'
      'subgraph:subgraph commands'
      'supergraph:supergraph commands'
      'check:schema check operations'
      'template:generate project from template'
      'readme:generate README for subgraph'
      'persisted-queries:manage persisted queries'
      'license:manage licenses'
      'update:update rover'
    )
    _describe -t commands 'rover command' commands && ret=0
    ;;
  args)
    case $line[1] in
      graph)
        _arguments '1:action:(check delete fetch introspect lint publish)' && ret=0
        ;;
      subgraph)
        _arguments '1:action:(check delete fetch introspect lint list publish)' && ret=0
        ;;
      supergraph)
        _arguments '1:action:(compose fetch)' && ret=0
        ;;
      dev)
        _arguments \
          '--name=[subgraph name]:name' \
          '--url=[subgraph URL]:url' \
          '--schema=[schema file]:file:_files -g "*.graphql"' \
          '--supergraph-config=[config file]:file:_files -g "*.{yaml,yml}"' \
          '--router-config=[router config]:file:_files -g "*.{yaml,yml}"' && ret=0
        ;;
      config)
        _arguments '1:action:(auth clear whoami)' && ret=0
        ;;
    esac
    ;;
esac

return ret
