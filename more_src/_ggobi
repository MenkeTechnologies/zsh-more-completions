#compdef ggobi
# _ggobi — Dianne Cook Deborah Swayne ggobi CLI interactive multivariate data exploration and visualization tool supporting scatterplot matrices parallel coordinates grand tours guided tours brushing-linking-spinning-zooming-projecting on numeric data XML CSV TSV input format Rggobi-R-integration (Dianne Cook team, C); custom argparse
# upstream: http://www.ggobi.org/

_ggobi() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s+[input source]:str:' \
        '--source=+[source]:str:' \
        '-l+[input file]:file:_files -g "*.csv *.tsv *.xml *.ggobi"' \
        '--input=+[file]:file:_files -g "*.csv *.tsv *.xml *.ggobi"' \
        '-f+[plugins file]:file:_files -g "*.xml"' \
        '--plugins=+[file]:file:_files -g "*.xml"' \
        '-c+[colorscheme]:c:(default rainbow heat cool blue red green pastel grayscale)' \
        '--colorscheme=+[name]:c:(default rainbow heat cool blue red green pastel grayscale)' \
        '-n+[init mode]:m:(rotation 2D-tour 1D-tour 2D-tour PCA scatterplot scatmatrix parcoords time-series barchart)' \
        '--mode=+[m]:m:(rotation 2D-tour 1D-tour 2D-tour PCA scatterplot scatmatrix parcoords time-series barchart)' \
        '-d[no display]' \
        '--no-display[no display]' \
        '*:input file:_files -g "*.csv *.tsv *.xml *.ggobi *.dat"'
}

_ggobi "$@"
