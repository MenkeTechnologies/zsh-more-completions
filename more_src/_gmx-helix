#compdef gmx-helix
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-helix.html
# gmx helix: calculate basic properties of alpha helices

local ret=1

_arguments -s \
  '-s[portable xdr run input file]:file:_files' \
  '-n[index file]:file:_files' \
  '-f[trajectory file]:file:_files' \
  '-cz[structure file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt = first time]:time:' \
  '-w[view output files]' \
  '-r0[the first residue number in the sequence]:int:' \
  '-q[check at every step which part is helical]' \
  '-F[toggle fit to a perfect helix]' \
  '-db[print debug info]' \
  '-ev[write a new trajectory file for ED]' \
  '-ahxstart[first residue in helix]:int:' \
  '-ahxend[last residue in helix]:int:' && ret=0

return ret
