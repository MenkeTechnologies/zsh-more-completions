#compdef openhands-cli
# Documentation: https://docs.openhands.dev/openhands/usage/cli/command-reference
# Reference accessed: 2026-05-23
# Verified: same surface as openhands; see _openhands.

# Zsh completion for openhands-cli - OpenHands agent CLI (alternate binary name)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--headless[run without interactive TUI]' \
  '(-t --task)'{-t,--task}'[task to run]:task:' \
  '(-f --file)'{-f,--file}'[instructions from file]:file:_files' \
  '--json[JSON output in headless mode]' \
  '--resume[resume conversation]' \
  '--last[resume most recent conversation]' \
  '--always-approve[auto-approve all actions]' \
  '--llm-approve[LLM-based security analyzer for approvals]' \
  '--override-with-envs[apply env overrides to settings]' \
  '--exp[textual-based UI]' \
  '--exit-without-confirmation[exit without confirmation dialog]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'openhands-cli command' \
      'acp[start ACP server for IDE integration]' \
      'cloud[run tasks on OpenHands Cloud]' \
      'login[authenticate with OpenHands Cloud]' \
      'logout[sign out from OpenHands Cloud]' \
      'mcp[manage MCP servers]' \
      'serve[start GUI server]' \
      'web[start browser interface]' && ret=0
    ;;
  args)
    case $line[1] in
      cloud)
        _arguments \
          '(-t --task)'{-t,--task}'[cloud task]:task:' \
          '(-f --file)'{-f,--file}'[instructions file]:file:_files' \
          '--json[JSON output]' \
          '--resume[resume cloud conversation]' \
          '--last[resume most recent cloud conversation]' && ret=0
        ;;
      mcp)
        _arguments -C \
          '1:subcommand:(add list get remove enable disable)' \
          '*:: :->mcp_args' && ret=0
        case $state in
          mcp_args)
            case $line[2] in
              add)
                _arguments \
                  '1:server name:' \
                  '--transport[transport type]:(stdio sse http)' \
                  '*:command:_command_names -e' && ret=0
                ;;
              enable|disable|get|remove)
                _arguments '1:server name:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      serve|web)
        _arguments \
          '(-p --port)'{-p,--port}'[port]:port:' \
          '(-H --host)'{-H,--host}'[host]:host:' && ret=0
        ;;
    esac
    ;;
esac

return ret
