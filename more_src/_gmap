#compdef gmap gmapl
# Documentation: https://manpages.debian.org/testing/gmap/gmap.1.en.html
# Genomic mapping and alignment program for mRNA and EST sequences

local ret=1

_arguments -s -S \
  '(-D --dir)'{-D,--dir=}'[genome directory]:dir:_files -/' \
  '(-d --db)'{-d,--db=}'[genome database]:db:' \
  '(-k --kmer)'{-k,--kmer=}'[kmer size to use in genome database]:int:' \
  '--sampling=[sampling to use in genome database]:int:' \
  '(-g --gseg)'{-g,--gseg=}'[user-supplied genomic segments]:file:_files' \
  '(-1 --selfalign)'{-1,--selfalign}'[align one sequence against itself in FASTA format via stdin]' \
  '(-2 --pairalign)'{-2,--pairalign}'[align two sequences in FASTA format via stdin]' \
  '--cmdline[align two sequences provided on the command line]:sequences:' \
  '--align-fraction[process only the given fraction of reads, selected at random]:fraction:' \
  '(-q --part)'{-q,--part=}'[process only the i-th out of every n sequences]:part:' \
  '--input-buffer-size[size of input buffer]:int:' \
  '(-B --batch)'{-B,--batch=}'[batch mode]:int:' \
  '--use-shared-memory[if 1, allocated memory is shared among all processes on this node]:int:' \
  '--nosplicing[turns off splicing]' \
  '--max-deletionlength[max length for a deletion]:int:' \
  '--min-intronlength[min length for one internal intron]:int:' \
  '--max-intronlength-middle[max length for one internal intron]:int:' \
  '--max-intronlength-ends[max length for first or last intron]:int:' \
  '--split-large-introns[force GMAP to split alignments exceeding max-intronlength-middle]' \
  '--end-trimming-score[trim ends if the alignment score is below this value]:int:' \
  '--trim-end-exons[trim end exons with fewer than given number of matches]:int:' \
  '(-w --localsplicedist)'{-w,--localsplicedist=}'[max length for known splice sites at ends of sequence]:int:' \
  '(-L --totallength)'{-L,--totallength=}'[max total intron length]:int:' \
  '(-x --chimera-margin)'{-x,--chimera-margin=}'[unaligned sequence that triggers search for the remaining sequence]:int:' \
  '--no-chimeras[turns off finding of chimeras]' \
  '(-t --nthreads)'{-t,--nthreads=}'[number of worker threads]:int:' \
  '(-c --chrsubset)'{-c,--chrsubset=}'[limit search to given chromosome]:chr:' \
  '--strand[genome strand to try aligning to]:strand:(plus minus both)' \
  '(-z --direction)'{-z,--direction=}'[cDNA direction]:direction:(sense_force antisense_force sense_filter antisense_filter auto)' \
  '--canonical-mode[reward for canonical and semi-canonical introns]:mode:' \
  '--cross-species[use a more sensitive search for canonical splicing]' \
  '--allow-close-indels[allow an insertion and deletion close to each other]:value:' \
  '--microexon-spliceprob[allow microexons only if splice site probability exceeds this value]:prob:' \
  '--indel-open[opening penalty for indel in dynamic programming]:int:' \
  '--indel-extend[extension penalty for indel in dynamic programming]:int:' \
  '--cmetdir[directory for methylcytosine index files]:dir:_files -/' \
  '--atoidir[directory for A-to-I RNA editing index files]:dir:_files -/' \
  '--mode[alignment mode]:mode:(standard cmet-stranded cmet-nonstranded atoi-stranded atoi-nonstranded ttoc-stranded ttoc-nonstranded)' \
  '(-p --prunelevel)'{-p,--prunelevel=}'[pruning level]:level:(0 1 2 3)' \
  '(-S --summary)'{-S,--summary}'[show summary of alignments only]' \
  '(-A --align)'{-A,--align}'[show alignments]' \
  '(-3 --continuous)'{-3,--continuous}'[show alignment in three continuous lines]' \
  '(-4 --continuous-by-exon)'{-4,--continuous-by-exon}'[show alignment in three lines per exon]' \
  '(-E --exons)'{-E,--exons=}'[print exons (cdna or genomic)]:type:(cdna genomic)' \
  '(-P --protein_dna)'{-P,--protein_dna}'[print protein sequence (cDNA)]' \
  '(-Q --protein_gen)'{-Q,--protein_gen}'[print protein sequence (genomic)]' \
  '(-f --format)'{-f,--format=}'[other format for output]:format:' \
  '(-n --npaths)'{-n,--npaths=}'[maximum number of paths to show]:int:' \
  '--suboptimal-score[report only paths whose score is within this value of the best path]:int:' \
  '(-O --ordered)'{-O,--ordered}'[print output in same order as input]' \
  '(-5 --md5)'{-5,--md5}'[print MD5 checksum for each query sequence]' \
  '(-o --chimera-overlap)'{-o,--chimera-overlap=}'[overlap to show at chimera breakpoint]:int:' \
  '--failsonly[print only failed alignments]' \
  '--nofails[exclude printing of failed alignments]' \
  '(-V --snpsdir)'{-V,--snpsdir=}'[directory for SNPs index files]:dir:_files -/' \
  '(-v --use-snps)'{-v,--use-snps=}'[use database containing known SNPs]:db:' \
  '--split-output[basename for multiple-file output]:basename:' \
  '--failed-input[print completely failed alignments as input FASTA or FASTQ]:basename:' \
  '--append-output[append output to existing files]' \
  '--output-buffer-size[buffer size, in queries, for output thread]:int:' \
  '--translation-code[genetic code used for translating codons to amino acids]:code:' \
  '--alt-start-codons[also use the alternate initiation codons]' \
  '(-F --fulllength)'{-F,--fulllength}'[assume full-length protein, starting with Met]' \
  '(-a --cdsstart)'{-a,--cdsstart=}'[translate codons from given nucleotide (1-based)]:int:' \
  '(-T --truncate)'{-T,--truncate}'[truncate alignment around full-length protein, Met to Stop]' \
  '(-Y --tolerant)'{-Y,--tolerant}'[translate cDNA with corrections for frameshifts]' \
  '--gff3-add-separators[add a separator after each query sequence]:value:' \
  '--gff3-swap-phase[swap phase in gff3_gene format]:value:' \
  '--gff3-fasta-annotation[include annotation from the FASTA header into the GFF3 output]:value:' \
  '--gff3-cds[use cDNA or genomic translation for the CDS coordinates]:value:' \
  '--no-sam-headers[do not print headers beginning with @]' \
  '--sam-use-0M[insert 0M in CIGAR between adjacent insertions and deletions]' \
  '--sam-extended-cigar[use extended CIGAR format (X and = instead of M)]' \
  '--sam-flipped[flip the query and genomic positions in the SAM output]' \
  '--force-xs-dir[disallow XS:A:? when the sense direction is unclear]' \
  '--md-lowercase-snp[print difference nucleotides as lower-case in MD string]' \
  '--action-if-cigar-error[action if CIGAR length disagrees with sequence length]:action:' \
  '--read-group-id[value to put into read-group id (RG-ID) field]:id:' \
  '--read-group-name[value to put into read-group name (RG-SM) field]:name:' \
  '--read-group-library[value to put into read-group library (RG-LB) field]:lib:' \
  '--read-group-platform[value to put into read-group platform (RG-PL) field]:platform:' \
  '--quality-protocol[protocol for input quality scores]:protocol:(illumina sanger)' \
  '(-j --quality-print-shift)'{-j,--quality-print-shift=}'[shift FASTQ quality scores by this amount in output]:int:' \
  '(-M --mapdir)'{-M,--mapdir=}'[map directory]:dir:_files -/' \
  '(-m --map)'{-m,--map=}'[map file]:file:_files' \
  '(-e --mapexons)'{-e,--mapexons}'[map each exon separately]' \
  '(-b --mapboth)'{-b,--mapboth}'[report hits from both strands of genome]' \
  '(-u --flanking)'{-u,--flanking=}'[show flanking hits]:int:' \
  '--print-comment[show comment line for each hit]' \
  '--nolengths[no intron lengths in alignment]' \
  '--nomargin[no left margin in GMAP standard output]' \
  '(-I --invertmode)'{-I,--invertmode=}'[mode for alignments to genomic (-) strand]:mode:' \
  '(-i --introngap)'{-i,--introngap=}'[nucleotides to show on each end of intron]:int:' \
  '(-l --wraplength)'{-l,--wraplength=}'[wrap length for alignment]:int:' \
  '--min-trimmed-coverage[do not print alignments with trimmed coverage less than this value]:value:' \
  '--min-identity[do not print alignments with identity less than this value]:value:' \
  '--check[check compiler assumptions]' \
  '--version[show version]' \
  '--help[show this help message]' \
  '*:fasta query:_files' && ret=0

return ret
