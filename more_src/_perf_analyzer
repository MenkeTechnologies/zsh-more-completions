#compdef perf_analyzer
# Documentation: https://github.com/triton-inference-server/perf_analyzer/blob/main/docs/cli.md
# NVIDIA Triton Performance Analyzer for measuring inference throughput and latency

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-m+[model name]:model:' \
  '-x+[model version]:version:' \
  '-u+[server URL]:url:' \
  '-i+[communication protocol]:protocol:(http grpc)' \
  '--async[enable asynchronous request mode]' \
  '--sync[enable synchronous request mode]' \
  '--streaming[enable bidirectional streaming RPC (gRPC only)]' \
  '-H+[add custom HTTP header]:header:' \
  '--concurrency-range=[concurrency range start:end:step]:range:' \
  '--request-rate-range=[request rate range start:end:step]:range:' \
  '-b+[batch size per request]:size:' \
  '--measurement-interval=[measurement window in ms]:ms:' \
  '--measurement-mode=[stabilization mode]:mode:(time_windows count_windows)' \
  '--latency-threshold=[maximum acceptable latency in ms]:ms:' \
  '--percentile=[confidence percentile for stability]:n:' \
  '--input-data=[input data source]:data:' \
  '--shape=[input tensor shape name:dim,list]:shape:' \
  '--string-data=[string initialization for string inputs]:str:' \
  '--service-kind=[service type]:kind:(triton triton_c_api tfserving torchserve dynamic_grpc)' \
  '-f+[latency report output file]:file:_files' \
  '--verbose-csv[enable extended CSV information]' && ret=0

return ret
