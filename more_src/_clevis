#compdef clevis

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'decrypt:decrypt data from standard input'
  'encrypt:encrypt data from standard input'
  'luks:manage LUKS volume bindings'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      encrypt)
        local -a pin_types=(
          'sss:Shamir Secret Sharing'
          'tang:Tang network binding'
          'tpm2:TPM 2.0 binding'
        )
        _arguments \
          '1:pin type:->pin' \
          '2:pin configuration (JSON)' && ret=0
        [[ $state == pin ]] && _describe -t pins 'pin type' pin_types && ret=0
        ;;
      decrypt)
        _arguments && ret=0
        ;;
      luks)
        local -a luks_cmds=(
          'bind:bind a LUKS device to a pin'
          'edit:edit a binding'
          'list:list bindings'
          'pass:initialize passphrase slot interactively'
          'regen:regenerate a binding'
          'report:report on bindings'
          'unbind:unbind a LUKS device from a pin'
          'unlock:unlock a LUKS device'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'luks subcommand' luks_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
