#compdef clamscan clamdscan freshclam

# Zsh completion for ClamAV antivirus tools

case "$service" in
  clamscan)
    _arguments -s -S \
      '(-r --recursive)'{-r,--recursive}'[scan subdirectories recursively]' \
      '--infected[only print infected files]' \
      '--suppress-ok-results[skip printing OK results]' \
      '--bell[sound bell on virus detection]' \
      '--no-summary[disable summary at end of scanning]' \
      '(-i --infected)'{-i,--infected}'[only print infected files]' \
      '(-v --verbose)'{-v,--verbose}'[verbose output]' \
      '--stdout[write to stdout instead of stderr]' \
      '--debug[enable debug messages]' \
      '--quiet[be quiet, only output error messages]' \
      '(-l --log)'{-l+,--log=}'[save report to file]:log file:_files' \
      '(-d --database)'{-d+,--database=}'[load virus database]:database:_files' \
      '--official-db-only[only load official signatures]' \
      '--max-filesize=[max file size to scan]:size:' \
      '--max-scansize=[max data to scan]:size:' \
      '--max-files=[max files to scan]:count:' \
      '--max-recursion=[max directory recursion]:depth:' \
      '--max-dir-recursion=[max directory recursion]:depth:' \
      '--cross-fs=[scan across filesystems]:mode:(yes no)' \
      '--follow-dir-symlinks=[follow directory symlinks]:level:(0 1 2)' \
      '--follow-file-symlinks=[follow file symlinks]:level:(0 1 2)' \
      '--move=[move infected files]:directory:_files -/' \
      '--copy=[copy infected files]:directory:_files -/' \
      '--remove[remove infected files]' \
      '--exclude=[exclude pattern]:regex:' \
      '--exclude-dir=[exclude directory pattern]:regex:' \
      '--include=[include pattern]:regex:' \
      '--include-dir=[include directory pattern]:regex:' \
      '--bytecode-timeout=[bytecode timeout]:ms:' \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '*:files or directories:_files'
    ;;
  clamdscan)
    _arguments -s -S \
      '--multiscan[scan using multiple threads]' \
      '--allmatch[continue scanning within file after finding a match]' \
      '--infected[only print infected files]' \
      '--no-summary[disable summary]' \
      '--remove[remove infected files]' \
      '--move=[move infected files]:directory:_files -/' \
      '--copy=[copy infected files]:directory:_files -/' \
      '--config-file=[config file]:file:_files' \
      '--fdpass[pass file descriptor instead of file path]' \
      '--stream[force streaming to clamd]' \
      '(-l --log)'{-l+,--log=}'[save report to file]:log file:_files' \
      '--verbose[verbose output]' \
      '--quiet[quiet output]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-h --help)'{-h,--help}'[show help]' \
      '*:files or directories:_files'
    ;;
  freshclam)
    _arguments -s -S \
      '--config-file=[config file]:file:_files' \
      '(-v --verbose)'{-v,--verbose}'[verbose output]' \
      '--debug[enable debug messages]' \
      '--quiet[quiet output]' \
      '--stdout[write to stdout]' \
      '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
      '--foreground[do not fork into background]' \
      '-p+[PID file]:pid file:_files' \
      '--user=[run as user]:user:_users' \
      '--no-dns[disable DNS lookups]' \
      '--checks=[number of checks per day]:checks:' \
      '--datadir=[database directory]:directory:_files -/' \
      '--daemon-notify=[notify clamd]:file:_files' \
      '(-l --log)'{-l+,--log=}'[save report to file]:log file:_files' \
      '--on-update-execute=[command on update]:command:' \
      '--on-error-execute=[command on error]:command:' \
      '--on-outdated-execute=[command on outdated]:command:' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-h --help)'{-h,--help}'[show help]'
    ;;
esac
