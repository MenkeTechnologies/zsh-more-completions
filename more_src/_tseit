#compdef tseit
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tseit.cpp
# tseit - manipulate EIT sections in transport stream files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-c,--command}'=[specify an EIT manipulation command]:command:' \
  '(-e --exit-on-error)'{-e,--exit-on-error}'[stop executing commands on error]' \
  '(-f --file)'{-f,--file}'=[text file containing EIT manipulation commands]:file:_files' \
  '(-i --input-directory)'{-i,--input-directory}'=[default directory of input files]:dir:_files -/' \
  '(-o --output-directory)'{-o,--output-directory}'=[default directory of output files]:dir:_files -/' \
  '*:command:(load save process generate reset dump set)' && ret=0

return ret
