#compdef ykneomgr
# _ykneomgr — Yubico ykneomgr CLI legacy YubiKey NEO YubiKey 4 NEO-N CCID smartcard interface tool managing Java Card applets installing deleting OpenPGP PIV OATH U2F OTP applet IDs from JCOP cap files Atmel SAM secure-element JCRE GlobalPlatform (Yubico team, C); custom argparse
# upstream: https://developers.yubico.com/libykneomgr/

_ykneomgr() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r+[reader]:str:' \
        '--reader=+[reader]:str:' \
        '-d+[hex auth key]:str:' \
        '--authkey=+[key]:str:' \
        '-l[list applets]' \
        '--list-applets[list applets]' \
        '-i[show identity]' \
        '--get-mode[get mode]' \
        '-M+[mode]:m:(OTP CCID OTP+CCID U2F OTP+U2F CCID+U2F OTP+CCID+U2F)' \
        '--set-mode=+[mode]:m:(OTP CCID OTP+CCID U2F OTP+U2F CCID+U2F OTP+CCID+U2F)' \
        '-s+[applet]:str:' \
        '--send-apdu=+[apdu]:str:' \
        '-a+[install cap]:file:_files -g "*.cap"' \
        '--install-applet=+[cap]:file:_files -g "*.cap"' \
        '-D+[applet aid]:str:' \
        '--delete-applet=+[aid]:str:' \
        '*:cap file:_files -g "*.cap"'
}

_ykneomgr "$@"
