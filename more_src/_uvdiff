#compdef uvdiff
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvdiff.html
# Difference two visibility datasets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'select=[select keyword]:select:' \
  'out=[out keyword]:out:' \
  'mode=[mode keyword]:mode:' \
  'tol=[tol keyword]:tol:' \
  '*:visibility dataset:_files' && ret=0

return ret
