#compdef bulldohzer
# ---------------------------------------------------------------------------
# bulldohzer — performance measurement tool for DNS supporting DNS-over-
#              HTTPS (DoH) and DNS-over-UDP (Do53) (Node.js, 127★)
#
# upstream: https://github.com/commonshost/bulldohzer
# author : Sebastiaan Deckers (sebdeckers) at Commons Host — operator
#          of the commonshost.com public DoH resolver and several
#          DoH-related npm packages (@commonshost/resolvers,
#          @commonshost/word-lists, @commonshost/sample)
# license: MIT-ish (package.json declares MIT but repo lacks LICENSE
#          file — listed as "None" by GitHub's license-detection)
#
# Source-direct completion: every flag below is verbatim from source/
# cli.js on the commonshost/bulldohzer tip — yargs `.option(...)` /
# `.options(...)` registrations parsed exactly as declared.
#
# Direct deps from package.json (selected):
#   dns-packet                ^5.2.1  ← canonical Node.js pure-JS DNS
#                                       protocol library (this axis) —
#                                       by Mathias Buus (mafintosh) +
#                                       Thomas Watson + the dns-packet
#                                       contributors; abstract-encoding-
#                                       compliant module for encoding/
#                                       decoding DNS protocol packets
#                                       in pure JavaScript.  Powers
#                                       multicast-dns (Bonjour/mDNS in
#                                       JS), dns-discovery (libp2p
#                                       discovery), hyperswarm,
#                                       npmjs.com's internal DNS
#                                       tooling, and every Node-based
#                                       DNS-protocol-aware tool.
#   @commonshost/resolvers              (curated table of well-known
#                                        public DoH/Do53 resolvers with
#                                        shortname aliases —
#                                        commonshost, cleanbrowsing,
#                                        cloudflare, quad9, powerdns,
#                                        google, opendns, mullvad, etc.)
#   yargs                              (Bash Hudson + the yargs collective
#                                       — canonical Node CLI argv parser)
#   sparkly                            (Sindre Sorhus's sparkly — Unicode
#                                       block-art sparklines for histograms)
#   ora + chalk                        (spinner + ANSI color)
#
# bulldohzer is a DNS performance benchmarking tool: send N DNS queries
# of any RR type to one or more DoH or Do53 resolvers, measure response
# times, and produce a comparison report with per-resolver percentile
# statistics (5th/50th/95th by default) + Unicode sparkline histograms.
# Useful for choosing between public DoH resolvers (Cloudflare 1.1.1.1
# vs Quad9 9.9.9.9 vs Google 8.8.8.8 vs CleanBrowsing vs commonshost).
# NDJSON output mode pipes to ndjson2csv for spreadsheet analysis.
#
# ============================================================================
# === AXIS 178 CLOSES — pure-language DNS libraries (resolver+protocol) ====
# === TRIPLE-233 ROUND-NUMBER LANDMARK · 171st AXIS CLOSED =================
# ============================================================================
# Axis position: TS-Node=233 CLOSES Axis 178 at slot 1/1/1 — quadruple-clean
# closure of the canonical pure-language DNS library ecosystem spanning
# the three major systems languages.  All three lanes anchor on a single
# pure-host-language DNS protocol implementation by a single recognized
# maintainer that does not shell out to the system stub resolver:
#
#     Rust    : hickory-resolver / hickory-dns  by Benjamin Fry
#                                                (bluejekyll) + the
#                                                Hickory DNS collective
#                                                (formerly trust-dns
#                                                until 2024 rename);
#                                                pure-Rust DNS stub
#                                                resolver + recursive
#                                                resolver + authoritative
#                                                server + protocol
#                                                message encoding/
#                                                decoding without
#                                                shelling out to libc's
#                                                getaddrinfo.
#                 → ttl (Lance0 lance0 — fast modern traceroute with
#                         real-time TUI per-hop stats ASN/geo lookup
#                         ECMP detection MPLS label parsing a better
#                         mtr; DNS lookups for reverse-DNS + ASN
#                         lookups + PeeringDB queries all route through
#                         hickory-resolver; 1032★ MIT OR Apache-2.0
#                         v0.19.1)
#                 _ttl              [Rust=233 OPENED Axis 178, slot 1/0/0]
#
#     Go      : github.com/miekg/dns       by Miek Gieben (miekg);
#                                          idiomatic Go DNS protocol
#                                          encoder/decoder + client +
#                                          server framework with full
#                                          RR-type coverage (every RR
#                                          from RFC 1035 onwards
#                                          including TSIG, DNSSEC,
#                                          EDNS0 options, SVCB/HTTPS)
#                                          + zone-file parsing.  THE
#                                          canonical Go DNS library —
#                                          every notable Go DNS tool
#                                          depends on it including
#                                          CoreDNS (which Miek co-
#                                          created), doggo, go-acme/
#                                          lego, gobuster, DNSCrypt-
#                                          proxy, NextDNS CLI, blocky,
#                                          dnsproxy.
#                 → addrd (Brian Shea brianshea2 — authoritative DNS
#                          server backing addr.tools website collection
#                          of DNS-based introspection tools; -c config
#                          serves DNS daemon defining zones/handlers/
#                          TSIG keys + -k generates DNSSEC keys for
#                          zone with -a algorithm selectable; 2060★
#                          AGPL-3.0)
#                 _addrd            [Go=233 CONTINUED Axis 178, slot 2/0/0]
#
#     JS/Node : dns-packet                by Mathias Buus (mafintosh) +
#                                         Thomas Watson + the dns-packet
#                                         contributors; abstract-encoding-
#                                         compliant module for encoding/
#                                         decoding DNS protocol packets
#                                         in pure JavaScript.  Powers
#                                         multicast-dns (Bonjour/mDNS),
#                                         dns-discovery (libp2p), hyper-
#                                         swarm, npmjs.com internal DNS,
#                                         and every Node-based DNS-
#                                         protocol-aware tool.
#                 → bulldohzer (Sebastiaan Deckers sebdeckers at Commons
#                                Host — DNS performance benchmarking
#                                tool supporting DoH and Do53 with
#                                comparison reports + Unicode sparkline
#                                histograms across well-known public
#                                resolvers; 127★ MIT)
#                 _bulldohzer        [TS-Node=233 CLOSES Axis 178, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 dns-packet is the only npm DNS library that is pure-
#                 JS DNS protocol encoder/decoder — no native bindings,
#                 no libc getaddrinfo shell-out.  Plays the same role
#                 in Node as miekg/dns does in Go and hickory-dns does
#                 in Rust: the foundational protocol library that
#                 every higher-level DNS tool builds on top of.
#
# Round-number 233 landmark fires simultaneously across all three lanes:
# Rust completion #233 (_ttl) + Go completion #233 (_addrd) + TS-Node
# completion #233 (_bulldohzer) = triple-233.  Axis #171 closed in the
# lifetime of the corpus — every pure-language DNS protocol library
# in the three big systems languages now has both a representative
# consumer completion AND a documented axis closure landmark; the
# lanes are tied together by a common design discipline (pure-host-
# language DNS protocol encoding/decoding, no shelling out to system
# stub resolver, support for modern RR types and protocol extensions
# like DNSSEC + TSIG + EDNS0).
# ============================================================================

_bulldohzer() {
    local -a known_doh_resolvers known_dns_resolvers known_rrtypes
    known_doh_resolvers=(commonshost cleanbrowsing cloudflare quad9 powerdns google opendns mullvad nextdns adguard)
    known_dns_resolvers=(commonshost cleanbrowsing cloudflare quad9 powerdns google opendns mullvad nextdns adguard)
    known_rrtypes=(A AAAA CNAME MX NS PTR SOA SRV TXT CAA TLSA SVCB HTTPS DS DNSKEY RRSIG NSEC NSEC3 NSEC3PARAM CDS CDNSKEY OPENPGPKEY SMIMEA)

    _arguments -s -S \
        '(- *)--help[show help]' \
        '(- *)--version[print version]' \
        '*--doh=[URLs or shortnames of DNS-over-HTTPS resolvers (repeatable; shortnames resolve via @commonshost/resolvers)]:DoH URL or shortname:('"${known_doh_resolvers[*]}"')' \
        '*--dns=[IPs or shortnames of DNS-over-UDP resolvers (repeatable)]:Do53 IP or shortname:('"${known_dns_resolvers[*]}"')' \
        '(-q --queries)'{-q,--queries=}'[number of domain resolutions to perform (default 10)]:N:' \
        '*'{-n,--names=}'[domain names to resolve (repeatable; default example.com)]:domain:_hosts' \
        '(--rr --rrtype)'{--rr=,--rrtype=}'[resource record type of the query (default A)]:RR type:('"${known_rrtypes[*]}"')' \
        '--proxy[use a DNS-to-DoH proxy server (default false)]' \
        '*'{-p,--percentiles=}'[percentile measurement times in milliseconds (repeatable; default 5 50 95)]:percentile 1-100:' \
        '--histogram[include all percentiles from 1 through 100 (only with --ndjson)]' \
        '(--ndjson --jsonl --json)'{--ndjson,--jsonl,--json}'[output as NDJSON instead of human-readable report]' \
        '--report[view results as table and graphs (default true; use --no-report to disable)]' \
        '--no-report[disable the human-readable report]' \
        '--spinner[animation to soothe the mind while waiting (default true)]' \
        '--no-spinner[disable the spinner animation]'
}

_bulldohzer "$@"
