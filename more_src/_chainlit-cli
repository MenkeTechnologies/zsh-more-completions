#compdef chainlit-cli
# Documentation: https://docs.chainlit.io
# Reference accessed: 2026-05-23
# Verified: chainlit --help (see also _chainlit).

# Zsh completion for chainlit-cli - Chainlit LLM app CLI package name

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'chainlit command' \
      'run[run Chainlit app]' \
      'hello[run hello demo]' \
      'init[initialize project]' \
      'create-secret[create auth secret]' \
      'lint-translations[lint translation files]' && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments \
          '(-w --watch)'{-w,--watch}'[reload on file changes]' \
          '(-h --headless)'{-h,--headless}'[do not open browser]' \
          '(-d --debug)'{-d,--debug}'[debug logging]' \
          '(-c --ci)'{-c,--ci}'[CI mode]' \
          '(-h --host)'{-h,--host}'[bind host]:host:' \
          '(-p --port)'{-p,--port}'[bind port]:port:' \
          ':app file:_files' && ret=0
        ;;
      init)
        _arguments ':directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
