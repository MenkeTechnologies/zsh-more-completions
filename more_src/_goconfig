#compdef goconfig
# Documentation: https://github.com/rpsene/goconfig
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above. goconfig is rpsene/goconfig — a Go install/version manager (go.sh).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install a Go version'
  'remove:uninstall a Go version'
  'update:update Go to latest version'
  'env:print/setup environment'
  'versions:list available remote Go versions'
  'use:switch active Go version'
  'list:list locally installed versions'
  'status:show current configuration status'
  'cache:cache management (clear)'
  'config:show or save configuration'
  'self-update:update goconfig itself'
  'completions:generate shell completions'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose/debug output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'goconfig command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (cache) _values 'cache subcommand' 'clear' && ret=0 ;;
      (config) _values 'config subcommand' 'show' 'save' && ret=0 ;;
      (completions) _values 'shell' 'bash' 'zsh' 'fish' && ret=0 ;;
    esac ;;
esac

return ret
