#compdef slow_cooker
# _slow_cooker — load generator that focuses on tail latency (buoyantio/slow_cooker)
# upstream: https://github.com/buoyantio/slow_cooker
# Flags from main.go.

_slow_cooker() {
    _arguments \
        '-help[show help]' \
        '-qps=[QPS per request thread]:qps:' \
        '-concurrency=[number of request threads]:n:' \
        '-iterations=[number of iterations (0 = infinite)]:n:' \
        '-host=[value of Host header]:host:' \
        '-method=[HTTP method]:method:(GET POST PUT DELETE HEAD PATCH)' \
        '-interval=[reporting interval]:duration:' \
        '-noreuse[do not reuse connections]' \
        '-compress[use HTTP compression]' \
        '-timeout=[per-request timeout]:duration:' \
        '-noLatencySummary[suppress final latency summary]' \
        '-reportLatenciesCSV=[CSV file to write latency report]:file:_files' \
        '-latencyUnit=[latency unit]:unit:(ms us ns)' \
        '-totalRequests=[total number of requests before exit]:n:' \
        '*-header=[HTTP request header (repeatable)]:header:' \
        '-data=[HTTP request body data]:data:' \
        '-metric-addr=[address to serve metrics on]:addr:' \
        '-hashValue=[fnv-1a hash value to validate body against]:hash:' \
        '-hashSampleRate=[sample rate 0.0-1.0]:rate:' \
        '1:url:'
}

_slow_cooker "$@"
