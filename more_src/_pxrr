#compdef pxrr
# Documentation: https://github.com/FePhyFoFum/phyx/wiki/Program-list
# phyx pxrr: reroot and unroot trees.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-t+[input tree file]:file:_files' \
  '-g+[outgroup taxa (comma-separated)]:taxa:' \
  '-u[unroot the tree]' \
  '-s[silent: proceed with available outgroups]' \
  '-r[root on first present outgroup (ranked)]' && ret=0

return ret
