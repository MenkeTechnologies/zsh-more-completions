#compdef ridgepole
# _ridgepole — database schema management tool
# upstream: https://github.com/ridgepole/ridgepole

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-c --config)'{-c,--config=}'[database config file]:file:_files' \
    '(-E --env)'{-E,--env=}'[environment]:env:(development test staging production)' \
    '(-a --apply)'{-a,--apply}'[apply Schemafile to database]' \
    '(-e --export)'{-e,--export}'[export database schema to file]' \
    '--merge[merge Schemafile into database without drop]' \
    '(-f --file)'{-f,--file=}'[Schemafile path]:file:_files' \
    '(-o --output)'{-o,--output=}'[output file for export]:file:_files' \
    '--diff=[diff between two databases or files]:source dest:' \
    '--dry-run[show SQL without executing]' \
    '--table-options=[table options]:options:' \
    '--alter-extra=[extra alter table options]:options:' \
    '--external-script=[external script to run]:script:_files' \
    '--bulk-change[apply all changes in a single ALTER TABLE]' \
    '--default-bool-limit=[default limit for boolean columns]:limit:' \
    '--default-int-limit=[default limit for integer columns]:limit:' \
    '--default-float-limit=[default limit for float columns]:limit:' \
    '--default-string-limit=[default limit for string columns]:limit:' \
    '--default-text-limit=[default limit for text columns]:limit:' \
    '--default-binary-limit=[default limit for binary columns]:limit:' \
    '--enable-foreigner[enable Foreigner integration]' \
    '--enable-mysql-awesome[enable MySQL awesome support]' \
    '--enable-migration-comments[enable migration comments]' \
    '--skip-drop-table[skip drop table operations]' \
    '--dump-with-default-fk-name[dump with default FK names]' \
    '--index-removed-drop-column[remove index when column is dropped]' \
    '--mysql-change-table-comment[apply MySQL table comment changes]' \
    '--check-relation-type=[check column relation type]:type:' \
    '(-t --tables)'{-t,--tables=}'[target tables (comma-separated)]:tables:' \
    '--ignore-tables=[tables to ignore (comma-separated)]:tables:' \
    '--verbose[verbose output]' \
    '--debug[debug output]' \
    && return 0
