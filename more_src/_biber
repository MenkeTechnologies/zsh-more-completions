#compdef biber

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help message]'
  '(-V --version)'{-V,--version}'[show version]'
  '--cache[show the biber cache location]'
  '--clrmacros[clear all BibLaTeX macros before processing]'
  '(-c --configfile)'{-c,--configfile}'[use a configuration file]:config file:_files'
  '(-C --convert-control)'{-C,--convert-control}'[convert control characters in UTF-8 output]'
  '(-d --debug)'{-d,--debug}'[turn on debugging for biber]'
  '--decodecharsset[decode LaTeX chars set]:set:'
  '(-D --diealiases)'{-D,--diealiases}'[error on alias fields]'
  '--dot-include[specify DOT graph elements to include]:elements:'
  '-e[encoding of the .bib files]:encoding:'
  '-E[encoding of the .bbl file]:encoding:'
  '(-g --glob-datasources)'{-g,--glob-datasources}'[glob the datasource filenames]'
  '--input-directory[directory for input files]:directory:_directories'
  '--input-encoding[input file encoding]:encoding:'
  '--isbn10[force ISBN-10 normalisation]'
  '--isbn13[force ISBN-13 normalisation]'
  '--isbn-normalise[normalise ISBNs]'
  '--logfile[use a log file]:log file:_files'
  '--listencodings[list supported encodings]'
  '(-l --logfile)'{-l,--logfile}'[set log file location]:log file:_files'
  '--map-debug[show data source field mapping debug info]'
  '(-m --mincrossrefs)'{-m,--mincrossrefs}'[minimum number of crossrefs for xref inclusion]:number:'
  '--no-bblxml-schema[do not validate bblxml output]'
  '--no-bltxml-schema[do not validate bltxml config]'
  '--noconf[do not look for configuration file]'
  '--nolog[do not write a log file]'
  '--nostdmacros[do not load default macro definitions]'
  '--onlylog[do not write to screen, only log file]'
  '--others-string[set the "others" string]:string:'
  '--output-align[align field values in output]:alignment:'
  '--output-annotation-marker[set annotation marker]:marker:'
  '--output-directory[output directory]:directory:_directories'
  '--output-encoding[output file encoding]:encoding:'
  '(-O --output-file)'{-O,--output-file}'[output file name]:output file:_files'
  '--output-fieldcase[set output field case]:case:(upper lower title)'
  '--output-file[set output file]:file:_files'
  '--output-format[set output format]:format:(bbl bblxml)'
  '--output-indent[set output indentation]:indent:'
  '--output-listsep[set output list separator]:separator:'
  '--output-namesep[set output name separator]:separator:'
  '--output-safechars[restrict output to ASCII]'
  '--output-safecharsset[set safe chars set for output]:set:'
  '(-q --quiet)'{-q,--quiet}'[quiet mode]'
  '--recodedata[file for reencoding data]:file:_files'
  '-s[sort order]:order:'
  '--sortcase[case-sensitive sorting]'
  '--sortdebug[add sorting debug info to output]'
  '--sortupper[uppercase before lowercase sorting]'
  '--strip-comments[strip all comments from output]'
  '(-T --tool)'{-T,--tool}'[run in tool mode]'
  '--tool-config[config file for tool mode]:config file:_files'
  '--tool-noremove[do not remove missing entries in tool mode]'
  '--tool-resolve[resolve cross-references in tool mode]'
  '(-t --trace)'{-t,--trace}'[turn on tracing]'
  '(-u --input-encoding)'{-u,--input-encoding}'[input encoding]:encoding:'
  '(-U --output-encoding)'{-U,--output-encoding}'[output encoding]:encoding:'
  '--validate-config[validate the biber config against the schema]'
  '--validate-control[validate the .bcf file against the schema]'
  '--validate-datamodel[validate against the data model]'
  '(-w --wraplines)'{-w,--wraplines}'[wrap output lines]'
  '*:bcf file:_files -g "*.bcf"'
)

_arguments -s -S $arguments
