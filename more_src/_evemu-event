#compdef evemu-event
# Documentation: https://man.archlinux.org/search?q=evemu-event
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--sync)--sync[send a SYN_REPORT event after]' \
  '(--type)--type=+[event type]:type:' \
  '(--code)--code=+[event code]:code:' \
  '(--value)--value=+[event value]:val:' \
  '*:device:_files -g "/dev/input/event*"' && ret=0

return ret
