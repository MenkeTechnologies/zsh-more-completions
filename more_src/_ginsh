#compdef ginsh
# Documentation: https://www.ginac.de/tutorial/Brief-Demonstration.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:script:_files' && ret=0

return ret
