#compdef hledger-web
# Documentation: https://hledger.org/hledger-web.html
# Documentation: https://github.com/simonmichael/hledger/blob/master/hledger-web/Hledger/Web/WebOptions.hs
# Reference accessed: 2026-05-27
# Verified: upstream hledger-web/Hledger/Web/WebOptions.hs (webflags list).

# Zsh completion for hledger-web (web interface for hledger).
# Only the web-specific flags from WebOptions.hs are listed here; the
# command also accepts hledger's general reporting flags which are not
# enumerated to keep this completion focused on the hledger-web binary.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--serve-browse[serve the web UI and JSON API, open a browser, exit when idle (default)]' \
  '--serve[just serve the web UI and JSON API]' \
  '--serve-api[just serve the JSON API]' \
  '--allow=[set the user access level for changing data]:level:(view add edit sandstorm)' \
  '--cors=[allow cross-origin requests from the specified origin]:origin:' \
  '--host=[listen on this IP address]:ip address:' \
  '--port=[listen on this TCP port]:port:' \
  '--socket=[listen on the given unix socket instead of an IP/port]:socket:_files' \
  '--base-url=[set the base url]:url:' \
  '--test[run hledger-web tests and exit]' \
  '(-f --file)'{-f+,--file=}'[journal file]:file:_files -g "*.{journal,hledger,csv,tsv}"' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:query:' && ret=0

return ret
