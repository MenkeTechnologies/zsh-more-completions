#compdef clickhouse-keeper clickhouse-keeper-client

local cmd="${words[1]}"

if [[ $cmd == clickhouse-keeper ]]; then
  _arguments -s \
    '--config=[config file]:file:_files -g "*.(xml|yaml|yml)"' \
    '--config-file=[config file]:file:_files -g "*.(xml|yaml|yml)"' \
    '--pid-file=[pid file]:file:_files' \
    '--daemon[run as daemon]' \
    '--help[show help]' \
    '(-V --version)'{-V,--version}'[show version]'
else
  _arguments -s \
    '(-q --query)'{-q,--query}'=[query]:query:' \
    '(-h --host)'{-h,--host}'=[host]:host:_hosts' \
    '(-p --port)'{-p,--port}'=[port]:port:' \
    '(-c --config-file)'{-c,--config-file}'=[config file]:file:_files' \
    '--password=[password]:password:' \
    '--identity=[auth identity]:identity:' \
    '--connection-timeout=[connection timeout]:s:' \
    '--session-timeout=[session timeout]:s:' \
    '--operation-timeout=[operation timeout]:s:' \
    '--history-file=[history file]:file:_files' \
    '--log-level=[log level]:level:' \
    '--no-confirmation[skip confirmations]' \
    '--help[show help]'
fi
