#compdef gzr
# ============================================================================
#  _gzr — gzr: A Command Line Tool for Looker Content Management
#
#  Source-direct extraction from
#    https://github.com/looker-open-source/gzr/blob/main/lib/gzr/cli.rb
#    https://github.com/looker-open-source/gzr/tree/main/lib/gzr/commands
#    https://github.com/rails/thor (the Thor library)
#
#  Maintained by Looker (looker-open-source/gzr) — Google Looker Data
#  Sciences team.  133 GH stars.  gzr manages Looker BI content via the
#  Looker API — alerts, attributes, permissions, queries, roles, plans,
#  groups, LookML models, connections, users, dashboards, looks, folders
#  (a.k.a. "spaces"), sessions, and projects.  Sister tools: lookml
#  (LookML compiler), bigquery CLI, tableau-server-client.
#
#  CLI library taxonomy update: 2nd Ruby CLI library — Thor.  Ruby
#  ecosystem now has 2 documented CLI libraries (R280 + R358 Thor)
#  joining the multi-library leaders.  Thor (rails/thor) is THE
#  de-facto Ruby CLI framework — used by Bundler, Rails generators
#  (bin/rails), Vagrant, Chef, Jekyll, Middleman, Foreman, Capistrano,
#  CocoaPods, Padrino, Fastlane, and ALMOST EVERY major Ruby CLI tool
#  + EVERY Rails generator (`rails generate scaffold` etc. use Thor
#  under the hood).  ~4400 GH stars on rails/thor.
#
#  Thor API:
#    require 'thor'
#    class CLI < Thor
#      class_option :debug, type: :boolean, default: false, desc: '...'
#      class_option :host, type: :string, default: 'localhost'
#
#      desc 'version', 'Show version'
#      def version
#        puts "v#{Gzr::VERSION}"
#      end
#      map %w(--version -v) => :version    # flag aliases
#      map space: :folder                  # subcommand alias
#
#      register Gzr::Commands::Alert, 'alert', 'alert [SUBCOMMAND]',
#               'Alert subcommands'
#      register Gzr::Commands::Dashboard, 'dashboard',
#               'dashboard [SUBCOMMAND]', 'Dashboard subcommands'
#      ...
#    end
#
#  Thor distinctive features:
#    - `class CLI < Thor` — INHERIT from Thor base class
#    - `desc 'verb', 'description'` + `def verb; ... end` — RUBY METHOD
#      DEFINITION as a CLI command — method NAME becomes verb name
#    - `class_option :name, type: :T, default: V, desc: 'X'` — GLOBAL
#      option visible across all commands in this class
#    - `option :name, type: :T, default: V, desc: 'X'` (before `def`)
#      — PER-COMMAND option
#    - `type:` values: `:string`/`:numeric`/`:boolean`/`:array`/`:hash`
#    - `register SubClass, 'name', 'usage', 'description'` — REGISTER a
#      SUBCOMMAND AS A SEPARATE THOR CLASS — `gzr alert init` dispatches
#      to `Gzr::Commands::Alert#init`
#    - `map %w(--version -v) => :version` — FLAG ALIASES via hash
#      mapping
#    - `map space: :folder` — SUBCOMMAND ALIAS (same as flag alias but
#      maps subcommand names)
#    - `self.exit_on_failure?` — class method for exit behavior
#    - `options[:name]` — accessor for parsed values inside command
#      method (`options` is implicit hash on the Thor instance)
#  Distinct from R346 mainargs (Scala annotations on methods), R275
#  clap-derive (Rust struct + macro), R340 oclif (TS class-inheritance
#  with static fields), R341 yargs (TS fluent builder), R343 commander.js
#  (TS explicit-instance builder), R356 Symfony Console (PHP class-
#  inheritance with attribute), R322 JCommander (Java annotations on
#  fields).  Thor's approach: CLASS-INHERITANCE + RUBY METHOD-AS-COMMAND
#  + `register SubClass` for subcommand groups — corpus's **first
#  documented Ruby-method-name-as-command-name CLI pattern**.
#  Brings cross-language CLI library taxonomy variant count to 97;
#  Ruby ecosystem now has 2 documented CLI libraries.
#
#  Surface (verbatim from lib/gzr/cli.rb `class CLI < Thor`):
#
#  Global flags (class_option in CLI class — visible to all subcommands):
#    --debug                 Run in debug mode (default false)
#    --host=HOST             Looker Host (default localhost)
#    --port=PORT             Looker API Port (default 19999)
#    --client_id=ID          API Client Id
#    --client_secret=SECRET  API Client Secret
#    --ssl                   Use SSL (default true)
#    --verify_ssl            Verify SSL certificate (default true)
#    --timeout=N             Seconds to wait for response (default 60)
#    --http_proxy=URL        HTTP Proxy for Looker host
#    --force                 Overwrite objects on server (default false)
#    --su=USER_ID            After connecting, change to user_id
#    --width=N               Width of rendering for tables
#    --token=TOKEN           Access token for authentication
#    --token_file            Use access token stored in file
#    -v, --version           Show gzr version
#
#  Top-level subcommands (each `register`-ed as separate Thor class):
#    version                 Show gzr version
#    alert                   Alert subcommands
#    attribute               Attribute subcommands
#    permission              Permission subcommands
#    query                   Query subcommands
#    role                    Role subcommands
#    plan                    Plan subcommands
#    group                   Group subcommands
#    model                   LookML Model subcommands
#    connection              Connection/dialect subcommands
#    user                    User subcommands
#    dashboard               Dashboard subcommands
#    look                    Look subcommands
#    folder | space          Folder subcommands (alias: space)
#    session                 Session subcommands
#    project                 Project subcommands
#
#  Dup-skipped neighbors during hunt (already in corpus):
#    - bundler (Ruby package manager — IN CORPUS, uses Thor)
#    - rails (Ruby on Rails — IN CORPUS, uses Thor for generators)
#    - jekyll (Ruby static site gen — IN CORPUS, uses Thor)
#    - middleman (Ruby static site gen — IN CORPUS via blacklist,
#      uses Thor)
#    - chef (Chef Infra — IN CORPUS, uses Thor for knife)
#    - cocoapods (pod — IN CORPUS, uses Thor)
#    - fastlane (Ruby iOS automation — IN CORPUS, uses Thor)
#    - vagrant (HashiCorp Vagrant — IN CORPUS, uses Thor)
#    - fpm (jordansissel/fpm — IN CORPUS, uses Thor-like option parsing)
#    - haml (HTML Abstraction Markup Language — IN CORPUS)
# ============================================================================

_gzr() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '--debug[run in debug mode]' \
    '--host=[Looker host]:host:_hosts' \
    '--port=[Looker API port (default 19999)]:port' \
    '--client_id=[API client ID]:client id' \
    '--client_secret=[API client secret]:client secret' \
    '--ssl[use SSL]' \
    '--verify_ssl[verify SSL certificate]' \
    '--timeout=[seconds to wait for response]:seconds' \
    '--http_proxy=[HTTP proxy URL]:proxy URL' \
    '--force[overwrite objects on server]' \
    '--su=[after connecting, change to user_id]:user id' \
    '--width=[width of rendering for tables]:width' \
    '--token=[access token for authentication]:token' \
    '--token_file[use access token stored in file]' \
    '(-v --version)'{-v,--version}'[show gzr version]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'version:show gzr version'
        'alert:alert subcommands'
        'attribute:attribute subcommands'
        'permission:permission subcommands'
        'query:query subcommands'
        'role:role subcommands'
        'plan:plan subcommands'
        'group:group subcommands'
        'model:LookML Model subcommands'
        'connection:connection/dialect subcommands'
        'user:user subcommands'
        'dashboard:dashboard subcommands'
        'look:look subcommands'
        'folder:folder subcommands'
        'space:folder subcommands (alias)'
        'session:session subcommands'
        'project:project subcommands'
        'help:show help'
      )
      _describe -t commands 'gzr subcommand' verbs
      ;;
  esac
}

_gzr "$@"
