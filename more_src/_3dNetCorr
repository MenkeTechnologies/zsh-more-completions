#compdef 3dNetCorr
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dNetCorr.html
# AFNI: ROI-based correlation matrices from time series

local ret=1

_arguments -s -S \
  '-prefix[output file name prefix]:prefix:' \
  '-inset[4D time series dataset]:dataset:_files' \
  '-in_rois[ROI file with integer labels]:rois:_files' \
  '-mask[brain mask]:mask:_files' \
  '-fish_z[output Fisher Z-transform values]' \
  '-part_corr[generate partial correlation matrices]' \
  '-ts_out[output mean time series per ROI]' \
  '-ts_label[include ROI label at line start]' \
  '-ts_indiv[directory of individual ROI time series]' \
  '-ts_wb_corr[whole brain Pearson correlation maps]' \
  '-ts_wb_Z[whole brain Fisher Z-score maps]' \
  '-weight_ts[multiplicative weights for ROI time series]:file:_files' \
  '-weight_corr[weighted Pearson correlation]:file:_files' \
  '-ts_wb_strlabel[string labels in whole brain output]' \
  '-nifti[output correlation maps as NIFTI]' \
  '-output_mask_nonnull[output mask of non-null time series]' \
  '-push_thru_many_zeros[allow calc despite >10% null voxels]' \
  '-allow_roi_zeros[permit ROIs with all-zero time series]' \
  '-automask_off[disable internal automasking]' \
  '-ignore_LT[ignore label table in ROI file]' \
  '*:dataset:_files' && ret=0

return ret
