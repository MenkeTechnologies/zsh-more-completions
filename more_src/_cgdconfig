#compdef cgdconfig
# Documentation: man cgdconfig(8)
# Source: netbsd/src sbin/cgdconfig — cryptographic disk driver configuration (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C[configure all devices in configuration file]' \
    '-e[echo the passphrase]' \
    '-f+[configuration file]:config file:_files' \
    '-G[generate new paramsfile from existing one]' \
    '-g[generate a paramsfile to stdout]' \
    '-i+[IV method (default encblkno1)]:ivmeth:_default' \
    '-k+[key generation method (default pkcs5_pbkdf2/sha1)]:kgmeth:_default' \
    '-l[list state of cgd devices]' \
    '-n[dry run, report steps only]' \
    '-o+[output file for generated paramsfile]:outfile:_files' \
    '-P+[parameters file with shared key]:paramsfile:_files' \
    '-p[read passphrases from stdin]' \
    '-S[use subkey of shared key]' \
    '-s[read key from stdin]' \
    '-T[generate all keys for all devices in config file]' \
    '-t[generate key, print to stdout in base64]' \
    '-U[unconfigure all devices in configuration file]' \
    '-u[unconfigure a cgd]' \
    '-V+[verification method (default none)]:vmeth:_default' \
    '*-v[be verbose (repeatable)]' \
    '*::cgd, disk device, or paramsfile:_files' \
    && ret=0

return ret
