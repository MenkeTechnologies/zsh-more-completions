#compdef opm
# Documentation: https://man.archlinux.org/search?q=opm
# Reference accessed: 2026-05-16

# opm: Operator Lifecycle Manager registry tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'alpha:alpha subcommands'
  'completion:emit shell completion'
  'generate:generate registry data'
  'index:operator-registry index commands'
  'init:init a registry catalog'
  'migrate:migrate registry data'
  'registry:registry server commands'
  'render:render registry objects to DC catalog'
  'serve:serve a registry catalog'
  'validate:validate a catalog'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--skip-tls[skip TLS]' \
  '--skip-tls-verify[skip TLS verify]' \
  '--use-http[use HTTP]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'opm command' commands && ret=0 ;;
esac
return ret
