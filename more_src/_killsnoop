#compdef killsnoop killsnoop-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/killsnoop.py argparse)
# Reference accessed: 2026-05-29
# killsnoop — trace kill() signals (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-x --failed)'{-x,--failed}'[only show failed kill syscalls]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only (sender)]:pid:_pids' \
  '(-T --tpid)'{-T,--tpid=}'[trace this target PID only (receiver)]:pid:_pids' \
  '(-s --signal)'{-s,--signal=}'[trace a signal or comma-separated list]:signal:(TERM KILL HUP INT QUIT USR1 USR2 STOP CONT WINCH PIPE TSTP ABRT ALRM CHLD)' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
