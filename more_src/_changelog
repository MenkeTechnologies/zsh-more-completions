#compdef changelog
# Documentation: https://github.com/schpet/changelog
# Reference accessed: 2026-05-23
# Verified: upstream README commands (add, release, review, version, entry, fmt, init).

# Zsh completion for changelog - keep-a-changelog CLI (schpet)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add changelog entry'
  'release:release unreleased section'
  'review:interactive commit review'
  'version:show version info'
  'entry:show version entry'
  'fmt:format changelog'
  'init:create CHANGELOG.md'
  'completions:generate shell completions'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'changelog command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '--type[change type]:type:(added changed deprecated removed fixed security)' \
          '--version[target version]:version:' \
          '--attribute-pr[attribute PR from commit]:sha:' \
          '--exclude-users[exclude users from attribution]:users:' \
          ':message:' && ret=0
        ;;
      (release)
        _arguments \
          ':level:(major minor patch)' \
          '--date[release date]:date:' && ret=0
        ;;
      (version)
        _arguments '1:sub:(latest list range)' && ret=0
        ;;
      (entry|fmt|init|review|completions)
        _arguments '*::args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
