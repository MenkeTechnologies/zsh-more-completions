#compdef amavisd-nanny
# Documentation: https://www.manpagez.com/man/8/amavisd-nanny/
# show status and health of amavisd-new child processes

local ret=1

_arguments -s -S \
  '-c[number of check rounds, then exit]:count' \
  '-w[wait interval in seconds between updates]:seconds' \
  '*:socket:_files' && ret=0

return ret
