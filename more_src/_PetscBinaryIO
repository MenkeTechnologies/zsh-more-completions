#compdef PetscBinaryIO
# Documentation: https://gitlab.com/petsc/petsc/-/blob/main/lib/petsc/bin/PetscBinaryIO.py
# PETSc binary matrix/vector I/O utility (MatrixMarket -> PETSc conversion)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '1:command:((convert\:"convert matrices to/from PETSc format"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '(-o --outfile)'{-o,--outfile}'[name of output file]:file:_files' \
      '--symmetrize[symmetrize (A+A^T)/2 during conversion]' \
      '--precision[precision of scalar values]:precision:(single double __float128)' \
      '--complex[use complex scalars]' \
      '--indices[integer size for indices]:size:(32bit 64bit)' \
      '1:infile:_files' && ret=0
    ;;
esac

return ret
