#compdef genai-perf
# Documentation: https://github.com/triton-inference-server/perf_analyzer/blob/main/genai-perf/README.md
# NVIDIA GenAI-Perf: benchmark generative AI model serving

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --model)'{-m,--model}'=[model name(s) to benchmark]:model:' \
  '(-u --url)'{-u,--url}'=[server endpoint URL]:url:' \
  '--backend=[inference backend]:backend:(tensorrtllm vllm)' \
  '--endpoint-type=[request endpoint type]:type:(kserve chat completions embeddings rankings multimodal)' \
  '--streaming[enable streaming API]' \
  '--concurrency=[number of concurrent requests]:count:' \
  '--request-rate=[requests per second]:rate:' \
  '--warmup-request-count=[warm-up requests before measurement]:count:' \
  '--synthetic-input-tokens-mean=[mean synthetic input token count]:count:' \
  '--output-tokens-mean=[mean output token count]:count:' \
  '--tokenizer=[HuggingFace tokenizer name or path]:tokenizer:' \
  '(-p --measurement-interval)'{-p,--measurement-interval}'=[measurement window in ms]:ms:' \
  '--stability-percentage=[latency variation tolerance]:percent:' \
  '--artifact-dir=[output directory for results]:dir:_files -/' \
  '--generate-plots[generate visualization plots]' \
  '1:command:((
    profile\:"run performance benchmarking"
    analyze\:"sweep through multiple scenarios"
    config\:"benchmark from a YAML config file"
    create-template\:"generate a template config file"
    process-export-files\:"aggregate distributed run export files"
  ))' \
  '*::arg:->args' && ret=0

return ret
