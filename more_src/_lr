#compdef lr
# Documentation: https://man.archlinux.org/search?q=lr
# Reference accessed: 2026-05-16

# leahneukirchen/lr — file list (`lr.c` getopt: 01ABC:DFGHLPQST:UWXde:f:hlo:qst:x)

local ret=1
_arguments -s -S \
  '-0[\\0-delimited output; disable -Q/-P defaults]' \
  '-1[prune everything except depth>0 (hide top)]' \
  '-A[hide dot-files except . and .. at depth>0]' \
  '-B[balanced tree (repeat for “wide” tree); clears -D/-U]' \
  '-C+[colorized path (repeatable)]:colorpath:' \
  '-D[ASCII depth indentation; clears -B/-U]' \
  '-F[print type character (like ls -F)]' \
  '-G[color; tty enables; NO_COLOR disables]' \
  '-H[do not follow symlinks (for -l)]' \
  '-L[follow symlinks]' \
  '-Q[quote filenames (default on tty)]' \
  '-P[force shell-escaping (-Q)]' \
  '-S[stat-style one-line format (-Q)]' \
  '-T+[time field selection for -l]:field:' \
  '-W[ordering by disk block (-o ord); clears -B/-U]' \
  '-U[ordering for inode-heavy dirs; clears -B/-W]' \
  '-X[print relative path from hostname-based base]' \
  '-d[directories only (prune files)]' \
  '-e+[filter path by regex]:regex:' \
  '-f+[output format string]:format:' \
  '-h[human-readable sizes]' \
  '-l[long listing (-Q); implies stat work]' \
  '-o+[sort ordering key]:key:' \
  '-s[show apparent directory size]' \
  '-t+[add filter expression]:expr:' \
  '-q[quiet errors]' \
  '-x[print paths relative to start dir (-X)]' \
  '*:paths:_files -/' && ret=0
return ret
