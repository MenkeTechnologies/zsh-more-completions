#compdef lr
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/lr.1.html
# Reference accessed: 2026-05-17
# Verified: leahneukirchen/lr — Ubuntu focal lr(1) manpage.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -C/-P/-S/-T/-h/-s/-q/-X (none in upstream getopt string);
# fabricated -1 description and -B "balanced" semantics.

# lr: list files, recursively
local curcontext="$curcontext" ret=1
_arguments -C \
  '-0[NUL-terminated output]' \
  '-1[do not descend below one level]' \
  '-A[list dotfiles too (skip ./..)]' \
  '-B[breadth-first traversal]' \
  '-D[depth-first traversal]' \
  '-F[append type indicator]' \
  '-G[colorize output]' \
  '-H[follow command-line symlinks]' \
  '-L[dereference all symlinks]' \
  '-Q[quote names]' \
  '-U[unsorted (print during traversal)]' \
  '-W[sort, print during traversal]' \
  '-d[list directories themselves]' \
  '-f[printf-style format]:fmt:' \
  '-l[long output (implies -Q)]' \
  '-o[sort expression]:expr:' \
  '-e[boolean filter expression]:expr:' \
  '-t[prune expression]:expr:' \
  '-x[stay on one filesystem]' \
  '*:paths:_files -/' && ret=0
return ret
