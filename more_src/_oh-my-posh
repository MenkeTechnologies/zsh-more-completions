#compdef oh-my-posh
# Documentation: https://github.com/JanDeDobbeleer/oh-my-posh/tree/main/src/cli
# Reference accessed: 2026-05-19
# Verified: upstream Cobra command sources at the URL above.

local curcontext="$curcontext" state line ret=1

_oh-my-posh_commands() {
  local -a commands=(
    'auth:manage authentication'
    'cache:interact with the oh-my-posh cache'
    'config:interact with the config'
    'debug:print the prompt in debug mode'
    'disable:disable a feature'
    'enable:enable a feature'
    'font:manage fonts'
    'get:get a value from oh-my-posh'
    'init:initialize the shell'
    'notice:print the upgrade notice'
    'print:print the prompt/context'
    'shell:shell-related operations'
    'stream:stream-related operations'
    'toggle:toggle one or more segments on/off'
    'upgrade:upgrade the oh-my-posh executable'
    'version:print the version'
    'help:help about any command'
  )
  _describe -t commands 'oh-my-posh command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '(-s --shell)'{-s,--shell}'[shell]:shell:(bash zsh fish powershell pwsh nu cmd elvish xonsh)' \
  '(-i --init)'{-i,--init}'[init]' \
  '--version[print version and exit]' \
  '--silent[do not print anything]' \
  '--trace[enable tracing]' \
  '--plain[plain text output (no ANSI)]' \
  '1: :_oh-my-posh_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      init)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-p --print)'{-p,--print}'[print the init script]' \
          '(-s --strict)'{-s,--strict}'[run in strict mode]' \
          '--debug[enable/disable debug mode]' \
          '--eval[output the full init script for eval]' \
          '1:shell:(bash zsh fish powershell pwsh cmd nu elvish xonsh)' && ret=0
        ;;
      print)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--pwd=[current working directory]:pwd' \
          '--pswd=[current working directory per pwsh]:pwd' \
          '--shell=[shell to print for]:shell:(bash zsh fish powershell pwsh cmd nu elvish xonsh)' \
          '--shell-version=[shell version]:version' \
          '--status=[last known status code]:n' \
          '--no-status[no valid status code]' \
          '--pipestatus=[PIPESTATUS array]:status' \
          '--execution-time=[last command execution time]:ms' \
          '(-s --stack-count)'{-s,--stack-count}'[number of locations on stack]:n' \
          '(-w --terminal-width)'{-w,--terminal-width}'[terminal width]:n' \
          '--command=[tooltip command]:cmd' \
          '--cleared[cleared terminal]' \
          '--eval[output the prompt for eval]' \
          '--column=[cursor column position]:n' \
          '--job-count=[number of background jobs]:n' \
          '(-f --force)'{-f,--force}'[force rendering the segments]' \
          '1:type:(debug primary secondary transient right tooltip valid error preview)' && ret=0
        ;;
      config)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(edit export)' \
          '*:: :->cfgargs' && ret=0
        case $state in
          cfgargs)
            case $words[1] in
              export)
                _arguments \
                  '(-f --format)'{-f,--format}'[config format]:format:(json yaml toml)' \
                  '(-o --output)'{-o,--output}'[output file]:file:_files' \
                  '1:subcommand:(image)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      debug)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--pwd=[current working directory]:pwd' && ret=0
        ;;
      disable|enable)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:feature:(notice upgrade reload)' && ret=0
        ;;
      get)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:key:(millis shell accent toggles width)' && ret=0
        ;;
      toggle)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:segment name' && ret=0
        ;;
      upgrade)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --force)'{-f,--force}'[force the upgrade even if up to date]' \
          '--auto[respect cache interval for automatic upgrades]' \
          '--debug[enable/disable debug mode]' && ret=0
        ;;
      font)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--zip-folder=[folder inside the zip file]:folder' \
          '--headless[install font without TUI]' \
          '1:subcommand:(install configure)' \
          '*:font name' && ret=0
        ;;
      cache)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-s --session)'{-s,--session}'[show the session cache]' \
          '1:subcommand:(path clear ttl show)' && ret=0
        ;;
      version)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-v --verbose)'{-v,--verbose}'[write verbose output]' && ret=0
        ;;
      notice|claude|copilot|stream|shell|auth)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
