#compdef oh-my-posh

# Zsh completion for oh-my-posh - prompt engine for any shell

local curcontext="$curcontext" state line ret=1

_oh-my-posh_commands() {
  local -a commands=(
    'cache:interact with the oh-my-posh cache'
    'completion:generate the autocompletion script for the specified shell'
    'config:interact with the config'
    'debug:print the prompt in debug mode'
    'disable:disable a feature'
    'enable:enable a feature'
    'font:manage fonts'
    'get:get a value from oh-my-posh'
    'help:help about any command'
    'init:initialize the shell'
    'notice:print the upgrade notice'
    'print:print the prompt in the shell'
    'toggle:toggle a segment'
    'upgrade:upgrade the oh-my-posh executable'
    'version:print the version'
  )
  _describe -t commands 'oh-my-posh command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '(-s --shell)'{-s,--shell}'[the shell)]:shell:(bash zsh fish powershell pwsh nu cmd tcsh xonsh elvish)' \
  '1: :_oh-my-posh_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      init)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --config)'{-c,--config}'[config file path]:file:_files' \
          '(-s --strict)'{-s,--strict}'[run in strict mode]' \
          '--manual[enable/disable manual mode]' \
          '--print[print the init script]' \
          '1:shell:(bash zsh fish pwsh powershell nu cmd tcsh xonsh elvish)' && ret=0
        ;;
      print)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --config)'{-c,--config}'[config file path]:file:_files' \
          '--shell[the shell]:shell:(bash zsh fish pwsh cmd)' \
          '--shell-version[the shell version]:version' \
          '--pswd[current working dir]:pwd' \
          '--pipestatus[pipe status values]:status' \
          '--status[last exit code]:status' \
          '--execution-time[last command execution time]:ms' \
          '--stack-count[prompt stack count]:count' \
          '--terminal-width[terminal width]:cols' \
          '--eval[output for eval]' \
          '--no-status[no status reported]' \
          '--cleanpwd[cleaned pwd]:path' \
          '--plain[render in plain text]' \
          '1:type:(primary secondary debug error right tooltip transient valid)' && ret=0
        ;;
      config)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(edit export migrate get)' \
          '*:file:_files' && ret=0
        ;;
      debug)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --config)'{-c,--config}'[config file path]:file:_files' \
          '--plain[render in plain text]' && ret=0
        ;;
      disable|enable)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:feature:(notice upgrade autoupgrade)' && ret=0
        ;;
      get)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:key:(shell millis accent cleanpwd)' && ret=0
        ;;
      toggle)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --config)'{-c,--config}'[config file path]:file:_files' \
          '1:segment name' && ret=0
        ;;
      upgrade)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --force)'{-f,--force}'[force upgrade]' && ret=0
        ;;
      font)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(install)' \
          '*:font name' && ret=0
        ;;
      cache)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(clear edit path)' && ret=0
        ;;
      completion)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      version)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
