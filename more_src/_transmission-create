#compdef transmission-create

# Zsh completion for transmission-create - create torrent files

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-p --private)'{-p,--private}'[mark the torrent as private]' \
  '(-o --outfile)'{-o,--outfile}'[save the generated torrent to this file]:file:_files -g "*.torrent"' \
  '(-s --piecesize)'{-s,--piecesize}'[set the piece size in KiB]:size (KiB)' \
  '(-c --comment)'{-c,--comment}'[add a comment]:comment' \
  '(-t --tracker)'{-t,--tracker}'[add a tracker announce URL]:URL' \
  '(-S --source)'{-S,--source}'[set the source tag for private trackers]:source' \
  '(-V --version)'{-V,--version}'[show version number]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file or directory:_files' && ret=0

return ret
