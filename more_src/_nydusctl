#compdef nydusctl
# _nydusctl — control client for nydusd (dragonflyoss/nydus)
# upstream: https://github.com/dragonflyoss/nydus
# Subcommands from src/bin/nydusctl/main.rs (clap).

_nydusctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--sock=[nydusd API socket]:file:_files' \
        '--raw[raw API response output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'info:get nydusd daemon info'
                'set:set runtime config value'
                'metrics:show daemon metrics'
                'mount:mount a Nydus image'
                'umount:unmount a Nydus image'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                set) _arguments '1:KIND:' '2:VALUE:' ;;
                metrics)
                    _arguments \
                        '--category=[metric category]:cat:(fs blob)' \
                        '--interval=[refresh interval (s)]:secs:'
                    ;;
                mount)
                    _arguments \
                        '--source=[image source]:src:' \
                        '--config=[config file]:file:_files' \
                        '--mountpoint=[mountpoint]:dir:_files -/' \
                        '--type=[FS type]:type:(rafs passthrough)'
                    ;;
                umount) _arguments '--mountpoint=[mountpoint to unmount]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_nydusctl "$@"
