#compdef rofi-pass

# Zsh completion for rofi-pass (rofi-based interface for pass/password-store)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--insert[Insert a new password entry]' \
  '--manage[Open the management menu]' \
  '--last-used[Show the last used entry]' \
  '--show-all[Show all entries]' \
  '--bmarks[Open bookmarks]' \
  '--help[Print help]' && ret=0

return ret
