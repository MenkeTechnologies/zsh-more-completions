#compdef agent-cli agent ag
# Documentation: https://github.com/basnijholt/agent-cli
# Reference accessed: 2026-05-22
# Verified: agent_cli/cli.py and command modules (dev, server, daemon, agents).

# Zsh completion for agent-cli - local-first AI voice/text/dev CLI suite

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'agent-cli command' \
      'transcribe[transcribe audio to clipboard]' \
      'transcribe-live[live transcription]' \
      'chat[conversational AI with tools]' \
      'assistant[wake-word voice assistant]' \
      'autocorrect[correct grammar and spelling]' \
      'speak[text to speech]' \
      'voice-edit[edit clipboard text by voice]' \
      'memory[long-term memory]' \
      'rag-proxy[RAG proxy server]' \
      'diarize-live-session[live speaker diarization]' \
      'speakers[manage speaker profiles]' \
      'dev[parallel dev with worktrees and agents]' \
      'server[ASR/TTS servers]' \
      'daemon[background service management]' \
      'install-services[install Ollama Whisper Piper OpenWakeWord]' \
      'install-hotkeys[install system hotkeys]' \
      'install-extras[install optional Python extras]' \
      'config[view or edit configuration]' && ret=0
    ;;
  args)
    case $line[1] in
      dev)
        if (( CURRENT == 2 )); then
          _values 'dev command' \
            'new[create worktree]' \
            'list[list worktrees]' \
            'status[worktree status]' \
            'rm[remove worktree]' \
            'path[print worktree path]' \
            'editor[open editor in worktree]' \
            'agent[start coding agent]' \
            'agents[list supported agents]' \
            'editors[list supported editors]' \
            'terminals[list supported terminals]' \
            'run[run command in worktree]' \
            'clean[remove stale worktrees]' \
            'doctor[diagnose dev setup]' \
            'install-skill[install dev skill file]' && ret=0
        else
          case $line[2] in
            agent|run|editor)
              _arguments \
                '--agent[coding agent]:agent:(claude codex gemini aider copilot cn opencode cursor-agent auto)' \
                '--editor[editor]:editor:(cursor vscode zed nvim vim emacs sublime idea pycharm)' \
                '--multiplexer[tmux or zellij pane]:mux:(tmux zellij)' \
                '--start-agent[start agent without prompt]' \
                '*:args:' && ret=0
              ;;
            new)
              _arguments '*:branch or path:' && ret=0
              ;;
          esac
        fi
        ;;
      server)
        _arguments \
          '1:server command:(whisper transcribe-proxy tts)' && ret=0
        ;;
      daemon)
        _arguments \
          '1:daemon command:(status install uninstall)' && ret=0
        ;;
      memory)
        _arguments \
          '1:memory command:(add proxy)' \
          '*:: :->memargs' && ret=0
        ;;
      config)
        _arguments \
          '1:config command:(init edit show)' && ret=0
        ;;
    esac
    ;;
esac

return ret
