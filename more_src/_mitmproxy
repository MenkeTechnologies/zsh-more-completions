#compdef mitmproxy

# Zsh completion for mitmproxy - Interactive HTTPS proxy

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--mode[proxy mode]:mode:((regular transparent socks5 reverse upstream))' \
  {-p,--listen-port}'[proxy service port]:port:' \
  '--listen-host[address to bind proxy server to]:host:_hosts' \
  '--set[set an option value]:option:' \
  {-s,--scripts}'[execute a script]:script:_files' \
  '--anticache[strip cache headers]' \
  '--anticomp[strip compression from requests]' \
  '--showhost[use host header for URL display]' \
  '--no-showhost[do not use host header for URL display]' \
  {-n,--no-server}'[do not start a proxy server]' \
  {-k,--ssl-insecure}'[do not verify upstream server SSL certificates]' \
  '--cert[SSL certificate]:cert:_files' \
  '--certs[SSL certificate directory]:dir:_directories' \
  '--client-certs[client certificate directory or file]:path:_files' \
  '--upstream-cert[connect to upstream server to look up certificates]' \
  '--no-upstream-cert[do not connect to upstream server for certificates]' \
  {-q,--quiet}'[quiet mode]' \
  {-v,--verbose}'[increase log verbosity]' \
  {-r,--rfile}'[read flows from file]:file:_files' \
  {-w,--wfile}'[write flows to file]:file:_files' \
  {-a,--afile}'[append flows to file]:file:_files' \
  '--view-filter[limit display to matching flows]:filter:' \
  '--save-stream-file[save stream to file]:file:_files' \
  '--readfile-filter[read filter]:filter:' \
  '--intercept[set intercept filter expression]:filter:' \
  '--tcp-hosts[generic TCP SSL proxy]:host:' \
  '--upstream-auth[upstream proxy authentication]:user\:password:' \
  '--modify-body[modify body]:pattern:' \
  '--modify-headers[modify headers]:pattern:' \
  '--map-remote[map remote]:pattern:' \
  '--map-local[map local]:pattern:' \
  '--stickycookie[set sticky cookie filter]:filter:' \
  '--stickyauth[set sticky auth filter]:filter:' \
  '--console-layout[console layout]:layout:(horizontal vertical single)' \
  '--console-layout-headers[show headers in console layout]' \
  '--no-console-layout-headers[hide headers in console layout]' \
  && return 0
