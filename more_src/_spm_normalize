#compdef spm_normalize
# Documentation: https://github.com/google/sentencepiece/blob/master/src/spm_normalize_main.cc
# SentencePiece text normalizer

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model=[model file name]:model:_files' \
  '--use_internal_normalization[run normalizer as-is for SentencePiece segmentation]' \
  '--normalization_rule_name=[normalization rule name]:rule:(nfkc identity)' \
  '--normalization_rule_tsv=[normalization rule TSV file]:file:_files' \
  '--remove_extra_whitespaces=[remove extra whitespaces]:bool:(true false)' \
  '--decompile[decompile compiled charmap and output it as TSV]' \
  '--input=[input filename]:file:_files' \
  '--output=[output filename]:file:_files' \
  '*:input file:_files' && ret=0

return ret
