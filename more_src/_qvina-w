#compdef qvina-w
# Documentation: https://qvina.github.io/
# QuickVina-W: QuickVina variant optimized for blind (wide-search) docking

local ret=1

_arguments -s -S \
  '(- *)--help[display usage summary]' \
  '(- *)--help_advanced[display usage summary with advanced options]' \
  '(- *)--version[display program version]' \
  '--receptor=[rigid part of the receptor (PDBQT)]:receptor file:_files -g "*.pdbqt"' \
  '--flex=[flexible side chains (PDBQT)]:flex file:_files -g "*.pdbqt"' \
  '--ligand=[ligand (PDBQT)]:ligand file:_files -g "*.pdbqt"' \
  '--center_x=[X coordinate of the center]:X coordinate:' \
  '--center_y=[Y coordinate of the center]:Y coordinate:' \
  '--center_z=[Z coordinate of the center]:Z coordinate:' \
  '--size_x=[size in the X dimension (Angstroms)]:X size:' \
  '--size_y=[size in the Y dimension (Angstroms)]:Y size:' \
  '--size_z=[size in the Z dimension (Angstroms)]:Z size:' \
  '--out=[output models (PDBQT)]:output file:_files -g "*.pdbqt"' \
  '--log=[write log file]:log file:_files' \
  '--score_only[score only - search space can be omitted]' \
  '--local_only[do local search only]' \
  '--randomize_only[randomize input, avoiding clashes]' \
  '--cpu=[number of CPUs to use]:cpus:' \
  '--seed=[explicit random seed]:seed:' \
  '--exhaustiveness=[exhaustiveness of the global search (default 8)]:exhaustiveness:' \
  '--max_evals=[number of evaluations in each MC run (0 = based on box size)]:max evals:' \
  '--num_modes=[maximum number of binding modes to generate (default 9)]:num modes:' \
  '--energy_range=[max energy difference between best and worst mode (default 3)]:energy range:' \
  '--config=[options can be put here]:config file:_files' && ret=0

return ret
