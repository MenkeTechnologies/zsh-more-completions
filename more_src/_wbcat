#compdef wbcat
# _wbcat — Samba wbcat (winbind helper that probes the Winbind daemon's authorization decisions for a username + service against /etc/security/access.conf and prints a one-line yes/no result; --version, --help, -v verbose, -u user, -h hostname, -t service)
# upstream: distro-shipped Samba winbind helper on tip.
# Common flag shape from samba contrib/winbind on tip.

_wbcat() {
    _arguments \
        '-h+[hostname]:host:_hosts' \
        '--help[show help]' \
        '-v[verbose]' \
        '--version[show version]' \
        '-u+[user]:user:_users' \
        '-t+[service]:service:'
}

_wbcat "$@"
