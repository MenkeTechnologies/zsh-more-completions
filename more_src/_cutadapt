#compdef cutadapt

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --adapter)'{-a,--adapter}'[3'\'' adapter sequence]:adapter' \
  '(-g --front)'{-g,--front}'[5'\'' adapter sequence]:adapter' \
  '(-b --anywhere)'{-b,--anywhere}'[5'\'' or 3'\'' adapter sequence]:adapter' \
  '(-A)'-A'[3'\'' adapter for read2]:adapter' \
  '(-G)'-G'[5'\'' adapter for read2]:adapter' \
  '(-B)'-B'[5'\'' or 3'\'' adapter for read2]:adapter' \
  '(-o --output)'{-o,--output}'[output file]:output file:_files' \
  '(-p --paired-output)'{-p,--paired-output}'[output file for read2]:output file:_files' \
  '(-j --cores)'{-j,--cores}'[number of CPU cores]:cores' \
  '(-e --error-rate)'{-e,--error-rate}'[maximum error rate]:rate' \
  '--no-indels[do not allow indels in alignments]' \
  '(-n --times)'{-n,--times}'[remove up to N adapters]:count' \
  '(-O --overlap)'{-O,--overlap}'[minimum overlap length]:length' \
  '--match-read-wildcards[allow IUPAC wildcards in reads]' \
  '(-N --no-match-adapter-wildcards)'{-N,--no-match-adapter-wildcards}'[do not allow wildcards in adapters]' \
  '--action=[action to perform on adapter match]:action:(trim mask lowercase none retain)' \
  '--rc[also check reverse complement]' \
  '--revcomp[also check reverse complement]' \
  '(-m --minimum-length)'{-m,--minimum-length}'[discard reads shorter than N]:length' \
  '(-M --maximum-length)'{-M,--maximum-length}'[discard reads longer than N]:length' \
  '(-q --quality-cutoff)'{-q,--quality-cutoff}'[trim low-quality bases]:cutoff' \
  '--quality-base=[quality base value]:base:(33 64)' \
  '--nextseq-trim=[NextSeq quality trimming]:cutoff' \
  '-u[remove N bases from start]:bases' \
  '--cut=[remove N bases from start]:bases' \
  '-U[remove N bases from read2]:bases' \
  '--pair-filter=[filter criterion for pairs]:criterion:(any both first)' \
  '--pair-adapters[treat adapters as pairs]' \
  '--interleaved[input/output interleaved paired-end]' \
  '--untrimmed-output=[output file for untrimmed reads]:file:_files' \
  '--too-short-output=[output file for too-short reads]:file:_files' \
  '--too-long-output=[output file for too-long reads]:file:_files' \
  '--info-file=[write info about each read]:file:_files' \
  '--rest-file=[write rest of read to file]:file:_files' \
  '--wildcard-file=[write wildcards to file]:file:_files' \
  '--json=[JSON report file]:file:_files' \
  '--rename=[rename reads]:template' \
  '--discard-trimmed[discard reads with adapters]' \
  '--discard-untrimmed[discard reads without adapters]' \
  '--max-n=[discard reads with more than N unknown bases]:count' \
  '--max-expected-errors=[discard reads with too many expected errors]:count' \
  '--max-aer=[maximum average error rate]:rate' \
  '--report=[report type]:type:(full minimal)' \
  '--length=[shorten reads to N]:length' \
  '-l[shorten reads to N]:length' \
  '--trim-n[trim N bases on ends]' \
  '--poly-a[remove poly-A tails]' \
  '--zero-cap[change negative quality values to zero]' \
  '*:input files:_files -g "*.{fq,fastq,fq.gz,fastq.gz,fa,fasta}"' && ret=0

return ret
