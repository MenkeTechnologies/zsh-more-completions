#compdef create-solana-program
# Documentation: https://www.npmjs.com/package/create-solana-program
# Reference accessed: 2026-05-24
# Verified: npm view create-solana-program bin; npm readme CLI options section.

# Zsh completion for create-solana-program - Solana on-chain program repository scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--org=[organization prefix for generated names]:org:' \
  '--anchor[scaffold using Anchor framework]' \
  '--shank[scaffold using Shank framework]' \
  '--client=[client languages to generate]:client:(js rust)' \
  '--no-clients[skip generating client packages]' \
  '--default[use default answers for all prompts]' \
  '--address=[program address override]:address:' \
  '--solana=[Solana toolchain version]:version:' \
  '--force[overwrite existing directory contents]' \
  '--program-crate-name=[Rust program crate name]:name:' \
  '--rust-client-crate-name=[Rust client crate name]:name:' \
  '--js-client-package-name=[JavaScript client package name]:name:' \
  ':program name:' && ret=0

return ret
