#compdef repomix-cli
# Documentation: https://github.com/yamadashy/repomix
# Reference accessed: 2026-05-23
# Verified: npx repomix --help (see also _repomix).

# Zsh completion for repomix-cli - pack repositories for AI context

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --output)'{-o,--output}'[output file path]:file:_files' \
  '--style=[output style]:style:(xml markdown json plain)' \
  '--stdout[write output to stdout]' \
  '--stdin[read file paths from stdin]' \
  '--copy[copy output to clipboard]' \
  '--quiet[suppress console output except errors]' \
  '--verbose[enable debug logging]' \
  '--include=[include glob patterns]:patterns:' \
  '(-i --ignore)'{-i,--ignore}'[additional ignore patterns]:patterns:' \
  '--no-gitignore[disable .gitignore]' \
  '--no-default-patterns[disable built-in ignores]' \
  '(-c --config)'{-c,--config}'[repomix.config.json path]:file:_files' \
  '--global[write config to home with --init]' \
  '--init[create default config]' \
  '--no-file-summary[omit file summary]' \
  '--no-directory-structure[omit directory tree]' \
  '--no-files[metadata only, no file contents]' \
  '--remove-comments[strip comments]' \
  '--remove-empty-lines[strip empty lines]' \
  '--truncate-base64[truncate base64 strings]' \
  '--header-text=[custom header text]:text:' \
  '--instruction-file-path=[custom instructions file]:file:_files' \
  '--top-files-len=[largest files to show]:n:' \
  '--output-show-line-numbers[line numbers in output]' \
  '--compress[Tree-sitter structure extract]' \
  '--token-count-tree=[file tree with token counts]:threshold:' \
  '--token-count-encoding=[tokenizer]:encoding:(o200k_base cl100k_base p50k_base r50k_base)' \
  '--remote=[clone and pack remote repo]:url:' \
  '--remote-branch=[remote ref]:ref:' \
  '--remote-trust-config[load remote config files]' \
  '--split-output=[split output file size]:size:' \
  '--no-security-check[disable secret scanning]' \
  '--parsable-style[escape special characters]' \
  '--include-diffs[include git diffs]' \
  '--include-logs[include git commit history]' \
  '--include-logs-count=[commits to include]:n:' \
  '--include-empty-directories[include empty dirs]' \
  '--include-full-directory-structure[full directory tree]' \
  '--no-git-sort-by-changes[do not sort by git churn]' \
  '--mcp[run as MCP server]' \
  '(-f --force)'{-f,--force}'[skip confirmation prompts]' \
  '*:directory:_directories' && ret=0

return ret
