#compdef fix_ms
# Documentation: https://github.com/AlecThomson/FixMS
# Correct ASKAP beam positions and apply correlation rotation to MS visibilities.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--chunksize[chunk size for reading the MS]:size:' \
  '--max-chunks[maximum chunks to process at once]:count:' \
  '--data-column[column to fix]:column:' \
  '--corrected-data-column[output column]:column:' \
  '--no-fix-stokes-factor[disable Stokes factor correction for non-ASKAPsoft calibrations]' \
  '*:measurement set:_files -/' && ret=0

return ret
