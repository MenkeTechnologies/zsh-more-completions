#compdef sfmatch
# Documentation: https://github.com/ahay/src/blob/master/system/generic/Mmatch.c
# Madagascar: simple matching filtering

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'adj=[adjoint flag]:flag:(y n)' \
  'nf=[filter size]:size' \
  '*:RSF file:_files' && ret=0

return ret
