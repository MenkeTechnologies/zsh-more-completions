#compdef convmv
# Documentation: https://www.j3e.de/linux/convmv/man/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--list[list all available encodings]' \
  '(- *)--dump-options[list all options]' \
  '-f+[source encoding]:encoding:' \
  '-t+[target encoding]:encoding:' \
  '-r[recurse into directories]' \
  '-i[interactive mode (confirm each rename)]' \
  '--notest[actually rename files (default is dry-run)]' \
  '--nosmart[disable UTF-8 detection]' \
  '--nfc[target NFC normalisation form]' \
  '--nfd[target NFD normalisation form]' \
  '--qfrom[suppress non-ASCII characters in from output]' \
  '--qto[suppress non-ASCII characters in to output]' \
  '--replace[overwrite identical files instead of skipping]' \
  '--unescape[remove percent-encoded sequences]' \
  '--upper[convert filenames to uppercase]' \
  '--lower[convert filenames to lowercase]' \
  '--parsable[output in machine-readable format]' \
  '--run-parsable[execute output of a previous --parsable run]' \
  '--dotlessi[handle Turkish/Azeri dotless i/I]' \
  '--caseful-sz[convert German ß ligature case variants]' \
  '--fixdouble[fix double-encoded UTF-8 filenames]' \
  '--lowmem[reduce memory usage for large file sets]' \
  '--no-preserve-mtimes[do not preserve modification times]' \
  '--exec=[run a custom command per file]:command:' \
  '--map=[apply character mappings]:mapping:' \
  '*:files and directories:_files' && ret=0

return ret
