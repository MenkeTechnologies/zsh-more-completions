#compdef convmv

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--list[list all available encodings]' \
  '-f+[source encoding]:encoding:' \
  '-t+[target encoding]:encoding:' \
  '-r[recurse into directories]' \
  '--notest[actually rename files (default is dry-run)]' \
  '--nosmart[do not skip files already in target encoding]' \
  '--nfc[target NFD or NFC encoding (Mac OS X)]' \
  '--nfd[target NFD encoding]' \
  '--qfrom[do not stripping strippable escape sequences from source]' \
  '--qto[do not stripping strippable escape sequences from target]' \
  '--replace[replace files instead of skipping]' \
  '--unescape[unescape percent-encoded characters]' \
  '--upper[convert to uppercase]' \
  '--lower[convert to lowercase]' \
  '--parsable[output in parsable format]' \
  '--dotlessi[use dotless i (Turkish)]' \
  '--fixdouble[fix double-encoded UTF-8]' \
  '--map=[apply character mappings]:mapping:' \
  '*:files and directories:_files' && ret=0

return ret
