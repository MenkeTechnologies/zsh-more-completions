#compdef calendar
# Documentation: man calendar (BSD)
# Source: BSD reminder service — print upcoming events from a calendar file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[days ahead to look]:num:' \
    '-a[run for all users (root)]' \
    '-B+[days back to look]:num:' \
    '-D+[ephemeris-table type]:type:(sun moon)' \
    '-d[debug output]' \
    '-F+[day used as Friday for Friday rules]:friday:' \
    '-f+[calendar file]:file:_files' \
    '-l+[longitude for ephemeris]:longitude:' \
    '-t+[date dd[.mm[.year]]]:date:' \
    '-U+[UTC offset]:utcoffset:' \
    '-W+[work-days-ahead]:days:' \
    && ret=0

return ret
