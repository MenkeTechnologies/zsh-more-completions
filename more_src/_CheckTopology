#compdef CheckTopology
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/CheckTopology.cxx — verify/repair topology of binary image (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:image.nii:_files -g "*.{nii,nii.gz}"' \
    '2::genus-0 image.nii (smoothed result):_files' \
    '3::threshold:_default' \
    && ret=0

return ret
