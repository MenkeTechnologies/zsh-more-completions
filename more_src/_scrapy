#compdef scrapy

# Zsh completion for scrapy - Python web scraping framework

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'startproject:create new project'
  'genspider:generate new spider using pre-defined templates'
  'crawl:run a spider'
  'check:check spider contracts'
  'list:list available spiders'
  'edit:edit spider'
  'parse:parse URL and print results'
  'bench:run quick benchmark test'
  'fetch:fetch a URL using the Scrapy downloader'
  'view:open URL in browser as seen by Scrapy'
  'shell:interactive scraping console'
  'version:print Scrapy version'
  'settings:get the value of a Scrapy setting'
  'runspider:run a spider from a Python file'
)

local -a global_opts=(
  '(-h --help)'{-h,--help}'[show help message and exit]'
  '--logfile[log file]:log file:_files'
  '--loglevel[log level]:level:(CRITICAL ERROR WARNING INFO DEBUG)'
  '--nolog[disable logging]'
  '--profile[write python cProfile stats to file]:file:_files'
  '--pidfile[write process ID to file]:pid file:_files'
  '(-s --set)'{-s,--set}'[set/override setting (may be repeated)]:name=value:'
)

_arguments -s -S \
  "${global_opts[@]}" \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'scrapy command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      crawl)
        _arguments -s -S \
          "${global_opts[@]}" \
          '-a[set spider argument (may be repeated)]:name=value:' \
          '1:spider:' && ret=0
        ;;
      genspider)
        _arguments -s -S \
          "${global_opts[@]}" \
          '(-l --list)'{-l,--list}'[list available templates]' \
          '(-d --dump)'{-d,--dump}'[dump template]:template:(basic crawl csvfeed xmlfeed)' \
          '(-t --template)'{-t,--template}'[use this template]:template:(basic crawl csvfeed xmlfeed)' \
          '--force[force creation even if spider already exists]' \
          '1:spider name:' \
          '2:domain:' && ret=0
        ;;
      startproject)
        _arguments -s -S \
          "${global_opts[@]}" \
          '1:project name:' \
          '2::project directory:_files -/' && ret=0
        ;;
      parse)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--spider[use this spider]:spider:' \
          '-a[set spider argument (may be repeated)]:name=value:' \
          '--pipelines[process items through pipelines]' \
          '--nolinks[do not show extracted links]' \
          '--noitems[do not show scraped items]' \
          '--nocolour[avoid using pygments to colorize output]' \
          '(-r --rules)'{-r,--rules}'[use CrawlSpider rules to discover the callback]' \
          '(-c --callback)'{-c,--callback}'[use this callback for parsing]:callback:' \
          '(-m --meta)'{-m,--meta}'[inject extra meta into the Request]:meta:' \
          '--cbkwargs[inject extra callback kwargs into the Request]:kwargs:' \
          '(-d --depth)'{-d,--depth}'[maximum depth for following links]:depth:' \
          '(-v --verbose)'{-v,--verbose}'[print each depth level one by one]' \
          '1:URL:' && ret=0
        ;;
      fetch)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--spider[use this spider]:spider:' \
          '--headers[print response HTTP headers]' \
          '--no-redirect[do not follow HTTP 3xx redirects]' \
          '1:URL:' && ret=0
        ;;
      shell)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--spider[use this spider]:spider:' \
          '--no-redirect[do not follow HTTP 3xx redirects]' \
          '-c[evaluate the code in the shell and print the result]:code:' \
          '1::URL:' && ret=0
        ;;
      runspider)
        _arguments -s -S \
          "${global_opts[@]}" \
          '-a[set spider argument (may be repeated)]:name=value:' \
          '1:spider file:_files -g "*.py"' && ret=0
        ;;
      settings)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--get[print raw setting value]:setting:' \
          '--getbool[print setting value interpreted as boolean]:setting:' \
          '--getint[print setting value interpreted as integer]:setting:' \
          '--getfloat[print setting value interpreted as float]:setting:' \
          '--getlist[print setting value interpreted as list]:setting:' && ret=0
        ;;
      check)
        _arguments -s -S \
          "${global_opts[@]}" \
          '*:spider:' && ret=0
        ;;
      edit)
        _arguments -s -S \
          "${global_opts[@]}" \
          '1:spider:' && ret=0
        ;;
      list|bench|version|view)
        _arguments -s -S \
          "${global_opts[@]}" \
          '1::URL:' && ret=0
        ;;
    esac
    ;;
esac

return ret
