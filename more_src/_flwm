#compdef flwm
# Documentation: https://man.archlinux.org/search?q=flwm
# Reference accessed: 2026-05-16

# flwm: Fast Light Window Manager (FLTK)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-display[X display]:display:' \
  '-bg[background color]:color:' \
  '-fg[foreground color]:color:' \
  '-bw[border width]:n:' \
  '-bx[border x style]:style:' \
  '-by[border y style]:style:' \
  '*::flwm args:_files' && ret=0
return ret
