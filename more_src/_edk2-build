#compdef edk2-build

# edk2-build: EDK2 build helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --arch)'{-a,--arch=}'[target architecture]:arch:(IA32 X64 ARM AARCH64 RISCV64 LOONGARCH64 EBC)' \
  '(-p --platform)'{-p,--platform=}'[platform DSC file]:file:_files -g "*.dsc"' \
  '(-m --module)'{-m,--module=}'[single module to build]:file:_files -g "*.inf"' \
  '(-b --buildtarget)'{-b,--buildtarget=}'[build target]:target:(DEBUG RELEASE NOOPT)' \
  '(-t --tagname)'{-t,--tagname=}'[tool chain tag]:tag:(GCC5 CLANGPDB CLANGDWARF VS2017 VS2019)' \
  '(-c --conffile)'{-c,--conffile=}'[conf directory]:dir:_files -/' \
  '(-n --thread-num)'{-n,--thread-num=}'[number of build threads]:n:' \
  '(-q --quiet)'{-q,--quiet}'[quiet build]' \
  '(-v --verbose)'{-v,--verbose}'[verbose build]' \
  '*::edk2-build args:_files' && ret=0
return ret
