#compdef edk2-build
# Documentation: https://github.com/tianocore/edk2/blob/master/BaseTools/Source/Python/build/buildoptions.py
# Reference accessed: 2026-05-17
# Verified: upstream source at the URL above.

# edk2-build: build a TianoCore EDK2 project (BaseTools/Source/Python/build/build.py)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --arch)'{-a,--arch}'[target architecture]:arch:(IA32 X64 ARM AARCH64 RISCV64 LOONGARCH64 EBC)' \
  '(-p --platform)'{-p,--platform}'[platform DSC file]:file:_files -g "*.dsc"' \
  '(-m --module)'{-m,--module}'[module INF]:file:_files -g "*.inf"' \
  '(-b --buildtarget)'{-b,--buildtarget}'[build target]:target:(DEBUG RELEASE NOOPT)' \
  '(-t --tagname)'{-t,--tagname}'[toolchain tagname]:tag:(VS2015 VS2017 VS2019 VS2022 GCC GCC5 CLANGPDB CLANGDWARF CLANG38 CLANG35)' \
  '(-D --define)'{-D,--define}'[macro definition Name[=Value]]:macro:' \
  '(-y --report-file)'{-y,--report-file}'[create/overwrite report file]:file:_files' \
  '(-Y --report-type)'{-Y,--report-type}'[report type]:type:(PCD LIBRARY FLASH DEPEX BUILD_FLAGS FIXED_ADDRESS HASH EXECUTION_ORDER COMPILE_INFO)' \
  '(-r --rom-image)'{-r,--rom-image}'[name of FD to generate from FDF]:fd:' \
  '(-l --cmd-len)'{-l,--cmd-len}'[max line length of build command]:len:' \
  '-n[number of build threads (0=auto, 1=disable)]:n:' \
  '(-s --silent)'{-s,--silent}'[use silent mode of (n)make]' \
  '(-q --quiet)'{-q,--quiet}'[disable all messages except FATAL ERRORS]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose informational messages]' \
  '(-c --case-insensitive)'{-c,--case-insensitive}'[do not check case of file names]' \
  '*::edk2-build args:_files' && ret=0
return ret
