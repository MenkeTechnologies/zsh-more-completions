#compdef di
# Documentation: https://man.archlinux.org/search?q=di
# Reference accessed: 2026-05-16

# Zsh completion for di
# Upstream: Advanced df-like disk information utility
# Conservative fallback — run `di --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
