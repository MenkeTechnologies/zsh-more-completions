#compdef lego

# Zsh completion for lego (ACME/Let's Encrypt client)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dnshelp:show additional help for the --dns flag'
  'list:display certificates and accounts'
  'renew:renew a certificate'
  'revoke:revoke a certificate'
  'run:register an account then create a certificate'
)

_arguments -s -S \
  '--accept-tos[accept the ACME TOS]' \
  '--csr[certificate signing request file]:file:_files' \
  '(-d --domains)'{-d,--domains}'[add a domain]:domain:' \
  '--dns[use DNS challenge with provider]:provider:' \
  '--dns.disable-cp[disable CNAME propagation check]' \
  '--dns.resolvers[DNS resolvers]:resolvers:' \
  '--dns-timeout[DNS query timeout]:seconds:' \
  '--email[email address for registration]:email:' \
  '--eab[use External Account Binding]' \
  '--filename[certificate and key filename]:filename:' \
  '--http[use HTTP challenge]' \
  '--http.port[HTTP challenge port]:port:' \
  '--http.proxy-header[proxy header]:header:' \
  '--http.webroot[webroot directory]:dir:_files -/' \
  '--http.memcached-host[memcached host]:host:_hosts' \
  '--key-type[key type]:type:(ec256 ec384 rsa2048 rsa4096 rsa8192)' \
  '--kid[key identifier for EAB]:kid:' \
  '--hmac[HMAC for EAB]:hmac:' \
  '--path[certificate output path]:path:_files -/' \
  '--pem[save cert and key to a single .pem file]' \
  '--pfx[create a .pfx PKCS#12 file]' \
  '--pfx.pass[password for .pfx file]:password:' \
  '(-s --server)'{-s,--server}'[ACME server URL]:url:' \
  '--tls[use TLS-ALPN-01 challenge]' \
  '--tls.port[TLS challenge port]:port:' \
  '--user-agent[custom user agent]:agent:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'lego command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (renew)
        _arguments \
          '--days[renew if fewer days until expiry]:days:' \
          '--reuse-key[reuse the current private key]' \
          '--no-bundle[do not create a bundle file]' \
          '--must-staple[add OCSP must-staple extension]' \
          '--preferred-chain[preferred certificate chain]:chain:' \
          '--always-deactivate-authorizations[deactivate authorizations after]' \
          '--run-hook[run a hook command on renewal]:command:' \
          '--renew-hook[run a hook command on renewal]:command:' && ret=0
        ;;
      (revoke)
        _arguments \
          '--keep[keep local certificate files]' \
          '--reason[revocation reason]:reason:(0 1 3 4 5)' && ret=0
        ;;
    esac
    ;;
esac

return ret
