#compdef rpicam-vid
# _rpicam-vid — Raspberry Pi Foundation rpicam-vid successor to libcamera-vid CLI for capturing H264 MJPEG YUV raw video streams to file network or pipe with the rpicam-apps libcamera-based stack supporting circular-buffer split-recording streaming (raspberrypi team, C++); boost program_options
# upstream: https://github.com/raspberrypi/rpicam-apps

_rpicam-vid() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-t+[timeout ms]:n:' \
        '--timeout=+[timeout ms]:n:' \
        '-o+[output file]:file:_files -g "*.h264 *.mkv *.mp4 *.mjpeg *.raw *.yuv"' \
        '--output=+[output file]:file:_files' \
        '--codec=+[c]:c:(h264 mjpeg yuv420 libav)' \
        '--width=+[N]:n:' \
        '--height=+[N]:n:' \
        '--framerate=+[F]:f:' \
        '--rotation=+[deg]:n:(0 90 180 270)' \
        '--hflip[horizontal flip]' \
        '--vflip[vertical flip]' \
        '--roi=+[x,y,w,h]:str:' \
        '--gain=+[F]:f:' \
        '--shutter=+[us]:n:' \
        '--awb=+[mode]:m:(auto incandescent tungsten fluorescent indoor daylight cloudy custom)' \
        '--exposure=+[mode]:m:(normal short long custom)' \
        '--ev=+[F]:f:' \
        '--metering=+[mode]:m:(centre spot average matrix custom)' \
        '--saturation=+[F]:f:' \
        '--sharpness=+[F]:f:' \
        '--contrast=+[F]:f:' \
        '--brightness=+[F]:f:' \
        '--denoise=+[mode]:m:(off cdn_off cdn_fast cdn_hq auto)' \
        '--profile=+[p]:p:(baseline main high)' \
        '--level=+[level]:l:(4 4.1 4.2)' \
        '--bitrate=+[bps]:n:' \
        '-b+[bps]:n:' \
        '--intra=+[N]:n:' \
        '-g+[N]:n:' \
        '--inline[inline headers]' \
        '--initial=+[mode]:m:(record pause)' \
        '--save-pts=+[file]:file:_files' \
        '--circular[circular buffer]' \
        '--split[split on signal]' \
        '--segment=+[ms]:n:' \
        '--listen[listen mode]' \
        '--keypress[wait for key]' \
        '-k[wait for key]' \
        '--signal[wait for signal]' \
        '-s[wait for signal]' \
        '--info-text=+[text]:str:' \
        '--camera=+[index]:n:' \
        '--nopreview[no preview]' \
        '-n[no preview]' \
        '--mode=+[N:N:fmt:packing]:str:' \
        '--tuning-file=+[file]:file:_files -g "*.json"' \
        '--list-cameras[list cameras]' \
        '--autofocus-mode=+[mode]:m:(manual auto continuous)' \
        '--autofocus-range=+[range]:r:(normal macro full)'
}

_rpicam-vid "$@"
