#compdef pocketsphinx_continuous
# _pocketsphinx_continuous — CMU PocketSphinx speech recognizer (cmusphinx/pocketsphinx)
# upstream: https://github.com/cmusphinx/pocketsphinx
# Flags from pocketsphinx_continuous(1) man page.

_pocketsphinx_continuous() {
    _arguments \
        '-help[show help]' \
        '-adcdev+[audio device for input]:device:' \
        '-agc+[automatic gain control mode]:mode:(max emax noise none)' \
        '-agcthresh+[initial AGC threshold]:value:' \
        '-allphone+[phoneme decoding with phonetic LM]:lm:' \
        '-allphone_ci[phoneme decoding context-independent]' \
        '-alpha+[preemphasis parameter]:value:' \
        '-argfile+[extra arguments file]:file:_files' \
        '-ascale+[inverse acoustic model scale]:value:' \
        '-aw+[inverse acoustic weight]:value:' \
        '-backtrace[print backtraces to log]' \
        '-beam+[Viterbi search beam width]:value:' \
        '-bestpath[run bestpath Dijkstra search]' \
        '-bestpathlw+[language model weight for bestpath]:value:' \
        '-ceplen+[feature vector components]:n:' \
        '-cmn+[cepstral mean normalization]:mode:(current prior none)' \
        '-cmninit+[initial cepstral mean values]:csv:' \
        '-compallsen[compute all senone scores per frame]' \
        '-debug+[debug message level]:level:' \
        '-dict+[pronunciation dictionary file]:file:_files' \
        '-dictcase[case-sensitive dictionary]' \
        '-dither[add 1/2-bit noise]' \
        '-doublebw[use double bandwidth filters]' \
        '-ds+[GMM downsampling ratio]:ratio:' \
        '-fdict+[filler dictionary file]:file:_files' \
        '-feat+[feature stream type]:type:' \
        '-featparams+[feature extraction parameter file]:file:_files' \
        '-fillprob+[filler transition probability]:value:' \
        '-frate+[frame rate]:rate:' \
        '-fsg+[finite state grammar file]:file:_files' \
        '-fsgusealtpron[add alternate FSG pronunciations]' \
        '-fsgusefiller[insert filler words at each state]' \
        '-fwdflat[run forward flat-lexicon search]' \
        '-fwdtree[run forward lexicon-tree search]' \
        '-hmm+[acoustic model directory]:dir:_files -/' \
        '-infile+[input audio file]:file:_files -g "*.{wav,raw}"' \
        '-inmic[transcribe from microphone]:on:(yes no)' \
        '-input_endian+[input data endianness]:endian:(big little)' \
        '-jsgf+[JSGF grammar file]:file:_files -g "*.jsgf"' \
        '-keyphrase+[phrase to spot]:phrase:' \
        '-kws+[keyword spotting file]:file:_files' \
        '-kws_threshold+[KWS threshold]:value:' \
        '-lda+[LDA transformation file]:file:_files' \
        '-lifter+[liftering parameter]:value:' \
        '-lm+[N-gram language model file]:file:_files' \
        '-lmctl+[language model control file]:file:_files' \
        '-lmname+[default LM name to use]:name:' \
        '-logfn+[log file]:file:_files' \
        '-mdef+[model definition file]:file:_files' \
        '-mfclogdir+[MFC log output dir]:dir:_files -/' \
        '-rawlogdir+[raw audio log dir]:dir:_files -/' \
        '-samprate+[sampling rate (Hz)]:rate:' \
        '-time[output timing info]' \
        '-topn+[max N senones evaluated]:n:'
}

_pocketsphinx_continuous "$@"
