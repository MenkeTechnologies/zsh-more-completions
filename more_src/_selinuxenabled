#compdef selinuxenabled getenforce setenforce restorecond setroubleshootd seinfo sesearch sediff secon
# Documentation: https://man7.org/linux/man-pages/man8/selinuxenabled.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (selinuxenabled|getenforce)
    _arguments '*: :' && ret=0 ;;
  (setenforce)
    _arguments '1:mode:(0 1 enforcing permissive Enforcing Permissive)' && ret=0 ;;
  (restorecond)
    _arguments -C \
      '-h[help]' \
      '-d[do not daemonize]' \
      '-f+[config file]:file:_files' \
      '-u[user mode]' \
      '-v[verbose]' \
      '*: :' && ret=0 ;;
  (setroubleshootd)
    _arguments -C \
      '-d[do not daemonize]' \
      '-f[run in foreground]' \
      '-t+[idle timeout]:s:' \
      '*: :' && ret=0 ;;
  (seinfo)
    _arguments -C \
      '(- *)'{-h,--help}'[help]' \
      '(-V --version)'{-V,--version}'[version]' \
      '(-A --all)'{-A,--all}'[all components]' \
      '(-c --class)'{-c+,--class=}'[object class]:cls:' \
      '(-t --type)'{-t+,--type=}'[type]:t:' \
      '(-r --role)'{-r+,--role=}'[role]:r:' \
      '(-u --user)'{-u+,--user=}'[user]:u:_users' \
      '(-b --bool)'{-b+,--bool=}'[boolean]:b:' \
      '(--polcap)--polcap=[policy cap]:c:' \
      '(--portcon)--portcon=[port context]:p:' \
      '(--netifcon)--netifcon=[netif context]:i:' \
      '(--genfscon)--genfscon=[genfs context]:g:' \
      '(--fs_use)--fs_use=[fs_use type]:f:' \
      '(--initialsid)--initialsid=[initial SID]:s:' \
      '*: :_files -g "*.conf *.bin"' && ret=0 ;;
  (sesearch)
    _arguments -C \
      '(- *)'{-h,--help}'[help]' \
      '(-A --allow)'{-A,--allow}'[allow rules]' \
      '(-N --neverallow)'{-N,--neverallow}'[neverallow rules]' \
      '(-T --type)'{-T,--type}'[type rules]' \
      '(--auditallow)--auditallow[auditallow rules]' \
      '(--dontaudit)--dontaudit[dontaudit rules]' \
      '(-s --source)'{-s+,--source=}'[source type]:t:' \
      '(-t --target)'{-t+,--target=}'[target type]:t:' \
      '(-c --class)'{-c+,--class=}'[class]:c:' \
      '(-p --perm)'{-p+,--perm=}'[permission]:p:' \
      '(-b --bool)'{-b+,--bool=}'[boolean]:b:' \
      '(-D --direct)'{-D,--direct}'[direct match]' \
      '(-R --regex)'{-R,--regex}'[regex match]' \
      '*: :_files' && ret=0 ;;
  (sediff)
    _arguments -C \
      '(- *)'{-h,--help}'[help]' \
      '(-q --quiet)'{-q,--quiet}'[quiet]' \
      '(-F --stats)'{-F,--stats}'[stats]' \
      '(--commons)--commons[diff commons]' \
      '(--classes)--classes[diff classes]' \
      '(--types)--types[diff types]' \
      '(--roles)--roles[diff roles]' \
      '(--users)--users[diff users]' \
      '(--bools)--bools[diff bools]' \
      '(--allow)--allow[diff allow]' \
      '*: :_files -g "*.conf *.bin"' && ret=0 ;;
  (secon)
    _arguments -C \
      '(- *)-h[help]' \
      '(-V --version)'{-V,--version}'[version]' \
      '(-c --current)'{-c,--current}'[current process]' \
      '(-f --file)'{-f+,--file=}'[file context]:file:_files' \
      '(-l --link)'{-l+,--link=}'[link context]:file:_files' \
      '(-p --pid)'{-p+,--pid=}'[pid context]:pid:_pids' \
      '(--user)--user[show user]' \
      '(--role)--role[show role]' \
      '(--type)--type[show type]' \
      '(-r --range --sensitivity)*'{-r,--range,--sensitivity}'[show range]' \
      '(--prompt)--prompt[prompt format]' \
      '(--mlsrange)--mlsrange[show MLS range]' \
      '*: :' && ret=0 ;;
esac

return ret
