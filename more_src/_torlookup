#compdef torlookup
# Documentation: https://raw.githubusercontent.com/phaag/nfdump/master/man/torlookup.1
# Reference accessed: 2026-05-30
# torlookup — Tor-exit-node lookup helper for nfdump. Builds a torDB from CSV or queries existing DB.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-d+[directory of CSV input files to build torDB]:dir:_directories' \
  '-w+[output torDB file to create]:file:_files' \
  '-H+[use binary torDB file for queries]:file:_files' \
  '*:IP query:' \
  && ret=0

return ret
