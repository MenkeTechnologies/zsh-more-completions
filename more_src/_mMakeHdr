#compdef mMakeHdr
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mMakeHdr.html
# Generate a FITS header template covering a set of images

local ret=1

_arguments -s -S \
  '-d+[debugging level (1-3)]:level' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '-p+[pixel scale for the header]:cdelt' \
  '-n[north-aligned output]' \
  '1:images table:_files -g "*.tbl"' \
  '2:header template:_files' \
  '3::coordinate system:(EQUJ EQUB ECLJ ECLB GAL SGAL)' \
  '4::equinox' && ret=0

return ret
