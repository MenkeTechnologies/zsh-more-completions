#compdef ftcreate
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftcreate.html
# Create a FITS table extension from ASCII column-description and data files

local ret=1

_arguments -s -S \
  'cdfile=[ASCII file describing column formats and attributes]:cdfile:_files' \
  'datafile=[ASCII data file with table contents]:datafile:_files' \
  'outfile=[output FITS file]:outfile:_files' \
  'headfile=[optional file of extra header keywords]:headfile:_files' \
  'tbltype=[output table type]:tbltype:(binary ascii)' \
  'nskip=[number of initial data rows to skip]:nskip:' \
  'nrows=[max rows to read, 0 for all]:nrows:' \
  'morehdr=[reserve space for more keywords]:morehdr:' \
  'extname=[name of output extension]:extname:' \
  'anull=[string for undefined ASCII values]:anull:' \
  'inull=[value for undefined binary integers]:inull:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[record parameters as HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
