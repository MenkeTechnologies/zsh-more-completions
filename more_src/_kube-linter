#compdef kube-linter
# Documentation: https://github.com/stackrox/kube-linter
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'lint:lint Kubernetes manifests'
      'checks:list available checks'
      'templates:list available templates'
      'completion:generate shell completion'
      'version:print version'
    )
    _describe -t commands 'kube-linter command' commands && ret=0
    ;;
  args)
    case $words[1] in
      lint)
        _arguments -s -S \
          '--config=[config file]:config:_files' \
          '--format=[output format]:format:(plain json sarif)' \
          '--fail-if-no-objects-found[fail if no objects found]' \
          '--add-all-built-in[add all built-in checks]' \
          '--do-not-auto-add-defaults[do not auto-add default checks]' \
          '--verbose[enable verbose output]' \
          '--include=[checks to include]:checks' \
          '--exclude=[checks to exclude]:checks' \
          '*:file or directory:_files' \
          && ret=0
        ;;
      checks)
        _arguments -s -S \
          'list:list checks' \
          && ret=0
        ;;
      templates)
        _arguments -s -S \
          'list:list templates' \
          && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
