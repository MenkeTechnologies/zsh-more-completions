#compdef ydotoold
# Documentation: https://man.archlinux.org/search?q=ydotoold
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --socket-path)'{-p+,--socket-path=}'[custom socket path]:file:_files' \
  '(-P --socket-perm)'{-P+,--socket-perm=}'[socket permission (e.g. 0660)]:perm:' \
  '(-o --socket-own)'{-o+,--socket-own=}'[socket ownership UID:GID]:owner:' \
  '(-m --mouse-off)'{-m,--mouse-off}'[disable mouse (EV_REL)]' \
  '(-k --keyboard-off)'{-k,--keyboard-off}'[disable keyboard (EV_KEY)]' \
  '(-T --touch-on)'{-T,--touch-on}'[enable touchscreen (EV_ABS)]' \
  '(-D --device)*'{-D+,--device=}'[input device to use]:device:_files -W /dev/input' \
  '*::passthrough:' && ret=0

return ret
