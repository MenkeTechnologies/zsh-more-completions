#compdef hound houndd

# Zsh completion for houndd - Hound fast source code search server

local curcontext="$curcontext" state line ret=1

case "$service" in
  houndd)
    _arguments -s -S \
      '-addr=[listen address and port]:address\:port' \
      '-conf=[path to config file]:config file:_files -g "*.json"' \
      '-dbpath=[path to database directory]:database path:_directories' \
      '-dev[enable development mode]' \
      '-exclude-file-globs=[glob patterns to exclude]:glob patterns' \
      '-poll=[poll interval for repository updates]:interval' \
      '-ref=[default ref to index]:ref' && ret=0
    ;;
  hound)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' && ret=0
    ;;
esac

return ret
