#compdef dagu

# Zsh completion for dagu - DAG-based job scheduler

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  {-c,--config}'=[config file path]:file:_files' \
  {-d,--dags}'=[DAGs directory]:directory:_directories' \
  {-H,--host}'=[server host]:host' \
  {-p,--port}'=[server port]:port' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'start:start a DAG'
      'stop:stop a running DAG'
      'restart:restart a DAG'
      'retry:retry a failed DAG run'
      'dry:dry run a DAG'
      'status:show the status of a DAG'
      'version:show version'
      'server:start the web server'
      'scheduler:start the scheduler'
    )
    _describe -t commands 'dagu command' commands && ret=0
    ;;
  args)
    case $words[1] in
      start|stop|restart|retry|dry|status)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:DAG file:_files -g "*.yaml(-.)"' \
          && ret=0
        ;;
      server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-H,--host}'=[server host]:host' \
          {-p,--port}'=[server port]:port' \
          {-d,--dags}'=[DAGs directory]:directory:_directories' \
          && ret=0
        ;;
      scheduler)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-d,--dags}'=[DAGs directory]:directory:_directories' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
