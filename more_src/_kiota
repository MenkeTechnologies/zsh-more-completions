#compdef kiota
# Documentation: https://learn.microsoft.com/en-us/openapi/kiota/using
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Microsoft Kiota OpenAPI client generator. Expanded from prior bare
# stub to the real subcommands and generate parameters.

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'search:search for APIs and their description from various registries'
  'download:download an API description'
  'show:show the API paths tree for an API description'
  'generate:generate a client for any API from its description'
  'update:update existing clients from previous generations'
  'info:show languages and runtime dependencies information'
  'login:sign in to private API description repositories'
  'logout:sign out from private API description repositories'
)

_arguments -C \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'kiota command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      generate)
        _arguments \
          '(-d --openapi)'{-d,--openapi}'=[OpenAPI description path or URL]:path:_files' \
          '(-l --language)'{-l,--language}'=[target language]:language:(csharp go java php python ruby shell swift typescript)' \
          '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
          '(-c --class-name)'{-c,--class-name}'=[core client class name]:name:' \
          '(-n --namespace-name)'{-n,--namespace-name}'=[core client namespace]:name:' \
          '(--ll --log-level)'{--ll,--log-level}'=[log level]:level:(critical debug error information none trace warning)' \
          '(-b --backing-store)'{-b,--backing-store}'[enable backing store for models]' \
          '(--ebc --exclude-backward-compatible)'{--ebc,--exclude-backward-compatible}'[exclude backward-compatibility code]' \
          '(--ad --additional-data)'{--ad,--additional-data}'=[include AdditionalData property]:bool:(true false)' \
          '*'{-s,--serializer}'=[fully qualified serializer class]:class:' \
          '*'{--ds,--deserializer}'=[fully qualified deserializer class]:class:' \
          '(--co --clean-output)'{--co,--clean-output}'[delete the output directory before generating]' \
          '(--cc --clear-cache)'{--cc,--clear-cache}'[clear the cached file for the command]' \
          '*'{-m,--structured-mime-types}'=[structured MIME types]:mime:' \
          '*'{-i,--include-path}'=[glob pattern to include paths]:glob:' \
          '*'{-e,--exclude-path}'=[glob pattern to exclude paths]:glob:' \
          '*'{--dvr,--disable-validation-rules}'=[disable a validation rule]:rule:' \
          '(--dsv --disable-ssl-validation)'{--dsv,--disable-ssl-validation}'[disable SSL certificate validation]' \
          '(--tam --type-access-modifier)'{--tam,--type-access-modifier}'=[generated type access modifier]:modifier:(Public Internal Protected)' && ret=0
        ;;
      update)
        _arguments \
          '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
          '(--ll --log-level)'{--ll,--log-level}'=[log level]:level:(critical debug error information none trace warning)' \
          '(--co --clean-output)'{--co,--clean-output}'[delete the output directory before generating]' \
          '(--cc --clear-cache)'{--cc,--clear-cache}'[clear the cached file for the command]' && ret=0
        ;;
      search)
        _arguments \
          '(--cc --clear-cache)'{--cc,--clear-cache}'[clear the cached file for the command]' \
          '(--ll --log-level)'{--ll,--log-level}'=[log level]:level:(critical debug error information none trace warning)' \
          '(-v --version)'{-v,--version}'=[API description version]:version:' \
          '1:search term:' && ret=0
        ;;
      download)
        _arguments \
          '(-o --output)'{-o,--output}'=[output file path]:file:_files' \
          '(--co --clean-output)'{--co,--clean-output}'[delete the output directory before generating]' \
          '(--cc --clear-cache)'{--cc,--clear-cache}'[clear the cached file for the command]' \
          '(--ll --log-level)'{--ll,--log-level}'=[log level]:level:(critical debug error information none trace warning)' \
          '(-v --version)'{-v,--version}'=[API description version]:version:' \
          '(--dsv --disable-ssl-validation)'{--dsv,--disable-ssl-validation}'[disable SSL certificate validation]' \
          '1:search term:' && ret=0
        ;;
      show)
        _arguments \
          '(-d --openapi)'{-d,--openapi}'=[OpenAPI description path or URL]:path:_files' \
          '(-k --search-key)'{-k,--search-key}'=[search key to fetch the description]:key:' \
          '(--m-d --max-depth)'{--m-d,--max-depth}'=[maximum tree depth]:n:' \
          '*'{-i,--include-path}'=[glob pattern to include paths]:glob:' \
          '*'{-e,--exclude-path}'=[glob pattern to exclude paths]:glob:' \
          '(--cc --clear-cache)'{--cc,--clear-cache}'[clear the cached file for the command]' \
          '(--ll --log-level)'{--ll,--log-level}'=[log level]:level:(critical debug error information none trace warning)' \
          '(--dsv --disable-ssl-validation)'{--dsv,--disable-ssl-validation}'[disable SSL certificate validation]' && ret=0
        ;;
      info)
        _arguments \
          '(-d --openapi)'{-d,--openapi}'=[OpenAPI description path or URL]:path:_files' \
          '(-l --language)'{-l,--language}'=[target language]:language:(csharp go java php python ruby shell swift typescript)' \
          '(-k --search-key)'{-k,--search-key}'=[search key to fetch the description]:key:' \
          '(--dt --dependency-type)'{--dt,--dependency-type}'=[dependency type to display]:type:(Abstractions Additional Authentication Bundle HTTP Serialization)' \
          '--json[render output as JSON]' \
          '(--cc --clear-cache)'{--cc,--clear-cache}'[clear the cached file for the command]' \
          '(--ll --log-level)'{--ll,--log-level}'=[log level]:level:(critical debug error information none trace warning)' && ret=0
        ;;
      login)
        _arguments \
          '1:provider:(github)' \
          '2:method:(device pat)' \
          '--pat=[GitHub personal access token]:token:' \
          '(--ll --log-level)'{--ll,--log-level}'=[log level]:level:(critical debug error information none trace warning)' && ret=0
        ;;
      logout)
        _arguments \
          '1:provider:(github)' \
          '(--ll --log-level)'{--ll,--log-level}'=[log level]:level:(critical debug error information none trace warning)' && ret=0
        ;;
    esac
    ;;
esac

return ret
