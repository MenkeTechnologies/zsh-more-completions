#compdef pepinfo
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/pepinfo.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS pepinfo: plot hydrophobicity/iep/charge/etc properties of protein
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence]:protein USA:_files' \
  '-hwindow=[hydrophobicity window size]:size:' \
  '-aaproperties=[AA properties data file]:file:_files' \
  '-aahydropathy=[hydropathy data file]:file:_files' \
  '-graph=[graph output format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-outfile=[report output file]:file:_files' \
  '-generalplot[plot AA general properties]' \
  '-hydropathyplot[plot hydropathy]' \
  '*:protein USA:_files' && ret=0
return ret
