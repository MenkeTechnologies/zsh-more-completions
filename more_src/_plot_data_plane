#compdef plot_data_plane
# Documentation: https://metplus.readthedocs.io/projects/met/en/latest/Users_Guide/plotting.html
# plot_data_plane - MET tool to plot a gridded data field to PostScript

local ret=1

_arguments -s \
  '-color_table[override the default color table]:table:_files' \
  '-plot_range[set minimum and maximum plot values]:min: :max:' \
  '-title[plot title string]:title:' \
  '-log[direct output and errors to log file]:file:_files' \
  '-v[verbosity level]:level:' \
  '*:file:_files' && ret=0

return ret
