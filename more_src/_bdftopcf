#compdef bdftopcf
# Documentation: man bdftopcf(1) (X.Org)
# Source: X.Org bdftopcf — convert X font from BDF to PCF (Portable Compiled Format).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p+[glyph padding (1/2/4/8 bytes)]:n:(1 2 4 8)' \
    '-u+[scanline unit (1/2/4 bytes)]:n:(1 2 4)' \
    '(-m -l)-m[font bit order MSB-first]' \
    '(-m -l)-l[font bit order LSB-first]' \
    '(-M -L)-M[font byte order MSB-first]' \
    '(-M -L)-L[font byte order LSB-first]' \
    '-t[generate terminal font (padded uniform glyphs)]' \
    '-i[inhibit ink-metric computation]' \
    '-o+[output PCF file (default stdout)]:file:_files' \
    '*:BDF font file:_files -g "*.bdf"' \
    && ret=0

return ret
