#compdef sfphasescan
# Documentation: https://ahay.org/RSF/sfphasescan.html
# Madagascar: phase scan for stretch-based velocity analysis

local ret=1

_arguments -s \
  'other=[auxiliary input file name]:file:_files' \
  'verb=[verbosity flag (y/n)]:bool:(y n)' \
  'ng=[number of gamma values]:int:' \
  'g0=[gamma origin]:float:' \
  'dg=[gamma sampling]:float:' \
  'rect1=[vertical smoothing]:int:' \
  'rect2=[gamma smoothing]:int:' \
  'rect3=[in-line smoothing]:int:' \
  'rect4=[cross-line smoothing]:int:' \
  'niter=[number of iterations]:int:' \
  'accuracy=[interpolation accuracy (1-4)]:int:(1 2 3 4)' \
  '*:rsf file:_files' && ret=0

return ret
