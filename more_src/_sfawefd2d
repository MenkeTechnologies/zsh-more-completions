#compdef sfawefd2d
# Documentation: http://www.ahay.org/RSF/sfawefd2d.html
# Madagascar: 2-D acoustic time-domain finite-difference modeling

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'adj=[adjoint flag]' \
  'cden=[constant density]' \
  'dabc=[absorbing BC]' \
  'expl=[multiple sources, one wavelet]' \
  'fdorder=[spatial FD order]' \
  'fsrf=[free surface flag]' \
  'hybridbc=[hybrid absorbing BC]' \
  'jdata=[# of t steps at which to save receiver data]' \
  'jsnap=[# of t steps at which to save wavefield]' \
  'optfd=[optimized FD coefficients flag]' \
  'sinc=[sinc source injection]' \
  'snap=[wavefield snapshots flag]' \
  'verb=[verbosity flag]' \
  'nqx=[saved wfld window nx]' \
  'nqz=[saved wfld window nz]' \
  'oqx=[saved wfld window ox]' \
  'oqz=[saved wfld window oz]' \
  'dqx=[saved wfld window dx]' \
  'dqz=[saved wfld window dz]' \
  'vel=[velocity input file]:file:_files' \
  'den=[density input file]:file:_files' \
  'sou=[source coordinates input file]:file:_files' \
  'rec=[receiver coordinates input file]:file:_files' \
  'wfl=[wavefield output file]:file:_files' \
  '*:RSF file:_files' && ret=0

return ret
