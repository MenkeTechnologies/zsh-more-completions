#compdef schema-salad-tool
# Documentation: https://github.com/common-workflow-language/schema_salad/blob/main/src/schema_salad/main.py
# schema-salad-tool: validate, transform and codegen from Schema Salad / CWL schemas

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--version -v)'{--version,-v}'[print version]' \
  '--rdf-serializer=[RDF serialization format for --print-rdf]:format:(turtle n3 nt xml)' \
  '--skip-schemas[ignore $schemas sections]' \
  '--strict-foreign-properties[strict checking of foreign properties]' \
  '--print-jsonld-context[print JSON-LD context for schema]' \
  '--print-rdfs[print RDF schema]' \
  '--print-avro[print Avro schema]' \
  '--print-rdf[print corresponding RDF graph for document]' \
  '--print-pre[print document after preprocessing]' \
  '--print-index[print node index]' \
  '--print-metadata[print document metadata]' \
  '--print-inheritance-dot[print graphviz file of inheritance]' \
  '--print-fieldrefs-dot[print graphviz file of field refs]' \
  '--print-oneline[print each error message in oneline]' \
  '--print-doc[print HTML schema documentation page]' \
  '--codegen=[generate classes in target language]:language:(python java typescript dotnet cpp dlang)' \
  '--codegen-target=[output target for generated code]:target:_files' \
  '--codegen-examples=[directory of example documents for test case generation]:dir:_files -/' \
  '--codegen-package=[override the generated package name]:package' \
  '--codegen-copyright=[copyright of the input schema]:copyright' \
  '--codegen-parser-info=[parser name accessible via the generated parser API]:name' \
  '--strict[strict validation (default)]' \
  '--non-strict[lenient validation (ignore unrecognized fields)]' \
  '--verbose[default logging]' \
  '--quiet[only print warnings and errors]' \
  '--debug[print even more logging]' \
  '--only=[document only listed types]:type' \
  '--redirect=[override default link for type]:redirect' \
  '--brand=[set the brand text in nav bar]:brand' \
  '--brandlink=[set the link for brand in nav bar]:link' \
  '*:file:_files' && ret=0

return ret
