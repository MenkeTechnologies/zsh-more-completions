#compdef surfaceTransformPoints
# Documentation: https://www.openfoam.com/documentation/guides/latest/man/
# Transforms a surface geometry by translation, rotation and/or scaling

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' \
  ':transformations:' \
  ':surface file:_files' \
  ':output surface file:_files' && ret=0

return ret
