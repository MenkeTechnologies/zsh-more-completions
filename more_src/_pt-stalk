#compdef pt-stalk

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--collect[collect diagnostic data]' \
  '--collect-gdb[collect GDB stacktraces]' \
  '--collect-oprofile[collect oprofile data]' \
  '--collect-strace[collect strace data]' \
  '--collect-tcpdump[collect tcpdump data]' \
  '--config=[config file]:config file:_files' \
  '--cycles=[number of cycles to detect problem]:count:' \
  '--daemonize[run as daemon]' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--dest=[destination directory]:directory:_directories' \
  '--disk-bytes-free=[min free disk space]:bytes:' \
  '--disk-pct-free=[min free disk percentage]:percent:' \
  '--function=[trigger function]:function:' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--interval=[check interval]:seconds:' \
  '--iterations=[number of iterations]:count:' \
  '--log=[log file]:log file:_files' \
  '--notify-by-email=[send email notification]:email:' \
  '--password=[MySQL password]:password:' \
  '--pid=[PID file]:pid file:_files' \
  '--plugin=[plugin to execute]:plugin:_files' \
  '--port=[MySQL port]:port:' \
  '--prefix=[filename prefix]:prefix:' \
  '--retention-time=[retention time]:seconds:' \
  '--run-time=[collection time]:seconds:' \
  '--sleep=[sleep between collections]:seconds:' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--threshold=[trigger threshold]:value:' \
  '--user=[MySQL user]:username:' \
  '--variable=[MySQL status variable to check]:variable:' && ret=0

return ret
