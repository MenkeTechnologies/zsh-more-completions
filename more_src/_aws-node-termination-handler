#compdef aws-node-termination-handler
# _aws-node-termination-handler — AWS Node Termination Handler (drains nodes on spot interruption / ASG lifecycle / scheduled events / rebalance)
# upstream: https://github.com/aws/aws-node-termination-handler
# Flags from pkg/config/config.go on tip; every flag also reads from the corresponding env var.

_aws-node-termination-handler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--dry-run[only log if a node would be drained]' \
        '--node-name=[Kubernetes node name]:name:' \
        '--pod-name=[Kubernetes pod name]:name:' \
        '--pod-namespace=[Kubernetes pod namespace]:ns:' \
        '--metadata-url=[EC2 IMDS URL]:url:' \
        '--ignore-daemon-sets=[ignore daemon sets when draining]:bool:(true false)' \
        '--delete-local-data=[drain pods using emptyDir local storage]:bool:(true false)' \
        '--kubernetes-service-host=[k8s API host (advanced)]:host:' \
        '--kubernetes-service-port=[k8s API port (advanced)]:port:' \
        '--pod-termination-grace-period=[pod termination grace period (s)]:s:' \
        '--node-termination-grace-period=[node termination grace period (s)]:s:' \
        '--webhook-url=[webhook URL for interruption events]:url:_urls' \
        '--webhook-proxy=[HTTP(S) proxy for webhook requests]:url:' \
        '--webhook-headers=[webhook headers JSON]:json:' \
        '--webhook-template=[webhook payload template]:tpl:' \
        '--webhook-template-file=[webhook payload template file]:file:_files' \
        '--enable-scheduled-event-draining=[drain on scheduled maintenance events]:bool:(true false)' \
        '--enable-spot-interruption-draining=[drain on spot interruption]:bool:(true false)' \
        '--enable-asg-lifecycle-draining=[drain on ASG lifecycle terminate]:bool:(true false)' \
        '--enable-sqs-termination-draining=[drain on SQS termination event]:bool:(true false)' \
        '--enable-rebalance-monitoring[cordon on rebalance recommendation]' \
        '--enable-rebalance-draining[drain on rebalance recommendation]' \
        '--check-tag-before-draining=[only act on instances tagged aws-node-termination-handler/managed]:bool:(true false)' \
        '--managed-tag=[managed-instance tag key]:tag:' \
        '--metadata-tries=[IMDS retry count]:n:' \
        '--cordon-only[cordon only; do not drain]' \
        '--taint-node[taint node on interruption]' \
        '--taint-effect=[taint effect]:effect:(NoSchedule PreferNoSchedule NoExecute)' \
        '--enable-out-of-service-taint[apply out-of-service taint after drain]' \
        '--exclude-from-load-balancers[mark node for LB exclusion on interruption]' \
        '--json-logging[JSON-format logs]' \
        '--log-level=[log level]:level:(INFO DEBUG ERROR)' \
        '--log-format-version=[log format version]:n:' \
        '--uptime-from-file=[read system uptime from file (testing)]:file:_files' \
        '--enable-prometheus-server[expose /metrics endpoint]' \
        '--prometheus-server-port=[Prometheus server port]:port:' \
        '--enable-probes-server[expose /healthz endpoint]' \
        '--probes-server-port=[probes server port]:port:' \
        '--probes-server-endpoint=[probes endpoint path]:path:' \
        '--emit-kubernetes-events=[emit Kubernetes events on interruption]:bool:(true false)' \
        '--kubernetes-events-extra-annotations=[csv of key=value annotations on emitted events]:csv:' \
        '--aws-region=[AWS region for API calls]:region:' \
        '--aws-endpoint=[AWS endpoint (testing)]:url:' \
        '--queue-url=[SQS queue URL to listen on]:url:' \
        '--workers=[parallel event processors]:n:' \
        '--use-provider-id[use Node spec.ProviderID instead of AWS PrivateDnsHostname]' \
        '--complete-lifecycle-action-delay-seconds=[delay after drain before CompleteLifecycleAction]:s:' \
        '--delete-sqs-msg-if-node-not-found[delete SQS message when target node is missing]' \
        '--use-apiserver-cache[use apiserver pod-index cache to list pods on a node]' \
        '--heartbeat-interval=[heartbeat interval (s)]:s:' \
        '--heartbeat-until=[heartbeat duration (s)]:s:' \
        '--sqs-msg-visibility-timeout-sec=[SQS message visibility timeout (s)]:s:'
}

_aws-node-termination-handler "$@"
