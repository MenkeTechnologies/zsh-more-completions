#compdef metabase-cli metabase metabase-cli2
# _metabase-cli — Metabase metabase-cli CLI command-line frontend wrapping the Metabase open-source business intelligence BI platform managing dashboards collections questions cards alerts pulses users groups permissions databases tables fields metrics segments embedding-tokens snapshots backup restore configuration (Metabase team, Java); custom argparse
# upstream: https://www.metabase.com/

_metabase-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'user:user management'
        'group:group management'
        'permission:permission management'
        'database:database management'
        'table:table management'
        'field:field management'
        'card:card question management'
        'dashboard:dashboard management'
        'collection:collection management'
        'pulse:pulse management'
        'alert:alert management'
        'metric:metric management'
        'segment:segment management'
        'embed:embedding tokens'
        'snapshot:snapshot operations'
        'backup:backup database'
        'restore:restore database'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--metabase-url=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--session-token=+[token]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '--insecure[skip TLS verify]' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'metabase-cli subcommand' sub ;;
        args)
            case $words[1] in
                user|group|database|table|field|card|dashboard|collection|pulse|alert|metric|segment|permission|embed) _arguments '1:op:(list get create update delete archive unarchive enable disable)' '*:id:' ;;
                backup|restore|snapshot) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_metabase-cli "$@"
