#compdef 3dClustSim
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dClustSim.html
# AFNI Monte Carlo cluster-size thresholds for multiple-comparison correction

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-nxyz[set 3D grid dimensions]:n1' \
  '-dxyz[voxel sizes for three axes]:d1' \
  '-BALL[restrict simulation to spherical region]' \
  '-mask[mask dataset to define analysis region]:dataset:_files' \
  '-OKsmallmask[allow masks under 128 voxels]' \
  '-inset[use datasets as simulations]:dataset:_files' \
  '-fwhm[Gaussian filtering width]:s' \
  '-fwhmxyz[per-axis smoothing amounts]:sx' \
  '-acf[autocorrelation function parameters]:a' \
  '-nopad[disable padding during smoothing]' \
  '-pthr[per-voxel p-value thresholds]:p1' \
  '-athr[corrected alpha levels]:a1' \
  '-LOTS[use extended threshold value lists]' \
  '-MEGA[use even more threshold values]' \
  '-iter[number of Monte Carlo simulations]:n' \
  '-seed[random number seed]:S' \
  '-niml[output in XML/NIML format]' \
  '-both[output both NIML and .1D formats]' \
  '-prefix[write results to named files]:prefix' \
  '-cmd[alternate command file location]:file:_files' \
  '-nodec[remove decimal places from output]' \
  '-quiet[suppress progress messages]' \
  '*:dataset:_files' && ret=0

return ret
