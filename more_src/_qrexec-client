#compdef qrexec-client qrexec-client-vm qrexec-policy qrexec-policy-graph

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--buffer-size=[buffer size in bytes]:size:' \
  '-d+[dom0 target]:dom:' \
  '-l+[local program]:cmd:_command_names' \
  '-c+[command to execute]:cmd:' \
  '-e[disable echo]' \
  '-t[fail on missing target]' \
  '-T[strict mode]' \
  '-W[wait for VM to start]' \
  '*: :' && ret=0

return ret
