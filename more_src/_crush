#compdef crush
# Documentation: https://github.com/charmbracelet/crush
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (internal/cmd/root.go + run.go).

# Zsh completion for charmbracelet/crush - glamourous AI coding agent for the terminal

local curcontext="$curcontext" state line ret=1

_crush_commands() {
  local -a commands=(
    'run:run a single non-interactive prompt'
    'logs:view application logs'
    'update-providers:update the embedded providers list'
    'login:authenticate with a provider'
    'logout:remove provider credentials'
    'models:list available models'
    'projects:manage projects'
    'server:run crush in client/server mode'
    'schema:print config schema'
    'help:show help'
  )
  _describe -t commands 'crush command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --cwd)'{-c+,--cwd=}'[current working directory]:dir:_directories' \
  '(-D --data-dir)'{-D+,--data-dir=}'[custom crush data directory]:dir:_directories' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '(-H --host)'{-H+,--host=}'[connect to a specific crush server host]:host:' \
  '(-y --yolo)'{-y,--yolo}'[auto accept all permissions]' \
  '(-s --session)'{-s+,--session=}'[continue a previous session by ID]:id:' \
  '(-C --continue)'{-C,--continue}'[continue the most recent session]' \
  '1: :_crush_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[hide spinner]' \
          '(-v --verbose)'{-v,--verbose}'[show logs]' \
          '(-m --model)'{-m+,--model=}'[model (name or provider/model)]:model:' \
          '--small-model=[small model override]:model:' \
          '(-s --session)'{-s+,--session=}'[continue a previous session]:id:' \
          '(-C --continue)'{-C,--continue}'[continue the most recent session]' \
          '*:prompt' && ret=0
        ;;
      logs)
        _arguments \
          '--follow[follow log output]' \
          '--tail=[number of lines]:lines:' && ret=0
        ;;
    esac
    ;;
esac

return ret
