#compdef crush

# Zsh completion for crush - Charm's glamourous AI coding agent for your favorite terminal

local curcontext="$curcontext" state line ret=1

_crush_commands() {
  local -a commands=(
    'run:run a single non-interactive prompt'
    'logs:view application logs'
    'update-providers:update the embedded providers list'
    'help:show help'
  )
  _describe -t commands 'crush command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --cwd)'{-c,--cwd}'[working directory]:dir:_directories' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-y --yolo)'{-y,--yolo}'[auto accept everything]' \
  '1: :_crush_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
          '*:prompt' && ret=0
        ;;
      logs)
        _arguments \
          '(-f --follow)'{-f,--follow}'[follow log output]' \
          '--tail[number of lines to show]:lines' && ret=0
        ;;
    esac
    ;;
esac

return ret
