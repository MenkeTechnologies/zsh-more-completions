#compdef eagle
# Documentation: https://alkesgroup.broadinstitute.org/Eagle/
# Eagle: haplotype phasing of genotype data

local ret=1

_arguments -s -S \
  '--bfile=[PLINK binary format input]:prefix:_files' \
  '--vcfTarget=[target genotypes in VCF/BCF]:file:_files' \
  '--vcfRef=[reference panel genotypes in VCF/BCF]:file:_files' \
  '--outPrefix=[output file path prefix]:prefix:_files' \
  '--vcfOutFormat=[output format]:fmt:(z b u v)' \
  '--chrom=[chromosome to phase]:chr' \
  '--bpStart=[start position for region]:pos' \
  '--bpEnd=[end position for region]:pos' \
  '--bpFlanking=[flanking region for phasing]:bp' \
  '--remove=[file listing individuals to exclude]:file:_files' \
  '--exclude=[file listing SNPs to exclude]:file:_files' \
  '--vcfExclude=[variants to exclude from reference phasing]:file:_files' \
  '--geneticMapFile=[path to reference genetic map]:file:_files' \
  '--Kpbwt=[number of conditioning haplotypes]:num' \
  '--pbwtIters=[PBWT iteration count]:num' \
  '--pbwtOnly[skip non-PBWT iterations]' \
  '--noImpMissing[leave missing genotypes unimputed]' \
  '--maxMissingPerSnp=[SNP missing rate threshold]:rate' \
  '--maxMissingPerIndiv=[individual missing rate threshold]:rate' \
  '--allowRefAltSwap[tolerate REF/ALT allele swaps]' \
  '--keepMissingPloidyX[preserve ploidy of missing chrX genotypes]' \
  '--numThreads=[number of threads]:num' \
  '*:file:_files' && ret=0

return ret
