#compdef ldns-keyfetcher
# _ldns-keyfetcher — NLnet Labs ldns-keyfetcher (retrieve DNSKEY records for a domain by walking from the root down to the authoritative servers; optionally store keys as files)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-keyfetcher.c usage on tip.

_ldns-keyfetcher() {
    _arguments \
        '-h[show help]' \
        '(-4 -6)-4[force IPv4]' \
        '(-4 -6)-6[force IPv6]' \
        '-i[insecure mode: skip checks, just query]' \
        '-r+[root hints file]:file:_files' \
        '-s[store keys to K<name>.+<alg>+<keytag>.key files instead of stdout]' \
        '-v+[verbosity level]:n:(0 1 2 3 4 5)' \
        '1:domain:'
}

_ldns-keyfetcher "$@"
