#compdef nrpe

# Zsh completion for nrpe (Nagios Remote Plugin Executor daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[Specify configuration file]:config file:_files' \
  '-d[Run as a standalone daemon]' \
  '-f[Do not fork (run in foreground)]' \
  '-i[Run under inetd/xinetd]' \
  '-n[Do not use SSL]' \
  '-4[Use IPv4 only]' \
  '-6[Use IPv6 only]' \
  '-s[Log to stderr]' \
  '-l+[Specify log file]:log file:_files' \
  '-V[Print version information]' \
  '-h[Print help]' && ret=0

return ret
