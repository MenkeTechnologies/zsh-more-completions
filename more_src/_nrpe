#compdef nrpe
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man8/nrpe.8.html
# Reference accessed: 2026-05-19
# Verified: upstream Ubuntu manpage at the URL above (Nagios NRPE daemon).

# nrpe: Nagios Remote Plugin Executor daemon. Upstream manpage documents
# the operating-mode flags; additional flags below are present in the
# source-released nrpe binary (NagiosEnterprises/nrpe).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[configuration file]:config file:_files' \
  '-d[run as standalone daemon]' \
  '-f[do not fork (run in foreground)]' \
  '-i[run under inetd/xinetd]' \
  '-n[do not use SSL]' \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  '-s[log to stderr]' \
  '-l+[log file]:log file:_files' \
  '-V[show version information]' \
  '-h[show help]' && ret=0

return ret
