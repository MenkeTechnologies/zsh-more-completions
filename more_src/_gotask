#compdef task

# Zsh completion for go-task/task (Taskfile runner)
# Note: This completes the 'task' command from go-task, not taskwarrior

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c[colored output]:mode:(true false auto)' \
  '--color=[colored output]:mode:(true false auto)' \
  '-C[concurrency limit]:limit' \
  '--concurrency=[concurrency limit]:limit' \
  '-d+[sets directory of execution]:directory:_directories' \
  '--dir=[sets directory of execution]:directory:_directories' \
  '--dry[dry run mode]' \
  '-f[force execution even when task is up-to-date]' \
  '--force[force execution even when task is up-to-date]' \
  '-g[run as global Taskfile]' \
  '--global[run as global Taskfile]' \
  '--init[creates a new Taskfile]' \
  '-l[list tasks with description]' \
  '--list[list tasks with description]' \
  '--list-all[list tasks with or without description]' \
  '-a[list tasks with or without description]' \
  '--json[output task list as JSON]' \
  '-o+[output format]:format:(interleaved group prefixed)' \
  '--output=[output format]:format:(interleaved group prefixed)' \
  '--output-group-begin=[output group begin template]:template' \
  '--output-group-end=[output group end template]:template' \
  '-p[run tasks in parallel]' \
  '--parallel[run tasks in parallel]' \
  '-s[silent mode]' \
  '--silent[silent mode]' \
  '--status[show task status without running]' \
  '--summary[show task summary]' \
  '--sort=[sort order for task list]:order:(default alphanumeric none)' \
  '-t+[Taskfile to use]:taskfile:_files -g "Taskfile*.{yml,yaml}"' \
  '--taskfile=[Taskfile to use]:taskfile:_files -g "Taskfile*.{yml,yaml}"' \
  '-v[verbose mode]' \
  '--verbose[verbose mode]' \
  '-w[watch for file changes and re-run]' \
  '--watch[watch for file changes and re-run]' \
  '*:task:->tasks' && ret=0

case $state in
  tasks)
    local -a tasks
    tasks=(${(f)"$(task --list-all --json 2>/dev/null | command grep -o '"name":"[^"]*"' | sed 's/"name":"//;s/"//')"})
    if [[ -z "$tasks" ]]; then
      tasks=(${(f)"$(task --list-all 2>/dev/null | awk '/^\* /{print $2}' | sed 's/:$//')"})
    fi
    _describe -t tasks 'task' tasks && ret=0
    ;;
esac

return ret
