#compdef gotask
# Documentation: https://github.com/owenthereal/gotask
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for gotask - a Go-based build tool (jingweno/owenthereal)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-g --generate)'{-g,--generate}'[generate task scaffold (pkg_task.go)]' \
  '(-c --compile)'{-c,--compile}'[compile task definitions to a binary]' \
  '--debug[run gotask in debug mode]' \
  '--version[show version]' \
  '*:task name or args:'
