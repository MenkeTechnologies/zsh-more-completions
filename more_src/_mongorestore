#compdef mongorestore
# Documentation: https://www.mongodb.com/docs/database-tools/mongorestore/
# Source: MongoDB Database Tools — restore BSON dumps + replay oplog.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
    '--quiet[quiet mode]' \
    '(- *)--version[show version]' \
    '--config=[YAML config file]:file:_files' \
    '--uri=[MongoDB connection URI]:uri:' \
    '(-h --host)'{-h+,--host=}'[hostname[:port]]:host:_hosts' \
    '--port=[TCP port]:port:' \
    '--ssl[enable TLS/SSL]' \
    '--sslCAFile=[CA cert chain (.pem)]:file:_files' \
    '--sslPEMKeyFile=[client cert+key (.pem)]:file:_files' \
    '--sslPEMKeyPassword=[cert-key password]:password:' \
    '--sslCRLFile=[CRL file]:file:_files' \
    '--sslAllowInvalidCertificates[bypass server cert validation]' \
    '--sslAllowInvalidHostnames[bypass hostname validation]' \
    '(-u --username)'{-u+,--username=}'[auth username]:user:_users' \
    '(-p --password)'{-p+,--password=}'[auth password]:password:' \
    '--awsSessionToken=[AWS session token]:token:' \
    '--authenticationDatabase=[auth database]:db:' \
    '--authenticationMechanism=[auth mechanism]:mech:(SCRAM-SHA-1 SCRAM-SHA-256 MONGODB-X509 MONGODB-AWS GSSAPI PLAIN)' \
    '--gssapiServiceName=[GSSAPI service name]:name:' \
    '--gssapiHostName=[GSSAPI host name]:host:_hosts' \
    '(-d --db)'{-d+,--db=}'[destination DB (deprecated; use --nsInclude)]:db:' \
    '(-c --collection)'{-c+,--collection=}'[destination collection (deprecated; use --nsInclude)]:collection:' \
    '*--nsInclude=[restore only matching namespaces]:pattern:' \
    '*--nsExclude=[skip matching namespaces]:pattern:' \
    '*--nsFrom=[source namespace pattern (with --nsTo)]:pattern:' \
    '*--nsTo=[destination namespace (with --nsFrom)]:pattern:' \
    '--drop[drop collections before restoring]' \
    '--dryRun[no insertions; print summary]' \
    '--writeConcern=[write concern]:doc:' \
    '--noIndexRestore[do not restore/build indexes]' \
    '--convertLegacyIndexes[rewrite legacy indexes]' \
    '--noOptionsRestore[do not restore collMod-style options]' \
    '--keepIndexVersion[do not upgrade indexes to latest version]' \
    '--maintainInsertionOrder[insert documents in source order]' \
    '--numInsertionWorkersPerCollection=[workers per collection (default 1)]:n:' \
    '(-j --numParallelCollections)'{-j+,--numParallelCollections=}'[parallel collections (default 4)]:n:' \
    '--stopOnError[halt restore on first error]' \
    '--bypassDocumentValidation[skip document validation]' \
    '--objcheck[validate documents on receipt]' \
    '--oplogReplay[replay oplog.bson after restore]' \
    '--oplogLimit=[skip oplog after this timestamp]:ts:' \
    '--oplogFile=[oplog file path]:file:_files' \
    '--restoreDbUsersAndRoles[restore user+role definitions]' \
    '--gzip[restore from gzip-compressed input]' \
    '--archive=-[restore from archive file (or stdin)]:file:_files' \
    '*:dump directory or BSON file:_files' \
    && ret=0

return ret
