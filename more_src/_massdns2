#compdef massdns2
# _massdns2 — Bernhard Schmidt blechschmidt massdns2 CLI command-line frontend wrapping the MassDNS high-performance DNS stub resolver for bulk lookups and reconnaissance open-source written in C bulk-A-AAAA-CNAME-MX-TXT-PTR-NS-SOA-SRV-ANY-CAA-DNAME-DNSKEY-DS-NSEC3-OPT-RRSIG-TLSA-SPF-CDS-CDNSKEY-NSEC3PARAM-EUI48-EUI64-HINFO query-types output-format-json-text-list-list-clean-binary multiple-resolvers retry hashmap-size interval-rate processes filter-state response-section (Quirin Schmidt blechschmidt team, C); custom argparse
# upstream: https://github.com/blechschmidt/massdns

_massdns2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[hashmap size]:n:' \
        '--hashmap-size=+[N]:n:' \
        '-e+[extended exit code]' \
        '-i+[interval ms]:n:' \
        '--interval=+[ms]:n:' \
        '-l+[error log]:file:_files' \
        '--error-log=+[file]:file:_files' \
        '-n[normalize names]' \
        '--norecurse[no recurse]' \
        '-o+[format]:f:(B J L S l m b)' \
        '--output=+[fmt]:f:(B J L S l m b)' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r+[resolvers file]:file:_files' \
        '--resolvers=+[file]:file:_files' \
        '-rand[random seeds]' \
        '-resolve-count=+[N]:n:' \
        '-s+[rate limit]:n:' \
        '--rate-limit=+[N]:n:' \
        '-t+[record type]:t:(A AAAA AFSDB ANY APL CAA CDNSKEY CDS CERT CNAME DHCID DLV DNAME DNSKEY DS HIP IPSECKEY KEY KX LOC MX NAPTR NS NSEC NSEC3 NSEC3PARAM OPENPGPKEY PTR RRSIG RP SIG SMIMEA SOA SRV SSHFP TA TKEY TLSA TSIG TXT URI ZONEMD)' \
        '--type=+[type]:str:' \
        '-w+[output file]:file:_files' \
        '--write=+[file]:file:_files' \
        '-x[extreme mode]' \
        '--extreme[extreme]' \
        '--filter=+[s]:s:(OK SERVFAIL REFUSED NXDOMAIN NOERROR FORMERR NOTIMP)' \
        '--retry=+[N]:str:' \
        '-z+[hash seed]:n:' \
        '*:file:_files'
}

_massdns2 "$@"
