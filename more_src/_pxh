autoload -U is-at-least

_pxh() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--db=[path to the history database (default\: ~/.local/share/pxh/pxh.db)]:DB:_files' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_pxh_commands" \
"*::: :->pxh" \
&& ret=0
    case $state in
    (pxh)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pxh-command-$line[1]:"
        case $line[1] in
            (show)
_arguments "${_arguments_options[@]}" : \
'-l+[Display at most this many entries; 0 for unlimited]:LIMIT:_default' \
'--limit=[Display at most this many entries; 0 for unlimited]:LIMIT:_default' \
'--working-directory=[Filter to commands run in the specified directory (implies --here)]:WORKING_DIRECTORY:_files' \
'(-H --here --working-directory)-S+[Display only commands from the specified session ("current", "last", or a session ID)]:SESSION:_default' \
'(-H --here --working-directory)--session=[Display only commands from the specified session ("current", "last", or a session ID)]:SESSION:_default' \
'-i[Perform case-insensitive matching]' \
'--ignore-case[Perform case-insensitive matching]' \
'-v[Display extra fields in the output]' \
'--verbose[Display extra fields in the output]' \
'--suppress-headers[Suppress headers]' \
'-H[Show entries that were populated while in the current working directory]' \
'--here[Show entries that were populated while in the current working directory]' \
'-F[Show only commands that exited with a non-zero status]' \
'--failed[Show only commands that exited with a non-zero status]' \
'--loosen[Match patterns in any order instead of sequentially]' \
'-h[Print help]' \
'--help[Print help]' \
'*::patterns -- One or more regular expressions to search through history entries; multiple values joined by `.*\s.*`:_default' \
&& ret=0
;;
(s)
_arguments "${_arguments_options[@]}" : \
'-l+[Display at most this many entries; 0 for unlimited]:LIMIT:_default' \
'--limit=[Display at most this many entries; 0 for unlimited]:LIMIT:_default' \
'--working-directory=[Filter to commands run in the specified directory (implies --here)]:WORKING_DIRECTORY:_files' \
'(-H --here --working-directory)-S+[Display only commands from the specified session ("current", "last", or a session ID)]:SESSION:_default' \
'(-H --here --working-directory)--session=[Display only commands from the specified session ("current", "last", or a session ID)]:SESSION:_default' \
'-i[Perform case-insensitive matching]' \
'--ignore-case[Perform case-insensitive matching]' \
'-v[Display extra fields in the output]' \
'--verbose[Display extra fields in the output]' \
'--suppress-headers[Suppress headers]' \
'-H[Show entries that were populated while in the current working directory]' \
'--here[Show entries that were populated while in the current working directory]' \
'-F[Show only commands that exited with a non-zero status]' \
'--failed[Show only commands that exited with a non-zero status]' \
'--loosen[Match patterns in any order instead of sequentially]' \
'-h[Print help]' \
'--help[Print help]' \
'*::patterns -- One or more regular expressions to search through history entries; multiple values joined by `.*\s.*`:_default' \
&& ret=0
;;
(recall)
_arguments "${_arguments_options[@]}" : \
'-q+[Initial search query]:QUERY:_default' \
'--query=[Initial search query]:QUERY:_default' \
'-l+[Limit results when printing]:LIMIT:_default' \
'--limit=[Limit results when printing]:LIMIT:_default' \
'(--global)--here[Search only in current directory]' \
'--global[Search across all directories (overrides --here in config)]' \
'-p[Print results instead of showing TUI]' \
'--print[Print results instead of showing TUI]' \
'--timing[Show timing information]' \
'--paint-then-exit[Paint TUI once then exit (for profiling)]' \
'--shell-mode[Shell integration mode (outputs command for shell to execute)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(r)
_arguments "${_arguments_options[@]}" : \
'-q+[Initial search query]:QUERY:_default' \
'--query=[Initial search query]:QUERY:_default' \
'-l+[Limit results when printing]:LIMIT:_default' \
'--limit=[Limit results when printing]:LIMIT:_default' \
'(--global)--here[Search only in current directory]' \
'--global[Search across all directories (overrides --here in config)]' \
'-p[Print results instead of showing TUI]' \
'--print[Print results instead of showing TUI]' \
'--timing[Show timing information]' \
'--paint-then-exit[Paint TUI once then exit (for profiling)]' \
'--shell-mode[Shell integration mode (outputs command for shell to execute)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shellname -- Shell to install helpers into (bash or zsh):_default' \
&& ret=0
;;
(import)
_arguments "${_arguments_options[@]}" : \
'--histfile=[Path to history file to import (defaults\: bash=~/.bash_history, zsh=~/.zsh_history)]:HISTFILE:_files' \
'--shellname=[Type of shell history specified by --histfile]:SHELLNAME:_default' \
'--hostname=[Hostname to tag imported entries with (defaults to current hostname)]:HOSTNAME:_default' \
'--username=[Username to tag imported entries with (defaults to current user)]:USERNAME:_default' \
'-n[Show what would be imported without making changes]' \
'--dry-run[Show what would be imported without making changes]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(sync)
_arguments "${_arguments_options[@]}" : \
'--remote=[Remote host to sync with via SSH]:REMOTE:_default' \
'--remote-db=[Remote database path]:REMOTE_DB:_files' \
'-e+[SSH command to use for connection (like rsync'\''s -e option)]:SSH_CMD:_default' \
'--ssh-cmd=[SSH command to use for connection (like rsync'\''s -e option)]:SSH_CMD:_default' \
'--remote-pxh=[Path to pxh binary on the remote host]:REMOTE_PXH:_default' \
'--since=[Only sync commands from the last N days (remote sync only)]:DAYS:_default' \
'--export-only[(directory sync only) Only export the current database; do not read other databases]' \
'(--receive-only)--send-only[Only send database to remote (no receive)]' \
'(--send-only)--receive-only[Only receive database from remote (no send)]' \
'--server[Internal\: run in server mode]' \
'--stdin-stdout[Use stdin/stdout for sync instead of SSH (for testing)]' \
'--no-secret-filter[Disable automatic filtering of potential secrets during sync import]' \
'-h[Print help]' \
'--help[Print help]' \
'::dirname -- Directory for sync operations (required for directory-based sync):_files' \
&& ret=0
;;
(scrub)
_arguments "${_arguments_options[@]}" : \
'--histfile=[Scrub from this histfile instead of (or in addition to) the database]:HISTFILE:_files' \
'(--histfile)--dir=[Scrub from all .db files in this directory (e.g., sync folder)]:DIR:_files' \
'(--histfile --dir)--remote=[Scrub from remote host via SSH sync protocol]:REMOTE:_default' \
'-e+[SSH command to use for connection (like rsync'\''s -e option)]:SSH_CMD:_default' \
'--ssh-cmd=[SSH command to use for connection (like rsync'\''s -e option)]:SSH_CMD:_default' \
'--remote-pxh=[Path to pxh binary on the remote host]:REMOTE_PXH:_default' \
'--remote-db=[Remote database path]:REMOTE_DB:_files' \
'-c+[]:CONFIDENCE:(critical high low all)' \
'--confidence=[]:CONFIDENCE:(critical high low all)' \
'--shellname=[Shell format for histfile (bash or zsh); auto-detected if not specified]:SHELLNAME:_default' \
'-n[Dry-run mode (only display the rows, don'\''t actually scrub)]' \
'--dry-run[Dry-run mode (only display the rows, don'\''t actually scrub)]' \
'--scan[Use secret detection to find entries to scrub (instead of interactive prompt)]' \
'-y[Skip confirmation prompt]' \
'--yes[Skip confirmation prompt]' \
'-h[Print help]' \
'--help[Print help]' \
'::contraband -- The string to scrub (for interactive mode):_default' \
&& ret=0
;;
(insert)
_arguments "${_arguments_options[@]}" : \
'--shellname=[]:SHELLNAME:_default' \
'--hostname=[]:HOSTNAME:_default' \
'--username=[]:USERNAME:_default' \
'--working-directory=[]:WORKING_DIRECTORY:_files' \
'--exit-status=[]:EXIT_STATUS:_default' \
'--session-id=[]:SESSION_ID:_default' \
'--start-unix-timestamp=[]:START_UNIX_TIMESTAMP:_default' \
'--end-unix-timestamp=[]:END_UNIX_TIMESTAMP:_default' \
'-h[Print help]' \
'--help[Print help]' \
'*::command:_default' \
&& ret=0
;;
(seal)
_arguments "${_arguments_options[@]}" : \
'--session-id=[]:SESSION_ID:_default' \
'--exit-status=[]:EXIT_STATUS:_default' \
'--end-unix-timestamp=[]:END_UNIX_TIMESTAMP:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(shell-config)
_arguments "${_arguments_options[@]}" : \
'--no-ctrl-r[Don'\''t bind Ctrl-R to pxh recall]' \
'-h[Print help]' \
'--help[Print help]' \
':shellname -- Shell name (bash or zsh):_default' \
&& ret=0
;;
(autosuggest)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':prefix -- Prefix to match against command history:_default' \
&& ret=0
;;
(maintenance)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'*::files -- Path(s) to SQLite database files to maintain (if not specified, maintains the current database):_files' \
&& ret=0
;;
(scan)
_arguments "${_arguments_options[@]}" : \
'-c+[]:CONFIDENCE:(critical high low all)' \
'--confidence=[]:CONFIDENCE:(critical high low all)' \
'--histfile=[Scan this histfile instead of the database]:HISTFILE:_files' \
'(--histfile)--dir=[Scan all .db files in this directory (e.g., sync folder)]:DIR:_files' \
'--shellname=[Shell format for histfile (bash or zsh); auto-detected if not specified]:SHELLNAME:_default' \
'-j[Output as JSON]' \
'--json[Output as JSON]' \
'-v[Verbose output with pattern details]' \
'--verbose[Verbose output with pattern details]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for (bash, zsh):(bash elvish fish powershell zsh)' \
&& ret=0
;;
(stats)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
'--path[Print the config file path]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(cfg)
_arguments "${_arguments_options[@]}" : \
'--path[Print the config file path]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
'--fix[Attempt to fix issues automatically (prompts first)]' \
'--report[Output a GitHub-issue-ready diagnostic report]' \
'-v[Show all checks, including passing ones]' \
'--verbose[Show all checks, including passing ones]' \
'-y[Skip confirmation prompts for --fix]' \
'--yes[Skip confirmation prompts for --fix]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_pxh__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pxh-help-command-$line[1]:"
        case $line[1] in
            (show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(recall)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(import)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(sync)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(scrub)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(insert)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(seal)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(shell-config)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(autosuggest)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(maintenance)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(scan)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(stats)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_pxh_commands] )) ||
_pxh_commands() {
    local commands; commands=(
'show:search for and display history entries' \
's:search for and display history entries' \
'recall:interactive history search (Ctrl-R replacement)' \
'r:interactive history search (Ctrl-R replacement)' \
'install:install pxh helpers by modifying your shell rc file' \
'import:import history entries from your existing shell history or from an export' \
'export:export full history as JSON' \
'sync:synchronize to and from a directory of other pxh history databases' \
'scrub:scrub (remove) history entries matching the prompted-for string' \
'insert:(internal) invoked by the shell to insert a history entry' \
'seal:(internal) seal the previous inserted command to mark status, timing, etc' \
'shell-config:(internal) shell configuration suitable for \`source\`'\''ing to enable pxh' \
'autosuggest:(internal) print the most recent command matching a prefix for zsh-autosuggestions' \
'maintenance:perform ANALYZE and VACUUM on the specified database files to optimize performance and reclaim space' \
'scan:scan history for potential secrets and sensitive data' \
'completions:generate shell completions' \
'stats:show history statistics' \
'config:edit or initialize configuration' \
'cfg:edit or initialize configuration' \
'doctor:diagnose common issues and produce diagnostic reports' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'pxh commands' commands "$@"
}
