#compdef qp
# Documentation: https://man.archlinux.org/search?q=qp
# Reference accessed: 2026-05-16

# f5io/qp — NDJSON processor (see upstream `qp --help`)

local ret=1
_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '-f+[filter expression]:expr:' \
  '-c+[count / limit (per upstream)]:n:' \
  '*:: :_files' && ret=0
return ret
