#compdef empire empire-server
# _empire — BC-Security empire CLI PowerShell Empire Python Empire 5 modular Adversary Emulation Framework command and control server-only headless executable providing REST API GraphQL endpoint for agents stagers listeners modules malleable-profile sliver-style for authorized red-team operations (BC-Security team, Python); argparse
# upstream: https://github.com/BC-SECURITY/Empire

_empire() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--silent[silent]' \
        '--reset[reset database]' \
        '--migrate[migrate database]' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '--restport=+[port]:n:' \
        '--socketport=+[port]:n:' \
        '--mysql-host=+[host]:_hosts' \
        '--mysql-port=+[port]:n:' \
        '--mysql-database=+[name]:str:' \
        '--mysql-username=+[user]:str:' \
        '--mysql-password=+[password]:str:' \
        '--password=+[password]:str:' \
        '--bypass-tls[disable TLS]' \
        '--no-autostart[no auto start]' \
        '--no-banner[no banner]' \
        '--no-rest[no rest server]' \
        '*::'
}

_empire "$@"
