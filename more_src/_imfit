#compdef imfit
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imfit.html
# MIRIAD: fit models to an image dataset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image dataset]:in:_files' \
  'region=[region of interest]:region:' \
  'clip=[clip level threshold]:clip:' \
  'object=[component types to fit]:object:(level gaussian disk point beam)' \
  'spar=[initial parameter estimates]:spar:' \
  'fix=[fixed parameter letter codes]:fix:' \
  'out=[output model or residual dataset]:out:_files' \
  'options=[residual]:options:(residual)' \
  '*:image:_files' && ret=0

return ret
