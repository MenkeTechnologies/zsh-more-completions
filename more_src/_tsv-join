#compdef tsv-join

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-f+[filter file]:file:_files' \
  '--filter-file=[filter file]:file:_files' \
  '-k+[key fields]:fields' \
  '--key-fields=[key fields]:fields' \
  '-d+[delimiter]:delimiter' \
  '--delimiter=[delimiter]:delimiter' \
  '--header[input has header]' \
  '--append=[append fields from filter]:fields' \
  '--exclude[exclude matches instead of include]' \
  '--write-all=[write all including non-matches]:default value' \
  '*:file:_files' && return 0
