#compdef mf6
# Documentation: https://github.com/MODFLOW-ORG/modflow6/blob/develop/src/Utilities/comarg.f90
# MODFLOW 6 USGS modular hydrologic model

local ret=1

_arguments -s -S \
  '(-h -? --help)'{-h,-\?,--help}'[show help message]' \
  '(-v --version)'{-v,--version}'[display program version information]' \
  '(-dev --develop)'{-dev,--develop}'[display program develop option mode]' \
  '(-d --disclaimer)'{-d,--disclaimer}'[display program disclaimer]' \
  '(-p --parallel)'{-p,--parallel}'[run program in parallel mode]' \
  '(-lic --license)'{-lic,--license}'[display program license information]' \
  '(-c --compiler)'{-c,--compiler}'[display compiler information]' \
  '(-co --compiler-opt)'{-co,--compiler-opt}'[display compiler options]' \
  '(-s --silent)'{-s,--silent}'[send all STDOUT to mfsim.stdout]' \
  '(-l --level)'{-l,--level}'[set STDOUT output level based on str]:level:(summary debug)' \
  '(-m --mode)'{-m,--mode}'[set simulation mode based on str]:mode:(validate)' && ret=0

return ret
