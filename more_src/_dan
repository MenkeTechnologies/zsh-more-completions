#compdef dan
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/dan.html
# dan - Calculate nucleic acid melting temperature

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-sequence[input nucleotide sequence(s)]:file:_files' \
  '-windowsize[size of sequence window]:size:' \
  '-shiftincrement[amount window moves per increment]:n:' \
  '-dnaconc[DNA concentration in nM]:conc:' \
  '-saltconc[salt concentration in mM]:conc:' \
  '-mintemp[minimum temperature for plot y-axis]:temp:' \
  '-graph[graphics output device type]:device:' \
  '-outfile[output report file]:file:_files' \
  '-product[prompt for formamide/mismatch/product length]' \
  '-formamide[percent formamide]:pct:' \
  '-mismatch[percent mismatch allowed]:pct:' \
  '-prodlen[product length]:len:' \
  '-thermo[output thermodynamic values]' \
  '-temperature[temperature for thermodynamic calculations]:temp:' \
  '-rna[specify sequence as RNA]' \
  '-plot[generate graphical plot instead of data file]' \
  '-auto[turn off prompts]' \
  '-version[display version number]' \
  '*:sequence file:_files' && ret=0

return ret
