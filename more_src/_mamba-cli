#compdef mamba-cli
# _mamba-cli — Mamba fast conda-compatible package manager CLI alias (Mamba project / QuantStack, C++); reads conda env yamls
# upstream: https://github.com/mamba-org/mamba

_mamba-cli() {
    local -a sub=(
        'activate:activate env'
        'deactivate:deactivate env'
        'clean:remove unused files'
        'compare:compare envs'
        'config:manage config'
        'create:create env'
        'env:env subcommand'
        'info:show info'
        'init:init shell'
        'install:install packages'
        'list:list installed'
        'mambasearch:search packages'
        'package:create custom package'
        'remove:remove packages or env'
        'rename:rename env'
        'repoquery:query conda repo'
        'run:run command in env'
        'search:search packages'
        'self-update:update mamba'
        'update:update packages'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--json[json output]' \
        '--dry-run[dry run]' \
        '--name=+[env name]:str:' \
        '-n+[env name]:str:' \
        '--prefix=+[env prefix]:dir:_files -/' \
        '-p+[env prefix]:dir:_files -/' \
        '--root-prefix=+[root prefix]:dir:_files -/' \
        '-r+[root prefix]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mamba subcommand' sub ;;
        args)
            case $words[1] in
                install|update|remove|create) _arguments \
                    '--channel=+[channel]:str:' \
                    '-c+[channel]:str:' \
                    '--override-channels[override channels]' \
                    '--strict-channel-priority[strict channel priority]' \
                    '--no-channel-priority[no channel priority]' \
                    '--yes[assume yes]' \
                    '-y[assume yes]' \
                    '--no-deps[no deps]' \
                    '--no-pin[no pin]' \
                    '--offline[offline]' \
                    '--use-local[use local conda-bld]' \
                    '--use-index-cache[use index cache]' \
                    '--insecure[insecure]' \
                    '-k[insecure]' \
                    '--force-reinstall[force reinstall]' \
                    '--update-deps[update deps]' \
                    '--update-all[update all]' \
                    '--copy[copy not symlink]' \
                    '--file=+[env file]:file:_files -g "*.txt *.yml *.yaml"' \
                    '-f+[env file]:file:_files -g "*.txt *.yml *.yaml"' \
                    '*:package:' ;;
                env) _arguments \
                    '1:cmd:(create export list remove update config)' \
                    '*:arg:' ;;
                list) _arguments '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(append list prepend remove set sources)' \
                    '*:arg:' ;;
                run) _arguments '*:cmd:_command_names -e' ;;
                init) _arguments \
                    '1:shell:(bash zsh fish powershell tcsh xonsh)' ;;
                clean) _arguments \
                    '--all[remove all]' \
                    '-a[remove all]' \
                    '--index-cache[index cache]' \
                    '-i[index cache]' \
                    '--packages[packages]' \
                    '-p[packages]' \
                    '--tarballs[tarballs]' \
                    '-t[tarballs]' \
                    '--locks[locks]' ;;
            esac
            ;;
    esac
}

_mamba-cli "$@"
