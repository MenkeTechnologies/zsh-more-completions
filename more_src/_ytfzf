#compdef ytfzf
# Documentation: https://github.com/pystardust/ytfzf
# Reference accessed: 2026-05-21
# Verified: upstream docs/man/ytfzf.1 at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --download)'{-d,--download}'[download selected videos]' \
  '(-m --audio-only)'{-m,--audio-only}'[play audio only]' \
  '(-f --formats)'{-f,--formats}'[show available formats before proceeding]' \
  '--format-selection=[format selection screen type]:type:(normal simple)' \
  '--format-sort=[--format-sort to use in ytdl]:sort:' \
  '--video-pref=[ytdl video format]:pref:' \
  '--audio-pref=[ytdl audio format]:pref:' \
  '--ytdl-pref=[ytdl format]:pref:' \
  '--detach[detach video player from terminal]' \
  '(-u --url-handler)'{-u+,--url-handler=}'[url handler function/program]:handler:' \
  '-I+[print info instead of playing]:option:(L l link VJ vj video-json J j json F f format R r raw)' \
  '-L[alias for -I L]' \
  '--info-action=[action when --info-wait is 1]:action:' \
  '--info-wait=[wait after -I or -L]:n:' \
  '--url-handler-opts=[opts to pass to url handler]:opts:' \
  '(-l --loop)'{-l,--loop}'[reopen menu when video stops]' \
  '(-s --search-again)'{-s,--search-again}'[search again after closing fzf]' \
  '(-t --show-thumbnails)'{-t,--show-thumbnails}'[show thumbnails]' \
  '--async-thumbnails[download thumbnails asynchronously]' \
  '--skip-thumb-download[skip thumbnail download]' \
  '--notify-playing[notify when a video is about to play]' \
  '--preview-side=[fzf preview side]:side:(left right up down)' \
  '(-T --thumb-viewer)'{-T+,--thumb-viewer=}'[thumbnail viewer program]:viewer:(chafa chafa-16 chafa-tty catimg catimg-256 imv mpv swayimg swayimg-hyprland)' \
  '(-D --external-menu)'{-D,--external-menu}'[use external menu instead of fzf]' \
  '(-i --interface)'{-i+,--interface=}'[custom interface]:interface:' \
  '--sort[sort scraped videos by upload date]' \
  '--sort-name=[sort-name function]:name:' \
  '--fancy-subs[separator between subscriptions]' \
  '--disable-back[disable back button in submenus]' \
  '--disable-actions[disable actions like submenus and back]' \
  '--disable-submenus[disable submenus]' \
  '--keep-vars[pass options into submenus]' \
  '--submenu-opts=[opts to use in submenu]:opts:' \
  '(-a --auto-select)'{-a,--auto-select}'[auto-play first result]' \
  '(-A --select-all)'{-A,--select-all}'[select all results]' \
  '(-r --random-select)'{-r,--random-select}'[auto-play a random result]' \
  '(-S --select)'{-S+,--select=}'[auto-play specific video by sed address]:sed-address:' \
  '(-n --link-count)'{-n+,--link-count=}'[number of videos to select with -a or -r]:n:' \
  '(-c --scrape)'{-c+,--scrape=}'[scraper(s) to use]:scrapers:' \
  '(-H --history)'{-H,--history}'[alias for -c H]' \
  '--scrape+=[add to default scrapers]:scrapers:' \
  '--scraper-=[remove scraper from list]:scrapers:' \
  '--multi-search[enable multi search]' \
  '--force-youtube[convert invidious links to youtube]' \
  '--force-invidious[use invidious instance instead of youtube]' \
  '--pages=[pages to scrape]:n:' \
  '--pages-start=[page to start on]:n:' \
  '--max-threads=[max scrape threads]:n:' \
  '--single-threaded[force single-threaded scraping]' \
  '--odysee-video-count=[videos to scrape on odysee]:n:' \
  '--nsfw[search for nsfw videos]' \
  '--sort-by=[search-time sort]:sort:(relevance rating upload_date oldest_first view_count)' \
  '--upload-date=[time frame filter]:frame:(hour today week month year)' \
  '--video-duration=[duration filter]:duration:(short long)' \
  '--type=[result type]:type:(video playlist channel all)' \
  '--thumbnail-quality=[thumbnail quality]:q:(maxres maxresdefault sddefault high medium default start middle end)' \
  '--features=[features filter (comma-separated)]:features:' \
  '--region=[country code]:region:' \
  '--ii=[invidious instance]:url:' \
  '--invidious-instance=[invidious instance]:url:' \
  '--rii[refresh invidious instance cache]' \
  '--refresh-inv-instance[refresh invidious instance cache]' \
  '--available-inv-instances[print available invidious instances]' \
  '--channel-link=[convert channel link to /channel/id form]:link:' \
  '-q[use search history instead of a search]' \
  '--search-source=[search source]:source:(args prompt hist next fn-args)' \
  '(-x --history-clear)'{-x,--history-clear=}'[clear search/watch history]:which:(search watch)' \
  '--keep-cache[keep cache after exit]' \
  '--ytdl-opts=[options to pass to youtube-dl]:opts:' \
  '--ytdl-path=[path to youtube-dl or fork]:path:_files' \
  '(-e --ext)'{-e+,--ext=}'[load extension]:ext:' \
  '--list-addons[list all addons and exit]' \
  '--thumbnail-log=[thumbnail debug log file]:file:_files' \
  '*:search query:' && ret=0

return ret
