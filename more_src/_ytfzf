#compdef ytfzf
# Zsh completion for ytfzf (find and watch YouTube videos from terminal)
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-t --thumb)'{-t,--thumb}'[Enable thumbnail previews]' \
  '(-D --download)'{-D,--download}'[Download selected video]' \
  '(-m --audio-only)'{-m,--audio-only}'[Play audio only]' \
  '(-l --loop)'{-l,--loop}'[Loop playback]' \
  '(-s --search)'{-s,--search}'[Search for a video]' \
  '(-n --count)'{-n,--count}'[Number of results to show]:count:' \
  '--pages[Number of pages to scrape]:pages:' \
  '--type[Type of content to search for]:type:(video playlist channel all)' \
  '--sort[Sort results by]:sort order:(relevance date views rating)' \
  '--duration[Filter by duration]:duration:(short medium long)' \
  '--features[Filter by features]:features:(live 4k subtitles hd cc 360 vr180 3d hdr location)' \
  '(-u --url)'{-u,--url}'[Print URL instead of playing]' \
  '(-I --info)'{-I,--info}'[Print video information]' \
  '--detach[Detach player from terminal]' \
  '--notify-playing[Send notification when video starts playing]' \
  '(-f --format-selection)'{-f,--format-selection}'[Show format selection menu]' \
  '(-d --ext-menu)'{-d,--ext-menu}'[Use external menu (dmenu/rofi)]' \
  '(-H --history)'{-H,--history}'[Show history]' \
  '(-x --clear-history)'{-x,--clear-history}'[Clear history]' \
  '--force-youtube[Force YouTube as source]' \
  '--force-invidious[Force Invidious as source]' \
  '--invidious-instance[Specify Invidious instance URL]:url:' \
  '(-c --channel)'{-c,--channel}'[Search a specific channel]:channel url:' \
  '(- *)--help[Show help message]' \
  '(- *)--version[Show version]' \
  '*:search query:' && ret=0
return ret
