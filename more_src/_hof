#compdef hof
# Documentation: https://github.com/hofstadter-io/hof
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hofstadter-io/hof: CUE-powered data model, schema, code gen, task engine.
# Persistent flags from cmd/hof/flags/root.go; subcommands from
# cmd/hof/cmd/root.go, gen.go, flow.go, mod.go, completions.go.

local curcontext="$curcontext" state line ret=1
local -a top gen1 flow1 mod1 comp1

top=(
  'agent:build chat with and serve agentic systems'
  'create:starter kits or blueprints from git repos'
  'datamodel:manage diff and migrate data models'
  'def:print consolidated CUE definitions'
  'env:build run ship and deploy environments'
  'eval:evaluate and print CUE configuration'
  'export:output data in a standard format'
  'extension:run the extension server'
  'flow:run workflows and tasks powered by CUE'
  'f:alias for flow'
  'fmt:format code and manage formatters'
  'gen:CUE powered code generation'
  'G:alias for gen'
  'mod:CUE module dependency management'
  'tui:terminal UI for Hof and CUE'
  'vet:validate data with CUE'
  'run:Hof Line Script successor to bash/python scripting'
  'r:alias for run'
  'update:check for new versions and self-update'
  'version:print detailed version information'
  'completion:generate shell completion scripts'
  'completions:alias for completion'
  'feedback:open GitHub issue or discussion'
)

gen1=(
  'init:bootstrap a new generator module'
  'info:generator module info'
  'list:list available generators'
)

flow1=(
  'list:print available flows'
)

mod1=(
  'edit:pass-through to cue mod edit'
  'fix:pass-through to cue mod fix'
  'get:pass-through to cue mod get'
  'init:pass-through to cue mod init'
  'publish:pass-through to cue mod publish'
  'registry:pass-through to cue mod registry'
  'resolve:pass-through to cue mod resolve'
  'tidy:pass-through to cue mod tidy'
)

comp1=(
  'bash:Bash completion script'
  'zsh:Zsh completion script'
  'fish:Fish completion script'
  'power-shell:PowerShell completion script'
  'windows:alias for power-shell'
  'win:alias for power-shell'
  'power:alias for power-shell'
  'ps:alias for power-shell'
)

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --package)'{-p+,--package=}'[CUE package for execution]:package:' \
  '(*-I --input)'{-I+,--input=}'[extra data unified into root]:input:' \
  '(-0 --stdin-empty)'{-0,--stdin-empty}'[do not block on empty stdin]' \
  '(*-e --expression)'{-e+,--expression=}'[evaluate these CUE expressions only]:expr:' \
  '(*-t --tags)'{-t+,--tags=}'[@tags() values injected into CUE]:tag:' \
  '(*-l --path)'{-l+,--path=}'[single path component for data files]:path:' \
  '(*-d --schema)'{-d+,--schema=}'[schema expression for data files]:schema:' \
  '(-D --include-data)'{-D,--include-data}'[auto-include data files with cue files]' \
  '--with-context[extra context for data files for -l/path]' \
  '(-V --inject-env)'{-V,--inject-env}'[inject ENV as default tag vars]' \
  '(*-U --user-files)'{-U+,--user-files=}'[file globs embedded into root]:glob:' \
  '(-E --all-errors)'{-E,--all-errors}'[print all CUE errors]' \
  '(-i --ignore-errors)'{-i,--ignore-errors}'[assume defaults at prompts]' \
  '--dry-run[dry run supported commands]' \
  '--stats[print generator statistics]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output; assume defaults at prompts]' \
  '(-v --verbosity)'{-v+,--verbosity=}'[verbosity level]:level:' \
  '1: :->top' \
  '*::arg:->args' && ret=0

case $state in
  (top) _describe -t commands 'hof command' top && ret=0 ;;
  (args)
    case $line[1] in
      (gen|G)
        if (( CURRENT == 3 )); then
          _describe -t commands 'hof gen command' gen1 && ret=0
        else
          _default && ret=0
        fi ;;
      (flow|f)
        if (( CURRENT == 3 )); then
          _describe -t commands 'hof flow command' flow1 && ret=0
        else
          _default && ret=0
        fi ;;
      (mod)
        if (( CURRENT == 3 )); then
          _describe -t commands 'hof mod pass-through' mod1 && ret=0
        else
          _default && ret=0
        fi ;;
      (completion|completions)
        if (( CURRENT == 3 )); then
          _describe -t commands 'hof completion shell' comp1 && ret=0
        else
          _default && ret=0
        fi ;;
      (*) _default && ret=0 ;;
    esac ;;
esac

return ret
