#compdef deCONZ
# Documentation: https://github.com/dresden-elektronik/deconz-rest-plugin/wiki/deCONZ-command-line-parameters
# deCONZ: dresden elektronik Zigbee gateway daemon

local ret=1

_arguments -s -S \
  '--dev=[serial device to connect to]:device:_files' \
  '--dev-test-managed[run in dev test managed mode]' \
  '--always-add-lights[always add discovered lights]' \
  '--auto-connect=[auto-connect to the device]:flag:(0 1)' \
  '--http-listen=[HTTP listen interface IP]:ip' \
  '--http-port=[HTTP server port]:port' \
  '--https-port=[HTTPS server port]:port' \
  '--http-root=[HTTP document root path]:dir:_files -/' \
  '--ws-port=[websocket server port]:port' \
  '--read-reg-interval=[register read interval]:interval' \
  '--read-reg=[register to read]:reg' \
  '--baudrate=[serial baud rate]:baudrate' \
  '--zdp-aps-ack[request APS ack for ZDP requests]' \
  '--mgtmlqi-delay=[mgmt LQI request delay]:delay' \
  '--appdata=[config folder path]:dir:_files -/' \
  '--dbg-info=[info debug level]:level' \
  '--dbg-error=[error debug level]:level' \
  '--dbg-ddf=[DDF debug level]:level' \
  '--dbg-dev=[device debug level]:level' \
  '--dbg-aps=[APS debug level]:level' \
  '--dbg-ota=[OTA debug level]:level' \
  '--dbg-prot=[protocol debug level]:level' \
  '--dbg-wire=[wire debug level]:level' \
  '--dbg-zdp=[ZDP debug level]:level' \
  '--dbg-zcl=[ZCL debug level]:level' \
  '--dbg-zcldb=[ZCL database debug level]:level' \
  '--dbg-http=[HTTP debug level]:level' \
  '--dbg-tlink=[touchlink debug level]:level' \
  '-platform[Qt platform plugin]:platform:(minimal)' \
  '*::arg:_files' && ret=0

return ret
