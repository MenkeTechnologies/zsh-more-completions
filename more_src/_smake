#compdef smake
# _smake — SchilliX/Joerg Schilling smake portable make (Joerg Schilling, C); POSIX/SVR4 make with extensions
# upstream: https://sourceforge.net/projects/schilytools

_smake() {
    _arguments \
        '-c+[change to dir]:dir:_files -/' \
        '-C+[change to dir]:dir:_files -/' \
        '-debug[debug]' \
        '-DEBUG[debug]' \
        '-e[env-vars override]' \
        '-f+[makefile]:file:_files -g "[Mm]akefile*"' \
        '-globals[print globals]' \
        '-h[show help]' \
        '-help[show help]' \
        '-I+[include dir]:dir:_files -/' \
        '-i[ignore errors]' \
        '-j+[jobs]:n:' \
        '-K[ignore SIGTERM]' \
        '-k[keep going]' \
        '-l+[load file]:file:_files' \
        '-M[show maximum time]' \
        '-m[show resources]' \
        '-n[no execute]' \
        '-NO_DEBUG[no debug]' \
        '-no_warn[no warnings]' \
        '-old[legacy mode]' \
        '-p[print database]' \
        '-pwd[show working dir]' \
        '-q[question]' \
        '-r[no implicit rules]' \
        '-S[stop on error]' \
        '-s[silent]' \
        '-t[touch]' \
        '-version[show version]' \
        '-V[show version]' \
        '-W+[what-if file]:file:_files' \
        '-x[xtrace]' \
        '*:target:'
}

_smake "$@"
