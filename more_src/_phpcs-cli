#compdef phpcs-cli
# _phpcs-cli — Squiz Labs PHP_CodeSniffer code-style linter CLI alias (PHPCSStandards team, PHP); custom argparse
# upstream: https://github.com/PHPCSStandards/PHP_CodeSniffer

_phpcs-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--standard=+[standard]:s:(PSR1 PSR2 PSR12 PEAR Squiz Zend MySource Generic)' \
        '--sniffs=+[sniffs]:str:' \
        '--exclude=+[sniffs to exclude]:str:' \
        '--ignore=+[ignore patterns]:str:' \
        '--extensions=+[extensions]:str:' \
        '--file-list=+[file list]:file:_files' \
        '--report=+[report]:r:(full xml checkstyle csv emacs source summary diff svnblame gitblame hgblame info notifysend performance code junit cbf)' \
        '--report-file=+[report file]:file:_files' \
        '--report-width=+[width]:n:' \
        '--basepath=+[base path]:dir:_files -/' \
        '--bootstrap=+[bootstrap file]:file:_files' \
        '--cache=+[cache file]:file:_files' \
        '--no-cache[no cache]' \
        '--tab-width=+[tab width]:n:' \
        '--encoding=+[encoding]:e:(utf-8 iso-8859-1)' \
        '--parallel=+[parallel processes]:n:' \
        '--severity=+[severity]:n:' \
        '--error-severity=+[error severity]:n:' \
        '--warning-severity=+[warning severity]:n:' \
        '--colors[force colors]' \
        '--no-colors[no colors]' \
        '-p[show progress]' \
        '-q[quiet]' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-vvv[max verbose]' \
        '-l[do not recurse]' \
        '-s[show source codes]' \
        '-n[hide warnings]' \
        '-w[show warnings]' \
        '-i[show installed standards]' \
        '-e[explain standard]' \
        '--generator=+[generator]:g:(HTML Markdown Text)' \
        '--config-set[set config option]' \
        '--config-delete[delete config option]' \
        '--config-show[show config]' \
        '*:files:_files'
}

_phpcs-cli "$@"
