#compdef netbird-mgmt
# _netbird-mgmt — NetBird management server daemon (netbirdio/netbird)
# upstream: https://github.com/netbirdio/netbird
# Flags from management/cmd/root.go (cobra).

_netbird-mgmt() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[log level]:level:(panic fatal error warn info debug trace)' \
        '--log-file=[log file path or "console"]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'management:start NetBird Management Server'
                'sqlite-migration:JSON store ⇆ SQLite migration tools'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                management)
                    _arguments \
                        '--port=[server port]:port:' \
                        '--disable-legacy-port[disable legacy port 33073]' \
                        '--metrics-port=[metrics HTTP port]:port:' \
                        '--datadir=[server data directory]:dir:_files -/' \
                        '--config=[config file path]:file:_files' \
                        '--letsencrypt-domain=[domain for Let'\''s Encrypt cert]:domain:' \
                        '--single-account-mode-domain=[single-account-mode domain]:domain:' \
                        '--disable-single-account-mode[disable single-account mode]' \
                        '--cert-file=[SSL cert file]:file:_files' \
                        '--cert-key=[SSL cert private key]:file:_files' \
                        '--disable-anonymous-metrics[disable anonymous metrics]' \
                        '--dns-domain=[peer DNS domain]:domain:' \
                        '--idp-sign-key-refresh-enabled[refresh IdP signing key on expiry]' \
                        '--user-delete-from-idp[delete users from IdP on account deletion]' \
                        '--disable-geolite-update[disable Geolite2 auto-update]'
                    ;;
            esac
            ;;
    esac
}

_netbird-mgmt "$@"
