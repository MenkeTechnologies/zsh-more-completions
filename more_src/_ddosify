#compdef ddosify

# Zsh completion for Ddosify load testing tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-t+[target URL]:url' \
  '-n+[total request count]:count' \
  '-d+[test duration in seconds]:seconds' \
  '-m+[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '-b+[request body]:body' \
  '-h+[request headers]:header' \
  '-T+[timeout per request in seconds]:seconds' \
  '-P+[proxy address]:proxy url' \
  '-o+[output type]:type:(stdout json json-summary)' \
  '-l+[load type]:type:(linear incremental waved)' \
  '--cert-path=[TLS certificate path]:file:_files' \
  '--key-path=[TLS key path]:file:_files' \
  '--config=[config file path]:file:_files -g "*.json"' \
  && ret=0

return ret
