#compdef ddosify
# Documentation: https://github.com/getanteon/anteon/blob/master/ddosify_engine/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for Ddosify load testing tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[show version]' \
  '-t+[target URL]:url' \
  '-n+[total request count]:count' \
  '-d+[test duration in seconds]:seconds' \
  '-m+[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '-b+[request body]:body' \
  '*-h+[request headers (repeatable)]:header' \
  '-T+[timeout per request in seconds]:seconds' \
  '-P+[proxy address]:proxy url' \
  '-o+[output type]:type:(stdout json json-summary)' \
  '-l+[load type]:type:(linear incremental waved)' \
  '--cert_path=[TLS certificate path]:file:_files' \
  '--cert_key_path=[TLS certificate key path]:file:_files' \
  '--config=[config file path]:file:_files -g "*.json"' \
  '--debug[single scenario iteration with verbose output]' \
  && ret=0

return ret
