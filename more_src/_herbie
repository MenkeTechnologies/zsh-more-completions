#compdef herbie
# Documentation: https://herbie.readthedocs.io/en/latest/user_guide/cli.html
# herbie - download numerical weather prediction model data

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(data download inventory)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s \
      '(-m --model)'{-m,--model}'=[NWP model name (default hrrr)]:model:(hrrr rap gfs ifs nbm rrfs hrrrak gefs ecmwf)' \
      '(-d --date)'{-d,--date}'=[model initialization date]:date:' \
      '(-f --fxx)'{-f,--fxx}'=[forecast hour(s)]:fxx:' \
      '(-p --priority)'{-p,--priority}'=[data source priority order]:priority:' \
      '--product=[product type specific to the model]:product:' \
      '--subset=[search string for filtering variables]:subset:' \
      '--save_dir=[root directory to save downloaded files]:dir:_files -/' \
      '--overwrite[replace existing GRIB2 files]' \
      '--verbose[enable verbose output]' && ret=0
    ;;
esac

return ret
