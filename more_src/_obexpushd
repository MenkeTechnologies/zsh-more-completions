#compdef obexpushd
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/obexpushd.1.html
# Reference accessed: 2026-05-19
# Verified: obexpushd Ubuntu xenial manpage. Real flags (short
# only, no long forms): -B [addr:chan], -I [app], -N [addr:port],
# -p file, -A file, -a file, -o dir, -s script, -n, -d, -h, -v.
# Corrected from prior file: many fabricated long forms
# (--bluetooth, --usb, --root, --allow, --deny, --realm, --auth,
# --no-disconnect, --output-only, --trusted, --no-trusted,
# --event, --network, --debug, --script, --user) — none exist
# in the manpage. Also removed fabricated -I (was --usb but real
# -I is IrDA), -e/-D/-r/-R/-S/-t/-T/-u flags.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-B[listen to Bluetooth]:addr\:chan:' \
  '-I[listen to IrDA]:app:' \
  '-N[listen to network TCP]:addr\:port:' \
  '-p[write pid to file]:file:_files' \
  '-A[TLS/filter support]:file:_files' \
  '-a[auth credentials file]:file:_files' \
  '-o[output directory]:dir:_files -/' \
  '-s[forward script]:script:_files' \
  '-n[do not detach from terminal]' \
  '-d[enable debug (implies -n)]' && ret=0

return ret
