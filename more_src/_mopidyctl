#compdef mopidyctl
# Documentation: https://man.archlinux.org/search?q=mopidyctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:show effective configuration'
  'deps:show dependencies'
  'help:show help'
  'extension:manage extensions'
  'status:show service status'
  'restart:restart service'
  'start:start service'
  'stop:stop service'
  'reload:reload service'
)

_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--config=[config files]:files:' \
  '--option=[option name=value]:opt:' \
  '*-o+[option]:opt:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mopidyctl command' commands && ret=0 ;;
esac

return ret
