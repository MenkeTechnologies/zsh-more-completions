#compdef xpra

# Zsh completion for xpra - persistent remote applications

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start a new xpra session'
  'start-desktop:start a new xpra desktop session'
  'shadow:shadow an existing display'
  'attach:attach to a running session'
  'detach:detach from a running session'
  'stop:stop a running session'
  'exit:stop a running session'
  'screenshot:take a screenshot'
  'info:show session information'
  'id:show the session id'
  'version:show version'
  'list:list running sessions'
  'list-windows:list windows in a session'
  'sessions:list sessions'
  'launcher:open the session launcher'
  'top:show sessions in a top-like format'
  'control:send a control command to a session'
  'print:print a file via the session'
  'showconfig:show configuration'
  'configure:open configuration GUI'
  'encoding:show available encodings'
  'path-info:show path information'
  'autostart:autostart xpra sessions'
  'recover:recover a session'
  'clean:clean session files'
  'clean-displays:clean up stale displays'
  'clean-sockets:clean up stale sockets'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'xpra command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (start|start-desktop|shadow)
        _arguments -s -S \
          '--bind-tcp=[bind to TCP address]:address\:port' \
          '--bind-ws=[bind to WebSocket address]:address\:port' \
          '--bind-wss=[bind to secure WebSocket address]:address\:port' \
          '--bind-ssl=[bind to SSL address]:address\:port' \
          '--bind=[bind to socket]:socket' \
          '--start=[start command in session]:command' \
          '--start-child=[start child command]:command' \
          '--start-after-connect=[start command after first client connects]:command' \
          '--exit-with-children[exit when all children exit]' \
          '--daemon=[daemonize]:enabled:(yes no)' \
          '--encoding=[set default encoding]:encoding:(h264 h265 vp8 vp9 av1 rgb png jpeg webp)' \
          '--quality=[set encoding quality]:quality (1-100)' \
          '--speed=[set encoding speed]:speed (1-100)' \
          '--min-quality=[set minimum quality]:quality' \
          '--min-speed=[set minimum speed]:speed' \
          '--html=[enable HTML5 client]:enabled:(on off auto)' \
          '--dpi=[set DPI]:dpi' \
          '--xvfb=[custom Xvfb command]:command' \
          '--clipboard=[enable clipboard]:enabled:(yes no auto)' \
          '--speaker=[enable speaker forwarding]:enabled:(on off disabled)' \
          '--microphone=[enable microphone forwarding]:enabled:(on off disabled)' \
          '--webcam=[enable webcam forwarding]:enabled:(on off)' \
          '--file-transfer=[enable file transfers]:enabled:(on off)' \
          '--printing=[enable printing]:enabled:(on off)' \
          '--notifications=[enable notifications]:enabled:(yes no)' \
          '--sharing=[allow sharing the session]:enabled:(yes no)' \
          '--ssl-cert=[SSL certificate file]:file:_files' \
          '--ssl-key=[SSL key file]:file:_files' \
          '--auth=[authentication module]:module' \
          '--tcp-auth=[TCP authentication module]:module' \
          '--password-file=[password file]:file:_files' \
          '--systemd-run=[use systemd-run]:enabled:(yes no auto)' \
          '1:display' && ret=0
        ;;
      (attach)
        _arguments -s -S \
          '--encoding=[set encoding]:encoding:(h264 h265 vp8 vp9 av1 rgb png jpeg webp)' \
          '--quality=[set quality]:quality' \
          '--speed=[set speed]:speed' \
          '--title=[set window title]:title' \
          '--desktop-scaling=[scale desktop]:scaling' \
          '--border=[window border]:border' \
          '--clipboard=[enable clipboard]:enabled:(yes no auto)' \
          '--speaker=[enable speaker]:enabled:(on off disabled)' \
          '--microphone=[enable microphone]:enabled:(on off disabled)' \
          '--readonly[connect in read-only mode]' \
          '--opengl=[enable OpenGL]:enabled:(yes no auto)' \
          '--password-file=[password file]:file:_files' \
          '1:session (host\:display or socket)' && ret=0
        ;;
      (detach|stop|exit|info|id|version)
        _arguments '1:session (host\:display or socket)' && ret=0
        ;;
      (screenshot)
        _arguments \
          '1:output file:_files -g "*.png"' \
          '2:session (host\:display or socket)' && ret=0
        ;;
      (control)
        _arguments \
          '1:session (host\:display or socket)' \
          '2:control command' && ret=0
        ;;
    esac
    ;;
esac

return ret
