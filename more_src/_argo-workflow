#compdef argo-workflow argo-workflows
# _argo-workflow — Argo Workflows long alias for argo CLI (Argo project, Go); spf13/cobra
# upstream: https://github.com/argoproj/argo-workflows

_argo-workflow() {
    local -a sub=(
        'archive:manage archived workflows'
        'auth:authenticate'
        'cluster-template:manage cluster workflow templates'
        'completion:generate shell completion'
        'cp:copy artifacts'
        'cron:manage cron workflows'
        'delete:delete workflows'
        'executor-plugin:manage executor plugins'
        'get:show workflow details'
        'lint:lint manifests'
        'list:list workflows'
        'logs:show workflow logs'
        'node:manage workflow nodes'
        'plugin:manage plugins'
        'resubmit:resubmit workflows'
        'resume:resume workflows'
        'retry:retry failed workflows'
        'server:start server'
        'stop:stop workflows'
        'submit:submit workflow'
        'suspend:suspend workflows'
        'template:manage workflow templates'
        'terminate:terminate workflows'
        'version:show version'
        'wait:wait for completion'
        'watch:watch workflow'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--namespace=+[namespace]:ns:' \
        '-n+[namespace]:ns:' \
        '--token=+[bearer token]:str:' \
        '--kubeconfig=+[kubeconfig path]:file:_files' \
        '--context=+[kube context]:ctx:' \
        '--insecure-skip-verify[insecure skip tls verify]' \
        '--argo-base-href=+[base href]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'argo subcommand' sub ;;
        args)
            case $words[1] in
                submit|lint) _arguments \
                    '--from=+[from]:str:' \
                    '--parameter=+[parameter]:str:' \
                    '--parameter-file=+[parameter file]:file:_files' \
                    '--watch[watch]' \
                    '--wait[wait]' \
                    '--log[stream logs]' \
                    '--name=+[name]:str:' \
                    '--generate-name=+[generate name]:str:' \
                    '--entrypoint=+[entrypoint]:str:' \
                    '*:file:_files -g "*.(yml|yaml|json)"' ;;
                get|delete|stop|terminate|suspend|resume|retry|resubmit|wait|watch|logs) _arguments \
                    '*:workflow:' ;;
                list) _arguments \
                    '--status=+[status]:status:(Pending Running Succeeded Failed Error)' \
                    '--prefix=+[prefix]:str:' \
                    '--running[running only]' \
                    '--completed[completed only]' \
                    '--output=+[output]:fmt:(name json yaml wide)' \
                    '-o+[output]:fmt:(name json yaml wide)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_argo-workflow "$@"
