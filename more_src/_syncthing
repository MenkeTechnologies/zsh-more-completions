#compdef syncthing

# Zsh completion for syncthing - Continuous file synchronization

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--audit[write events to audit log]' \
  '--auditfile[specify audit file]:file:_files' \
  '--browser-only[open GUI in browser]' \
  '--config[set configuration directory]:dir:_directories' \
  '--data[set data directory]:dir:_directories' \
  '--device-id[print device ID]' \
  '--generate[generate initial configuration]:dir:_directories' \
  '--gui-address[override GUI address]:address:' \
  '--gui-apikey[override GUI API key]:key:' \
  '--home[set configuration and data directory]:dir:_directories' \
  '--logfile[set log output destination]:file:_files' \
  '--logflags[set log flags]:flags:' \
  '--log-max-old-files[number of old log files to keep]:number:' \
  '--log-max-size[maximum size of log file]:size:' \
  '--no-browser[do not start browser]' \
  '--no-console[hide console window (Windows)]' \
  '--no-default-folder[do not create default folder]' \
  '--no-restart[do not restart when upgrading]' \
  '--no-upgrade[do not check for upgrades]' \
  '--paths[print paths used]' \
  '--paused[start with all devices paused]' \
  '--reset-database[reset the database]' \
  '--reset-deltas[reset delta index IDs]' \
  '--skip-port-probing[skip initial port availability check]' \
  '--unpaused[start with all devices unpaused]' \
  '--upgrade[perform upgrade]' \
  '--upgrade-check[check for available upgrade]' \
  '--upgrade-to[force upgrade to specified version]:version:' \
  '--verbose[print verbose log output]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'cli:command line interface'
      'decrypt:decrypt a folder'
      'generate:generate initial configuration'
      'serve:run syncthing'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (cli)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(config debug errors operations show)' \
          && ret=0
        ;;
      (decrypt)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--password[folder password]:password:' \
          '--token[auth token]:token:' \
          '--to[destination directory]:dir:_directories' \
          '--verify-only[verify data can be decrypted but do not write it]' \
          '*:path:_directories' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
