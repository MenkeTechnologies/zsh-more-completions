#compdef ipa-kra-install
# Documentation: https://github.com/freeipa/freeipa/blob/master/install/tools/man/ipa-kra-install.1
# Reference accessed: 2026-05-16
# Verified: upstream install/tools/man/ipa-kra-install.1.

# ipa-kra-install: install IPA Key Recovery Authority
local curcontext="$curcontext" ret=1
_arguments -C \
  '--no-host-dns[do not use DNS for hostname lookup]' \
  '(-U --unattended)'{-U,--unattended}'[unattended installation]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[output only errors]' \
  '--log-file=[log to file]:file:_files' \
  '--pki-config-override=[KRA install overrides file]:file:_files' \
  '--token-password=[PKCS#11 token password]:password:' \
  '--token-password-file=[PKCS#11 token password file]:file:_files' \
  '*:replica file:_files' && ret=0
return ret
