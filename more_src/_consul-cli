#compdef consul-cli
# _consul-cli — Consul HTTP API CLI (mantl/consul-cli)
# upstream: https://github.com/mantl/consul-cli
# Subcommands from commands/root.go (cobra).

_consul-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-q --quiet)'{-q,--quiet}'[do not show usage on error]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'acl:ACL management'
                'agent:agent operations'
                'catalog:catalog operations'
                'check:health-check operations'
                'coordinate:network coordinates'
                'event:user events'
                'health:service/node health queries'
                'kv:key-value store operations'
                'operator:operator (raft/keyring/autopilot) commands'
                'service:service register/deregister/maintenance'
                'session:session operations'
                'snapshot:snapshot save/restore'
                'status:cluster status'
                'txn:atomic key-value transactions'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                kv)        _arguments '1:subcommand:(read write delete list lock unlock watch get-acquired delete-cas write-cas check-and-set)' ;;
                acl)       _arguments '1:subcommand:(clone create destroy info list update replication)' ;;
                agent)     _arguments '1:subcommand:(checks members reload self join leave force-leave maintenance)' ;;
                catalog)   _arguments '1:subcommand:(nodes services datacenters node service)' ;;
                health)    _arguments '1:subcommand:(checks node service state)' ;;
                operator)  _arguments '1:subcommand:(autopilot keyring raft)' ;;
                service)   _arguments '1:subcommand:(register deregister maintenance)' ;;
                session)   _arguments '1:subcommand:(create destroy info list node renew)' ;;
                snapshot)  _arguments '1:subcommand:(save restore)' ;;
                status)    _arguments '1:subcommand:(leader peers)' ;;
            esac
            ;;
    esac
}

_consul-cli "$@"
