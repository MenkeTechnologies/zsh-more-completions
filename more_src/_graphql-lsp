#compdef graphql-lsp
# Documentation: https://github.com/graphql/graphiql/tree/main/packages/graphql-language-service-cli
# graphql-lsp - GraphQL Language Service command-line interface

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-c --configDir)'{-c,--configDir}'=[path to configuration directory]:dir:_files -/' \
  '(-s --schemaPath)'{-s,--schemaPath}'=[path to schema DSL file]:file:_files' \
  '(-t --text)'{-t,--text}'=[text buffer for GraphQL diagnostics]:text' \
  '(-f --file)'{-f,--file}'=[file path for GraphQL diagnostics]:file:_files' \
  '--row=[row number for autocomplete suggestions]:row' \
  '--column=[column number for autocomplete suggestions]:column' \
  '1:command:(server validate autocomplete outline)' && ret=0

return ret
