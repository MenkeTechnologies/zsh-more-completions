#compdef create-jollof-app
# Documentation: https://www.npmjs.com/package/create-jollof-app
# Reference accessed: 2026-05-24
# Verified: npm view create-jollof-app bin; npx create-jollof-app --help output.

# Zsh completion for create-jollof-app - FastAPI + Next.js fullstack scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--type=[project type]:type:(fullstack backend frontend)' \
  '(-t --theme)'{-t,--theme=}'[color theme]:theme:' \
  '(-p --payment)'{-p,--payment=}'[payment provider]:provider:(nomba stripe paystack)' \
  '(-e --email)'{-e,--email=}'[email provider]:provider:(resend brevo none)' \
  '--frontend-port=[frontend dev server port]:port:' \
  '--backend-port=[backend dev server port]:port:' \
  '--no-git[skip git initialization]' \
  '--no-install[skip dependency installation]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[output version number]' \
  ':project name:' && ret=0

return ret
