#compdef samtools-addreplacerg
# Documentation: http://www.htslib.org/doc/samtools-addreplacerg.html
# samtools addreplacerg: Add or replace read group tags in a file

local ret=1

_arguments -s -S \
  '(-r)'-r'[Allows you to specify a read group line to append to the header and ap]:STRING: ' \
  '(-R)'-R'[Allows you to specify the read group ID of an existing @RG line and ap]:STRING: ' \
  '(-m)'-m'[If you choose orphan_only then existing RG tags are not overwritten, i]:MODE: ' \
  '(-o)'-o'[Write the final output to STRING. The default is to write to stdout. B]:STRING: ' \
  '(-u)'-u'[Output uncompressed SAM, BAM or CRAM.]' \
  '(-w)'-w'[Overwrite an existing @RG line, if a new one with the same ID value is]' \
  '(--no-PG)'--no-PG'[Do not add a @PG line to the header of the output file.]' \
  '(--threads)'--threads'[Number of input/output compression threads to use in addition to main]:INT: ' \
  '*:file:_files' && ret=0

return ret
