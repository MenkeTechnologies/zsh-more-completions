#compdef rbac-tool
# Documentation: https://man.archlinux.org/search?q=rbac-tool
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'who-can:list subjects who can verb resource'
      'policy-rules:dump RBAC policy rules'
      'show-groups:expand groups for a user'
      'show-wildcard-access:find overly broad bindings'
      'visualize:emit RBAC graph (Graphviz/dot)'
    )
    _describe -t commands 'rbac-tool command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '--kubeconfig=[kubeconfig path]:file:_files' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
