#compdef s3fs
# Documentation: https://manpages.debian.org/s3fs.1
# Source: s3fs-fuse — FUSE-based file system backed by Amazon S3.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a opt_values
opt_values=(
    'bucket=:bucket name'
    'passwd_file=:custom password file path'
    'profile=:AWS credentials profile name'
    'use_session_token:require AWS session token'
    'iam_role=:IAM role name or "auto"'
    'imdsv1only:use IMDSv1 without token'
    'ibm_iam_auth:enable IBM IAM authentication'
    'ibm_iam_endpoint=:IBM IAM auth endpoint URL'
    'ecs:query ECS metadata for credentials'
    'credlib=:external credential library'
    'credlib_opts=:options for credential library'
    'url=:S3 endpoint URL'
    'host=:non-Amazon S3 host'
    'endpoint=:AWS region for SigV4 signing'
    'servicepath=:service path prefix'
    'use_path_request_style:enable path-style API calls'
    'listobjectsv2:use ListObjectsV2 instead of ListObjects'
    'requester_pays:enable Requester-Pays buckets'
    'storage_class=:storage class (standard/glacier/etc)'
    'use_rrs:use Reduced Redundancy Storage (deprecated)'
    'use_sse=:server-side encryption (s3/custom/kmsid)'
    'load_sse_c=:SSE-C key file for decryption'
    'multipart_size=:part size (MB) for multipart uploads'
    'multipart_threshold=:threshold (MB) for multipart'
    'multipart_copy_size=:part size (MB) for copy ops'
    'singlepart_copy_limit=:max single-part copy size (MB)'
    'parallel_count=:parallel upload threads'
    'nomultipart:disable multipart uploads'
    'streamupload:enable experimental stream upload'
    'max_thread_count=:threads for stream upload'
    'max_dirty_data=:flush threshold for dirty data (MB)'
    'enable_content_md5:allow Content-MD5 validation'
    'enable_unsigned_payload:skip Content-SHA256 calculation'
    'use_cache=:enable local file cache (DIR)'
    'check_cache_dir_exist:verify cache directory exists'
    'del_cache:delete cache on startup/exit'
    'ensure_diskfree=:minimum free-space threshold (MB)'
    'free_space_ratio=:min free-space ratio (percent)'
    'max_stat_cache_size=:stat-cache entry limit'
    'stat_cache_expire=:stat-cache timeout (seconds)'
    'stat_cache_interval_expire=:cache expiry from last access'
    'disable_noobj_cache:do not cache non-existent objects'
    'multireq_max=:parallel list requests'
    'list_object_max_keys=:max keys per list call'
    'nodnscache:disable DNS caching'
    'nosscache:disable SSL session caching'
    'default_acl=:canned ACL for new objects'
    'umask=:file permission mask (mode)'
    'mp_umask=:mount-point permission mask'
    'use_xattr:support extended attributes'
    'complement_stat:auto-complete missing file mode info'
    'compat_dir:support alternative directory naming'
    'use_wtf8:re-encode non-UTF8 object names'
    'ahbe_conf=:HTTP-headers-by-file-extension config'
    'update_parent_dir_stat:update parent mtime on changes'
    'sigv2:use signature version 2 only'
    'sigv4:use signature version 4 only'
    'nocopyapi:do not use copy API'
    'norenameapi:do not use copy API for renames'
    'nomixupload:disable PUT in multipart uploads'
    'noxmlns:skip XML namespace registration'
    'public_bucket:mount public bucket anonymously'
    'connect_timeout=:connection timeout (seconds)'
    'readwrite_timeout=:read/write timeout (seconds)'
    'retries=:retry attempts'
    'no_check_certificate:do not verify server certificate'
    'ssl_verify_hostname=:hostname verification level (0-2)'
    'ssl_client_cert=:client certificate'
    'cipher_suites=:colon-separated TLS ciphers'
    'proxy=:proxy server (URL)'
    'proxy_cred_file=:proxy auth credentials file'
    'ipresolve=:IP version (whatever/IPv4/IPv6)'
    'noua:suppress User-Agent header'
    'instance_name=:instance identifier for logging'
    'bucket_size=:advertised bucket capacity'
    'tmpdir=:temporary file directory'
    'logfile=:log file output path'
    'dbglevel=:debug level (crit/err/warn/info)'
    'curldbg=:curl debug mode (normal/body)'
    'no_time_stamp_msg:omit timestamps from debug messages'
    'set_check_cache_sigusr1=:cache-validation output file'
    'mime=:MIME types file'
)

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '-f[run FUSE in foreground (no daemon)]' \
    '-s[single-threaded FUSE operation]' \
    '-d[enable debug output]' \
    '(-u --incomplete-mpu-list)'{-u,--incomplete-mpu-list}'[list incomplete multipart uploads]' \
    '--incomplete-mpu-abort=[delete incomplete multipart uploads]:when:(all)' \
    '*-o+[mount option]:option:->opts' \
    '1:bucket\:path:' \
    '2:mountpoint:_files -/' \
    && ret=0

case $state in
    opts)
        _describe -t s3fs-mount-opts 's3fs mount option' opt_values && ret=0
        ;;
esac

return ret
