#compdef clamsmtp clamsmtpd
# Documentation: https://manpages.debian.org/bookworm/clamsmtp/clamsmtpd.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# clamsmtpd is an SMTP filter that virus-scans via clamd.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-d[do not detach; set error level 0-4]:level:(0 1 2 3 4)' \
  '-f[alternate config file]:file:_files' \
  '-p[pid file path]:file:_files' \
  '(- *)-v[print version and exit]' && ret=0

return ret
