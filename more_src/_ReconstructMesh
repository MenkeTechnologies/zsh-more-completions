#compdef ReconstructMesh
# Documentation: https://github.com/cdcseacave/openMVS/wiki/Usage
# OpenMVS: reconstruct a mesh from a dense point-cloud

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-w --working-folder)'{-w,--working-folder}'=[working directory]:dir:_files -/' \
  '(-c --config-file)'{-c,--config-file}'=[config file]:file:_files' \
  '--export-type=[output format]:type:(ply obj)' \
  '--archive-type=[project archive type]:type:(-1 0 1 2)' \
  '--process-priority=[process priority]:prio' \
  '--max-threads=[max worker threads]:n' \
  '(-v --verbosity)'{-v,--verbosity}'=[verbosity level]:level' \
  '--cuda-device=[CUDA device]:dev' \
  '(-i --input-file)'{-i,--input-file}'=[input scene file]:file:_files' \
  '(-p --pointcloud-file)'{-p,--pointcloud-file}'=[dense point-cloud file]:file:_files' \
  '(-o --output-file)'{-o,--output-file}'=[output mesh file]:file:_files' \
  '(-d --min-point-distance)'{-d,--min-point-distance}'=[min pixel distance between projected points]:n' \
  '--integrate-only-roi=[use only points inside ROI]:n' \
  '--constant-weight=[treat all view weights as 1]:n' \
  '(-f --free-space-support)'{-f,--free-space-support}'=[enable free-space support]:n' \
  '--thickness-factor=[min thickness during visibility weighting]:n' \
  '--quality-factor=[quality weight in graph-cut]:n' \
  '--decimate=[mesh decimation factor]:n' \
  '--target-face-num=[target face count]:n' \
  '--remove-spurious=[remove faces with long edges]:n' \
  '--remove-spikes=[remove spike faces]:n' \
  '--close-holes=[close small holes]:n' \
  '--smooth=[smoothing iterations]:n' \
  '--edge-length=[target average edge length]:n' \
  '--roi-border=[region-of-interest border]:n' \
  '--crop-to-roi=[crop scene to ROI]:n' \
  '*:scene:_files' && ret=0

return ret
