#compdef ic-wasm

# https://github.com/dfinity/ic-wasm — ICP canister Wasm transforms (clap). Typical: ic-wasm input.wasm <metadata|resource|info|shrink|optimize|instrument> ...

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-o --output)'{-o+,--output=}'[output wasm path]:file:_files' \
  '1:input wasm:_files -g "*.wasm"' \
  '*::subcommand and args:_default'
