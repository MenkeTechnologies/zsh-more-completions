#compdef pixa
# Documentation: https://github.com/techarm/pixa
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Source: cargo binstall pixa@0.2.0 -- completions zsh

autoload -U is-at-least

_pixa() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_pixa_commands" \
"*::: :->pixa" \
&& ret=0
    case $state in
    (pixa)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pixa-command-$line[1]:"
        case $line[1] in
            (remove-watermark)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file or directory (defaults to overwriting input)]:OUTPUT:_files' \
'--output=[Output file or directory (defaults to overwriting input)]:OUTPUT:_files' \
'--force-size=[Force watermark size (auto-detect if omitted)]:FORCE_SIZE:(small large)' \
'--threshold=[Detection confidence threshold (0.0-1.0)]:THRESHOLD:_default' \
'-r[Recursively process directories]' \
'--recursive[Recursively process directories]' \
'--if-detected[Run detection first and skip images with no watermark]' \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input image file or directory. Use @clipboard (aliases\: @clip, @c) to read the image from the OS clipboard:_files' \
&& ret=0
;;
(detect)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON]' \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input image file. Use @clipboard (aliases\: @clip, @c) to read the image from the OS clipboard:_files' \
&& ret=0
;;
(compress)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file or directory. If omitted, writes alongside the input with a \`.min\` suffix (file) or to a sibling \`<input>.min\` directory (directory)]:OUTPUT:_files' \
'--output=[Output file or directory. If omitted, writes alongside the input with a \`.min\` suffix (file) or to a sibling \`<input>.min\` directory (directory)]:OUTPUT:_files' \
'--max=[Resize so the longest edge is at most this many pixels (preserves aspect ratio). Useful for shrinking AI-generated 4K images down to web-friendly sizes]:PIXELS:_default' \
'-r[Recursively process directories]' \
'--recursive[Recursively process directories]' \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input image file or directory. Use @clipboard (aliases\: @clip, @c) to read the image from the OS clipboard:_files' \
&& ret=0
;;
(convert)
_arguments "${_arguments_options[@]}" : \
'--format=[Target format extension when processing a directory (e.g. webp, png)]:FORMAT:_default' \
'-r[Recursively process directories]' \
'--recursive[Recursively process directories]' \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input image file or directory. Use @clipboard (aliases\: @clip, @c) to read the image from the OS clipboard:_files' \
':output -- Output file (single input) or directory (recursive):_files' \
&& ret=0
;;
(info)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON]' \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input image file. Use @clipboard (aliases\: @clip, @c) to read the image from the OS clipboard:_files' \
&& ret=0
;;
(favicon)
_arguments "${_arguments_options[@]}" : \
'-o+[Output directory for the icon set]:OUTPUT_DIR:_files' \
'--output-dir=[Output directory for the icon set]:OUTPUT_DIR:_files' \
'--png-level=[PNG optimization level (0-6)]:PNG_LEVEL:_default' \
'--json[Output as JSON]' \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input image file. Use @clipboard (aliases\: @clip, @c) to read the image from the OS clipboard:_files' \
&& ret=0
;;
(split)
_arguments "${_arguments_options[@]}" : \
'-o+[Output directory for the cropped objects]:OUTPUT:_files' \
'--output=[Output directory for the cropped objects]:OUTPUT:_files' \
'*--names=[Comma-separated names for each object (also used as the expected count, which enables re-splitting near-touching objects)]:NAMES:_default' \
'--padding=[Pixels of background padding around each crop]:PADDING:_default' \
'--preview-style=[What to draw in the preview image. Defaults to \`output\` when \`--uniform\` is set (the uniform-bbox frame matches what gets saved), otherwise \`detected\` (the tight per-object bbox)]:PREVIEW_STYLE:((detected\:"Tight per-object detected bbox"
output\:"Uniform max_w × max_h frame for each output PNG"
both\:"Both, with the output frame as the thicker line"))' \
'--tolerance=[RGB distance from the detected background colour at or below which a pixel is treated as background. Only used with \`--transparent\`]:TOLERANCE:_default' \
'--despill-band=[Edge-band radius (pixels) for \`--despill\`]:DESPILL_BAND:_default' \
'--shrink=[Morphologically erode each transparent crop'\''s opaque region by this many pixels]:SHRINK:_default' \
'--preview[Always write a \`<basename>-preview.png\` next to the input]' \
'--transparent[Replace the detected background with transparency in each output. Uses the same chroma-key logic as \`pixa transparent\`]' \
'--despill[Enable channel-based spill suppression on the edge band]' \
'--uniform[Pad every output to the largest detected bbox so all crops share the same dimensions. Useful for sprite sheets / avatar swaps where consistent positioning matters. By default each crop is saved at its own tight bbox size]' \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':input -- Input sheet image (objects on a single-color background). Use @clipboard (aliases\: @clip, @c) to read from the OS clipboard:_files' \
&& ret=0
;;
(transparent)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file or directory. Defaults to \`<input>.transparent.png\` (file) or \`<input>.transparent/\` (directory)]:OUTPUT:_files' \
'--output=[Output file or directory. Defaults to \`<input>.transparent.png\` (file) or \`<input>.transparent/\` (directory)]:OUTPUT:_files' \
'--bg=[Background color to key out, as \`#RRGGBB\` or \`RRGGBB\`. If omitted, the color is auto-detected from the image'\''s corner patches]:BG:_default' \
'--tolerance=[RGB-space distance from the detected background colour at or below which a pixel is treated as background. Wider picks up more of the AA contamination ring at the subject'\''s outer edge; too wide and pastel/near-bg subject regions start dissolving]:TOLERANCE:_default' \
'--despill-band=[Edge-band radius (in pixels) for \`--despill\`. Ignored otherwise]:DESPILL_BAND:_default' \
'--shrink=[Morphologically erode the opaque region by this many pixels after flood. Useful when the AA contamination ring is too wide to clean up cosmetically and the silhouette tolerating a slight shrink is acceptable]:SHRINK:_default' \
'-r[Recursively process directories]' \
'--recursive[Recursively process directories]' \
'--despill[Enable channel-based spill suppression on the edge band\: neutralises bg-colour contamination on AA edges while keeping alpha and interior pixels untouched. Lets you use prettier AI prompts (softer outlines) without a visible pink/magenta ring]' \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input image file or directory. Use @clipboard (aliases\: @clip, @c) to read the image from the OS clipboard:_files' \
&& ret=0
;;
(paste)
_arguments "${_arguments_options[@]}" : \
'--format=[Force output format (png, jpg, jpeg, webp, bmp, gif, tiff). Inferred from the output extension when omitted]:FORMAT:_default' \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help]' \
'--help[Print help]' \
':output -- Output file path, or `-` for stdout:_default' \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
'--skills[Install the Claude Code skill into ~/.claude/skills/pixa/SKILL.md]' \
'--completions[Install shell completions (auto-detects shell and install path)]' \
'--force[Overwrite the destination if it already exists]' \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-v[Enable verbose (debug) logging]' \
'--verbose[Enable verbose (debug) logging]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_pixa__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pixa-help-command-$line[1]:"
        case $line[1] in
            (remove-watermark)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(detect)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(compress)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(convert)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(info)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(favicon)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(split)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(transparent)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(paste)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_pixa_commands] )) ||
_pixa_commands() {
    local commands; commands=(
'remove-watermark:Remove Gemini watermark from an image or directory' \
'detect:Detect whether a Gemini watermark is present' \
'compress:Compress / optimize images (MozJPEG, OxiPNG, WebP)' \
'convert:Convert between image formats' \
'info:Show image metadata and dimensions' \
'favicon:Generate a web-ready favicon/icon set from an image' \
'split:Auto-detect and crop individual objects from a sheet image' \
'transparent:Replace a solid background color with transparency (chroma-key)' \
'paste:Save the clipboard image to a file (or stdout with \`-\`)' \
'install:Install integrations (Claude Code skill, etc.)' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'pixa commands' commands "$@"
}
