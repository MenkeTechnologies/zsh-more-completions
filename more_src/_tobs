#compdef tobs

# Zsh completion for tobs (The Observability Stack for Kubernetes)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'helm:manage the Helm release'
  'install:install the observability stack'
  'metrics:manage metrics'
  'port-forward:set up port forwarding'
  'uninstall:uninstall the observability stack'
  'upgrade:upgrade the observability stack'
  'volume:manage volumes'
)

_arguments -s -S \
  '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]:namespace:' \
  '--name[Helm release name]:name:' \
  '--chart-reference[Helm chart reference]:reference:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tobs command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (install|upgrade)
        _arguments \
          '(-f --filename)'{-f,--filename}'[values file]:file:_files -g "*.yaml *.yml"' \
          '--enable-prometheus-ha[enable HA for Prometheus]' \
          '--enable-timescaledb-backup[enable TimescaleDB backup]' \
          '--external-timescaledb-uri[external TimescaleDB URI]:uri:' \
          '--only-secrets[install only secrets]' \
          '--reset-values[reset values on upgrade]' && ret=0
        ;;
      (port-forward)
        _arguments \
          '--grafana[port-forward Grafana]' \
          '--prometheus[port-forward Prometheus]' \
          '--promscale[port-forward Promscale]' \
          '--promlens[port-forward PromLens]' \
          '--timescaledb[port-forward TimescaleDB]' && ret=0
        ;;
    esac
    ;;
esac

return ret
