#compdef task
# Documentation: https://taskfile.dev/reference/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-s --silent)'{-s,--silent}'[silent mode]' \
  '--disable-fuzzy[disable fuzzy task name matching]' \
  '(-F --failfast)'{-F,--failfast}'[stop dependencies on first failure]' \
  '(-f --force)'{-f,--force}'[force execution even when up-to-date]' \
  '(-n --dry)'{-n,--dry}'[compile and print tasks without executing]' \
  '(-p --parallel)'{-p,--parallel}'[run tasks in parallel]' \
  '(-C --concurrency)'{-C,--concurrency}'=[concurrency limit]:limit:' \
  '(-x --exit-code)'{-x,--exit-code}'[pass through failed command exit code]' \
  '(-d --dir)'{-d,--dir}'=[working directory]:directory:_directories' \
  '(-t --taskfile)'{-t,--taskfile}'=[path to Taskfile]:taskfile:_files' \
  '(-g --global)'{-g,--global}'[run global Taskfile]' \
  '(-o --output)'{-o,--output}'=[output style]:output:(interleaved group prefixed)' \
  '(-c --color)'{-c,--color}'[colored output]' \
  '--output-group-begin=[output group begin template]:template:' \
  '--output-group-end=[output group end template]:template:' \
  '--output-group-error-only[only show output on non-zero exit]' \
  '--status[show task status]' \
  '--summary[show task summary]' \
  '--json[output as JSON]' \
  '--sort=[sort order]:sort:(alphanumeric none default)' \
  '(-w --watch)'{-w,--watch}'[watch for changes]' \
  '(-I --interval)'{-I,--interval}'=[watch interval]:duration:' \
  '(-y --yes)'{-y,--yes}'[auto-answer yes to all prompts]' \
  '--interactive[prompt for missing required vars]' \
  '(-l --list)'{-l,--list}'[list tasks]' \
  '(-a --list-all)'{-a,--list-all}'[list all tasks]' \
  '--experiments[list experiments]' \
  '*:task name:' \
  && ret=0
return ret
