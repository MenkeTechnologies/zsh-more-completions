#compdef MotionCor3
# Documentation: https://hpc.nih.gov/apps/RELION/MotionCor2-UserManual-05-31-2022.pdf
# MotionCor3 - beam-induced motion correction for dose-fractionated movies

local ret=1

_arguments -s -S \
  '-InMrc[input MRC movie stack or folder]:file:_files' \
  '-InTiff[input TIFF movie stack]:file:_files' \
  '-InEer[input EER movie stack]:file:_files' \
  '-InSuffix[suffix used to select input files in serial mode]:suffix' \
  '-OutMrc[output corrected-sum MRC file]:file:_files' \
  '-Gain[gain reference MRC file]:file:_files' \
  '-Dark[dark reference MRC file]:file:_files' \
  '-DefectFile[camera defect description file]:file:_files' \
  '-FmIntFile[frame integration file (3-column text)]:file:_files' \
  '-Patch[local-motion patch grid (e.g. 5 5)]:patch' \
  '-Iter[max alignment iterations]:n' \
  '-Tol[alignment error tolerance in pixels]:tol' \
  '-Bft[B-factor for global/local alignment]:bfactor' \
  '-FtBin[Fourier-space binning factor]:bin' \
  '-Throw[number of leading frames to discard]:n' \
  '-Trunc[number of trailing frames to discard]:n' \
  '-Group[frames per alignment sub-group]:n' \
  '-FmRef[zero-indexed frame to align to]:n' \
  '-Kv[acceleration voltage in kV]:kv' \
  '-PixSize[pixel size in Angstrom]:apix' \
  '-FmDose[dose per frame in e/A^2]:dose' \
  '-Mag[anisotropic mag major minor angle]:mag' \
  '-OutStack[output motion-corrected stack (0/1 [zbin])]:val' \
  '-SumRange[lower upper sum range in e/A^2]:range' \
  '-SplitSum[output odd/even half-sums (0/1)]:val' \
  '-RotGain[rotate gain reference 0-3 (x90 deg)]:n' \
  '-FlipGain[flip gain reference 0-2]:n' \
  '-InvGain[invert gain reference (0/1)]:val' \
  '-PhaseOnly[phase-only cross correlation (0/1)]:val' \
  '-GpuMemUsage[fraction of GPU memory to buffer frames]:frac' \
  '-InFmMotion[account for in-frame motion blur (0/1)]:val' \
  '-EerSampling[EER upsampling 1/2/3 (1x/2x/4x)]:n' \
  '-Serial[enable batch/serial processing (0/1)]:val' \
  '-LogDir[directory for log files]:dir:_files -/' \
  '-Gpu[GPU device IDs]:gpus' \
  '-UseGpus[number of GPUs each process uses]:n' \
  '*:file:_files' && ret=0

return ret
