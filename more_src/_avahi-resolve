#compdef avahi-resolve avahi-resolve-host-name avahi-resolve-address
# _avahi-resolve — Avahi mDNS resolver (resolves hostnames to addresses or vice versa via the Avahi daemon; binary is symlinked as avahi-resolve-host-name / avahi-resolve-address)
# upstream: https://github.com/lathiat/avahi
# Flags from avahi-utils/avahi-resolve.c long_options on tip.

_avahi-resolve() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '(-n --name -a --address)'{-n,--name}'[resolve hostname to address]' \
        '(-n --name -a --address)'{-a,--address}'[resolve address to hostname]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '*:target:'
}

_avahi-resolve "$@"
