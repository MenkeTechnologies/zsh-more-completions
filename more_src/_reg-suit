#compdef reg-suit
# Documentation: https://github.com/reg-viz/reg-suit
# reg-suit - visual regression testing tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'=[specify configuration file path]:config:_files' \
  '(-t --test)'{-t,--test}'[perform dry-run mode]' \
  '(-v --verbose)'{-v,--verbose}'[display debug logging messages]' \
  '(-q --quiet)'{-q,--quiet}'[suppress logging messages]' \
  '--use-yarn[use yarn instead of npm for package installation]' \
  '--use-yarn-ws[enable when using yarn workspace]' \
  '(-n --notification)'{-n,--notification}'[send notifications via notifier plugins]' \
  '(-p --plugin)'{-p,--plugin}'=[specify plugin name(s) to configure]:plugin' \
  '1:command:(run sync-expected compare publish init prepare)' \
  '*::arg:_files' && ret=0

return ret
