#compdef scrm
# Documentation: https://github.com/scrm/scrm/wiki/Command-Line-Options
# scrm: fast coalescent simulator with recombination (ms-compatible)

local ret=1

_arguments -s -S \
  '-t+[set mutation rate theta=4*N0*u]:theta' \
  '-r+[set recombination rate R=4*N0*r and locus length]:rate' \
  '-l+[use approximation within a sliding window]:window' \
  '-G+[exponential growth rate of all populations]:rate' \
  '-I+[island model with npop populations]:npop' \
  '-n+[present day size of population i to n*N0]:size' \
  '-g+[exponential growth rate of population i]:rate' \
  '-eN+[size of all populations to n*N0 at time t]:t' \
  '-eG+[exponential growth rate of all populations at time t]:t' \
  '-em+[migration rate from population j to i at time t]:t' \
  '-ema+[migration matrix at time t]:t' \
  '-ej+[specialization event creating a population]:t' \
  '-es+[population admixture at time t]:t' \
  '-M+[symmetric migration rate M/(npop-1)]:M' \
  '-m+[migration rate from population j to i]:M' \
  '-T[print local genealogies in newick format]' \
  '-O[print local genealogies in oriented forest format]' \
  '-L[print TMRCA and local tree length per segment]' \
  '-SC+[scaling of sequence positions]:mode:(rel abs ms)' \
  '-oSFS[print the site frequency spectrum]' \
  '-seed+[seed for the simulation]:seed' \
  '--print-model[print information about the defined model]' \
  '-v[print version information]' \
  '-p+[number of significant digits in output]:digits' && ret=0

return ret
