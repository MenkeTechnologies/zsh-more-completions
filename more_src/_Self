#compdef Self
# =============================================================================
# Self — David Ungar + Randall B. Smith's "Self programming
#         language and environment" — the foundational PROTOTYPE-
#         BASED OBJECT-ORIENTED LANGUAGE that influenced
#         JavaScript prototypes, Io, NewtonScript, Lua tables,
#         and the V8 compiler's design.  Created at Xerox PARC
#         (1986) by Ungar + Smith, then developed at Stanford
#         University (1986-1991) and Sun Microsystems Research
#         Labs (1991-1995).  Self pioneered:
#           - PROTOTYPE-BASED INHERITANCE: no classes; every
#             object is a prototype that can be cloned to make
#             new objects, with slot lookup walking the parent
#             slot chain (no class hierarchy)
#           - DYNAMIC COMPILATION via TYPE FEEDBACK + INLINE
#             CACHES + ADAPTIVE OPTIMIZATION — the compiler
#             techniques later commercialized as HotSpot JVM
#             (Lars Bak, Urs Hölzle joined Sun from Self team)
#             and V8 (Bak + Hölzle co-founded V8 at Google)
#           - DIRECT MANIPULATION OUTLINER UI — Self's Morphic
#             interface let you drag/drop/inspect objects
#             visually as the program ran
#           - LIVE PROGRAMMING — modify methods of running
#             programs from the IDE without restart
#         Self's compiler research is the direct ancestor of:
#           - Sun HotSpot JVM (Urs Hölzle + Lars Bak)
#           - Google V8 JavaScript engine (Lars Bak + Hölzle)
#           - JikesRVM research VM
#           - .NET CoreCLR's adaptive optimization
#           - Strongtalk, Newspeak (Gilad Bracha)
#         Self ran on Sun SPARC workstations through 1995; the
#         project was discontinued at Sun but the VM was open-
#         sourced under BSD-style license in 2006.  Russell
#         Allen (Sydney, Australia) restarted active maintenance
#         in 2011 and continues to maintain russellallen/self
#         for Linux/macOS/Windows.
#
# Author:  David Ungar (IBM Research, formerly Sun Microsystems
#          Labs, Stanford University) + Randall B. Smith (former
#          Sun Microsystems Labs) — co-creators of Self in 1986.
#          Modern maintainer: Russell Allen (Sydney, Australia)
#          since 2011.  Self's research papers + reference
#          implementation defined the modern understanding of
#          prototype-based OOP.
# Source:  https://github.com/russellallen/self
#          https://selflanguage.org/
#          https://github.com/russellallen/self/blob/main/vm/src/any/runtime/shell.cpp
# CLI:     vm/src/any/runtime/shell.cpp — uses POSIX `getopt`
#          (already documented for other languages) with
#          optstring `"Ff:hl:prtcs:woa"`.  Hand-rolled CASE
#          statement on returned option character dispatches
#          to per-option setup code.
# Library: POSIX getopt (Self-flavored — embedded in shell.cpp)
#          (Self uses the venerable POSIX `getopt(3)` from
#           C stdlib for command-line parsing.  No higher-level
#           framework — just a single-character optstring
#           parsed by the OS's `getopt` then a switch statement
#           selecting per-letter handlers.  Self predates most
#           modern argv frameworks; the `getopt` call has been
#           in shell.cpp essentially unchanged since the 1990s
#           Sun Microsystems Labs era, only updated when new
#           debugging flags were added.)
# License: BSD-style (Self VM); BSD/Public Domain (POSIX getopt)
# Status:  russellallen/self has 790+ GH stars; ongoing
#          maintenance with periodic releases for modern
#          Linux/macOS hardware (Apple Silicon support added
#          2022).  Self remains the canonical reference
#          implementation studied by language designers.
#          selflanguage.org hosts the binaries + tutorials +
#          handbook + research papers archive.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 78TH LANGUAGE
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy welcomes
# its 78TH DOCUMENTED LANGUAGE — SELF (David Ungar + Randall B. Smith,
# Stanford / Sun Microsystems Labs, 1986-present) — and its FIRST
# documented Self CLI mechanism: POSIX `getopt(3)` with optstring
# `"Ff:hl:prtcs:woa"` + hand-rolled CASE-on-character dispatch in
# vm/src/any/runtime/shell.cpp.
# Taxonomy now spans 320 cross-language CLI library variants across
# 78 documented languages.
#
# Pattern: 3 leader bumps (R578 Rust=52 reedline/xinfer → R579 Go=52
# zap/testground → R580 TS-Node=52 winston/peertube) followed by 1
# NEW LANGUAGE (R581 Self THIS).  Leaderboard unchanged: Rust=52,
# Go=52, TypeScript-Node=52 (three-way tie at 52 since R580).
#
# Self is DISTINCT from every other documented language by being the
# FOUNDATIONAL PROTOTYPE-BASED OOP LANGUAGE — the language whose
# research papers (Ungar+Smith 1987 "Self: The Power of Simplicity";
# Chambers+Ungar+Lee 1989 "An Efficient Implementation of SELF";
# Hölzle+Ungar+Chambers 1991 "Optimizing Dynamically-Typed Object-
# Oriented Languages With Polymorphic Inline Caches") established the
# theoretical + practical foundations for:
#   - PROTOTYPE-BASED OOP (vs class-based) — direct slot lookup +
#     parent chains; later adopted by JavaScript, Io (R??? _io was
#     the FIRST documented prototype-based lang), Lua tables,
#     NewtonScript, Cecil, Cel
#   - ADAPTIVE OPTIMIZATION via TYPE FEEDBACK — runtime type
#     specialization based on observed types; later commercialized
#     as HotSpot JVM, V8, .NET CoreCLR adaptive JIT
#   - INLINE CACHES (mono/poly/mega) — fast method dispatch via
#     cached type→method mappings; now standard in every modern VM
#   - METHOD CUSTOMIZATION via PROFILE-GUIDED RECOMPILATION
#
# The taxonomy now documents the Smalltalk → Self → JavaScript
# prototype lineage:
#   - Smalltalk-80 (Squeak R???, Pharo R???, GST R???)
#   - Self (THIS R581) — prototype-based, dynamic compilation
#   - Io (R???) — prototype-based, message-passing, embeddable
#   - JavaScript (V8/Node R??? heavy corpus) — prototype-based
#                                                browser+server lang
#
# -----------------------------------------------------------------------------
#
# WHAT IS SELF AND WHY IS IT THE 78TH LANGUAGE?
#
# Self is a pure object-oriented programming language where:
#
#   1. NO CLASSES — EVERYTHING IS A PROTOTYPE — Self has NO
#      class-vs-instance distinction.  Every object is a
#      collection of NAMED SLOTS (data slots holding values +
#      method slots holding code).  To create "instances", you
#      CLONE an existing object — the clone copies the
#      prototype's slots and starts independent existence.
#      No inheritance hierarchy — only the `parent*` slot
#      pointing to another object that lookup falls back to:
#
#          point = (|
#              x <- 0.
#              y <- 0.
#              parent* = traits point.
#              distance = ( (x*x + y*y) sqrt ).
#          |)
#
#          p1: point copy.
#          p1 x: 3. p1 y: 4.
#          p1 distance.  "= 5"
#
#      Compare:
#         * Smalltalk: classes + instances (Self's ancestor)
#         * Java/C#: classes + instances
#         * JavaScript: prototypes (Self's descendant)
#         * Io: prototypes (Self-inspired)
#         * Lua: tables (prototype-like via metatables)
#         * Self: PURE PROTOTYPES — no classes anywhere in the
#                  language
#      FIRST documented language with pure prototype-only OOP
#      (no classes).
#
#   2. UNIFORM MESSAGE-PASSING SYNTAX — Every operation is a
#      MESSAGE sent to an object — `+`, `printNl`, `if:`, `do:`,
#      `at:Put:`, etc.  Numeric literals respond to `+ other`;
#      booleans respond to `ifTrue:False:`; the `if` "construct"
#      is a method on Boolean objects:
#
#          (x > 0) ifTrue: [ 'positive' printNl ]
#                  False: [ 'non-positive' printNl ].
#
#          1 to: 10 Do: [|:i| i printNl ].
#
#          arr at: 0 Put: 'hello'.
#
#      Even control flow is just messages.  Compare every other
#      documented OOP language — only Smalltalk has the same
#      uniformity, and Self's syntax is derived from Smalltalk-80
#      but cleaner (keyword messages with capitalized
#      continuation, multi-line literals).  FIRST documented
#      language descending from Smalltalk syntax with
#      keyword-message convention.
#
#   3. SLOT-LEVEL MUTATION — Every slot can be added, removed,
#      or modified at runtime.  An object with no `printNl` slot
#      can have one added mid-program:
#
#          point _AddSlots: (|
#              describe = ( 'I am at ' print. x print. ', ' print. y printNl )
#          |).
#
#      No notion of "schema" or "fixed structure" — objects are
#      mutable property bags.  Compare:
#         * Smalltalk: schema fixed at class-definition time
#         * Java/C#: schema fixed (no mid-program field add)
#         * JavaScript: mutable like Self (descended directly)
#         * Self: SLOT MUTATION as PRIMARY mechanism for objects
#                  to evolve over their lifetime
#
#   4. INDIRECT INHERITANCE VIA PARENT* SLOTS — Self objects
#      have zero or more SLOTS WITH `*` SUFFIX that designate
#      them as PARENT SLOTS.  When a message arrives and no
#      slot matches, Self looks in each parent slot's object,
#      following the chain.  An object can have MULTIPLE
#      PARENTS (multiple inheritance via multiple `parent*`
#      slots — sometimes ambiguous, resolved by source order).
#      Compare:
#         * Java/C#: SINGLE inheritance + interfaces
#         * C++: MULTIPLE inheritance via VIRTUAL bases
#         * JavaScript: SINGLE __proto__ chain
#         * Lua: __index metatable (typically single chain)
#         * Self: MULTIPLE PARENT* slots with order-resolved
#                  fallback
#
#   5. METHOD CUSTOMIZATION + INLINE CACHES + TYPE FEEDBACK —
#      Self's research papers (Ungar, Chambers, Hölzle 1989-1991)
#      defined ADAPTIVE OPTIMIZATION: the runtime profiles method
#      calls, identifies frequently-occurring receiver types,
#      compiles SPECIALIZED versions of methods for those types
#      (METHOD CUSTOMIZATION), and uses POLYMORPHIC INLINE CACHES
#      to dispatch them with single-instruction speed.  This
#      technology underpins:
#         * Sun HotSpot JVM (Java)
#         * Google V8 (JavaScript)
#         * Mozilla SpiderMonkey
#         * .NET CoreCLR adaptive JIT
#         * Strongtalk JIT (a Smalltalk + Self hybrid)
#      Compare every other documented language — Self is the
#      FIRST documented language whose VM design is the direct
#      ancestor of modern JIT compilers in widespread use.
#
#   6. MORPHIC UI + LIVE PROGRAMMING — Self's standard
#      environment is MORPHIC: a direct-manipulation graphical
#      interface where every visible thing on screen is a
#      MORPH (a Self object with rendering + interaction
#      protocol).  You can:
#         * Drag a method out of a class browser
#         * Drop it onto an object in the world
#         * Modify the method's code in place
#         * See the change take effect immediately on running
#           code
#      Squeak (Smalltalk-80 reimplementation) adopted Morphic
#      from Self.  Pharo (Squeak fork) inherited it.  Modern
#      Self continues to use Morphic for its primary UI.
#
# Use cases for Self:
#   * Programming-language research (Self is the standard
#     reference implementation for prototype-based OOP studies)
#   * Compiler / runtime research (Self's IR + JIT serves as
#     reference for adaptive-optimization research)
#   * Live-programming pedagogy (Morphic environment is unmatched
#     for teaching object orientation viscerally)
#   * Historical interest (running Self today preserves access
#     to the language whose VM defined modern dynamic-language
#     performance)
#
# -----------------------------------------------------------------------------
#
# THE Self CLI — POSIX getopt + getopt-on-character dispatch
#
# Self's argv parsing is in vm/src/any/runtime/shell.cpp.  It
# uses POSIX getopt directly:
#
#     int c;
#     while (
#         (c = OS::getopt(argc, (char* const*)copy_of_argv,
#                          "Ff:hl:prtcs:woa")) != (char)-1) {
#         switch (c) {
#         case 'F': discardSavedCode = true; break;
#         case 'f': startUpSelfFile = OS::optarg; break;
#         case 'h': /* print usage */ exit(0); break;
#         case 'l': spyLogFile = OS::optarg; break;
#         case 'p': skipPostRead = true; break;
#         case 'r': IntervalTimer::dont_use_real_timer = true; break;
#         case 't': IntervalTimer::dont_use_any_timer = true; break;
#         case 'c': IntervalTimer::use_real_instead_of_cpu_timer = !IntervalTimer::use_real_instead_of_cpu_timer; break;
#         case 's': startUpSnapshotFile = OS::optarg; break;
#         case 'w': suppressOptimizedCodeWarning = true; break;
#         case 'o': IntervalTimer::oversample_timers = true; break;
#         case 'a': testAssembler = true; break;
#         }
#     }
#
# Comment from shell.cpp notes that GNU's getopt rearranges argv,
# so Self passes a COPY of argv to getopt and keeps the original
# accessible via `prog_argv` for Self code to introspect.
#
# Available command-line options:
#   -F          Discard saved code from snapshot (debug)
#   -f filename Read Self source immediately after startup
#   -h          Print this help message and exit
#   -l logfile  Write spy log to logfile (debug)
#   -p          Don't do `snapshotAction postRead` after reading
#   -r          Disable real timer (debug; useful under gdb)
#   -t          Disable all timers (needed for tracing)
#   -c          Use real timer instead of CPU timer (OS X workaround)
#   -s snapshot Read initial world from snapshot file
#   -w          Suppress warnings about optimized code discarded
#   -o          Oversample timers (run 10x faster to flush bugs)
#   -a          Test the Assembler (added for Intel)
#
# Five-axis distinctness from every other documented argv parser:
#
#   1. SUN-MICROSYSTEMS-LABS PROVENANCE — Every other documented
#      argv parser was written in the 2000s+.  Self's getopt
#      usage has been essentially unchanged since the 1990s Sun
#      Microsystems Labs era (researchers Ungar + Smith + Hölzle
#      were focused on language design + JIT, not CLI design).
#      FIRST documented argv parser from the Sun Labs 1990s
#      pre-Web language-research era.
#
#   2. UPPERCASE BINARY NAME — Every other documented binary
#      uses lowercase.  Self's binary is `Self` (capital S) —
#      reflecting Smalltalk's tradition of capitalizing language
#      names + class names.  FIRST documented argv parser with
#      uppercase binary name.
#
#   3. ARGV INTROSPECTION VIA prog_argv — Self exposes a COPY of
#      the original argv via `prog_argv`/`prog_argc` globals so
#      Self programs can inspect their own command line from
#      within the language.  Necessary because POSIX getopt
#      mutates argv ordering (GNU getopt also rearranges).
#      FIRST documented argv parser exposing argv introspection
#      via a separate const reference.
#
#   4. SNAPSHOT-FILE CENTRAL TO INVOCATION — Self programs are
#      not source files — they are SNAPSHOTS of running Self
#      worlds saved to disk.  The `-s morphic.snap` flag is
#      essentially MANDATORY for normal use (otherwise Self
#      starts with an empty world).  Compare every other
#      documented language compiler/interpreter — none use
#      "execution snapshots" as the primary input format.
#      FIRST documented argv parser where the main argument
#      is a serialized VM state file.
#
#   5. RESEARCH-COMPILER CULTURAL ORIGIN — Every other documented
#      argv parser comes from a production-tool culture
#      (sysadmin, devops, web).  Self's CLI reflects RESEARCH
#      COMPILER culture: 13 single-character flags, half for
#      debugging the VM itself, no help generation, no
#      autocompletion, no man page in the binary.  FIRST
#      documented argv parser with explicit research-compiler
#      provenance.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/russellallen/self/blob/main/vm/src/any/runtime/shell.cpp
# usage() function + getopt() optstring `"Ff:hl:prtcs:woa"`.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[print help message and exit]' \
    '-f+[read Self source immediately after startup]:file:_files -g "*.self"' \
    '-s+[read initial world from snapshot file]:file:_files -g "*.snap"' \
    '-p[do not run `snapshotAction postRead` after reading snapshot]' \
    '-w[suppress warnings about optimized code being discarded]' \
    '-F[discard saved code from snapshot (debug)]' \
    '-l+[write spy log to logfile (debug)]:file:_files' \
    '-r[disable real timer (debug; useful under gdb)]' \
    '-t[disable all timers (needed for tracing)]' \
    '-c[use real timer instead of CPU timer (OS X workaround)]' \
    '-o[oversample timers (10x faster to flush bugs)]' \
    '-a[test the Assembler (added for Intel)]' \
    '*: :_files' \
    && ret=0

return ret
