}
(( $+functions[_steel__test_commands] )) ||
_steel__test_commands() {
    local commands; commands=()
    _describe -t commands 'steel test commands' commands "$@"
}

if [ "$funcstack[1]" = "_steel" ]; then
    _steel "$@"
else
    compdef _steel steel
fi
