#compdef steel
# Documentation: https://man.archlinux.org/search?q=steel
# Reference accessed: 2026-05-16
# Source: cargo binstall steel-interpreter@0.8.2
# Probed via: completions zsh
# Repository: https://github.com/mattwparas/steel

autoload -U is-at-least

_steel() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::default_file -- The existence of this argument indicates whether we want to run the repl, or interpret this file:_files' \
'::arguments -- Arguments to the input file:_default' \
":: :_steel_commands" \
"*::: :->steel" \
&& ret=0
    case $state in
    (steel)
        words=($line[3] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:steel-command-$line[3]:"
        case $line[3] in
            (bytecode)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::default_file:_files' \
&& ret=0
;;
(b)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::default_file:_files' \
&& ret=0
;;
(ast)
_arguments "${_arguments_options[@]}" : \
'--expanded=[]:EXPANDED:(true false)' \
'--pretty=[]:PRETTY:(true false)' \
'--require=[]:REQUIRE:(true false)' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::default_file:_files' \
&& ret=0
;;
(a)
_arguments "${_arguments_options[@]}" : \
'--expanded=[]:EXPANDED:(true false)' \
'--pretty=[]:PRETTY:(true false)' \
'--require=[]:REQUIRE:(true false)' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::default_file:_files' \
&& ret=0
;;
(interactive)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::default_file:_files' \
'*::arguments:_default' \
&& ret=0
;;
(r)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::default_file:_files' \
'*::arguments:_default' \
&& ret=0
;;
(test)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::default_file:_default' \
&& ret=0
;;
(t)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::default_file:_default' \
&& ret=0
;;
(doc)
_arguments "${_arguments_options[@]}" : \
'-i+[Specify the root path to search for Steel source file. (default\: current directory)]:INPUT_PATH:_files' \
'--input-path=[Specify the root path to search for Steel source file. (default\: current directory)]:INPUT_PATH:_files' \
'-o+[Specify the output path for generated documentation. (default\: docs)]:OUTPUT_PATH:_files -/' \
'--output-path=[Specify the output path for generated documentation. (default\: docs)]:OUTPUT_PATH:_files -/' \
'-t+[Specify the type of documentation to generate. (defaults\: html)]:OUTPUT_TYPE:(html markdown)' \
'--output-type=[Specify the type of documentation to generate. (defaults\: html)]:OUTPUT_TYPE:(html markdown)' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(d)
_arguments "${_arguments_options[@]}" : \
'-i+[Specify the root path to search for Steel source file. (default\: current directory)]:INPUT_PATH:_files' \
'--input-path=[Specify the root path to search for Steel source file. (default\: current directory)]:INPUT_PATH:_files' \
'-o+[Specify the output path for generated documentation. (default\: docs)]:OUTPUT_PATH:_files -/' \
'--output-path=[Specify the output path for generated documentation. (default\: docs)]:OUTPUT_PATH:_files -/' \
'-t+[Specify the type of documentation to generate. (defaults\: html)]:OUTPUT_TYPE:(html markdown)' \
'--output-type=[Specify the type of documentation to generate. (defaults\: html)]:OUTPUT_TYPE:(html markdown)' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(compile)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':file:_files' \
&& ret=0
;;
(c)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':file:_files' \
&& ret=0
;;
(dylib)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(dl)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_steel_commands] )) ||
_steel_commands() {
    local commands; commands=(
'bytecode:Output a debug display of the fully transformed bytecode' \
'b:Output a debug display of the fully transformed bytecode' \
'ast:Print a debug display of the fully expanded AST' \
'a:Print a debug display of the fully expanded AST' \
'interactive:Enter the repl with the given file loaded' \
'r:Enter the repl with the given file loaded' \
'test:Tests the module - only tests modules which provide values' \
't:Tests the module - only tests modules which provide values' \
'doc:Generate the documentation from source code' \
'd:Generate the documentation from source code' \
'compile:Compile. (Experimental)' \
'c:Compile. (Experimental)' \
'dylib:Build a dylib from the root of this directory' \
'dl:Build a dylib from the root of this directory' \
'completions:Generate Shell completions' \
    )
    _describe -t commands 'steel commands' commands "$@"
}
(( $+functions[_steel__ast_commands] )) ||
_steel__ast_commands() {
    local commands; commands=()
    _describe -t commands 'steel ast commands' commands "$@"
}
(( $+functions[_steel__bytecode_commands] )) ||
_steel__bytecode_commands() {
