#compdef pambayer
# Documentation: man pambayer (Netpbm)
# Source: Netpbm pambayer — interpret Bayer color-filter-array pattern as RGB image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-type=[Bayer pattern layout]:type:(1 2 3 4)' \
    '-nointerpolate[no interpolation (missing samples = 0)]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:input Bayer-pattern PAM/PNM:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
