#compdef korganizer
# Documentation: https://invent.kde.org/pim/korganizer/-/blob/master/src/korganizer_options.h
# Reference accessed: 2026-05-19
# Verified: korganizer_options.h QCommandLineOption definitions.

# Fixed #compdef: scoped to `korganizer` only (was wrongly applying
# korganizer flags to kontact/kmail/akregator/etc). Removed invented
# flags (--list, --module, --iconify, --display, --icon, --miniicon,
# --caption, --nofork, --style, --stylesheet, --graphicssystem,
# --qmljsdebugger, --qwindowtitle, --qwindowicon, --export, --print,
# --show, --view enum). Real options: -i/--import, -m/--merge,
# --view <url>, --feedback plus generic Qt/KDE flags.
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help about options]' \
  '--help-all[show all options]' \
  '--help-qt[show Qt specific options]' \
  '--help-kde[show KDE specific options]' \
  '(- *)'{-v,--version}'[show version information]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '(-i --import)'{-i,--import}'[import the specified files as separate calendars]' \
  '(-m --merge)'{-m,--merge}'[merge the specified files into an existing calendar]' \
  '--view=[show the incidence specified by the given URL]:url:' \
  '--feedback[list the available options for user feedback]' \
  '*:calendar file or URL:_files' && ret=0

return ret
