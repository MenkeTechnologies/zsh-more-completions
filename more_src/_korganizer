local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--help-all[all help options]' \
  '--help-qt[Qt help options]' \
  '--help-kde[KDE help options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--list[list available plugins/modules]' \
  '--module=[active module on start]:module:(kmail korganizer kaddressbook akregator knotes summaryview kontactsummary specialdates planner)' \
  '--iconify[start iconified]' \
  '--display=[X display]:display:' \
  '--icon=[icon name]:icon:' \
  '--miniicon=[mini icon]:icon:' \
  '--caption=[window title]:title:' \
  '--nofork[do not fork]' \
  '--style=[Qt style]:style:' \
  '--stylesheet=[stylesheet path]:file:_files' \
  '--graphicssystem=[graphics system]:gs:(raster opengl native)' \
  '--qmljsdebugger=[QML debugger ports]:val:' \
  '--qwindowtitle=[window title]:title:' \
  '--qwindowicon=[window icon]:icon:' \
  '--export[export calendar to file]' \
  '--print[print active view]' \
  '--show=[item URL to show]:url:' \
  '--view=[default view]:view:(WhatsNext List Day Week WorkWeek Month Journal Todo)' \
  '*:URL or file:_files' && ret=0

return ret
