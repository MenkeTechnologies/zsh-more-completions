#compdef bibletime
# Documentation: https://man.archlinux.org/search?q=bibletime
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--ignore-session[start fresh session]' \
  '--open-default-bible=+[open passage]:ref:' \
  '--debug[debug output]' && ret=0

return ret
