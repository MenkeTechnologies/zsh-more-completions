#compdef bibletime
# Documentation: https://bibletime.info/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--ignore-session[start fresh session]' \
  '--open-default-bible=+[open passage]:ref:' \
  '--debug[debug output]' && ret=0

return ret
