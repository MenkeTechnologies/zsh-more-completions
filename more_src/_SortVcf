#compdef SortVcf
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/vcf/SortVcf.java
# Picard: sort one or more VCF files into coordinate order

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-I,--INPUT}'=[input VCF(s) to sort]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[sorted output VCF]:file:_files' \
  '(-D --SEQUENCE_DICTIONARY)'{-D,--SEQUENCE_DICTIONARY}'=[external sequence dictionary]:file:_files' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--MAX_RECORDS_IN_RAM=[records kept in RAM before spilling]:n:' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
