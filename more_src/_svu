#compdef svu

# Zsh completion for svu - semantic version utility

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'current:print current version'
      'next:print next version'
      'major:print next major version'
      'minor:print next minor version'
      'patch:print next patch version'
      'prerelease:print next prerelease version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    _arguments \
      '(-h --help)'{-h,--help}'[show help]' \
      '--pattern[tag glob pattern]:pattern:' \
      '--prefix[version prefix]:prefix:' \
      '--strip-prefix[strip prefix from output]' \
      '--tag-mode[tag mode]:mode:(current-branch all-branches)' \
      '--pre-release[prerelease identifier]:identifier:' \
      '--build[build metadata]:metadata:' \
      '--metadata[alias for --build]:metadata:' \
      '--no-metadata[strip metadata from output]' \
      '--no-pre-release[strip prerelease from output]' \
      '--force-patch-increment[always increment patch]' \
      '--directory[git directory]:dir:_directories' \
      && ret=0
    ;;
esac

return ret
