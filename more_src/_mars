#compdef mars
# Documentation: https://dpetersanderson.github.io/Help/MarsHelpCommand.html
# MARS MIPS Assembler and Runtime Simulator (command-line mode)

local ret=1

_arguments -s -S \
  'a[assemble only, do not simulate]' \
  'ascii[display memory or register contents as ASCII codes]' \
  'b[brief - do not display register/memory address with contents]' \
  'd[display MARS debugging statements]' \
  'db[MIPS delayed branching is enabled]' \
  'dec[display memory or register contents in decimal]' \
  'dump[dump memory contents to file (segment format file)]' \
  'h[display help (use by itself with no filename)]' \
  'hex[display memory or register contents in hexadecimal (default)]' \
  'ic[display instruction count of basic instructions executed]' \
  'mc[set memory configuration]:config' \
  'me[display MARS messages to standard err instead of standard out]' \
  'nc[copyright notice will not be displayed]' \
  'np[pseudo-instructions and extended formats are not permitted]' \
  'p[project option - assemble specified file and all others in directory]' \
  'sm[start execution at statement having global label main if defined]' \
  'smc[self modifying code - program can write and execute in text or data]' \
  'we[assembler warnings will be considered errors]' \
  '*:file:_files' && ret=0

return ret
