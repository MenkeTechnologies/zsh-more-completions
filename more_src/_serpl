#compdef serpl

# Zsh completion for serpl - terminal UI for search and replace

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --dir)'{-d,--dir}'[directory to search in]:directory:_files -/' \
  '--hidden[search hidden files]' \
  '(-g --glob)'{-g,--glob}'[glob pattern to filter files]:pattern:' \
  '--regex[use regex for search pattern]' \
  '--case-sensitive[case-sensitive search]' \
  '--gitignore[respect .gitignore]' \
  '--no-gitignore[do not respect .gitignore]' \
  '1:search pattern:' \
  '2:replacement:' && return 0
