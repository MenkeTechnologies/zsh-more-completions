#compdef serpl
# Documentation: https://github.com/yassinebridi/serpl
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: fabricated -d/--dir, --hidden, -g/--glob,
# --regex, --case-sensitive, --gitignore, --no-gitignore, search/replace
# positional args. Real serpl is a TUI; only --project-root and
# --version are documented flags.

# serpl: terminal UI for search and replace
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version and config path]' \
  '--project-root=[project root path]:dir:_files -/' && return 0
