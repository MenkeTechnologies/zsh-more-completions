#compdef bundlewatch
# Documentation: https://bundlewatch.io/reference/cli
# bundlewatch - keep watch of your bundle size

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[file to read configuration from (overrides other options)]:config:_files' \
  '--max-size=[maximum size threshold (e.g. 3kb)]:size' \
  '--compression=[compression algorithm to use]:compression:(none gzip brotli)' \
  '--normalize=[regex to standardize filenames; matching portions excluded]:regex' \
  '*:file glob:_files' && ret=0

return ret
