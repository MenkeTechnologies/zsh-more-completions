#compdef sniffles
# Documentation: https://github.com/fritzsedlazeck/Sniffles
# sniffles - structural variation caller using long reads

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--expert-help[show expert help options]' \
  '(-i --input)'{-i,--input}'[input BAM/CRAM or .snf file(s)]:input:_files' \
  '(-v --vcf)'{-v,--vcf}'[output VCF file]:vcf:_files' \
  '--snf[output .snf file for multi-sample calling]:snf:_files' \
  '--reference[reference fasta (enables DEL sequences)]:fasta:_files' \
  '--tandem-repeats[bed of tandem repeat annotations]:bed:_files' \
  '--phase[enable phasing of SVs]' \
  '(-t --threads)'{-t,--threads}'[number of threads]:n' \
  '(-c --contig)'{-c,--contig}'[only process this contig]:contig' \
  '--regions[bed of regions to process]:bed:_files' \
  '--region[only process this region]:region' \
  '--tmp-dir[temporary directory]:dir:_files -/' \
  '--all-contigs[process all contigs]' \
  '--minsupport[min supporting reads for an SV]:n' \
  '--minsupport-auto-mult[multiplier for auto min support]:mult' \
  '--minsvlen[min SV length]:len' \
  '--minsvlen-screen-ratio[min SV length screening ratio]:ratio' \
  '--mapq[min mapping quality]:mapq' \
  '--no-qc[disable QC filtering]' \
  '--qc-output-all[output all SVs regardless of QC]' \
  '--pass-only[only output PASS SVs]' \
  '--min-alignment-length[min alignment length]:len' \
  '--max-splits-kb[max splits per kb]:n' \
  '--max-splits-base[max splits base]:n' \
  '(-F --exclude-flags --excl-flags)'{-F,--exclude-flags,--excl-flags}'[exclude reads with these SAM flags]:flags' \
  '--cluster-binsize[cluster bin size]:n' \
  '--cluster-merge-pos[max distance to merge cluster positions]:n' \
  '--genotype-ploidy[ploidy for genotyping]:n' \
  '--genotype-vcf[genotype SVs from this VCF]:vcf:_files' \
  '--sample-id[sample id for output]:id' \
  '--mosaic[enable mosaic SV detection]' \
  '--mosaic-af-max[max allele frequency for mosaic]:af' \
  '--mosaic-af-min[min allele frequency for mosaic]:af' \
  '--mosaic-include-germline[include germline in mosaic mode]' \
  '--output-rnames[output supporting read names]' \
  '--no-consensus[disable consensus sequence generation]' \
  '--no-sort[do not sort output VCF]' \
  '--no-progress[disable progress display]' \
  '--quiet[disable logging to stderr]' \
  '--symbolic[output symbolic SV alleles]' \
  '--allow-overwrite[allow overwriting output files]' \
  '--low-memory[reduce memory usage]' \
  '--combine-high-confidence[high confidence threshold for combining]:val' \
  '--combine-low-confidence[low confidence threshold for combining]:val' \
  '--combine-output-filtered[output filtered SVs when combining]' && ret=0

return ret
