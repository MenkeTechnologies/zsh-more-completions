#compdef flux-proxy
# Documentation: https://flux-framework.readthedocs.io/projects/flux-core/en/latest/man1/flux-proxy.html
# create proxy environment for Flux instance

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --force)'{-f,--force}'[allow connecting to different Flux version]' \
  '(-n --nohup)'{-n,--nohup}'[do not send SIGHUP/SIGCONT on connection error]' \
  '--reconnect[reconnect every 2 seconds on failure]' \
  '1:target:_default' \
  '*::command:_command_names -e' && ret=0

return ret
