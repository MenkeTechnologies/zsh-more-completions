#compdef condor_job_router_info
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_job_router_info.html
# display information about job routing

local ret=1

_arguments -s -S \
  '-help[display usage information and exit]' \
  '-version[display HTCondor version information and exit]' \
  '-config[display configured routes]' \
  '-match-jobs[for each job, display the first route found]' \
  '-route-jobs[apply the first route found and print routed jobs to file]:filename:_files' \
  '-log-steps[print each transform step as job transforms are applied]' \
  '-ignore-prior-routing[remove existing routing attributes and set jobs idle first]' \
  '-jobads[read job ClassAds from the given file]:filename:_files' && ret=0

return ret
