#compdef easyocr
# Documentation: https://github.com/JaidedAI/EasyOCR/blob/master/easyocr/cli.py
# Ready-to-use OCR with 80+ supported languages

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --lang)'{-l,--lang}'+[languages for OCR, e.g. en ch_sim]:lang' \
  '(-f --file)'{-f,--file}'=[input image file]:file:_files' \
  '--gpu=[use GPU]:gpu:(True False)' \
  '--model_storage_directory=[directory for model .pth file]:dir:_files -/' \
  '--user_network_directory=[directory for custom network files]:dir:_files -/' \
  '--recog_network=[recognition network]:network' \
  '--download_enabled=[enable download]:dl:(True False)' \
  '--detector=[initialize text detector module]:detector:(True False)' \
  '--recognizer=[initialize text recognizer module]:recognizer:(True False)' \
  '--verbose=[print detail/warning]:verbose:(True False)' \
  '--quantize=[use dynamic quantization]:quantize:(True False)' \
  '--decoder=[decoder algorithm]:decoder:(greedy beamsearch wordbeamsearch)' \
  '--beamWidth=[size of beam search]:width' \
  '--batch_size=[batch size]:size' \
  '--workers=[number of processing cpu cores]:workers' \
  '--allowlist=[recognize only subset of characters]:chars' \
  '--blocklist=[block subset of characters]:chars' \
  '--detail=[output detail level]:detail:(0 1)' \
  '--paragraph=[combine result into paragraph]:para:(True False)' \
  '--min_size=[filter text box smaller than minimum in pixels]:size' \
  '--contrast_ths=[contrast threshold]:value' \
  '--adjust_contrast=[target contrast level for low contrast box]:value' \
  '--text_threshold=[text confidence threshold]:value' \
  '--low_text=[text low-bound score]:value' \
  '--link_threshold=[link confidence threshold]:value' \
  '--canvas_size=[maximum image size]:size' \
  '--mag_ratio=[image magnification ratio]:value' \
  '--output_format=[output format]:format:(standard dict json)' && ret=0

return ret
