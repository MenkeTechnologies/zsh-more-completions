#compdef fdbrestore

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start a restore'
  'abort:abort a running restore'
  'wait:wait for a restore to finish'
  'status:show restore status'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-t=[restore tag]:tag:' \
  '--blob-credentials=[blob credentials file]:file:_files' \
  '--dest-cluster-file=[destination cluster file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'fdbrestore subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '-r=[backup URL]:url:' \
          '-w[wait for restore to finish]' \
          '-k=[key ranges]:keys:' \
          '--remove-prefix=[prefix to remove]:prefix:' \
          '--add-prefix=[prefix to add]:prefix:' \
          '-n[dry run]' \
          '-v=[restore to version]:version:' \
          '--timestamp=[restore to timestamp]:datetime:' \
          '--orig-cluster-file=[original cluster file]:file:_files' \
          '--inconsistent-snapshot-only[restore from inconsistent snapshot]' \
          '--user-data[restore user data only]' \
          '--system-metadata[restore system metadata only]' && ret=0
        ;;
    esac
    ;;
esac

return ret
