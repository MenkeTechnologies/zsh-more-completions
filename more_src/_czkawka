#compdef czkawka_cli

_czkawka_subcommands() {
  local -a subcmds=(
    'dup:Find duplicate files'
    'empty-dirs:Find empty directories'
    'big:Find biggest files'
    'empty-files:Find empty files'
    'temp:Find temporary files'
    'image:Find similar images'
    'music:Find similar music'
    'symlinks:Find invalid symlinks'
    'broken:Find broken files'
    'video:Find similar videos'
    'bad-extensions:Find files with bad extensions'
    'tester:Internal testing tool'
  )
  _describe -t commands 'czkawka subcommand' subcmds
}

_czkawka_cli() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-V,--version}'[Show version]' \
    '1:subcommand:_czkawka_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        dup)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            {-d,--directories}'[Directories to scan]:dir:_directories' \
            {-e,--excluded-directories}'[Directories to exclude]:dir:_directories' \
            {-E,--excluded-items}'[Excluded item patterns]:pattern:' \
            '--minimal-file-size[Minimum file size]:size:' \
            '--maximal-file-size[Maximum file size]:size:' \
            '--search-method[Search method]:method:(name size hash)' \
            '--hash-type[Hash type]:type:(blake3 crc32 xxh3)' \
            '--delete-method[Delete method]:method:(aen aeo aon aoo none)' \
            '--file-to-save[File to save results]:file:_files' \
            '--not-recursive[Do not search recursively]' \
            '--allow-hard-links[Allow hard links]' \
            '--case-sensitive-name-comparison[Case-sensitive name comparison]' \
            {-f,--file-to-save}'[File to save results]:file:_files'
          ;;
        image)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            {-d,--directories}'[Directories to scan]:dir:_directories' \
            {-e,--excluded-directories}'[Directories to exclude]:dir:_directories' \
            {-E,--excluded-items}'[Excluded item patterns]:pattern:' \
            '--minimal-file-size[Minimum file size]:size:' \
            '--maximal-file-size[Maximum file size]:size:' \
            '--similarity[Similarity preset]:preset:(minimal very_high high medium small very_small minimal)' \
            '--hash-alg[Hash algorithm]:alg:(gradient blockhash mean)' \
            '--hash-size[Hash size]:size:(8 16 32 64)' \
            '--image-filter[Image filter]:filter:(lanczos3 nearest triangle catmullrom gaussian)' \
            '--delete-method[Delete method]:method:(aen aeo aon aoo none)' \
            {-f,--file-to-save}'[File to save results]:file:_files' \
            '--not-recursive[Do not search recursively]'
          ;;
        big)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            {-d,--directories}'[Directories to scan]:dir:_directories' \
            {-e,--excluded-directories}'[Directories to exclude]:dir:_directories' \
            {-E,--excluded-items}'[Excluded item patterns]:pattern:' \
            '--number-of-files[Number of files to show]:count:' \
            '--delete-files[Delete found files]' \
            {-f,--file-to-save}'[File to save results]:file:_files' \
            '--not-recursive[Do not search recursively]'
          ;;
        empty-dirs|empty-files|temp|symlinks|broken|bad-extensions)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            {-d,--directories}'[Directories to scan]:dir:_directories' \
            {-e,--excluded-directories}'[Directories to exclude]:dir:_directories' \
            {-E,--excluded-items}'[Excluded item patterns]:pattern:' \
            '--delete-files[Delete found items]' \
            {-f,--file-to-save}'[File to save results]:file:_files' \
            '--not-recursive[Do not search recursively]'
          ;;
      esac
      ;;
  esac
}

_czkawka_cli "$@"
