#compdef funtable
# Documentation: https://github.com/ericmandel/funtools/blob/master/man/man1/funtable.1
# Copy selected rows from a Funtools file to a FITS binary table

local ret=1

_arguments -s -S \
  '-a[append output table to existing FITS file]' \
  '-i[image data: generate only X and Y columns]' \
  '-z[image data: include zero-value pixels]' \
  '-m[tables: write a separate file per filter region]' \
  '-s+[sort output rows by columns]:cols' \
  '*:file:_files' && ret=0

return ret
