#compdef gh-fzf
# Documentation: https://man.archlinux.org/search?q=gh-fzf
# Reference accessed: 2026-05-16

_gh-fzf() {
    local -a commands
    commands=(
        'issue:Fuzzy find issues'
        'pr:Fuzzy find pull requests'
        'repo:Fuzzy find repositories'
    )
    _arguments \
        '1: :->command' \
        '*: :_files'
}

_gh-fzf "$@"
