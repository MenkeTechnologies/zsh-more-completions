#compdef pdb_tidy
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Modifies the file to adhere to the PDB format specifications

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-strict[do not add TER/END records, only fix existing records]' \
  '-h36[use hybrid36 numbering for large serials]' \
  '*:PDB file:_files' && ret=0

return ret
