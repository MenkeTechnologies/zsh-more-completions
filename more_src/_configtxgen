#compdef configtxgen configtxlator cryptogen
# Documentation: upstream Hyperledger Fabric docs at hyperledger-fabric.readthedocs.io/en/latest/commands/{configtxgen,configtxlator,cryptogen}.html
# Reference accessed: 2026-05-30
# Hyperledger Fabric multi-binary harvest R44 — channel-config + crypto
# material generation utilities from fabric/cmd/.

local curcontext="$curcontext" state line ret=1

case $service in

  configtxgen)
    # hyperledger/fabric configtxgen — channel config + genesis block generator.
    _arguments -s -S \
      '-asOrg=[org-scoped generation]:org:' \
      '-channelCreateTxBaseProfile=[orderer-system-channel base profile (DEPRECATED)]:profile:' \
      '-channelID=[channel identifier]:channel:' \
      '-configPath=[directory containing configuration files]:directory:_directories' \
      '-inspectBlock=[display configuration from a block file]:file:_files' \
      '-inspectChannelCreateTx=[display configuration from a channel-create tx (DEPRECATED)]:file:_files' \
      '-outputBlock=[output genesis block file]:file:_files' \
      '-outputCreateChannelTx=[output channel-create tx (DEPRECATED)]:file:_files' \
      '-printOrg=[print org definition as JSON]:org:' \
      '-profile=[profile from configtx.yaml to generate]:profile:' \
      '-version[show version]' \
      && ret=0
    ;;

  configtxlator)
    # hyperledger/fabric configtxlator — protobuf/JSON config translator + REST server.
    local -a _subcmds
    _subcmds=(
      'start:launch the REST server'
      'proto_encode:convert JSON to protobuf'
      'proto_decode:convert protobuf to JSON'
      'compute_update:compute configuration update between two states'
      'version:show version'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'configtxlator subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          start)
            _arguments \
              '--hostname=[hostname (default 0.0.0.0)]:host:' \
              '--port=[port (default 7059)]:port:' \
              '*--CORS=[CORS-allowed domain]:domain:' \
              '--help[show help]' && ret=0
            ;;
          proto_encode|proto_decode)
            _arguments \
              '--type=[message type (required, e.g. common.Config)]:type:' \
              '--input=[input file (default /dev/stdin)]:file:_files' \
              '--output=[output file (default /dev/stdout)]:file:_files' \
              '--help[show help]' && ret=0
            ;;
          compute_update)
            _arguments \
              '--original=[original config message file]:file:_files' \
              '--updated=[updated config message file]:file:_files' \
              '--channel_id=[channel name (required)]:channel:' \
              '--output=[output file (default /dev/stdout)]:file:_files' \
              '--help[show help]' && ret=0
            ;;
          version)
            _arguments '--help[show help]' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  cryptogen)
    # hyperledger/fabric cryptogen — crypto material generator for test networks.
    local -a _subcmds
    _subcmds=(
      'help:context-sensitive help'
      'generate:create key material from template'
      'showtemplate:display the default configuration template'
      'extend:expand an existing network with new organizations'
      'version:show version'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'cryptogen subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          generate)
            _arguments \
              '--output=[output directory (default crypto-config)]:directory:_directories' \
              '--config=[configuration template file]:file:_files' \
              '--help[show help]' && ret=0
            ;;
          extend)
            _arguments \
              '--input=[input directory (default crypto-config)]:directory:_directories' \
              '--config=[configuration template file]:file:_files' \
              '--help[show help]' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
