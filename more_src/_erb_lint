#compdef erb_lint erblint
# Documentation: https://github.com/Shopify/erb_lint
# ERB Lint linter for Rails ERB templates

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show this message]' \
  '--version[show version]' \
  '--config=[config file]:file:_files' \
  '(-f --format)'{-f,--format}'=[output format]:format:(compact multiline json junit gitlab)' \
  '--lint-all[lint all files matching configured glob]' \
  '--enable-all-linters[enable all known linters]' \
  '--enable-linters=[enable specific linters]:linters' \
  '--cache[enable caching]' \
  '--cache-dir=[set the cache directory]:dir:_files -/' \
  '--clear-cache[clear cache]' \
  '--fail-level=[minimum severity for exit with error code]:severity' \
  '(-a --autocorrect)'{-a,--autocorrect}'[correct offenses automatically if possible]' \
  '--show-linter-names[show linter names]' \
  '--allow-no-files[exit successfully when no matching files found]' \
  '--disable-inline-configs[report all offenses ignoring inline disable comments]' \
  '(-s --stdin)'{-s,--stdin}'=[read file from stdin with given path]:file:_files' \
  '*:file:_files' && ret=0

return ret
