#compdef toshi
# =============================================================================
# toshi — toshi-search/Toshi's pure-Rust FULL-
#   TEXT SEARCH ENGINE — an Elasticsearch /
#   Solr-style HTTP-API-driven search daemon
#   built directly on top of the canonical
#   Rust full-text search library `tantivy`.
#   Exposes a JSON-over-HTTP API at `:8080`
#   with index lifecycle (create / delete /
#   describe), bulk + per-doc indexing,
#   structured query DSL, and built-in
#   Raft-based clustering (gated behind the
#   experimental flag).  Built on direct
#   `tantivy ^0.19` (quickwit-oss/tantivy) +
#   hyper 0.14 + tokio + structopt + slog.
#   Rust=105 leader bump opening Axis 50 —
#   THE HALF-CENTURY AXIS LANDMARK.
#
# AXIS 50 — FULL-TEXT SEARCH ENGINE — OPENS @ R789
# ================================================
# Establishes the 50th three-language axis in
# the corpus — a major landmark.  This axis
# covers CLI tools written in language X that
# ship a DIRECT library binding to a full-text
# inverted-index search engine.  Canonical
# implementations per language:
#   * Rust       : tantivy (this entry)
#                  — quickwit-oss/tantivy.
#                    Lucene-inspired in pure
#                    Rust: posting lists,
#                    skip lists, BM25 +
#                    TF-IDF scoring, faceted
#                    search, fast field
#                    column-store, segment
#                    merging.  ~12k stars
#                    on GitHub
#                  — version ^0.19 used here
#                  — direct dep at
#                    `toshi-search/Toshi`
#                    toshi-server/Cargo.toml
#                    line: `tantivy = "^0.19"`
#   * Go         : blevesearch/bleve — pure-Go
#                  full-text search.  Similar
#                  Lucene-inspired data model
#                  but pure Go, no FFI.  R790
#                  will close the Go side
#   * TS-Node    : elasticlunr / lunr /
#                  orama — JS-native search
#                  indexes that run in Node or
#                  browser.  R791 will close
#                  the TS-Node side
#
# Tantivy distinguishes from other Rust search
# crates:
#   - meilisearch (binary `meilisearch`,
#     already in corpus): a HIGHER-LEVEL
#     search engine built ON TOP of milli +
#     LMDB.  Different abstraction layer
#     (HTTP API + JS SDK + admin UI), not
#     a search-library replacement
#   - sonic (binary `sonic` family): a
#     lightweight schemaless search engine
#     in Rust + RocksDB.  Not Lucene-style.
#     Different scoring model
#   - quickwit (sibling project from
#     tantivy maintainers): a distributed
#     log search engine optimised for
#     append-only object-storage indexes.
#     Different operational shape
#   - tantivy is the LIBRARY; toshi is a
#     thin HTTP wrapper around it (similar
#     to how Elasticsearch is a thin HTTP
#     wrapper around Lucene)
#
# Distinguishing Toshi from other corpus
# tantivy users (TabbyML/tabby, devflowinc/
# trieve, paradedb/paradedb, chroma-core/
# chroma, zu1k/book-searcher):
#   - PURE FULL-TEXT SEARCH FOCUS — Toshi is
#     an Elasticsearch-shaped HTTP API around
#     tantivy with no AI / RAG / vector-search
#     extensions.  paradedb wraps tantivy as
#     a Postgres extension; chroma is vector-
#     search-first; tabby is an AI coding
#     assistant; trieve is a multi-modal
#     search-as-a-service platform.  Toshi
#     is the cleanest "tantivy in a box" CLI
#   - SCHEMA-DRIVEN — every index has a
#     declared schema (field names + types
#     + indexing/storage flags).  No
#     dynamic schema discovery.  Mirrors
#     Solr / Elasticsearch's "indices have
#     mappings" model
#   - SEGMENT MERGE POLICY CONFIGURABLE —
#     three flat CLI flags pick the merge
#     policy: `--kind` (log|nomerge),
#     `--min-merge-size`, `--min-layer-size`,
#     `--level-log-size`.  Direct passthrough
#     to tantivy's `LogMergePolicy`
#   - WRITER MEMORY KNOB — `-w/--writer-
#     memory <BYTES>` controls how much
#     RAM each per-index writer pre-allocates
#     for buffer.  tantivy's writer is
#     latency-vs-throughput-tuned by this
#     setting.  Default 200 MiB
#   - AUTO-COMMIT POLLER — `-a/--auto-
#     commit-duration <SECONDS>` controls
#     how often pending writes are flushed
#     to disk (with a writer.commit()).
#     Lower = lower max-doc-age, higher =
#     higher throughput
#   - BULK INDEXING TUNED — `-b/--bulk-
#     buffer-size <DOCS>` and `-m/--max-
#     line-length <BYTES>` bound the
#     per-request batch size for the bulk
#     /index/<name>/_bulk endpoint
#   - EXPERIMENTAL RAFT CLUSTERING — `-e/
#     --experimental` enables a Raft-
#     replicated cluster mode with `--leader`,
#     `--nodes <ADDR...>`, `--id <ID>`,
#     `--rpc-port`.  Uses tikv/raft-rs
#     under the hood.  Not on by default
#     because the consensus path is still
#     considered alpha-quality
#   - JSON PARSING THREAD POOL — `-j/--
#     json-parsing-threads <N>` tunes
#     the rayon-shared pool for parsing
#     incoming JSON bodies during bulk
#     indexing.  Default 4
#   - SLOG STRUCTURED LOGGING — logs go
#     through slog (not env_logger / tracing).
#     `-l/--log-level <LEVEL>` is the global
#     filter (trace / debug / info / warn /
#     error).  Logger config separately
#     loaded from `config/logging.toml`
#   - HTTP-FIRST — no gRPC API.  All
#     interactions are JSON-over-HTTP at
#     `<host>:<port>`.  Endpoints follow the
#     Elasticsearch shape:
#       PUT  /<idx>           create index
#       DEL  /<idx>           delete index
#       POST /<idx>/_create   add document
#       POST /<idx>/_bulk     bulk index
#       POST /<idx>/_search   search
#       GET  /<idx>/_summary  index info
#       GET  /                catalog list
#
# CONFIG FILE LOADING:
#   * `-c/--config <PATH>` (default
#     `config/config.toml`) is parsed by
#     the `config` crate as TOML.
#     CLI flags OVERRIDE config file
#     values
#   * Logging is separately loaded from
#     `config/logging.toml` (hardcoded
#     path, not overridable via CLI yet)
#
# CRITICAL DIRECT DEPENDENCIES (from
# toshi-server/Cargo.toml):
#   - tantivy ^0.19           — full-text
#                                search library
#                                [AXIS 50 LIBRARY]
#   - hyper 0.14 (full)       — HTTP/1.1 +
#                                HTTP/2 server
#   - tokio 1.x (full)        — async runtime
#   - structopt 0.3           — CLI parser
#                                (clap 2.x
#                                derived)
#   - clap 4 (color)          — CLI surface
#                                (alongside
#                                structopt)
#   - config 0.13             — TOML config
#                                loader
#   - slog 2.7 + slog-stdlog 4
#                              — structured
#                                logging
#   - serde 1.0 (derive) +    — JSON
#     serde_json 1.0 +          serialisation
#     serde_urlencoded
#   - bytes 1.x + http 0.2    — HTTP types
#   - dashmap 5               — concurrent
#                                hash map for
#                                the index
#                                catalog
#   - tower-util 0.3          — HTTP-service
#                                middleware
#   - cang-jie (optional      — Chinese
#     `extra_tokenizers`)       segmentation
#                                tokenizer for
#                                CJK text
#   - thiserror 1.0 + anyhow 1.0
#                              — error types
#   - async-trait 0.1          — async trait
#                                methods
#
# Rust 2021 edition.  Builds with stable
# Rust.  Single Cargo workspace under
# `toshi-server/` + `toshi-client/` +
# `toshi-types/` + (experimental)
# `toshi-raft/` + `toshi-proto/`.
#
# UPSTREAM:
#   * Source             : https://github.com/toshi-search/Toshi
#   * tantivy            : https://github.com/quickwit-oss/tantivy
#   * Tantivy docs       : https://docs.rs/tantivy
#   * License            : MIT
#   * Maintainer         : Stephen Carman <shcarman@gmail.com>
#
# INSTALL:
#   # From source
#   git clone https://github.com/toshi-search/Toshi
#   cd Toshi
#   cargo build --release
#   ./target/release/toshi
#
#   # Or directly
#   cargo install --git https://github.com/toshi-search/Toshi --bin toshi
#
#   # With CJK tokenizers
#   cargo install --git https://github.com/toshi-search/Toshi \
#       --bin toshi --features extra_tokenizers
#
# USAGE EXAMPLES:
#
#   # Run with defaults (config/config.toml,
#   # bind 127.0.0.1:8080, data/ data dir)
#   toshi
#
#   # Run with a custom config file
#   toshi -c /etc/toshi/prod.toml
#   toshi --config /etc/toshi/prod.toml
#
#   # Override individual settings on the CLI
#   toshi --host 0.0.0.0 --port 9200 \
#         --path /var/lib/toshi/data
#
#   # Crank writer memory for high-throughput
#   # bulk indexing
#   toshi -w 1073741824   # 1 GiB
#
#   # Tune the JSON parser thread pool
#   toshi -j 16
#
#   # Verbose logging
#   toshi -l debug
#   toshi --log-level trace
#
#   # Faster auto-commit (lower max-doc-age)
#   toshi -a 1.0
#
#   # Higher bulk batch sizes
#   toshi -b 100000 -m 65536
#
#   # Tune segment merge policy
#   toshi --kind log \
#         --min-merge-size 8 \
#         --min-layer-size 10000 \
#         --level-log-size 0.75
#
#   # Disable segment merging (write-heavy
#   # short-lived workloads)
#   toshi --kind nomerge
#
#   # Enable experimental Raft clustering
#   toshi --experimental \
#         --leader \
#         --nodes "127.0.0.1:8082" \
#         --nodes "127.0.0.1:8083" \
#         --id 1 \
#         --rpc-port 8081
#
#   # Help + version (structopt defaults)
#   toshi --version
#
# CLIENT-SIDE HTTP API EXAMPLES (curl):
#
#   # Create an index named "books" with a
#   # schema
#   curl -X PUT http://localhost:8080/books \
#       -H 'Content-Type: application/json' \
#       -d '{"name":"books","schema":[
#             {"name":"title","type":"text",
#              "options":{"indexing":{
#                "record":"position",
#                "tokenizer":"en_stem"},
#                "stored":true}},
#             {"name":"author","type":"text",
#              "options":{"indexing":{
#                "record":"basic",
#                "tokenizer":"raw"},
#                "stored":true}}
#           ]}'
#
#   # Add a document
#   curl -X POST http://localhost:8080/books/_create \
#       -H 'Content-Type: application/json' \
#       -d '{"document":{
#             "title":"The Rust Book",
#             "author":"Klabnik & Nichols"
#           }}'
#
#   # Search
#   curl -X POST http://localhost:8080/books/_search \
#       -H 'Content-Type: application/json' \
#       -d '{"query":{"term":{
#             "title":"rust"
#           }}}'
#
#   # Index summary
#   curl http://localhost:8080/books/_summary
#
# OPTIONS (sourced directly from
# https://github.com/toshi-search/Toshi/blob/master/toshi-server/src/settings.rs Settings struct):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _toshi_log_levels
_toshi_log_levels=(
    'trace:Most verbose'
    'debug:Debug-level events'
    'info:Default; informational messages'
    'warn:Warnings only'
    'error:Errors only'
)

local -a _toshi_merge_kinds
_toshi_merge_kinds=(
    'log:Logarithmic level-based segment merge policy (default)'
    'nomerge:Disable segment merging entirely'
)

_arguments -C \
    '(- *)--help[show help]' \
    '(- *)-V[show version]' \
    '(- *)--version[show version]' \
    '(-c --config)'{-c+,--config=}'[config file path (default config/config.toml)]:file:_files -g "*.(toml|TOML)"' \
    '(-h --host)'{-h+,--host=}'[bind host (default 127.0.0.1)]:host: ' \
    '(-p --port)'{-p+,--port=}'[bind port (default 8080)]:port: ' \
    '(-P --path)'{-P+,--path=}'[index data directory (default data/)]:dir:_files -/' \
    '(-l --log-level)'{-l+,--log-level=}'[slog filter level (default info)]:level:->level' \
    '(-w --writer-memory)'{-w+,--writer-memory=}'[per-index writer memory budget in bytes (default 200000000)]:bytes: ' \
    '(-j --json-parsing-threads)'{-j+,--json-parsing-threads=}'[rayon pool size for JSON bulk parsing (default 4)]:n: ' \
    '(-a --auto-commit-duration)'{-a+,--auto-commit-duration=}'[seconds between auto commits (default 5)]:seconds: ' \
    '(-b --bulk-buffer-size)'{-b+,--bulk-buffer-size=}'[bulk batch size in documents (default 10000)]:docs: ' \
    '(-m --max-line-length)'{-m+,--max-line-length=}'[max bytes per bulk line (default 10000)]:bytes: ' \
    '--kind=[segment merge policy kind (default log)]:kind:->mergekind' \
    '--min-merge-size=[minimum segment count to trigger merge]:n: ' \
    '--min-layer-size=[minimum docs-per-segment for a merge layer]:n: ' \
    '--level-log-size=[log-base sizing for the level policy]:ratio: ' \
    '(-e --experimental)'{-e,--experimental}'[enable experimental Raft clustering features]' \
    '--leader[start as the Raft leader (experimental)]' \
    '*--nodes=[peer node address (experimental, repeatable)]:host:port: ' \
    '--id=[Raft node ID (experimental, default 1)]:id: ' \
    '--rpc-port=[Raft RPC port (experimental, default 8081)]:port: ' \
    && ret=0

case $state in
    level)
        _describe -t levels 'slog log level' _toshi_log_levels && ret=0 ;;
    mergekind)
        _describe -t kinds 'merge policy kind' _toshi_merge_kinds && ret=0 ;;
esac

return ret
