#compdef pdftoppm
# Documentation: https://manpages.debian.org/pdftoppm.1
# Source: poppler-utils — PDF page rasterizer to PPM / PNG / JPEG / TIFF.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[first page to convert]:n:' \
    '-l[last page to convert]:n:' \
    '(-o -e)-o[only odd-numbered pages]' \
    '(-o -e)-e[only even-numbered pages]' \
    '-singlefile[write only first page (no digit suffix)]' \
    '-r[X+Y resolution (default 150 dpi)]:dpi:' \
    '-rx[X resolution]:dpi:' \
    '-ry[Y resolution]:dpi:' \
    '-scale-to[scale long side to N pixels]:n:' \
    '-scale-to-x[scale horizontal to N pixels]:n:' \
    '-scale-to-y[scale vertical to N pixels]:n:' \
    '-scale-dimension-before-rotation[swap H/V before scaling rotated pdf]' \
    '-x[crop top-left X coordinate]:n:' \
    '-y[crop top-left Y coordinate]:n:' \
    '-W[crop width (pixels)]:n:' \
    '-H[crop height (pixels)]:n:' \
    '-sz[crop square size (sets W=H=size)]:n:' \
    '-cropbox[use crop box instead of media box]' \
    '-hide-annotations[suppress annotations]' \
    '(-mono -gray -png -jpeg -tiff)-mono[output monochrome PBM]' \
    '(-mono -gray -png -jpeg -tiff)-gray[output grayscale PGM]' \
    '(-mono -gray -png -jpeg -tiff)-png[output PNG (instead of PPM)]' \
    '(-mono -gray -png -jpeg -tiff)-jpeg[output JPEG]' \
    '(-mono -gray -png -jpeg -tiff)-tiff[output TIFF]' \
    '-jpegopt[JPEG options (key=value,key=value)]:opts:' \
    '-tiffcompression[TIFF compression]:type:(none packbits jpeg lzw zip deflate)' \
    '-displayprofile[display ICC profile]:file:_files' \
    '-defaultgrayprofile[DefaultGray ICC profile]:file:_files' \
    '-defaultrgbprofile[DefaultRGB ICC profile]:file:_files' \
    '-defaultcmykprofile[DefaultCMYK ICC profile]:file:_files' \
    '-freetype[FreeType font rasterizer]:flag:(yes no)' \
    '-thinlinemode[thin-line mode]:mode:(none solid shape)' \
    '-aa[font anti-aliasing]:flag:(yes no)' \
    '-aaVector[vector anti-aliasing]:flag:(yes no)' \
    '-opw[owner password]:password:' \
    '-upw[user password]:password:' \
    '-q[no messages or errors]' \
    '-progress[print progress per page]' \
    '-sep[name<sep>page-number separator (default -)]:char:' \
    '-forcenum[force page number suffix even for 1-page PDFs]' \
    '(- *)-v[show version]' \
    '(- *)-h[show help]' \
    '*:PDF file then root:_files -g "*.pdf"' \
    && ret=0

return ret
