#compdef cardano-node
# Documentation: https://github.com/IntersectMBO/cardano-node
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run the node'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cardano-node command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--topology=[topology JSON file]:file:_files' \
          '--database-path=[database directory]:dir:_files -/' \
          '--socket-path=[node socket path]:file:_files' \
          '--port=[port to listen]:port:' \
          '--host-addr=[host IP]:ip:' \
          '--host-ipv6-addr=[host IPv6]:ip:' \
          '--config=[node config YAML]:file:_files' \
          '--shelley-kes-key=[KES signing key file]:file:_files' \
          '--shelley-vrf-key=[VRF signing key file]:file:_files' \
          '--shelley-operational-certificate=[op cert file]:file:_files' \
          '--bulk-credentials-file=[bulk creds JSON]:file:_files' \
          '--byron-delegation-certificate=[byron delegation cert]:file:_files' \
          '--byron-signing-key=[byron signing key]:file:_files' \
          '--validate-db[validate db on startup]' \
          '--mempool-capacity-override=[mempool capacity bytes]:n:' \
          '--no-mempool-capacity-override[reset mempool override]' \
          '--start-as-non-producing-node[start as relay]' \
          '--snapshot-interval=[snapshot interval]:n:' \
          '--num-of-disk-snapshots=[disk snapshots count]:n:' \
          '--non-producing-node[run as relay]' \
          '--tracer-socket-path-accept=[tracer socket path accept]:path:_files' \
          '--tracer-socket-path-connect=[tracer socket path connect]:path:_files' && ret=0 ;;
    esac ;;
esac

return ret
