#compdef pup
# Zsh completion for pup
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  {-f,--file}'[file to read]:file:_files' \
  {-c,--charset}'[character set of the input]:charset:' \
  '--color[colorize output]' \
  '--plain[do not colorize output]' \
  '--pre[preserve preformatted text]' \
  {-n,--number}'[number the results]' \
  {-l,--limit}'[limit number of results]:number:' \
  {-i,--indent}'[number of spaces for indentation]:spaces:' \
  '--version[display version]' \
  '--help[display help]' \
  '*:CSS selector:' && ret=0
return ret
