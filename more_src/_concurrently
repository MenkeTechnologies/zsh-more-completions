#compdef concurrently
# Documentation: https://github.com/open-cli-tools/concurrently/blob/main/bin/index.ts
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Run commands concurrently.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-m --max-processes)'{-m,--max-processes}'[how many processes should run at once (number or percent like 50%)]:value:' \
  '(-n --names)'{-n,--names}'[list of custom names to be used in prefix template]:names:' \
  '--name-separator=[character to split names on]:separator:' \
  '(-s --success)'{-s,--success}'[which commands must exit 0 for concurrently to exit 0]:value:(first last all command-name command-index)' \
  '(-r --raw)'{-r,--raw}'[output raw output of processes]' \
  '--no-color[disable colors in output]' \
  '--hide=[comma-separated list of processes to hide]:processes:' \
  '(-g --group)'{-g,--group}'[order output as if commands ran sequentially]' \
  '--timings[show timing information for all processes]' \
  '(-P --passthrough-arguments)'{-P,--passthrough-arguments}'[passthrough additional arguments to commands via placeholders]' \
  '*--teardown=[clean-up command(s) to execute before exiting concurrently]:command:' \
  '(-k --kill-others)'{-k,--kill-others}'[kill other processes once the first exits]' \
  '--kill-others-on-fail[kill other processes if one exits with non-zero]' \
  '--kill-signal=[signal to send to other processes (default SIGTERM)]:signal:(SIGTERM SIGKILL SIGINT SIGHUP)' \
  '-ks+[signal to send to other processes (default SIGTERM)]:signal:(SIGTERM SIGKILL SIGINT SIGHUP)' \
  '--kill-timeout=[milliseconds to wait before force-terminating]:ms:' \
  '(-p --prefix)'{-p,--prefix}'[prefix used in logging for each process]:type:(index pid time command name none)' \
  '(-c --prefix-colors)'{-c,--prefix-colors}'[comma-separated list of chalk colors for prefixes]:colors:' \
  '(-l --prefix-length)'{-l,--prefix-length}'[limit how many characters of the command are displayed]:length:' \
  '--pad-prefix[pad short prefixes with spaces so all prefix lengths match]' \
  '(-t --timestamp-format)'{-t,--timestamp-format}'[timestamp format per Unicode TR35]:format:' \
  '--restart-tries=[how many times a dead process should restart]:number:' \
  '--restart-after=[delay before restarting (ms or "exponential")]:value:' \
  '(-i --handle-input)'{-i,--handle-input}'[forward stdin input to child processes]' \
  '--default-input-target=[identifier for child to receive stdin when unspecified]:target:' \
  '*:command:' && ret=0

return ret
