#compdef mutect2

# Mutect2: GATK4 somatic SNV+indel caller (gatk Mutect2 wrapper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-R[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '-I[input BAM file (specify multiple times)]:file:_files -g "*.(bam|cram)"' \
  '--tumor=[tumor sample name]:name:' \
  '--normal=[normal sample name (matched-normal mode)]:name:' \
  '-L[interval(s) to call]:intervals:_files' \
  '-XL[interval(s) to exclude]:intervals:_files' \
  '-O[output VCF file]:file:_files' \
  '--germline-resource=[gnomAD germline resource]:file:_files' \
  '--panel-of-normals=[panel of normals VCF]:file:_files' \
  '--af-of-alleles-not-in-resource=[allele frequency for variants not in PON]:val:' \
  '--f1r2-tar-gz=[F1R2 read orientation TAR.GZ]:file:_files' \
  '--callable-loci-output=[callable loci output BED]:file:_files' \
  '--bam-output=[output BAM with read assembly]:file:_files' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--native-pair-hmm-threads=[PairHMM threads]:n:' \
  '--mitochondria-mode[mitochondria-tuned mode]' \
  '--genotype-pon-sites[include PON sites in output]' \
  '*:options:_files' && ret=0
return ret
