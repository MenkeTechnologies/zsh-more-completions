#compdef modeltest-ng
# ModelTest-NG: selection of best-fit models of nucleotide/amino acid substitution

local ret=1

_arguments -s -S \
  '(-h --model-het)'{-h,--model-het}'[set candidate models rate heterogeneity]:het:' \
  '--help[show help]' \
  '--usage[show summarized usage information]' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '(-i --input_msa)'{-i,--input_msa}'[input MSA file (FASTA or PHYLIP)]:file:_files' \
  '(-o --output)'{-o,--output}'[prefix for output files]:prefix:' \
  '(-d --datatype)'{-d,--datatype}'[set the data type]:type:(nt aa)' \
  '(-p --threads)'{-p,--threads}'[number of threads (shared memory)]:number:' \
  '(-q --partitions)'{-q,--partitions}'[partitioning scheme file]:file:_files' \
  '(-r --rngseed)'{-r,--rngseed}'[random number generator seed]:seed:' \
  '(-t --topology)'{-t,--topology}'[tree topology used during search]:topology:(ml mp fixed-ml-jc fixed-ml-gtr fixed-mp user random)' \
  '(-u --utree)'{-u,--utree}'[fixed user tree for model selection]:file:_files' \
  '(-a --asc-bias)'{-a,--asc-bias}'[ascertainment bias correction type]:type:' \
  '(-f --frequencies)'{-f,--frequencies}'[candidate models frequencies]:freq:' \
  '(-m --models)'{-m,--models}'[candidate model matrices, comma separated]:models:' \
  '(-s --schemes)'{-s,--schemes}'[number of DNA substitution schemes]:n:(3 5 7 11 203)' \
  '(-T --template)'{-T,--template}'[candidate models for a specified tool]:tool:(raxml phyml mrbayes paup)' \
  '(-g --gamma-rates)'{-g,--gamma-rates}'[set gamma rates mode]:mode:' \
  '(-H --no-compress)'{-H,--no-compress}'[disable pattern compression]' \
  '(-k --keep-params)'{-k,--keep-params}'[keep branch lengths fixed during optimization]' \
  '(-V --verbose)'{-V,--verbose}'[run in verbose mode]' \
  '--ultraverbose[run in ultraverbose mode]' \
  '--eps[model optimization epsilon (log-likelihood units)]:eps:' \
  '--tol[tolerance for each parameter evaluation]:tol:' \
  '--smooth-frequencies[smooth frequencies for absent states]' \
  '--disable-checkpoint[skip creating checkpoint files]' \
  '--force[force output overriding if files exist]' && ret=0

return ret
