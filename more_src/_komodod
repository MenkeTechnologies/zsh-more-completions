#compdef komodod komodo-cli
# _komodod — Komodo Platform komodod fork-of-zcashd Pirate-style daemon with smart-chain composability (komodoplatform team, C++); custom argparse
# upstream: https://github.com/KomodoPlatform/komodo

_komodod() {
    _arguments \
        '--help[show help]' \
        '-?[show help]' \
        '-version[show version]' \
        '-conf=+[config file]:file:_files -g "*.conf"' \
        '-datadir=+[data dir]:dir:_files -/' \
        '-pid=+[pid file]:file:_files' \
        '-daemon[run as daemon]' \
        '-server[accept rpc]' \
        '-nodebug[disable debug]' \
        '-debug=+[category]:c:(net tor mempool http bench zmq db rpc dbtraversal rebatch coindb estimatefee addrman alert qt zrpcunsafe pow leveldb cmpctblock libevent partitioncheck )' \
        '-printtoconsole[log to console]' \
        '-logips[log peer ip]' \
        '-logtimestamps[log timestamps]' \
        '-shrinkdebugfile[shrink debug file]' \
        '-testnet[testnet]' \
        '-regtest[regtest]' \
        '-ac_name=+[smart chain]:str:' \
        '-ac_supply=+[supply]:n:' \
        '-ac_reward=+[reward]:n:' \
        '-ac_halving=+[blocks]:n:' \
        '-ac_decay=+[decay]:n:' \
        '-ac_perc=+[percent]:n:' \
        '-ac_blocktime=+[seconds]:n:' \
        '-ac_cc=+[cc]:n:' \
        '-ac_staked=+[percent]:n:' \
        '-pubkey=+[pubkey]:str:' \
        '-bind=+[bind address]:str:' \
        '-port=+[p2p port]:port:_ports' \
        '-listen[accept connections]' \
        '-connect=+[peer]:host:_hosts' \
        '-addnode=+[peer]:host:_hosts' \
        '-rpcuser=+[rpc user]:user:_users' \
        '-rpcpassword=+[rpc password]:str:' \
        '-rpcbind=+[bind addr]:str:' \
        '-rpcport=+[rpc port]:port:_ports' \
        '-rpcallowip=+[CIDR]:str:' \
        '-rpcssl[ssl rpc]' \
        '-rpcsslciphers=+[ciphers]:str:' \
        '-rpccert=+[cert]:file:_files' \
        '-rpckey=+[key]:file:_files' \
        '-rpcthreads=+[N]:n:' \
        '-mineraddress=+[address]:str:' \
        '-gen[mine]' \
        '-genproclimit=+[N]:n:' \
        '-wallet=+[wallet file]:file:_files' \
        '-walletbroadcast=+[bool]:b:(0 1)' \
        '-zapwallettxes=+[mode]:m:(0 1 2)' \
        '-reindex[reindex blockchain]' \
        '-reindex-chainstate[reindex chainstate]' \
        '-rescan[rescan wallet]' \
        '-spentindex[spent index]' \
        '-addressindex[address index]' \
        '-timestampindex[timestamp index]' \
        '-paytxfee=+[fee]:f:' \
        '-maxconnections=+[N]:n:' \
        '-banscore=+[N]:n:' \
        '-bantime=+[seconds]:n:'
}

_komodod "$@"
