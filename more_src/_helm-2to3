#compdef helm-2to3
# Documentation: https://github.com/helm/helm-2to3
# Helm plugin to migrate Helm v2 configuration and releases to v3

local ret=1
local -a subcmds

subcmds=(
  'move:migrate Helm v2 configuration in-place to Helm v3'
  'convert:migrate Helm v2 release in-place to Helm v3'
  'cleanup:clean up Helm v2 configuration, release data and Tiller'
)

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'helm 2to3 command' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      convert)
        _arguments -s \
          '--delete-v2-releases[delete v2 release versions after migration]' \
          '--dry-run[simulate a command]' \
          '--ignore-already-migrated[continue migrating despite already-migrated versions]' \
          '--kube-context=[name of the kubeconfig context to use]:context' \
          '--kubeconfig=[path to the kubeconfig file]:file:_files' \
          '(-l --label)'{-l,--label}'=[label to select Tiller resources]:label' \
          '(-s --release-storage)'{-s,--release-storage}'=[v2 storage type]:type:(secrets configmaps)' \
          '--release-versions-max=[limit versions converted per release]:n' \
          '(-t --tiller-ns)'{-t,--tiller-ns}'=[namespace of Tiller]:namespace' \
          '--tiller-out-cluster[for non-cluster Tiller instances]' \
          '(-h --help)'{-h,--help}'[help for convert]' \
          '*:release:' && ret=0
        ;;
      cleanup)
        _arguments -s \
          '--config-cleanup[perform configuration cleanup]' \
          '--dry-run[simulate a command]' \
          '--kube-context=[name of the kubeconfig context to use]:context' \
          '--kubeconfig=[path to the kubeconfig file]:file:_files' \
          '(-l --label)'{-l,--label}'=[label to select Tiller resources]:label' \
          '--name=[remove named release and its versions only]:name' \
          '(-s --release-storage)'{-s,--release-storage}'=[v2 storage type]:type:(secrets configmaps)' \
          '--skip-confirmation[skip confirmation before cleanup]' \
          '--tiller-cleanup[perform Tiller deployment cleanup]' \
          '(-t --tiller-ns)'{-t,--tiller-ns}'=[Tiller namespace]:namespace' \
          '--tiller-out-cluster[for non-cluster Tiller]' \
          '--release-cleanup[perform v2 release data cleanup]' \
          '(-h --help)'{-h,--help}'[help for cleanup]' && ret=0
        ;;
      move)
        _arguments -s \
          '--dry-run[simulate a command]' \
          '--skip-confirmation[skip confirmation before performing move]' \
          '(-h --help)'{-h,--help}'[help for move]' \
          '*:arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
