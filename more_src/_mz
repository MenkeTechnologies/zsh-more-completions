#compdef mz

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'app-password:manage application passwords for authentication'
  'config:get/set/list/remove CLI configuration parameters'
  'profile:manage authentication profiles'
  'region:enable, list, and view status of Materialize regions'
  'secret:create and manage secrets stored in Materialize'
  'sql:execute SQL statements against a region'
  'user:manage users in your Materialize organization'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config=[path to configuration file]:file:_files' \
  '(-f --format)'{-f,--format=}'[output format]:format:(text json csv)' \
  '--no-color[disable colored output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'mz subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (app-password)
        _values 'app-password action' \
          'create' 'list' 'remove' && ret=0
        ;;
      (config)
        _values 'config action' \
          'get' 'set' 'list' 'remove' && ret=0
        ;;
      (profile)
        _values 'profile action' \
          'init' 'list' 'remove' 'config' && ret=0
        ;;
      (region)
        _values 'region action' \
          'enable' 'disable' 'list' 'show' && ret=0
        ;;
      (secret)
        _values 'secret action' \
          'create' 'delete' 'list' && ret=0
        ;;
      (user)
        _values 'user action' \
          'create' 'list' 'remove' && ret=0
        ;;
    esac
    ;;
esac

return ret
