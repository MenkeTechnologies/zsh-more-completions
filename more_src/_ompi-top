#compdef ompi-top
# Documentation: https://www.open-mpi.org/doc/v3.1/man1/ompi-top.1.php
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ompi-top: top-like monitor of MPI processes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-mca[MCA parameter]:param value:' \
  '--mca=[MCA parameter]:param value:' \
  '*::ompi-top args:_files' && ret=0
return ret
