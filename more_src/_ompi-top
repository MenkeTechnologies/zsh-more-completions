#compdef ompi-top
# Documentation: https://man.archlinux.org/search?q=ompi-top
# Reference accessed: 2026-05-16

# ompi-top: top-like monitor of MPI processes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-mca[MCA parameter]:param value:' \
  '--mca=[MCA parameter]:param value:' \
  '*::ompi-top args:_files' && ret=0
return ret
