#compdef ompi-top
# Documentation: https://www.open-mpi.org/doc/v1.8/man1/ompi-top.1.php
# Reference accessed: 2026-05-20
# Verified: upstream Open MPI ompi-top(1) manpage.

# ompi-top: top-like monitor of MPI processes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[display help]' \
  '(-pid --pid)'{-pid+,--pid=}'[pid of mpirun or file containing it]:pid:' \
  '(-uri --uri)'{-uri+,--uri=}'[URI of mpirun or file containing it]:uri:' \
  '(-rank --rank)'{-rank+,--rank=}'[monitor specific rank(s)]:rank:' \
  '(-bynode --bynode)'{-bynode,--bynode}'[organize output by node]' \
  '(-update-rate --update-rate)'{-update-rate+,--update-rate=}'[refresh interval in seconds]:seconds:' \
  '(-timestamp --timestamp)'{-timestamp,--timestamp}'[include sample collection time]' \
  '(-log-file --log-file)'{-log-file+,--log-file=}'[write results to file]:file:_files' \
  '*::ompi-top args:' && ret=0
return ret
