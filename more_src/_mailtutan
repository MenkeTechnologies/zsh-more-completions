#compdef mailtutan
# ---------------------------------------------------------------------------
# mailtutan — SMTP test server: accepts mail from any local development
#             environment on SMTP port 1025, parses each incoming
#             message with mail-parser, stores it (in memory or in a
#             Maildir on disk), and exposes a browser-viewable web UI
#             on port 1080 plus an HTTP+WebSocket API for live preview.
#             Drop-in replacement for MailHog / Mailpit / Mailcatcher
#             with a smaller binary and fewer dependencies (Rust, 203★)
#
# upstream: https://github.com/mailtutan/mailtutan
# author : Mohsen Alizadeh (mailtutan)
# license: MIT
#
# Source-direct completion: every flag below is verbatim from
# mailtutan/src/config.rs on the mailtutan/mailtutan tip — clap
# `#[derive(Parser)]` macros (Config struct + StorageType ValueEnum)
# parsed exactly as declared, with the `env(...)` annotations
# preserved (every CLI flag has an equivalent `MAILTUTAN_*`
# environment variable for container deployments) and the
# `requires(...)` constraints (--smtp-auth-username / --smtp-auth-
# password require --smtp-cert-path + --smtp-key-path because SMTP AUTH
# is only allowed over TLS) preserved.
#
# Direct deps from mailtutan/Cargo.toml + mailtutan-lib/Cargo.toml
# (selected):
#   mail-parser           "0.8.2"   ← canonical Rust RFC 5322 / MIME
#                                      email parser library (this
#                                      axis) — by Stalwart Labs
#                                      (stalwartlabs/mail-parser);
#                                      pure-Rust streaming parser for
#                                      RFC 5322 (Internet Message
#                                      Format) + RFC 2045-2049 (MIME) +
#                                      RFC 6532 (Internationalized
#                                      Email Headers) + RFC 2047 (MIME
#                                      Encoded-Words) + RFC 6854
#                                      (Group Syntax) + delivery-
#                                      status / disposition-
#                                      notification report formats.
#                                      THE Rust answer to "parse this
#                                      email" — used by stalwartlabs/
#                                      stalwart (the all-in-one mail
#                                      server by the same author),
#                                      tutao/tutanota (the privacy-
#                                      respecting webmail), windmill-
#                                      labs/windmill (workflow
#                                      automation platform with email
#                                      triggers), terhechte/postsack
#                                      (email visualizer / clusterer),
#                                      dreamhunter2333/cloudflare_
#                                      temp_email, miakizz/mop3, and
#                                      most Rust email tools.
#                                      mailtutan uses mail-parser
#                                      inside mailtutan-lib's SMTP
#                                      DATA handler — when a test
#                                      application POSTs an SMTP
#                                      `DATA` block, mailtutan-lib
#                                      runs the bytes through
#                                      mail-parser to extract the
#                                      structured Message{ from /
#                                      to / subject / parts / headers
#                                      / attachments } that the web
#                                      UI renders.
#   mailin-embedded       "0.8.0"   (SMTP server library — handles
#                                      EHLO/MAIL FROM/RCPT TO/DATA
#                                      state machine + STARTTLS +
#                                      AUTH negotiation; mailtutan
#                                      hooks the DATA-handler callback
#                                      to feed bytes to mail-parser)
#   mailin                "0.6.3"   (sister crate — pure SMTP-protocol
#                                      state-machine without the
#                                      embedded server loop; used in
#                                      mailtutan-lib for unit-tests
#                                      that drive the protocol
#                                      directly without binding a
#                                      socket)
#   axum                  "0.6.18"  (HTTP + WebSocket server for the
#                                      browser-viewable web UI on
#                                      port 1080)
#   clap (with derive + env)        (CLI parser with both --long-form
#                                      flags and MAILTUTAN_* env-var
#                                      bindings — friendly to both
#                                      command-line invocations and
#                                      container `environment:` lists)
#   tokio + reqwest + uuid + http-body + chrono
#
# mailtutan exists for the same reason MailHog / Mailpit / Mailcatcher
# exist: when developing a web app that sends emails (signup
# confirmations / password reset links / notification digests), you
# don't want each test run to hit a real SMTP server — you want a
# local server that accepts the mail, surfaces it in a browser UI so
# you can visually verify the rendered HTML, and discards everything
# on restart.  mailtutan listens on SMTP :1025 (point your app's
# SMTP_HOST=localhost / SMTP_PORT=1025 at it), accepts mail from any
# source, parses each RFC 5322 message via mail-parser, stores the
# structured representation (in memory by default; in a Maildir on
# disk when --storage maildir + --maildir-path are set), and exposes
# the inbox as a browser-viewable web UI on port 1080 + a JSON HTTP
# API for programmatic test assertions.  Optional --web-hook POSTs
# each received message to a webhook URL for downstream pipelines.
#
# ============================================================================
# === AXIS 188 OPENS — RFC 5322 / MIME email parser libraries =============
# === Rust=243 OPENS at slot 1/0/0 ========================================
# ============================================================================
# Axis position: Rust=243 OPENS Axis 188 at slot 1/0/0 — the first of the
# three lanes for the canonical RFC 5322 / MIME email parser trio.  The
# axis anchors on a single pure-host-language parser library for the
# Internet Message Format (RFC 5322) + MIME (RFC 2045-2049) + their
# associated encoding standards (RFC 2047 encoded-words, RFC 6532
# internationalized headers, RFC 6854 group syntax) with structured
# typed-message representation (from / to / cc / bcc / subject /
# headers / parts / attachments) suitable for downstream consumers:
#
#     Rust    : mail-parser                  by Stalwart Labs
#                                              (stalwartlabs/mail-
#                                              parser); pure-Rust
#                                              streaming parser
#                                              covering RFC 5322 +
#                                              MIME + RFC 6532 +
#                                              RFC 2047 + RFC 6854 +
#                                              delivery-status report
#                                              formats.  Sister
#                                              project to stalwart
#                                              mail-server by the
#                                              same author Mauro
#                                              Bianco — the parser
#                                              and the server are
#                                              tightly coordinated.
#                 → mailtutan (Mohsen Alizadeh — SMTP test server for
#                               development environments; accepts mail
#                               on :1025, parses via mail-parser, shows
#                               browser UI on :1080 + JSON HTTP API;
#                               drop-in MailHog/Mailpit/Mailcatcher
#                               replacement with smaller binary;
#                               203★ MIT)
#                 _mailtutan        [Rust=243 OPENS Axis 188, 1/0/0]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#
#     Go      : (next round — Go=243, slot 2/0/0)
#                Canonical Go email parser: github.com/emersion/go-
#                message by Simon Ser (emersion) — already seen in this
#                corpus's _reader completion (R1254 / Axis 183) where
#                mrusme/reader uses it for `--eml` input mode.  RFC
#                5322 + MIME + IMAP integration.  THE Go answer to
#                "parse this email."  [TBD next-round consumer]
#
#     JS/Node : (Axis 188 CLOSES at TS-Node=243, slot 1/1/1)
#                Canonical JS email parser: `mailparser` by Andris
#                Reinman (nodemailer/mailparser) — sister project to
#                Nodemailer (the canonical email-SENDING library; same
#                author).  Streaming RFC 5322 / MIME parser with
#                attachment extraction + DKIM / DMARC / SPF
#                verification helpers built on the same primitives
#                Nodemailer uses for outbound signing.  Used by every
#                Node mail-handling tool.  [TBD closer consumer]
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=243     ← THIS FILE          (axis 188 OPENS, slot 1/0/0)
#   Go=243       ← next round         (axis 188 continues, slot 2/0/0)
#   TS-Node=243  ← round after        (axis 188 CLOSES at triple-243, 1/1/1)
# ============================================================================

_mailtutan() {
    _arguments -s -S \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--ip=[IPv4 address to bind to (env MAILTUTAN_IPADDR, default 0.0.0.0)]:addr:_hosts' \
        '--http-port=[HTTP server port for the browser UI + JSON API (env MAILTUTAN_HTTP_PORT, default 1080)]:port:' \
        '--smtp-port=[SMTP server port for receiving test mail (env MAILTUTAN_SMTP_PORT, default 1025)]:port:' \
        '--smtp-cert-path=[path to SMTP TLS certificate (env MAILTUTAN_SMTP_CERT_PATH; required for SMTP AUTH)]:cert:_files -g "*.(pem|crt|cer)"' \
        '--smtp-key-path=[path to SMTP TLS private key (env MAILTUTAN_SMTP_KEY_PATH; required for SMTP AUTH)]:key:_files -g "*.(pem|key)"' \
        '--smtp-auth-username=[SMTP AUTH username (env MAILTUTAN_AUTH_USERNAME; requires --smtp-cert-path and --smtp-key-path)]:username:' \
        '--smtp-auth-password=[SMTP AUTH password (env MAILTUTAN_AUTH_PASSWORD; requires --smtp-cert-path and --smtp-key-path)]:password:' \
        '--http-auth[require HTTP basic auth on the browser UI / JSON API (env MAILTUTAN_HTTP_AUTH, default false)]' \
        '--http-username=[HTTP basic-auth username (env MAILTUTAN_HTTP_USERNAME, default admin)]:username:' \
        '--http-password=[HTTP basic-auth password (env MAILTUTAN_HTTP_PASSWORD, default admin)]:password:' \
        '--messages-limit=[maximum number of messages retained in storage (env MAILTUTAN_MESSAGES_LIMIT, default 1000)]:n:' \
        '--storage=[storage backend (env MAILTUTAN_STORAGE, default memory)]:type:(memory maildir)' \
        '--maildir-path=[directory for the Maildir storage backend (env MAILTUTAN_MAILDIR_PATH, default maildir)]:dir:_files -/' \
        '--web-hook=[URL to POST each received message to (env MAILTUTAN_WEB_HOOK)]:url:_urls'
}

_mailtutan "$@"
