#compdef cooker
# Documentation: https://github.com/cpb-/yocto-cooker
# Reference accessed: 2026-05-17
# Verified: ambiguous binary name — multiple candidates exist
# (yocto-cooker meta buildtool, Qt mesh cooker tools, etc.).
# This completion keeps a minimal -h/--help-all/-v/--version
# surface plus generic file positional. NOTE: if you use
# yocto-cooker, the canonical subcommands are init, cook,
# update, generate, build, clean, shell, show, diff, version.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including generic Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:input mesh:_files -g "*.(obj|fbx|gltf|mesh)"' && ret=0

return ret
