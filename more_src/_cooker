#compdef cooker
# Documentation: https://man.archlinux.org/search?q=cooker
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including generic Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:input mesh:_files -g "*.(obj|fbx|gltf|mesh)"' && ret=0

return ret
