#compdef otbcli_SampleSelection
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_SampleSelection.html
# Orfeo ToolBox: select samples from polygons for training a classifier

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[support image to be classified]:image:_files' \
  '-mask[validity mask for filtering pixels]:image:_files' \
  '-vec[input geometries to analyze]:vector:_files' \
  '-out[output resampled geometries]:output:_files' \
  '-instats[input statistics file in XML format]:file:_files' \
  '-outrates[output rates in CSV format]:output:_files' \
  '-field[field carrying the class name]:name:' \
  '-layer[layer index to read]:value:' \
  '-rand[random seed value]:value:' \
  '-sampler[type of sampling]:type:(periodic random)' \
  '-sampler.periodic.jitter[jitter amplitude added during selection]:value:' \
  '-strategy[strategy for sample selection]:strategy:(byclass constant percent total smallest all)' \
  '-strategy.byclass.in[CSV with class names and sample counts]:file:_files' \
  '-strategy.constant.nb[number of samples for all classes]:value:' \
  '-strategy.percent.p[percentage of samples per class]:value:' \
  '-strategy.total.v[total number of samples to generate]:value:' \
  '-elev.dem[directory containing DEM files]:dir:_files -/' \
  '-elev.geoid[geoid grid file]:file:_files' \
  '-elev.default[default height above ellipsoid]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
