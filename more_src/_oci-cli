#compdef oci

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--config-file[OCI config file]:file:_files' \
  '--profile[config profile]:profile:' \
  '--region[OCI region]:region:' \
  '--endpoint[API endpoint]:url:' \
  '--cert-bundle[CA cert bundle]:file:_files' \
  '--output[output format]:format:(json table)' \
  '--query[JMESPath query]:query:' \
  '--raw-output[raw output]' \
  '--auth[auth type]:type:(api_key instance_principal instance_obo_user resource_principal security_token)' \
  '--generate-full-command-json-input[show full JSON input template]' \
  '--generate-param-json-input[show JSON input for param]:param:' \
  '--max-retries[max retries]:count:' \
  '--no-retry[disable retries]' \
  '--debug[enable debug output]' \
  '-d[enable debug output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:service:(compute network iam os bv db dns audit ons streaming ce setup session)' \
  '*:args:' && ret=0

return ret
