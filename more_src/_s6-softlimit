#compdef s6-softlimit
# Documentation: https://skarnet.org/software/s6/s6-softlimit.html
# Reference accessed: 2026-05-30
# s6-softlimit — apply resource limits via setrlimit() then exec a program.
# Each numeric option accepts '=' to mean "set to hard limit".

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-H -h)-H[set both hard + soft limits (root only for raising)]' \
  '(-H -h)-h[set hard limit only (do not modify soft limit)]' \
  '-a+[limit total available memory (use "=" for hard)]:bytes:' \
  '-c+[limit core file size]:bytes:' \
  '-d+[limit available heap memory]:bytes:' \
  '-f+[limit file size]:bytes:' \
  '-l+[limit locked memory]:bytes:' \
  '-m+[limit all types of memory]:bytes:' \
  '-o+[limit number of open file descriptors]:N:' \
  '-P+[limit real-time priority]:prio:' \
  '-p+[limit number of processes per user]:N:' \
  '-r+[limit available physical memory]:bytes:' \
  '-s+[limit available stack memory]:bytes:' \
  '-t+[limit CPU time (seconds)]:sec:' \
  '*:program + args:_command_names -e' \
  && ret=0

return ret
