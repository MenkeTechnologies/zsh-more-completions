#compdef fplll
# Documentation: https://github.com/fplll/fplll
# fplll - lattice reduction (LLL, BKZ, HKZ, SVP, CVP) tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-a[reduction algorithm]:algorithm:(lll bkz hkz svp cvp sdb sld hlll)' \
  '-d[LLL delta parameter (default 0.99)]:delta' \
  '-e[LLL eta parameter (default 0.51)]:eta' \
  '-f[floating-point type]:type:(mpfr dd qd dpe double longdouble)' \
  '-p[precision with MPFR]:precision' \
  '-m[LLL algorithm variant]:method:(wrapper fast heuristic proved)' \
  '-z[integer type]:type:(mpz int long double)' \
  '-l[Lovasz (0) vs Siegel (1) condition]:cond:(0 1)' \
  '-y[early reduction]' \
  '-nolll[skip initial LLL]' \
  '-b[BKZ block size]:block_size' \
  '-bkzmaxloops[BKZ maximum iterations]:loops' \
  '-bkzmaxtime[BKZ time limit in seconds]:seconds' \
  '-bkzautoabort[automatic BKZ termination]' \
  '-s[BKZ strategy file]:file:_files -g "*.json"' \
  '-bkzghbound[Gaussian heuristic multiplier]:bound' \
  '-bkzboundedlll[restrict LLL to current block]' \
  '-bkzdumpgso[GSO log output file]:file:_files' \
  '-t[HLLL theta parameter (default 0.001)]:theta' \
  '-c[HLLL size-reduction constant]:c' \
  '-of[output format]:format:(b bk c s t u uk v vk)' \
  '-v[verbose mode]' \
  '*:file:_files' && ret=0

return ret
