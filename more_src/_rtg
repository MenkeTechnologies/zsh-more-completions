#compdef rtg
# Documentation: https://github.com/RealTimeGenomics/rtg-tools
# rtg - RTG Tools utilities for VCF and sequence data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:subcommand:(format map vcfeval rocplot vcffilter vcfstats mendelian sdf2fasta bgzip index)' \
  '*::args:_files' && ret=0

return ret
