#compdef luigi-cli luigi luigid
# _luigi-cli — Spotify Luigi luigi luigid CLI command-line frontend wrapping the Luigi Python module providing build dependency-resolution batch-job-workflow-scheduling running task scheduler central monitoring REST API web-UI worker-pool retry batch_id command-line parameters for ETL pipeline orchestration (Spotify team, Python); argparse
# upstream: https://luigi.readthedocs.io/

_luigi-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--module=+[module]:str:' \
        '--task-id=+[id]:str:' \
        '--background[run in background]' \
        '--logdir=+[dir]:dir:_files -/' \
        '--logging-conf-file=+[file]:file:_files -g "*.conf *.cfg *.ini"' \
        '--log-level=+[l]:l:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '--no-lock[no lock]' \
        '--lock-pid-dir=+[dir]:dir:_files -/' \
        '--take-lock[take lock]' \
        '--scheduler-host=+[host]:_hosts' \
        '--scheduler-port=+[port]:n:' \
        '--scheduler-url=+[url]:str:' \
        '--retcode-already-running=+[N]:n:' \
        '--retcode-missing-data=+[N]:n:' \
        '--retcode-not-run=+[N]:n:' \
        '--retcode-task-failed=+[N]:n:' \
        '--retcode-scheduling-error=+[N]:n:' \
        '--retcode-unhandled-exception=+[N]:n:' \
        '--workers=+[N]:n:' \
        '--local-scheduler[run local scheduler]' \
        '--worker-keep-alive[worker keep alive]' \
        '--worker-no-install-shutdown-handler[no shutdown handler]' \
        '--scheduler-remove-delay=+[sec]:n:' \
        '--scheduler-retry-delay=+[sec]:n:' \
        '--scheduler-record-task-history[record task history]' \
        '--scheduler-state-path=+[file]:file:_files' \
        '--no-restart-on-error[no restart on error]' \
        '--statsd-host=+[host]:_hosts' \
        '--statsd-port=+[port]:n:' \
        '--parallel-scheduling[parallel scheduling]' \
        '--parallel-scheduling-processes=+[N]:n:' \
        '--keep-alive[keep alive]' \
        '*:task class:'
}

_luigi-cli "$@"
