#compdef hash-identifier hashID hashid
# _hash-identifier — Zion3R hash-identifier classic and c0re hashID Python tools for identifying hash algorithm types (psypanda/zion3r teams, Python); argparse
# upstream: https://github.com/psypanda/hashID

_hash-identifier() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-e[show extended]' \
        '--extended[show extended hashes]' \
        '-m[show hashcat mode]' \
        '--mode[show hashcat mode]' \
        '-j[show john mode]' \
        '--john[show john mode]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '*:hash or file:'
}

_hash-identifier "$@"
