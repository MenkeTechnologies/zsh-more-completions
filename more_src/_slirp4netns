#compdef slirp4netns
# _slirp4netns — user-mode networking for unprivileged netns (rootless-containers/slirp4netns)
# upstream: https://github.com/rootless-containers/slirp4netns
# Flags from main.c getopt_long usage on tip.

_slirp4netns() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print version]' \
        '(-c --configure)'{-c,--configure}'[bring up the interface]' \
        '(-e --exit-fd)'{-e,--exit-fd=}'[FD to signal termination]:fd:' \
        '(-r --ready-fd)'{-r,--ready-fd=}'[FD signalled when ready]:fd:' \
        '(-m --mtu)'{-m,--mtu=}'[MTU (max 65521)]:n:' \
        '(-6 --enable-ipv6)'{-6,--enable-ipv6}'[enable IPv6 (experimental)]' \
        '(-a --api-socket)'{-a,--api-socket=}'[API socket path]:path:_files' \
        '--cidr=[network CIDR]:cidr:' \
        '--disable-host-loopback[block connections to 127.0.0.1:* on host]' \
        '--netns-type=[netns target type]:type:(netns bess)' \
        '--target-type=[target type]:type:(netns bess)' \
        '--userns-path=[user namespace path]:path:_files' \
        '--enable-sandbox[create new mount namespace and drop privileges]' \
        '--enable-seccomp[restrict syscalls with seccomp]' \
        '--outbound-addr=[outbound IPv4 bind address]:ip:' \
        '--outbound-addr6=[outbound IPv6 bind address]:ip:' \
        '--disable-dns[disable internal DNS resolver]' \
        '--macaddress=[TAP MAC address (with -c)]:mac:' \
        '1:pid-or-netns-path:' \
        '2:tapname:'
}

_slirp4netns "$@"
