#compdef opendkim-genzone
# Documentation: https://man.archlinux.org/search?q=opendkim-genzone
# Reference accessed: 2026-05-16

# opendkim-genzone: generate DNS zone entries for DKIM keys
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[domain]:domain:' \
  '-D[server name]:host:_hosts' \
  '-E[zone TTL]:n:' \
  '-F[fewer comments]' \
  '-N[hide notes]' \
  '-o[output file]:file:_files' \
  '-r[selector]:sel:' \
  '-S[verbose mode]' \
  '-t[TTL]:n:' \
  '-T[default TTL]:n:' \
  '*:keys directory:_files -/' && ret=0
return ret
