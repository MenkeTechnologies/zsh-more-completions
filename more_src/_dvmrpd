#compdef dvmrpd
# _dvmrpd — OpenBSD dvmrpd (Distance Vector Multicast Routing Protocol v3.255 daemon for IPv4 multicast routing tables; controlled at runtime by dvmrpctl(8))
# upstream: https://github.com/openbsd/src (usr.sbin/dvmrpd)
# Flags from usr.sbin/dvmrpd/dvmrpd.8 on tip.

_dvmrpd() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-n[validate config + exit]' \
        '-v[verbose]' \
        '-f+[config file (default /etc/dvmrpd.conf)]:file:_files'
}

_dvmrpd "$@"
