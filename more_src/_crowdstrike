#compdef crowdstrike falcon-cli
# _crowdstrike — CrowdStrike crowdstrike CLI client to the Falcon REST API for endpoint detection response EDR XDR threat intelligence detect host indicator-of-attack indicator-of-compromise quarantine release contain RTR-real-time-response prevention-policy host-group sensor-version (CrowdStrike team, Python/Go); custom argparse
# upstream: https://www.crowdstrike.com/

_crowdstrike() {
    local -a sub=(
        'host:host management'
        'detect:detection queries'
        'incident:incident management'
        'rtr:run real-time-response scripts'
        'ioc:indicators of compromise'
        'ioa:indicators of attack'
        'sensor:sensor download management'
        'policy:prevention policy management'
        'group:host group management'
        'oauth:oauth token management'
        'discover:asset discovery'
        'identity:identity threat protection'
        'spotlight:vulnerability management'
        'falconx:sandbox detonation'
        'recon:recon notifications'
        'mssp:Falcon Flight Control MSSP'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--client-id=+[id]:str:' \
        '--client-secret=+[secret]:str:' \
        '--member-cid=+[cid]:str:' \
        '--cloud=+[c]:c:(us-1 us-2 eu-1 us-gov-1 us-gov-2)' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'crowdstrike subcommand' sub ;;
        args)
            case $words[1] in
                host) _arguments '1:op:(list show contain lift-containment hide unhide tag untag)' ;;
                rtr) _arguments '1:op:(start_session list_sessions delete_session run_admin_command run_command list_files get_file batch_run)' ;;
                ioc) _arguments '1:op:(list add remove)' ;;
            esac
            ;;
    esac
}

_crowdstrike "$@"
