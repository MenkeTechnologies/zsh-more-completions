#compdef rtrtr

_arguments -s \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--syslog[log to syslog]' \
  '--syslog-facility=[syslog facility]:facility:(daemon user local0 local1 local2 local3 local4 local5 local6 local7)' \
  '--logfile=[log file]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
