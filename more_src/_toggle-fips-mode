#compdef toggle-fips-mode fips-mode-setup
# _toggle-fips-mode — Fedora/RHEL fips-mode-setup (enable / disable Federal Information Processing Standard mode by flipping kernel cmdline + /etc/system-fips and re-running dracut(8); --enable enable FIPS, --disable disable FIPS, --check show current state, --is-enabled exit 0/1, --boot-mode allow boot-time setup, --no-bootcfg do not update bootloader; positional argument none)
# upstream: https://github.com/crypto-policies/crypto-policies
# Flags from crypto-policies fips-mode-setup on tip.

_toggle-fips-mode() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '(--disable --check)--enable[enable FIPS]' \
        '(--enable --check)--disable[disable FIPS]' \
        '(--enable --disable)--check[show current state]' \
        '--is-enabled[exit 0 if enabled]' \
        '--boot-mode[boot-time setup]' \
        '--no-bootcfg[do not update bootloader]'
}

_toggle-fips-mode "$@"
