#compdef ExternalCalibration
# Documentation: https://www.openms.org/documentation/html/TOPP_ExternalCalibration.html
# OpenMS: applies an external m/z calibration using offset, slope and power terms

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '-in[input peak file (mzML)]:file:_files -g "*.mzML"' \
  '-out[output file (mzML)]:file:_files' \
  '-offset[mass offset in ppm]:double:' \
  '-slope[slope dependent on m/z]:double:' \
  '-power[power dependent on m/z]:double:' \
  '*-ms_level[target MS levels for transformation]:int:' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
