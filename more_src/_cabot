#compdef cabot
# Documentation: https://man.archlinux.org/search?q=cabot
# Reference accessed: 2026-05-16

# Cabot: free, open self-hosted alerting system (Django)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'runserver:run dev server'
  'migrate:run database migrations'
  'createsuperuser:create a superuser'
  'collectstatic:collect static assets'
  'shell:Django shell'
  'celery:run celery worker'
  'rebuild_index:rebuild search index'
  'update_index:update search index'
  'check:django check'
  'showmigrations:show migrations'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--settings=[Django settings module]:mod:' \
  '--pythonpath=[python path]:path:' \
  '--traceback[print traceback on error]' \
  '--no-color[disable color]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'cabot command' commands && ret=0 ;;
esac
return ret
