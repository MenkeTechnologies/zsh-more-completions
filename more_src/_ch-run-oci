#compdef ch-run-oci
# Documentation: https://charliecloud.io/latest/ch-run-oci.html
# Charliecloud: OCI wrapper for ch-run (for use by buildah etc.).

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '1:operation:->ops' \
  '*:: :->args' && ret=0

case $state in
  ops)
    local -a ops=(
      'create:create the container scaffolding'
      'delete:clean up the OCI scaffolding'
      'kill:no-op'
      'start:execute the user command in a container'
      'state:print container state as OCI JSON'
    )
    _describe -t operations 'operation' ops && ret=0
    ;;
  args)
    case ${words[1]} in
      create)
        _arguments -s -S \
          '--bundle[directory containing the OCI bundle]:dir:_files -/' \
          '--pid-file[file to write the container process PID to]:file:_files' \
          '--no-new-keyring[ignored]' \
          '--console-socket[UNIX socket for pseudoterminal fd (unsupported)]:socket:_files' \
          '1:container id:' && ret=0
        ;;
      delete|kill|start|state)
        _arguments '1:container id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
