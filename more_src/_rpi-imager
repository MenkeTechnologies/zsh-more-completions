#compdef rpi-imager
# Documentation: https://github.com/raspberrypi/rpi-imager/blob/main/doc/man/rpi-imager.1
# Flash OS images to removable storage (Raspberry Pi Imager)

local ret=1

_arguments -s \
  '(- *)--help[display command line syntax and exit]' \
  '(- *)--version[report the version of the utility]' \
  '--cli[flash image to drive without the graphical interface]' \
  '--debug[output extra debugging information]' \
  '--disable-verify[skip verifying the image was written correctly]' \
  '--quiet[suppress all console output]' \
  '--disable-telemetry[do not report OS writes to Raspberry Pi]' \
  '--enable-secure-boot[force enable secure boot customisation]' \
  '--sha256=[expected SHA256 checksum of the image]:hash:' \
  '--secure-boot-key=[private key file for signing the boot partition]:key file:_files' \
  '--repo=[query this URL for the list of available OS images]:url:' \
  '--qm=[alternate Qt message translations file]:file:_files' \
  '*:image or device:_files' && ret=0

return ret
