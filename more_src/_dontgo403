#compdef dontgo403 nomore403

_arguments -s \
  '(-i --bypass-ip)'{-i,--bypass-ip}'=[bypass IP]:ip:' \
  '(-d --delay)'{-d,--delay}'=[delay ms]:ms:' \
  '(-f --folder)'{-f,--folder}'=[payloads folder]:dir:_files -/' \
  '*'{-H,--header}'=[header]:header:' \
  '--http[use HTTP not HTTPS]' \
  '(-t --http-method)'{-t,--http-method}'=[method]:method:(GET POST PUT DELETE HEAD OPTIONS PATCH)' \
  '(-m --max-goroutines)'{-m,--max-goroutines}'=[goroutines]:n:' \
  '--no-banner[no banner]' \
  '(-x --proxy)'{-x,--proxy}'=[proxy URL]:url:' \
  '--random-agent[random User-Agent]' \
  '(-l --rate-limit)'{-l,--rate-limit}'[halt on 429]' \
  '(-r --redirect)'{-r,--redirect}'[follow redirects]' \
  '--request-file=[Burp request file]:file:_files' \
  '--no-calibrate[no calibrate]' \
  '--strict-calibrate[strict calibrate]' \
  '--status=[status filter]:codes:' \
  '*'{-k,--technique}'=[technique]:technique:(verbs verbs-case headers endpaths midpaths double-encoding unicode http-versions http-parser path-case hop-by-hop absolute-uri method-override path-normalization suffix-tricks header-confusion host-override forwarded-trust proto-confusion ip-encoding raw-duplicates raw-authority raw-desync payload-position)' \
  '--timeout=[timeout ms]:ms:' \
  '--retry-count=[retries]:n:' \
  '--retry-backoff-ms=[backoff ms]:ms:' \
  '--host-delay=[host delay ms]:ms:' \
  '--top=[max entries]:n:' \
  '--top-score-min=[min score]:n:' \
  '--variation-score-min=[min score]:n:' \
  '--unique[unique results]' \
  '(-u --uri)'{-u,--uri}'=[URL or file]:url:' \
  '(-a --user-agent)'{-a,--user-agent}'=[user agent]:ua:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '--json[JSON output]' \
  '--jsonl[JSONL output]' \
  '--raw-http[raw HTTP]' \
  '(-p --payload-position)'{-p,--payload-position}'=[marker]:marker:' \
  '--version[show version]'
