#compdef essentia essentia-cli essentia_streaming_extractor_music essentia_streaming_extractor_freesound essentia_streaming_beatsmarker essentia_streaming_keymarker
# _essentia — Music Technology Group UPF Essentia C++ library and CLI tools for audio analysis music information retrieval (mtg team, C++/Python); custom argparse
# upstream: https://github.com/MTG/essentia

_essentia() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '--profile=+[profile yaml]:file:_files -g "*.yaml *.yml *.json"' \
        '--output=+[output file]:file:_files -g "*.yaml *.yml *.json"' \
        '-o+[output file]:file:_files' \
        '--svm-models-dir=+[dir]:dir:_files -/' \
        '--start-time=+[seconds]:f:' \
        '--end-time=+[seconds]:f:' \
        '--sample-rate=+[Hz]:n:' \
        '--lowlevel-frameSize=+[N]:n:' \
        '--lowlevel-hopSize=+[N]:n:' \
        '--rhythm-method=+[method]:m:(multifeature degara)' \
        '--mood-aggressive[detect mood aggressive]' \
        '--genre-rosamerica[detect genre]' \
        '--tonal-key-method=+[method]:m:(temperley krumhansl edma)' \
        '--namespace=+[namespace]:str:' \
        '--format=+[format]:f:(yaml json)' \
        '*:input audio:_files -g "*.wav *.mp3 *.flac *.ogg *.aiff *.aif *.m4a *.opus"'
}

_essentia "$@"
