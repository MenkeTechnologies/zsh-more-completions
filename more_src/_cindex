#compdef cindex
# Zsh completion for cindex - build code search index (Google Codesearch)
# https://github.com/google/codesearch

_arguments -s -S \
  '-list[list indexed paths and exit]' \
  '-reset[reset the index]' \
  '-verbose[enable verbose output]' \
  '-indexpath=[set path to index file]:index path:_files' \
  '-maxlinelen=[set maximum line length to index]:max line length:' \
  '-maxfilelen=[set maximum file size to index]:max file length:' \
  '-maxtrigrams=[set maximum number of trigrams per file]:max trigrams:' \
  '-cpuprofile=[write CPU profile to file]:profile file:_files' \
  '-logskip[log skipped files to stderr]' \
  '-no-follow-symlinks[do not follow symbolic links]' \
  '*:directory:_files -/'
