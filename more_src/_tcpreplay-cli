#compdef tcpreplay tcpreplay-edit tcpbridge tcpliveplay

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-i --intf1)'{-i+,--intf1=}'[interface 1]:if:_net_interfaces' \
  '(-I --intf2)'{-I+,--intf2=}'[interface 2]:if:_net_interfaces' \
  '(-l --loop)'{-l+,--loop=}'[loop count]:n:' \
  '--loopdelay-ms=[loop delay ms]:ms:' \
  '--loopdelay-ns=[loop delay ns]:ns:' \
  '(-r --duration)'{-r+,--duration=}'[duration s]:s:' \
  '(-K --enable-file-cache)'{-K,--enable-file-cache}'[file cache]' \
  '--preload-pcap[preload pcap]' \
  '(-c --cachefile)'{-c+,--cachefile=}'[cache file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-T --timer)'{-T+,--timer=}'[timer]:t:(select gtod nano)' \
  '(-x --multiplier)'{-x+,--multiplier=}'[multiplier]:m:' \
  '(-p --pps)'{-p+,--pps=}'[packets per sec]:n:' \
  '(-M --mbps)'{-M+,--mbps=}'[megabits per sec]:n:' \
  '(-t --topspeed)'{-t,--topspeed}'[top speed]' \
  '(-o --oneatatime)'{-o,--oneatatime}'[one at a time]' \
  '(-P --pid)'{-P,--pid}'[print pid]' \
  '(--stats)--stats=[stats interval]:n:' \
  '(--no-flow-stats)--no-flow-stats[no flow stats]' \
  '(--flow-expiry)--flow-expiry=[flow expiry]:s:' \
  '(--unique-ip)--unique-ip[unique IPs]' \
  '(--unique-ip-loops)--unique-ip-loops=[loops]:n:' \
  '(--netmap)--netmap[use netmap]' \
  '(--no-cidr)--no-cidr[no CIDR]' \
  '(--include)*--include=[include file]:file:_files' \
  '(--exclude)*--exclude=[exclude file]:file:_files' \
  '(-w --pps-multi)'{-w+,--pps-multi=}'[pps multi]:n:' \
  '(--listnics)--listnics[list NICs]' \
  '(--list)--list[list cores]' \
  '(--snaplen)--snaplen=[snap length]:n:' \
  '(--xdp)--xdp[XDP mode]' \
  '*: :_files -g "*.pcap *.cap"' && ret=0

return ret
