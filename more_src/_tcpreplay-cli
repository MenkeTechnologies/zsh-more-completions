#compdef tcpreplay tcpreplay-edit tcpbridge tcpliveplay
# Documentation: https://tcpreplay.appneta.com/wiki/tcpreplay-man.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-H,--help}'[show usage information]' \
  '(- *)-h[show minimal usage information]' \
  '(- *)--less-help[show minimal usage information]' \
  '(- *)'{-\!,--more-help}'[pass usage info through pager]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --dbug)'{-d+,--dbug=}'[enable debugging output]:level:(0 1 2 3 4 5)' \
  '(-q --quiet)'{-q,--quiet}'[print nothing except stats]' \
  '(-T --timer)'{-T+,--timer=}'[packet timing mode]:t:(select ioport gtod nano)' \
  '--maxsleep=[sleep limit between packets in ms]:ms:' \
  '(-v --verbose)'{-v,--verbose}'[print decoded packets via tcpdump]' \
  '(-A --decode)'{-A+,--decode=}'[args passed to tcpdump decoder]:args:' \
  '(-K --preload-pcap)'{-K,--preload-pcap}'[preload packets into RAM]' \
  '(-c --cachefile)'{-c+,--cachefile=}'[split traffic via tcpprep cache file]:file:_files' \
  '(-2 --dualfile)'{-2,--dualfile}'[replay two files from network tap]' \
  '(-i --intf1)'{-i+,--intf1=}'[primary output interface]:if:_net_interfaces' \
  '(-I --intf2)'{-I+,--intf2=}'[secondary output interface]:if:_net_interfaces' \
  '(-w --write)'{-w+,--write=}'[pcap file to receive output]:file:_files' \
  '*--include=[send only selected packet numbers]:list:' \
  '*--exclude=[send all but selected packet numbers]:list:' \
  '--listnics[list available network interfaces]' \
  '(-l --loop)'{-l+,--loop=}'[loop through capture file N times]:n:' \
  '--loopdelay-ms=[delay between loops in milliseconds]:ms:' \
  '--loopdelay-ns=[delay between loops in nanoseconds]:ns:' \
  '--pktlen[override snaplen and use actual packet length]' \
  '(-L --limit)'{-L+,--limit=}'[limit packets to send]:n:' \
  '--duration=[limit seconds to send]:s:' \
  '(-x --multiplier)'{-x+,--multiplier=}'[modify replay speed multiplier]:m:' \
  '(-p --pps)'{-p+,--pps=}'[packets per second rate]:n:' \
  '(-M --mbps)'{-M+,--mbps=}'[Mbps rate]:n:' \
  '(-t --topspeed)'{-t,--topspeed}'[replay as fast as possible]' \
  '(-o --oneatatime)'{-o,--oneatatime}'[replay one packet at a time]' \
  '--pps-multi=[packets per time interval]:n:' \
  '--unique-ip[generate unique flows per loop iteration]' \
  '--unique-ip-loops=[loop iterations before new unique IP]:n:' \
  '--netmap[write directly to netmap-enabled adapter]' \
  '--nm-delay=[netmap startup delay in seconds]:s:' \
  '--no-flow-stats[suppress flow statistics collection]' \
  '--flow-expiry=[inactive seconds before flow expires]:s:' \
  '(-P --pid)'{-P,--pid}'[print pid at startup]' \
  '--stats=[print stats every X seconds]:n:' \
  '(-W --suppress-warnings)'{-W,--suppress-warnings}'[suppress warning messages]' \
  '--xdp[write directly to AF_XDP-enabled adapter]' \
  '--xdp-batch-size=[max packets submitted to AF_XDP TX ring]:n:' \
  '--save-opts=[save option state to config file]:file:_files' \
  '--load-opts=[load options from config file]:file:_files' \
  '*: :_files -g "*.(pcap|cap)"' && ret=0

return ret
