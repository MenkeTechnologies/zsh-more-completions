#compdef slade
# Documentation: https://github.com/sirjuddington/SLADE/blob/master/src/Application/App.cpp
# Reference accessed: 2026-05-21
# Verified: src/Application/App.cpp processCommandLine() (lines 334-361).
# Args are looped manually via strutil::equalCI; wxCmdLineParser is NOT used.
# Only -nosplash and -debug are real flags.

# SLADE: Doom-engine archive (WAD/PK3) editor and lump manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '-nosplash[disable splash window]' \
  '-debug[enable debug mode]' \
  '*:archive:_files -g "*.(wad|pk3|pk7|zip|7z|pak|grp|rff|hog|lib|res|dat)"' && ret=0
return ret
