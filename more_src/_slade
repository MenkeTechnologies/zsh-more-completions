#compdef slade
# Documentation: https://slade.mancubus.net/index.php?page=manual
# Reference accessed: 2026-05-16

# SLADE: Doom-engine archive (WAD/PK3) editor and lump manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '*:archive:_files -g "*.(wad|pk3|pk7|zip|7z|pak|grp|rff|hog|lib|res|dat)"' && ret=0
return ret
