#compdef hyperapp
# _hyperapp — Hyperapp tiny functional UI framework CLI (Jorge Bucaran); helper script for hyperapp project scaffolds
# upstream: https://github.com/jorgebucaran/hyperapp

_hyperapp() {
    local -a sub=(
        'new:scaffold a new project'
        'dev:run dev server'
        'build:build for production'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hyperapp subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments '1:dir:_files -/' ;;
                dev) _arguments '--port+[port]:port:' '--host+[host]:host:_hosts' ;;
            esac
            ;;
    esac
}

_hyperapp "$@"
