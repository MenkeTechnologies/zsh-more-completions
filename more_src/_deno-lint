#compdef deno-lint dlint
# Documentation: https://github.com/denoland/deno_lint
# Reference accessed: 2026-05-17
# Verified: denoland/deno_lint upstream. NOTE: there is no standalone
# `deno-lint` binary upstream — the production linter is `deno lint`
# (a Deno runtime subcommand); the example binary in this crate is
# `dlint`. This completion targets both names for compatibility.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --no-config (real `deno lint` uses --no-config).

# deno-lint / dlint: Deno linter (matches `deno lint` flag surface)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[config file]:file:_files -g "deno.json*(-.)"' \
  '--no-config[do not use config file]' \
  '--rules[list available rules]' \
  '--rules-tags=[include rules with tags]:tags:' \
  '--rules-include=[include rules]:rules:' \
  '--rules-exclude=[exclude rules]:rules:' \
  '--ignore=[ignore paths]:paths:' \
  '--json[output as JSON]' \
  '--compact[compact format]' \
  '--watch[watch mode]' \
  '--fix[apply fixes]' \
  '*:file:_files -g "*.(ts|tsx|js|jsx|mjs|mts|cjs|cts)(-.)"' && ret=0
return ret
