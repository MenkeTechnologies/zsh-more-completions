#compdef deno-lint
# Documentation: https://man.archlinux.org/search?q=deno-lint
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[config file]:config:_files -g "deno.json*(-.)"' \
  '--no-config[do not use config file]' \
  '--ignore=[ignore files]:files' \
  '--json[output as JSON]' \
  '--compact[use compact format]' \
  '--rules[list available rules]' \
  '--rules-include=[include rules]:rules' \
  '--rules-exclude=[exclude rules]:rules' \
  '--rules-tags=[include rules with tags]:tags' \
  '--watch[watch for file changes]' \
  '*:file:_files' && return 0
