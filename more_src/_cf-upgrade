#compdef cf-upgrade
# Documentation: https://docs.cfengine.com/docs/master/reference-components-cf-upgrade.html
# Source: cfengine/core cf-upgrade/command_line.c — CFEngine package upgrade helper (small custom parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-v[show version]' \
    '-c+[copy path]:path:_files' \
    '-b+[backup tool]:tool:_default' \
    '-s+[backup path]:path:_directories' \
    '-f+[CFEngine path]:path:_directories' \
    '-i[copy and fork (initial update)]' \
    '-x[perform upgrade]' \
    '*:update command args:_default' \
    && ret=0

return ret
