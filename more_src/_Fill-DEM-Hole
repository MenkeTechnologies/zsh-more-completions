#compdef Fill-DEM-Hole
# Documentation: https://raw.githubusercontent.com/senbox-org/snap-engine/master/snap-dem/src/main/java/org/esa/snap/dem/gpf/FillDEMHoleOp.java
# ESA SNAP gpt Fill-DEM-Hole operator - fill no-data holes in a DEM band

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PsourceBands=[the list of source bands]:bands' \
  '-PNoDataValue=[the no data value to fill]:value' \
  '*:graph xml:_files' && ret=0

return ret
