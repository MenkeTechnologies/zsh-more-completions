#compdef rspress
# Documentation: https://rspress.rs
# Source: https://github.com/web-infra-dev/rspress/blob/main/packages/core/src/cli/index.ts
# Reference accessed: 2026-06-01
# Rsbuild-based static site generator with MDX support.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _rp_cmds
_rp_cmds=(
    'dev:start dev server (default)'
    'build:build for production'
    'preview:preview built output'
    'serve:alias for preview'
    'eject:eject a theme component to customize it'
)

_arguments -C \
    '(-c --config)'{-c+,--config=}'[path to config file]:config:_files' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'rspress command' _rp_cmds && ret=0
        ;;
    args)
        case $line[1] in
            dev|preview|serve)
                _arguments -s -S \
                    '--port=[port number]:port:_default' \
                    '--host=[hostname]:host:_default' \
                    '--base=[deployment base path]:base:_default' \
                    '1:root:_files -/' && ret=0
                ;;
            build)
                _arguments -s -S \
                    '--base=[deployment base path]:base:_default' \
                    '1:root:_files -/' && ret=0
                ;;
            eject)
                _arguments -s -S \
                    '1:component name:_default' && ret=0
                ;;
        esac
        ;;
esac

return ret
