#compdef rsgisimg2webtiles
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgisimg2webtiles RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Input image.]:value:_files' \
  '(-o --output)'{-o,--output}'[Output directory within which the tile cache can be found.]:value:_files' \
  '(-b --bands)'{-b,--bands}'[Comma seperated set of bands. Either single or r,g,b.]:value:_files' \
  '(-z --zoom)'{-z,--zoom}'[What zoom levels do you wish to be calculated, e.g., 2-10, 1-12.]:value:_files' \
  '(-r --resample)'{-r,--resample}'[Method of resampling to produce the tile cache; Default\: average]:value:(average near bilinear cubic cubicspline lanczos antialias)' \
  '(-f --finite)'{-f,--finite}'[Apply a finite mask to the input image before stretching.]' \
  '--xyz[Output the tile cache in XYZ format rather than TMS.]' \
  '*:file:_files' && ret=0

return ret
