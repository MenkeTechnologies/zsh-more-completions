#compdef rspack

# Zsh completion for Rspack bundler CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:Run rspack build'
      'serve:Run rspack dev server'
    )
    _describe -t commands 'rspack command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
          '(-m --mode)'{-m,--mode}'[build mode]:mode:(development production none)' \
          '--entry=[entry point]:entry file:_files' \
          '(-o --output-path)'{-o,--output-path}'[output path]:directory:_directories' \
          '--env=[environment variables]:env' \
          '(-w --watch)'{-w,--watch}'[watch mode]' \
          '--devtool=[source map strategy]:devtool:(eval source-map cheap-source-map cheap-module-source-map eval-source-map eval-cheap-source-map eval-cheap-module-source-map inline-source-map inline-cheap-source-map inline-cheap-module-source-map hidden-source-map nosources-source-map)' \
          '--analyze[enable bundle analysis]' \
          '--json=[output stats as JSON]:file:_files' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
          '(-m --mode)'{-m,--mode}'[build mode]:mode:(development production none)' \
          '--entry=[entry point]:entry file:_files' \
          '(-o --output-path)'{-o,--output-path}'[output path]:directory:_directories' \
          '--env=[environment variables]:env' \
          '--port=[port to listen on]:port' \
          '--host=[hostname to listen on]:host' \
          '--hot[enable hot module replacement]' \
          '--open[open browser on server start]' \
          '--devtool=[source map strategy]:devtool:(eval source-map cheap-source-map cheap-module-source-map eval-source-map eval-cheap-source-map eval-cheap-module-source-map inline-source-map inline-cheap-source-map inline-cheap-module-source-map hidden-source-map nosources-source-map)' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
