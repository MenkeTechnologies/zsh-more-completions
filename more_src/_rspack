#compdef rspack
# Documentation: https://rspack.rs/guide/start/quick-start
# Reference accessed: 2026-05-21
# Verified: source at https://raw.githubusercontent.com/web-infra-dev/rspack/main/packages/rspack-cli/src/utils/options.ts

# Zsh completion for Rspack bundler CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:run rspack build'
      'serve:run rspack dev server (aka dev)'
      'preview:preview the built production artifacts'
    )
    _describe -t commands 'rspack command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'=[config file path]:file:_files' \
          '--config-name=[name(s) of the configuration to use]:name:' \
          '--config-loader=[config loader]:loader:(auto jiti native)' \
          '*--env=[env passed to config function]:env:' \
          '--node-env=[set process.env.NODE_ENV]:value:' \
          '(-d --devtool)'{-d,--devtool}'=[source map style]:value:' \
          '*--entry=[entry file]:entry:_files' \
          '(-m --mode)'{-m,--mode}'=[build mode]:mode:(development production none)' \
          '(-o --output-path)'{-o,--output-path}'=[output path dir]:dir:_directories' \
          '(-w --watch)'{-w,--watch}'[watch mode]' \
          '--json=[emit stats json]:path:_files' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      serve|dev)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'=[config file path]:file:_files' \
          '--config-name=[name(s) of the configuration to use]:name:' \
          '--config-loader=[config loader]:loader:(auto jiti native)' \
          '*--env=[env passed to config function]:env:' \
          '--node-env=[set process.env.NODE_ENV]:value:' \
          '(-d --devtool)'{-d,--devtool}'=[source map style]:value:' \
          '*--entry=[entry file]:entry:_files' \
          '(-m --mode)'{-m,--mode}'=[build mode]:mode:(development production none)' \
          '(-o --output-path)'{-o,--output-path}'=[output path dir]:dir:_directories' \
          '(-w --watch)'{-w,--watch}'[watch mode]' \
          '--hot=[enables hot module replacement]:mode:' \
          '--port=[port to listen on]:port:' \
          '--host=[hostname to listen on]:host:_hosts' \
          '--open=[open browser on server start]:value:' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      preview)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'=[config file path]:file:_files' \
          '--public-path=[static resource server path]:path:' \
          '--port=[preview server port]:port:' \
          '--host=[preview server host]:host:_hosts' \
          '--open[open browser]' \
          '--server=[server configuration]:config:' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
