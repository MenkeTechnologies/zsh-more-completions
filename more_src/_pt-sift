#compdef pt-sift
# Documentation: https://docs.percona.com/percona-toolkit/pt-sift.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '*:dir_or_prefix:_files' && ret=0

return ret
