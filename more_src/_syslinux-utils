#compdef syslinux-utils

# syslinux-utils: extra utilities bundled with syslinux (gethostip, isohybrid, etc.)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'gethostip:hex format IP for PXE'
  'isohybrid:make ISO bootable as hybrid USB image'
  'mboot:multiboot loader helper'
  'lss16toppm:convert LSS16 image to PPM'
  'ppmtolss16:convert PPM to LSS16'
  'memdiskfind:locate memdisk image in memory'
  'sdi:syslinux disk image helper'
  'pxelinux:PXELINUX loader'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'syslinux-utils command' commands && ret=0 ;;
esac
return ret
