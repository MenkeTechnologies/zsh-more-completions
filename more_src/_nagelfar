#compdef nagelfar
# Documentation: https://wiki.tcl-lang.org/page/Nagelfar
# Static syntax checker for Tcl

local ret=1

_arguments -s \
  '(-help -h)'{-help,-h}'[show usage]' \
  '-gui[start with GUI even when files are specified]' \
  '*-s[include a database file]:dbfile:_files' \
  '-encoding[read script with this encoding]:encoding:' \
  '-filter[suppress any message matching the glob pattern]:pattern:' \
  '-severity[set severity level filter to N/W/E]:level:(N W E)' \
  '-html[generate html output]' \
  '-prefix[prefix for line anchors in html output]:prefix:' \
  '-novar[disable variable checking]' \
  '-strictappend[enforce an initialised variable in (l)append]' \
  '-tab[tab size (default 8)]:size:' \
  '-header[create a header file with syntax info]:file:_files' \
  '-instrument[instrument source file for code coverage]' \
  '-markup[markup source file with code coverage result]' \
  '-quiet[suppress non-syntax output]' \
  '-glob[add matching files to scriptfiles to check]:pattern:' \
  '-H[prefix each error line with file name]' \
  '-exitcode[return status 2 for error or 1 for warning]' \
  '*:script file:_files' && ret=0

return ret
