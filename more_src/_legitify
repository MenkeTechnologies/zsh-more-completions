#compdef legitify

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'analyze:analyze GitHub/GitLab organization security'
  'gpt-analysis:GPT-powered analysis of findings'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'legitify command' commands && ret=0
    ;;
  args)
    case $line[1] in
      analyze)
        _arguments -s -S \
          '--org[organization name]:org:' \
          '--repo[specific repository]:repo:' \
          '--token[access token]:token:' \
          '--scm[SCM provider]:provider:(github gitlab)' \
          '--output-format[output format]:format:(human json sarif markdown)' \
          '--output-file[output file]:file:_files' \
          '--namespace[policy namespace]:namespace:(organization repository member actions runner_group)' \
          '--scorecard[enable OpenSSF Scorecard]' \
          '--color[color output]:when:(auto always never)' \
          '--failed-only[show only failed checks]' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
