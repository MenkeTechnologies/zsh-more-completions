#compdef pdb_reres
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Renumbers the residues of the PDB file starting from a given number

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[starting residue number, e.g. -1]:start number' \
  '*:PDB file:_files' && ret=0

return ret
