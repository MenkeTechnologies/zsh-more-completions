#compdef ssl_client1 ssl_client2
# Documentation: https://github.com/Mbed-TLS/mbedtls/blob/development/programs/ssl/ssl_client1.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
#
# ssl_client1 is a hardcoded demo program with NO command-line arguments.
# ssl_client2 accepts param=value style options; only the most common are listed here.

local curcontext="$curcontext" state line ret=1
local -a params

# Subset of ssl_client2 param=value options verified against programs/ssl/ssl_client2.c
params=(
  'server_name=:server hostname'
  'server_addr=:server address'
  'server_port=:server port'
  'debug_level=:debug level (0-65535)'
  'ca_file=:trusted CA file'
  'ca_path=:trusted CA directory'
  'crt_file=:client certificate'
  'key_file=:client key'
  'key_pwd=:client key password'
  'psk=:pre-shared key'
  'psk_identity=:PSK identity'
  'force_ciphersuite=:force a single ciphersuite'
  'min_version=:minimum TLS version'
  'max_version=:maximum TLS version'
  'auth_mode=:authentication mode'
)

if [[ ${words[1]} == ssl_client1 ]]; then
  # ssl_client1 takes no arguments
  return 1
fi

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    if compset -P '(ca_file|crt_file|key_file)='; then
      _files && ret=0
    elif compset -P 'ca_path='; then
      _files -/ && ret=0
    elif compset -P 'auth_mode='; then
      _values 'auth mode' none optional required && ret=0
    elif compset -P '(min_version|max_version)='; then
      _values 'TLS version' tls12 tls13 dtls12 && ret=0
    else
      _describe -t params 'param' params -S '' && ret=0
    fi
    ;;
esac

return ret
