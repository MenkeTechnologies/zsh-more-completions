#compdef mscan
# Documentation: https://manpages.debian.org/testing/mblaze/mscan.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. mblaze mscan one-line summaries.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[format string (printf-inspired)]:format:' \
  '-n[print message numbers/filenames only]' \
  '-I[force ISO date output even for %d]' \
  '-v[print scan count to stderr]' \
  '*:message:_files' && ret=0

return ret
