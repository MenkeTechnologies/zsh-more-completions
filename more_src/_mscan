#compdef mscan
# Documentation: https://man.archlinux.org/search?q=mscan
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[output format string]:format:' \
  '-n[number of messages to print]:number:' \
  '-I[print message filename]' \
  '*:message:_files' && ret=0

return ret
