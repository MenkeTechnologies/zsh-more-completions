#compdef vk
# _vk — CLI client for the Vikunja to-do app (JMARyA/vk)
# upstream: https://github.com/JMARyA/vk
# Subcommands + flags from src/args.rs (argh).

_vk() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-d --done)'{-d,--done}'[show completed tasks too]' \
        '(-f --favorite)'{-f,--favorite}'[show only favorites]' \
        '--from=[show only tasks from this project]:project:' \
        '(-l --label)'{-l+,--label=}'[show only tasks with label]:label:' \
        '(-j --json)'{-j,--json}'[JSON output]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_vk_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                prj)
                    _arguments '1:project subcommand:(ls add rm)'
                    ;;
                labels)
                    _arguments '1:label subcommand:(ls new rm)'
                    ;;
                login)
                    _arguments \
                        '--username=[Vikunja username]:user:' \
                        '--password=[Vikunja password]:password:' \
                        '--totp=[TOTP code]:totp:' \
                        '--host=[Vikunja server host]:host:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_vk_commands] )) ||
_vk_commands() {
    local -a commands
    commands=(
        'info:show information on a task'
        'edit:edit a task'
        'rm:delete a task'
        'done:mark task as done (-u to undo)'
        'new:create a new task'
        'login:get a JWT auth token and store it'
        'assign:assign a user to a task'
        'comments:list comments on a task'
        'comment:add a comment to a task'
        'relation:manage task relations'
        'fav:toggle favorite on a task'
        'label:add / remove a label on a task'
        'check:check a checklist item in a task description'
        'stats:show overall stats'
        'prj:manage projects (ls / add / rm)'
        'labels:manage labels (ls / new / rm)'
    )
    _describe -t commands 'vk command' commands
}

_vk "$@"
