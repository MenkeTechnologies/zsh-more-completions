#compdef hv_kvp_daemon hv-kvp-daemon
# _hv-kvp — Linux hv_kvp_daemon (Hyper-V Key/Value Pair integration daemon: lets the Hyper-V host read and write KVPs (IP config, intrinsic guest info) inside the guest; -n no daemonize, -d debug output, -p pool dir override)
# upstream: https://git.kernel.org/pub/scm/linux/kernel/git/torvalds/linux.git (tools/hv)
# Flags from kernel tools/hv/hv_kvp_daemon.c on tip.

_hv-kvp() {
    _arguments \
        '-h[show help]' \
        '-n[no daemonize]' \
        '-d[debug]' \
        '-p+[pool directory]:dir:_files -/'
}

_hv-kvp "$@"
