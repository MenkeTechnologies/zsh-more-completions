#compdef wt
# Documentation: https://learn.microsoft.com/en-us/windows/terminal/command-line-arguments
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Top-level options table from Microsoft Learn:
#   --help/-h/-?, --maximized/-M, --fullscreen/-F, --focus/-f, --pos, --size,
#   --window/-w (id or 'new'/'-1', 'last'/'0', name).
# Subcommands: new-tab/nt, split-pane/sp, focus-tab/ft, move-focus/mf,
# move-pane/mp, swap-pane.
# Removed from prior file:
#   -v/--version (not documented), top-level -p/-d/--title/etc (those are
#   new-tab/split-pane flags), focus-tab -n/--next/-p/--previous (docs only
#   show --target/-t), move-focus 'last' (not documented), swap-pane 'next'
#   (not documented), 'last' in -w (correct is '0' alias for 'last', plus
#   reserved 'new'/'-1', '_quake').
# Added per docs: --pos, --size, -M, -F, -f, --useApplicationTitle,
# --appendCommandLine, --inheritEnvironment, --reloadEnvironment, -D.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help -? /?)'{-h,--help,-\?,/\?}'[show help]' \
  '(-M --maximized)'{-M,--maximized}'[launch maximized]' \
  '(-F --fullscreen)'{-F,--fullscreen}'[launch fullscreen]' \
  '(-f --focus)'{-f,--focus}'[launch in focus mode]' \
  '--pos=[launch at position x,y]:pos:' \
  '--size=[launch with columns,rows]:size:' \
  '(-w --window)'{-w+,--window=}'[target window id, name, new, -1, last, 0, _quake]:window:(0 -1 new last _quake)' \
  '1:subcommand:->cmds' \
  '*::arg:->args' && ret=0

case "$state" in
  cmds)
    local -a subcmds
    subcmds=(
      'new-tab:open a new tab'
      'nt:alias for new-tab'
      'split-pane:split the current pane'
      'sp:alias for split-pane'
      'focus-tab:focus on a specific tab'
      'ft:alias for focus-tab'
      'move-focus:move focus between panes'
      'mf:alias for move-focus'
      'move-pane:move pane to another tab'
      'mp:alias for move-pane'
      'swap-pane:swap the focused pane'
    )
    _describe -t commands 'wt subcommand' subcmds && ret=0
    ;;
  args)
    case "$words[1]" in
      new-tab|nt)
        _arguments \
          '(-p --profile)'{-p+,--profile=}'[profile name]:profile:' \
          '(-d --startingDirectory)'{-d+,--startingDirectory=}'[starting directory]:directory:_directories' \
          '--title=[tab title]:title:' \
          '--tabColor=[tab color (#RGB or #RRGGBB)]:color:' \
          '--suppressApplicationTitle[suppress application title]' \
          '--useApplicationTitle[allow application title changes]' \
          '--colorScheme=[color scheme name]:scheme:' \
          '--appendCommandLine[append commandline to profile default]' \
          '--inheritEnvironment[inherit env when creating session]' \
          '--reloadEnvironment[fresh environment block]' \
          '*:command:_command_names -e' && ret=0
        ;;
      split-pane|sp)
        _arguments \
          '(-H --horizontal -V --vertical)'{-H,--horizontal}'[split horizontally]' \
          '(-H --horizontal -V --vertical)'{-V,--vertical}'[split vertically]' \
          '(-p --profile)'{-p+,--profile=}'[profile name]:profile:' \
          '(-d --startingDirectory)'{-d+,--startingDirectory=}'[starting directory]:directory:_directories' \
          '--title=[pane title]:title:' \
          '--tabColor=[tab color]:color:' \
          '(-s --size)'{-s+,--size=}'[size as fraction of parent pane (e.g. .4)]:size:' \
          '--suppressApplicationTitle[suppress application title]' \
          '--useApplicationTitle[allow application title changes]' \
          '--colorScheme=[color scheme name]:scheme:' \
          '(-D --duplicate)'{-D,--duplicate}'[duplicate focused pane]' \
          '*:command:_command_names -e' && ret=0
        ;;
      focus-tab|ft)
        _arguments \
          '(-t --target)'{-t+,--target=}'[tab index]:index:' && ret=0
        ;;
      move-focus|mf)
        _arguments \
          '1:direction:(up down left right first previous nextInOrder previousInOrder)' && ret=0
        ;;
      move-pane|mp)
        _arguments \
          '(-t --tab)'{-t+,--tab=}'[target tab index (zero-based)]:index:' && ret=0
        ;;
      swap-pane)
        _arguments \
          '1:direction:(up down left right first previous nextInOrder previousInOrder)' && ret=0
        ;;
    esac
    ;;
esac

return ret
