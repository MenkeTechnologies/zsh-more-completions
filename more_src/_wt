#compdef wt

# Zsh completion for wt - Windows Terminal CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--maximized[launch maximized]' \
  '--fullscreen[launch fullscreen]' \
  '--focus[launch in focus mode]' \
  '-w+[target window]:window:(0 -1 new last)' \
  '--window[target window]:window:(0 -1 new last)' \
  '-p+[specify profile]:profile name' \
  '--profile[specify profile]:profile name' \
  '-d+[starting directory]:directory:_directories' \
  '--startingDirectory[starting directory]:directory:_directories' \
  '--title[set tab title]:title' \
  '--tabColor[set tab color]:color' \
  '--suppressApplicationTitle[suppress application title changes]' \
  '--colorScheme[set color scheme]:scheme' \
  '1:subcommand:->cmds' \
  '*::arg:->args' && ret=0

case "$state" in
  cmds)
    local -a subcmds
    subcmds=(
      'new-tab:open a new tab'
      'split-pane:split the current pane'
      'focus-tab:focus on a specific tab'
      'move-focus:move focus between panes'
      'move-pane:move pane to another tab'
      'swap-pane:swap the focused pane'
    )
    _describe -t commands 'wt subcommand' subcmds && ret=0
    ;;
  args)
    case "$words[1]" in
      new-tab)
        _arguments \
          '-p+[profile]:profile name' \
          '--profile[profile]:profile name' \
          '-d+[starting directory]:directory:_directories' \
          '--startingDirectory[starting directory]:directory:_directories' \
          '--title[tab title]:title' \
          '--tabColor[tab color]:color' \
          '--suppressApplicationTitle[suppress application title]' \
          '--colorScheme[color scheme]:scheme' \
          '*:command:_command_names -e' && ret=0
        ;;
      split-pane)
        _arguments \
          '-H[split horizontally]' \
          '-V[split vertically]' \
          '--horizontal[split horizontally]' \
          '--vertical[split vertically]' \
          '-p+[profile]:profile name' \
          '--profile[profile]:profile name' \
          '-d+[starting directory]:directory:_directories' \
          '--startingDirectory[starting directory]:directory:_directories' \
          '--title[pane title]:title' \
          '--tabColor[tab color]:color' \
          '-s+[size as fraction]:size' \
          '--size[size as fraction]:size' \
          '--suppressApplicationTitle[suppress application title]' \
          '--colorScheme[color scheme]:scheme' \
          '--duplicate[duplicate focused pane]' \
          '*:command:_command_names -e' && ret=0
        ;;
      focus-tab)
        _arguments \
          '-t+[tab index]:index' \
          '--target[tab index]:index' \
          '-n[focus next tab]' \
          '--next[focus next tab]' \
          '-p[focus previous tab]' \
          '--previous[focus previous tab]' && ret=0
        ;;
      move-focus)
        _arguments \
          '1:direction:(up down left right first last nextInOrder previousInOrder)' && ret=0
        ;;
      move-pane)
        _arguments \
          '-t+[target tab index]:index' \
          '--tab[target tab index]:index' && ret=0
        ;;
      swap-pane)
        _arguments \
          '1:direction:(up down left right first last next previous nextInOrder previousInOrder)' && ret=0
        ;;
    esac
    ;;
esac

return ret
