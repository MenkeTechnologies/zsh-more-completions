#compdef mdbook-test
# Documentation: https://rust-lang.github.io/mdBook/cli/test.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for mdbook test subcommand (standalone)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-L --library-path)'{-L+,--library-path=}'[library search path for rustdoc]:directory:_directories' \
  '(-c --chapter)'{-c+,--chapter=}'[test a specific chapter]:chapter:' \
  '1:directory:_directories' && ret=0

return ret
