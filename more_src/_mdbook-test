#compdef mdbook-test

# Zsh completion for mdbook test subcommand (standalone)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-d+[output directory]:directory:_directories' \
  '--dest-dir=[output directory]:directory:_directories' \
  '-L+[library directory to add to rustdoc search path]:directory:_directories' \
  '--library-path=[library directory to add to rustdoc search path]:directory:_directories' \
  '1:directory:_directories' && ret=0

return ret
