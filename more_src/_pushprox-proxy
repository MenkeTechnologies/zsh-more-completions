#compdef pushprox-proxy
# Documentation: https://github.com/prometheus-community/PushProx
# PushProx proxy that brokers scrapes between Prometheus and clients

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--web.listen-address=[address to listen on for proxy and client requests]:addr' \
  '--scrape.max-timeout=[clamp any scrape timeout higher than this]:dur' \
  '--scrape.default-timeout=[use this value if a scrape lacks a timeout]:dur' && ret=0

return ret
