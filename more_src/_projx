#compdef projx
# Documentation: https://www.npmjs.com/package/projx
# Reference accessed: 2026-05-23
# Verified: npm view projx bin.

# Zsh completion for projx - ewdjs project manager CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a projx project'
  'build:build the project'
  'dev:start development server'
  'deploy:deploy the project'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'projx command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
