#compdef vitepress

# Zsh completion for vitepress - VitePress static site generator

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'dev:Start development server'
      'build:Build for production'
      'preview:Preview production build locally'
      'init:Initialize a new VitePress project'
    )
    _describe -t commands 'vitepress command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      dev)
        _arguments -s -S \
          '--port[specify port]:port' \
          '--host[specify host]:host' \
          '--open[open browser on startup]' \
          '--force[force the optimizer to ignore cache and re-bundle]' \
          '--base[public base path]:path' \
          '--cors[enable CORS]' \
          '--strictPort[exit if specified port is already in use]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:root:_directories' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--base[public base path]:path' \
          '--outDir[output directory]:directory:_directories' \
          '--minify[enable/disable minification]:minifier:(terser esbuild false)' \
          '--assetsInlineLimit[static asset base64 inline threshold in bytes]:size' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:root:_directories' && ret=0
        ;;
      preview)
        _arguments -s -S \
          '--port[specify port]:port' \
          '--host[specify host]:host' \
          '--open[open browser on startup]' \
          '--base[public base path]:path' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:root:_directories' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:root:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
