#compdef cuda-gdbserver
# Documentation: https://docs.nvidia.com/cuda/cuda-gdb/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cuda-gdbserver: GDB server for CUDA
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--multi[multi-process mode]' \
  '--attach=[attach to PID]:pid:' \
  '--cuda-use-lockfile=[use lockfile]:val:(0 1)' \
  '*:host\:port program:' && ret=0
return ret
