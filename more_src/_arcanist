#compdef arc

# Zsh completion for arc (Arcanist) - Phabricator command-line tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '--conduit-uri=[Phabricator URI]:URI' \
  '--conduit-token=[API token]:token' \
  '--trace[enable tracing]' \
  '--no-ansi[disable ANSI output]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case "$state" in
  subcmd)
    local -a subcmds=(
      'diff:create or update a code review'
      'land:merge an accepted revision'
      'patch:apply a patch from a revision'
      'branch:create or checkout a branch'
      'browse:open a URI in a browser'
      'todo:create a task'
      'lint:run static analysis on changes'
      'unit:run unit tests on changes'
      'which:show which revision is in the working copy'
      'close-revision:close a revision'
      'close:close a task or revision'
      'feature:manage feature branches'
      'tasks:show assigned tasks'
      'upload:upload a file'
      'download:download a file'
      'amend:amend the working copy'
      'commit:finalize a revision'
      'export:export a diff or revision'
      'help:show help for a command'
      'install-certificate:install an API certificate'
      'linters:list available linters'
      'shell-complete:generate shell completion'
      'version:show version information'
      'call-conduit:make a raw Conduit API call'
      'get-config:read a configuration value'
      'set-config:set a configuration value'
      'alias:manage command aliases'
      'anoid:show Arcanist user ID'
      'bookmarks:show bookmarks'
      'cascade:cascade changes'
      'cover:find reviewers for a path'
      'flag:manage flags on objects'
      'graft:copy commits from one branch to another'
      'inspect:inspect internal data'
      'liberate:create or update an Arcanist library'
      'look:look up objects'
      'paste:create or read pastes'
      'revert:revert a commit'
      'start:start work on a task'
      'stop:stop work on a task'
      'time:show time tracking info'
      'weld:weld dependencies together'
    )
    _describe -t subcommands 'arc subcommand' subcmds && ret=0
    ;;
  args)
    case "${line[1]}" in
      diff)
        _arguments -s -S \
          '--conduit-uri=[Phabricator URI]:URI' \
          '--conduit-token=[API token]:token' \
          '--trace[enable tracing]' \
          '--no-ansi[disable ANSI output]' \
          {-m,--message}'[provide a diff summary]:message' \
          '--reviewers=[comma-separated list of reviewers]:reviewers' \
          '--cc=[comma-separated list of subscribers]:subscribers' \
          '--allow-untracked[do not warn about untracked files]' \
          '--less-context[show less context in diffs]' \
          '--create[always create a new revision]' \
          '--update=[always update a specific revision]:revision ID' \
          '--nounit[do not run unit tests]' \
          '--nolint[do not run lint]' \
          '--plan-changes[create as planning changes]' \
          '--browse[open revision in browser after creating]' \
          '--only[only generate a diff, without creating a revision]' \
          '--raw[emit raw diff to stdout]' \
          '--base=[specify base commit]:commit' \
          '--no-diff[do not attach a diff]' \
          '--verbatim[use the working copy commit message verbatim]' \
          '--json[output as JSON]' \
          '--excuse=[provide an excuse for lint or test failures]:excuse' \
          '*:path:_files' && ret=0
        ;;
      land)
        _arguments -s -S \
          '--conduit-uri=[Phabricator URI]:URI' \
          '--conduit-token=[API token]:token' \
          '--trace[enable tracing]' \
          '--no-ansi[disable ANSI output]' \
          '--onto=[target branch to land onto]:branch' \
          '--remote=[remote to push to]:remote' \
          '--hold[do not push after merging]' \
          '--keep-branch[do not delete the feature branch]' \
          '--revision=[revision to land]:revision ID' \
          '--preview[preview the land operation without executing]' \
          '--squash[squash commits when landing]' \
          '--merge[merge commits when landing]' \
          '*:branch' && ret=0
        ;;
      patch)
        _arguments -s -S \
          '--conduit-uri=[Phabricator URI]:URI' \
          '--conduit-token=[API token]:token' \
          '--trace[enable tracing]' \
          '--no-ansi[disable ANSI output]' \
          '1:revision or diff ID' && ret=0
        ;;
      help)
        _arguments -s -S \
          '1:command:(diff land patch branch browse todo lint unit which close-revision close feature tasks upload download amend commit export install-certificate linters shell-complete version call-conduit get-config set-config alias)' && ret=0
        ;;
      upload)
        _arguments -s -S \
          '--conduit-uri=[Phabricator URI]:URI' \
          '--conduit-token=[API token]:token' \
          '*:file:_files' && ret=0
        ;;
      download)
        _arguments -s -S \
          '--conduit-uri=[Phabricator URI]:URI' \
          '--conduit-token=[API token]:token' \
          '1:file ID' \
          '2:output path:_files' && ret=0
        ;;
      *)
        _arguments -s -S \
          '--conduit-uri=[Phabricator URI]:URI' \
          '--conduit-token=[API token]:token' \
          '--trace[enable tracing]' \
          '--no-ansi[disable ANSI output]' \
          '*:argument' && ret=0
        ;;
    esac
    ;;
esac

return ret
