#compdef extractseq
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/extractseq.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# EMBOSS extractseq: extract regions from a sequence
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-regions=[regions to extract (start..end,start..end)]:regions:' \
  '-separate[produce one output sequence per region]' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output format]:format:(fasta embl genbank gff swiss gcg pir nbrf raw msf ace text)' \
  '*:sequence USA:_files' && ret=0
return ret
