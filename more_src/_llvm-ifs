#compdef llvm-ifs
# _llvm-ifs — LLVM interface stub tool (LLVM project, C++); generate Linux ELF stub shared objects from .ifs ABI files
# upstream: https://github.com/llvm/llvm-project

_llvm-ifs() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--input-format=+[input format]:fmt:(IFS ELF)' \
        '--output-format=+[output format]:fmt:(IFS TBD ELF)' \
        '--output=+[output file]:file:_files' \
        '--output-elf=+[output ELF]:file:_files' \
        '--output-ifs=+[output IFS]:file:_files' \
        '--output-tbd=+[output TBD]:file:_files' \
        '--arch=+[arch]:arch:' \
        '--bitwidth=+[bitwidth]:n:(32 64)' \
        '--endianness=+[endianness]:e:(little big)' \
        '--target=+[target]:triple:' \
        '--soname=+[soname]:str:' \
        '--hint-ifs-target=+[hint ifs target]:triple:' \
        '--strip-needed[strip needed]' \
        '--strip-size[strip size]' \
        '--strip-undefined[strip undefined]' \
        '--strip-ifs-arch[strip ifs arch]' \
        '--strip-ifs-bitwidth[strip ifs bitwidth]' \
        '--strip-ifs-endianness[strip ifs endianness]' \
        '--strip-ifs-target[strip ifs target]' \
        '--exclude=+[exclude symbol]:sym:' \
        '--write-if-changed[write if changed]' \
        '*:file:_files'
}

_llvm-ifs "$@"
