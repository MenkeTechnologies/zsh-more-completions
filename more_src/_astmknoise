#compdef astmknoise
# Documentation: https://www.gnu.org/software/gnuastro/manual/html_node/Invoking-astmknoise.html
# astmknoise — add noise to all pixels in an input dataset

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[only report errors, remain quiet about steps]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and abort]' \
  '(-N --numthreads)'{-N,--numthreads}'[number of CPU threads to use]:number' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[type of output]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--wcslinearmatrix[WCS linear matrix of output]:matrix:(pc cd)' \
  '(-h --hdu)'{-h,--hdu}'[extension name or number of input data]:HDU' \
  '(-I --ignorecase)'{-I,--ignorecase}'[ignore case when matching column names]' \
  '(-b --background)'{-b,--background}'[fixed background magnitude for whole input]:magnitude' \
  '(-i --instrumental)'{-i,--instrumental}'[instrument noise level in pixel value units]:value' \
  '(-s --sigma)'{-s,--sigma}'[total noise sigma, ignore other options]:sigma' \
  '(-z --zeropoint)'{-z,--zeropoint}'[zeropoint magnitude of input]:magnitude' \
  '(-B --bgisbrightness)'{-B,--bgisbrightness}'[background is brightness, not magnitude]' \
  '(-e --envseed)'{-e,--envseed}'[use GSL_RNG_SEED environment variable for seed]' \
  '*:input:_files' && ret=0

return ret
