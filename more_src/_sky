#compdef sky

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'launch:launch a cluster or task'
  'exec:execute a task on existing cluster'
  'stop:stop clusters'
  'start:restart clusters'
  'down:tear down clusters'
  'status:show clusters'
  'autostop:schedule autostop/autodown'
  'queue:show job queue'
  'cancel:cancel jobs'
  'logs:tail job logs'
  'check:verify cloud credentials'
  'show-gpus:list available GPUs'
  'dashboard:open dashboard'
  'cost-report:show cost report'
  'jobs:managed jobs operations'
  'serve:SkyServe service serving'
  'storage:storage objects'
  'volumes:managed volumes'
  'api:API server interactions'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sky subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (launch|exec)
        _arguments \
          '(-c --cluster)'{-c,--cluster=}'[cluster name]:name:' \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' \
          '--detach-run[detach run]' \
          '(-n --name)'{-n,--name=}'[task name]:name:' \
          '--workdir=[working directory]:dir:_files -/' \
          '--infra=[infrastructure]:infra:' \
          '--cpus=[CPU count]:n:' \
          '--memory=[memory]:mem:' \
          '--disk-size=[disk size]:gb:' \
          '--gpus=[GPU spec]:gpu:' \
          '--instance-type=[instance type]:type:' \
          '--ports=[ports]:ports:' \
          '--idle-minutes-to-autostop=[autostop minutes]:n:' \
          '--down[autodown]' \
          '--use-spot[use spot instances]' \
          '--region=[region]:region:' \
          '--zone=[zone]:zone:' \
          '--image-id=[image id]:id:' \
          '*--env=[env var]:key=value:' \
          '--env-file=[env file]:file:_files' \
          '--num-nodes=[node count]:n:' \
          ':task yaml:_files -g "*.(yaml|yml)"' && ret=0
        ;;
      (stop|down|cancel)
        _arguments \
          '(-a --all)'{-a,--all}'[all clusters]' \
          '(-u --all-users)'{-u,--all-users}'[all users]' \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' \
          '(-p --purge)'{-p,--purge}'[purge cluster]' \
          '--async[async operation]' && ret=0
        ;;
      (start)
        _arguments \
          '(-a --all)'{-a,--all}'[all clusters]' \
          '(-i --idle-minutes-to-autostop)'{-i,--idle-minutes-to-autostop=}'[autostop mins]:n:' \
          '--down[autodown]' \
          '(-f --force)'{-f,--force}'[force]' \
          '--async[async]' && ret=0
        ;;
      (status)
        _arguments \
          '(-a --all)'{-a,--all}'[show all]' \
          '(-r --refresh)'{-r,--refresh}'[refresh status]' \
          '--ip[show IPs]' \
          '--endpoints[show endpoints]' \
          '--show-managed-jobs[show managed jobs]' \
          '--show-services[show services]' \
          '--show-pools[show pools]' \
          '(-u --all-users)'{-u,--all-users}'[all users]' && ret=0
        ;;
      (autostop)
        _arguments \
          '(-i --idle-minutes)'{-i,--idle-minutes=}'[idle minutes]:n:' \
          '--cancel[cancel autostop]' \
          '--down[autodown]' \
          '--wait[wait]' \
          '--async[async]' && ret=0
        ;;
      (queue)
        _arguments \
          '(-u --all-users)'{-u,--all-users}'[all users]' \
          '(-s --skip-finished)'{-s,--skip-finished}'[skip finished jobs]' && ret=0
        ;;
      (logs)
        _arguments \
          '--provision-logs[show provision logs]' \
          '--autostop-logs[show autostop logs]' \
          '--worker-id=[worker id]:id:' \
          '--sync-down[sync logs down]' \
          '--status[show status]' \
          '(-f --follow)'{-f,--follow}'[follow logs]' \
          '--tail=[tail lines]:n:' && ret=0
        ;;
      (jobs)
        _values 'jobs action' 'launch' 'queue' 'cancel' 'logs' 'pool' && ret=0
        ;;
      (serve)
        _values 'serve action' 'up' 'down' 'status' 'logs' 'update' && ret=0
        ;;
      (storage)
        _values 'storage action' 'ls' 'delete' && ret=0
        ;;
      (volumes)
        _values 'volumes action' 'ls' 'apply' 'delete' && ret=0
        ;;
      (api)
        _values 'api action' 'login' 'info' 'logs' 'status' && ret=0
        ;;
    esac
    ;;
esac

return ret
