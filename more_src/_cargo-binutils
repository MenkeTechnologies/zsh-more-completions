# Reference accessed: 2026-05-16

# RustSec cargo-binutils — cargo forwards to llvm-<tool> after resolving the workspace crate.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '*'{-v,--verbose}'[verbose cargo / tool]' \
  '--manifest-path=[path to Cargo.toml]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet cargo output]' \
  '(-p --package)'{-p,--package}'=[package]:pkg:' \
  '(-j --jobs)'{-j,--jobs}'=[jobs]:n:' \
  '--lib[use only the lib target]' \
  '--bin=[binary target]:name:' \
  '--example=[example target]:name:' \
  '--test=[test target]:name:' \
  '--bench=[bench target]:name:' \
  '--release[artifact in release mode]' \
  '--profile=[custom profile]:profile:' \
  '*'{-F,--features}'=[features]:features:' \
  '--all-features[activate all optional features]' \
  '--no-default-features[disable default features]' \
  '--target=[rustc target triple]:triple:' \
  '--config=[Cargo config KEY=VAL]:setting:' \
  '--color=[diagnostics color]:when:(auto always never)' \
  '--frozen[error if lockfile needs update]' \
  '--locked[error if lockfile not up to date]' \
  '--offline[avoid hitting the network]' \
  '*-Z[unstable rustc flag]:flag:' \
  '*::llvm tool arguments:_normal' && ret=0

return ret
