#compdef dbigcg
# Documentation: https://man.archlinux.org/search?q=dbigcg
# Reference accessed: 2026-05-16

# EMBOSS dbigcg: build EMBOSS index for GCG-format sequence database
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-dbname=[database name]:name:' \
  '-directory=[directory containing GCG database files]:dir:_files -/' \
  '-filenames=[pattern for files]:pattern:' \
  '-fields=[fields to index]:fields:' \
  '-release=[release]:release:' \
  '-date=[date]:date:' \
  '-exclude=[exclude patterns]:patterns:' \
  '-indexoutdir=[output dir for indexes]:dir:_files -/' \
  '-systemsort[use OS sort utility]' \
  '-cleanup[delete temp files]' \
  '-idformat=[ID format]:format:(EMBL SWISS GB GCG PIR)' \
  '*:database name:' && ret=0
return ret
