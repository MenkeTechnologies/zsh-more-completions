#compdef gen2xyz
# Documentation: https://github.com/dftbplus/dftbplus/blob/main/tools/dptools/src/dptools/scripts/gen2xyz.py
# DFTB+ dptools: convert a DFTB+ gen geometry file to XYZ format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --lattice-file)'{-l,--lattice-file}'+[store lattice vectors in an external file]:file:_files' \
  '(-o --output)'{-o,--output}'+[override the name of the output file]:file:_files' \
  '(-c --comment)'{-c,--comment}'+[comment for the second line of the xyz file]:comment:' \
  '*:gen input file:_files -g "*.gen"' && ret=0

return ret
