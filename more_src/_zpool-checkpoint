#compdef zpool-checkpoint
# _zpool-checkpoint — OpenZFS zpool checkpoint (capture a pool-wide point-in-time checkpoint that can later be reverted to; --discard removes the existing checkpoint, --wait blocks until done; positional argument is the pool name)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_checkpoint) on tip.

_zpool-checkpoint() {
    _arguments \
        '-d[discard existing checkpoint]' \
        '--discard[discard existing checkpoint]' \
        '-w[wait until done]' \
        '--wait[wait until done]' \
        '1:pool:'
}

_zpool-checkpoint "$@"
