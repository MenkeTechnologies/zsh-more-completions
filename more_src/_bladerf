#compdef bladeRF-cli bladerf-cli bladeRF
# _bladerf — Nuand bladeRF-cli command line interface for the Nuand bladeRF software-defined radio platform (Nuand team, C); custom argparse
# upstream: https://github.com/Nuand/bladeRF

_bladerf() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbosity]:l:(critical error warning info debug verbose silent)' \
        '--verbose=+[verbosity]:l:(critical error warning info debug verbose silent)' \
        '-d+[device string]:str:' \
        '--device=+[device string]:str:' \
        '-e+[command]:str:' \
        '--exec=+[command]:str:' \
        '-s+[script file]:file:_files -g "*.brf *.sh *.txt"' \
        '--script=+[script file]:file:_files -g "*.brf *.sh *.txt"' \
        '-L+[probe library]:file:_files' \
        '--library=+[probe library]:file:_files' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '-b[disable banner]' \
        '--no-banner[disable banner]' \
        '-p[probe]' \
        '--probe[probe]' \
        '-l+[flash FPGA]:file:_files -g "*.rbf *.bin"' \
        '--load-fpga=+[flash FPGA]:file:_files -g "*.rbf *.bin"' \
        '-f+[flash firmware]:file:_files -g "*.img"' \
        '--flash-firmware=+[flash firmware]:file:_files -g "*.img"' \
        '-F+[serial number]:str:' \
        '-u+[USB speed]:s:(SS HS)' \
        '*:command:'
}

_bladerf "$@"
