#compdef electron-packager

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--platform=[target platform]:platform:(darwin linux mas win32 all)' \
  '--arch=[target architecture]:arch:(ia32 x64 armv7l arm64 mips64el universal all)' \
  '--out=[output directory]:dir:_files -/' \
  '--overwrite[replace existing output dir]' \
  '--asar[bundle app into an asar archive]' \
  '--asar.unpack=[asar unpack glob]:glob:' \
  '--asar.unpackDir=[asar unpack dir glob]:glob:' \
  '--icon=[icon for the app]:file:_files -g "*.(icns|ico|png)"' \
  '--app-bundle-id=[macOS bundle ID]:id:' \
  '--app-category-type=[macOS LSApplicationCategoryType]:category:' \
  '--app-copyright=[copyright string]:copyright:' \
  '--app-version=[CFBundleShortVersionString / FileVersion]:version:' \
  '--build-version=[CFBundleVersion / ProductVersion]:version:' \
  '--executable-name=[name for the executable]:name:' \
  '--extend-info=[plist file to merge into Info.plist]:file:_files -g "*.plist"' \
  '--extra-resource=[file to copy to resources dir]:file:_files' \
  '--helper-bundle-id=[macOS helper bundle ID]:id:' \
  '--ignore=[regex of paths to ignore]:regex:' \
  '--name=[application name]:name:' \
  '--no-deref-symlinks[do not dereference symlinks]' \
  '--no-prune[do not run npm prune --production]' \
  '--osx-sign[code-sign the app (macOS)]' \
  '--osx-sign.identity=[signing identity]:identity:' \
  '--osx-sign.entitlements=[entitlements file]:file:_files -g "*.plist"' \
  '--osx-sign.hardenedRuntime[enable hardened runtime]' \
  '--osx-sign.gatekeeper-assess[run gatekeeper assess after signing]' \
  '--osx-notarize[submit for notarization (macOS)]' \
  '--osx-notarize.appleId=[Apple ID]:apple id:_email_addresses' \
  '--osx-notarize.appleIdPassword=[Apple ID password]:password:' \
  '--osx-notarize.teamId=[Apple team ID]:team id:' \
  '--prebuilt-asar=[path to pre-built asar archive]:file:_files -g "*.asar"' \
  '--protocol=[URL handler protocol]:protocol:' \
  '--protocol-name=[URL handler name]:name:' \
  '--prune[run npm prune --production (default true)]' \
  '--quiet[suppress output]' \
  '--tmpdir=[temporary directory]:dir:_files -/' \
  '--win32metadata.CompanyName=[Windows CompanyName]:name:' \
  '--win32metadata.FileDescription=[Windows FileDescription]:desc:' \
  '--win32metadata.OriginalFilename=[Windows OriginalFilename]:name:' \
  '--win32metadata.ProductName=[Windows ProductName]:name:' \
  '--win32metadata.InternalName=[Windows InternalName]:name:' \
  '1:source directory:_files -/' \
  '2::application name:' && ret=0

return ret
