#compdef b2

# Zsh completion for b2 (Backblaze B2 Cloud Storage CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'account:manage B2 account'
      'bucket:manage buckets'
      'file:manage files'
      'key:manage application keys'
      'install-autocomplete:install shell completions'
      'license:display license info'
      'ls:list files in a bucket'
      'rm:remove files'
      'sync:sync local files with B2'
      'version:show version'
    )
    _describe -t commands 'b2 command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (account)
        local -a subcmds=(
          'authorize:authorize account'
          'clear:clear stored credentials'
          'get:get account info'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd) _describe -t commands 'subcommand' subcmds && ret=0 ;;
        esac
        ;;
      (bucket)
        local -a subcmds=(
          'create:create a bucket'
          'delete:delete a bucket'
          'get-download-auth:get download authorization'
          'list:list buckets'
          'update:update bucket settings'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd) _describe -t commands 'subcommand' subcmds && ret=0 ;;
        esac
        ;;
      (file)
        local -a subcmds=(
          'copy-by-id:copy file by ID'
          'download:download a file'
          'hide:hide a file'
          'info:get file info'
          'large:manage large file uploads'
          'update:update file metadata'
          'upload:upload a file'
          'url:get file URL'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd) _describe -t commands 'subcommand' subcmds && ret=0 ;;
        esac
        ;;
      (key)
        local -a subcmds=(
          'create:create an application key'
          'delete:delete an application key'
          'list:list application keys'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd) _describe -t commands 'subcommand' subcmds && ret=0 ;;
        esac
        ;;
      (ls)
        _arguments \
          '--recursive[list recursively]' \
          '--long[long listing format]' \
          '--json[output as JSON]' \
          '--versions[show all versions]' \
          '--with-wildcard[use wildcards]' \
          '1:bucket name' \
          '2:folder name' && ret=0
        ;;
      (rm)
        _arguments \
          '--recursive[remove recursively]' \
          '--dry-run[show what would be removed]' \
          '--no-progress[disable progress]' \
          '--threads[number of threads]:threads' \
          '--versions[remove all versions]' \
          '--with-wildcard[use wildcards]' \
          '1:b2 URI' && ret=0
        ;;
      (sync)
        _arguments \
          '--no-progress[disable progress display]' \
          '--dry-run[show what would be done]' \
          '--allow-empty-source[allow empty source]' \
          '--exclude-all-symlinks[exclude symbolic links]' \
          '--threads[number of threads]:threads' \
          '--compare-versions[comparison method]:method:(none modTime size)' \
          '--compare-threshold[modification time threshold]:milliseconds' \
          '--exclude-regex[exclude files matching regex]:regex' \
          '--include-regex[include files matching regex]:regex' \
          '--exclude-dir-regex[exclude directories matching regex]:regex' \
          '--skip-newer[skip files newer on destination]' \
          '--replace-newer[replace files newer on destination]' \
          '--delete[delete files not in source]' \
          '--keep-days[keep old versions for N days]:days' \
          '1:source:_files -/' \
          '2:destination' && ret=0
        ;;
    esac
    ;;
esac

return ret
