#compdef k2pdfopt
# optimize PDF/DJVU files for mobile e-reader displays (PDF reflow tool)

local ret=1

_arguments -s -S \
  '-a-[disable text coloring using ANSI codes]' \
  '-author+[set PDF author metadata]:author' \
  '-title+[set PDF title metadata]:title' \
  '-bpc+[bits per color plane (1, 2, 4, or 8; default 4)]:bpc' \
  '-c[output in color instead of grayscale]' \
  '-col+[max columns: 1, 2, or 4 (default 2)]:maxcol' \
  '-dev+[select device profile]:device' \
  '-dpi+[same as -odpi]:dpi' \
  '-d[enable dithering for bpc values < 8]' \
  '-g+[set gamma value (default 0.5)]:gamma' \
  '-gs[force use of Ghostscript for PDF reading]' \
  '-gui-[do not use the graphical user interface]' \
  '-h+[set output device height]:height' \
  '-w+[set output device width]:width' \
  '-hy-[disable hyphen detection when wrapping text]' \
  '-i[echo source file information (PDF only)]' \
  '-idpi+[set input file pixels per inch]:dpi' \
  '-j+[set output text justification (-1 0 1 2)]:justify' \
  '-jpg+[use JPEG compression (default quality 90)]:quality' \
  '-png[use PNG compression in PDF file (default)]' \
  '-mode+[shortcut setting multiple options]:mode:(copy fp fw 2col tm crop concat def)' \
  '-n-[do not use native PDF output format]' \
  '-o+[set output file name format]:namefmt' \
  '-ocr+[use optical character recognition (t tesseract)]:engine' \
  '-ocrlang+[select Tesseract OCR language]:lang' \
  '-odpi+[set output screen pixels per inch (default 167)]:dpi' \
  '-p+[specify pages to convert]:pagelist' \
  '-px+[exclude pages from processing]:pagelist' \
  '-r-[enable right-to-left page scans]' \
  '-rt+[rotate source page counterclockwise]:degrees' \
  '-s-[disable image sharpening]' \
  '-sm[show marked source with region annotations]' \
  '-t-[do not trim white space from output regions]' \
  '-toc-[do not include bookmark information]' \
  '-v[verbose output mode]' \
  '-vb+[set vertical-break threshold between regions]:threshold' \
  '-wrap-[disable text wrapping]' \
  '-x[exit after completion without waiting for Enter]' \
  '-y[assume yes to queries and disable warnings]' \
  '*:file:_files' && ret=0

return ret
