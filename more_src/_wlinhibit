#compdef wlinhibit
# Documentation: https://github.com/einetuer/wlinhibit
# Reference accessed: 2026-05-16
# Verified: README documents no CLI flags. Usage pattern is
# `killall wlinhibit || wlinhibit`.

# wlinhibit: Wayland idle inhibitor toggle
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::extra args:_files' && ret=0
return ret
