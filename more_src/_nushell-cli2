#compdef nushell-cli2 nushell2 nu2
# _nushell-cli2 — Jonathan Turner Andrés N Robalino Yehuda Katz Nushell nushell-cli2 CLI command-line frontend wrapping the Nushell new shell that takes a modern structured-data approach written in Rust originally Jonathan Turner Andrés N Robalino Yehuda Katz now Nushell team a new type of shell where everything is data and pipelines flow through them everything is a stream of structured data semicolon-as-pipe-separator commands return tables and records dataframe-like-structured-output Polars-DataFrames plugins-using-MsgPack-protocol cross-platform interactive run script repl init benchmark plugin --help --version --config --env-config --plugin-config --commands --interactive --execute --no-config-file --plugin --stdin --testbin --include-path --log-include --log-target --threads --execute --no-history (Jonathan Turner Andrés N Robalino Yehuda Katz Nushell team, Rust); clap
# upstream: https://www.nushell.sh/

_nushell-cli2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[commands]:str:' \
        '*-c+[commands]:str:' \
        '--commands=+[commands]:str:' \
        '-e+[execute]:str:' \
        '*-e+[execute]:str:' \
        '--execute=+[code]:str:' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '-l[login shell]' \
        '--login[login shell]' \
        '--stdin[stdin mode]' \
        '--no-config-file[no config file]' \
        '-n[no config file]' \
        '--config=+[file]:file:_files -g "*.nu"' \
        '--env-config=+[file]:file:_files -g "*.nu"' \
        '--plugin-config=+[file]:file:_files -g "*.nu *.msgpackz"' \
        '--plugin=+[name]:str:' \
        '*--plugin=+[name]:str:' \
        '--plugins=+[name]:str:' \
        '*--plugins=+[name]:str:' \
        '--log-level=+[l]:l:(off error warn info debug trace)' \
        '--log-include=+[tags]:str:' \
        '--log-exclude=+[tags]:str:' \
        '--log-target=+[t]:t:(file stderr stdout mixed)' \
        '--threads=+[N]:n:' \
        '--testbin=+[name]:str:' \
        '--no-history[no history]' \
        '--no-newline[no newline]' \
        '--include-path=+[paths]:str:' \
        '-I+[paths]:str:' \
        '--ide-goto-def=+[name]:str:' \
        '--ide-hover=+[name]:str:' \
        '--ide-complete=+[N]:n:' \
        '--ide-check=+[N]:n:' \
        '--ide-ast[IDE AST]' \
        '-t+[testbin]:str:' \
        '-m[mark line]' \
        '--no-std-lib[no std lib]' \
        '--lsp[start LSP]' \
        '*:nu file:_files -g "*.nu"'
}

_nushell-cli2 "$@"
