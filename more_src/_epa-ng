#compdef epa-ng
# EPA-ng: evolutionary placement of query sequences on a reference tree

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --ref-msa)'{-s,--ref-msa}'[reference MSA (fasta)]:file:_files' \
  '(-t --tree)'{-t,--tree}'[reference tree (newick)]:file:_files' \
  '(-q --query)'{-q,--query}'[query sequences (fasta or bfast)]:file:_files' \
  '(-w --outdir)'{-w,--outdir}'[output directory]:dir:_files -/' \
  '--model[evolutionary model specification]:model:' \
  '(-T --threads)'{-T,--threads}'[number of threads to use]:number:' \
  '(-g --dyn-heur)'{-g,--dyn-heur}'[use dynamic preplacement heuristic (default)]' \
  '(-G --fix-heur)'{-G,--fix-heur}'[use fixed preplacement heuristic]' \
  '--no-heur[disable preplacement heuristic]' \
  '--no-pre-mask[disable premasking]' \
  '(-c --bfast)'{-c,--bfast}'[convert query fasta to binary format]:file:_files' \
  '--redo[overwrite existing output files]' \
  '--preserve-rooting[preserve the rooting of the reference tree]' && ret=0

return ret
