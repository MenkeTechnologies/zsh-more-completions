#compdef ovs-fields
# _ovs-fields — Open vSwitch ovs-fields list OpenFlow fields supported by ovs-ofctl with reference documentation (openvswitch team, Bash); custom argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-fields() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]'
}

_ovs-fields "$@"
