#compdef upsd

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-c+[command for running daemon]:cmd:(stop reload)' \
  '-P+[pid file]:file:_files' \
  '-D[debug, do not fork]' \
  '-F[run in foreground]' \
  '-B[run in background]' \
  '-f[run as foreground (no logging redirect)]' \
  '-r+[chroot directory]:dir:_files -/' \
  '-u+[switch to user]:user:_users' && ret=0

return ret
