#compdef upsd
# Documentation: https://networkupstools.org/docs/man/upsd.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[display version]' \
  '-c+[signal running daemon]:cmd:(reload stop)' \
  '-P+[PID number to signal (overrides PID file)]:pid:' \
  '-D[raise debugging level (foreground)]' \
  '-F[force foreground execution]' \
  '-B[force background execution]' \
  '-r+[chroot to directory shortly after startup]:dir:_files -/' \
  '-u+[switch to user after startup]:user:_users' && ret=0

return ret
