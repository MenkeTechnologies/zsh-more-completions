#compdef ccze

# Zsh completion for ccze (log colorizer)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-A --raw-ansi)'{-A,--raw-ansi}'[generate raw ANSI output]' \
  '(-h --html)'{-h,--html}'[generate HTML output]' \
  '(-c --color)'{-c,--color}'[set color]:color spec' \
  '(-C --convert-date)'{-C,--convert-date}'[convert UNIX timestamps]' \
  '(-F --rcfile)'{-F,--rcfile}'[config file]:file:_files' \
  '(-l --plugin)'{-l,--plugin}'[load plugin]:plugin' \
  '(-m --mode)'{-m,--mode}'[set mode]:mode' \
  '(-o --option)'{-o,--option}'[set option]:option:(scroll noscroll wordcolor)' \
  '(-p --list-plugins)'{-p,--list-plugins}'[list available plugins]' \
  '(-r --remove-facility)'{-r,--remove-facility}'[remove syslog facility]' \
  '--transparent[use transparent background]' \
  '--cssoptions[CSS options for HTML]:options' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
