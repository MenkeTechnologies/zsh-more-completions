#compdef ccze
# Documentation: https://manpages.debian.org/bookworm/ccze/ccze.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for ccze (log colorizer)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-a --argument)'{-a+,--argument=}'[pass ARGS to plugin]:plugin:args:' \
  '(-A --raw-ansi)'{-A,--raw-ansi}'[raw ANSI output instead of curses]' \
  '(-c --color)'{-c+,--color=}'[set color of keyword]:keyword=color:' \
  '(-C --convert-date)'{-C,--convert-date}'[convert UNIX timestamps]' \
  '(-F --rcfile)'{-F+,--rcfile=}'[config file]:file:_files' \
  '(-h --html)'{-h,--html}'[generate HTML output]' \
  '(-l --plugin)'{-l+,--plugin=}'[load only specified plugins]:plugin:' \
  '(-m --mode)'{-m+,--mode=}'[output mode]:mode:(curses ansi html)' \
  '(-o --options)'{-o+,--options=}'[toggle option]:option:(scroll noscroll wordcolor nowordcolor lookups nolookups transparent notransparent cssfile)' \
  '(-p --list-plugins)'{-p,--list-plugins}'[list available plugins]' \
  '(-r --remove-facility)'{-r,--remove-facility}'[strip syslog facility]' \
  '--help[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
