#compdef hadoop-distcp distcp
# _hadoop-distcp — Apache Hadoop distcp (parallel inter-cluster HDFS/S3/azure copier; -update overwrite only when content changes, -delete remove orphans at target, -p preserve attributes, -m max maps, -bandwidth MB/s cap, -strategy uniformsize|dynamic, -filters skip regex file, -skipcrccheck, -i ignore failures, -log logdir; positional source(s) then target)
# upstream: https://github.com/apache/hadoop (tools/hadoop-distcp)
# Flags from Apache Hadoop hadoop-distcp src/main/java/org/apache/hadoop/tools/DistCpOptions.java on tip.

_hadoop-distcp() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-async[run async]' \
        '-update[update on content change]' \
        '-overwrite[force overwrite]' \
        '-delete[delete orphan targets]' \
        '-i[ignore failures]' \
        '-skipcrccheck[skip CRC check]' \
        '-rdiff[reverse snapshot diff]' \
        '-diff+[snapshot diff]:snapshots:' \
        '-numListstatusThreads+[N]:n:' \
        '-strategy+[strategy]:strategy:(uniformsize dynamic)' \
        '-p+[preserve attrs]:attrs:(r b c u g p t a x e q)' \
        '-bandwidth+[MB/s cap]:mb:' \
        '-m+[max maps]:n:' \
        '-filters+[skip regex file]:file:_files' \
        '-log+[log directory]:dir:_files -/' \
        '-blocksperchunk+[blocks per chunk]:n:' \
        '-copybuffersize+[buffer bytes]:bytes:' \
        '-direct[direct write to dest]' \
        '-atomic[atomic commit]' \
        '-tmp+[atomic temp dir]:dir:' \
        '*:source... target:_files'
}

_hadoop-distcp "$@"
