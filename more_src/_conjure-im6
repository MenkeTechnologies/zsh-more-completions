#compdef conjure-im6
# Documentation: https://imagemagick.org/script/conjure.php
# conjure-im6 — interpret and execute MSL scripts (ImageMagick 6, Debian binary)

local ret=1

_arguments -s -S \
  '-help[print program options]' \
  '-debug[display copious debugging information]:events' \
  '-log[format of debugging information]:format' \
  '-monitor[monitor progress]' \
  '-quiet[suppress all warning messages]' \
  '-regard-warnings[pay attention to warning messages]' \
  '-seed[seed a new sequence of pseudo-random numbers]:value' \
  '-verbose[print detailed information about the image]' \
  '-version[print version information]' \
  '*:MSL script:_files -g "*.msl"' && ret=0

return ret
