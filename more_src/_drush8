#compdef drush8
# _drush8 — Greg Anderson drush8 Drupal Shell binary CLI for Drupal 8 administration site-install module-enable feature-revert cache-rebuild config-export sql-dump update-database user-login (drush-ops team, PHP); Symfony Console
# upstream: https://github.com/drush-ops/drush

_drush8() {
    local -a sub=(
        'archive-dump:archive site to tarball'
        'archive-restore:restore site from tarball'
        'cache-clear:clear cache'
        'cache-rebuild:rebuild cache'
        'config-edit:edit config interactively'
        'config-export:export config'
        'config-import:import config'
        'config-list:list all configuration'
        'core-rsync:rsync between drush aliases'
        'core-status:show site status'
        'cron:run cron'
        'features-export:export feature'
        'features-import:import feature'
        'features-revert:revert feature'
        'pm-disable:disable module'
        'pm-download:download module'
        'pm-enable:enable module'
        'pm-list:list modules'
        'pm-uninstall:uninstall module'
        'pm-update:update modules'
        'queue-list:list queues'
        'queue-run:run queue'
        'role-add-perm:add role permission'
        'site-install:install drupal site'
        'site-set:set drupal alias'
        'sql-dump:dump SQL'
        'sql-query:run SQL query'
        'sql-sync:sync SQL between aliases'
        'updatedb:run database updates'
        'user-create:create user'
        'user-login:login as user'
        'user-block:block user'
        'user-unblock:unblock user'
        'user-password:set password'
        'watchdog-list:list watchdog'
        'watchdog-show:show watchdog'
        'help:show help'
        'list:list commands'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-y[yes confirm]' \
        '--yes[yes confirm]' \
        '-n[no confirm]' \
        '--no[no confirm]' \
        '-r+[drupal root]:dir:_files -/' \
        '--root=+[drupal root]:dir:_files -/' \
        '-l+[uri]:str:' \
        '--uri=+[uri]:str:' \
        '-d[debug]' \
        '--debug[debug]' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '--format=+[format]:f:(table list json yaml csv var_export print_r)' \
        '--fields=+[csv]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'drush8 subcommand' sub ;;
        args) ;;
    esac
}

_drush8 "$@"
