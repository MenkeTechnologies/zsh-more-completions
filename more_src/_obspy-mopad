#compdef obspy-mopad
# Documentation: https://docs.obspy.org/
# ObsPy: MoPaD moment tensor plotting and decomposition tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--input-system=[input coordinate basis (NED USE XYZ NWU)]:basis:(NED USE XYZ NWU)' \
  '--output-system=[output coordinate basis]:basis:(NED USE XYZ NWU)' \
  '--basis-vectors[display NED basis directions]' \
  '--show-isotropic-part[include isotropic component]' \
  '--show-faultplanes[render both nodal plane geometries]' \
  '--show-1fp[display single fault plane]' \
  '--full-sphere[plot complete spherical projection]' \
  '--pa-system[show principal axes coordinate frame]' \
  '--lines-only[omit fill colouring from plot]' \
  '--projection=[projection type]:projection' \
  '--viewpoint=[observation angle]:viewpoint' \
  '--tension-colour=[extension region colour]:colour' \
  '--pressure-colour=[compression region colour]:colour' \
  '--scaling=[beachball size factor]:factor' \
  '(-o --output-file)--output-file=[save destination]:file:_files' \
  '1:subcommand:(plot save gmt convert decompose)' \
  '*::moment tensor or source:' && ret=0

return ret
