#compdef hopp

# Zsh completion for Hoppscotch CLI
# https://github.com/hoppscotch/hoppscotch

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'test:Run tests against a Hoppscotch collection'
)

_arguments -s -S \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'hopp command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (test)
        _arguments -s -S \
          '(-e --env)'{-e+,--env=}'[path to an environment JSON file or an environment ID]:file:_files -g "*.json"' \
          '(-d --delay)'{-d+,--delay=}'[adds a delay between requests (ms)]:delay (ms):' \
          '--token=[personal access token]:token:' \
          '--server=[URL of self-hosted Hoppscotch instance]:url:_urls' \
          '--reporter-junit=[generate a JUnit XML report]:path:_files' \
          '1:collection file or ID:_files -g "*.json"' && ret=0
        ;;
    esac
    ;;
esac

return ret
