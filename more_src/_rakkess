#compdef rakkess kubectl-access_matrix
# Documentation: https://github.com/corneliusweig/rakkess/blob/master/doc/USAGE.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'completion:generate shell completion'
  'help:show help'
  'for:show all subjects with access to a given resource'
  'resource:alias for for'
  'r:alias for for'
  'version:print the version information'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--as=[impersonate user]:user:' \
  '*--as-group=[impersonate group]:group:' \
  '--sa=[impersonate service account (namespace:sa)]:sa:' \
  '--diff-with=[show diff for modified call (e.g. namespace=kube-system)]:flagname=value:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[all namespaces]' \
  '--context=[kubectl context]:ctx:' \
  '--cluster=[kubeconfig cluster]:cluster:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--user=[kubeconfig user]:user:' \
  '--token=[bearer token]:tok:' \
  '--server=[API server]:url:' \
  '--certificate-authority=[CA cert]:file:_files' \
  '--client-certificate=[client cert]:file:_files' \
  '--client-key=[client key]:file:_files' \
  '--insecure-skip-tls-verify[skip TLS verify]' \
  '--verbs=[verbs csv]:list:(create get list watch update patch delete deletecollection)' \
  '-v+[verbosity]:lvl:' \
  '(-o --output)'{-o+,--output=}'[output format]:fmt:(icon-table ascii-table)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'rakkess command' commands && ret=0 ;;
esac

return ret
