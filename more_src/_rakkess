#compdef rakkess kubectl-access_matrix

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'completion:generate shell completion'
  'help:show help'
  'resource:show subjects with access to specific resource'
  'for:alias for resource'
  'r:alias for resource'
  'subject:show subjects with access'
  'version:show version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--as=[impersonate user]:user:' \
  '*--as-group=[impersonate group]:group:' \
  '-sa+[impersonate service account]:sa:' \
  '--diff-with=[diff mode comparing rights]:flagname=value:' \
  '*-n+[namespace]:ns:' \
  '*--namespace=[namespace]:ns:' \
  '-A[all namespaces]' \
  '--all-namespaces[all namespaces]' \
  '--context=[kubectl context]:ctx:' \
  '--cluster=[kubeconfig cluster]:cluster:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--user=[kubeconfig user]:user:' \
  '--token=[bearer token]:tok:' \
  '--server=[API server]:url:' \
  '--certificate-authority=[CA cert]:file:_files' \
  '--client-certificate=[client cert]:file:_files' \
  '--client-key=[client key]:file:_files' \
  '--insecure-skip-tls-verify[skip TLS verify]' \
  '--verbs=[verbs csv]:list:(create get list watch update patch delete deletecollection all)' \
  '-v+[verbosity]:lvl:' \
  '-o+[output]:fmt:(icon-table table ascii-table)' \
  '--output=[output]:fmt:(icon-table table ascii-table)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'rakkess command' commands && ret=0 ;;
esac

return ret
