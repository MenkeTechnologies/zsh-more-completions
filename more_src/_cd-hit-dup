#compdef cd-hit-dup
# Documentation: https://github.com/weizhongli/cdhit/blob/master/cd-hit-auxtools/cdhit-dup.cxx
# CD-HIT-DUP - remove duplicate sequences from single or paired-end reads

local ret=1

_arguments -s \
  '-i[input file (FASTQ or FASTA)]:input:_files' \
  '-i2[second input file (FASTQ or FASTA)]:input2:_files' \
  '-o[output file]:output:_files' \
  '-o2[output file for R2]:output2:_files' \
  '-d[description length (default 0)]:length' \
  '-u[length of prefix used in the analysis (default 0)]:length' \
  '-m[match length (true/false, default true)]:matchlen:(true false)' \
  '-e[maximum number of mismatches allowed]:mismatches' \
  '-f[filter out chimeric clusters (true/false, default false)]:filter:(true false)' \
  '-s[minimum length of common sequence shared between a chimeric read and each parent (default 30)]:length' \
  '-a[abundance cutoff (default 1, or 2 with chimeric filtering)]:cutoff' \
  '-b[abundance ratio between a parent read and chimeric read (default 1)]:ratio' \
  '-p[dissimilarity control for chimeric filtering (default 1)]:dissimilarity' \
  '*:file:_files' && ret=0

return ret
