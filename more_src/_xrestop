#compdef xrestop
# _xrestop — xrestop (curses-style top(1) for X server resources; shows per-client pixmap/window/gc/font/colormap counts and bytes; --batch one-shot dump, --delay refresh seconds, --max iterations, --display picks X display)
# upstream: https://gitlab.freedesktop.org/xorg/app/xrestop
# Flags from xrestop xrestop.c on tip.

_xrestop() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-b[batch mode (one shot)]' \
        '--batch[batch mode]' \
        '-d+[refresh seconds]:seconds:' \
        '--delay+[refresh seconds]:seconds:' \
        '-n+[iterations]:n:' \
        '--max+[iterations]:n:' \
        '--display+[X display]:display:'
}

_xrestop "$@"
