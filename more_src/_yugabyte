#compdef yugabyte
# Documentation: https://man.archlinux.org/search?q=yugabyte
# Reference accessed: 2026-05-16

# yugabyte: legacy launcher for YugabyteDB (umbrella to yb-master, yb-tserver)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(start stop restart status destroy version)' \
  '*::yugabyte args:_files' && ret=0
return ret
