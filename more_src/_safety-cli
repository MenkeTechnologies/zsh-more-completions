#compdef safety

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'check:check vulnerabilities (legacy)'
  'scan:scan project for vulnerabilities'
  'review:review a saved scan'
  'license:list package licenses'
  'auth:authenticate to safety'
  'configure:configure safety'
  'firewall:firewall management'
  'init:initialize safety in project'
  'validate:validate a policy file'
  'pip:pip wrapper'
  'generate:generate policy file'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*--debug[debug]' \
  '*--key=[API key]:k:' \
  '*--proxy-protocol=[proxy proto]:p:(http https)' \
  '*--proxy-host=[proxy host]:host:_hosts' \
  '*--proxy-port=[proxy port]:port:' \
  '*--disable-optional-telemetry[disable telemetry]' \
  '*--disable-telemetry[disable telemetry]' \
  '*--telemetry[telemetry]' \
  '*--no-color[no color]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'safety command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (check)
        _arguments \
          '(-r --file)*'{-r+,--file=}'[req file]:file:_files -g "*.txt"' \
          '(--stdin)--stdin[read from stdin]' \
          '(-i --ignore)*'{-i+,--ignore=}'[ignore vuln id]:id:' \
          '(--exit-code)--exit-code[exit non-zero on vuln]' \
          '(--continue-on-error)--continue-on-error[continue on errors]' \
          '(--output)--output=[format]:f:(screen text json bare html)' \
          '(--save-html)--save-html=[save HTML]:file:_files' \
          '(--save-json)--save-json=[save JSON]:file:_files' \
          '(--save-text)--save-text=[save text]:file:_files' \
          '(--full-report)--full-report[full report]' \
          '(--short-report)--short-report[short report]' \
          '(--bare)--bare[bare format]' \
          '(--cache)--cache=[cache time]:s:' \
          '(--policy-file)--policy-file=[policy file]:file:_files' \
          '(--audit-and-monitor)--audit-and-monitor[audit and monitor]' \
          '(--project)--project=[project id]:id:' \
          '*: :_files' && ret=0 ;;
      (scan)
        _arguments \
          '(--target)--target=[target dir]:dir:_files -/' \
          '(--policy-file-path)--policy-file-path=[policy]:file:_files' \
          '(--output)--output=[format]:f:(screen json html spdx)' \
          '(--save-as)--save-as=[save report]:s:' \
          '(--detailed-output)--detailed-output[detailed output]' \
          '(--apply-fixes)--apply-fixes[apply fixes]' \
          '*: :_files -/' && ret=0 ;;
      (review)
        _arguments \
          '(--file)--file=[scan file]:file:_files' \
          '(--output)--output=[format]:f:' \
          '*: :_files' && ret=0 ;;
      (license)
        _arguments \
          '(-r --file)*'{-r+,--file=}'[req file]:file:_files' \
          '(--cache)--cache=[cache]:s:' \
          '*: :' && ret=0 ;;
      (auth)
        _arguments \
          '1:subcommand:(login logout status)' \
          '*: :' && ret=0 ;;
      (firewall)
        _arguments \
          '1:subcommand:(setup install enable disable status)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
