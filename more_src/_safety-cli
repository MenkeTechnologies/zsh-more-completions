#compdef safety
# Documentation: https://docs.safetycli.com/safety-docs/safety-cli-3
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'scan:scan a project directory for vulnerabilities'
  'system-scan:scan entire development machine'
  'check:legacy vulnerability check (deprecated)'
  'auth:authenticate with Safety platform'
  'configure:configure safety'
  'validate:validate a policy file'
  'generate:generate policy file'
  'license:scan licenses'
  'firewall:firewall (package manager protection)'
  'codebase:codebase tracking'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug mode]' \
  '--key=[API key]:key:' \
  '--stage=[lifecycle stage]:stage:(development production)' \
  '--disable-optional-telemetry-data[opt out of telemetry]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'safety command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (scan)
        _arguments \
          '--target=[target dir]:dir:_files -/' \
          '--policy-file=[policy file]:file:_files' \
          '--output=[format]:f:(screen json html spdx)' \
          '--apply-fixes[apply fixes]' \
          '--detailed-output[detailed output]' \
          '*: :_files -/' && ret=0 ;;
      (auth)
        _arguments \
          '1:subcommand:(login logout status)' && ret=0 ;;
      (firewall)
        _arguments \
          '1:subcommand:(init uninstall)' && ret=0 ;;
      (codebase)
        _arguments \
          '1:subcommand:(init)' && ret=0 ;;
      (configure)
        _arguments \
          '--proxy-host=[proxy host]:host:_hosts' \
          '--proxy-port=[proxy port]:port:' \
          '--proxy-protocol=[proxy proto]:p:(http https)' && ret=0 ;;
      (license)
        _arguments \
          '(-r --file)'{-r+,--file=}'[req file]:file:_files' \
          '--output=[format]:f:(screen json bare)' && ret=0 ;;
      (validate)
        _arguments \
          '*:policy file:_files' && ret=0 ;;
      (generate)
        _arguments \
          '1:type:(policy_file)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
