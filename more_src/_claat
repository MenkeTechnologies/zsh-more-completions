#compdef claat

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'export:export codelabs from a document'
  'serve:serve previously exported codelabs'
  'update:update previously exported codelabs'
  'version:print version and exit'
  'help:display help'
)

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'claat command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (export)
        _arguments \
          '-auth[OAuth2 token or path to token file]:token or file:_files' \
          '-e[codelab environment]:environment:(web kiosk)' \
          '-extra[extra metadata as colon-separated key=value pairs]:metadata:' \
          '-f[output format]:format:(html md)' \
          '-ga[Google Analytics tracking ID]:GA ID:' \
          '-o[output directory]:directory:_files -/' \
          '-prefix[URL prefix for serving codelabs]:prefix:' \
          '*:source:_files' \
          && ret=0
        ;;
      (serve)
        _arguments \
          '-addr[hostname and port to bind to]:address:' \
          '-prefix[URL prefix]:prefix:' \
          && ret=0
        ;;
      (update)
        _arguments \
          '-auth[OAuth2 token or path to token file]:token or file:_files' \
          '-ga[Google Analytics tracking ID]:GA ID:' \
          '-prefix[URL prefix for serving codelabs]:prefix:' \
          '*:source:_files' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
