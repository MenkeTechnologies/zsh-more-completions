#compdef grib_repair
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_repair
# Source: ecmwf/eccodes tools/grib_repair.cc — repair corrupted GRIB messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '1:input grib file:_files' \
    '2:output grib file:_files' \
    '3::bad-messages file:_files' \
    && ret=0

return ret
