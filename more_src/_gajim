#compdef gajim
# _gajim — Gajim XMPP / Jabber client (gajim/gajim)
# upstream: https://github.com/gajim/gajim
# Flags from gajim/gtk/application.py (GApplication add_main_option).

_gajim() {
    local -a args
    args=(
        '(-V --version)'{-V,--version}'[show the application version]'
        '(-q --quiet)'{-q,--quiet}'[show only critical errors]'
        '(-s --separate)'{-s,--separate}'[separate profile files completely (deprecated)]'
        '(-v --verbose)'{-v,--verbose}'[print XML stanzas and other debug information]'
        '(-p --profile)'{-p+,--profile=}'[use the named profile in the configuration directory (deprecated)]:profile:'
        '(-u --user-profile)'{-u+,--user-profile=}'[run multiple Gajim instances with the named profile]:profile:'
        '(-c --config-path)'{-c+,--config-path=}'[override the configuration directory]:dir:_files -/'
        '(-l --loglevel)'{-l+,--loglevel=}'[configure logging (e.g. .gajim=DEBUG,nbxmpp=INFO)]:spec:'
        '(-w --warnings)'{-w,--warnings}'[show all warnings]'
        '--gdebug[set G_MESSAGES_DEBUG so GLib debug messages are printed]'
        '--cprofile[profile the application with cProfile]'
        '--start-chat[open the start-a-chat dialog on launch]'
        '(- *)'{-h,--help}'[show help]'
    )
    _arguments -s -S $args
}

_gajim "$@"
