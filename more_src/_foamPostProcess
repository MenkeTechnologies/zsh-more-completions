#compdef foamPostProcess
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/postProcessing/foamPostProcess — execute functionObjects on existing field data (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-time+[restrict to selected times]:times:_default' \
    '-latestTime[use latest time]' \
    '-newTimes[only new times]' \
    '-solver+[solver name]:name:_default' \
    '-listTemplates[list functionObjects templates]' \
    '-field+[field name]:name:_default' \
    '-fields+[list of field names]:list:_default' \
    '-func+[built-in function name]:name:_default' \
    '-funcs+[list of function names]:list:_default' \
    '-list[list available functions]' \
    '-region+[region name]:region:_default' \
    && ret=0

return ret
