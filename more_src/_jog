#compdef jog
# Documentation: https://github.com/qiangyt/jog/blob/master/README.md
# jog - view structured (JSON) log like 'tail -f', with level and time range filtering

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-V --version)'{-V,--version}'[display app version information]' \
  '(-a --after)'{-a+,--after=}'[after time filter (auto-detect format, natural datetime)]:time' \
  '(-b --before)'{-b+,--before=}'[before time filter (auto-detect format, natural datetime)]:time' \
  '(-c --config)'{-c+,--config=}'[config YAML file path]:file:_files' \
  '(-cs --config-set)'{-cs+,--config-set=}'[set value to specified config item]:item' \
  '(-cg --config-get)'{-cg+,--config-get=}'[get value to specified config item]:item' \
  '(-d --debug)'{-d,--debug}'[print more error detail]' \
  '(-f --follow)'{-f,--follow}'[follow log output]' \
  '(-g --grok)'{-g+,--grok=}'[grok pattern for non-json log lines]:pattern' \
  '(-j --json)'{-j,--json}'[output the raw JSON but then apply filters]' \
  '(-l --level)'{-l+,--level=}'[filter by log level]:level' \
  '(-n --lines)'{-n+,--lines=}'[number of tail lines (default 10 for follow mode)]:lines' \
  '--reset-grok-library-dir[save default GROK patterns]' \
  '(-t --template)'{-t,--template}'[print a configuration YAML file template]' \
  '*:log file:_files' && ret=0

return ret
