#compdef cudafe
# Documentation: https://man.archlinux.org/search?q=cudafe
# Reference accessed: 2026-05-16

# cudafe: CUDA Front End (internal; called by nvcc)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-o[output file]:file:_files' \
  '*:input file:_files' && ret=0
return ret
