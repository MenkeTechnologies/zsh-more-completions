#compdef openMVG_main_ComputeFeatures
# Documentation: https://github.com/openMVG/openMVG/blob/develop/docs/sphinx/rst/software/SfM/SfM.rst
# openMVG: compute image features/descriptors

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input_file)'{-i,--input_file}'[input SfM_Data file]:file:_files' \
  '(-o --outdir)'{-o,--outdir}'[output directory]:dir:_files -/' \
  '(-m --describerMethod)'{-m,--describerMethod}'[describer method]:method:(SIFT SIFT_ANATOMY AKAZE_FLOAT AKAZE_MLDB)' \
  '(-u --upright)'{-u,--upright}'[use upright features (0 or 1)]:upright:(0 1)' \
  '(-f --force)'{-f,--force}'[force recompute data]:force:(0 1)' \
  '(-p --describerPreset)'{-p,--describerPreset}'[describer preset]:preset:(NORMAL HIGH ULTRA)' \
  '(-n --numThreads)'{-n,--numThreads}'[number of threads]:threads' \
  '*:arg:_files' && ret=0

return ret
