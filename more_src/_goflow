#compdef goflow
# Documentation: https://github.com/netsampler/goflow2
# Cloudflare NetFlow/sFlow collector that decodes and forwards flows to Kafka

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-nf=[enable/disable NetFlow]:enable:(true false)' \
  '-nf.addr=[NetFlow listener address]:address:_hosts' \
  '-nf.port=[NetFlow listener port]:port' \
  '-sflow=[enable/disable sFlow]:enable:(true false)' \
  '-sflow.addr=[sFlow listener address]:address:_hosts' \
  '-sflow.port=[sFlow listener port]:port' \
  '-kafka=[enable/disable Kafka output]:enable:(true false)' \
  '-kafka.brokers=[comma-separated Kafka broker addresses]:brokers' \
  '-kafka.srv=[use Kafka SRV record for broker discovery]:srv' \
  '-workers=[number of workers per protocol]:workers' && ret=0

return ret
