#compdef fstruct
# Output the names, sizes, etc of extensions in input file

local ret=1

_arguments -s \
  "infile=[input FITS file]:file:_files" \
  "outfile=[output file for the parameter values]:file:_files" \
  "colinfo=[list column information]:bool:(yes no)" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
