#compdef kfilebox
# Documentation: https://github.com/gtgt/kfilebox
# Reference accessed: 2026-05-16
# Verified: upstream gtgt/kfilebox - unmaintained since ~2013. KDE
# Dropbox front-end (not a Dolphin sidebar). No documented CLI flags
# beyond standard KDE/Qt generic options.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# kfilebox: KDE Dropbox front-end (unmaintained; GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--help-all[show all options]' && ret=0
return ret
