#compdef dosbox-staging

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--printconf[print config file location]' \
  '--editconf[open config file in editor]' \
  '--eraseconf[erase config file]' \
  '--resetconf[erase and regenerate config file]' \
  '--erasemapper[erase mapper file]' \
  '--resetmapper[erase and regenerate mapper file]' \
  '-conf+[use specified config file]:config file:_files -g "*.conf(-.)"' \
  '-c+[execute DOS command]:command:' \
  '-exit[exit after executing command (-c)]' \
  '-noautoexec[skip \[autoexec\] section of config]' \
  '-fullscreen[start in fullscreen mode]' \
  '-startmapper[start the keymapper]' \
  '-lang+[use language file]:language file:_files' \
  '-machine+[emulate specific machine type]:machine:(hercules cga ega vgaonly svga_s3 svga_et3000 svga_et4000 svga_paradise vesa_nolfb vesa_oldvbe tandy pcjr)' \
  '-noconsole[do not show console window (Windows)]' \
  '-securemode[enable secure mode]' \
  '-nolog[do not log to file]' \
  '-set+[set config option]:option:' \
  '*:file or directory:_files' && ret=0

return ret
