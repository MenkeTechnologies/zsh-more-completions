#compdef multirootca
# Documentation: https://github.com/cloudflare/cfssl/blob/master/cmd/multirootca/ca.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[listening address]:address:' \
  '-roots[root keys configuration file]:config file:_files' \
  '-l[default label]:label:' \
  '-tls-cert[server certificate]:cert file:_files' \
  '-tls-key[server private key]:key file:_files' \
  '-loglevel[log level (0=DEBUG..5=FATAL)]:level:(0 1 2 3 4 5)' && ret=0

return ret
