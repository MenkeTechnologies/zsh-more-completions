#compdef multirootca

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[listening address]:address:' \
  '-roots[root certificate configuration file]:config file:_files' \
  '-tls-cert[TLS certificate file]:cert file:_files' \
  '-tls-key[TLS key file]:key file:_files' \
  '-net[network type]:network:(tcp tcp4 tcp6 unix)' \
  '-l[default label]:label:' && ret=0

return ret
