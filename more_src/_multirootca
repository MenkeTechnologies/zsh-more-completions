#compdef multirootca

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[listening address]:address:' \
  '-l[log file]:file:_files' \
  '-roots[root certificate config file]:file:_files' \
  '-tls-cert[TLS certificate]:file:_files -g "*.pem(|.crt)"' \
  '-tls-key[TLS key]:file:_files -g "*.pem(|.key)"' \
  && ret=0

return ret
