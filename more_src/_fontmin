#compdef fontmin
# Documentation: https://github.com/ecomfe/fontmin
# Minify font files and subset glyphs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --text)'{-t,--text}'=[require glyphs by text]:text:' \
  '(-b --basic-text)'{-b,--basic-text}'[require glyphs with base chars]' \
  '(-d --deflate-woff)'{-d,--deflate-woff}'[deflate woff]' \
  '--font-family=[font-family for @font-face CSS]:family:' \
  '--css-glyph[generate a class for each glyph]' \
  '(-T --show-time)'{-T,--show-time}'[display processing time]' \
  '1:input file or directory:_files' \
  '2:output:_files -/' && ret=0

return ret
