#compdef traitor
# Linux privilege escalation exploit finder

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --any)'{-a,--any}'[try all exploits regardless of likelihood]' \
  '(-e --exploit)'{-e,--exploit}'[attempt to exploit found vulnerabilities]' \
  '(-p --path)'{-p,--path}'[additional paths to check]:path:_files -/' \
  && return 0
