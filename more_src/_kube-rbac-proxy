#compdef kube-rbac-proxy
# _kube-rbac-proxy — Kubernetes RBAC-aware reverse proxy
# upstream: https://github.com/brancz/kube-rbac-proxy
# Flags from cmd/kube-rbac-proxy/app/options/options.go on tip.

_kube-rbac-proxy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--insecure-listen-address=[DEPRECATED: HTTP listen host\:port]:host\:port:' \
        '--secure-listen-address=[HTTPS listen host\:port]:host\:port:' \
        '--upstream=[upstream URL to proxy to]:url:_urls' \
        '--upstream-force-h2c=[force h2c when talking to upstream]:bool:(true false)' \
        '--upstream-ca-file=[CA cert file for upstream TLS]:file:_files' \
        '--config-file=[proxy configuration file]:file:_files' \
        '--allow-paths=[csv of allowed request paths]:csv:' \
        '--ignore-paths=[csv of paths that bypass authn/authz]:csv:' \
        '--proxy-endpoints-port=[port for proxy /healthz etc]:port:' \
        '--tls-cert-file=[TLS server cert]:file:_files' \
        '--tls-private-key-file=[TLS server key]:file:_files' \
        '--tls-min-version=[min TLS version]:ver:(VersionTLS10 VersionTLS11 VersionTLS12 VersionTLS13)' \
        '--tls-cipher-suites=[csv of allowed cipher suites]:csv:' \
        '--tls-reload-interval=[DEPRECATED: TLS cert reload interval]:dur:' \
        '--upstream-client-cert-file=[client cert for authenticating to upstream]:file:_files' \
        '--upstream-client-key-file=[client key matching --upstream-client-cert-file]:file:_files' \
        '--client-ca-file=[CA cert file for client cert auth]:file:_files' \
        '--auth-header-fields-enabled=[forward auth-related headers upstream]:bool:(true false)' \
        '--auth-header-user-field-name=[user header field name]:name:' \
        '--auth-header-groups-field-name=[groups header field name]:name:' \
        '--auth-header-groups-field-separator=[groups header value separator]:sep:' \
        '--auth-token-audiences=[csv of accepted token audiences]:csv:' \
        '--oidc-issuer=[OIDC issuer URL]:url:_urls' \
        '--oidc-clientID=[OIDC client ID]:id:' \
        '--oidc-groups-claim=[JWT groups claim name]:name:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_kube-rbac-proxy "$@"
