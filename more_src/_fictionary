#compdef fictionary
# Documentation: https://github.com/judy2k/fictionary-rs
# Reference accessed: 2026-05-17
# Verified: clap-generated zsh completion shipped by upstream
# fictionary-rs v0.1.2 (probed via `fictionary completion zsh`
# after `cargo binstall fictionary@0.1.2`). Subcommands: words
# (default), compile, data-dir, data-dirs, names, completion, help.
# Removed from prior file: bogus man.archlinux.org search URL.

autoload -U is-at-least

_fictionary() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-c+[The number of fictionary words to be generated]:COUNT: ' \
'--count=[The number of fictionary words to be generated]:COUNT: ' \
'-m+[The minimum word length]:MIN_LENGTH: ' \
'--min-length=[The minimum word length]:MIN_LENGTH: ' \
'-x+[The maximum word length]:MAX_LENGTH: ' \
'--max-length=[The maximum word length]:MAX_LENGTH: ' \
'-p+[The path to a fictionary file which will be used to generate words]:FILE: ' \
'--fictionary-file=[The path to a fictionary file which will be used to generate words]:FILE: ' \
'-f+[The name of a fictionary to be used to generate words]:NAME: ' \
'--fictionary=[The name of a fictionary to be used to generate words]:NAME: ' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_fictionary_commands" \
"*::: :->fictionary" \
&& ret=0
    case $state in
    (fictionary)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:fictionary-command-$line[1]:"
        case $line[1] in
            (words)
_arguments "${_arguments_options[@]}" : \
'-c+[The number of fictionary words to be generated]:COUNT: ' \
'--count=[The number of fictionary words to be generated]:COUNT: ' \
'-m+[The minimum word length]:MIN_LENGTH: ' \
'--min-length=[The minimum word length]:MIN_LENGTH: ' \
'-x+[The maximum word length]:MAX_LENGTH: ' \
'--max-length=[The maximum word length]:MAX_LENGTH: ' \
'-p+[The path to a fictionary file which will be used to generate words]:FILE: ' \
'--fictionary-file=[The path to a fictionary file which will be used to generate words]:FILE: ' \
'-f+[The name of a fictionary to be used to generate words]:NAME: ' \
'--fictionary=[The name of a fictionary to be used to generate words]:NAME: ' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(compile)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':wordlist_path -- The path to a wordlist file. (A text file with one word per line):' \
':output_path -- The path to write the output fictionary file:' \
&& ret=0
;;
(data-dir)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(data-dirs)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(names)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':target:(bash fish zsh powershell man)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_fictionary__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:fictionary-help-command-$line[1]:"
        case $line[1] in
            (words)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(compile)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(data-dir)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(data-dirs)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(names)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_fictionary_commands] )) ||
_fictionary_commands() {
    local commands; commands=(
'words:Generate one or more fictionary words. This is the default command' \
'compile:Compile a fictionary from a wordlist file' \
'data-dir:Print out a (probably) writeable location of fictionary files' \
'data-dirs:Print out the locations to be searched for fictionary files' \
'names:Print out the available fictionary names' \
'completion:Generate completion files for different shells' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'fictionary commands' commands "$@"
}
(( $+functions[_fictionary__compile_commands] )) ||
_fictionary__compile_commands() {
    local commands; commands=()
    _describe -t commands 'fictionary compile commands' commands "$@"
}
