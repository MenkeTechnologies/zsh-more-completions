(( $+functions[_fictionary__names_commands] )) ||
_fictionary__names_commands() {
    local commands; commands=()
    _describe -t commands 'fictionary names commands' commands "$@"
}
(( $+functions[_fictionary__words_commands] )) ||
_fictionary__words_commands() {
    local commands; commands=()
    _describe -t commands 'fictionary words commands' commands "$@"
}

if [ "$funcstack[1]" = "_fictionary" ]; then
    _fictionary "$@"
else
    compdef _fictionary fictionary
fi
