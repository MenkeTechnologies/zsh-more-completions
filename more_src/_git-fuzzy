#compdef git-fuzzy

local -a arguments

arguments=(
    '1:command:(status log diff reflog stash branch)'
    '*:: :->args'
)

_arguments -s -S $arguments && return

case "$state" in
    args)
        case ${words[1]} in
            log)
                _arguments '*:git log arguments:'
                ;;
            diff)
                _arguments '*:files:_files'
                ;;
            branch)
                _arguments '*:branches:'
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac
