#compdef IntervalListTools
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#IntervalListTools
# Picard: manipulate interval lists (merge, subtract, scatter, pad, sort)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  '*'{-I=,--INPUT=}'[one or more interval lists to merge]:interval_list:_files' \
  {-O=,--OUTPUT=}'[output directory or file (depends on scatter count)]:output:_files' \
  '--PADDING=[amount to pad each end of the intervals by]:int:' \
  '--UNIQUE=[merge overlapping and adjacent intervals into unique intervals]:bool:(true false)' \
  '--SORT=[sort the resulting interval list by coordinate]:bool:(true false)' \
  '--ACTION=[action to take on inputs]:action:(CONCAT UNION INTERSECT SUBTRACT SYMDIFF DIFFERENCE OVERLAPS)' \
  {-SI=,--SECOND_INPUT=}'[second interval set for SUBTRACT and DIFFERENCE]:interval_list:_files' \
  '--COMMENT=[comment line to add to the output header]:comment:' \
  '--SCATTER_COUNT=[number of files to scatter the resulting list into]:int:' \
  '--INCLUDE_FILTERED=[include filtered variants when reading from VCF]:bool:(true false)' \
  '--INVERT=[produce the inverse list]:bool:(true false)' \
  {-BRK=,--BREAK_BANDS_AT_MULTIPLES_OF=}'[break intervals at integer multiples of this value]:int:' \
  {-M=,--SUBDIVISION_MODE=}'[subdivision mode during scattering]:mode:(INTERVAL_SUBDIVISION BALANCING_WITHOUT_INTERVAL_SUBDIVISION BALANCING_WITHOUT_INTERVAL_SUBDIVISION_WITH_OVERFLOW INTERVAL_COUNT INTERVAL_COUNT_WITH_DISTRIBUTED_REMAINDER)' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:interval list:_files' && ret=0

return ret
