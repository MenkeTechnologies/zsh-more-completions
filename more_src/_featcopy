#compdef featcopy
# Documentation: https://man.archlinux.org/search?q=featcopy
# Reference accessed: 2026-05-16

# EMBOSS featcopy: read and write a feature table (format conversion)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-features=[input feature table]:USA:_files' \
  '-outfeat=[output feature file]:file:_files' \
  '-offormat=[output feature format]:format:(gff3 gff2 embl swiss pir refseqp)' \
  '*:feature USA:_files' && ret=0
return ret
