#compdef u-boot-mkimage mkimage

# u-boot mkimage: build U-Boot legacy/FIT images
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-l[list image content]' \
  '-A[architecture]:arch:(alpha arc arm arm64 avr32 blackfin ia64 m68k microblaze mips mips64 nds32 nios2 or1k powerpc ppc riscv sandbox sh sparc sparc64 x86 x86_64)' \
  '-O[OS]:os:(invalid openbsd netbsd freebsd 4_4bsd linux svr4 esix solaris irix sco dell ncr lynxos vxworks psos qnx u-boot rtems artos unity integrity ose plan9 openrtos arm-trusted-firmware tee opensbi efi)' \
  '-T[image type]:type:(invalid standalone kernel ramdisk multi firmware script filesystem flat_dt kwbimage imximage ublimage omapimage aisimage kernel_noload pblimage mxsimage atmelimage x86_setup lpc32xximage rkimage rksd rkspi zynqimage zynqmpimage zynqmpbif fpga vybridimage tee firmware_ivt pmmc stm32image socfpgaimage socfpgaimage_v1 mtk_image copro sunxi_egon sunxi_toc0 fit imx8mimage imx8image phyimage)' \
  '-C[compression]:compression:(none gzip bzip2 lzma lzo lz4 zstd)' \
  '-a[load address (hex)]:hex:' \
  '-e[entry point address (hex)]:hex:' \
  '-n[image name]:name:' \
  '-d[data file (or list)]:files:_files' \
  '-x[set XIP flag]' \
  '-D[dtc options]:opts:' \
  '-B[FIT image padding alignment]:n:' \
  '-f[FIT config file]:file:_files -g "*.its"' \
  '-F[reuse existing FIT image as input]' \
  '-i[include images in FIT]:files:_files' \
  '-k[private key dir for signing]:dir:_files -/' \
  '-K[public key in DTB]:file:_files' \
  '-r[require signed images]' \
  '-R[required loadables]:str:' \
  '-N[engine for signing]:engine:' \
  '-s[skip data sign]' \
  '-v[verify]' \
  '-V[show version]' \
  '-G[private key file]:file:_files' \
  '-p[external data offset]:n:' \
  '-o[checksum type]:type:(crc32 md5 sha1 sha256 sha384 sha512)' \
  '*:output file:_files' && ret=0
return ret
