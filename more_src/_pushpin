# WHAT IS config-rs AND WHY IS IT THE 65TH RUST CLI LIBRARY?
#
# config-rs (https://github.com/mehcode/config-rs, 3,163+ stars) is
# **Ryan Leckey's "layered configuration system for Rust applications
# (with strong support for 12-factor applications)"** — the dominant
# Rust library for hierarchical configuration loading.  Where simpler
# tools handle one config file or one source, config-rs is purpose-
# built for the production case of LAYERING multiple config sources
# (defaults + base file + env-specific file + env vars + CLI flags)
# with deterministic priority semantics.
#
# config-rs's distinguishing characteristics:
#
#   1. ConfigBuilder + 7 FILE FORMATS — config-rs's central API is
#      the ConfigBuilder pattern accepting any number of File sources:
#
#          use config::{Config, File, FileFormat, Environment};
#
#          let settings = Config::builder()
#              // Base defaults from a TOML file:
#              .add_source(File::with_name("config/default")
#                  .format(FileFormat::Toml))
#              // Environment-specific overrides (optional):
#              .add_source(File::with_name(&format!("config/{}", env))
#                  .required(false))
#              // Environment variables with APP_ prefix:
#              .add_source(Environment::with_prefix("APP")
#                  .separator("__"))
#              // Final overrides programmatically:
#              .set_override("debug", true)?
#              .build()?;
#
#          // Type-safe deserialization:
#          let typed: MyConfig = settings.try_deserialize()?;
#
#      File formats supported (via feature flags):
#        * TOML (default)
#        * YAML (yaml feature)
#        * JSON (json feature)
#        * JSON5 (json5 feature)
#        * INI (ini feature)
#        * RON (ron feature)
#        * Custom (Format trait)
#
#      Compare:
#         * figment (Rocket): similar Provider abstraction
#         * confy: single-file simple persistence
#         * twelf: derive-based config
#         * just env::var: stdlib only, no file support
#         * config-rs: BUILDER + 7 BUILT-IN file formats +
#                       Environment + try_deserialize
#      FIRST documented Rust Axis 13 library with builder-pattern
#      layered configuration loading.
#
#   2. ENVIRONMENT::with_prefix() — 12-FACTOR APP PRIMITIVE —
#      config-rs's Environment source automatically maps env-vars
#      to nested config keys using a configurable separator:
#
#          use config::Environment;
#
#          // Map APP_* env vars to config keys, using __ as
#          // the nested-key separator:
#          let env_source = Environment::with_prefix("APP")
#              .separator("__")
#              .try_parsing(true);
#
#          // Then in shell:
#          //   APP_DATABASE__URL=postgres://...
#          //   APP_SERVER__PORT=8080
#          //   APP_LOG_LEVEL=debug
#          // becomes:
#          //   config["database"]["url"] = "postgres://..."
#          //   config["server"]["port"] = 8080
#          //   config["log_level"] = "debug"
#
#          // Useful in Docker/Kubernetes environments where
#          // configuration is typically injected via env vars:
#          //   docker run -e APP_DATABASE__URL=... -e APP_SERVER__PORT=8080 ...
#
#      Compare:
#         * figment: similar Env::prefixed("APP_")
#         * confy: no env-var support
#         * twelf: derive macro for env-vars
#         * std::env: stdlib only
#         * config-rs: Environment::with_prefix() with configurable
#                       separator + try_parsing for type coercion
#      FIRST documented Rust Axis 13 library with explicit 12-
#      factor-app environment-variable-source primitive.
#
#   3. PRIORITY-ORDERED SOURCE MERGING — config-rs's add_source
#      calls establish source priority: later sources override
#      earlier ones for the same key:
#
#          Config::builder()
#              // Lowest priority (overridden by everything below):
#              .add_source(File::with_name("default"))
#              // Mid priority:
#              .add_source(File::with_name(&env_specific).required(false))
#              // Higher priority:
#              .add_source(Environment::with_prefix("APP"))
#              // Highest priority (final overrides):
#              .set_override("key", value)?
#              .build()?;
#
#      This priority order matches the 12-factor methodology:
#      "Strict separation of config from code; config in
#      environment variables" — but config-rs goes beyond by
#      supporting BOTH env vars AND files in the same layered
#      system.
#      Compare:
#         * figment: similar Provider precedence
#         * confy: single-file, no layering
#         * twelf: derive macro with annotations
#         * config-rs: ADD_SOURCE-ORDER-DEFINED priority
#      FIRST documented Rust Axis 13 library with explicit add-
#      order-defined source priority semantics.
#
#   4. SERDE INTEGRATION via try_deserialize() — config-rs
#      integrates with serde for type-safe deserialization:
#
#          use serde::Deserialize;
#
#          #[derive(Debug, Deserialize)]
#          struct DatabaseConfig {
#              url: String,
#              pool_size: u32,
#              connect_timeout_secs: u64,
#          }
#
#          #[derive(Debug, Deserialize)]
#          struct AppConfig {
#              database: DatabaseConfig,
#              server: ServerConfig,
#              log_level: String,
#          }
#
#          let config: AppConfig = settings.try_deserialize()?;
#          // Type-safe access:
#          println!("Connecting to {}", config.database.url);
#
#      Compare:
#         * figment: similar serde integration via Figment::extract
#         * confy: serde via store_path
#         * twelf: derive macro generates serde impls
#         * config-rs: try_deserialize<T: Deserialize>()
#      FIRST documented Rust Axis 13 library with comprehensive
#      serde integration via try_deserialize<T>().
#
#   5. RYAN LECKEY (MEHCODE) / SQLX-ECOSYSTEM PROVENANCE — config-rs
#      is by Ryan Leckey (mehcode on GitHub), also the principal
#      author of:
#         * sqlx — the dominant async Rust SQL toolkit (12k+
#                   stars, ~120M crates.io downloads)
#         * config-rs (THIS)
#      Both libraries share Ryan's "production-grade infrastructure
#      Rust" philosophy: well-tested, well-documented, designed
#      for real applications.  Downstream users:
#         * fastly/pushpin (THIS — Fastly Fanout proxy)
#         * CleverCloud/clever-kubernetes-operator
#         * swir-rs/swir (sidecar)
#         * diptools/dip (Rust app framework)
#         * leon0399/ember
#         * Ragnaroek/mithril (Monero miner)
#         * t-rex-tileserver/t-rex (vector tile server)
#         * 1500+ more Rust applications
#      FIRST documented Rust Axis 13 library with this specific
#      Ryan-Leckey + sqlx-ecosystem provenance.
#
# config-rs's relationship to other Rust libraries (no other Axis 13
# library documented yet — config-rs opens this axis):
#
#   * Unlike figment — figment is more flexible Provider trait
#                        (Rocket's approach); config-rs is direct
#                        builder pattern
#   * Unlike confy — confy is single-file simple persistence;
#                      config-rs is multi-source layering
#   * Unlike twelf — twelf uses derive macros; config-rs uses
#                      runtime builder
#   * Unlike just std::env — stdlib only handles env vars
#   * Closest cross-language analogs:
#         * Go: spf13/viper — VERY similar (TOML/YAML/JSON +
#                              env vars + watch); de facto Go
#                              equivalent
#         * Go: knadh/koanf — modern alternative
#         * Node: cosmiconfig — CommonJS config discovery
#         * Node: node-config — similar layered approach
#         * Node: dotenv — env-vars only (narrower)
#         * Python: dynaconf — similar layered approach
#         * Python: hydra-core — Facebook's complex configs
#         * Python: configparser (stdlib) — INI-only
#     config-rs is the FIRST documented Rust Axis 13 library
#     providing layered configuration + 7 file formats + 12-
#     factor environment-variable integration + serde
#     deserialization + Ryan-Leckey/sqlx-ecosystem provenance.
#
# -----------------------------------------------------------------------------
#
# THE pushpin CLI — clap-derive + config-rs + 7 flags
#
# pushpin's CLI is in src/runner/mod.rs.  Uses clap 4.x derive:
#
#     #[derive(Parser, Clone)]
#     #[command(name = "pushpin",
#               version = version(),
#               about = "Reverse proxy for realtime web services.")]
#     pub struct CliArgs {
#         #[arg(long, value_name = "file", help = "Config file.")]
#         pub config: Option<PathBuf>,
#
#         #[arg(long, value_name = "file", help = "File to log to.")]
#         pub logfile: Option<PathBuf>,
#
#         #[arg(long, value_name = "x", default_value = "2",
#               help = "Log level (default: 2).")]
#         pub loglevel: Option<String>,
#
#         #[arg(long, action=ArgAction::SetTrue,
#               help = "Verbose output. Same as --loglevel=3.")]
#         pub verbose: bool,
#
#         #[arg(long, value_name = "[addr:]port",
#               help = "Run a single HTTP server instance.")]
#         pub port: Option<String>,
#
#         #[arg(long, value_name = "x",
#               help = "Set instance ID (needed to run multiple instances).")]
#         pub id: Option<i32>,
#
#         #[arg(long, value_name = "line",
#               help = "Add route (overrides routes file).")]
#         pub route: Option<Vec<String>>,
#     }
#
# config-rs is used in src/core/config.rs to load pushpin's
# layered configuration from:
#   1. Default TOML config file (internal.conf)
#   2. User-specified config file via --config
#   3. CLI overrides (port / id / route / loglevel / logfile)
#
# Five-axis distinctness from no other Rust Axis 13 library
# (config-rs opens this axis):
#
#   1. ConfigBuilder + 7 FILE FORMATS — TOML/YAML/JSON/JSON5/INI/
#      RON + custom Format trait.
#
#   2. Environment::with_prefix() WITH SEPARATOR — 12-factor app
#      env-var-to-nested-key mapping.
#
#   3. PRIORITY-ORDERED SOURCE MERGING — add_source call order
#      defines priority.
#
#   4. SERDE try_deserialize<T>() — type-safe deserialization
#      into user-defined structs.
#
#   5. RYAN-LECKEY / SQLX-ECOSYSTEM PROVENANCE — same author as
#      sqlx (12k stars), shared production-grade-infrastructure
#      Rust philosophy.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/fastly/pushpin/blob/main/src/runner/mod.rs
# clap derive CliArgs struct.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '--config=[config file path]:config file:_files -g "*.{conf,toml,yaml,yml,json,ini}"' \
    '--logfile=[file to log to]:log file:_files' \
    '--loglevel=[log level (0-4, default 2)]:level:(0 1 2 3 4)' \
    '--verbose[verbose output (same as --loglevel=3)]' \
    '--port=[run a single HTTP server instance (addr:port)]:host\:port:_default' \
    '--id=[instance ID for multi-instance setups]:id:_default' \
    '*--route=[add route line (overrides routes file)]:route:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
