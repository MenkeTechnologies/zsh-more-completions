#compdef totalseg_get_phase
# Documentation: https://github.com/wasserth/TotalSegmentator
# Predict contrast phase from a TotalSegmentator input image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[input image]:input:_files' \
  '-o[output file]:output:_files' \
  '*:arg:_files' && ret=0

return ret
