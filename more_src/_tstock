#compdef tstock

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-y[show yearly chart]' \
  '--yearly[show yearly chart]' \
  '-w[show weekly chart]' \
  '--weekly[show weekly chart]' \
  '-d[show daily chart]' \
  '--daily[show daily chart]' \
  '-i[show intraday chart]' \
  '--intraday[show intraday chart]' \
  '--padx[horizontal padding]:padding value:' \
  '--pady[vertical padding]:padding value:' \
  '-c[chart type]:chart type:(line candle)' \
  '--chart[chart type]:chart type:(line candle)' \
  '--color[color scheme]:color scheme:(default green red)' \
  '*:stock symbol:' && ret=0

return ret
