#compdef virt-launcher
# _virt-launcher — KubeVirt per-VMI pod entrypoint (kubevirt/kubevirt)
# upstream: https://github.com/kubevirt/kubevirt
# Flags from cmd/virt-launcher/virt-launcher.go (pflag) on tip.

_virt-launcher() {
    _arguments \
        '--qemu-timeout=[qemu start timeout]:dur:' \
        '--kubevirt-share-dir=[shared dir with virt-handler]:dir:_files -/' \
        '--ephemeral-disk-dir=[ephemeral disk dir]:dir:_files -/' \
        '--container-disk-dir=[container disk dir]:dir:_files -/' \
        '--hotplug-disk-dir=[hotplug disk dir]:dir:_files -/' \
        '--name=[VirtualMachineInstance name]:name:' \
        '--uid=[VirtualMachineInstance UID]:uid:' \
        '--namespace=[VirtualMachineInstance namespace]:ns:' \
        '--grace-period-seconds=[SIGTERM grace period (s)]:n:' \
        '--allow-emulation[allow software emulation fallback]' \
        '--run-as-nonroot[run virtqemud as virt user]' \
        '--image-volume[use ImageVolume instead of containerDisk]' \
        '--libvirt-hook-server-and-client[enable pre-migration hooks on target pod]' \
        '--upgrade-ordinal-ifaces[enable ordinal iface naming upgrade]' \
        '--vgpu-dedicated-hook[enable vGPU mdev UUID mutation hook]' \
        '--vm-stats-collector[enable guest-agent VMStats workers]' \
        '--hook-sidecars=[expected hook sidecars to wait for]:n:' \
        '--disk-memory-limit=[disk verification memory limit (bytes)]:n:' \
        '--ovmf-path=[OVMF EFI ROM directory]:dir:_files -/' \
        '--qemu-agent-sys-interval=[guest-agent sys poll interval]:dur:' \
        '--qemu-agent-file-interval=[guest-agent file poll interval]:dur:' \
        '--qemu-agent-user-interval=[guest-agent user poll interval]:dur:' \
        '--qemu-agent-version-interval=[guest-agent version poll interval]:dur:' \
        '--qemu-fsfreeze-status-interval=[fsfreeze status poll interval]:dur:' \
        '--simulate-crash[crash immediately for crash-loop test]' \
        '--libvirt-log-filters=[libvirt log filters string]:filters:' \
        '--hypervisor=[hypervisor backend]:hyp:(kvm qemu)' \
        '-v[klog verbosity level]:n:'
}

_virt-launcher "$@"
