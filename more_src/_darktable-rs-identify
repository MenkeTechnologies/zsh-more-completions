#compdef darktable-rs-identify
# Documentation: https://man.archlinux.org/search?q=darktable-rs-identify
# Reference accessed: 2026-05-16

# darktable-rs-identify: identify rawspeed-supported camera/file properties
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)-h[show help]' \
  '*:raw files:_files -g "*.(cr2|cr3|nef|raf|arw|orf|dng|raw|rw2|pef|srw|3fr|fff|iiq|x3f|mrw|mef|kdc|dcr|mos)"' && ret=0
return ret
