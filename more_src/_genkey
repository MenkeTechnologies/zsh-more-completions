#compdef genkey
# Documentation: https://www.systutorials.com/docs/linux/man/1-genkey/
# Reference accessed: 2026-05-16
# Verified: Red Hat crypto-utils genkey(1).

# genkey: Red Hat crypto-utils interactive cert/key generator
local curcontext="$curcontext" ret=1
_arguments -C \
  '--test[skip slow random generation (test only)]' \
  '--days=[certificate validity days (default 30)]:count:' \
  '--genreq[generate CSR for an existing key]' \
  '--makeca[generate CA keypair and certificate]' \
  '--nss[use mod_nss database for storage]' \
  '--renew[renewal mode (use with --genreq)]' \
  '--cacert[renewal is for a CA cert (openssl only)]' \
  '*:hostname:' && ret=0
return ret
