#compdef psftostl
# Documentation: https://man.archlinux.org/search?q=psftostl
# Reference accessed: 2026-05-16

# psftostl: convert Linux PSF console font to STL (3D printable model)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:input PSF file and output STL:_files -g "*.(psf|psf.gz|stl)"' && ret=0
return ret
