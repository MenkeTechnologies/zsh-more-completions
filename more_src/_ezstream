#compdef ezstream
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/ezstream.1.html
# ezstream - source client for Icecast with external de-/encoder support

local ret=1

_arguments -s -S \
  '-c[use the XML configuration in configfile]:configfile:_files' \
  '-p[write the ezstream process ID to pidfile]:pidfile:_files' \
  '-s[run ezstream as a line-based shuffling utility]:playlist:_files' \
  '-r[maintain real-time status information on stdout]' \
  '-q[be more quiet, suppress external program stderr]' \
  '*-v[increase logging verbosity]' \
  '-V[print the ezstream version number and exit]' \
  '-h[print a summary of available command line arguments]' && ret=0

return ret
