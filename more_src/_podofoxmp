#compdef podofoxmp
# Documentation: https://github.com/podofo/podofo/blob/master/tools/podofoxmp/podofoxmp.cpp
# podofoxmp - display or replace XMP metadata in a PDF document

local ret=1

_arguments -s -S \
  '1:PDF file:_files -g "*.pdf"' \
  '2:XMP file:_files' \
  '3:output PDF file:_files -g "*.pdf"' && ret=0

return ret
