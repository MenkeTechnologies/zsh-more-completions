#compdef ndb_mgmd
# Documentation: https://dev.mysql.com/doc/refman/8.0/en/mysql-cluster-programs.html
# NDB Cluster management server daemon

local ret=1

_arguments -s -S \
  '(-? --help --usage)'{-\?,--help,--usage}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --config-file)'{-f,--config-file}'+[cluster configuration file]:file:_files' \
  '--configdir=[configuration cache directory]:dir:_files -/' \
  '--ndb-nodeid=[set node ID for this node]:id:' \
  '--nodaemon[run in foreground]' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '--initial[delete cache and reload config from file]' \
  '--reload[reload config if file differs from cache]' \
  '--bind-address=[bind to specific network interface]:host:_hosts' \
  '(-c --ndb-connectstring --connect-string)'{-c,--ndb-connectstring,--connect-string}'+[management server connection string]:string:' \
  '--config-cache=[enable/disable config cache]:bool:(TRUE FALSE)' \
  '--skip-config-cache[disable configuration caching]' \
  '--skip-config-file[do not read config file]' \
  '(-P --print-full-config)'{-P,--print-full-config}'[print full configuration and exit]' \
  '--mycnf[read configuration from my.cnf]' \
  '--cluster-config-suffix=[override defaults group suffix]:name:' \
  '--log-name=[name for this node in cluster log]:name:' \
  '(-v --verbose)'{-v,--verbose}'[write additional info to log]' \
  '--interactive[start in interactive mode]' \
  '--nowait-nodes=[do not wait for listed management nodes]:list:' \
  '--no-nodeid-checks[skip node ID checks]' \
  '--defaults-file=[read options from specified file only]:file:_files' \
  '--defaults-extra-file=[read file after global files]:file:_files' \
  '--no-defaults[do not read default options]' \
  '--print-defaults[print argument list and exit]' && ret=0

return ret
