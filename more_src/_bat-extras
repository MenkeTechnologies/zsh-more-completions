#compdef batgrep batdiff batman batpipe prettybat batwatch

# Zsh completion for bat-extras collection

local curcontext="$curcontext" state line ret=1

case ${words[1]} in
  batgrep)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--no-separator[do not show separators between files]' \
      '--no-snip[do not show snip markers]' \
      '--no-highlight[do not highlight matches]' \
      '--color[force color output]' \
      '--no-color[disable color output]' \
      '--paging=[paging mode]:mode:(auto always never)' \
      '--pager=[pager program]:pager' \
      '--terminal-width=[terminal width]:width' \
      '--context=[context lines]:lines' \
      '-A+[lines after match]:lines' \
      '-B+[lines before match]:lines' \
      '-C+[context lines]:lines' \
      '-i[case insensitive]' \
      '-s[case sensitive]' \
      '-S[smart case]' \
      '--search-pattern=[search pattern]:pattern' \
      '*:pattern or file:_files' && ret=0
    ;;
  batdiff)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--delta[use delta as diff viewer]' \
      '--color[force color output]' \
      '--no-color[disable color output]' \
      '--paging=[paging mode]:mode:(auto always never)' \
      '--pager=[pager program]:pager' \
      '--terminal-width=[terminal width]:width' \
      '--context=[context lines]:lines' \
      '*:file:_files' && ret=0
    ;;
  batman)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--color=[color mode]:mode:(auto always never)' \
      '--paging=[paging mode]:mode:(auto always never)' \
      '--pager=[pager program]:pager' \
      '*:man page' && ret=0
    ;;
  batpipe)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--color=[color mode]:mode:(auto always never)' \
      '--paging=[paging mode]:mode:(auto always never)' \
      '--pager=[pager program]:pager' \
      '--terminal-width=[terminal width]:width' \
      '*:file:_files' && ret=0
    ;;
  prettybat)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--color=[color mode]:mode:(auto always never)' \
      '--paging=[paging mode]:mode:(auto always never)' \
      '--pager=[pager program]:pager' \
      '--language=[language]:language' \
      '--theme=[bat theme]:theme' \
      '*:file:_files' && ret=0
    ;;
  batwatch)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--watcher=[file watcher]:watcher:(poll entr)' \
      '-n+[interval in seconds]:seconds' \
      '--interval=[interval in seconds]:seconds' \
      '--color=[color mode]:mode:(auto always never)' \
      '--paging=[paging mode]:mode:(auto always never)' \
      '*:file:_files' && ret=0
    ;;
esac

return ret
