#compdef apitrace
# OpenGL / Direct3D API call tracer

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'trace:trace API calls'
  'retrace:replay API trace'
  'dump:dump trace to text'
  'diff:compare two traces'
  'trim:trim a trace'
  'pick:pick frames from trace'
  'sed:search and replace in trace'
)

_arguments -s -S \
  '1:command:->command' \
  '--help[show help]' \
  '--version[show version]' \
  '*:argument:' && ret=0

case $state in
  (command)
    _describe -t commands 'apitrace command' commands && ret=0
    ;;
esac

return ret
