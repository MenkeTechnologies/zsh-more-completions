#compdef acpihelp
# Documentation: acpihelp
# Source: acpica/acpica source/tools/acpihelp/ahmain.c (master) — display ACPI/ASL/AML reference info (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '(-v -vd)-v[show version]' \
    '(-v -vd)-vd[show build date]' \
    '-a+[show ASL operator and AML opcode by name/prefix]:name:_default' \
    '-g+[show AML grammar element]:name:_default' \
    '-m+[show AML opcode by name]:name:_default' \
    '-e+[decode ACPICA exception code]:hex:_default' \
    '-o+[decode hex AML opcode]:hex:_default' \
    '-x+[decode iASL exception code]:hex:_default' \
    '-k+[show ASL keyword]:name:_default' \
    '-p+[show ASL predefined method]:name:_default' \
    '-s+[show ASL operator name]:name:_default' \
    '-i+[show ACPI/PnP Hardware IDs]:name:_default' \
    '-d[show iASL preprocessor directives]' \
    '-t[show supported ACPI tables]' \
    '-u[show ACPI UUIDs]' \
    && ret=0

return ret
