#compdef simg2img

# simg2img: convert Android sparse images to raw images
# Documentation: https://android.googlesource.com/platform/system/core/+/refs/heads/main/libsparse/README.md
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:input sparse images output:_files' && ret=0
return ret
