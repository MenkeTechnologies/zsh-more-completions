local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*--allow-build=[packages allowed to run postinstall scripts]:packages:' \
  '--package=[package to install before running command]:package:' \
  {-c,--shell-mode}'[run script inside a shell]' \
  '*::command and args:_normal' && ret=0

return ret
