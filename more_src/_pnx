#compdef pnx
# Documentation: https://pnpm.io/cli/dlx
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Note: pnx is an alias for pnpm dlx.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--allow-build=[packages allowed to run postinstall scripts]:packages' \
  '*--package=[package to install before running command]:package' \
  {-c,--shell-mode}'[run command inside a shell]' \
  {-s,--silent}'[only show output from executed command]' \
  '*::command and args:_normal' && ret=0

return ret
