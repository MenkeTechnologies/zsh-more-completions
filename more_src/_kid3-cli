#compdef kid3-cli
# _kid3-cli — Kid3 ID3-tag editor CLI / batch mode (KDE/kid3)
# upstream: https://github.com/KDE/kid3
# Subcommands from src/app/cli/clicommand.cpp.

_kid3-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--portable[use a portable config file (./kid3.ini)]' \
        '--dbus[activate the D-Bus interface]' \
        '(-c --command)'{-c+,--command=}'[run this command (repeatable, ; for multiple)]:cmd:' \
        '1: :_kid3-cli_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                ls|pwd|save|exit|revert|copy|paste|remove|albumart)
                    ;;
                cd|renamedir)
                    _arguments '1:directory:_files -/'
                    ;;
                select)
                    _arguments '1:selection:(all none first previous next)'
                    ;;
                tag)
                    _arguments '1:tag number:(1 2 3 12 23 123)'
                    ;;
                config)
                    _arguments '1:config key:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kid3-cli_commands] )) ||
_kid3-cli_commands() {
    local -a commands
    commands=(
        'help:show kid3-cli help'
        'timeout:set/show the per-command timeout'
        'exit:quit the application'
        'cd:change directory'
        'pwd:print current directory'
        'ls:list files in current directory'
        'save:save the changed files'
        'select:select a file (all/none/first/previous/next)'
        'tag:select tag (1, 2, 3, 12, 23, 123)'
        'get:get a tag frame value'
        'set:set a tag frame value'
        'revert:revert all unsaved changes'
        'import:import tags from a file'
        'autoimport:auto-import via the configured services'
        'export:export tags to a file'
        'config:get/set a kid3 config value'
        'copy:copy tags to the internal buffer'
        'paste:paste tags from the internal buffer'
        'remove:remove tags'
        'fromtag:set filename from tag values'
        'syncto:sync the selected tag to another tag'
        'filenameformat:set/show the filename format'
        'tagformat:set/show the tag format'
        'textencoding:set/show the text encoding'
        'numbertracks:auto-number track tags'
        'renamedir:rename the current directory from tags'
        'filter:filter the current file list'
        'playlist:create / open a playlist'
        'albumart:fetch / replace album art'
        'execute:execute an external command'
    )
    _describe -t commands 'kid3-cli command' commands
}

_kid3-cli "$@"
