#compdef samtools-markdup
# Documentation: http://www.htslib.org/doc/samtools-markdup.html
# samtools markdup: Mark duplicate alignments in a coordinate sorted file

local ret=1

_arguments -s -S \
  '(-l)'-l'[Expected maximum read length of INT bases. \[300\]]:INT: ' \
  '(-r)'-r'[Remove duplicate reads.]' \
  '(-T)'-T'[Write temporary files to PREFIX . samtools . nnnn . mmmm . tmp]:PREFIX: ' \
  '(-S)'-S'[Mark supplementary reads of duplicates as duplicates.]' \
  '(-s)'-s'[Print some basic stats. See STATISTICS.]' \
  '(-f)'-f'[Write stats to named file.]:file:_files' \
  '(--json)'--json'[Output stats in JSON format.]' \
  '(-d)'-d'[The optical duplicate distance. Suggested settings of 100 for HiSeq st]:distance: ' \
  '(-c)'-c'[Clear previous duplicate settings and tags.]' \
  '(-t)'-t'[Mark duplicates with the name of the original in a do tag.]' \
  '(--duplicate-count)'--duplicate-count'[Record the original primary read duplication count (including itself)]' \
  '(-m --mode)'{-m,--mode}'[Duplicate decision method for paired reads. Values are t or s . Mode t]:TYPE: ' \
  '(-u)'-u'[Output uncompressed SAM, BAM or CRAM.]' \
  '(--include-fails)'--include-fails'[Include quality checked failed reads.]' \
  '(--no-multi-dup)'--no-multi-dup'[Stop checking duplicates of duplicates for correctness. While still ma]' \
  '(--read-coords)'--read-coords'[This takes a POSIX regular expression for at least x and y to be used]:REGEX: ' \
  '(--coords-order)'--coords-order'[The order of the elements captured in the regular expression. Default]:ORDER: ' \
  '(--barcode-tag)'--barcode-tag'[Duplicates must now also match the barcode tag.]:TAG: ' \
  '(--barcode-name)'--barcode-name'[Use the UMI/barcode embedded in the read name (eigth colon delimited p]' \
  '(--barcode-rgx)'--barcode-rgx'[Regex for barcode in the readname (alternative to --barcode-name).]:REGEX: ' \
  '(--use-read-groups)'--use-read-groups'[The @RG tags must now also match to be a duplicate.]' \
  '(--no-PG)'--no-PG'[Do not add a PG line to the output file.]' \
  '(--threads)'--threads'[Number of input/output compression threads to use in addition to main]:INT: ' \
  '*:file:_files' && ret=0

return ret
