# _libtiff — SGI libtiff TIFF tools tiffinfo tiffcp tiff2pdf tiff2ps for inspecting and converting TIFF images (libtiff team, C); getopt
# upstream: https://gitlab.com/libtiff/libtiff

_libtiff() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[compression]:c:(none g3 g4 lzw jpeg zip packbits)' \
        '--compress=+[compression]:c:(none g3 g4 lzw jpeg zip packbits)' \
        '-f+[fill order]:f:(lsb2msb msb2lsb)' \
        '--fill-order=+[fill order]:f:(lsb2msb msb2lsb)' \
        '-l+[length]:n:' \
        '-p+[photometric]:p:(min-is-black min-is-white miniswhite minisblack rgb rgba palette mask ycbcr cielab itulab logl logluv)' \
        '--photometric=+[photometric]:p:(min-is-black min-is-white rgb rgba palette mask ycbcr)' \
        '-r+[rows per strip]:n:' \
        '--rows-per-strip=+[rows per strip]:n:' \
        '-s[strip output]' \
        '-t[tile output]' \
        '-w+[width]:n:' \
        '-x+[width units]:str:' \
        '-y+[height units]:str:' \
        '-i[ignore read errors]' \
        '-d+[directory]:n:' \
        '--dir=+[directory]:n:' \
        '-#+[strip number]:n:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-D[print directory listing]' \
        '-j[show JPEG info]' \
        '-J[show extended JPEG info]' \
        '-c+[compression]:c:(none g3 g4 lzw jpeg zip packbits)' \
        '-z+[deflate level]:n:' \
        '-X+[XMP file]:file:_files' \
        '-E+[EXIF file]:file:_files' \
        '--quality=+[N]:n:' \
        '--tile=+[width height]:str:' \
        '--bits=+[N]:n:' \
        '--strip=+[N]:n:' \
        '--rotate=+[N]:n:(0 90 180 270)' \
        '--flip=+[axis]:a:(h v)' \
        '*:tiff file:_files -g "*.tif *.tiff *.png *.jpg *.jpeg *.pdf *.ps *.bmp *.gif *.ppm *.pgm *.pbm *.raw *.yuv"'
}

_libtiff "$@"
