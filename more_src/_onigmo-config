#compdef onigmo-config

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[change/print prefix]:dir:_files -/' \
  '--exec-prefix=-[change/print exec prefix]:dir:_files -/' \
  '--cflags[print C compiler flags]' \
  '--libs[print library information]' \
  '--version[print onigmo version]' \
  '--help[print help]' && ret=0

return ret
