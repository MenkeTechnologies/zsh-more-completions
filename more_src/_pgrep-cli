#compdef pgrep-cli pkill-cli
# _pgrep-cli — procps pgrep/pkill look up or signal processes based on name CLI alias (procps team, C); custom argparse
# upstream: https://gitlab.com/procps-ng/procps

_pgrep-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[count of matching processes]' \
        '--count[count of matching processes]' \
        '-d+[delimiter]:str:' \
        '--delimiter=+[delimiter]:str:' \
        '-e[show actual pid match]' \
        '--echo[show actual pid match]' \
        '-f[use full process name]' \
        '--full[use full process name]' \
        '-g+[pgrp]:str:' \
        '--pgroup=+[pgrp]:str:' \
        '-G+[group]:_groups' \
        '--group=+[group]:_groups' \
        '-i[case insensitive]' \
        '--ignore-case[case insensitive]' \
        '-l[show name]' \
        '--list-name[show name]' \
        '-a[show full command]' \
        '--list-full[show full command]' \
        '-n[newest match]' \
        '--newest[newest match]' \
        '-o[oldest match]' \
        '--oldest[oldest match]' \
        '-O+[older]:str:' \
        '--older=+[older]:str:' \
        '-P+[parent pid]:str:' \
        '--parent=+[parent pid]:str:' \
        '-r+[runstate]:str:' \
        '--runstates=+[runstate]:str:' \
        '-s+[session]:str:' \
        '--session=+[session]:str:' \
        '-t+[ttys]:str:' \
        '--terminal=+[ttys]:str:' \
        '-u+[euid]:_users' \
        '--euid=+[euid]:_users' \
        '-U+[uid]:_users' \
        '--uid=+[uid]:_users' \
        '-v[invert match]' \
        '--inverse[invert match]' \
        '-w[wait for processes]' \
        '--lightweight[show all TIDs]' \
        '-x[exact match]' \
        '--exact[exact match]' \
        '-F+[pidfile]:file:_files' \
        '--pidfile=+[pidfile]:file:_files' \
        '-L+[logpidfile]:file:_files' \
        '--logpidfile=+[logpidfile]:file:_files' \
        '--ns=+[pid]:pid:_pids' \
        '--nslist=+[ns names csv]:str:' \
        '--signal=+[signal]:str:' \
        '-q[suppress non-essential output]' \
        '--queue=+[value]:n:' \
        '-e[print matching pid]' \
        '*:pattern:'
}

_pgrep-cli "$@"
