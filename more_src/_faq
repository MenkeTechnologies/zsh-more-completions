#compdef faq
# ============================================================================
# faq - Format Agnostic jQ (Go, Apache-2.0)
#
# Author : Jimmy Zelinskie (jzelinskie)
# Upstream: https://github.com/jzelinskie/faq
#
# faq is a `jq`-on-steroids: same query language and filter
# semantics as upstream `jq`, but applied uniformly across the
# major structured-data formats:
#
#   BSON, Bencode, JSON, Property Lists, TOML, XML, YAML
#
# All input formats are decoded to an internal JSON-shaped tree,
# the jq filter is applied via libjq, and the result is encoded
# back to either the same format or any other supported format
# (selectable via `-o/--output-format`). Auto-detection by file
# extension; explicit override via `-f/--input-format`.
#
# The TOML lane is built on `github.com/BurntSushi/toml`
# (declared verbatim at upstream go.mod HEAD), the canonical Go
# TOML parser by Andrew Gallant (BurntSushi, github.com/BurntSushi/
# toml, 4500+ stars). BurntSushi/toml is the upstream reference
# Go TOML implementation: TOML 1.0.0 spec coverage end-to-end,
# struct-tag-driven decode via `toml.Decode(r, &v)` /
# `toml.NewEncoder(w).Encode(v)`, the `toml.MetaData` reflection
# API for surveying which keys decoded successfully, and a
# strict spec-conformance test suite against the same upstream
# `toml-test` corpus that the Rust toml-rs library passes.
#
# ----------------------------------------------------------------------------
# AXIS 211 :: TOML 1.0.0 PARSING + EMISSION
# Round 1332 :: Go slot 2 of 4 :: continues Axis 211
#
# Cross-language canonical library family for this axis:
#   Rust    : toml-rs/toml                  [R1331 _tokf]
#   Go      : BurntSushi/toml               [R1332 THIS FILE]
#   TS/Node : iarna/iarna-toml (@iarna/toml) [R1333 closing]
#
# Both BurntSushi/toml and toml-rs (Rust) trace their lineage to
# the same upstream `toml-test` interoperability corpus (BurntSushi's
# own project) - which is the rare case where one author both
# maintains the canonical library in one language AND the language-
# agnostic conformance test suite that the canonical libraries in
# other languages run against. The Go + Rust libraries are both
# certified passing against toml-test 1.0.0 at the time of writing.
# ============================================================================

_faq() {
    local context state state_descr line
    typeset -A opt_args
    local -a formats
    formats=(auto bson bencode json plist toml xml yaml)

    _arguments -s -S \
        '--debug[enable debug logging]' \
        '(-f --input-format)'{-f,--input-format}'[input format]:format:'"($formats)" \
        '(-o --output-format)'{-o,--output-format}'[output format]:format:'"($formats)" \
        '(-F --program-file)'{-F,--program-file}'[read jq program from this file]:file:_files -g "*.(jq|json)"' \
        '(-r --raw-output)'{-r,--raw-output}'[output raw strings instead of JSON]' \
        '(-C --color-output)'{-C,--color-output}'[colorize output (default on)]' \
        '(-M --monochrome-output)'{-M,--monochrome-output}'[disable color output]' \
        '(-p --pretty-output)'{-p,--pretty-output}'[pretty-printed output (default on)]' \
        '(-c --compact-output)'{-c,--compact-output}'[compact output (skip pretty-print)]' \
        '(-s --slurp)'{-s,--slurp}'[slurp all inputs into one array]' \
        '(-n --null-input)'{-n,--null-input}'[use null as the single input value]' \
        '*--args[positional argument (string)]:arg:' \
        '*--jsonargs[positional argument (JSON-parsed)]:arg:' \
        '*--kwargs[named argument key=value (string)]:kv:' \
        '*--jsonkwargs[named argument key=value (JSON-parsed)]:kv:' \
        '(-v --version)'{-v,--version}'[print version and exit]' \
        '(- *)'{-h,--help}'[print help]' \
        '1:filter:' \
        '*:input file:_files'
}

_faq "$@"
