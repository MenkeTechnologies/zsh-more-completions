#compdef dnsmasq_exporter
# Documentation: https://github.com/google/dnsmasq_exporter
# Prometheus exporter for dnsmasq metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-listen=[listen address]:address' \
  '-expose_leases[expose dnsmasq leases as metrics (high cardinality)]' \
  '-leases_path=[path to the dnsmasq leases file]:file:_files' \
  '-dnsmasq=[dnsmasq host:port address]:address' \
  '-protocol=[connect using udp or tcp]:protocol:(udp tcp)' \
  '-metrics_path=[path under which metrics are served]:path' \
  '*:arg:_default' && ret=0

return ret
