#compdef xm
# Documentation: https://man.archlinux.org/search?q=xm
# Reference accessed: 2026-05-16

# xm: legacy Xen Management CLI (deprecated; use xl)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create a VM'
  'destroy:destroy a running VM'
  'console:attach console'
  'pause:pause a VM'
  'unpause:unpause a VM'
  'list:list VMs'
  'info:show host info'
  'log:show xend log'
  'shutdown:shutdown a VM'
  'reboot:reboot a VM'
  'sysrq:send SysRq to a VM'
  'top:show VM top'
  'vcpu-list:list VCPUs'
  'vcpu-pin:pin VCPU'
  'vcpu-set:set VCPU count'
  'help:show help'
  'block-attach:attach block device'
  'block-detach:detach block device'
  'block-list:list block devices'
  'network-attach:attach virtual net'
  'network-detach:detach virtual net'
  'network-list:list virtual nets'
  'mem-set:set memory'
  'mem-max:set memory max'
  'migrate:migrate VM'
  'save:save VM state'
  'restore:restore VM state'
  'dmesg:show hypervisor dmesg'
  'dump-core:dump core of VM'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'xm command' commands && ret=0 ;;
esac
return ret
