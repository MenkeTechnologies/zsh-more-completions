#compdef aide-init
# Documentation: https://man.archlinux.org/search?q=aide-init
# Reference accessed: 2026-05-16

# aide-init: initialise the AIDE filesystem integrity database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-B[config option (override)]:setting:' \
  '--before=[config option (override)]:setting:' \
  '-l[limit to entries matching regex]:regex:' \
  '--limit=[limit to entries matching regex]:regex:' \
  '-V[verbosity level]:level:' \
  '--verbose=[verbosity level]:level:' \
  '-y[answer yes]' \
  '*::aide-init args:_files' && ret=0
return ret
