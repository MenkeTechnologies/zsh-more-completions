#compdef re_data
# Documentation: https://docs.getre.io/master/docs/re_data/reference/cli/overview/
# re_data - data reliability/observability for dbt (run, overview, notify)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--start-date=[beginning of period (default today-7d)]:date' \
  '--end-date=[end of period (default today)]:date' \
  '--interval=[time grain, e.g. days:1 or hours:6]:interval' \
  '--full-refresh[run dbt with full-refresh]' \
  '--re-data-target-dir=[directory for generated alerts/files]:dir:_files -/' \
  '--dbt-vars=[YAML dict string passed to dbt]:vars' \
  '--profile=[dbt profile to load]:profile' \
  '--target=[dbt target for the profile]:target' \
  '--project-dir=[directory with dbt_project.yml]:dir:_files -/' \
  '--profiles-dir=[directory with profiles.yml]:dir:_files -/' \
  '--port=[overview serve port (default 8085)]:port' \
  '--no-browser[do not open browser when serving]' \
  '1:command:(run overview notify)' \
  '*::arg:->args' && ret=0

return ret
