#compdef automake-1.18

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  {-v,--verbose}'[verbosely list files processed]' \
  '--no-force[only update outdated Makefile.in]' \
  '*'{-W+,--warnings=}'[warnings category]:category:(gnu obsolete override portability syntax unsupported all none error no-error)' \
  {-a,--add-missing}'[add missing standard files]' \
  '--copy[copy missing files instead of symlinking]' \
  {-f,--force-missing}'[force update of standard files]' \
  '--foreign[set strictness to foreign]' \
  '--gnits[set strictness to gnits]' \
  '--gnu[set strictness to gnu]' \
  '--include-deps[include generated dependencies in output]' \
  {-i,--ignore-deps}'[do not include dependencies in output]' \
  '--no-print-directory[do not print directory entry messages]' \
  {-o+,--output-dir=}'[output directory]:dir:_files -/' \
  {-c,--clean}'[remove generated files]' \
  '*:Makefile:_files -g "*.am"' && ret=0

return ret
