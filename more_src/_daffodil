#compdef daffodil

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'parse:parse a file using a DFDL schema or saved parser'
  'unparse:unparse an infoset file using a DFDL schema or saved parser'
  'save-parser:persist a parser for reuse in future parsing/unparsing'
  'test:list or execute tests in a TDML file'
  'performance:run a performance test (parse or unparse)'
  'generate:generate code from a DFDL schema'
  'exi:encode or decode an XML file with Efficient XML Interchange'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show Daffodil version]' \
  '*'{-v,--verbose}'[enable verbose mode (repeat for more detail)]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'daffodil subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (parse)
        _arguments \
          '(-s --schema)'{-s,--schema=}'[DFDL schema file]:file:_files -g "*.(dfdl.xsd|xsd)"' \
          '(-r --root)'{-r,--root=}'[root element name]:name:' \
          '(-n --namespace)'{-n,--namespace=}'[root element namespace URI]:ns:' \
          '(-p --parser)'{-p,--parser=}'[saved parser file]:file:_files' \
          '(-c --config)'{-c,--config=}'[XML configuration file]:file:_files' \
          '(-D)'{-D=}'[set DFDL variable]:var:' \
          '(-I --infoset-type)'{-I,--infoset-type=}'[infoset type]:type:(xml json scala-xml jdom w3cdom)' \
          '(-o --output)'{-o,--output=}'[output file]:file:_files' \
          '(-T --tunable)'{-T,--tunable=}'[tunable parameter]:tunable:' \
          '*:input:_files' && ret=0
        ;;
      (unparse)
        _arguments \
          '(-s --schema)'{-s,--schema=}'[DFDL schema file]:file:_files' \
          '(-r --root)'{-r,--root=}'[root element name]:name:' \
          '(-n --namespace)'{-n,--namespace=}'[root element namespace URI]:ns:' \
          '(-p --parser)'{-p,--parser=}'[saved parser file]:file:_files' \
          '(-c --config)'{-c,--config=}'[XML configuration file]:file:_files' \
          '(-I --infoset-type)'{-I,--infoset-type=}'[infoset type]:type:(xml json scala-xml jdom w3cdom)' \
          '(-o --output)'{-o,--output=}'[output file]:file:_files' \
          '*:input:_files' && ret=0
        ;;
      (save-parser)
        _arguments \
          '(-s --schema)'{-s,--schema=}'[DFDL schema file]:file:_files' \
          '(-r --root)'{-r,--root=}'[root element name]:name:' \
          '(-o --output)'{-o,--output=}'[saved parser output file]:file:_files' && ret=0
        ;;
      (test)
        _arguments \
          '(-l --list)'{-l,--list}'[list tests instead of executing them]' \
          '(-r --regex)'{-r,--regex}'[treat names as regex patterns]' \
          '(-i --info)'{-i,--info=}'[display test info verbosity]:level:' \
          '*:tdml:_files -g "*.tdml"' && ret=0
        ;;
      (generate)
        _values 'language' 'c' && ret=0
        ;;
      (exi)
        _arguments \
          '(-d --decode)'{-d,--decode}'[decode EXI to XML]' \
          '(-o --output)'{-o,--output=}'[output file]:file:_files' \
          '*:input:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
