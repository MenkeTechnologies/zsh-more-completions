#compdef chrony_exporter
# Documentation: https://github.com/SuperQ/chrony_exporter
# Prometheus exporter for chrony NTP daemon metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--chrony.address=[where the chrony server listens]:addr' \
  '--chrony.timeout=[request timeout duration]:dur' \
  '--collector.tracking[enable tracking metrics]' \
  '--no-collector.tracking[disable tracking metrics]' \
  '--collector.sources[enable sources metrics]' \
  '--no-collector.sources[disable sources metrics]' \
  '--collector.sourcestats[enable sourcestats metrics]' \
  '--no-collector.sourcestats[disable sourcestats metrics]' \
  '--collector.sources.with-ntpdata[extend sources with NTP data]' \
  '--collector.serverstats[enable serverstats metrics]' \
  '--no-collector.serverstats[disable serverstats metrics]' \
  '--collector.chmod-socket[set socket permissions to 0666]' \
  '--collector.dns-lookups[enable reverse DNS lookups]' \
  '--web.telemetry-path=[path under which to expose metrics]:path' \
  '--web.systemd-socket[use systemd socket activation (Linux only)]' \
  '--web.listen-address=[address to listen on (repeatable)]:addr' \
  '--web.config.file=[path to TLS/auth config file]:file:_files' \
  '--log.level=[only log messages with given severity or above]:level:(debug info warn error)' \
  '--log.format=[output format of log messages]:format:(logfmt json)' \
  '--version[show application version]' && ret=0

return ret
