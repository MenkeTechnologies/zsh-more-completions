#compdef temporal-cassandra-tool
# _temporal-cassandra-tool — Temporal Cassandra schema management tool (temporalio/temporal)
# upstream: https://github.com/temporalio/temporal
# Subcommands from tools/cassandra/main.go (urfave/cli).

_temporal-cassandra-tool() {
    local context state state_descr line
    typeset -A opt_args
    local -a common=(
        '--endpoint=[cassandra host]:host:_hosts'
        '--port=[cassandra port]:port:'
        '--user=[cassandra user]:user:'
        '--password=[cassandra password]:password:'
        '*--allowed-authenticators=[allowed gocql authenticators]:auth:'
        '--timeout=[CQL client request timeout (s)]:s:'
        '(-k --keyspace)'{-k+,--keyspace=}'[cassandra keyspace]:name:'
        '--datacenter=[NetworkTopologyStrategy datacenter]:dc:'
        '(-q --quiet)'{-q,--quiet}'[do not set exit status 1 on error]'
        '--disable-initial-host-lookup[do not look up additional hosts via system.peers]'
        '--tls[enable TLS]'
        '--tls-cert-file=[TLS cert file]:file:_files'
    )

    _arguments -C \
        $common \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                setup-schema:'setup initial cassandra schema'
                setup:'setup initial cassandra schema'
                update-schema:'update cassandra schema to a specific version'
                update:'update cassandra schema to a specific version'
                create-keyspace:'create keyspace with simple or network topology strategy'
                create:'create keyspace'
                drop-keyspace:'drop keyspace'
                drop:'drop keyspace'
                validate-health:'validate cassandra health'
                vh:'validate cassandra health'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                setup-schema|setup)
                    _arguments $common \
                        '(-v --version)'{-v+,--version=}'[initial schema version]:ver:' \
                        '(-f --schema-file)'{-f+,--schema-file=}'[CQL schema file]:file:_files' \
                        '--disable-versioning[disable schema versioning]' \
                        '--overwrite[drop and recreate the schema]' ;;
                update-schema|update)
                    _arguments $common \
                        '(-d --schema-dir)'{-d+,--schema-dir=}'[directory of schema upgrades]:dir:_files -/' \
                        '(-v --version)'{-v+,--version=}'[target schema version]:ver:' \
                        '--dryrun[do not run, only print plan]' ;;
                create-keyspace|create)
                    _arguments $common \
                        '(-k --keyspace)'{-k+,--keyspace=}'[keyspace name]:name:' \
                        '--replication-factor=[replication factor]:n:' ;;
                drop-keyspace|drop)
                    _arguments $common \
                        '(-k --keyspace)'{-k+,--keyspace=}'[keyspace name]:name:' \
                        '(-f --force)'{-f,--force}'[do not prompt]' ;;
            esac
            ;;
    esac
}

_temporal-cassandra-tool "$@"
