#compdef qdrant
# Documentation: https://man.archlinux.org/search?q=qdrant
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--bootstrap+[bootstrap node]:url:' \
  '--uri+[bootstrap URI]:url:' \
  '--snapshot+[snapshot URL]:url:' \
  '--storage-snapshot+[storage snapshot]:file:_files' \
  '--config-path+[config file]:file:_files -g "*.yaml *.yml"' \
  '--disable-telemetry[disable telemetry]' \
  '--reinit[reinit cluster]' \
  '--force-snapshot[force snapshot recovery]' \
  '*: :_files' && ret=0

return ret
