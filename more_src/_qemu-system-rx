#compdef qemu-system-rx
# Documentation: https://www.qemu.org/docs/master/system/invocation.html
# QEMU full-system emulator for the Renesas RX target

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[display help and exit]' \
  '(-version --version)'{-version,--version}'[display version information and exit]' \
  '-machine[select the emulated machine by name (help to list)]:machine' \
  '-cpu[select CPU model (help for list)]:cpu' \
  '-smp[simulate an SMP system with n CPUs]:n' \
  '-m[set guest startup RAM size in megabytes]:size' \
  '-kernel[use bzImage as kernel image]:file:_files' \
  '-append[use cmdline as kernel command line]:cmdline' \
  '-initrd[use file as initial ram disk]:file:_files' \
  '-bios[set the filename for the BIOS]:file:_files' \
  '-drive[define a new drive]:drive' \
  '-hda[use file as hard disk 0 image]:file:_files' \
  '-cdrom[use file as CD-ROM image]:file:_files' \
  '-boot[specify boot order as a string of drive letters]:order' \
  '-netdev[configure a network backend]:netdev' \
  '-nic[configure guest NIC and host backend together]:nic' \
  '-device[add device driver]:device' \
  '-display[select type of display to use (help to list)]:display' \
  '-nographic[disable graphical output, run as command line app]' \
  '-serial[redirect the virtual serial port to host device]:dev' \
  '-monitor[redirect the monitor to host device]:dev' \
  '-vga[select type of VGA card to emulate]:type' \
  '-snapshot[write to temporary files instead of disk image files]' \
  '-gdb[accept a gdb connection on device]:dev' \
  '-S[do not start CPU at startup]' \
  '-d[enable logging of specified items]:items' \
  '-name[set the name of the guest]:name' \
  '*:file:_files' && ret=0

return ret
