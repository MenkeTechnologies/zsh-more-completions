#compdef cargo-bootimage
# Documentation: https://github.com/rust-osdev/bootimage
# cargo-bootimage: build a bootable disk image from a Rust kernel binary

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--target=[build for the given custom target]:target:_files -g "*.json"' \
  '(--release)--release[build artifacts in release mode]' \
  '*:cargo build args:_default' && ret=0

return ret
