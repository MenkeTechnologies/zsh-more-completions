#compdef datu
# Documentation: https://man.archlinux.org/search?q=datu
# Reference accessed: 2026-05-16

_datu() {
    local line state
    local -a commands
    commands=(
        'schema:Display the structure of a file'
        'head:Print the first N rows of a file'
        'convert:Convert data between supported formats'
        'help:Print this message or the help of the given subcommand(s)'
    )

    _arguments -C \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'datu command' commands
            ;;
        args)
            case $line[1] in
                schema)
                    _arguments \
                        '(-I --input)'{-I,--input}'[Override file type detection]:type:(avro csv json orc parquet)' \
                        '(-O --output)'{-O,--output}'[Output format for the schema]:format:(csv json json-pretty yaml)' \
                        '--input-headers[Whether the first row is a header]:bool:(true false)' \
                        '--help[Print help]' \
                        '*:data file:_files'
                    ;;
                head)
                    _arguments \
                        '-n[Number of rows to print]:number:' \
                        '(-O --output)'{-O,--output}'[Format of the output data]:format:(csv json json-pretty yaml)' \
                        '(-s --select)'{-s,--select}'[Comma-separated list of columns to include]:columns:' \
                        '--sparse[Omit null/missing values]:bool:(true false)' \
                        '--help[Print help]' \
                        '*:data file:_files'
                    ;;
                convert)
                    _arguments \
                        '(-s --select)'{-s,--select}'[Filter specific columns]:columns:' \
                        '(-w --where)'{-w,--where}'[Filter rows with condition]:condition:' \
                        '(-I --input)'{-I,--input}'[Manual input format]:type:(avro csv json orc parquet)' \
                        '(-O --output)'{-O,--output}'[Manual output format]:type:(avro csv json orc parquet)' \
                        '--input-headers[Control header detection for CSV]:bool:(true false)' \
                        '--help[Print help]' \
                        '*:file:_files'
                    ;;
                help)
                    _describe -t commands 'datu command' commands
                    ;;
            esac
            ;;
    esac
}

_datu "$@"
