#compdef gerris2D gerris3D gfsview2D gfsview3D gfs2oogl gfsmovie gfs2gfs gfsjoin gfssplit
# Documentation: https://manpages.debian.org/bookworm/gerris/gerris2D.1.en.html
# Reference accessed: 2026-05-17
# Verified: Debian bookworm gerris2D(1) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

case $service in
  (gerris2D|gerris3D)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-q --quiet)'{-q,--quiet}'[quiet]' \
      '(-d --define)'{-d+,--define=}'[define macro]:macro:' \
      '(-s --split)'{-s+,--split=}'[split level]:n:' \
      '(-p --partition)'{-p+,--partition=}'[partition n procs]:n:' \
      '(-P --pid)'{-P+,--pid=}'[set process id]:n:' \
      '(-b --box)'{-b+,--box=}'[box id]:id:' \
      '(-e --event)'{-e+,--event=}'[event class]:e:' \
      '(-t --time)'{-t,--time}'[print times]' \
      '(-D --data)'{-D+,--data=}'[data file]:file:_files' \
      '(-r --restore)'{-r,--restore}'[restore from sim]' \
      '(-m --macros)'{-m,--macros}'[print macros]' \
      '(-c --command)'{-c+,--command=}'[command line argument]:s:' \
      '*: :_files -g "*.gfs"' && ret=0 ;;
  (gfsview2D|gfsview3D)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-s --script)'{-s+,--script=}'[script]:file:_files -g "*.gfv"' \
      '(-p --pipe)'{-p,--pipe}'[pipe mode]' \
      '(-c --command)'{-c+,--command=}'[command]:cmd:' \
      '*: :_files -g "*.gfs *.gfv"' && ret=0 ;;
  (gfs2oogl|gfsmovie|gfs2gfs|gfsjoin|gfssplit)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '*: :_files -g "*.gfs"' && ret=0 ;;
esac

return ret
