#compdef salt-key
# _salt-key — SaltStack salt-key (manage minion authentication keys on the master: list/accept/reject/delete/finger, bulk operations via -A/-D/-Y, gen-keys for new minion bootstraps)
# upstream: https://github.com/saltstack/salt (salt/cli/key.py)
# Flags from salt cli/key.py on tip.

_salt-key() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '-c+[config dir]:dir:_files -/' \
        '-l+[match type]:state:(pre un acc accepted unaccepted rej rejected den denied all)' \
        '-L[list all keys]' \
        '-a+[accept matched]:match:' \
        '-A[accept all unaccepted]' \
        '-r+[reject matched]:match:' \
        '-R[reject all unaccepted]' \
        '-d+[delete matched]:match:' \
        '-D[delete all]' \
        '-f+[fingerprint matched]:match:' \
        '-F[fingerprint all]' \
        '-p+[print matched]:match:' \
        '-P[print all]' \
        '-y[yes]' \
        '--accept-all[accept all]' \
        '--reject-all[reject all]' \
        '--delete-all[delete all]' \
        '--gen-keys+[name to create keypair for]:name:' \
        '--gen-keys-dir+[output dir]:dir:_files -/' \
        '--keysize+[key size bits]:bits:' \
        '--output+[output format]:format:(yaml json nested key pprint table txt)' \
        '--no-color[disable colors]'
}

_salt-key "$@"
