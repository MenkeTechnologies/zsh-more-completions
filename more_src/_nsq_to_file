#compdef nsq_to_file
# Documentation: https://nsq.io/components/utilities.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-version[show version]' \
  '*-topic=[NSQ topic (repeatable)]:topic:' \
  '-topic-pattern=[only log topics matching pattern]:regex:' \
  '-channel=[channel name]:channel:' \
  '*-nsqd-tcp-address=[nsqd TCP address (repeatable)]:address:' \
  '*-lookupd-http-address=[lookupd HTTP address (repeatable)]:address:' \
  '-output-dir=[output directory]:dir:_files -/' \
  '-work-dir=[temp work directory]:dir:_files -/' \
  '-filename-format=[filename format pattern]:fmt:' \
  '-skip-empty-files[skip writing empty files]' \
  '-rotate-interval=[rotate file every duration]:duration:' \
  '-rotate-size=[rotate file when bigger than n bytes]:n:' \
  '-sync-interval=[sync to disk every duration]:duration:' \
  '-topic-refresh=[how often to refresh the list of topics]:duration:' \
  '-datetime-format=[strftime-like date/time format for filenames]:fmt:' \
  '-host-identifier=[value to substitute for HOSTNAME in filenames]:id:' \
  '-gzip[gzip output]' \
  '-gzip-level=[gzip compression level]:level:(1 2 3 4 5 6 7 8 9)' \
  '-max-in-flight=[max in-flight messages]:n:' \
  '-http-client-connect-timeout=[HTTP connect timeout]:duration:' \
  '-http-client-request-timeout=[HTTP request timeout]:duration:' \
  '-log-level=[log verbosity]:level:(debug info warn error fatal)' \
  '-log-prefix=[log message prefix]:prefix:' && ret=0

return ret
