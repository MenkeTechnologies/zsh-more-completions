#compdef mpvpaper
# Documentation: https://github.com/GhostNaN/mpvpaper/blob/master/mpvpaper.man
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[displays usage options]' \
  '(- *)'{-d,--help-output}'[display all available outputs and quit]' \
  '*'{-v,--verbose}'[be more verbose (-vv higher verbosity)]' \
  '(-f --fork)'{-f,--fork}'[fork to background]' \
  '(-p --auto-pause)'{-p,--auto-pause}'[pause mpv when wallpaper is hidden]' \
  '(-s --auto-stop)'{-s,--auto-stop}'[stop mpv when wallpaper is hidden]' \
  '(-n --slideshow)'{-n+,--slideshow=}'[slideshow play next every <seconds>]:seconds:' \
  '(-l --layer)'{-l+,--layer=}'[shell surface layer]:layer:(background bottom top overlay)' \
  '(-o --mpv-options)'{-o+,--mpv-options=}'[forward mpv options (within quotes)]:options:' \
  '1:output name (* for all):' \
  '2:video file or URL:_files' && ret=0

return ret
