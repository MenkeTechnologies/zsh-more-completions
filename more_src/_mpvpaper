#compdef mpvpaper

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-o[mpv options]:mpv options:' \
  '-s[slideshow mode - wait time in seconds]:seconds:' \
  '-p[pause on start]' \
  '-n[no auto stop/start on output visibility]' \
  '-f[fork to background]' \
  '-l[layer]:layer:(background bottom top overlay)' \
  '-Z[suppress mpv rendering]' \
  '1:output name (* for all):' \
  '2:video file or URL:_files' && ret=0

return ret
