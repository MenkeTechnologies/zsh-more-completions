#compdef fff
# Documentation: https://github.com/dylanaraps/fff
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:starting directory:_directories' && ret=0

return ret
