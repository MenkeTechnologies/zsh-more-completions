#compdef fff
# Documentation: https://man.archlinux.org/search?q=fff
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:starting directory:_directories' && ret=0

return ret
