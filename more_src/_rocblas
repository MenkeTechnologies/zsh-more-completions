#compdef rocblas-test rocblas-bench
# _rocblas — AMD ROCm rocBLAS dense linear algebra library BLAS L1 L2 L3 routines test and benchmark runners (ROCm team, C++); custom argparse
# upstream: https://github.com/ROCm/rocBLAS

_rocblas() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--gtest_filter=+[pattern]:str:' \
        '--gtest_list_tests[list tests]' \
        '--gtest_repeat=+[N]:n:' \
        '--gtest_random_seed=+[N]:n:' \
        '--gtest_color=+[mode]:m:(yes no auto)' \
        '-r+[precision]:p:(s d c z h b)' \
        '--precision=+[precision]:p:(s d c z h b)' \
        '-f+[function]:str:' \
        '--function=+[function]:str:' \
        '-m+[M]:n:' \
        '--sizeM=+[M]:n:' \
        '-n+[N]:n:' \
        '--sizeN=+[N]:n:' \
        '-k+[K]:n:' \
        '--sizeK=+[K]:n:' \
        '--lda=+[ld A]:n:' \
        '--ldb=+[ld B]:n:' \
        '--ldc=+[ld C]:n:' \
        '--ldd=+[ld D]:n:' \
        '--stride_a=+[stride A]:n:' \
        '--stride_b=+[stride B]:n:' \
        '--stride_c=+[stride C]:n:' \
        '--stride_d=+[stride D]:n:' \
        '--batch_count=+[batch]:n:' \
        '--transposeA=+[N T C]:str:' \
        '--transposeB=+[N T C]:str:' \
        '--side=+[L R]:str:' \
        '--uplo=+[U L]:str:' \
        '--diag=+[N U]:str:' \
        '--algo=+[algo]:str:' \
        '--solution-index=+[N]:n:' \
        '--initialization=+[init]:i:(rand_int trig_float hpl)' \
        '--alpha=+[F]:f:' \
        '--alphai=+[F]:f:' \
        '--beta=+[F]:f:' \
        '--betai=+[F]:f:' \
        '--devices=+[device id csv]:str:' \
        '--device-id=+[id]:n:' \
        '--iters=+[iterations]:n:' \
        '--cold_iters=+[N]:n:' \
        '--flush-batch-count=+[N]:n:' \
        '--flush-mem-size=+[MiB]:n:' \
        '--unit-check=+[bool]:b:(0 1)' \
        '--norm-check=+[bool]:b:(0 1)' \
        '--mem=+[mem]:m:(host device managed)' \
        '--known-bug-platforms=+[platforms csv]:str:' \
        '--workspace=+[bytes]:n:' \
        '--log_function_name[log function name]' \
        '--log_datatype[log datatype]' \
        '--log_layer[log layer]'
}

_rocblas "$@"
