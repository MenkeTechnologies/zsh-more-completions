#compdef sumo-bandplot
# Documentation: https://smtg-bham.github.io/sumo/sumo-bandplot.html
# sumo band structure plotting tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --filenames)'{-f,--filenames}'[one or more vasprun.xml files to plot]:files:_files' \
  '(-c --code)'{-c,--code}'[electronic structure code]:code:(vasp questaal)' \
  '(-p --prefix)'{-p,--prefix}'[prefix for generated files]:prefix:' \
  '(-d --directory)'{-d,--directory}'[output directory for files]:dir:_files -/' \
  '(-b --band-edges)'{-b,--band-edges}'[highlight band edges with markers]' \
  '--project=[select orbitals to project onto band structure]:project:' \
  '--mode=[projection mode]:mode:(rgb stacked)' \
  '--normalise=[projection normalization method]:norm:(all select)' \
  '--interpolate-factor=[interpolation factor for projections]:factor:' \
  '--cartesian[read cartesian k-point coordinates]' \
  '--colour1=[first color for RGB projections]:colour:' \
  '--colour2=[second color for RGB projections]:colour:' \
  '--colour3=[third color for RGB projections]:colour:' \
  '--colourspace=[colorspace for RGB interpolation]:space:' \
  '--circle-size=[circle size for stacked projections]:size:' \
  '--ylabel=[y-axis energy label]:label:' \
  '--dos-label=[axis label for DOS]:label:' \
  '--dos=[path to DOS vasprun.xml file]:file:_files' \
  '--zero-line[plot horizontal line at energy zero]' \
  '--zero-energy=[reference energy for shifting]:energy:' \
  '--elements=[elemental orbitals to plot]:elements:' \
  '--orbitals=[orbitals for lm-decomposed contributions]:orbitals:' \
  '--atoms=[atoms to include]:atoms:' \
  '--spin=[spin channel selection]:spin:(up down 1 -1)' \
  '--scissor=[apply scissor operator]:value:' \
  '--total-only[plot only total density of states]' \
  '--no-total[do not plot total density of states]' \
  '--legend-cutoff=[DOS cutoff percentage for labels]:pct:' \
  '(-g --gaussian)'{-g,--gaussian}'[standard deviation of DOS broadening]:sigma:' \
  '--scale=[scaling factor for density of states]:scale:' \
  '--height=[graph height]:height:' \
  '--width=[graph width]:width:' \
  '--ymin=[minimum energy on y-axis]:ymin:' \
  '--ymax=[maximum energy on y-axis]:ymax:' \
  '--style=[matplotlib style specifications]:style:' \
  '--no-base-style[prevent use of sumo base style]' \
  '--config=[colour configuration file]:file:_files' \
  '--format=[image file format]:format:(pdf svg jpg png)' \
  '--dpi=[pixel density for image]:dpi:' \
  '--font=[font to use]:font:' \
  '--title=[plot title]:title:' && ret=0

return ret
