#compdef spark-sql

# Zsh completion for spark-sql - Apache Spark SQL CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--master=[master URL]:master:(local local\[\*\] yarn spark\://HOST\:PORT mesos\://HOST\:PORT k8s\://HOST\:PORT)' \
  '--deploy-mode=[deployment mode]:mode:(client cluster)' \
  '--driver-memory=[memory for driver]:memory:' \
  '--driver-cores=[number of cores for driver]:cores:' \
  '--executor-memory=[memory per executor]:memory:' \
  '--executor-cores=[number of cores per executor]:cores:' \
  '--num-executors=[number of executors]:number:' \
  '--total-executor-cores=[total cores for all executors]:cores:' \
  '*--conf=[Spark configuration property]:property (key=value):' \
  '--properties-file=[path to properties file]:file:_files' \
  '--driver-class-path=[extra class path for driver]:classpath:_files' \
  '--driver-java-options=[extra Java options for driver]:options:' \
  '--driver-library-path=[extra library path for driver]:path:_files' \
  '--jars=[comma-separated list of jars]:jars:_files' \
  '--packages=[comma-separated list of Maven coordinates]:packages:' \
  '--exclude-packages=[comma-separated list of packages to exclude]:packages:' \
  '--repositories=[comma-separated list of Maven repositories]:repositories:' \
  '--files=[comma-separated list of files to place in working directory]:files:_files' \
  '--archives=[comma-separated list of archives]:archives:_files' \
  '--name=[application name]:name:' \
  '--queue=[YARN queue]:queue:' \
  '--proxy-user=[user to impersonate]:user:_users' \
  '--verbose[print additional debug output]' \
  '-e+[execute SQL from command line]:sql:' \
  '-f+[execute SQL from file]:file:_files' \
  '--database=[database to use]:database:' \
  '*--hiveconf=[Hive configuration property]:property (key=value):' \
  '*--hivevar=[Hive variable]:variable (key=value):' \
  '-i+[initialization SQL file]:file:_files' \
  '(-S --silent)'{-S,--silent}'[silent mode in interactive shell]' \
  '(-d --define)'{-d,--define}'[variable substitution]:variable (key=value):' && ret=0

return ret
