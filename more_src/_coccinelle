#compdef spatch

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--sp-file=[semantic patch file]:file:_files -g "*.cocci(-.)"' \
  '-sp_file+[semantic patch file]:file:_files -g "*.cocci(-.)"' \
  '--dir=[directory to process]:directory:_directories' \
  '--include-headers[process header files too]' \
  '--no-includes[do not expand includes]' \
  '--all-includes[expand all includes]' \
  '--local-includes[use local includes only]' \
  '-I+[include path]:directory:_directories' \
  '-D+[define macro]:macro' \
  '--macro-file=[macro definition file]:file:_files' \
  '--macro-file-builtins=[builtin macros file]:file:_files' \
  '-j+[number of threads]:threads' \
  '--jobs=[number of threads]:threads' \
  '--chunksize=[files per thread]:count' \
  '-o+[output file]:output file:_files' \
  '--out-place[create .cocci_res files]' \
  '--in-place[modify files in place]' \
  '--patch=[patch directory]:directory:_directories' \
  '--iso-file=[isomorphism file]:file:_files' \
  '--debug[debug mode]' \
  '--very-quiet[suppress all output]' \
  '--quiet[quiet mode]' \
  '-timeout+[timeout in seconds]:seconds' \
  '--test[test mode]' \
  '--testall[run all tests]' \
  '--profile[show profiling information]' \
  '*:source file:_files -g "*.(c|h)(-.)"' && return 0
