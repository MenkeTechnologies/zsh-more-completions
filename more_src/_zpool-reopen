#compdef zpool-reopen
# _zpool-reopen — OpenZFS zpool reopen (close and re-open all vdevs of a pool to pick up new device paths or geometry changes; -n no autoresume of in-progress scan after reopen; positional argument is the pool to reopen)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_reopen) on tip.

_zpool-reopen() {
    _arguments \
        '-n[do not resume in-progress scan]' \
        '1:pool:'
}

_zpool-reopen "$@"
