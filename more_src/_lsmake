#compdef lsmake

# lsmake: GNU make with LSF parallel job distribution
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-j[max parallel jobs]:n:' \
  '-J[job name]:name:' \
  '-R[resource req]:expr:' \
  '-Tc[max jobs per node]:n:' \
  '-t[max wallclock]:hh\:mm:' \
  '-f[makefile]:file:_files' \
  '-G[user group]:group:_groups' \
  '-P[project]:project:' \
  '-q[queue]:queue:' \
  '-x[exclusive]' \
  '-pack[pack jobs]' \
  '-Tpf[parsable output]' \
  '*:target:_files' && ret=0
return ret
