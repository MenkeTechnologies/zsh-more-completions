#compdef kramdown
# kramdown — fast, pure-Ruby Markdown-superset converter

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --input)'{-i,--input}'[input format]:format:(kramdown html GFM)' \
  '(-o --output)*'{-o,--output}'[output format (may be repeated)]:format:(html kramdown latex man remove_html_tags)' \
  '--no-config-file[do not read any config file]' \
  '--config-file=[config file to read]:file:_files' \
  '--auto-id-prefix=[prefix for auto-generated header IDs]:prefix:' \
  '--auto-id-stripping[strip formatting in header IDs]' \
  '--auto-ids[automatically generate IDs for headers]' \
  '--coderay-bold-every=[bold every N-th line number]:n:' \
  '--coderay-css=[CSS mode for CodeRay]:mode:(class style)' \
  '--coderay-default-lang=[default CodeRay language]:lang:' \
  '--coderay-line-number-start=[starting line number]:n:' \
  '--coderay-line-numbers=[line number mode]:mode:(table inline)' \
  '--coderay-tab-width=[tab width for CodeRay]:n:' \
  '--coderay-wrap=[wrap mode for CodeRay]:mode:(div span)' \
  '--enable-coderay[use CodeRay for syntax highlighting]' \
  '--entity-output=[entity output format]:format:(as_char as_input numeric symbolic)' \
  '--footnote-backlink=[footnote backlink text]:text:' \
  '--footnote-backlink-inline[use inline footnote backlinks]' \
  '--footnote-nr=[starting footnote number]:n:' \
  '--footnote-prefix=[prefix for footnote IDs]:prefix:' \
  '--gfm-quirks=[GFM quirks to use]:quirks:' \
  '--hard-wrap[interpret newlines as hard line breaks in GFM]' \
  '--header-offset=[offset for header levels]:n:' \
  '--html-to-native[convert HTML to native elements when possible]' \
  '--latex-headers=[LaTeX header commands]:headers:' \
  '--line-width=[output line width (-1 to disable)]:width:' \
  '--link-defs=[predefined link definitions]:defs:' \
  '--math-engine=[math engine]:engine:(mathjax katex)' \
  '--math-engine-opts=[math engine options]:opts:' \
  '--parse-block-html[parse block HTML tags]' \
  '--parse-span-html[parse span HTML tags]' \
  '--smart-quotes=[smart quote substitution chars]:chars:' \
  '--syntax-highlighter=[syntax highlighter]:highlighter:(coderay rouge)' \
  '--syntax-highlighter-opts=[syntax highlighter options]:opts:' \
  '--template=[ERB template for wrapping output]:template:_files' \
  '--toc-levels=[header levels for TOC]:levels:' \
  '--transliterated-header-ids[use transliterated header IDs]' \
  '--typographic-symbols=[typographic symbol substitution]:symbols:' \
  '*:input file:_files -g "*.{md,markdown,mkd,txt,html,htm}"' \
  && ret=0

return ret
