#compdef expectk
# Documentation: https://www.tcl-lang.org/man/expect/expect.1.html
# Expect with Tk (uses long flag names)

local ret=1

_arguments -s \
  '*-command[execute command before the script]:command:' \
  '-diag[enable diagnostic output]' \
  '-Debug[enable interactive debugger]:value:' \
  '-file[read commands from file]:command file:_files' \
  '-buffer[read command file one line at a time]' \
  '-interactive[prompt interactively for commands]' \
  '-NORC[do not source exp_library expect.rc]' \
  '-norc[do not source ~/.expect.rc]' \
  '-version[print version number and exit]' \
  '1:command file:_files' \
  '*::args:_default' && ret=0

return ret
