#compdef amulecmd
# _amulecmd — console-based program to control aMule (amule-project/amule)
# upstream: https://github.com/amule-project/amule
# Flags from docs/man/amulecmd.1.in.

_amulecmd() {
    _arguments \
        '(-h --host --help)'{-h+,--host=}'[aMule host (default localhost)]:host:_hosts' \
        '(-h --host --help)--help[show help]' \
        '(-p --port)'{-p+,--port=}'[external connections port (default 4712)]:port:' \
        '(-P --password)'{-P+,--password=}'[external connections password]:password:' \
        '(-f --config-file)'{-f+,--config-file=}'[configuration file]:file:_files' \
        '(-q --quiet)'{-q,--quiet}'[no stdout output]' \
        '(-v --verbose --version)'{-v,--verbose}'[verbose / debug messages]' \
        '(-v --verbose --version)--version[show version]' \
        '(-l --locale)'{-l+,--locale=}'[program locale]:lang:' \
        '(-w --write-config -c --command)'{-w,--write-config}'[write CLI options to config and exit]' \
        '(-w --write-config -c --command)'{-c+,--command=}'[execute single command and exit]:cmd:' \
        '--create-config-from=[create config from existing aMule config]:file:_files'
}

_amulecmd "$@"
