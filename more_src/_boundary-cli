#compdef boundary
# Documentation: https://developer.hashicorp.com/boundary/docs/commands
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'accounts:account commands'
  'aliases:alias commands'
  'authenticate:authenticate to a Boundary controller'
  'auth-methods:auth method commands'
  'auth-tokens:auth token commands'
  'cache:cache management'
  'config:CLI config'
  'connect:connect via Boundary'
  'credential-libraries:credential library commands'
  'credentials:credential commands'
  'credential-stores:credential store commands'
  'daemon:daemon commands'
  'database:database commands'
  'dev:run a dev controller+worker'
  'groups:group commands'
  'host-catalogs:host catalog commands'
  'hosts:host commands'
  'host-sets:host set commands'
  'logout:log out'
  'managed-groups:managed group commands'
  'policies:policy commands'
  'roles:role commands'
  'scopes:scope commands'
  'search:search local Boundary'
  'server:run a Boundary server'
  'session-recordings:session recording commands'
  'sessions:session commands'
  'storage-buckets:storage bucket commands'
  'targets:target commands'
  'users:user commands'
  'workers:worker commands'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*-format=[output format]:f:(json table)' \
  '*-no-color[no color]' \
  '*-output-curl-string[output curl]' \
  '*-recovery-config=[recovery config]:file:_files' \
  '*-skip-cache-daemon[skip cache daemon]' \
  '*-skip-client-agent[skip client agent]' \
  '*-tls-insecure[insecure TLS]' \
  '*-token=[token]:t:' \
  '*-token-name=[token name]:n:' \
  '*-keyring-type=[keyring type]:k:(auto pass keychain wincred secret-service none)' \
  '*-addr=[server address]:url:' \
  '*-ca-cert=[CA cert]:file:_files' \
  '*-ca-path=[CA path]:dir:_files -/' \
  '*-client-cert=[client cert]:file:_files' \
  '*-client-key=[client key]:file:_files' \
  '*-tls-server-name=[server SNI]:s:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'boundary command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (connect)
        _arguments \
          '-target-id=[target ID]:id:' \
          '-target-name=[target name]:n:' \
          '-target-scope-id=[scope ID]:s:' \
          '-target-scope-name=[scope name]:s:' \
          '-host-id=[host ID]:h:' \
          '-listen-port=[port]:port:' \
          '-listen-addr=[addr]:a:' \
          '-exec=[exec command]:c:_command_names -e' \
          '-egress=[egress]:e:' \
          '-style=[style]:s:(http kube ssh postgres rdp)' \
          '-username=[username]:u:_users' \
          '-dbname=[db name]:d:' \
          '*: :' && ret=0 ;;
      (server|dev)
        _arguments \
          '-config=[config file]:file:_files' \
          '-config-kms=[KMS config]:file:_files' \
          '-log-format=[log format]:f:(standard json)' \
          '-log-level=[log level]:l:(trace debug info warn err)' \
          '*: :' && ret=0 ;;
      (database)
        _arguments \
          '1:subcommand:(init migrate)' \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
