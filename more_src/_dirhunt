#compdef dirhunt
# _dirhunt — Nekmo dirhunt CLI web-server crawl and analysis tool finding open directories indexable files robots-txt sitemap-xml from-error-page hidden-files inferred-content-paths without brute-force using public-index-page-listings response-fingerprint-matching producing console output of interesting findings (Nekmo team, Python); click
# upstream: https://github.com/Nekmo/dirhunt

_dirhunt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-x+[exclude flag]:str:' \
        '--exclude-flags=+[flag]:str:' \
        '-i+[include flag]:str:' \
        '--include-flags=+[flag]:str:' \
        '-e+[exclude code]:n:' \
        '--exclude-codes=+[code]:n:' \
        '--include-codes=+[code]:n:' \
        '-E+[extensions]:str:' \
        '--exclude-extensions=+[ext]:str:' \
        '-X+[remove flags]:str:' \
        '--remove-flags=+[flag]:str:' \
        '--header=+[header]:str:' \
        '--user-agent=+[ua]:str:' \
        '--cookies=+[cookies]:str:' \
        '--proxies=+[url]:str:' \
        '--timeout=+[sec]:n:' \
        '--max-depth=+[N]:n:' \
        '--max-files=+[N]:n:' \
        '--no-progress-bar[hide progress bar]' \
        '--no-redirects[disable redirects]' \
        '--limit=+[N]:n:' \
        '--to-file=+[file]:file:_files' \
        '-l+[limit subdomains]:n:' \
        '--limit-subdomains=+[N]:n:' \
        '--proxy-type=+[t]:t:(http https socks5)' \
        '--interesting-files=+[file]:file:_files' \
        '--interesting-extensions=+[ext]:str:' \
        '*:url:'
}

_dirhunt "$@"
