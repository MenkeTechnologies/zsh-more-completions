#compdef bashtop

# Zsh completion for bashtop (terminal resource monitor)

_arguments -s -S \
  '-h[Show help]' \
  '--help[Show help]' \
  '-v[Show version]' \
  '--version[Show version]' \
  '-lc[Detect and set correct locale]' \
  '-t+[Set bashtop color theme]:theme:' \
  '--theme=[Set bashtop color theme]:theme:' \
  '-ut[Force update check]' \
  '--update[Force update check]' && return 0
