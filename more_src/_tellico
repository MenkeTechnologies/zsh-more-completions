#compdef tellico
# Documentation: https://man.archlinux.org/search?q=tellico
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--nofile[do not open last file]' \
  '--bibtex=+[convert to bibtex]:file:_files -g "*.tc"' \
  '--bibtexml=+[convert to bibtexml]:file:_files' \
  '--mods=+[convert to MODS]:file:_files' \
  '--csv=+[convert to CSV]:file:_files' \
  '--alex=+[convert to alex]:file:_files' \
  '--cif=+[convert to crystallography CIF]:file:_files' \
  '--export-format=+[export format]:fmt:(bibtex bibtexml mods csv html alexandria onix referencer)' \
  '*:collection:_files -g "*.tc"' && ret=0

return ret
