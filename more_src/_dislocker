#compdef dislocker

# Zsh completion for dislocker - BitLocker volume decryption

_arguments -s -S \
  '(- *)'{-h,--help}'[display help and exit]' \
  '-V+[volume to decrypt]:volume:_files -g "*(-%b)"' \
  '*-v[increase verbosity (can be repeated)]' \
  '-p+[use this password to decrypt the volume]:password:' \
  '-u[use the user password to decrypt (prompts for input)]' \
  '-f+[use BEK file to decrypt]:BEK file:_files' \
  '-c[use the clear key to decrypt]' \
  '-k+[use FVEK file directly]:FVEK file:_files' \
  '-K+[use VMK file directly]:VMK file:_files' \
  '-H[force use of a backed up VMK]' \
  '-r[read only mode]' \
  '-F[force decryption]' \
  '-o+[FUSE mount options]:FUSE options:' \
  '--stateok[do not check the BitLocker volume state]' \
  '1:volume path:_files' \
  '2:mount point:_directories'
