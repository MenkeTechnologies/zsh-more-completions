#compdef e2image
# _e2image — save ext2/3/4 metadata to image (e2fsprogs); produces sparse image of FS metadata for debugging/recovery
# upstream: https://github.com/tytso/e2fsprogs

_e2image() {
    _arguments \
        '-r[raw image format]' \
        '-Q[QCOW2 format]' \
        '-q[quiet]' \
        '-f[force]' \
        '-p[preserve sparse layout]' \
        '-a+[include data of files]:offset:' \
        '-b+[superblock]:n:' \
        '-B+[block size]:n:' \
        '-c[print only data]' \
        '-n[no write to target]' \
        '-o+[source offset]:n:' \
        '-O+[dest offset]:n:' \
        '-s+[scramble strings]:scramble:' \
        '-I[install metadata to existing FS]' \
        '*:device or image:_files'
}

_e2image "$@"
