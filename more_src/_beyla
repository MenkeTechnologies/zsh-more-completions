#compdef beyla
# Documentation: https://grafana.com/docs/beyla/latest/configure/options/
# Reference accessed: 2026-05-29
# Beyla — Grafana eBPF auto-instrumentation agent for HTTP/gRPC traces. Mostly env-var configured.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help,--help}'[show help]' \
  '-config=[path to a YAML configuration file]:file:_files -g "*.(yaml|yml)"' \
  && ret=0

# NOTE: Beyla is overwhelmingly env-var driven. Key environment variables:
#   BEYLA_CONFIG_PATH       — alternate config path
#   BEYLA_AUTO_TARGET_EXE   — glob-match executable paths to instrument
#   BEYLA_OPEN_PORT         — instrument processes by open ports (CSV)
#   BEYLA_SHUTDOWN_TIMEOUT  — graceful shutdown timeout
#   BEYLA_LOG_LEVEL         — DEBUG, INFO, WARN, ERROR
#   BEYLA_LOG_FORMAT        — text, json
#   BEYLA_TRACE_PRINTER     — output trace format
#   BEYLA_ENFORCE_SYS_CAPS  — fail when system capabilities are missing
#   BEYLA_AUTO_TARGET_LANGUAGE — go, java, python, rust, ruby, ...
# Env vars take precedence over YAML config.

return ret
