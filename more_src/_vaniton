#
# vaniton is a vanity-address generator for The
# Open Network (TON) blockchain wallets — generates
# 24-word secret phrases, computes the wallet
# address, filters by user-supplied pattern.
# Authored by AntonMeep (69 GH stars).  Pure Ada
# 2012.  Sister tools: alr (Alire Ada package
# manager, already in corpus as `_alr`), gnatmake
# (Ada compiler driver, already in corpus as
# `_gnatmake`), gprbuild (GNAT Project build, in
# corpus).
#
# Critical extraction note: vaniton uses **Ada
# `GNAT.Command_Line` library** at vaniton.adb:5 —
# corpus's **first documented Ada CLI library**.
# `GNAT.Command_Line` is AdaCore's stdlib CLI parser
# (Ada source at `gcc/ada/g-comlin.ads`/`g-comlin.
# adb` in the GCC tree).  Ships with EVERY GNAT
# compiler — no external dependency.  Distinct from
# R301 Nim cligen (third-party library), R302
# Clojure babashka.cli (third-party — bundled with
# Babashka), R303 Gleam Glint (third-party hex.pm
# package).  Ada's approach is STDLIB-FIRST like
# R287 Nim parseopt (stdlib), R297 SWI-Prolog
# optparse (stdlib), R298 Pony stdlib cli, R300 V
# stdlib flag.  Corpus's **first documented GNAT-
# stdlib-bundled CLI library**.  Extends cross-
# language CLI taxonomy to FORTY-THREE library
# variants: Rust (6), Go (4), Python (3), Crystal 1
# OptionParser (R269), Haskell (R270), OCaml (R271),
# C (R272), Java (R276), Kotlin (R277), Scala (R278),
# Dart (R279), Ruby (R280), Perl (R281), PHP (R282),
# Swift (R283), F# (R284), Lua (R285), C# (R286),
# Nim 1 parseopt (R287), Zig (R288), D (R289),
# Racket (R290), Common Lisp 1 (R291), Erlang (R292),
# Tcl (R293), Pharo Smalltalk (R294), Common Lisp 2
# clingon (R295), Julia (R296), SWI-Prolog optparse
# (R297), Pony stdlib cli (R298), Crystal 2 Admiral
# (R299), V stdlib `flag` (R300), Nim 2 cligen (R301),
# Clojure babashka.cli (R302), Gleam Glint (R303),
# **Ada GNAT.Command_Line** (R304 — NEW).
# **MAJOR PATTERN MILESTONE**: 43 cross-language CLI
# library variants documented.
#
# Critical extraction note: vaniton uses **Ada
# `aliased` storage qualifier + `'Access` attribute
# for parser-bound variables** at vaniton.adb:14-19
# — `Number_Of_Workers : aliased Integer;` declares
# the variable as ALIASED (Ada's marker meaning
# "this variable can have a pointer taken to it").
# Then `Define_Switch (Config, Number_Of_Workers'
# Access, "-j:", "--threads=", ...)` passes the
# variable's POINTER (via the `'Access` ATTRIBUTE,
# Ada's address-of operator).  Without `aliased`,
# Ada's STRONG ALIASING DISCIPLINE would reject the
# `'Access` reference at compile time.  Distinct
# from R301 Nim cligen (compile-time macro
# generates parser binding direct to proc params —
# no pointer needed), R302 Clojure babashka.cli
# (parsed values returned in a map — no mutation),
# R303 Gleam Glint (parsed values returned via
# `use`-callback closures — immutable).  Ada's
# approach: EXPLICIT POINTER REGISTRATION at spec
# time — the parser writes through the pointer
# into the caller's variable.  Corpus's **first
# documented explicit-pointer-registration CLI
# pattern**.
#
# Critical extraction note: vaniton uses **Ada
# `Define_Switch` for spec + `Getopt` for parse**
# at vaniton.adb:45-80 — GNAT.Command_Line's API is
# IMPERATIVE: `Define_Switch` calls accumulate
# switch specs into the Config record, then a
# single `Getopt (Config)` triggers the parse.  The
# switch strings use POSTFIX MARKERS:
#   `"-X"`     ← short flag, no arg (boolean)
#   `"-X:"`    ← short flag with REQUIRED arg
#   `"-X?"`    ← short flag with OPTIONAL arg
#   `"--long"` ← long flag, no arg
#   `"--long="`← long flag with REQUIRED arg
#   `"--long?"`← long flag with OPTIONAL arg
# Distinct from POSIX getopt strings (`"a:b"` style
# at R272 C getopt) and from R281 Perl Getopt::Long
# `"name=s"` suffix syntax — Ada uses POSTFIX
# SYMBOL CHARACTERS within the switch literal.
# Corpus's **first documented postfix-symbol-in-
# switch-literal CLI pattern** — combines C-getopt
# brevity with Perl-style required-vs-optional
# distinction.
#
# Critical extraction note: vaniton uses **Ada
# `Define_Alias` for VALUE-EMBEDDED short flags**
# at vaniton.adb:66-78 — 13 `Define_Alias` calls
# map ABBREVIATED tokens like `-wv4` to expanded
# long forms like `--wallet=V4_R2`.  Distinct from
# conventional short flags (`-w V4_R2` is also
# valid because the underlying switch is `-w:`) —
# aliases provide ABBREVIATED-VALUE-COMBOS where
# the value is BAKED INTO the flag itself.  When
# the user types `-wv4`, GNAT.Command_Line REWRITES
# it to `--wallet=V4_R2` BEFORE option parsing
# proceeds.  Distinct from R302 Clojure babashka.cli
# `:aliases {:T :tool}` (short-name → long-name
# map; same-value alias), R301 Nim cligen
# `short={"output":'o'}` (one-char short for a
# long), R285 Lua argparse (no value-embedded
# alias).  Corpus's **first documented value-
# embedded-alias CLI pattern**.
#
# Critical extraction note: vaniton uses **Ada
# inverted-default boolean pattern** at vaniton.adb:
# 50-65 — `Define_Switch (Config, Case_Sensitive'
# Access, "-c", "--case-sensitive", "Match case-
# sensitive (default: " & Case_Sensitive'Img &
# ")", "", not Case_Sensitive)`.  The 6th argument
# is the VALUE TO SET when the flag is matched —
# `not Case_Sensitive` reads as "set to the
# OPPOSITE of the current default".  Since
# `Case_Sensitive` defaults to False, passing `-c`
# sets it to True.  Distinct from R301 Nim cligen
# (default in proc param), R302 Clojure babashka.
# cli (default via `cli/parse-opts :spec {:default
# ...}`), R303 Gleam Glint (default via builder
# method).  Ada's approach: EXPLICIT VALUE
# COMPUTATION at spec time via `not DEFAULT`.
# Reads as the flag FLIPS the default — and works
# correctly even when defaults are dynamically
# computed.  Corpus's **first documented inverted-
# default-via-not-expression CLI pattern**.
#
# Critical extraction note: vaniton uses **Ada
# exception-based help-flag handling** at vaniton.
# adb:105-107 — `when Exit_From_Command_Line =>
# GNAT.OS_Lib.OS_Exit (0);`.  When the user passes
# `-h` or `--help`, GNAT.Command_Line RAISES the
# standard exception `Exit_From_Command_Line`
# (declared in `GNAT.Command_Line` itself).  The
# main procedure's `exception` block catches it
# and exits with status 0.  Sister to R295 CL
# clingon's condition system but Ada-flavored:
# CHECKED EXCEPTION control flow for help-text
# emission.  Distinct from R296 Julia Comonicon's
# `--help` flag (auto-handled by macro), R302
# Clojure babashka.cli (returns `:help true` in
# parsed map for caller to check), R303 Gleam
# Glint (returns `glint.Help(help)` constructor in
# Result).  Ada's approach is EXCEPTION-AS-EARLY-
# EXIT — semantically equivalent to a `goto end`
# from the parser into the caller's exception
# block.  Corpus's **first documented exception-
# based-help-flag CLI pattern**.
#
# Hunt-skip notes: skipped `_alr` (Alire Ada
# package manager, already in corpus + blacklisted
# — uses GNAT.Command_Line + Cobra-style subcommand
# framework; complex surface), `_gnatmake` /
# `_gprbuild` / `_gprinstall` / `_gprclean` (GNAT
# project toolchain, all in corpus), `_iex` /
# `_livebook` / `_elixir` (Elixir tools in corpus),
# `_unison` (DUP with stock zsh).  Probed
# `dmbaturin/hvinfo` (Ada hypervisor detector, 18
# stars — uses GNAT.Command_Line but smaller
# surface), `OpenAADL/ocarina` (AADL model
# processor, 76 stars — complex multi-binary
# toolchain), `stcarrez/ada-awa` (Ada Web Application
# framework, 109 stars — but the framework itself
# isn't a CLI; only `awa-commands-info` is a
# library helper), `AdaCore/gnatstudio` (IDE,
# enormous codebase), `AntonMeep/vaniton` (CHOSEN
# — 69 stars, 6 switches with full `:`/`=` postfix-
# marker surface, 13 `Define_Alias` calls, real
# binary published in `alire.toml`, exercises the
# Ada-specific `aliased`/`'Access` pointer-
# registration pattern).  Chose vaniton: focused
# single-binary tool with EVERY MAJOR GNAT.Command_
# Line PATTERN represented (Set_Usage, Define_
# Switch with all 4 postfix markers, Define_Alias
# for value-embedded shortcuts, Getopt single-shot
# parse, Exit_From_Command_Line exception
# handler, Get_Argument positional retrieval), and
# stable v0.10.0 release.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# Wallet_Kind enum values from source/wallets.ads
local -a vaniton_wallets=(
  'Simple_R1:Simple wallet contract version R1'
  'Simple_R2:Simple wallet contract version R2'
  'Simple_R3:Simple wallet contract version R3 (alias for "Simple")'
  'V2_R1:Wallet V2 contract version R1'
  'V2_R2:Wallet V2 contract version R2 (alias for "V2")'
  'V3_R1:Wallet V3 contract version R1'
  'V3_R2:Wallet V3 contract version R2 (DEFAULT; alias for "V3")'
  'V4_R1:Wallet V4 contract version R1'
  'V4_R2:Wallet V4 contract version R2 (alias for "V4")'
)

# 6 switches + 13 value-embedded aliases decoded
# source-direct from vaniton.adb:45-78.  Aliases
# are exposed as additional short forms so users
# can tab-complete them.
_arguments -s -S \
  '(-j --threads)'{-j+,--threads=}'[number of working threads running in parallel (default: 1)]:threads:' \
  '(-w --wallet -wsimpler1 -wsimpler2 -wsimpler3 -wsimple -wv2r1 -wv2r2 -wv2 -wv3r1 -wv3r2 -wv3 -wv4r1 -wv4r2 -wv4)'{-w+,--wallet=}'[wallet version (default: V3_R2)]:wallet kind:->wallets' \
  '-wsimpler1[alias for --wallet=Simple_R1]' \
  '-wsimpler2[alias for --wallet=Simple_R2]' \
  '-wsimpler3[alias for --wallet=Simple_R3]' \
  '-wsimple[alias for --wallet=Simple_R3]' \
  '-wv2r1[alias for --wallet=V2_R1]' \
  '-wv2r2[alias for --wallet=V2_R2]' \
  '-wv2[alias for --wallet=V2_R2]' \
  '-wv3r1[alias for --wallet=V3_R1]' \
  '-wv3r2[alias for --wallet=V3_R2]' \
  '-wv3[alias for --wallet=V3_R2]' \
  '-wv4r1[alias for --wallet=V4_R1]' \
  '-wv4r2[alias for --wallet=V4_R2]' \
  '-wv4[alias for --wallet=V4_R2]' \
  '(-c --case-sensitive)'{-c,--case-sensitive}'[match pattern case-sensitively (default: False)]' \
  '(-l --log)'{-l+,--log=}'[log program output to file (default: stdout)]:log file:_files' \
  '(-t --test-only)'{-t,--test-only}'[generate testnet addresses (default: mainnet)]' \
  '(-b --bounceable)'{-b,--bounceable}'[generate non-bounceable addresses (default: bounceable)]' \
  '(- *)'{-h,--help}'[display GNAT.Command_Line auto-generated help]' \
  '*:pattern:' && ret=0

case $state in
  wallets)
    _describe -t wallet_kinds 'TON wallet contract version' vaniton_wallets && ret=0
    ;;
esac

return ret
