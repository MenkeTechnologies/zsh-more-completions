#compdef hdlmake
# Documentation: https://hdlmake.readthedocs.io/en/master/
# hdlmake: generate makefiles/projects for HDL synthesis and simulation toolchains

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version information]' \
  '--log=[set logging level]:level:(critical error warning info debug)' \
  '--logfile=[store log information to file]:file:_files' \
  '(-f --filename)'{-f,--filename}'=[name of synthesis or simulation Makefile]:file:_files' \
  '(-a --all)'{-a,--all}'[do not purge files not dependent on top entity]' \
  '(-p --prefix)'{-p,--prefix}'=[Python code evaluated before each Manifest.py]:code:' \
  '(-s --suffix)'{-s,--suffix}'=[Python code evaluated after each Manifest.py]:code:' \
  '1:action:((makefile\:"generate simulation/synthesis makefile" fetch\:"fetch/update remote modules" clean\:"remove fetched modules" list-mods\:"list all modules in design" list-files\:"list all files in hierarchy" manifest-help\:"print manifest variable descriptions"))' && ret=0

return ret
