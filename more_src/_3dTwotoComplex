#compdef 3dTwotoComplex
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTwotoComplex.html
# Combine two datasets into a complex-valued dataset

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-prefix[output dataset prefix]:prefix:' \
  '-RI[inputs are real and imaginary parts]' \
  '-MP[inputs are magnitude and phase (radians)]' \
  '-mask[output nonzero only where mask is nonzero]:dataset:_files' \
  '*:dataset:_files' && ret=0

return ret
