#compdef pbibtex upbibtex
# Documentation: pbibtex --help / upbibtex --help (TeX Live 2026)
# Source: pBibTeX / upBibTeX — Japanese BibTeX variants for pTeX / upTeX.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(--guess-input-enc --no-guess-input-enc)-guess-input-enc[enable input-encoding guess]' \
    '(--guess-input-enc --no-guess-input-enc)-no-guess-input-enc[disable input-encoding guess]' \
    '-kanji=[Japanese encoding]:enc:(euc jis sjis utf8 uptex)' \
    '-kanji-internal=[Japanese internal encoding]:enc:(euc uptex)' \
    '-min-crossrefs=[min cross-refs to inline (default 2)]:n:' \
    '-terse[no progress reports]' \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '1:aux file:_files -g "*.aux"' \
    && ret=0

return ret
