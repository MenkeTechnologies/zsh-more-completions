#compdef vcfkit
# Source: cargo binstall vcfkit-cli@0.3.0
# Probed via: completions zsh
# Repository: https://github.com/robertlangdonn/vcfkit

autoload -U is-at-least

_vcfkit() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--color=[Control colour output]:WHEN:(auto always never)' \
'*-v[Increase verbosity (-v = info, -vv = debug, -vvv = trace)]' \
'*--verbose[Increase verbosity (-v = info, -vv = debug, -vvv = trace)]' \
'(-v --verbose)-q[Suppress non-error output]' \
'(-v --verbose)--quiet[Suppress non-error output]' \
'--no-telemetry[Disable telemetry for this run]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_vcfkit_commands" \
"*::: :->vcfkit" \
&& ret=0
    case $state in
    (vcfkit)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:vcfkit-command-$line[1]:"
        case $line[1] in
            (normalize)
_arguments "${_arguments_options[@]}" : \
'-f+[Reference genome FASTA (required)]:FASTA:_files' \
'--reference=[Reference genome FASTA (required)]:FASTA:_files' \
'-o+[Output file (default\: stdout)]:FILE:_files' \
'--output=[Output file (default\: stdout)]:FILE:_files' \
'--check-ref=[How to handle reference mismatches]:MODE:(ignore warn error)' \
'--color=[Control colour output]:WHEN:(auto always never)' \
'--no-split[Do not split multi-allelic sites]' \
'--no-left-align[Do not left-align indels]' \
'--no-progress[Suppress the progress bar even when stderr is a TTY]' \
'--fast[Fast path\: biallelic SNPs/MNPs skip noodles entirely and are written as raw bytes (~4× faster on SNP-heavy VCFs). Multi-allelics and indels fall back to the full pipeline automatically]' \
'*-v[Increase verbosity (-v = info, -vv = debug, -vvv = trace)]' \
'*--verbose[Increase verbosity (-v = info, -vv = debug, -vvv = trace)]' \
'(-v --verbose)-q[Suppress non-error output]' \
'(-v --verbose)--quiet[Suppress non-error output]' \
'--no-telemetry[Disable telemetry for this run]' \
'-h[Print help]' \
'--help[Print help]' \
'::input -- Input VCF/BCF (default\: stdin):_files' \
&& ret=0
;;
(liftover)
_arguments "${_arguments_options[@]}" : \
'-s+[Source reference genome (required unless --list-chains)]:FASTA:_files' \
'--source-ref=[Source reference genome (required unless --list-chains)]:FASTA:_files' \
'-t+[Target reference genome (optional; when omitted REF alleles are not validated against the target build after liftover)]:FASTA:_files' \
'--target-ref=[Target reference genome (optional; when omitted REF alleles are not validated against the target build after liftover)]:FASTA:_files' \
'-c+[Chain file (required unless --list-chains)]:FILE:_files' \
'--chain=[Chain file (required unless --list-chains)]:FILE:_files' \
'-r+[Write rejected variants here]:FILE:_files' \
'--reject=[Write rejected variants here]:FILE:_files' \
'-o+[Output file (default\: stdout)]:FILE:_files' \
'--output=[Output file (default\: stdout)]:FILE:_files' \
'--color=[Control colour output]:WHEN:(auto always never)' \
'--list-chains[Print known chain file URLs and exit]' \
'--write-src-coords[Add INFO/SRC_CONTIG and INFO/SRC_POS to each mapped record]' \
'--no-fix-swapped-ref[Do not flip alleles when a chain block is on the opposite strand; reject such records instead]' \
'--allow-contig-mismatch[Suppress the contig-name mismatch error (e.g. b37 VCF + UCSC chain) and proceed — all mismatched records will be rejected]' \
'--no-progress[Suppress the progress bar even when stderr is a TTY]' \
'*-v[Increase verbosity (-v = info, -vv = debug, -vvv = trace)]' \
'*--verbose[Increase verbosity (-v = info, -vv = debug, -vvv = trace)]' \
'(-v --verbose)-q[Suppress non-error output]' \
'(-v --verbose)--quiet[Suppress non-error output]' \
'--no-telemetry[Disable telemetry for this run]' \
'-h[Print help]' \
'--help[Print help]' \
'::input -- Input VCF/BCF (default\: stdin):_files' \
&& ret=0
;;
(filter)
_arguments "${_arguments_options[@]}" : \
'-e+[Filter expression]:EXPR:_default' \
'--expression=[Filter expression]:EXPR:_default' \
'-a+[Natural-language query (translated to an expression via Anthropic API)]:QUERY:_default' \
'--ask=[Natural-language query (translated to an expression via Anthropic API)]:QUERY:_default' \
'-o+[Output file (default\: stdout)]:FILE:_files' \
'--output=[Output file (default\: stdout)]:FILE:_files' \
'--color=[Control colour output]:WHEN:(auto always never)' \
'--yes[Skip confirmation when using --ask (for scripting)]' \
'--accept-low-confidence[Proceed even when the translation confidence is below 50%]' \
'--invert[Keep variants NOT matching the expression]' \
'--no-progress[Suppress the progress bar even when stderr is a TTY]' \
'*-v[Increase verbosity (-v = info, -vv = debug, -vvv = trace)]' \
'*--verbose[Increase verbosity (-v = info, -vv = debug, -vvv = trace)]' \
'(-v --verbose)-q[Suppress non-error output]' \
'(-v --verbose)--quiet[Suppress non-error output]' \
'--no-telemetry[Disable telemetry for this run]' \
'-h[Print help]' \
'--help[Print help]' \
'::input -- Input VCF/BCF (default\: stdin):_files' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--color=[Control colour output]:WHEN:(auto always never)' \
'*-v[Increase verbosity (-v = info, -vv = debug, -vvv = trace)]' \
'*--verbose[Increase verbosity (-v = info, -vv = debug, -vvv = trace)]' \
'(-v --verbose)-q[Suppress non-error output]' \
'(-v --verbose)--quiet[Suppress non-error output]' \
'--no-telemetry[Disable telemetry for this run]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_vcfkit__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:vcfkit-help-command-$line[1]:"
        case $line[1] in
            (normalize)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(liftover)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(filter)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_vcfkit_commands] )) ||
_vcfkit_commands() {
    local commands; commands=(
'normalize:Normalize a VCF (left-align, split multi-allelics)' \
'liftover:Convert variants between reference builds' \
'filter:Filter variants by expression' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'vcfkit commands' commands "$@"
}
(( $+functions[_vcfkit__subcmd__completions_commands] )) ||
_vcfkit__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'vcfkit completions commands' commands "$@"
}
(( $+functions[_vcfkit__subcmd__filter_commands] )) ||
_vcfkit__subcmd__filter_commands() {
    local commands; commands=()
    _describe -t commands 'vcfkit filter commands' commands "$@"
}
(( $+functions[_vcfkit__subcmd__help_commands] )) ||
_vcfkit__subcmd__help_commands() {
    local commands; commands=(
'normalize:Normalize a VCF (left-align, split multi-allelics)' \
'liftover:Convert variants between reference builds' \
'filter:Filter variants by expression' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'vcfkit help commands' commands "$@"
}
(( $+functions[_vcfkit__subcmd__help__subcmd__completions_commands] )) ||
_vcfkit__subcmd__help__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'vcfkit help completions commands' commands "$@"
}
(( $+functions[_vcfkit__subcmd__help__subcmd__filter_commands] )) ||
_vcfkit__subcmd__help__subcmd__filter_commands() {
    local commands; commands=()
    _describe -t commands 'vcfkit help filter commands' commands "$@"
}
(( $+functions[_vcfkit__subcmd__help__subcmd__help_commands] )) ||
_vcfkit__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'vcfkit help help commands' commands "$@"
}
(( $+functions[_vcfkit__subcmd__help__subcmd__liftover_commands] )) ||
_vcfkit__subcmd__help__subcmd__liftover_commands() {
    local commands; commands=()
    _describe -t commands 'vcfkit help liftover commands' commands "$@"
}
(( $+functions[_vcfkit__subcmd__help__subcmd__normalize_commands] )) ||
_vcfkit__subcmd__help__subcmd__normalize_commands() {
    local commands; commands=()
    _describe -t commands 'vcfkit help normalize commands' commands "$@"
}
(( $+functions[_vcfkit__subcmd__liftover_commands] )) ||
_vcfkit__subcmd__liftover_commands() {
    local commands; commands=()
    _describe -t commands 'vcfkit liftover commands' commands "$@"
}
(( $+functions[_vcfkit__subcmd__normalize_commands] )) ||
_vcfkit__subcmd__normalize_commands() {
    local commands; commands=()
    _describe -t commands 'vcfkit normalize commands' commands "$@"
}

if [ "$funcstack[1]" = "_vcfkit" ]; then
    _vcfkit "$@"
else
    compdef _vcfkit vcfkit
fi
