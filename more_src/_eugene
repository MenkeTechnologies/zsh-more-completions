#compdef eugene
# Documentation: https://man.archlinux.org/search?q=eugene
# Reference accessed: 2026-05-16
# Source: cargo binstall eugene@0.8.3
# Probed via: completions --shell zsh
# Repository: https://github.com/kaaveland/eugene.git

autoload -U is-at-least

_eugene() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_eugene_commands" \
"*::: :->eugene" \
&& ret=0
    case $state in
    (eugene)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:eugene-command-$line[1]:"
        case $line[1] in
            (lint)
_arguments "${_arguments_options[@]}" : \
'*-v+[Provide name=value for replacing \${name} with value in the SQL script]:PLACEHOLDERS:_default' \
'*--var=[Provide name=value for replacing \${name} with value in the SQL script]:PLACEHOLDERS:_default' \
'*-i+[Ignore the hints with these IDs, use \`eugene hints\` to see available hints]:IGNORED_HINTS:_default' \
'*--ignore=[Ignore the hints with these IDs, use \`eugene hints\` to see available hints]:IGNORED_HINTS:_default' \
'-f+[Output format, plain, json or markdown]:FORMAT:(json markdown md plain)' \
'--format=[Output format, plain, json or markdown]:FORMAT:(json markdown md plain)' \
'--sort-mode=[Sort mode for script discovery, auto, name or none]:SORT_MODE:(auto name none)' \
'-g+[Filter out discovered scripts that have not been changed since this git ref]:GIT_DIFF:_default' \
'--git-diff=[Filter out discovered scripts that have not been changed since this git ref]:GIT_DIFF:_default' \
'*--skip=[Skip SQL statements matching this regex (do not execute or lint them)]:SKIP:_default' \
'-a[Exit successfully even if problems are detected]' \
'--accept-failures[Exit successfully even if problems are detected]' \
'-s[Skip the summary section for markdown output]' \
'--skip-summary[Skip the summary section for markdown output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'*::paths -- Path to SQL migration scripts, directories, or '\''-'\'' to read from stdin:_default' \
&& ret=0
;;
(trace)
_arguments "${_arguments_options[@]}" : \
'*-v+[Provide name=value for replacing \${name} with value in the SQL script]:PLACEHOLDERS:_default' \
'*--var=[Provide name=value for replacing \${name} with value in the SQL script]:PLACEHOLDERS:_default' \
'*-i+[Ignore the hints with these IDs, use \`eugene hints\` to see available hints]:IGNORED_HINTS:_default' \
'*--ignore=[Ignore the hints with these IDs, use \`eugene hints\` to see available hints]:IGNORED_HINTS:_default' \
'-f+[Output format, plain, json or markdown]:FORMAT:(json markdown md plain)' \
'--format=[Output format, plain, json or markdown]:FORMAT:(json markdown md plain)' \
'--sort-mode=[Sort mode for script discovery, auto, name or none]:SORT_MODE:(auto name none)' \
'-g+[Filter out discovered scripts that have not been changed since this git ref]:GIT_DIFF:_default' \
'--git-diff=[Filter out discovered scripts that have not been changed since this git ref]:GIT_DIFF:_default' \
'*--skip=[Skip SQL statements matching this regex (do not execute or lint them)]:SKIP:_default' \
'-o+[Portgres options to pass to the temporary postgres server]:POSTGRES_OPTIONS:_default' \
'--postgres-options=[Portgres options to pass to the temporary postgres server]:POSTGRES_OPTIONS:_default' \
'*--initdb=[Initdb options to pass when creating the temporary postgres server]:INITDB_OPTIONS:_default' \
'-U+[Username to use for connecting to postgres]:USER:_default' \
'--user=[Username to use for connecting to postgres]:USER:_default' \
'-d+[Database to connect to]:DATABASE:_default' \
'--database=[Database to connect to]:DATABASE:_default' \
'-H+[Host to connect to]:HOST:_default' \
'--host=[Host to connect to]:HOST:_default' \
'-p+[Port to connect to]:PORT:_default' \
'--port=[Port to connect to]:PORT:_default' \
'-a[Exit successfully even if problems are detected]' \
'--accept-failures[Exit successfully even if problems are detected]' \
'-s[Skip the summary section for markdown output]' \
'--skip-summary[Skip the summary section for markdown output]' \
'--disable-temporary[Disable creation of temporary postgres server for tracing]' \
'-c[Commit at the end of the transaction]' \
'--commit[Commit at the end of the transaction]' \
'-e[Show locks that are normally not in conflict with application code]' \
'--extra[Show locks that are normally not in conflict with application code]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'*::paths -- Path to SQL migration scripts, directories, or '\''-'\'' to read from stdin:_default' \
&& ret=0
;;
(modes)
_arguments "${_arguments_options[@]}" : \
'-f+[Output format, json]:FORMAT:_default' \
'--format=[Output format, json]:FORMAT:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(explain)
_arguments "${_arguments_options[@]}" : \
'-f+[Output format, json]:FORMAT:_default' \
'--format=[Output format, json]:FORMAT:_default' \
'-h[Print help]' \
'--help[Print help]' \
':mode -- Lock mode to explain:_default' \
&& ret=0
;;
(hints)
_arguments "${_arguments_options[@]}" : \
'-f+[Output format, json]:FORMAT:_default' \
'--format=[Output format, json]:FORMAT:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-s+[]:SHELL:(bash zsh fish pwsh powershell)' \
'--shell=[]:SHELL:(bash zsh fish pwsh powershell)' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_eugene__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:eugene-help-command-$line[1]:"
        case $line[1] in
            (lint)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(trace)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(modes)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(explain)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(hints)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_eugene_commands] )) ||
_eugene_commands() {
    local commands; commands=(
'lint:Lint SQL migration script by analyzing syntax tree' \
'trace:Trace effects by running statements from SQL migration script' \
'modes:List postgres lock modes' \
'explain:Explain what operations a lock mode allows and conflicts with' \
'hints:Show migration hints that eugene can detect in traces' \
'completions:Generate shell completions for eugene' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'eugene commands' commands "$@"
}
(( $+functions[_eugene__completions_commands] )) ||
_eugene__completions_commands() {
    local commands; commands=()
    _describe -t commands 'eugene completions commands' commands "$@"
}
(( $+functions[_eugene__explain_commands] )) ||
_eugene__explain_commands() {
    local commands; commands=()
    _describe -t commands 'eugene explain commands' commands "$@"
}
(( $+functions[_eugene__help_commands] )) ||
_eugene__help_commands() {
    local commands; commands=(
'lint:Lint SQL migration script by analyzing syntax tree' \
'trace:Trace effects by running statements from SQL migration script' \
'modes:List postgres lock modes' \
'explain:Explain what operations a lock mode allows and conflicts with' \
'hints:Show migration hints that eugene can detect in traces' \
'completions:Generate shell completions for eugene' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'eugene help commands' commands "$@"
}
(( $+functions[_eugene__help__completions_commands] )) ||
_eugene__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'eugene help completions commands' commands "$@"
}
(( $+functions[_eugene__help__explain_commands] )) ||
_eugene__help__explain_commands() {
    local commands; commands=()
    _describe -t commands 'eugene help explain commands' commands "$@"
}
(( $+functions[_eugene__help__help_commands] )) ||
_eugene__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'eugene help help commands' commands "$@"
}
(( $+functions[_eugene__help__hints_commands] )) ||
_eugene__help__hints_commands() {
    local commands; commands=()
    _describe -t commands 'eugene help hints commands' commands "$@"
}
(( $+functions[_eugene__help__lint_commands] )) ||
_eugene__help__lint_commands() {
    local commands; commands=()
    _describe -t commands 'eugene help lint commands' commands "$@"
}
(( $+functions[_eugene__help__modes_commands] )) ||
_eugene__help__modes_commands() {
    local commands; commands=()
    _describe -t commands 'eugene help modes commands' commands "$@"
}
(( $+functions[_eugene__help__trace_commands] )) ||
_eugene__help__trace_commands() {
    local commands; commands=()
    _describe -t commands 'eugene help trace commands' commands "$@"
}
(( $+functions[_eugene__hints_commands] )) ||
_eugene__hints_commands() {
    local commands; commands=()
    _describe -t commands 'eugene hints commands' commands "$@"
}
(( $+functions[_eugene__lint_commands] )) ||
_eugene__lint_commands() {
    local commands; commands=()
    _describe -t commands 'eugene lint commands' commands "$@"
}
(( $+functions[_eugene__modes_commands] )) ||
_eugene__modes_commands() {
    local commands; commands=()
    _describe -t commands 'eugene modes commands' commands "$@"
}
(( $+functions[_eugene__trace_commands] )) ||
_eugene__trace_commands() {
    local commands; commands=()
    _describe -t commands 'eugene trace commands' commands "$@"
}

if [ "$funcstack[1]" = "_eugene" ]; then
    _eugene "$@"
else
    compdef _eugene eugene
fi
