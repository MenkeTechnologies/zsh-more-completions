#compdef fastx_quality_stats
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fastx_quality_stats.1.en.html
# FASTX-Toolkit: produce per-cycle quality statistics for a FASTQ file

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-N[new output format with more information per nucleotide/cycle]' \
  '-Q+[FASTQ ASCII offset (default 33)]:offset' \
  '-i+[FASTQ input file (default STDIN)]:input file:_files' \
  '-o+[TEXT output file (default STDOUT)]:output file:_files' && ret=0

return ret
