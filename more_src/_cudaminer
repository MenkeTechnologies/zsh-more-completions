#compdef cudaminer
# Documentation: https://github.com/cbuchner1/CudaMiner
# Reference accessed: 2026-05-16
# Verified: upstream cbuchner1/CudaMiner. Dead project (last commit
# 2014); CryptoNote-era miner.
# Removed from prior file: bogus man.archlinux.org search URL.

# cudaminer: discontinued NVIDIA CUDA crypto miner (CryptoNote era)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --algo)'{-a+,--algo=}'[hash algorithm]:algo:(scrypt scrypt:N keccak blake)' \
  '(-o --url)'{-o+,--url=}'[mining pool URL]:url:_urls' \
  '(-u --user)'{-u+,--user=}'[username]:user:' \
  '(-p --pass)'{-p+,--pass=}'[password]:password:' \
  '(-O --userpass)'{-O+,--userpass=}'[user\:pass combo]:userpass:' \
  '(-t --threads)'{-t+,--threads=}'[CPU threads]:n:' \
  '(-d --devices)'{-d+,--devices=}'[GPU device list]:devices:' \
  '(-i --intensity)'{-i+,--intensity=}'[hash intensity]:n:' \
  '(-l --launch-config)'{-l+,--launch-config=}'[launch config]:config:' \
  '(-H --hash-parallel)'{-H+,--hash-parallel=}'[hash parallelism]:n:' \
  '(-C --texture-cache)'{-C+,--texture-cache=}'[texture cache mode]:mode:' \
  '(-m --lookup-gap)'{-m+,--lookup-gap=}'[lookup gap]:n:' \
  '(-T --timeout)'{-T+,--timeout=}'[timeout]:s:' \
  '(-r --retries)'{-r+,--retries=}'[retries]:n:' \
  '(-R --retry-pause)'{-R+,--retry-pause=}'[retry pause]:s:' \
  '(-s --scantime)'{-s+,--scantime=}'[scan time]:s:' \
  '(-D --debug)'{-D,--debug}'[debug output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-P --protocol-dump)'{-P,--protocol-dump}'[dump protocol]' \
  '(-B --background)'{-B,--background}'[run in background]' && ret=0
return ret
