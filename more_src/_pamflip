#compdef pamflip
# Documentation: man pamflip (Netpbm)
# Source: Netpbm pamflip — flip or rotate a PAM or PNM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a actions
actions=(
    -leftright -lr -topbottom -tb -transpose -xy
    -rotate90 -r90 -cw -rotate270 -r270 -ccw
    -rotate180 -r180 -null -xform -reflect
)

_arguments -s \
    "(${actions[*]})"{-leftright,-lr}'[flip left for right]' \
    "(${actions[*]})"{-topbottom,-tb}'[flip top for bottom]' \
    "(${actions[*]})"{-transpose,-xy}'[transpose (mirror about main diagonal)]' \
    "(${actions[*]})-reflect[reflect about secondary diagonal]" \
    "(${actions[*]})"{-rotate90,-r90,-cw}'[rotate 90° clockwise]' \
    "(${actions[*]})"{-rotate270,-r270,-ccw}'[rotate 270° clockwise (= 90° ccw)]' \
    "(${actions[*]})"{-rotate180,-r180}'[rotate 180°]' \
    "(${actions[*]})-null[null transform (pass image through)]" \
    "(${actions[*]})-xform=[apply listed transforms in order]:xform list:" \
    '-inverse[apply the inverse of the chosen transform]' \
    '-memsize=[buffer memory size (MiB)]:mebibytes:' \
    '-pagesize=[page size (bytes)]:bytes:' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:PAM/PNM file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
