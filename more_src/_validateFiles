#compdef validateFiles
# Documentation: https://github.com/ucscGenomeBrowser/kent/blob/master/src/hg/encode3/validateFiles/validateFiles.c
# Validates the format of different genomic files

local ret=1

_arguments -s -S \
  '-type=[file type to validate: fasta, fastq, bam, bigWig, bedN, bigBedN, narrowPeak, ...]:type:' \
  '-as=[AutoSql definition of extra bedPlus fields]:fields.as:_files' \
  '-tab[expect fields to be tab separated]' \
  '-chromDb=[DB containing chromInfo table to validate chrom names and sizes]:db:' \
  '-chromInfo=[chromInfo file to validate chrom names and sizes]:file:_files' \
  '-colorSpace[sequences include colorspace values 0-3]' \
  '-isSorted[input is sorted by chrom]' \
  '-doReport[output report in filename.report]' \
  '-version[print version]' \
  '-genome=[path to .2bit for validating sequence mappings]:2bit:_files' \
  '-nMatch[N s do not count as a mismatch]' \
  '-matchFirst=[only check the first N bases of the sequence]:n:' \
  '-mismatches=[maximum number of mismatches in sequence or read pair]:n:' \
  '-mismatchTotalQuality=[maximum total quality score at mismatching positions]:n:' \
  '-mmPerPair[check either pair does not exceed mismatch count]' \
  '-mmCheckOneInN=[check mismatches in only one in n lines]:n:' \
  '-allowOther[allow chromosomes that are not native in BAMs]' \
  '-allowBadLength[allow chromosomes that have the wrong length in BAM]' \
  '-complementMinus[complement the query sequence on the minus strand]' \
  '-bamPercent=[percentage of BAM alignments that must be compliant]:n:' \
  '-privateData[private data so empty sequence is tolerated]' \
  '*:file:_files' && ret=0

return ret
