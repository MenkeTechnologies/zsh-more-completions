#compdef re2swift
# Documentation: https://re2c.org/manual/manual_c.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# re2swift is re2c invoked for the Swift backend (or installed as `re2swift` wrapper).

local -a arguments

arguments=(
    '(- *)-h[show help message]'
    '(- *)--help[show help message]'
    '(- *)-\?[show help message]'
    '(- *)-v[show version information]'
    '(- *)--version[show version information]'
    '(- *)-V[show version in MMmmpp format]'
    '(- *)--vernum[show version in MMmmpp format]'
    '--verbose[print extra information during code generation]'
    '(-o --output)'{-o+,--output=}'[specify output file]:output file:_files'
    '(-b --bit-vectors)'{-b,--bit-vectors}'[optimize conditional jumps using bit masks]'
    '(-s --nested-ifs)'{-s,--nested-ifs}'[use nested if statements instead of switch]'
    '(-g --computed-gotos)'{-g,--computed-gotos}'[use computed-goto extension]'
    '--computed-gotos-relative[use computed-goto with relative offsets]'
    '(-e --ebcdic --ecb)'{-e,--ebcdic,--ecb}'[generate EBCDIC-encoded lexer]'
    '--encoding-policy[handling of Unicode surrogates]:policy:(fail substitute ignore)'
    '--input-encoding[regex parsing encoding]:encoding:(ascii utf8)'
    '(-i --no-debug-info)'{-i,--no-debug-info}'[do not output line directives]'
    '--no-generation-date[suppress generation date in output]'
    '--no-version[suppress version line in output]'
    '--no-unsafe[do not emit unsafe wrapper around YYPEEK (Rust)]'
    '(-r --reusable)'{-r,--reusable}'[allow reuse of scanner definitions (deprecated)]'
    '(-c --conditions --start-conditions)'{-c,--conditions,--start-conditions}'[enable Flex-style start conditions]'
    '(-t --header --type-header)'{-t+,--header=,--type-header=}'[generate header file]:header file:_files'
    '(-T --tags)'{-T,--tags}'[enable submatch extraction with tags]'
    '(-P --posix-captures)'{-P,--posix-captures}'[enable POSIX-style capturing groups]'
    '--posix-captvars[POSIX captures stored in yytl<k>/yytr<k>]'
    '--captures[leftmost greedy capturing groups]'
    '--leftmost-captures[leftmost greedy capturing groups]'
    '--captvars[leftmost greedy capture variables]'
    '--leftmost-captvars[leftmost greedy capture variables]'
    '--invert-captures[invert capturing/non-capturing groups]'
    '(-f --storable-state)'{-f,--storable-state}'[generate lexer that can store inner state]'
    '(-F --flex-syntax)'{-F,--flex-syntax}'[partial Flex syntax support]'
    '--case-insensitive[strings are case-insensitive]'
    '--case-inverted[invert case sensitivity of single/double quoted strings]'
    '--case-ranges[collapse switch cases into ranges]'
    '--empty-class[empty character class policy]:policy:(match-empty match-none error)'
    '--api[interface API style]:style:(simple record generic)'
    '--input[deprecated alias for --api]:api:(default custom)'
    '--lang[target language]:language:(none c d go haskell java js ocaml python rust swift v zig)'
    '--location-format[location format in messages]:format:(gnu msvc)'
    '--loop-switch[use loop/switch DFA code model]'
    '--goto-label[use goto/label DFA code model]'
    '--recursive-functions[use co-recursive function code model]'
    '--syntax[load syntax configuration file]:file:_files'
    '--depfile[write Makefile dependency information]:file:_files'
    '*-I+[add include search path]:path:_directories'
    '-W[turn on all warnings]'
    '-Werror[turn warnings into errors]'
    '-Wno-match-empty-string[suppress match-empty-string warnings]'
    '-Wno-nondeterministic-tags[suppress nondeterministic-tags warnings]'
    '-Wno-swapped-range[suppress swapped-range warnings]'
    '-Wno-undefined-control-flow[suppress undefined-control-flow warnings]'
    '-Wno-useless-escape[suppress useless-escape warnings]'
    '(-d --debug-output)'{-d,--debug-output}'[emit YYDEBUG invocations in generated code]'
    '(-S --skeleton)'{-S,--skeleton}'[generate self-contained skeleton program]'
    '(-D --emit-dot)'{-D,--emit-dot}'[emit DFA in .dot format]'
    '-8[generate UTF-8 scanner]'
    '--utf8[generate UTF-8 scanner]'
    '--utf-8[generate UTF-8 scanner]'
    '-x[generate UTF-16 scanner]'
    '--utf16[generate UTF-16 scanner]'
    '--utf-16[generate UTF-16 scanner]'
    '-u[generate UTF-32 scanner]'
    '--utf32[generate UTF-32 scanner]'
    '--unicode[generate UTF-32 scanner]'
    '-w[generate UCS-2 scanner]'
    '--ucs2[generate UCS-2 scanner]'
    '--wide-chars[generate UCS-2 scanner]'
    '*:input files:_files'
)

_arguments -s -S $arguments
