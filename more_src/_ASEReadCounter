#compdef ASEReadCounter
# Documentation: https://gatk.broadinstitute.org/hc/en-us/articles/360037593871-ASEReadCounter
# Generates allele-specific expression read counts at heterozygous sites

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-O --output)'{-O,--output}'=[output file (defaults to STDOUT)]:file:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '*'{-I,--input}'=[BAM/SAM/CRAM read file]:bam:_files' \
  '*'{-V,--variant}'=[one or more VCF files]:vcf:_files' \
  '(-min-depth --min-depth-of-non-filtered-base)'{-min-depth,--min-depth-of-non-filtered-base}'=[min bases that pass filters]:n:' \
  '(-mmq --min-mapping-quality)'{-mmq,--min-mapping-quality}'=[min read mapping quality]:q:' \
  '(-mbq --min-base-quality)'{-mbq,--min-base-quality}'=[min base quality]:q:' \
  '(-overlap --count-overlap-reads-handling)'{-overlap,--count-overlap-reads-handling}'=[handling of overlapping reads from same fragment]:mode:(COUNT_READS COUNT_FRAGMENTS COUNT_FRAGMENTS_REQUIRE_SAME_BASE)' \
  '--output-format=[format of the output file]:format:(CSV TABLE RTABLE)' \
  '*'{-L,--intervals}'=[genomic intervals to operate over]:intervals:' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam:_files' && ret=0

return ret
