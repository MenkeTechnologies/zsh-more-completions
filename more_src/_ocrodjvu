#compdef ocrodjvu
# Documentation: https://manpages.org/ocrodjvu
# perform OCR on a DjVu document and save results in the hidden text layer

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --save-bundled)'{-o,--save-bundled}'[save as bundled multi-page document]:file:_files' \
  '(-i --save-indirect)'{-i,--save-indirect}'[save as indirect multi-page document]:file:_files' \
  '--save-script=[save djvused script with OCR results]:file:_files' \
  '--in-place[save results in place]' \
  '--dry-run[process without changing files]' \
  '(-e --engine)'{-e,--engine}'[specify OCR engine]:engine' \
  '--list-engines[display available OCR engines]' \
  '--ocr-only[save only selected pages for OCR]' \
  '--clear-text[remove existing hidden text from unprocessed pages]' \
  '--save-raw-ocr=[save raw OCR results to directory]:dir:_files -/' \
  '--raw-ocr-filename-template=[naming scheme for raw results]:template' \
  '(-t --details)'{-t,--details}'[text segmentation detail level]:level:(lines words chars)' \
  '--word-segmentation=[word segmentation algorithm]:algo:(simple uax29)' \
  '(-l --language)'{-l,--language}'[set recognition language]:lang' \
  '--list-languages[display available languages]' \
  '--render=[layers to render]:render:(mask foreground all)' \
  '(-p --pages)'{-p,--pages}'[pages to process]:range' \
  '(-j --jobs)'{-j,--jobs}'[max concurrent OCR processes]:n' \
  '(-D --debug)'{-D,--debug}'[retain intermediate files]' \
  '-X[control operational details]:key=value' \
  '--on-error=[error handling]:mode:(abort resume)' \
  '--html5[use HTML5 parser]' \
  '--version[display version information]' \
  '*:djvu file:_files -g "*.djvu"' && ret=0

return ret
