#compdef h5debug
# Documentation: https://github.com/HDFGroup/hdf5
# Source: HDFGroup/hdf5 tools/src/misc/h5debug.c — debug HDF5 file objects by address (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:filename:_files -g "*.{h5,hdf5}"' \
    '2:object address:_default' \
    '*:extra args (e.g. local heap address):_default' \
    && ret=0

return ret
