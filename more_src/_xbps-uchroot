#compdef xbps-uchroot
# Documentation: https://man.voidlinux.org/xbps-uchroot.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '*-B+[bind mount src:dest read-only]:bind:' \
  '*-b+[bind mount src:dest]:bind:' \
  '-O[set up overlayfs over tmpfs]' \
  '-o+[tmpfs mount options (with -O or -t)]:opts:' \
  '-t[mount temporary dir as tmpfs]' \
  '1:chroot_dir:_files -/' \
  '*::command:_command_names' && ret=0

return ret
