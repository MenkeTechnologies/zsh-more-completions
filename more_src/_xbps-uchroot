#compdef xbps-uchroot
# Documentation: https://man.voidlinux.org/xbps-uchroot.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-O+[overlay tmpfs paths]:paths:' \
  '-D+[distfiles directory bind mount]:dir:_files -/' \
  '-H+[host directory bind mount]:dir:_files -/' \
  '-S+[size of tmpfs overlay]:size:' \
  '1:chroot_dir:_files -/' \
  '*::command:_command_names' && ret=0

return ret
