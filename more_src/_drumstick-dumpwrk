#compdef drumstick-dumpwrk
# _drumstick-dumpwrk — dump Cakewalk WRK files as text (pedrolcl/drumstick)
# upstream: https://github.com/pedrolcl/drumstick
# Flags from utils/dumpwrk/dumpwrk.cpp (QCommandLineParser).

_drumstick-dumpwrk() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--verbose[verbose output]' \
        '*:WRK file:_files -g "*.wrk"'
}

_drumstick-dumpwrk "$@"
