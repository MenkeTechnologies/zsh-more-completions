#                                      `query::BoostQuery`,
#                                      `query::ConstScoreQuery`,
#                                      `query::EmptyQuery`,
#                                      `query::AllQuery`,
#                                      `query::ExistsQuery`,
#                                      `query::RegexQuery`,
#                                      `query::MoreLikeThisQuery`,
#                                      `query::QueryParser`
#                                      (the typed Lucene-style
#                                      query-string parser)
#     тАв Typed collector framework      typed `collector::Collector`
#                                      trait + concrete typed
#                                      `collector::TopDocs`,
#                                      `collector::Count`,
#                                      `collector::FacetCollector`,
#                                      `collector::FilterCollector`,
#                                      `collector::MultiCollector`,
#                                      `collector::HistogramCollector`,
#                                      `collector::CustomScoreTopCollector`,
#                                      `collector::DocSetCollector`
#     тАв Typed tokenizer framework      typed `tokenizer::Tokenizer`
#                                      trait + concrete typed
#                                      `tokenizer::SimpleTokenizer`,
#                                      `tokenizer::WhitespaceTokenizer`,
#                                      `tokenizer::NgramTokenizer`,
#                                      `tokenizer::FacetTokenizer`,
#                                      `tokenizer::RawTokenizer`,
#                                      `tokenizer::Tokenizer`
#                                      filter chain with typed
