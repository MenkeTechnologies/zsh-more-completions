#                                      range-filter at search
#                                      time (the Lucene
#                                      DocValues equivalent)
#     тАв Typed segment writer + merge
#       policy                         typed
#                                      `merge_policy::MergePolicy`
#                                      + concrete typed
#                                      `LogMergePolicy`,
#                                      `NoMergePolicy`,
#                                      `DefaultMergePolicy`
#     тАв Typed bit-packed integer
#       compression (`tantivy-bitpacker`)
#                                      typed PFOR / FOR-delta
#                                      compression for the
#                                      posting-list integer
#                                      streams
#     тАв Typed memory-mapped IO layer
#       (`tantivy-common` + the typed
#       `tantivy::directory` module
#       with `MmapDirectory` /
#       `RamDirectory` /
#       `ManagedDirectory`)
#     тАв Typed near-real-time (NRT)
#       reload + commit
#     тАв Typed transactional commit
#       (atomic writer-state flush
#       with typed lock files)
#     тАв Typed garbage-collection of
#       obsolete segments
#     тАв Typed snapshot / restore for
#       index directories
#     тАв Typed parallel-segment
#       multi-threaded search
#       (`Searcher::search_with_executor`)
#
#   tantivy is the inverted-index library behind essentially
#   every modern Rust-based search system:
#
#     тАв **Quickwit** (quickwit-oss/quickwit, 8,800+ тШЕ) тАФ the
#       cloud-native log-analytics + observability search
#       engine;  same parent organization as tantivy itself
#     тАв **Meilisearch** (meilisearch/meilisearch, 50,000+ тШЕ)
#       тАФ the developer-friendly typo-tolerant search engine
#       (wraps tantivy via a wrapper layer + own typo-tolerance
#       layer);  fork-relationship is the most-debated tantivy
#       lineage point but the kernel is tantivy-derived
#     тАв **Toshi** (toshi-search/Toshi) тАФ Elasticsearch-shaped
#       HTTP API on tantivy with Raft replication
#     тАв **Bayard** (this very project) тАФ distributed
#       tantivy with SWIM gossip + Raft
#     тАв **Sonic** тАФ Valeurian's lightweight search backend
#     тАв **Atomic-Server** (ontola/atomic-server) тАФ Atomic Data
#       persistence with tantivy search
#     тАв **Pathway** тАФ Pathway Inc.'s streaming data-processing
#       engine
#     тАв **databend** (databendlabs/databend, 8,500+ тШЕ) тАФ cloud
#       data-warehouse (uses tantivy for inverted indexes
#       inside its storage engine)
#     тАв **Trieve** (devflowinc/trieve) тАФ RAG-as-a-service for
#       LLM applications
#     тАв **Chroma** (chroma-core/chroma) тАФ the vector database
#       (uses tantivy in the metadata-filtering layer)
#     тАв **TiFlash** (PingCAP, 1,200+ тШЕ) тАФ TiDB's columnar
#       storage engine
#     тАв **TabbyML/tabby** тАФ AI coding assistant (tantivy for
#       code-search backend)
#     тАв **OkuBrowser/oku** тАФ the P2P web browser (tantivy for
#       local history + bookmark search)
#     тАв **windmill-labs/windmill** тАФ the workflow engine
#     тАв **Memvid** тАФ the long-context video-as-memory project
#     тАв **Fuzzy_ruby_server** тАФ Ruby LSP server's symbol search
#     тАв **Pollinations.ai/polly** тАФ the generative-AI API
#       gateway
#     тАв Plus thousands of internal Rust search-backed apps,
#       Rust-embedded mobile / desktop apps with full-text
#       indexes, and Rust-native logging/observability
#       pipelines.
#
#   The tantivy project is structurally significant because it
#   was the **first mature pure-Rust Lucene-equivalent** тАФ every
#   prior Rust attempt at a search engine either:
#     (a) wrapped Lucene via JNI (defeats the purpose of using
#         Rust),
#     (b) bound C/C++ libraries via FFI (CLucene, Xapian тАФ the
#         unsafe-FFI tax + complicated build dep),
#     (c) implemented a toy inverted index that didn't scale
#         past a few million documents.
#   tantivy was the first that matched Lucene feature-for-
#   feature on the index + query path (BM25, phrase queries,
#   regex, fuzzy, faceting, NRT, columnar fast fields) while
#   delivering measurably faster indexing throughput (~2-5├Ч)
#   and lower memory overhead per document.
#
#   Verified via:
#     gh api repos/mosuka/bayard/contents/bayard/Cargo.toml
#       тЖТ name = "bayard"
#       тЖТ [[bin]] name = "bayard" path = "src/main.rs"
#       тЖТ tantivy = "0.18.0"  (DIRECT)
#       тЖТ lindera-tantivy = { version = "0.16.2",
#                              features = ["ipadic", "ko-dic",
#                                          "cc-cedict"] }
#       тЖТ clap = { version = "4.0.12", features = ["derive"] }
#       тЖТ foca = { version = "0.4.1",
#                  features = ["postcard-codec"] }
#       тЖТ axum = "0.5.16"
#     raw.githubusercontent.com mosuka/bayard main bayard/src/main.rs
#       тЖТ use clap::Parser;
#       тЖТ #[derive(Parser, Debug)] #[clap(version, about, ...)]
#         struct Args { bind_address, advertise_address,
#                       seed_address, grpc_address,
#                       http_address, data_directory }
#       тЖТ #[clap(short = 'b', long = "bind-address",
#                default_value = "0.0.0.0:2000", ...)]
#       тЖТ #[clap(short = 'a', long = "advertise-address", ...)]
#       тЖТ #[clap(short = 's', long = "seed-address", ...)]
#       тЖТ #[clap(short = 'g', long = "grpc-address",
#                default_value = "0.0.0.0:5000", ...)]
#       тЖТ #[clap(short = 'H', long = "http-address",
#                default_value = "0.0.0.0:8000", ...)]
#       тЖТ #[clap(short = 'd', long = "data-directory",
#                default_value = "/tmp/bayard", ...)]
#
#   This entry is the Rust=181 leader bump that **OPENS** Axis 126
#   (pure-Rust full-text search / Lucene-equivalent inverted-
#   index engine / tantivy ecosystem) at 1/0/0 following R1075
#   _gitvan (TS-Node=180 CLOSED Axis 125 pure-Rust+Go+JS Git
#   implementations at 1/1/1 with triple-180 landmark + 118th
#   axis closed).  R1077 on deck: Go=181 continues Axis 126 via
#   a Go consumer of a canonical Go full-text search library
#   (the natural pick is `blevesearch/bleve` тАФ the dominant
#   Go-side inverted-index library, the Lucene-equivalent for
#   Go, used by Couchbase / Hugo / many indexing tools).
#
#   No completion for `bayard` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) тАФ confirmed absent.
# ============================================================================

_bayard() {
    _arguments -s -S \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-b --bind-address)'{-b,--bind-address}'=[internal cluster bind address (default 0.0.0.0:2000)]:addr:' \
        '(-a --advertise-address)'{-a,--advertise-address}'=[advertise address to gossip peers (defaults to bind address)]:addr:' \
        '(-s --seed-address)'{-s,--seed-address}'=[seed bootstrap-peer address for joining cluster]:addr:' \
        '(-g --grpc-address)'{-g,--grpc-address}'=[gRPC bind address (default 0.0.0.0:5000)]:addr:' \
        '(-H --http-address)'{-H,--http-address}'=[HTTP REST bind address (default 0.0.0.0:8000)]:addr:' \
        '(-d --data-directory)'{-d,--data-directory}'=[node data directory (default /tmp/bayard)]:dir:_files -/'
}

_bayard "$@"
