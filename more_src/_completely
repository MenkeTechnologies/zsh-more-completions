#compdef completely
# Documentation: https://github.com/DannyBen/completely
# completely: generate bash completion scripts from a YAML config

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)--help[display help information]' \
  '(- *)--version[show version information]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'completely command' \
      'init[generate a sample completely.yaml config file]' \
      'generate[produce the bash completion script from config]' \
      'preview[display the generated script without saving it]' \
      'test[test completions with the built-in tester]' \
      'install[copy the generated script to the bash completions dir]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--nested[create example using the nested syntax]' \
          '*:file:_files' && ret=0
        ;;
      generate|preview|test|install)
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
