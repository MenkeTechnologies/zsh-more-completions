#compdef butterfish
# Documentation: https://github.com/bakks/butterfish
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bakks/butterfish — AI shell wrapper with LLM-assisted commands.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'shell:Start AI shell wrapper'
  'prompt:Send a direct prompt to LLM'
  'gencmd:Generate shell command from prompt'
  'exec:Run command and suggest fix on failure'
  'summarize:Generate summary of file or directory'
  'index:Create embeddings for a directory'
  'indexsearch:Search indexed files semantically'
)

_arguments -s -S \
  '*'{-v,--verbose}'[enable verbose output (repeatable for -vv)]' \
  '(-L --log)'{-L,--log}'[write logs to file]:file:_files' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-u --base-url)'{-u,--base-url}'[set OpenAI-compatible API base URL]:url:_urls' \
  '(-m --model)'{-m,--model}'[specify LLM model]:model:' \
  '(-r --reasoning-effort)'{-r,--reasoning-effort}'[reasoning effort level]:effort:(low medium high)' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'butterfish command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (shell)
        _arguments -s -S \
          '-A[disable shell autosuggest]' \
          '-t[autosuggest timeout (ms)]:ms:' \
          '(-b --bin)'{-b,--bin}'[shell binary]:path:_files' && ret=0
        ;;
      (gencmd)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[execute immediately]' \
          '1:prompt:' && ret=0
        ;;
      (summarize|index|indexsearch)
        _arguments -s -S '1:path:_files' && ret=0
        ;;
      (prompt|exec)
        _arguments -s -S '1:query:' && ret=0
        ;;
    esac
    ;;
esac

return ret
