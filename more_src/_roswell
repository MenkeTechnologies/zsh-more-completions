#compdef ros

# Zsh completion for Roswell - Common Lisp environment manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-w+[set warning level]:level' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-Q[quiet output]' \
  '--quiet[quiet output]' \
  '-L+[use specified lisp implementation]:impl:(sbcl ccl ecl abcl clisp clasp cmucl)' \
  '--lisp=[use specified lisp implementation]:impl:(sbcl ccl ecl abcl clisp clasp cmucl)' \
  '-l+[load file]:file:_files -g "*.lisp"' \
  '--load=[load file]:file:_files -g "*.lisp"' \
  '-S+[source registry override]:path:_directories' \
  '--source-registry=[source registry override]:path:_directories' \
  '-s+[load system]:system' \
  '--system=[load system]:system' \
  '-e+[evaluate form]:form' \
  '--eval=[evaluate form]:form' \
  '-p+[load system and change package]:package' \
  '--package=[load system and change package]:package' \
  '-r[restart]:restart' \
  '--restart=[restart]:restart' \
  '-E+[entry function]:function' \
  '--entry=[entry function]:function' \
  '-i+[init file]:file:_files' \
  '--init=[init file]:file:_files' \
  '-q[quit after initialization]' \
  '--quit[quit after initialization]' \
  '-R[run REPL]' \
  '--restart=[run REPL]:mode' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'install:install a Lisp implementation or system'
      'use:set default Lisp implementation'
      'list:list installed implementations'
      'run:run a Lisp script'
      'build:build a system'
      'init:create a Roswell script'
      'dump:dump a Lisp image'
      'delete:delete an installed implementation'
      'config:manage configuration'
      'setup:setup Roswell'
      'update:update Roswell'
      'emacs:setup SLIME for Emacs'
      'wait:wait for async install to complete'
      'template:manage script templates'
      'which:show implementation path'
      'exec:execute a Roswell script'
      'fmt:format Lisp source code'
    )
    _describe -t commands 'ros command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:implementation or system' && ret=0
        ;;
      use)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:implementation:(sbcl ccl ecl abcl clisp clasp cmucl)' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:script:_files -g "*.{ros,lisp}"' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:script name' && ret=0
        ;;
      dump)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:dump type:(output executable)' && ret=0
        ;;
    esac
    ;;
esac

return ret
