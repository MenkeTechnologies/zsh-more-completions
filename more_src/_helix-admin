#compdef helix-admin helix-admin.sh

_arguments -s \
  '(- *)--help[show help]' \
  '--zkSvr=[ZooKeeper server address]:addr:' \
  '--activateCluster[activate a cluster]' \
  '--addCluster[add a cluster]' \
  '--addIdealState[add ideal state for a resource]' \
  '--addInstanceTag[add instance tag]' \
  '--addNode[add a node to a cluster]' \
  '--addResource[add a resource to a cluster]' \
  '--addResourceProperty[add resource property]' \
  '--addStateModelDef[add state model definition]' \
  '--dropCluster[drop a cluster]' \
  '--dropNode[drop a node]' \
  '--dropResource[drop a resource]' \
  '--enableCluster[enable cluster]' \
  '--enableInstance[enable instance]' \
  '--enablePartition[enable partition]' \
  '--getConfig[get configuration]' \
  '--getConstraints[get constraints]' \
  '--instanceGroupTag[set instance group tag]' \
  '--listClusterInfo[list cluster info]' \
  '--listClusters[list clusters]' \
  '--listInstanceInfo[list instance info]' \
  '--listInstances[list instances]' \
  '--listPartitionInfo[list partition info]' \
  '--listResourceInfo[list resource info]' \
  '--listResources[list resources]' \
  '--listStateModel[list state model]' \
  '--listStateModels[list state models]' \
  '--maxPartitionsPerNode[set max partitions per node]' \
  '--rebalance[rebalance a resource]' \
  '--removeConfig[remove configuration]' \
  '--removeConstraint[remove constraint]' \
  '--removeInstanceTag[remove instance tag]' \
  '--removeResourceProperty[remove resource property]' \
  '--resetInstance[reset instance state]' \
  '--resetPartition[reset partition state]' \
  '--resetResource[reset resource state]' \
  '--setConfig[set configuration]' \
  '--setConstraint[set constraint]' \
  '--swapInstance[swap instance]' \
  '*:arg:'
