#compdef polars-cli polars
# Documentation: https://github.com/pola-rs/polars-cli
# Documentation: https://github.com/pola-rs/polars-cli/blob/main/src/main.rs
# Reference accessed: 2026-05-27
# Verified: upstream pola-rs/polars-cli src/main.rs clap derive Args struct (short = 'c', short = 'o').

local -a _polars_cli_output_modes
_polars_cli_output_modes=(csv json parquet arrow table markdown md)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '-c[execute COMMAND and exit]:command:' \
  '-o[set output mode (default: table)]:mode:('"${_polars_cli_output_modes[*]}"')' \
  '1:query:'
