#compdef rivet-cmphistos
# Documentation: https://rivet.hepforge.org/
# rivet-cmphistos - prepare comparison .dat plot files from YODA inputs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --outdir)'{-o,--outdir}'[write data files into this directory]:dir:_files -/' \
  '--hier-out[write output dat files into a directory hierarchy matching analysis paths]' \
  '--plotinfodir[directory that may contain plot header information]:dir:_files -/' \
  '--no-rivet-refs[do not use Rivet reference data files]' \
  '--reftitle[reference data legend entry]:title:' \
  '--pwd[append current directory to analysis/data search paths]' \
  '(-v --verbose)'{-v,--verbose}'[produce debug output to the terminal]' \
  '--linear[plot with linear scale]' \
  '(--errs --mcerrs --mc-errs)'{--errs,--mcerrs,--mc-errs}'[show vertical error bars on the MC lines]' \
  '--no-ratio[disable the ratio plot]' \
  '--rel-ratio[show the ratio plots scaled to the ref error]' \
  '--no-plottitle[do not show the plot title on the plot]' \
  '--style[change plotting style]:style:(default bw talk)' \
  '*'{-c,--config}'[additional plot config file(s)]:file:_files' \
  '--remove-options[remove options label from legend]' \
  '*'{-m,--match}'[only write histograms whose path/name matches regexes]:regex:' \
  '*'{-M,--unmatch}'[exclude histograms whose path/name matches regexes]:regex:' \
  '*:yodafile:_files' && ret=0

return ret
