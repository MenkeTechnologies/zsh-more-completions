#compdef asbench
# Documentation: https://aerospike.com/docs/database/tools/asbench/
# asbench - Aerospike benchmark tool

local ret=1

_arguments -s -S \
  '(-h --hosts)'{-h,--hosts}'=[seed hosts list HOST:TLSNAME:PORT]:hosts:' \
  '(-p --port)'{-p,--port}'=[connection port]:port:' \
  '(-U --user)'{-U,--user}'=[username for authentication]:user:' \
  '-P[prompt for password]' \
  '--auth=[authentication mode]:mode:(INTERNAL EXTERNAL EXTERNAL_INSECURE PKI)' \
  '--services-alternate[use alternate-access-address]' \
  '(-tls --tls-enable)'{-tls,--tls-enable}'[enable TLS sockets]' \
  '--tls-cafile=[trusted CA certificate file]:file:_files' \
  '--tls-capath=[directory of trusted CA certificates]:dir:_files -/' \
  '--tls-name=[TLS name for socket authentication]:name:' \
  '--tls-protocols=[TLS protocol selection]:protocols:' \
  '--tls-cipher-suite=[cipher selection criteria]:suite:' \
  '--tls-keyfile=[key for mutual authentication]:file:_files' \
  '--tls-certfile=[chain file for mutual authentication]:file:_files' \
  '(-n --namespace)'{-n,--namespace}'=[namespace]:namespace:' \
  '(-s --set)'{-s,--set}'=[set name]:set:' \
  '(-b --bin)'{-b,--bin}'=[base bin name]:bin:' \
  '(-K --start-key)'{-K,--start-key}'=[starting key value]:key:' \
  '(-k --keys)'{-k,--keys}'=[number of keys]:count:' \
  '(-o --object-spec)'{-o,--object-spec}'=[bin specifications]:spec:' \
  '(-e --expiration-time)'{-e,--expiration-time}'=[record TTL in seconds]:ttl:' \
  '(-w --workload)'{-w,--workload}'=[workload type]:type:' \
  '(-t --duration)'{-t,--duration}'=[benchmark duration]:seconds:' \
  '(-g --throughput)'{-g,--throughput}'=[max transactions per second]:tps:' \
  '--batch-size=[records per batch call]:size:' \
  '--batch-read-size=[records per batch read]:size:' \
  '--batch-write-size=[records per batch write]:size:' \
  '--workload-stages=[YAML file with workload stages]:file:_files' \
  '(-z --threads)'{-z,--threads}'=[synchronous threads]:count:' \
  '(-W --event-loops)'{-W,--event-loops}'=[event loops for async mode]:count:' \
  '(-c --async-max-commands)'{-c,--async-max-commands}'=[concurrent async commands]:count:' \
  '(-a --async)'{-a,--async}'[enable asynchronous mode]' \
  '(-R --random)'{-R,--random}'[generate random bin values per write]' \
  '--read-bins=[bins to read]:bins:' \
  '--write-bins=[bins to write]:bins:' \
  '(-C --replica)'{-C,--replica}'=[replica policy]:type:(master any sequence preferRack)' \
  '(-N --read-mode-ap)'{-N,--read-mode-ap}'=[AP namespace read mode]:mode:(one all)' \
  '(-B --read-mode-sc)'{-B,--read-mode-sc}'=[SC read mode]:mode:(session linearize allowReplica allowUnavailable)' \
  '(-M --commit-level)'{-M,--commit-level}'=[write guarantee level]:level:(all master)' \
  '--socket-timeout=[read/write socket timeout ms]:ms:' \
  '--read-socket-timeout=[read socket timeout ms]:ms:' \
  '--write-socket-timeout=[write socket timeout ms]:ms:' \
  '(-T --timeout)'{-T,--timeout}'=[total read/write timeout ms]:ms:' \
  '--max-retries=[maximum retries before abort]:count:' \
  '(-L --latency)'{-L,--latency}'[enable HDR histogram summary]' \
  '--output-file=[latency histogram output file]:file:_files' \
  '--hdr-hist=[HDR histogram output directory]:dir:_files -/' \
  '--percentiles=[percentiles to display]:list:' \
  '--output-period=[snapshot interval seconds]:seconds:' \
  '(-upn --udf-package-name)'{-upn,--udf-package-name}'=[UDF package name]:name:' \
  '(-ufn --udf-function-name)'{-ufn,--udf-function-name}'=[UDF function name]:name:' \
  '(-ufv --udf-function-values)'{-ufv,--udf-function-values}'=[UDF function arguments]:spec:' \
  '--compress[enable binary data compression]' \
  '--send-key[send key with key digest]' \
  '--durable-delete[set durable-delete flag on deletes]' \
  '(-d --debug)'{-d,--debug}'[run in debug mode]' \
  '(-V --version)'{-V,--version}'[print asbench version]' \
  '--help[display all supported options]' && ret=0

return ret
