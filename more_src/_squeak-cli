# upstream: https://squeak.org/

_squeak-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-headless[headless mode]' \
        '--headless[headless mode]' \
        '-vm-display=+[d]:d:(null x11 fbdev quartz Cocoa cocoa Mesa OffscreenMesa OSMesa)' \
        '--vm-display=+[d]:d:(null x11 fbdev quartz Cocoa cocoa Mesa OffscreenMesa OSMesa)' \
        '-vm-display-null[null display]' \
        '-vm-sound=+[s]:s:(null alsa oss pulse jack macosx win)' \
        '--vm-sound=+[s]:s:(null alsa oss pulse jack macosx win)' \
        '-vm-sound-null[null sound]' \
        '-vm-debug[VM debug]' \
        '--vm-debug[VM debug]' \
        '-vm-version[VM version]' \
        '--vm-version[VM version]' \
        '-vm-vmlibdir=+[dir]:dir:_files -/' \
        '-vm-encoding=+[enc]:str:' \
        '-memory=+[N]:n:' \
        '--memory=+[N]:n:' \
        '-image=+[file]:file:_files -g "*.image"' \
        '-script[treat as script]' \
        '-noevents[no events]' \
        '-noxshm[no XShm]' \
        '-nointl[no intl]' \
        '-nohandlers[no handlers]' \
        '--no-handlers[no handlers]' \
        '-mmap=+[N]:n:' \
        '-eden=+[N]:n:' \
        '-leakcheck=+[N]:n:' \
        '-checkpluginwrites[check plugin writes]' \
        '-grabkeyboard[grab keyboard]' \
        '-grabpointer[grab pointer]' \
        '-nosound[no sound]' \
        '-encoding=+[enc]:str:' \
        '-charwidth=+[N]:n:' \
        '-evallog[eval log]' \
        '-headfull[head full]' \
        '-codesize=+[N]:n:' \
        '-stackpages=+[N]:n:' \
        '-numextrasemroots=+[N]:n:' \
        '-edenSize=+[N]:n:' \
        '-eventBufferSize=+[N]:n:' \
        '-jitInputDataPath=+[dir]:dir:_files -/' \
        '-image-name=+[name]:str:' \
        '-trace=+[file]:file:_files' \
        '-warnpid=+[N]:n:' \
        '-warnAlmostFull[warn almost full]' \
        '*:image file:_files -g "*.image *.changes *.st *.sources"'
}

_squeak-cli "$@"
