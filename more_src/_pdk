#compdef pdk

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'new:create new module/class/task/etc.'
  'build:build module artifact'
  'console:start an interactive Puppet console'
  'convert:convert an existing module to PDK'
  'env:activate the PDK env shell'
  'get:get a config value'
  'module:legacy module subcommands'
  'release:prepare and publish a release'
  'remove:remove config'
  'set:set a config value'
  'test:run module tests'
  'update:update template files in a module'
  'validate:validate the module'
  'completion:emit shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '--answer-file=[answer file path]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pdk subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (new)
        _values 'new target' \
          'module' 'class' 'defined_type' 'fact' 'function' 'task' \
          'test' 'provider' 'transport' 'role' 'profile' && ret=0
        ;;
      (get|set|remove)
        _values 'object' 'config' && ret=0
        ;;
      (test)
        _arguments \
          '--list[list available tests]' \
          '--tests=[tests to run]:tests:' \
          '--format=[format[:target]]:format:' \
          '--puppet-version=[Puppet version]:version:' \
          '--pe-version=[Puppet Enterprise version]:version:' \
          '--puppet-dev[use development Puppet]' \
          '--clean-fixtures[clean fixtures]' \
          '--verbose[verbose output]' \
          '--parallel[parallel execution]' \
          ':target:(unit)' && ret=0
        ;;
      (validate)
        _arguments \
          '--list[list validators]' \
          '--format=[format[:target]]:format:' \
          '--auto-correct[auto-correct issues]' \
          '--parallel[parallel validation]' \
          '--puppet-version=[Puppet version]:version:' \
          '--pe-version=[Puppet Enterprise version]:version:' \
          '--puppet-dev[use development Puppet]' && ret=0
        ;;
      (build)
        _arguments \
          '--target-dir=[output directory]:dir:_files -/' \
          '--force[overwrite existing artifact]' && ret=0
        ;;
      (convert|update)
        _arguments \
          '--noop[no-op]' \
          '--force[force]' \
          '--template-url=[git URL of template]:url:' \
          '--template-ref=[template ref]:ref:' \
          '--skip-interview[skip interview]' \
          '--full-interview[full interview]' \
          '--add-tests[add test scaffolding]' \
          '--default-template[use default template]' && ret=0
        ;;
      (release)
        _values 'release action' 'prepare' 'publish' && ret=0
        ;;
      (module)
        _values 'module action' 'generate' 'build' 'install' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
