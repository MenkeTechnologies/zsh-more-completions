#compdef jdc
# Documentation: https://docs.jdcloud.com/en/cli/usage
# JD Cloud Command Line Interface

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '--debug[enable debug mode]' \
  '--region-id=[region identifier]:region' \
  '--scheme=[request scheme]:scheme:(http https)' \
  '--timeout=[request timeout in seconds]:seconds' \
  '*:command:((configure\:"manage credential and connection profiles" vm\:"virtual machine" disk\:"cloud disk" vpc\:"VPC network" lb\:"load balancer" rds\:"relational database" redis\:"cloud cache Redis" mongodb\:"cloud database MongoDB" oss\:"object storage" cdn\:"content delivery network" kubernetes\:"managed Kubernetes" nativecontainer\:"native container" pod\:"container pod" kms\:"key management service" iam\:"identity and access management" monitor\:"cloud monitor" billing\:"billing" sts\:"security token service" domainservice\:"domain service" clouddnsservice\:"cloud DNS service" ssl\:"SSL certificates" containerregistry\:"container registry"))' && ret=0

return ret
