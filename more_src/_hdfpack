#compdef hdfpack
# Documentation: https://manpages.debian.org/testing/hdf4-tools/hdfpack.1.en.html
# Compact (pack) the data in an HDF file

local ret=1

_arguments -s \
  '(-i -b)-b[non-coalesced blocks, do not coalesce linked-block elements]' \
  '(-i -b)-i[interactive mode, prompt for each linked-block element]' \
  '-d+[data descriptors per block]:num' \
  '-t+[linked blocks per table entry]:num' \
  '1:input hdf file:_files -g "*.(hdf|h4)"' \
  '2:output hdf file:_files -g "*.(hdf|h4)"' && ret=0

return ret
