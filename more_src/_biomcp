#
# `serve-http` flags:
#       --host <host>              - HTTP
#                                     bind
#                                     host
#                                     (default
#                                     127.0.0.1)
#       --port <port>              - HTTP
#                                     bind
#                                     port
#                                     (default
#                                     8080)
#
# Example invocations:
#   # Search for genes
#   biomcp search gene BRCA1
#
#   # Get a specific gene by ID
#   biomcp get gene BRCA1
#
#   # Variant normalization across multiple
#   # variant databases
#   biomcp variant normalize all \
#     NM_000248.3:c.135del
#   biomcp variant normalize variantvalidator \
#     NM_004448.2:c.829G>T
#
#   # Find clinical trials for a variant
#   biomcp variant trials "BRAF V600E" \
#     --limit 5
#
#   # Run as MCP server over stdio (for
#   # Claude Desktop integration)
#   biomcp mcp
#     # or equivalently:
#     # biomcp serve
#
#   # Run as HTTP MCP server (axum-based)
#   biomcp serve-http \
#     --host 0.0.0.0 \
#     --port 8080
#     # Endpoints:
#     #   POST /mcp - MCP Streamable HTTP
#     #   GET /health - health check
#     #   GET /readyz - readiness probe
#     #   GET / - landing page
#
#   # Sync local EMA data
#   biomcp ema sync
#
#   # Sync local WHO prequalification data
#   biomcp who sync
#
#   # Sync DDInter drug interaction CSVs
#   biomcp ddinter sync
#
#   # Check API connectivity
#   biomcp health
#
#   # Discover available entity types
#   biomcp discover
#
#   # Update biomcp binary + data bundles
#   biomcp update
#
#   # Install biomcp skill into Claude
#   # Code agent
#   biomcp skill install
#
# Claude Desktop MCP configuration
# (~/.config/claude/claude_desktop_config.json):
#   ```json
#   {
#     "mcpServers": {
#       "biomcp": {
#         "command": "biomcp",
#         "args": ["mcp"]
#       }
#     }
#   }
#   ```
#
# The axum lane is built on `axum = {
# version = "0.8.1", default-features = false,
# features = ["tokio", "http1", "json"] }`
# (declared verbatim at upstream Cargo.toml
# HEAD as a direct dep, imported by the
# serve-http MCP server implementation +
# the /health + /readyz routes + the
# MCP Streamable HTTP protocol endpoint
# at /mcp), the canonical Rust HTTP web
# framework by Lucio Franco + the
# tokio-rs team - github.com/tokio-rs/axum.
#
# tokio-rs/axum is the de-facto canonical
# Rust HTTP web framework:
#   - **Built on hyper + tokio + tower**
#     (the canonical Rust async HTTP
#     stack; axum is the high-level
#     framework layer on top)
#   - **Type-safe extractors** (the
#     idiomatic axum pattern: function
#     signatures use extractors for
#     query params + JSON bodies +
#     state + ...; compile-time route
#     validation)
#   - **Tower middleware integration**
#     (the canonical Rust middleware
#     framework; CORS + tracing + rate
#     limiting + compression via tower-
#     http)
#   - **Async-first** (tokio runtime;
#     non-blocking handler functions)
#   - **WebSocket + HTTP/2 + SSE
#     support** (built-in support for
#     streaming protocols beyond plain
#     HTTP/1.1)
#   - **20,000+ stars on github.com/
#     tokio-rs/axum**
#   - **~10,000 reverse-deps on
#     crates.io** (the canonical Rust
#     web framework after the rise of
#     async-Rust)
#
# axum's distinguishing position vs Rust
# web framework alternatives:
#   - tokio-rs/axum (Franco + tokio-rs):
#     canonical; type-safe extractors;
#     tokio-native; THIS AXIS
#   - actix-web (actix/actix-web):
#     older mature framework;
#     actor-based; high performance;
#     pre-dates axum
#   - rocket (SergioBenitez/Rocket):
#     macro-heavy DSL framework;
#     elegant syntax but heavier
#     compile times
#   - warp (seanmonstar/warp): filter-
#     combinator framework by Sean
#     McArthur; functional style;
#     pre-dates axum
#   - poem (poem-web/poem): newer
#     framework; openapi-first;
#     smaller adoption
#   - salvo (salvo-rs/salvo): newer
#     framework with handler-style
#     API; smaller adoption
#
# Lucio Franco is the co-creator of axum +
# tonic + a long-time tokio-rs
# maintainer. His broader Rust ecosystem
# footprint:
#   - **tokio-rs/axum** (THIS AXIS;
#     canonical Rust HTTP framework)
#   - **tokio-rs/tonic** (canonical Rust
#     gRPC implementation; Axis 276 Rust
#     opener via _ztunnel earlier in
#     corpus)
#   - **tokio-rs/prost** (canonical Rust
#     Protocol Buffers library; Axis 279
#     Rust opener via _ztunnel)
#   - **hyperium maintenance** (the
#     foundational hyper HTTP stack
#     that axum builds on)
#
# Franco's role in Rust is *canonical
# protocol-layer infrastructure* spanning
# HTTP + gRPC + protobuf. His libraries
# form the canonical Rust async HTTP
# stack:
#   - tokio (async runtime)
#   - hyper (HTTP/1.1 + HTTP/2 primitive)
#   - h2 (HTTP/2 primitive)
#   - tonic (gRPC client+server)
#   - prost (protobuf wire encoding)
#   - axum (HTTP framework layer)
#   - bytes (zero-copy byte buffer)
#   - tower (middleware composition)
# All maintained under the tokio-rs org
# with Franco as a major contributor
# across the stack.
#
# Franco is one of the very few
# individual contributors who appears
# as a canonical-author for MULTIPLE
# axes in the corpus (Axis 274 hyper +
# Axis 275 h2 + Axis 276 tonic + Axis
# 279 prost + Axis 288 axum). His
# multi-axis canonical-author presence
# is the highest documented in the
# corpus by any individual contributor.
#
# Multi-axis canonical-Rust author/org
# cohort consolidation (Franco joining
# at THIS AXIS):
#   - Lucio Franco + tokio-rs org
#     (axum + tonic + prost + hyper +
#     h2 maintenance) - 5+ canonical
#     library lanes across Axes 274 +
#     275 + 276 + 279 + 288
#
# Franco's foundational protocol-layer
# canonical-author presence across
# multiple axes is the strongest
# documented example of *single-person
# cross-axis canonical-author
# concentration* in the corpus.
#
# biomcp uses axum for:
#   - The MCP Streamable HTTP server at
#     /mcp endpoint (serves AI agent
#     requests via the MCP protocol over
#     HTTP)
#   - Health + readiness check endpoints
#     (/health + /readyz for Kubernetes
#     liveness/readiness probes)
#   - Landing page at / (basic info +
#     documentation links)
#   - JSON request/response handling
#     (via axum's Json extractor +
#     IntoResponse)
#
# This is the canonical use case for
# axum in production Rust services:
# high-throughput HTTP API server with
# JSON request/response handling + health
# check endpoints + Kubernetes-friendly
# deployment patterns.
#
# ----------------------------------------------------------------------------
# AXIS 288 :: HTTP web frameworks
#              (high-level HTTP server
#              frameworks built on async
#              I/O primitives; routing +
#              middleware + extractors +
#              request/response handling)
# Round 1562 :: Rust slot 1 of 4 :: OPENS Axis 288
#
# Cross-language canonical library family
# for this axis (proposed):
#   Rust    : tokio-rs/axum             - Lucio
#                                          Franco +
#                                          tokio-rs
#                                          (canonical
#                                          Rust HTTP
#                                          framework;
#                                          type-safe
#                                          extractors)
#   Go      : gin-gonic/gin              - Manu
#                                          Mart
#                                          Esteve
#                                          (canonical
#                                          Go HTTP
#                                          framework;
#                                          ~80,000
#                                          stars;
#                                          de-facto
#                                          Go web
#                                          framework)
#   TS/Node : expressjs/express          - TJ
#                                          Holowaychuk
#                                          + Express
#                                          team
#                                          (canonical
#                                          Node HTTP
#                                          framework;
#                                          THE
#                                          original
#                                          framework
#                                          that
#                                          shaped Node
#                                          web
#                                          ecosystem)
#
# HTTP web frameworks are the *highest-
# level abstraction over HTTP I/O* in each
# language ecosystem - bridging raw socket
# handling to application-level request/
# response handlers. Each language's
# canonical framework has shaped its
# web ecosystem's idioms.
#
# Each canonical library provides:
#   - HTTP request routing (path patterns
#     + method matching)
#   - Middleware composition (request +
#     response transformation chains)
#   - Request body parsing (JSON + form +
#     multipart)
#   - Response serialization (JSON +
#     templating + streaming)
#   - WebSocket + Server-Sent Events
#     support (varies by framework)
#   - Type-safe handler signatures (Rust
#     axum's extractor pattern is
#     distinctive; Go gin uses context
#     + binding; Node Express uses
#     middleware (req, res, next)
#     pattern)
#
# Use-case spectrum for this axis (so far):
#   - biomcp (Rust, axum): biomedical AI
#     agent MCP server + REST API for
#     gene + variant + drug + clinical
#     trial queries
# ============================================================================

_biomcp() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_biomcp_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                serve-http)
                    _arguments \
                        '--host=[HTTP bind host]:host:_hosts' \
                        '--port=[HTTP bind port]:port:'
                    ;;
                search)
                    _arguments \
                        '1: :(all gene drug trial article disease variant pathway protein adverse-event)' \
                        '*::search-arg:'
                    ;;
                get)
                    _arguments \
                        '1: :(gene drug trial article disease variant pathway protein)' \
                        '*::get-arg:'
                    ;;
                variant)
                    _arguments \
                        '1: :(normalize trials annotate)' \
                        '*::variant-arg:'
                    ;;
                ema|who|who-ivd|cvx|ddinter|gtr)
                    _arguments \
                        '1: :(sync status info)' \
                        '*::data-arg:'
                    ;;
                cache)
                    _arguments \
                        '1: :(info clear list)' \
                        '*::cache-arg:'
                    ;;
                skill)
                    _arguments \
                        '1: :(install render show)' \
                        '*::skill-arg:'
                    ;;
                chart)
                    _arguments \
                        '1: :(list show)' \
                        '*::chart-arg:'
                    ;;
            esac
            ;;
    esac

    return ret
}

_biomcp_cmds() {
    local -a cmds
    cmds=(
        'mcp:run MCP server over stdio (Claude Desktop integration)'
        'serve:alias for mcp'
        'serve-http:run MCP Streamable HTTP server at /mcp (axum-based)'
        'search:search for entities (gene + drug + trial + article + ...)'
        'get:get entity by ID'
        'article:article cross-entity helpers'
        'variant:variant cross-entity helpers (normalize + trials)'
        'drug:drug cross-entity helpers'
        'gene:gene cross-entity helpers'
        'disease:disease cross-entity helpers'
        'pathway:pathway cross-entity helpers'
        'protein:protein cross-entity helpers'
        'study:local cBioPortal study analytics'
        'ema:EMA local data management'
        'who:WHO Prequalification local data management'
        'who-ivd:WHO Prequalified IVD local data management'
        'cvx:CDC CVX/MVX vaccine identity local data management'
        'ddinter:DDInter local interaction data management'
        'gtr:NCBI GTR local data management'
        'cache:inspect managed HTTP cache'
        'list:list available entities/commands'
        'discover:discover entity types + available fields'
        'health:check external API connectivity'
        'chart:chart type documentation for study visualizations'
        'skill:BioMCP skill overview + installer for agents'
        'update:update biomcp binary + bundled data'
    )
    _describe -t commands 'biomcp command' cmds
}

_biomcp "$@"
