#compdef showrecipes
# Documentation: https://dragons.readthedocs.io/projects/recipe-system-users-manual/en/stable/supptools.html
# DRAGONS: show recipe sequences and available recipes for datasets

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-r[specify a particular recipe to display]:recipe:' \
  '--all[show index of available recipes]' \
  '--adpkg[specify instrument package]:pkg:' \
  '*:file:_files' && ret=0

return ret
