#compdef qsynth
# Documentation: https://man.archlinux.org/search?q=qsynth
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-n --no-splash)'{-n,--no-splash}'[no splash screen]' \
  '(-d --daemon)'{-d,--daemon}'[daemon mode]' \
  '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
  '(-K --no-midi-in)'{-K,--no-midi-in}'[disable midi input]' \
  '(-T --no-server)'{-T,--no-server}'[do not start fluid server]' \
  '(-a --audio-driver)'{-a,--audio-driver}'+[audio driver]:drv:(jack alsa pulseaudio coreaudio dsound oss portaudio file)' \
  '(-m --midi-driver)'{-m,--midi-driver}'+[midi driver]:drv:(jack alsa_seq coremidi winmidi oss)' \
  '(-g --gain)'{-g,--gain}'+[master gain]:gain:' \
  '(-z --audio-bufsize)'{-z,--audio-bufsize}'+[buffer size]:n:' \
  '(-c --audio-bufcount)'{-c,--audio-bufcount}'+[buffer count]:n:' \
  '(-r --sample-rate)'{-r,--sample-rate}'+[sample rate]:rate:(22050 44100 48000 96000)' \
  '(-R --reverb)'{-R,--reverb}'+[reverb]:flag:(0 1 on off)' \
  '(-C --chorus)'{-C,--chorus}'+[chorus]:flag:(0 1 on off)' \
  '*:soundfont:_files -g "*.{sf2,sf3,dls}"' && ret=0

return ret
