#compdef qsynth
# Documentation: https://manpages.debian.org/bookworm/qsynth/qsynth.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --no-midi-in)'{-n,--no-midi-in}'[do not create midi driver]' \
  '(-m --midi-driver)'{-m,--midi-driver}'=[midi driver]:drv:(jack alsa alsa_seq coremidi winmidi oss)' \
  '(-K --midi-channels)'{-K,--midi-channels}'=[number of midi channels]:n:' \
  '(-a --audio-driver)'{-a,--audio-driver}'=[audio driver]:drv:(jack alsa pulseaudio coreaudio dsound oss portaudio file)' \
  '(-j --connect-jack-outputs)'{-j,--connect-jack-outputs}'[connect jack outputs to physical ports]' \
  '(-L --audio-channels)'{-L,--audio-channels}'=[number of stereo audio channels]:n:' \
  '(-G --audio-groups)'{-G,--audio-groups}'=[number of audio groups]:n:' \
  '(-z --audio-bufsize)'{-z,--audio-bufsize}'=[audio buffer size]:n:' \
  '(-c --audio-bufcount)'{-c,--audio-bufcount}'=[number of audio buffers]:n:' \
  '(-r --sample-rate)'{-r,--sample-rate}'=[sample rate]:rate:(22050 44100 48000 96000)' \
  '(-R --reverb)'{-R,--reverb}'=[reverb on/off]:flag:(0 1 yes no on off)' \
  '(-C --chorus)'{-C,--chorus}'=[chorus on/off]:flag:(0 1 yes no on off)' \
  '(-g --gain)'{-g,--gain}'=[master gain]:gain:' \
  '(-o --option)'{-o,--option}'[define a setting name=value]:name=value:' \
  '(-s --server)'{-s,--server}'[create and start server]' \
  '(-i --no-shell)'{-i,--no-shell}'[do not read commands from shell]' \
  '(-d --dump)'{-d,--dump}'[dump midi router events]' \
  '(-V --verbose)'{-V,--verbose}'[verbose midi event messages]' \
  '*:soundfont:_files -g "*.{sf2,sf3,dls}"' && ret=0

return ret
