#compdef cobaya-grid-run
# Documentation: https://cobaya.readthedocs.io/en/latest/grids.html
# cobaya: submit/run jobs for a grid of models

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--noqueue=[run directly, not using queue, ignoring most other arguments]:parallel count' \
  '--subitems[include sub-grid items]' \
  '--not_queued[only run jobs not currently queued]' \
  '--minimize[run minimization jobs]' \
  '--importance_minimize[run minimization jobs for importance-sampled chains]' \
  '--minimize_failed[run where minimization previously failed]' \
  '--checkpoint_run=[run if stopped and not finished]:R-1 threshold' \
  '--importance_ready[where parent chain has converged and stopped]' \
  '--importance_changed[run importance jobs where parent chain changed since last run]' \
  '--parent_converge=[minimum R-1 convergence for importance job parent]:R-1' \
  '--parent_stopped[only run if parent chain is not still running]' \
  '--converge=[minimum R-1 convergence]:R-1' \
  '--noimportance[original chains only, no importance sampled]' \
  '*--name=[specific chain full name only]:name' \
  '*--param=[runs including specific parameter only]:param' \
  '*--paramtag=[runs with specific parameter tag only]:paramtag' \
  '*--data=[runs including specific data only]:data' \
  '*--datatag=[runs with specific data tag only]:datatag' \
  '*--musthave-data=[include only runs that include specific data]:data' \
  '*--musthave-param=[include only runs that include specific parameter]:param' \
  '*--skip-data=[skip runs containing specific data]:data' \
  '*--skip-param=[skip runs containing specific parameter]:param' \
  '*--group=[include only runs with given group names]:group' \
  '*--skip-group=[exclude runs with given group names]:group' \
  '1:grid directory:_files -/' && ret=0

return ret
