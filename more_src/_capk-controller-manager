#compdef capk-controller-manager
# _capk-controller-manager — Cluster API KubeVirt provider (CAPK)
# upstream: https://github.com/kubernetes-sigs/cluster-api-provider-kubevirt
# Flags from main.go initFlags() on tip.

_capk-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-addr=[metrics bind host\:port]:host\:port:' \
        '--concurrency=[KubeVirtMachine/Cluster concurrent reconciles]:n:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--sync-period=[informer resync period]:dur:' \
        '--kube-api-qps=[Kubernetes API QPS]:f:' \
        '--kube-api-burst=[Kubernetes API burst]:n:' \
        '--health-addr=[health probe bind host\:port]:host\:port:' \
        '--webhook-port=[webhook server bind port]:port:' \
        '--webhook-cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--namespace=[restrict CAPK to a single namespace]:ns:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_capk-controller-manager "$@"
