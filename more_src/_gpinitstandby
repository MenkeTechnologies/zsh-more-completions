#compdef gpinitstandby
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gpinitstandby.html
# Add or remove a standby coordinator instance in a Greenplum Database system

local ret=1

_arguments -s -S \
  '(-? -h --help)'{-\?,-h,--help}'[display online help]' \
  '-a[do not prompt for confirmation]' \
  '-A[standby coordinator host address]:hostaddress' \
  '-D[set logging level to debug]' \
  '-l[directory for log files]:dir:_files -/' \
  '-n[start a configured but stopped standby coordinator]' \
  '-P[standby coordinator port]:port' \
  '-q[run in quiet mode]' \
  '-r[remove the currently configured standby coordinator]' \
  '-s[standby coordinator host name]:hostname:_hosts' \
  '-S[data directory for the standby coordinator]:dir:_files -/' \
  '-v[display version, status, last updated date, and checksum]' \
  '--hba-hostnames[use IP (0) or host names (1) in pg_hba.conf]:value:(0 1)' && ret=0

return ret
