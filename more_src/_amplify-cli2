#compdef amplify-cli2 amplify2
# _amplify-cli2 — Amazon Web Services AWS Amplify amplify-cli2 CLI command-line frontend wrapping the AWS Amplify CLI command-line toolchain for creating and maintaining backend resources on Amazon Web Services AWS open-source written in TypeScript Node provides a build pipeline for full-stack web and mobile apps AWS Amplify Gen1 init push publish pull configure mock model add api function storage auth analytics geo predictions notifications hosting interactions xr add-graphql-datasource remove update list status console env override import codegen serve migrate logout logout-all delete restore checkout invalidate-cdncache (AWS Amplify team Bret Johnson Nikhil Swaminathan Dabit, TypeScript); commander
# upstream: https://aws-amplify.github.io/

_amplify-cli2() {
    local -a sub=(
        'add:add a resource'
        'auth:auth operations'
        'api:API operations'
        'codegen:codegen operations'
        'configure:configure CLI'
        'console:open AWS console'
        'delete:delete project'
        'diagnose:diagnose project'
        'env:environment operations'
        'export:export project'
        'function:Lambda function operations'
        'help:show help'
        'hosting:hosting operations'
        'import:import resources'
        'init:initialize project'
        'logout:revoke session'
        'mock:run mock backend'
        'notifications:Pinpoint notifications'
        'override:create override'
        'plugin:plugin operations'
        'predictions:predictions ops'
        'publish:publish hosting site'
        'pull:pull backend'
        'push:push backend changes'
        'remove:remove a resource'
        'restore:restore an env'
        'serve:serve hosting site'
        'status:show status'
        'storage:storage operations'
        'team-provider-info:show team provider info'
        'update:update a resource'
        'upgrade:upgrade CLI'
        'version:show version'
        'analytics:analytics operations'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-y[yes]' \
        '--yes[yes]' \
        '--app=+[id]:str:' \
        '--appId=+[id]:str:' \
        '--envName=+[name]:str:' \
        '--name=+[name]:str:' \
        '--region=+[name]:str:' \
        '--profile=+[name]:str:' \
        '--access-key-id=+[key]:str:' \
        '--secret-access-key=+[key]:str:' \
        '--session-token=+[token]:str:' \
        '--no-override[no override]' \
        '--frontend=+[name]:str:' \
        '--framework=+[name]:str:' \
        '--editor=+[name]:str:' \
        '--useProfile[use profile]' \
        '--allow-destructive-graphql-schema-updates[allow destructive]' \
        '--no-confirm-app-id-on-pull[no confirm appId]' \
        '--code-generation-target=+[t]:t:(javascript typescript flow)' \
        '--codegen-target=+[t]:t:(javascript typescript flow)' \
        '--restore[restore]' \
        '--debug[debug]' \
        '--ci-bypass[CI bypass]' \
        '--continue[continue]' \
        '--force[force]' \
        '-f[force]' \
        '--type=+[t]:str:' \
        '--service=+[s]:str:' \
        '--container[container hosting]' \
        '--invalidate-cloudfront-cache[invalidate cloudfront]' \
        '--no-comments[no comments]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amplify subcommand' sub ;;
        args)
            case $words[1] in
                add|remove|update|push|pull) _arguments '1:category:(api auth function storage analytics geo predictions notifications hosting interactions xr custom)' '*:arg:' ;;
                env) _arguments '1:op:(add list get checkout pull push remove update import export init)' '*:name:' ;;
                hosting) _arguments '1:op:(add configure remove publish)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_amplify-cli2 "$@"
