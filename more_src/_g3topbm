#compdef g3topbm
# Documentation: man g3topbm (Netpbm)
# Source: convert a CCITT Group 3 fax file to a PBM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-reversebits[reverse bit order]' \
    '-stretch[stretch image to twice vertical resolution]' \
    '(-width -paper_size)-width=[image width in pixels]:pixels:' \
    '(-width -paper_size)-paper_size=[ISO paper size]:size:(A3 A4 A5 A6 B4)' \
    '-stop_error[stop on decode error]' \
    '-correctlong[correct overlength lines]' \
    '-kludge[try harder to handle slightly malformed G3]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:g3 file:_files -g "*.g3"' \
    && ret=0

return ret
