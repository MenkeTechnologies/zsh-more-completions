#compdef vault-agent

# vault-agent: Vault Agent (auto-auth + sink + template + caching)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'agent:run vault agent'
  'completion:emit shell completion'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-config=[config file (HCL/JSON)]:file:_files' \
  '-log-format=[log format]:fmt:(standard json)' \
  '-log-level=[log level]:level:(trace debug info warn error)' \
  '-log-file=[log file]:file:_files' \
  '-log-rotate-bytes=[log rotate bytes]:n:' \
  '-log-rotate-duration=[log rotate duration]:duration:' \
  '-log-rotate-max-files=[log rotate max files]:n:' \
  '-exit-after-auth[exit after auth]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'vault-agent command' commands && ret=0 ;;
esac
return ret
