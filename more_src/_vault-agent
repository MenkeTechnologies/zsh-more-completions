#compdef vault-agent
# Documentation: https://developer.hashicorp.com/vault/docs/agent-and-proxy/agent
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# NOTE: Vault Agent is normally invoked as `vault agent`. This wrapper covers
# the same flag surface for installations that expose `vault-agent` directly.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-config=[config file or directory (HCL/JSON)]:file:_files' \
  '-log-format=[log format]:fmt:(standard json)' \
  '-log-level=[log level]:level:(trace debug info warn error)' \
  '-log-file=[absolute path for log file]:file:_files' \
  '-log-rotate-bytes=[bytes before log rotation]:n:' \
  '-log-rotate-duration=[max duration before log rotation]:duration:' \
  '-log-rotate-max-files=[max number of archived log files to keep]:n:' \
  '-namespace=[Vault namespace]:namespace:' && ret=0

return ret
