#compdef bdeinfo
# Documentation: https://github.com/libyal/libbde
# Source: libyal/libbde manuals/bdeinfo.1 — display info about a BitLocker Drive Encryption (BDE) volume.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-k[full volume encryption key + tweak key as base16 FVEK:TWEAK]:keys:' \
    '-o[volume offset in bytes]:offset:' \
    '-p[password]:password:' \
    '-r[recovery password]:recovery password:' \
    '-s[startup key file (.BEK)]:startup key:_files' \
    '-u[unattended (disable user interaction)]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:image or volume:_files' \
    && ret=0

return ret
