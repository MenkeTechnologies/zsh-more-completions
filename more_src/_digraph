#compdef digraph
# _digraph — Go x/tools digraph utility (Alan Donovan); compute basic graph operations on directed graphs read on stdin
# upstream: https://pkg.go.dev/golang.org/x/tools/cmd/digraph

_digraph() {
    local -a sub=(
        'allpaths:all paths between two nodes'
        'cycles:print cycles'
        'degree:print in/out degree per node'
        'forward:nodes reachable forward'
        'reverse:nodes reachable backward'
        'nodes:print all nodes'
        'rank:print rank order'
        'preds:predecessors of node'
        'scc:strongly connected components'
        'succs:successors of node'
        'somepath:one path between two nodes'
        'transpose:transpose graph'
        'help:show help'
    )
    _arguments -C \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'digraph subcommand' sub ;;
    esac
}

_digraph "$@"
