#compdef hipster
# _hipster — Tyr Chen hipster (Host Identity Protocol HIPv2 reference daemon; -c config file, -d debug level, -f foreground, -p pidfile, -L log file, -P plugin path, --hipd-uri control socket override, --version; user-facing control via hipconf which talks to this daemon over the netlink socket)
# upstream: https://infrahip.hiit.fi/
# Flags from InfraHIP hipd src/hipd/hipd.c on tip.

_hipster() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-d+[debug level]:level:' \
        '-f[foreground]' \
        '-p+[pidfile]:file:_files' \
        '-L+[log file]:file:_files' \
        '-P+[plugin path]:dir:_files -/' \
        '--hipd-uri+[control socket]:file:_files'
}

_hipster "$@"
