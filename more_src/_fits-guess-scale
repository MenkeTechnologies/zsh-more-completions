#compdef fits-guess-scale
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/fits-guess-scale.1 — guess the image scale from FITS headers (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '*:FITS file:_files -g "*.{fits,fit,fts}"' \
    && ret=0

return ret
