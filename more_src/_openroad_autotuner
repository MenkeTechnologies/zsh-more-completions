#compdef openroad_autotuner
# Documentation: https://github.com/The-OpenROAD-Project/OpenROAD-flow-scripts
# OpenROAD-flow-scripts AutoTuner — sweep/tune flow parameters with Ray Tune

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--design=[name of the design for autotuning]:design:' \
  '--platform=[name of the platform for autotuning]:platform:' \
  '--config=[configuration file selecting knobs]:file:_files' \
  '--experiment=[experiment name prefix for FLOW_VARIANT]:name:' \
  '--timeout=[time limit (hours) for each trial run]:hours:' \
  '--stop_stage=[stage to stop after]:stage:(floorplan place cts globalroute route finish)' \
  '--jobs=[max number of concurrent jobs]:n:' \
  '--openroad_threads=[max threads openroad can use]:n:' \
  '--memory_limit=[max memory (GB) per trial job]:gb:' \
  '--server=[address of Ray server to connect]:addr:' \
  '--port=[port of Ray server to connect]:port:' \
  '--work-dir=[work directory for outputs (WORK_HOME)]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[verbosity level]' \
  '1:command:(tune sweep)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s \
      '--resume[resume previous run]' \
      '--algorithm=[search algorithm]:algo:(hyperopt ax optuna pbt random)' \
      '--eval=[evaluate function]:eval:(default ppa-improv)' \
      '--samples=[number of samples for tuning]:n:' \
      '--iterations=[number of iterations for tuning]:n:' \
      '--resources_per_trial=[number of CPUs per tuning job]:n:' \
      '--reference=[reference file for PPAImprov]:file:_files' \
      '--perturbation=[perturbation interval for PBT]:n:' \
      '--seed=[random seed (0 means no seed)]:n:' && ret=0
    ;;
esac

return ret
