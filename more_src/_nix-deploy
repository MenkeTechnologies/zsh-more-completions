#compdef nix-deploy
# _nix-deploy — push/pull Nix store paths over SSH (awakesecurity/nix-deploy)
# upstream: https://github.com/awakesecurity/nix-deploy
# Subcommands & flags from src/Main.hs (optparse-applicative).

_nix-deploy() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'path:deploy a single store path'
                'system:deploy and activate a NixOS system'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                path)
                    _arguments \
                        '--to=[remote user@host to push to]:addr:' \
                        '--from=[remote user@host to pull from]:addr:' \
                        '--sudo[run remote nix-store with sudo]' \
                        '--no-sign[do not sign payload]' \
                        '--path=[store path to deploy]:path:_files' \
                        '--profile-path=[parent profile directory]:dir:_files -/' \
                        '--profile-name=[profile name]:name:'
                    ;;
                system)
                    _arguments \
                        '--to=[remote user@host]:addr:' \
                        '--from=[remote user@host]:addr:' \
                        '--fail-on-partial-success[fail on partial activation]' \
                        '--no-sign[do not sign payload]' \
                        '--path=[system store path]:path:_files' \
                        '--system-name=[alternative system profile name]:name:' \
                        '--switch[nixos-rebuild switch]' \
                        '--boot[nixos-rebuild boot]' \
                        '--test[nixos-rebuild test]' \
                        '--dry-activate[nixos-rebuild dry-activate]' \
                        '--reboot[boot then reboot]'
                    ;;
            esac
            ;;
    esac
}

_nix-deploy "$@"
