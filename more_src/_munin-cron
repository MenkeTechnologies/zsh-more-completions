#compdef munin-cron munin-update munin-graph munin-html munin-limits munin-check
# Documentation: https://man.archlinux.org/search?q=munin-cron
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config=[Munin master config]:file:_files' \
  '--config_file=[Munin master config (munin-update)]:file:_files' \
  '--service=[limit to a service]:service:' \
  '--host=[limit to a host]:host:_hosts' \
  '--debug[debug output]' \
  '--nodebug[disable debug]' \
  '--fork[fork worker processes]' \
  '--nofork[do not fork]' \
  '--timeout=[timeout seconds]:secs:'
