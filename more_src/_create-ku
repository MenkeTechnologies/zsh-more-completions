#compdef create-ku
# Documentation: https://www.npmjs.com/package/create-ku
# Reference accessed: 2026-05-23
# Verified: npm view create-ku bin; npm readme scaffolding examples and dist/index.js options.

# Zsh completion for create-ku - monorepo/package/normal project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--dirname=[target directory name]:name:'   '(-m --monorepo)'{-m,--monorepo}'[create a monorepo project]'   '(-p --package)'{-p,--package}'[create a package project]'   '(-n --normal)'{-n,--normal}'[create a normal project]'   '--tools=[tooling to include]:tool:(oxfmt oxlint cspell lefthook bumpp)'   '--build-tool=[build tool]:tool:(turbo tsdown rolldown)'   '--in-monorepo[scaffold inside an existing monorepo]'   '(-t --template)'{-t,--template=}'[template preset]:template:(vanilla-ts vanilla vue-ts vue react-ts react express-ts express)'   '--overwrite[overwrite target directory if it exists]'   '--interactive[interactive mode]'   '--no-interactive[non-interactive mode]'   '--immediate[install dependencies immediately]'   ':target directory:_directories' && ret=0

return ret
