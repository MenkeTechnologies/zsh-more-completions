#compdef cvs2git

_arguments -s \
  '--options=[read all options from a file]:file:_files' \
  '--blobfile=[blob output file]:file:_files' \
  '--dumpfile=[revision dump output]:file:_files' \
  '--dry-run[print actions without writing]' \
  '--trunk-only[convert only trunk]' \
  '--encoding=[filename/log/author encoding]:enc:' \
  '--fallback-encoding=[fallback encoding]:enc:' \
  '--retain-conflicting-attic-files[keep attic versions]' \
  '*--symbol-transform=[regex symbol name transform]:p:s:' \
  '--symbol-hints=[symbol conversion hints file]:file:_files' \
  '--symbol-default=[symbol default]:opt:(heuristic strict branch tag exclude)' \
  '*--force-branch=[force as branch]:regex:' \
  '*--force-tag=[force as tag]:regex:' \
  '*--exclude=[exclude]:regex:' \
  '--keep-trivial-imports[keep trivial imports]' \
  '--username=[default username]:name:' \
  '--auto-props=[auto-props file]:file:_files' \
  '--mime-types=[mime-types file]:file:_files' \
  '--eol-from-mime-type[infer EOL from MIME]' \
  '--default-eol=[default EOL style]:style:(binary native CRLF LF CR)' \
  '--keywords-off[disable keywords]' \
  '--keep-cvsignore[keep .cvsignore]' \
  '--cvs-revnums[use CVS revnums]' \
  '--use-cvs[use cvs for blob extraction]' \
  '--use-rcs[use rcs for blob extraction]' \
  '--use-external-blob-generator[use external blob generator]' \
  '--tmpdir=[tmp directory]:dir:_files -/' \
  '--co=[co binary path]:file:_files' \
  '--cvs=[cvs binary path]:file:_files' \
  '--pass=[run single pass]:pass:' \
  '(-p --passes)'{-p,--passes=}'[pass range]:range:' \
  '(- *)--version[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '--help-passes[describe passes]' \
  '--man[show man page]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--write-symbol-info=[symbol info path]:file:_files' \
  '--skip-cleanup[skip cleanup]' \
  '--profile[profile run]' \
  ':cvs-repo path:_files -/'
