#compdef checkrestart
# Find processes that need restarting after library upgrades (debian-goodies)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-p --package)'{-p,--package}'[check only specific package]:package:' \
  '(-a --all)'{-a,--all}'[check all processes, not just those from packages]' \
  '(-b --blacklist)'{-b,--blacklist}'[specify blacklist file]:file:_files' \
  && return 0
