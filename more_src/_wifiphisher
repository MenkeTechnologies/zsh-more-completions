#compdef wifiphisher
# _wifiphisher — rogue AP framework (wifiphisher/wifiphisher)
# upstream: https://github.com/wifiphisher/wifiphisher
# Flags from wifiphisher/pywifiphisher.py (argparse).

_wifiphisher() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-i --interface)'{-i+,--interface=}'[main wireless interface]:iface:' \
        '(-eI --extensionsinterface)'{-eI+,--extensionsinterface=}'[extensions interface]:iface:' \
        '(-aI --apinterface)'{-aI+,--apinterface=}'[AP interface]:iface:' \
        '(-iI --internetinterface)'{-iI+,--internetinterface=}'[internet-facing interface]:iface:' \
        '(-pI --protectinterface)'{-pI+,--protectinterface=}'[interfaces to protect from mgmt]:iface:' \
        '(-mI --mitminterface)'{-mI+,--mitminterface=}'[MITM interface]:iface:' \
        '(-iAM --mac-ap-interface)'{-iAM+,--mac-ap-interface=}'[AP MAC override]:mac:' \
        '(-iEM --mac-extensions-interface)'{-iEM+,--mac-extensions-interface=}'[extensions MAC override]:mac:' \
        '(-iNM --no-mac-randomization)'{-iNM,--no-mac-randomization}'[disable MAC randomization]' \
        '(-kN --keepnetworkmanager)'{-kN,--keepnetworkmanager}'[do not kill NetworkManager]' \
        '(-nE --noextensions)'{-nE,--noextensions}'[disable extensions]' \
        '(-nD --nodeauth)'{-nD,--nodeauth}'[disable deauth attack]' \
        '(-dC --deauth-channels)'{-dC+,--deauth-channels=}'[deauth channels]:list:' \
        '(-dE --deauth-essid)'{-dE+,--deauth-essid=}'[deauth ESSID]:essid:' \
        '(-e --essid)'{-e+,--essid=}'[rogue AP ESSID]:essid:' \
        '(-pE --phishing-essid)'{-pE+,--phishing-essid=}'[phishing ESSID]:essid:' \
        '(-pPD --phishing-pages-directory)'{-pPD+,--phishing-pages-directory=}'[phishing pages dir]:dir:_files -/' \
        '(-p --phishingscenario)'{-p+,--phishingscenario=}'[phishing scenario name]:name:' \
        '(-pK --presharedkey)'{-pK+,--presharedkey=}'[expected PSK to capture]:psk:' \
        '(-hC --handshake-capture)'{-hC+,--handshake-capture=}'[handshake capture file]:file:_files' \
        '(-qS --quitonsuccess)'{-qS,--quitonsuccess}'[quit when credentials captured]' \
        '(-lP --logpath)'{-lP+,--logpath=}'[log file path]:file:_files' \
        '(-lC --credential-log-path)'{-lC+,--credential-log-path=}'[credential log file]:file:_files' \
        '(-l --logging)'{-l,--logging}'[enable logging]' \
        '(-dK --disable-karma)'{-dK,--disable-karma}'[disable KARMA attack]' \
        '(-kB --known-beacons)'{-kB,--known-beacons}'[enable known beacons attack]' \
        '(-fH --force-hostapd)'{-fH,--force-hostapd}'[use system hostapd]' \
        '(-pY --payload-path)'{-pY+,--payload-path=}'[payload binary path]:file:_files' \
        '(-cP --channel-monitor)'{-cP+,--channel-monitor=}'[channel to monitor]:n:' \
        '(-cM --channel-monitor)-cM[enable channel monitor]' \
        '(-wP --wps-pbc)'{-wP,--wps-pbc}'[enable WPS PBC association]' \
        '--dnsmasq-conf=[dnsmasq config file]:file:_files'
}

_wifiphisher "$@"
