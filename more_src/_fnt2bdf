#compdef fnt2bdf
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/fnt2bdf.1.html
# Convert VGA raw fonts to X11 BDF format

local ret=1

_arguments -s -S \
  '-x[do not do CP437 to ANSI glyph position translation]' \
  '-n[X11 font name to embed in BDF output]:fontname' \
  '-w[font width in pixels]:fontwidth' \
  '*:font file:_files' && ret=0

return ret
