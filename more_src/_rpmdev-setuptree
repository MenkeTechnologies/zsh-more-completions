#compdef rpmdev-setuptree
# Documentation: https://github.com/rsrchboy/rpmdevtools/blob/master/rpmdev-setuptree
# Reference accessed: 2026-05-21
# Verified: upstream rsrchboy/rpmdevtools rpmdev-setuptree source.
# Only flag is `-d` (debug). No -h/--help, no -v/--version in the script.
# Removed from prior file: fabricated -h/--help/-v/--version flags.

# rpmdev-setuptree: set up RPM build tree under ~/rpmbuild
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[debug mode]' && ret=0
return ret
