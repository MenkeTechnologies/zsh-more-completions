#compdef suinterp
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/interp_extrap/suinterp.c
# SUINTERP - interpolate traces using automatic event picking

local ret=1

_arguments -s -S \
  'ninterp=[traces to output between each input pair]:n:' \
  'nxmax=[maximum number of input traces]:n:' \
  'freq1=[starting corner freq of unaliased range]:f:' \
  'freq2=[ending corner freq of unaliased range]:f:' \
  'deriv=[=1 take vertical derivative on pick section]:d:(0 1)' \
  'linear=[=1 linear temporal interpolation]:l:(0 1)' \
  'lent=[time samples to smooth for dip estimate]:l:' \
  'lenx=[traces to smooth for dip estimate]:l:' \
  'lagc=[ms agc for dip estimate]:l:' \
  'xopt=[0 spatial derivative via FFT, 1 via differences]:x:(0 1)' \
  'iopt=[0 interpolate, 1 low-pass model, 2 dip picks]:i:(0 1 2)' \
  'verbose=[=1 echoes information]:v:(0 1)' \
  'tmpdir=[directory path prefix for temporary files]:d:_files -/' \
  '*:SU file:_files' && ret=0

return ret
