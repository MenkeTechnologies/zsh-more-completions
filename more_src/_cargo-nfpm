#compdef cargo-nfpm
# Documentation: https://crates.io/crates/cargo-nfpm
# Reference accessed: 2026-05-23
# Verified: crates.io/docs.rs cargo nfpm package flags.

# Zsh completion for cargo-nfpm - build Linux packages via nFPM from Rust projects

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'package:build apk/deb/rpm/ipk/archlinux package from a Cargo project'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'cargo nfpm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (package)
        _arguments \
          '(-p --package)'{-p+,--package=}'[package to build]:spec:' \
          '--target=[target triple]:triple:' \
          '--profile=[build profile]:profile:' \
          '(-F --features)'{-F+,--features=}'[features to activate]:features:' \
          '(-o --output)'{-o+,--output=}'[output path]:path:_files' \
          '--no-build[skip cargo build]' \
          '--no-vendor[skip downloading nFPM]' \
          '(-f --format)'{-f+,--format=}'[package format]:format:(apk archlinux deb ipk rpm)' \
          '(-s --strip)'{-s+,--strip=}'[strip action]:action:(skip keep-line-tables strip split)' \
          '(-V --version)'{-V,--version}'[show version]' \
          '*:cargo build options:' && ret=0 ;;
    esac ;;
esac

return ret
