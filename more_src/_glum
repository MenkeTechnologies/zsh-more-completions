#compdef glum
# Source: cargo binstall glum@0.2.2
# Probed via: --generate-completions zsh
# Repository: https://github.com/jaschadub/glum

autoload -U is-at-least

_glum() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--measure=[Target column width for the reading measure]:MEASURE:_default' \
'--theme=[Color theme. Press \`T\` at runtime to cycle themes. If omitted, the last theme you used is restored (first-run default is \`dark\`)]:THEME:((light\:"Off-white paper background"
dark\:"Near-black background"
sepia\:"Warm brown paper tones"
night\:"Deep blue-leaning dark theme"
plain\:"ANSI-16 fallback"))' \
'--layout=[Typographic layout. Press \`L\` at runtime to toggle. If omitted, the last layout you used is restored (first-run default is \`minimal\`)]:LAYOUT:((minimal\:"Understated typography"
vivid\:"Strong heading hierarchy with prefixes and heavy rules"))' \
'--align=[Horizontal alignment of the reading column. \`center\` leaves symmetric margins for classic reader-mode feel; \`left\` anchors the column to the left edge so code blocks don'\''t appear indented in wide terminals. Press \`A\` at runtime to toggle]:ALIGN:((center\:"Center the reading column — symmetric margins, classic reader-mode"
left\:"Anchor the reading column to the left edge (2-col gutter)"
right\:"Anchors the reading column to the right margin. Useful as a column placement hint for RTL scripts; note that glum does not perform bidirectional layout — individual RTL glyphs still render in terminal order unless your terminal itself applies \`BiDi\`"))' \
'-s+[Open with a search pre-populated; jump to the first match. \`n\`/\`N\` to step through as usual]:QUERY:_default' \
'--search=[Open with a search pre-populated; jump to the first match. \`n\`/\`N\` to step through as usual]:QUERY:_default' \
'-H+[Jump to the first heading whose title contains this text (case-insensitive substring match against the TOC)]:TITLE:_default' \
'--heading=[Jump to the first heading whose title contains this text (case-insensitive substring match against the TOC)]:TITLE:_default' \
'--generate-completions=[Emit a shell completion script for the given shell on stdout, then exit. Redirect into the shell'\''s completion directory — examples\: \`glum --generate-completions bash > ~/.local/share/bash-completion/completions/glum\`, \`glum --generate-completions zsh > "\${fpath\[1\]}/_glum"\`, \`glum --generate-completions fish > ~/.config/fish/completions/glum.fish\`]:SHELL:(bash elvish fish powershell zsh)' \
'--reset-position[Ignore any remembered position and start at the top of the document. Future positions are still saved (unless \`--no-remember\` is given)]' \
'--toc[Open with the table of contents overlay already visible]' \
'--no-remember[Disable remembering reading position across runs]' \
'-f[Follow file changes\: re-read and re-render when the file on disk is modified. Scroll position is preserved across reloads]' \
'--follow[Follow file changes\: re-read and re-render when the file on disk is modified. Scroll position is preserved across reloads]' \
'--truncate-code[Truncate long code lines with \`…\` instead of soft-wrapping them. Default is to soft-wrap so no code is hidden; pass this flag to get tight single-line-per-code-line layout. Press \`W\` at runtime to toggle]' \
'--mouse[Enable mouse wheel scrolling. Off by default because mouse capture disables the terminal'\''s native click-and-drag text selection — which most readers still want for copying. Turn it on when you prefer scrolling with the wheel over using \`j\`/\`k\`/space]' \
'--generate-man[Emit a roff-formatted man page on stdout, then exit. Typical use\: \`glum --generate-man > /usr/local/share/man/man1/glum.1\`]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::path -- Path to a markdown file. Pass `-` to read from stdin. Not required when `--generate-completions` or `--generate-man` is used, because those print to stdout and exit:_files' \
&& ret=0
}

(( $+functions[_glum_commands] )) ||
_glum_commands() {
    local commands; commands=()
    _describe -t commands 'glum commands' commands "$@"
}

if [ "$funcstack[1]" = "_glum" ]; then
    _glum "$@"
else
    compdef _glum glum
fi
