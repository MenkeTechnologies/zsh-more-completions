#compdef kubectl-mtv
# _kubectl-mtv — Migration Toolkit for Virtualization kubectl plugin (yaacov/kubectl-mtv)
# upstream: https://github.com/yaacov/kubectl-mtv
# Flags from cmd/kubectl-mtv.go (cobra/pflag).

_kubectl-mtv() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v+,--verbose=}'[verbose level 0-3]:lvl:(0 1 2 3)' \
        '(-A --all-namespaces)'{-A,--all-namespaces}'[query all namespaces]' \
        '--use-utc[format timestamps in UTC]' \
        '(-i --inventory-url)'{-i+,--inventory-url=}'[inventory service base URL]:url:' \
        '--inventory-insecure-skip-tls[skip TLS verify on inventory service]' \
        '--no-color[disable colored output]' \
        '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--context=[kubeconfig context]:ctx:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'archive:archive a migration plan'
                'cancel:cancel a running migration'
                'create:create MTV resources (plan/provider/etc.)'
                'cutover:execute migration cutover'
                'delete:delete MTV resources'
                'describe:show detailed resource info'
                'get:list/get MTV resources'
                'health:show service health'
                'help:show help'
                'mcpserver:start an MCP server'
                'patch:patch MTV resources'
                'settings:manage MTV settings'
                'start:start a migration plan'
                'unarchive:unarchive a migration plan'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_kubectl-mtv "$@"
