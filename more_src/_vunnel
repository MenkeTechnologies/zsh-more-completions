#compdef vunnel
# Documentation: https://github.com/anchore/vunnel
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (Click-shipped dynamic
# completion via _VUNNEL_COMPLETE=zsh_complete).
# Source: Homebrew bottle
# Formula: vunnel
# Type: maintainer-shipped (Homebrew)

_vunnel_completion() {
    local -a completions
    local -a completions_with_descriptions
    local -a response
    (( ! $+commands[vunnel] )) && return 1

    response=("${(@f)$(env COMP_WORDS="${words[*]}" COMP_CWORD=$((CURRENT-1)) _VUNNEL_COMPLETE=zsh_complete vunnel)}")

    for type key descr in ${response}; do
        if [[ "$type" == "plain" ]]; then
            if [[ "$descr" == "_" ]]; then
                completions+=("$key")
            else
                completions_with_descriptions+=("$key":"$descr")
            fi
        elif [[ "$type" == "dir" ]]; then
            _path_files -/
        elif [[ "$type" == "file" ]]; then
            _path_files -f
        fi
    done

    if [ -n "$completions_with_descriptions" ]; then
        _describe -V unsorted completions_with_descriptions -U
    fi

    if [ -n "$completions" ]; then
        compadd -U -V unsorted -a completions
    fi
}

if [[ $zsh_eval_context[-1] == loadautofunc ]]; then
    # autoload from fpath, call function directly
    _vunnel_completion "$@"
else
    # eval/source/. command, register function for later
    compdef _vunnel_completion vunnel
fi

