#compdef tinkerbell
# _tinkerbell — Tinkerbell all-in-one bare-metal provisioning daemon (Smee DHCP/PXE + Tootles metadata + Tink server + Tink controller + Rufio BMC + SecondStar console + UI)
# upstream: https://github.com/tinkerbell/tinkerbell
# Global flags from cmd/tinkerbell/flag/global.go on tip (peterbourgon/ff/v4); per-service flag groups live in flag/{smee,tootles,tink_server,tink_controller,rufio,secondstar,ui,kubeapiserver,etcd}.go.

_tinkerbell() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[log verbosity (higher = louder; negative disables)]:n:' \
        '--backend=[backend type]:type:(kube file none)' \
        '--backend-file-path=[file backend hardware spec path]:file:_files' \
        '--backend-kube-config=[kubeconfig used by the kube backend]:file:_files' \
        '--backend-kube-namespace=[kubernetes namespace watched by the kube backend]:ns:' \
        '--backend-kube-qps=[kube client QPS (negative disables ratelimiting)]:f:' \
        '--backend-kube-burst=[kube client burst]:n:' \
        '--public-ipv4=[public IPv4 advertised in responses (autodetected by default)]:ip:' \
        '--bind-address=[address to bind HTTP/HTTPS listeners to]:addr:' \
        '--http-port=[plain HTTP port]:port:' \
        '--https-port=[HTTPS port]:port:' \
        '--tls-cert-file=[HTTPS cert file]:file:_files' \
        '--tls-key-file=[HTTPS key file]:file:_files' \
        '--disable-http-to-https-redirect[do not redirect HTTP to HTTPS]' \
        '*--trusted-proxies=[csv of trusted-proxy CIDRs]:cidrs:' \
        '--otel-endpoint=[OpenTelemetry collector endpoint]:url:_urls' \
        '--otel-insecure[connect to the OTel collector without TLS]' \
        '--enable-smee=[run the Smee DHCP/PXE component]:bool:(true false)' \
        '--enable-tootles=[run the Tootles instance-metadata component]:bool:(true false)' \
        '--enable-tink-server=[run the Tink workflow gRPC server]:bool:(true false)' \
        '--enable-tink-controller=[run the Tink workflow controller]:bool:(true false)' \
        '--enable-rufio-controller=[run the Rufio BMC controller]:bool:(true false)' \
        '--enable-secondstar=[run the SecondStar serial-console proxy]:bool:(true false)' \
        '--enable-ui=[run the Tinkerbell UI]:bool:(true false)' \
        '--enable-crd-migrations=[run CRD migrations at startup]:bool:(true false)' \
        '--enable-embedded-kube-apiserver=[run an embedded kube-apiserver (single-node mode)]:bool:(true false)' \
        '--enable-embedded-etcd=[run an embedded etcd (single-node mode)]:bool:(true false)'
}

_tinkerbell "$@"
