#compdef wslconfig wslconfig.exe
# _wslconfig — Microsoft WSL legacy wslconfig.exe (predecessor to wsl.exe; /list with /all or /running, /setdefault, /terminate, /unregister, /upgrade convert v1->v2; replaced on modern Windows by wsl.exe but still ships for compatibility)
# upstream: https://github.com/microsoft/WSL
# Flags from WSL wslconfig.exe on tip.

_wslconfig() {
    _arguments \
        '/help[show help]' \
        '/list[list distros]' \
        '/l[list distros]' \
        '/all[(/list) include not-running]' \
        '/running[(/list) only running]' \
        '/setdefault+[set default distro]:distro:' \
        '/s+[set default distro]:distro:' \
        '/terminate+[terminate distro]:distro:' \
        '/t+[terminate distro]:distro:' \
        '/unregister+[unregister distro]:distro:' \
        '/u+[unregister distro]:distro:' \
        '/upgrade+[upgrade v1->v2 distro]:distro:'
}

_wslconfig "$@"
