#compdef xfs_undelete
# _xfs_undelete — ianka/xfs_undelete (recover recently deleted inodes from an XFS filesystem; -t time threshold (seconds), -i inode list, -t list output dir, -r regex matching filenames, -l limit results, -n no-write dry run; positional device required)
# upstream: https://github.com/ianka/xfs_undelete
# Flags from xfs_undelete xfs_undelete.tcl on tip.

_xfs_undelete() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-t+[time threshold seconds]:seconds:' \
        '-i+[inode list]:inodes:' \
        '-o+[output dir]:dir:_files -/' \
        '-r+[filename regex]:regex:' \
        '-l+[limit results]:n:' \
        '-n[no-write dry run]' \
        '1:device:_files -g "/dev/*"'
}

_xfs_undelete "$@"
