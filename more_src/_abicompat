#compdef abicompat
# Documentation: https://sourceware.org/libabigail/manual/abicompat.html
# libabigail tool to check app/library ABI compatibility

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-u --list-undefined-symbols)'{-u,--list-undefined-symbols}'[list undefined symbols of the application]' \
  '(-b --show-base-names)'{-b,--show-base-names}'[show base names of binaries]' \
  '--app-debug-info-dir[application debug info directory]:dir:_files -/' \
  '--lib-debug-info-dir1[first library debug info directory]:dir:_files -/' \
  '--lib-debug-info-dir2[second library debug info directory]:dir:_files -/' \
  '*--suppressions[suppression specification file]:file:_files' \
  '--no-show-locs[do not show source locations]' \
  '--btf[read ABI from BTF debug info]' \
  '--ctf[read ABI from CTF debug info]' \
  '--fail-no-debug-info[fail if no debug info is found]' \
  '--ignore-soname[ignore SONAME when comparing]' \
  '--weak-mode[check against a single library only]' \
  '*:file:_files' && ret=0

return ret
