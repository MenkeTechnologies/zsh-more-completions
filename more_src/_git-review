#compdef git-review

# Zsh completion for git-review - Gerrit code review tool

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-s --setup)'{-s,--setup}'[set up the gerrit remote]' \
  '(-d --download)'{-d,--download}'[download a change by number]:change number:' \
  '(-x --cherrypick)'{-x,--cherrypick}'[cherry-pick a change]:change number:' \
  '(-l --list)'{-l,--list}'[list open reviews]' \
  '(-m --compare)'{-m,--compare}'[compare two patch sets]:patch sets:' \
  '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
  '(-n --dry-run)'{-n,--dry-run}'[do not actually perform any commands]' \
  '(-R --no-rebase)'{-R,--no-rebase}'[do not rebase before pushing]' \
  '(-F --force-rebase)'{-F,--force-rebase}'[force rebase even if not needed]' \
  '(-r --remote)'{-r,--remote}'[git remote to use for gerrit]:remote:__git_remotes' \
  '(-T --no-topic)'{-T,--no-topic}'[do not set a topic]' \
  '(-t --topic)'{-t,--topic}'[set a topic]:topic:' \
  '(-b --branch)'{-b,--branch}'[target branch]:branch:__git_branch_names' \
  '(-D --draft)'{-D,--draft}'[submit as a draft]' \
  '(-f --finish)'{-f,--finish}'[close out a branch]' \
  '(-u --update)'{-u,--update}'[update an existing review]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--no-thin[do not use thin packs for push]' \
  '--notify[notify setting]:notify:(NONE OWNER OWNER_REVIEWERS ALL)' \
  '--reviewers[add reviewers]:reviewers:' \
  '--work-in-progress[mark as work in progress]' \
  '--ready[mark as ready for review]' \
  '--message[message to include with review]:message:' \
  '*:branch:__git_branch_names'

(( $+functions[__git_remotes] )) ||
__git_remotes() {
  local -a remotes
  remotes=(${(f)"$(git remote 2>/dev/null)"})
  _describe -t remotes 'remote' remotes
}

(( $+functions[__git_branch_names] )) ||
__git_branch_names() {
  local -a branches
  branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
  _describe -t branches 'branch' branches
}
