#compdef trashy trash

# Zsh completion for trashy - simple, fast trash CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'put:put files into trash'
  'list:list items in trash'
  'restore:restore items from trash'
  'empty:permanently delete items from trash'
  'completions:generate shell completions'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'trashy command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      put)
        _arguments \
          '*:file or directory:_files' && ret=0
        ;;
      list)
        _arguments \
          '--before[filter by date]:date' \
          '--after[filter by date]:date' \
          '--glob[filter by glob]:pattern' \
          '--regex[filter by regex]:pattern' \
          '--exact[exact match]:name' \
          '--max[max items]:count' \
          '--rev[reverse order]' && ret=0
        ;;
      restore|empty)
        _arguments \
          '--before[filter by date]:date' \
          '--after[filter by date]:date' \
          '--glob[filter by glob]:pattern' \
          '--regex[filter by regex]:pattern' \
          '--exact[exact match]:name' \
          '--ranges[ranges]:ranges' \
          '--all[apply to all]' && ret=0
        ;;
    esac
    ;;
esac

return ret
