#compdef trashy trash
# Documentation: https://github.com/oberblastmeister/trashy
# Reference accessed: 2026-05-21
# Verified: upstream docs (src/app/command/*.rs, src/filter.rs).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'put:put files into trash'
  'list:list items in the trash'
  'restore:restore items from the trash'
  'empty:permanently delete items from the trash'
  'completions:generate shell completions'
  'manpage:generate manpages'
)

local -a config_flags=(
  '(-c --color)'{-c,--color}'=[when to use colors]:when:(auto always never)'
  '--time=[when to use time]:mode:(precise imprecise)'
  '(-t --table)'{-t,--table}'=[when to format as table]:when:(auto always never)'
)

local -a filter_flags=(
  '*--before=[older than]:date'
  '*--within=[newer than]:date'
  '*--regex=[match regex]:pattern'
  '*--glob=[match glob]:pattern'
  '*--substring=[match substring]:pattern'
  '*--exact=[match exact name]:name'
  '(-m --match)'{-m,--match}'=[match mode]:mode:(regex glob substring exact)'
  '*'{-d,--directory,--dir}'=[restrict to directory]:dir:_directories'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  $config_flags \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'trashy command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      put)
        _arguments \
          '*:file or directory:_files' && ret=0
        ;;
      list)
        _arguments \
          $filter_flags \
          '--rev[reverse sort order]' \
          '(-n --max)'{-n,--max}'=[max items]:count' \
          '*:pattern:' && ret=0
        ;;
      restore)
        _arguments \
          $filter_flags \
          '--rev[reverse sort order]' \
          '(-n --max)'{-n,--max}'=[max items]:count' \
          '(-f --force)'{-f,--force}'[skip confirmation]' \
          '*:ranges or patterns:' && ret=0
        ;;
      empty)
        _arguments \
          $filter_flags \
          '--rev[reverse sort order]' \
          '(-n --max)'{-n,--max}'=[max items]:count' \
          '--all[empty all files]' \
          '(-f --force)'{-f,--force}'[skip confirmation]' \
          '*:ranges or patterns:' && ret=0
        ;;
      completions)
        _arguments '1:shell:(bash elvish fish powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
