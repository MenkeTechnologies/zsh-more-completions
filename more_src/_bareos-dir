#compdef bareos-dir
# Documentation: https://docs.bareos.org/Appendix/BareosPrograms.html
# Reference accessed: 2026-05-16
# Verified: Bareos docs Appendix - bareos-dir program reference.
# Removed from prior file: bogus man.archlinux.org search URL.

# bareos-dir: Bareos Director daemon (job scheduler/coordinator)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '--version[show version]' \
  '(-c --config)'{-c+,--config=}'[configuration file or directory]:path:_files' \
  '(-d --debug-level)'{-d+,--debug-level=}'[debug level]:level:' \
  '(--dt --debug-timestamps)'{--dt,--debug-timestamps}'[print timestamps in debug output]' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-g --group)'{-g+,--group=}'[run as group]:group:_groups' \
  '(-s --no-signals)'{-s,--no-signals}'[do not trap signals]' \
  '(-t --test-config)'{-t,--test-config}'[read configuration and exit]' \
  '(-u --user)'{-u+,--user=}'[run as user]:user:_users' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(--xc --export-configuration)'{--xc,--export-configuration}'[print current configuration and exit]' \
  '(--xs --export-schema)'{--xs,--export-schema}'[print configuration schema as JSON and exit]' && ret=0
return ret
