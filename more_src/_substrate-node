#compdef substrate-node node-template substrate polkadot-parachain
# Documentation: https://www.howtosolutions.net/2021/04/substrate-command-line-arguments-options-and-subcommands-list/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build-spec:build a chain specification'
  'check-block:validate a block'
  'export-blocks:export blocks to a file'
  'export-state:export state at a block as a chain spec'
  'import-blocks:import blocks from a file'
  'purge-chain:remove all chain data'
  'revert:revert chain to a previous state'
  'benchmark:benchmark runtime pallets'
  'try-runtime:try a runtime against current state'
  'key:local key management utilities'
  'inspect-block:inspect a block in storage'
  'inspect-extrinsic:inspect an extrinsic in storage'
  'sign:sign a message with a key'
  'verify:verify a signature'
  'vanity:generate a vanity address'
  'chain-info:print chain info'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--chain=[chain spec]:spec:(dev local staging mainnet kusama polkadot rococo westend custom)' \
  '(-d --base-path)'{-d+,--base-path=}'[base path for data]:dir:_files -/' \
  '--dev[development mode with fresh state]' \
  '--validator[enable validator role]' \
  '--port=[libp2p port]:port:' \
  '--rpc-port=[HTTP RPC port]:port:' \
  '--ws-port=[WebSocket RPC port]:port:' \
  '--rpc-cors=[RPC CORS origins]:origins:(all none localhost)' \
  '*--rpc-methods=[allowed RPC methods]:methods:(auto safe unsafe)' \
  '--rpc-external[allow external RPC]' \
  '--ws-external[allow external WS]' \
  '--unsafe-rpc-external[allow unsafe external RPC]' \
  '--unsafe-ws-external[allow unsafe external WS]' \
  '--pruning=[pruning mode]:mode:(archive 256 1000 keep-finalized)' \
  '--state-pruning=[state pruning]:mode:(archive 256 1000)' \
  '--blocks-pruning=[blocks pruning]:mode:(archive 256 1000)' \
  '--execution=[execution strategy]:strategy:(Native Wasm Both NativeElseWasm)' \
  '--wasm-execution=[Wasm execution]:method:(interpreted-i-know-what-i-do compiled)' \
  '--name=[node name]:name:' \
  '--node-key=[node key]:key:' \
  '--no-mdns[disable mDNS]' \
  '--no-telemetry[disable telemetry]' \
  '--telemetry-url=[telemetry URL,verbosity]:spec:' \
  '*--bootnodes=[bootnode multiaddr]:addr:' \
  '--in-peers=[max inbound peers]:n:' \
  '--out-peers=[max outbound peers]:n:' \
  '--alice[insert Alice into keystore]' \
  '--bob[insert Bob into keystore]' \
  '--charlie[insert Charlie into keystore]' \
  '--dave[insert Dave into keystore]' \
  '--eve[insert Eve into keystore]' \
  '--ferdie[insert Ferdie into keystore]' \
  '--one[insert One into keystore]' \
  '--two[insert Two into keystore]' \
  '--tmp[run with tmp data dir]' \
  '--prometheus-port=[Prometheus port]:port:' \
  '--prometheus-external[allow external Prometheus]' \
  '--reserved-only[connect only to reserved nodes]' \
  '*--reserved-nodes=[reserved node addr]:addr:' \
  '--keystore-uri=[keystore URI]:uri:' \
  '--keystore-path=[keystore path]:dir:_files -/' \
  '--password-interactive[prompt for keystore password]' \
  '--password-filename=[password file]:file:_files' \
  '--enable-offchain-indexing=[enable offchain indexing]:bool:(true false)' \
  '*-l+[log level (target=level)]:spec:' \
  '*--log=[log directive]:spec:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'substrate-node command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build-spec)
        _arguments \
          '--raw[output raw JSON]' \
          '--disable-default-bootnode[disable default bootnode]' \
          '--chain=[chain spec]:spec:' && ret=0 ;;
      (benchmark)
        _arguments '*::sub:(pallet block overhead storage machine extrinsic)' && ret=0 ;;
      (try-runtime)
        _arguments '*::sub:(on-runtime-upgrade execute-block offchain-worker follow-chain create-snapshot)' && ret=0 ;;
      (key)
        _arguments '*::sub:(generate generate-node-key inspect inspect-node-key insert)' && ret=0 ;;
      (purge-chain)
        _arguments \
          '(-y --yes)'{-y,--yes}'[do not ask for confirmation]' \
          '--chain=[chain spec]:spec:' && ret=0 ;;
      (revert)
        _arguments \
          '*::num_blocks:' && ret=0 ;;
    esac ;;
esac

return ret
