#compdef nikola

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'auto:automatically detect site changes and rebuild'
      'build:run tasks'
      'check:check links and files in the generated site'
      'clean:clean action'
      'console:start an interactive Python console'
      'deploy:deploy the site'
      'dumpdb:dump the dependency database'
      'forget:make tasks forget they were run'
      'github_deploy:deploy to GitHub Pages'
      'ignore:ignore a task'
      'import_wordpress:import a WordPress dump'
      'init:create a new site'
      'list:list tasks from dodo file'
      'new_page:create a new page'
      'new_post:create a new blog post'
      'orphans:list orphan files'
      'plugin:manage plugins'
      'serve:start the test webserver'
      'status:display site status'
      'stubs:create empty task stubs'
      'tabcompletion:generate shell completion'
      'theme:manage themes'
      'version:show version'
    )
    _describe -t commands 'nikola command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (new_post|new_page)
        _arguments -s -S \
          '(-t --title)'{-t,--title}'=[title]:title' \
          '(-a --author)'{-a,--author}'=[author]:author' \
          '--tags=[tags]:tags' \
          '(-1 --onefile)'{-1,--onefile}'[create single file post]' \
          '(-2 --twofile)'{-2,--twofile}'[create two file post]' \
          '(-e --editor)'{-e,--editor}'[open editor after creation]' \
          '(-f --format)'{-f,--format}'=[markup format]:format:(rest markdown html ipynb)' \
          '(-s --schedule)'{-s,--schedule}'[schedule post]' \
          '--date=[post date]:date' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '(-n --dry-run)'{-n,--dry-run}'[show what would be done]' \
          '--strict[treat warnings as errors]' \
          '--invariant[use invariant timestamps for testing]' \
          '--quiet[suppress output]' && ret=0
        ;;
      (serve)
        _arguments -s -S \
          '(-a --address)'{-a,--address}'=[address to bind]:address' \
          '(-p --port)'{-p,--port}'=[port to listen on]:port' \
          '(-b --browser)'{-b,--browser}'[open in browser]' \
          '(-6 --ipv6)'{-6,--ipv6}'[use IPv6]' && ret=0
        ;;
      (check)
        _arguments -s -S \
          '(-l --check-links)'{-l,--check-links}'[check links]' \
          '(-f --check-files)'{-f,--check-files}'[check files]' \
          '--clean-files[remove unknown files]' \
          '(-r --remote)'{-r,--remote}'[check remote links too]' && ret=0
        ;;
      (deploy)
        _arguments -s -S \
          '1:preset' && ret=0
        ;;
      (init)
        _arguments -s -S \
          '--demo[create demo site with example content]' \
          '--quiet[suppress output]' \
          '1:directory:_directories' && ret=0
        ;;
      (plugin)
        _arguments -s -S \
          '(-i --install)'{-i,--install}'=[install plugin]:plugin' \
          '--uninstall=[uninstall plugin]:plugin' \
          '(-l --list)'{-l,--list}'[list available plugins]' \
          '--list-installed[list installed plugins]' \
          '(-u --url)'{-u,--url}'=[plugin URL]:url' && ret=0
        ;;
      (theme)
        _arguments -s -S \
          '(-i --install)'{-i,--install}'=[install theme]:theme' \
          '--uninstall=[uninstall theme]:theme' \
          '(-l --list)'{-l,--list}'[list available themes]' \
          '--list-installed[list installed themes]' \
          '(-u --url)'{-u,--url}'=[theme URL]:url' \
          '(-c --copy-template)'{-c,--copy-template}'=[copy template]:template' && ret=0
        ;;
    esac
    ;;
esac

return ret
