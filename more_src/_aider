#compdef aider

# Zsh completion for aider - AI pair programming tool

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--model=[specify the model to use]:model' \
  '--opus[use Claude Opus]' \
  '--sonnet[use Claude Sonnet]' \
  '--haiku[use Claude Haiku]' \
  '--4[use GPT-4]' \
  '--4o[use GPT-4o]' \
  '--mini[use GPT-4o-mini]' \
  '--4-turbo[use GPT-4 Turbo]' \
  '--deepseek[use DeepSeek]' \
  '--edit-format=[edit format]:format:(diff whole udiff)' \
  '--editor-model=[model for editor tasks]:model' \
  '--no-auto-commits[disable auto commits]' \
  '--auto-test[run tests after changes]' \
  '--test-cmd=[command to run tests]:command' \
  '--lint-cmd=[command to run linter]:command' \
  '--dark-mode[use dark mode colors]' \
  '--light-mode[use light mode colors]' \
  '--pretty[enable pretty output]' \
  '--no-pretty[disable pretty output]' \
  '--no-stream[disable streaming responses]' \
  '--yes[always say yes to prompts]' \
  '--chat-mode=[chat mode]:mode:(code ask help)' \
  '--input-history-file=[input history file]:file:_files' \
  '--chat-history-file=[chat history file]:file:_files' \
  '--map-tokens=[number of tokens for repo map]:tokens' \
  '--map-refresh=[when to refresh the repo map]:refresh:(auto always files manual)' \
  '--no-auto-lint[disable auto linting]' \
  '--verbose[enable verbose output]' \
  '--show-diffs[show diffs when committing]' \
  '--git[enable git integration]' \
  '--no-git[disable git integration]' \
  '--gitignore[add aider files to .gitignore]' \
  '--no-gitignore[do not modify .gitignore]' \
  '--aiderignore=[aiderignore file path]:file:_files' \
  '--subtree-only[only consider files in current subtree]' \
  '--encoding=[specify file encoding]:encoding' \
  '--config=[config file path]:file:_files' \
  '--env-file=[environment file path]:file:_files' \
  '*:file:_files'
