#compdef clinic
# Zsh completion for clinic - Node.js performance profiling suite
# https://clinicjs.org/

local -a commands=(
  'doctor:detect performance issues automatically'
  'bubbleprof:profile asynchronous delays'
  'flame:generate CPU flamegraphs'
  'heapprofiler:profile heap memory allocations'
  'upload:upload a profile to Clinic.js'
  'login:log in to Clinic.js'
  'logout:log out from Clinic.js'
  'ask:ask the AI about a profile'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*::args:->args'

case $state in
  cmds)
    _describe -t commands 'clinic command' commands
    ;;
  args)
    case $words[1] in
      doctor|bubbleprof|flame|heapprofiler)
        _arguments \
          '--debug[enable debug mode]' \
          '--on-port=[run script when server starts]:script:' \
          '--autocannon=[run autocannon against server]:path:' \
          '--open[open results in browser]' \
          '--no-open[do not open results in browser]' \
          '--dest=[set output directory]:directory:_files -/' \
          '--name=[set profile name]:name:' \
          '--collect-only[only collect data, do not visualize]' \
          '--visualize-only=[visualize existing data]:data file:_files' \
          '--sample-interval=[set sample interval in ms]:interval:' \
          '--stop-delay=[delay before stopping in ms]:delay:' \
          '-- :node command:' \
          '*:arguments:'
        ;;
      upload)
        _arguments '*:profile file:_files -g "*.clinic-*"'
        ;;
    esac
    ;;
esac
