#compdef create-my-react-boilerplate
# Documentation: https://www.npmjs.com/package/create-my-react-boilerplate
# Reference accessed: 2026-05-23
# Verified: npm view create-my-react-boilerplate bin; npm readme CLI flags table.

# Zsh completion for create-my-react-boilerplate - React SPA boilerplate scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--ts[use TypeScript template]' \
  '--js[use JavaScript template]' \
  '--router=[client router]:router:(react-router tanstack-router)' \
  '--ui=[component library]:ui:(shadcn heroui)' \
  '--pm=[package manager]:manager:(npm yarn pnpm bun)' \
  '--no-install[skip dependency installation]' \
  '--no-git[skip git initialization]' \
  '--offline[use pinned versions from versions.lock.json]' \
  '(-v --version)'{-v,--version}'[print CLI version]' \
  '(-h --help)'{-h,--help}'[print usage]' \
  ':project name:' && ret=0

return ret
