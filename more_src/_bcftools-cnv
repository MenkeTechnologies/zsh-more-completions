#compdef bcftools-cnv
# Documentation: http://www.htslib.org/doc/bcftools.html#cnv
# bcftools cnv: Copy number variation caller

local ret=1

_arguments -s -S \
  '(-c --control-sample)'{-c,--control-sample}'[optional control sample name. If given, pairwise calling is performed]:string: ' \
  '(-f --AF-file)'{-f,--AF-file}'[read allele frequencies from a tab-delimited file with the columns CHR]:file:_files' \
  '(-o --output-dir)'{-o,--output-dir}'[output directory]:path:_files -/' \
  '(-p --plot-threshold)'{-p,--plot-threshold}'[call matplotlib to produce plots for chromosomes with quality at least]:float: ' \
  '(-r --regions)'{-r,--regions}'[see Common Options]:chr: ' \
  '(-R --regions-file)'{-R,--regions-file}'[see Common Options]:file:_files' \
  '(--regions-overlap)'--regions-overlap'[see Common Options]:0: ' \
  '(-s --query-sample)'{-s,--query-sample}'[query sample name]:string: ' \
  '(-t --targets)'{-t,--targets}'[see Common Options]:LIST: ' \
  '(-T --targets-file)'{-T,--targets-file}'[see Common Options]:FILE:_files' \
  '(--targets-overlap)'--targets-overlap'[see Common Options]:0: ' \
  '(-v --verbosity)'{-v,--verbosity}'[see Common Options]:INT: ' \
  '(-a --aberrant)'{-a,--aberrant}'[fraction of aberrant cells in query and control. The hallmark of dupli]:float: ' \
  '(-b --BAF-weight)'{-b,--BAF-weight}'[relative contribution from BAF]:float: ' \
  '(-d --BAF-dev)'{-d,--BAF-dev}'[expected BAF deviation in query and control, i.e. the noise observed i]:float: ' \
  '(-e --err-prob)'{-e,--err-prob}'[uniform error probability]:float: ' \
  '(-l --LRR-weight)'{-l,--LRR-weight}'[relative contribution from LRR. With noisy data, this option can have]:float: ' \
  '(-L --LRR-smooth-win)'{-L,--LRR-smooth-win}'[reduce LRR noise by applying moving average given this window size]:int: ' \
  '(-O --optimize)'{-O,--optimize}'[iteratively estimate the fraction of aberrant cells, down to the given]:float: ' \
  '(-P --same-prob)'{-P,--same-prob}'[the prior probability of the query and the control sample being the sa]:float: ' \
  '(-x --xy-prob)'{-x,--xy-prob}'[the HMM probability of transition to another copy number state. Increa]:float: ' \
  '*:file:_files' && ret=0

return ret
