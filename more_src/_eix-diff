#compdef eix-diff
# Gentoo eix database diff tool

local ret=1

_arguments -s -S \
  '-q[quiet mode]' \
  '-s[short output]' \
  '-n[no color]' \
  '-f[first database file]:file:_files' \
  '-F[second database file]:file:_files' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
