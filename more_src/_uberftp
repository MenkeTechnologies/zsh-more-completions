#compdef uberftp
# Documentation: https://man.archlinux.org/search?q=uberftp
# Reference accessed: 2026-05-16

# UberFTP: interactive GridFTP client
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[show version]' \
  '-V[show version]' \
  '-debug[debug]' \
  '-p[parallelism]:n:' \
  '-T[type]:type:(A I)' \
  '-S[stripe count]:n:' \
  '-r[recursive]' \
  '-active[active mode]' \
  '-passive[passive mode]' \
  '-keepalive=[keepalive timeout]:s:' \
  '-tcpbuf=[TCP buffer size]:bytes:' \
  '-bs=[block size]:bytes:' \
  '-c[command]:cmd:' \
  '-u[user]:user:_users' \
  '-pw[password]:pass:' \
  '-cred=[credential]:file:_files' \
  '-pwd=[password]:pass:' \
  '-mlsx[use MLSx commands]' \
  '*:host[port][/path]:' && ret=0
return ret
