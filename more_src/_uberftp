#compdef uberftp
# Documentation: https://raw.githubusercontent.com/JasonAlt/UberFTP/master/uberftp.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# uberftp: GridFTP-enabled client
local curcontext="$curcontext" ret=1
_arguments -C \
  '-P[port]:port:' \
  '-u[user]:user:_users' \
  '-p[password]:pass:' \
  '-active[active mode for data transfers]' \
  '-passive[passive mode for data transfers]' \
  '-ascii[ascii transfer mode]' \
  '-binary[binary transfer mode]' \
  '-blksize[internal buffer size in bytes]:n:' \
  '-parallel[parallel data channels for extended block transfers]:n:' \
  '-tcpbuf[TCP read/write buffer size in bytes]:n:' \
  '-pbsz[protection buffer size]:n:' \
  '-prot[data protection level]:level:(C S E P)' \
  '-cksum[CRC checksum]:mode:(on off)' \
  '-cos[HPSS class of service]:name:' \
  '-family[tape family name]:name:' \
  '-d[enable debugging (same as -debug 3)]' \
  '-debug[debug level (0-3)]:n:(0 1 2 3)' \
  '-glob[filename expansion]:mode:(on off)' \
  '-hash[print hash marks during transfers]' \
  '-keepalive[keepalive interval seconds]:n:' \
  '-mode[transfer mode]:mode:(E S)' \
  '-retry[retry count for transient errors]:n:' \
  '-resume[resume recursive transfer at path]:path:' \
  '-wait[wait for remote files to stage]' \
  '-v[print version]' \
  '-version[print UberFTP version]' \
  '-versions[print Globus module versions]' \
  '-cmds[print supported commands]' \
  '*:host[\:port][/path]:' && ret=0
return ret
