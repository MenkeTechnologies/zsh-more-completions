#compdef uberftp
# Documentation: https://www.mankier.com/1/uberftp
# Reference accessed: 2026-05-17
# Verified: mankier UberFTP(1) reference.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -T type and -S stripe-count and -r/-pw/-cred/-pwd/-mlsx
# top-level flags (real flags differ).

# uberftp: GridFTP-enabled client
local curcontext="$curcontext" ret=1
_arguments -C \
  '-P[port]:port:' \
  '-u[user]:user:_users' \
  '-p[password]:pass:' \
  '-active[active mode]' \
  '-passive[passive mode]' \
  '-ascii[ascii transfer]' \
  '-binary[binary transfer]' \
  '-blksize[block size]:n:' \
  '-parallel[parallel streams]:n:' \
  '-tcpbuf[TCP buffer size]:n:' \
  '-pbsz[PBSZ size]:n:' \
  '-prot[protection level]:level:(C S E P)' \
  '-cksum[checksum]:mode:(on off)' \
  '-cos[class of service]:name:' \
  '-family[address family]:name:' \
  '-debug[debug level]:n:' \
  '-glob[glob mode]:mode:(on off)' \
  '-hash[hash marks]' \
  '-keepalive[keepalive interval]:n:' \
  '-mode[transfer mode]:mode:(E S)' \
  '-retry[retry count]:n:' \
  '-resume[resume path]:path:' \
  '-wait[wait for server]' \
  '-v[show version]' \
  '-version[show version]' \
  '-versions[show all versions]' \
  '-cmds[enter command mode]' \
  '*:host[\:port][/path]:' && ret=0
return ret
