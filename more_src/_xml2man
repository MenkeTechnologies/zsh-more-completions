#compdef xml2man
# Documentation: https://www.manpagez.com/man/1/xml2man/
# Reference accessed: 2026-05-21
# Verified: upstream Apple HeaderDoc xml2man(1) manpage.

# Usage: xml2man [-f] filename [output_filename]
local -a arguments

arguments=(
    '-f[force overwrite of destination file]'
    '1:input XML file:_files -g "*.(xml|mxml)"'
    '2::output file:_files'
)

_arguments -s -S $arguments
