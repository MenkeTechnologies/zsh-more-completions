#compdef xml2man
# Documentation: https://man.archlinux.org/search?q=xml2man
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-s[Section number]:section:(1 2 3 4 5 6 7 8 9)'
    '-o[Output file]:output file:_files'
    '-h[Show help]'
    '*:XML file:_files -g "*.xml"'
)

_arguments -s -S $arguments
