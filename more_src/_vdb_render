#compdef vdb_render
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/vdb_render.1.html
# OpenVDB: ray-traces OpenVDB volumes

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print usage message]' \
  '-version[print version information]' \
  '-v[verbose; print timing and diagnostics]' \
  '-aperture=[perspective camera aperture in mm]:mm' \
  '-camera=[camera type]:type:(perspective ortho)' \
  '-compression=[EXR compression scheme]:scheme:(none rle zip)' \
  '-cpus=[number of rendering threads]:n' \
  '-far=[camera far plane depth]:depth' \
  '-focal=[perspective camera focal length in mm]:mm' \
  '-fov=[perspective camera field of view in degrees]:degrees' \
  '-frame=[ortho camera frame width in world units]:units' \
  '-lookat=[rotate the camera to point to X,Y,Z]:xyz' \
  '-name=[name of the volume to be rendered]:name' \
  '-near=[camera near plane depth]:depth' \
  '-res=[image dimensions in pixels WxH]:dims' \
  '(-rotate -r)'{-rotate,-r}'=[camera rotation in degrees X,Y,Z]:xyz' \
  '(-translate -t)'{-translate,-t}'=[camera translation X,Y,Z]:xyz' \
  '-up=[vector that should point up after rotation X,Y,Z]:xyz' \
  '-color=[name of a vec3s volume for material colors]:name' \
  '-isovalue=[isovalue in world units for level set ray intersection]:value' \
  '-samples=[number of samples per pixel]:n' \
  '-shader=[shader name]:shader:(diffuse matte normal position)' \
  '-absorb=[absorption coefficients R,G,B]:rgb' \
  '-cutoff=[density and transmittance cutoff value]:value' \
  '-gain=[amount of scatter along the shadow ray]:value' \
  '-light=[light source direction and optional color X,Y,Z\[,R,G,B\]]:light' \
  '-scatter=[scattering coefficients R,G,B]:rgb' \
  '-shadowstep=[step size in voxels for shadow ray integration]:value' \
  '-step=[step size in voxels for primary ray integration]:value' \
  '*:vdb file:_files -g "*.vdb"' && ret=0

return ret
