#compdef herbstclient

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-n[do not print trailing newline]' \
  '-0[use null char as delimiter]' \
  '-l[print last error status on stderr]' \
  '-i[wait for and print hook messages]' \
  '-c+[number of hooks to wait for]:count:' \
  '-q[be quiet; suppress output]' \
  '-w[print while waiting for hooks]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '--idle[wait for hooks (alias for -i)]' \
  '--wait+[wait for specific hook count]:count:' \
  '--no-newline[do not print trailing newline]' \
  '--quiet[be quiet]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'quit:quit herbstluftwm'
      'reload:reload autostart'
      'version:print version'
      'list_commands:list available commands'
      'list_monitors:list monitors'
      'list_keybinds:list key bindings'
      'list_rules:list window rules'
      'close:close focused window'
      'close_or_remove:close window or remove frame'
      'close_and_remove:close window and remove frame'
      'split:split current frame'
      'remove:remove current frame'
      'focus:change focus direction'
      'shift:shift window in direction'
      'resize:resize frame'
      'cycle:cycle through windows in frame'
      'cycle_all:cycle through all windows'
      'cycle_layout:cycle through frame layouts'
      'cycle_frame:cycle through frames'
      'cycle_monitor:cycle through monitors'
      'focus_monitor:focus a monitor'
      'use:switch to tag'
      'use_index:switch to tag by index'
      'use_previous:switch to previous tag'
      'tag_status:print tag status'
      'merge_tag:merge tag into another'
      'rename:rename a tag'
      'move:move window to tag'
      'move_index:move window to tag by index'
      'add:add a new tag'
      'keybind:bind a key'
      'keyunbind:unbind a key'
      'mousebind:bind a mouse button'
      'mouseunbind:unbind a mouse button'
      'spawn:spawn a command'
      'wmexec:replace WM with command'
      'chain:chain multiple commands'
      'and:logical AND chain'
      'or:logical OR chain'
      'not:logical NOT'
      'try:try command ignoring errors'
      'silent:run command silently'
      'emit_hook:emit a custom hook'
      'rule:add a window rule'
      'unrule:remove window rules'
      'apply_rules:apply rules to window'
      'set:set an attribute'
      'get:get an attribute'
      'toggle:toggle a boolean attribute'
      'attr:query attributes'
      'set_attr:set an attribute value'
      'get_attr:get an attribute value'
      'new_attr:create a user attribute'
      'remove_attr:remove a user attribute'
      'substitute:substitute attribute into command'
      'sprintf:sprintf-style command building'
      'monitor_rect:print monitor rectangle'
      'pad:set monitor padding'
      'layout:print frame layout'
      'load:load a frame layout'
      'dump:dump frame layout'
      'detect_monitors:auto-detect monitors'
      'add_monitor:add a monitor'
      'remove_monitor:remove a monitor'
      'move_monitor:move/resize a monitor'
      'raise_monitor:raise a monitor'
      'lock:lock screen updates'
      'unlock:unlock screen updates'
      'lock_tag:lock a tag to monitor'
      'unlock_tag:unlock a tag from monitor'
      'fullscreen:toggle fullscreen'
      'pseudotile:toggle pseudotile'
      'floating:toggle floating'
      'bring:bring window to current tag'
      'jumpto:jump to window'
      'watch:watch attribute changes'
      'compare:compare attribute value'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (focus|shift|resize)
        _values 'direction' left right up down
        ;;
      (split)
        _values 'split type' horizontal vertical top bottom left right explode auto
        ;;
      (use|move|merge_tag|rename)
        compadd $(herbstclient tag_status 2>/dev/null | tr '\t' '\n' | sed 's/^.//')
        ;;
      (cycle_layout)
        _values 'layout' vertical horizontal max grid
        ;;
      (set|get|toggle)
        compadd $(herbstclient list_settings 2>/dev/null | awk '{print $1}')
        ;;
      (focus_monitor|raise_monitor|remove_monitor|move_monitor)
        _message 'monitor index'
        ;;
      (spawn|wmexec)
        _command_names
        ;;
    esac
    ;;
esac

return ret
