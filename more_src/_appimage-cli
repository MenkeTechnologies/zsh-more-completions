#compdef appimage-cli appimagetool appimagelauncher
# _appimage-cli — AppImage portable Linux app format toolkit CLI alias (AppImage / probono, C); custom argparse
# upstream: https://github.com/AppImage/AppImageKit

_appimage-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[comp option]:c:(gzip xz lzo lz4 zstd)' \
        '--comp=+[squashfs compression]:c:(gzip xz lzo lz4 zstd)' \
        '--list[list AppImage contents]' \
        '-l[list AppImage contents]' \
        '--no-appstream[no appstream]' \
        '-n[no appstream]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--sign[sign with gpg]' \
        '-s[sign with gpg]' \
        '--sign-key=+[gpg key]:str:' \
        '--sign-args=+[gpg args]:str:' \
        '-g+[gpg args]:str:' \
        '--bintray-user=+[bintray user]:str:' \
        '-u+[bintray user]:str:' \
        '--bintray-repo=+[bintray repo]:str:' \
        '-r+[bintray repo]:str:' \
        '--version-from-changelog[version from changelog]' \
        '--guess[guess update info]' \
        '--no-update-info[no update info]' \
        '-U+[update info string]:str:' \
        '--updateinformation=+[update info string]:str:' \
        '--runtime-file=+[runtime file]:file:_files' \
        '--mksquashfs-opt=+[mksquashfs option]:str:' \
        '--appimage-extract-and-run[extract and run]' \
        '--appimage-extract[extract]' \
        '--appimage-mount[mount]' \
        '--appimage-offset[show offset]' \
        '--appimage-signature[show signature]' \
        '--appimage-updateinformation[show update info]' \
        '--appimage-portable-home[portable home]' \
        '--appimage-portable-config[portable config]' \
        '*:appdir-or-appimage:_files'
}

_appimage-cli "$@"
