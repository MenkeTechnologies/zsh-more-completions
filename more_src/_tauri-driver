#compdef tauri-driver
# Documentation: https://github.com/tauri-apps/tauri/blob/dev/crates/tauri-driver/src/cli.rs
# Cross-platform WebDriver server for Tauri applications

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[prints help information]' \
  '--port=[set the tauri-driver intermediary port]:port' \
  '--native-port=[set the port of the underlying WebDriver]:port' \
  '--native-host=[set the host of the underlying WebDriver (Linux only)]:host' \
  '--native-driver=[set the path to the native WebDriver binary]:path:_files' && ret=0

return ret
