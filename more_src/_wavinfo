#compdef wavinfo
# Documentation: https://wavinfo.readthedocs.io/en/latest/command_line.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '(-i --ixml --adm)-i[interactive mode]'
    '(-i --ixml --adm)--ixml[print iXML metadata payload]'
    '(-i --ixml --adm)--adm[print ADM XML metadata payload]'
    '*:WAV file:_files -g "*.(wav|WAV)"'
)

_arguments -s -S $arguments
