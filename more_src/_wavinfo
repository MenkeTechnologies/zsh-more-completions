#compdef wavinfo
# Documentation: https://wavinfo.readthedocs.io/en/latest/command_line.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '-h[Show help message]'
    '--help[Show help message]'
    '-v[Verbose output]'
    '--verbose[Verbose output]'
    '-j[Output as JSON]'
    '--json[Output as JSON]'
    '*:WAV file:_files -g "*.wav"'
)

_arguments -s -S $arguments
