#compdef symilar
# Documentation: https://pylint.readthedocs.io/en/stable/additional_tools/symilar/index.html
# Reference accessed: 2026-05-21
# Verified: upstream pylint symilar source
# (raw.githubusercontent.com/PyCQA/pylint/main/pylint/checkers/symilar.py).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --duplicates)'{-d+,--duplicates=}'[minimum number of similar lines (default 4)]:n:' \
  '(-i --ignore-comments)'{-i,--ignore-comments}'[ignore comments]' \
  '--ignore-docstrings[ignore docstrings]' \
  '--ignore-imports[ignore imports]' \
  '--ignore-signatures[ignore function signatures]' \
  '*:Python file:_files -g "*.py"' && ret=0

return ret
