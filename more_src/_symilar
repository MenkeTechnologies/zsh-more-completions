#compdef symilar

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-d+,--duplicates=}'[minimum duplicate lines threshold]:n:' \
  {-i,--ignore-comments}'[ignore comments]' \
  {-i,--ignore-docstrings}'[ignore docstrings]' \
  {-i,--ignore-imports}'[ignore imports]' \
  '*:Python file:_files -g "*.py"' && ret=0

return ret
