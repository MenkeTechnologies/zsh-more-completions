#compdef symilar
# Documentation: https://pylint.readthedocs.io/en/latest/additional_tools/symilar/index.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-d+,--duplicates=}'[minimum duplicate lines threshold]:n:' \
  {-i,--ignore-comments}'[ignore comments]' \
  {-i,--ignore-docstrings}'[ignore docstrings]' \
  {-i,--ignore-imports}'[ignore imports]' \
  '*:Python file:_files -g "*.py"' && ret=0

return ret
