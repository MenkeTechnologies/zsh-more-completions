#compdef e
# Documentation: https://github.com/electron/build-tools
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# electron/build-tools `e` CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'init:create a new build configuration and initialize a GN directory'
      'sync:fetch or update the source tree'
      'build:build an Electron executable'
      'start:execute the local Electron build'
      'node:run the build as Node.js'
      'debug:launch in a debugger (lldb/gdb)'
      'test:start the test runner'
      'npm:execute npm commands with local Electron'
      'show:display build configuration information'
      'shell:launch an environment shell with proper variables'
      'patches:refresh patches for various targets'
      'open:access GitHub pages for commits/PRs'
      'pr:work with pull requests'
      'backport:assist with manual backports'
      'cherry-pick:cherry-pick upstream changes into patches'
      'rcv:reconstruct intermediate Chromium versions'
      'use:switch the active build configuration'
      'remove:delete a build configuration'
      'sanitize-config:update configs to the latest schema'
      'worktree:manage additional working directories'
      'load-macos-sdk:download required macOS SDKs'
      'depot-tools:run depot-tools commands'
      'gh-auth:generate GitHub OAuth tokens'
      'auto-update:manage build-tools updates'
      'help:show help'
    )
    _describe -t commands 'e command' commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
