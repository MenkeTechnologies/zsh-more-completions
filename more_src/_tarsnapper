#compdef tarsnapper

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'make:create new backup and expire old'
  'expire:delete old backups'
  'list:list backups'
)

_arguments -C \
  '-q[quiet]' \
  '-v[verbose]' \
  '*-o=[tarsnap option]:option:' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '--target=[target filename]:name:' \
  '*--sources=[source path]:path:_files' \
  '*'{-d,--deltas}'=[deltas]:delta:' \
  '(-f --dateformat)'{-f,--dateformat}'=[date format]:fmt:' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'tarsnapper subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (make)
        _arguments -s \
          '--dry-run[simulate]' \
          '--no-expire[no expire]' \
          '*:job:' && ret=0 ;;
      (expire)
        _arguments -s \
          '--dry-run[simulate]' \
          '*:job:' && ret=0 ;;
      (list) _arguments '*:job:' && ret=0 ;;
    esac
    ;;
esac

return ret
