#compdef cipherscan
# _cipherscan — TLS cipher tester via openssl s_client (mozilla/cipherscan)
# upstream: https://github.com/mozilla/cipherscan
# Flags from cipherscan usage().

_cipherscan() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-a --allciphers)'{-a,--allciphers}'[test each known cipher individually]' \
        '(-b --benchmark)'{-b,--benchmark}'[activate benchmark mode]' \
        '--capath=[CA path (OpenSSL CAdir)]:dir:_files -/' \
        '--saveca[save intermediate certs in CA dir]' \
        '--savecrt=[save untrusted+leaf certs here]:dir:_files -/' \
        '(-d --delay)'{-d+,--delay=}'[pause between connections (s)]:secs:' \
        '(-D --debug)'{-D,--debug}'[verbose debug output]' \
        '(-j --json)'{-j,--json}'[output JSON]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-o --openssl)'{-o+,--openssl=}'[path to openssl binary]:file:_files' \
        '--curves[test ECC curves supported by server]' \
        '--no-curves[skip ECC curve test]' \
        '--sigalg[test TLSv1.2 ephemeral signature algorithms]' \
        '1:target[:port]:_hosts'
}

_cipherscan "$@"
