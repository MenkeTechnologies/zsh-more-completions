#compdef cargo-watt
# Documentation: https://crates.io/crates/cargo-watt
# build proc-macro crates as WebAssembly for the watt runtime

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--git[input git repository]:url' \
  '--crate[input crates.io crate]:crate' \
  '--no-wasm-strip[do not run wasm-strip on the output]' \
  '--no-wasm-opt[do not run wasm-opt on the output]' \
  '--compress[compress the wasm output]' \
  '-o[output directory]:dir:_files -/' \
  '--only-copy-essential[copy only Cargo.toml and src/* to new crate]' \
  '--overwrite[overwrite existing output]' \
  '--keep-tmp[do not delete the temporary build directory]' \
  '1:command:(build verify patch)' \
  '*::arg:_files' && ret=0

return ret
