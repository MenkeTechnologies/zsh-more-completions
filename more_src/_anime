_anime() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-C --dir)'{-C,--dir}'[specify the configuration directory]:path:_directories' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'watch:pull download upload all anime resources (continuous loop)'
        'push:pull download upload anime resources (one-shot)'
        'pull:sync storage state to local (no downloads)'
        'download:[WIP] download a specific resource from URL'
        'subject:manage watched subjects (anime entries)'
        'storage:manage storage backends (S3/WebDAV/aliyundrive/local)'
        'bangumi:Bangumi.tv search + import'
        'animegarden:AnimeGarden BT resource search'
        'tui:interactive terminal UI'
      )
      _describe -t subcommands 'anime subcommand' subcmds
      ;;
    args)
      case "${words[1]}" in
        watch|push|pull)
          _arguments -s -S \
            '(-n --name)'{-n,--name}'[filter by target anime name]:name:' \
            '--bgm[filter by Bangumi entry ID]:id:'
          ;;
        download)
          _arguments -s -S \
            ':url:'
          ;;
        subject)
          local -a subjectsubs
          subjectsubs=(
            'upload:[WIP] manually upload anime resources'
            'list:list subjects in watch list'
            'add:add a subject to watch list'
            'remove:remove a subject from watch list'
          )
          _describe -t subcommands 'subject subcommand' subjectsubs
          ;;
        storage)
          local -a storagesubs
          storagesubs=(
            'list:list configured storage backends'
            'get:get details of a specific storage'
            'put:add or update a storage config'
            'remove:remove a storage config'
            'move:move resources between storages'
          )
          _describe -t subcommands 'storage subcommand' storagesubs
          ;;
        bangumi)
          local -a bangumisubs
          bangumisubs=(
            'search:search Bangumi.tv for anime'
            'import:import Bangumi.tv watching collection'
          )
          _describe -t subcommands 'bangumi subcommand' bangumisubs
          ;;
        animegarden)
          local -a gardensubs
          gardensubs=('search:search AnimeGarden for BT resources')
          _describe -t subcommands 'animegarden subcommand' gardensubs
          ;;
      esac
      ;;
  esac
}

_anime "$@"
