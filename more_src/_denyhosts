#compdef denyhosts denyhosts.py
# Documentation: https://man.archlinux.org/search?q=denyhosts
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--version[show version]' \
  '-f+[log file]:file:_files' \
  '-c+[config file]:file:_files' \
  '-l+[log level]:level:(DEBUG INFO WARN ERROR CRITICAL)' \
  '-i[ignore hosts file]' \
  '-n[do not detach (foreground)]' \
  '--daemon[run as daemon]' \
  '--purge[purge expired bans]' \
  '--purge-all[purge all bans]' \
  '--migrate[migrate to current format]' \
  '--upgrade[upgrade plugins]' \
  '--sync[sync now]' \
  '--noemail[do not send email]' \
  '--debug[debug mode]' \
  '--verbose[verbose]' \
  '--version[show version]' \
  '--unlock[unlock host]' \
  '--add[add host to deny]:host:_hosts' && ret=0

return ret
