#compdef denyhosts denyhosts.py
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man8/denyhosts.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-f+[log file]:file:_files' \
  '-c+[config file]:file:_files' \
  '-l+[log level]:level:(DEBUG INFO WARN ERROR CRITICAL)' \
  '-i[ignore hosts file]' \
  '-n[do not detach (foreground)]' \
  '--daemon[run as daemon]' \
  '--purge[expire entries older than PURGE_DENY]' \
  '--purge-all[expire all entries]' \
  '--purgeip=[expire designated IP]:ip' \
  '--migrate[migrate HOSTS_DENY for --purge]' \
  '--upgrade099[upgrade from 0.9.9 format]' \
  '--sync[sync now]' \
  '--noemail[do not send email]' \
  '--debug[debug mode]' \
  '--verbose[verbose]' \
  '--unlock[unlock host]' \
  '--add[add host to deny]:host:_hosts' && ret=0

return ret
