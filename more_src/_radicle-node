#compdef radicle-node
# _radicle-node — Radicle peer-to-peer code-collaboration node daemon (Git replication + gossip protocol over noise/yamux)
# upstream: https://github.com/radicle-dev/heartwood
# Flags from crates/radicle-node/src/main.rs on tip (lexopt parser).

_radicle-node() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)-h[show help]' \
        '(- *)--version[show version and exit]' \
        '--config=[config file]:file:_files' \
        '--secret=[secret key file]:file:_files' \
        '--force[start even if a control socket already exists]' \
        '*--listen=[listen address (repeatable)]:addr:' \
        '--log-level=[log level]:level:(trace debug info warn error)' \
        '--log-logger=[logger implementation]:logger:(radicle structured systemd)' \
        '--log-format=[log format]:fmt:(json)'
}

_radicle-node "$@"
