#compdef autopsy-cli
# Documentation: https://man.archlinux.org/search?q=autopsy-cli
# Reference accessed: 2026-05-16

# Autopsy CLI: Sleuth Kit forensic GUI (CLI front-end)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[run as daemon]' \
  '-p[port]:port:' \
  '-x[host directory]:dir:_files -/' \
  '*::autopsy-cli args:_files' && ret=0
return ret
