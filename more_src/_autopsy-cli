#compdef autopsy-cli
# Documentation: https://sleuthkit.org/autopsy/docs/user-docs/4.14.0/command_line_ingest_page.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Autopsy CLI: Sleuth Kit forensic GUI (CLI front-end)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[run as daemon]' \
  '-p[port]:port:' \
  '-x[host directory]:dir:_files -/' \
  '*::autopsy-cli args:_files' && ret=0
return ret
