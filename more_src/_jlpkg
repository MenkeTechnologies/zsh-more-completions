#compdef jlpkg
# Documentation: https://github.com/fredrikekre/jlpkg
# jlpkg - a command line interface (CLI) for Pkg, Julia's package manager

local ret=1

_arguments -s -S \
  '(-h --help)--help[show the help message]' \
  '--version[show jlpkg and julia version numbers]' \
  '--project=-[set the home project/environment]::path:_files -/' \
  '--julia=[path to, or command for, the Julia executable]:path:_files' \
  '--update[allow subsequent commands to update package registries]' \
  '--offline[enable Pkg offline mode (requires Julia 1.5+)]' \
  '*:pkg command:(add build compat develop free generate pin remove test update activate gc help instantiate precompile resolve status registry)' && ret=0

return ret
