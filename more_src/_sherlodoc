#compdef sherlodoc
# _sherlodoc — OCaml documentation search engine by name and type (art-w/sherlodoc)
# upstream: https://github.com/art-w/sherlodoc
# Subcommands from cli/main.ml (cmdliner Cmd.group).

_sherlodoc() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '--format=[database format]:format:(marshal ancient bin_prot)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                search:'command-line search against an indexed database'
                index:'index odocl files to create a Sherlodoc database'
                serve:'webserver interface to a database'
                js:'emit sherlodoc compiled as javascript'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                search)
                    _arguments \
                        '--db=[database file to query]:file:_files' \
                        '(-n --limit)'{-n+,--limit=}'[maximum number of results per query]:n:' \
                        '--print-cost[print cost of each result]' \
                        '--print-time[print search time]' \
                        '--static-sort[disable dynamic sort]' \
                        '--no-rhs[suppress right-hand side of results]' \
                        '--no-right-hand-side[suppress right-hand side of results]' \
                        '--pretty-query[print parsed query]' \
                        '--print-docstring-html[print HTML docstring of results]' \
                        '1:query:' ;;
                index|serve)
                    _arguments \
                        '(-o --db)'{-o+,--db=}'[output/input database file]:file:_files' ;;
                js)
                    _arguments '1:output js file:_files' ;;
            esac
            ;;
    esac
}

_sherlodoc "$@"
