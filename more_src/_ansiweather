#compdef ansiweather

_arguments -s -S \
  '(-l)-l=[location name or coordinates]:location:' \
  '(-u)-u=[temperature units]:units:(metric imperial US)' \
  '(-f)-f=[forecast number of days]:days:' \
  -F'[shorthand for five-day forecast]' \
  '(-H)-H=[show feels-like temperature]:bool:(true false)' \
  '(-a)-a=[ANSI colorization]:bool:(true false)' \
  '(-s)-s=[weather symbol display]:bool:(true false)' \
  '(-k)-k=[OpenWeatherMap API key]:key:' \
  '(-i)-i=[show UV index]:bool:(true false)' \
  '(-w)-w=[show wind conditions]:bool:(true false)' \
  '(-h)-h=[show relative humidity]:bool:(true false)' \
  '(-p)-p=[show atmospheric pressure]:bool:(true false)' \
  '(-d)-d=[show daylight information]:bool:(true false)' \
  -v'[print ansiweather version]'
