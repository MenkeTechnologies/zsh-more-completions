#compdef msrtool
# Documentation: https://github.com/coreboot/coreboot/blob/master/util/msrtool/msrtool.c
# coreboot MSR (Model-Specific Register) decode tool

local ret=1

_arguments -s -S \
  '-h[show help text]' \
  '-q[be quiet (overrides -v)]' \
  '-v[be verbose]' \
  '-r[include reserved values]' \
  '-k[list all known systems and targets]' \
  '-l[list MSRs and bit fields for current target]' \
  '-c[access MSRs on the specified CPU]:cpu:' \
  '-m[force a system]:system:' \
  '*-t[force a target]:target:' \
  '-i[immediate mode: decode hex addr=hi:lo]:value:' \
  '-s[stream mode: read one MSR address per line]' \
  '-d[diff mode: read one address and value per line]' \
  '*:address:' && ret=0

return ret
