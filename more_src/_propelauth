#compdef propelauth

_propelauth() {
    local line state
    local -a commands
    commands=(
        'login:Login to PropelAuth'
        'logout:Logout from PropelAuth'
        'setup:Setup PropelAuth in your project'
        'set-default-project:Set default project'
        'users:Manage users'
        'organizations:Manage organizations'
        'api-keys:Manage API keys'
        'config:Manage configuration'
        'env:Manage environment variables'
        'help:Show help'
    )

    _arguments -C \
        '(-f --framework)'{-f,--framework}'[Specify framework]:framework:(nextjs-app nextjs-pages)' \
        '(-V --version)'{-V,--version}'[Show version]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'propelauth command' commands
            ;;
        args)
            case $line[1] in
                users)
                    _arguments '1:subcommand:(create get update delete)'
                    ;;
                organizations)
                    _arguments '1:subcommand:(create add-user delete)'
                    ;;
            esac
            ;;
    esac
}

_propelauth "$@"
