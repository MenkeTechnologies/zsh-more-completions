#compdef enlightenment_start
# Documentation: https://man.archlinux.org/search?q=enlightenment_start
# Reference accessed: 2026-05-16

# enlightenment_start: launcher that runs enlightenment with recovery loop
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::enlightenment_start args:_files' && ret=0
return ret
