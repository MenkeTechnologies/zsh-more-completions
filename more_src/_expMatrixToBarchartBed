#compdef expMatrixToBarchartBed
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# convert an expression matrix into a barChart bed6+5 file

local ret=1

_arguments -s -S \
  '--autoSql=[autoSql description file for extra fields in input bed]:file:_files' \
  '--groupOrderFile=[single-column file specifying group display order]:file:_files' \
  '--useMean[calculate group values using mean instead of median]' \
  '--verbose[display runtime messages]' \
  '1:sample file:_files' \
  '2:matrix file:_files' \
  '3:bed file:_files -g "*.bed"' \
  '4:output file:_files' && ret=0

return ret
