#compdef kamailio

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-D[run in foreground (no daemon)]' \
  '-E[log to stderr]' \
  '-f+[main config file]:file:_files -g "*.cfg"' \
  '-c[check config and exit]' \
  '-l+[listen address]:addr:' \
  '*-n+[number of worker processes]:n:' \
  '-N+[per-listener children]:n:' \
  '-T[disable TCP]' \
  '-S[disable SCTP]' \
  '-w+[working dir]:dir:_files -/' \
  '-Y+[runtime dir]:dir:_files -/' \
  '-u+[user]:user:_users' \
  '-g+[group]:group:_groups' \
  '-P+[PID file]:file:_files' \
  '-p+[pre-cache script]:script:_files' \
  '-A+[set ID]:id:' \
  '-b+[max receive buffer]:n:' \
  '-e[enable replication]' \
  '-r[require cache]' \
  '-x+[debug level]:n:' \
  '-X[detailed memory debug]' \
  '-v[show config and exit]' \
  '-d+[debug level]:n:' \
  '-O+[script optimizer level]:n:(0 1 2)' \
  '-a+[auto aliases]:mode:(yes no)' \
  '-K+[serialize commands per worker]:bool:(0 1)' \
  '-S+[disable SCTP]:bool:(0 1)' \
  '-G+[group ID]:gid:' \
  '*::passthrough:' && ret=0

return ret
