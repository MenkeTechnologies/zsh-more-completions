#compdef vue

# Zsh completion for Vue CLI

_vue-cli() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'create:create a new project powered by vue-cli-service'
    'add:install a plugin and invoke its generator in an already created project'
    'invoke:invoke the generator of a plugin in an already created project'
    'inspect:inspect the webpack config in a project with vue-cli-service'
    'serve:serve a .js or .vue file in development mode with zero config'
    'build:build a .js or .vue file in production mode with zero config'
    'ui:start and open the vue-cli ui'
    'init:generate a project from a remote template (legacy API)'
    'config:inspect and modify the config'
    'outdated:check for outdated vue cli service / plugins'
    'upgrade:upgrade vue cli service / plugins'
    'migrate:run migrator for an already-installed cli plugin'
    'info:print debugging information about your environment'
    'help:display help for a command'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'vue command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        create)
          _arguments -s -S \
            '(-p --preset)'{-p,--preset}'[skip prompts and use saved/remote preset]:preset:' \
            '(-d --default)'{-d,--default}'[skip prompts and use default preset]' \
            '(-i --inlinePreset)'{-i,--inlinePreset}'[skip prompts and use inline JSON preset]:JSON:' \
            '(-m --packageManager)'{-m,--packageManager}'[package manager]:manager:(npm yarn pnpm)' \
            '(-r --registry)'{-r,--registry}'[use specified npm registry]:registry URL:' \
            '(-g --git)'{-g,--git}'[force git initialization with initial commit]:commit message:' \
            '(-n --no-git)'{-n,--no-git}'[skip git initialization]' \
            '(-f --force)'{-f,--force}'[overwrite target directory if it exists]' \
            '--merge[merge target directory if it exists]' \
            '(-c --clone)'{-c,--clone}'[use git clone when fetching remote preset]' \
            '(-x --proxy)'{-x,--proxy}'[use HTTP proxy]:proxy URL:' \
            '(-b --bare)'{-b,--bare}'[scaffold without beginner instructions]' \
            '--skipGetStarted[skip "Get started" instructions]' \
            '1:project name:' \
            && ret=0
          ;;
        add)
          _arguments -s -S \
            '--registry=[use specified npm registry]:registry URL:' \
            '1:plugin:' \
            && ret=0
          ;;
        serve)
          _arguments -s -S \
            '--open[open browser]' \
            '--copy[copy URL to clipboard]' \
            '--https[use HTTPS]' \
            '1:entry file:_files -g "*.{js,vue}"' \
            && ret=0
          ;;
        build)
          _arguments -s -S \
            '-t+[build target]:target:(app lib wc wc-async)' \
            '--target=[build target]:target:(app lib wc wc-async)' \
            '-n+[library name]:name:' \
            '--name=[library name]:name:' \
            '--dest=[output directory]:directory:_files -/' \
            '--no-clean[do not remove dist directory before build]' \
            '1:entry file:_files -g "*.{js,vue}"' \
            && ret=0
          ;;
        ui)
          _arguments -s -S \
            '(-H --host)'{-H,--host}'[host]:host:_hosts' \
            '(-p --port)'{-p,--port}'[port]:port:' \
            '(-D --dev)'{-D,--dev}'[run in dev mode]' \
            '--headless[run without GUI]' \
            && ret=0
          ;;
        inspect)
          _arguments -s -S \
            '--mode=[inspect mode]:mode:(development production)' \
            '--rule=[inspect rule]:rule:' \
            '--plugin=[inspect plugin]:plugin:' \
            '--rules[list all rules]' \
            '--plugins[list all plugins]' \
            '-v[verbose]' \
            '--verbose[verbose]' \
            && ret=0
          ;;
        upgrade)
          _arguments -s -S \
            '-t+[upgrade to specified version]:version:' \
            '--to=[upgrade to specified version]:version:' \
            '-f[skip prompts]' \
            '--from=[skip confirmation for upgrades from version]:version:' \
            '--all[upgrade all plugins]' \
            '--next[check for alpha/beta/rc versions]' \
            '1:plugin:' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_vue-cli "$@"
