#compdef ocioperf
# measure the performance of OCIO color transforms

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--displayview[measure a display/view transform]:display: :view: :name:' \
  '--colorspaces[source and destination colorspaces]:src: :dst:' \
  '--transform=[external transform file]:file:_files' \
  '--image=[test image file]:file:_files' \
  '--iter=[number of test iterations]:count:' \
  '--test=[test type (per-pixel, line, or full image)]:test:' \
  '--out=[output data format]:format:' && ret=0

return ret
