#compdef SkylineCmd SkylineRunner
# Documentation: https://skyline.ms/_webdav/home/software/Skyline/@files/docs/Skyline%20Command-Line%20Interface-3_5.pdf
# Skyline: command-line interface for targeted proteomics documents

local ret=1

_arguments -s -S \
  '--in=[open a Skyline document]:file:_files' \
  '--out=[save the document to a file]:file:_files' \
  '--save[save changes to the open document]' \
  '--dir=[default root directory for path arguments]:dir:_files -/' \
  '--timestamp[prepend time/date to logging output]' \
  '--memstamp[prepend memory usage to logging output]' \
  '--log-file=[direct logged output to a file]:file:_files' \
  '--version[display version information]' \
  '--import-file=[import a replicate data file]:file:_files' \
  '--import-replicate-name=[name the new replicate]:name:' \
  '--import-all=[import all files/subfolders from a directory]:dir:_files -/' \
  '--import-fasta=[import a FASTA file]:file:_files' \
  '--import-transition-list=[import a transition list]:file:_files' \
  '--import-search-file=[import peptide search results]:file:_files' \
  '--report-name=[name of the report to export]:name:' \
  '--report-file=[report export destination]:file:_files' \
  '--report-format=[report output format]:format:(csv tsv)' \
  '--report-add=[add reports from a skyr template]:file:_files' \
  '--report-conflict-resolution=[handle report name conflicts]:mode:(overwrite skip)' \
  '--batch-commands=[execute commands line-by-line from a file]:file:_files' \
  '*:file:_files' && ret=0

return ret
