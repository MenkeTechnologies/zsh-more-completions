#compdef pflask

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --chroot)'{-c+,--chroot=}'[chroot directory]:dir:_files -/' \
  '(-r --root)'{-r+,--root=}'[root directory]:dir:_files -/' \
  '(-u --user)'{-u+,--user=}'[user inside container]:user:_users' \
  '(-w --chdir)'{-w+,--chdir=}'[working directory]:dir:_files -/' \
  '(-d --detach)'{-d,--detach}'[detach from current terminal]' \
  '(-a --attach)'{-a+,--attach=}'[attach to detached container]:pid:' \
  '(-s --setenv)*'{-s+,--setenv=}'[set env var]:var:' \
  '(-m --mount)*'{-m+,--mount=}'[mount type:src:dst[:opts]]:mount:' \
  '(-n --netif)'{-n,--netif}'[disconnect networking]' \
  '(-N --netif-name)'{-N+,--netif-name=}'[move netif into container]:iface:' \
  '(-g --cgroup)*'{-g+,--cgroup=}'[cgroup name]:cgroup:' \
  '(-U --no-userns)'{-U,--no-userns}'[disable user namespace]' \
  '(-M --no-mountns)'{-M,--no-mountns}'[disable mount namespace]' \
  '(-T --no-netns)'{-T,--no-netns}'[disable network namespace]' \
  '(-I --no-ipcns)'{-I,--no-ipcns}'[disable IPC namespace]' \
  '(-O --no-utsns)'{-O,--no-utsns}'[disable UTS namespace]' \
  '(-P --no-pidns)'{-P,--no-pidns}'[disable PID namespace]' \
  '(-e --ephemeral)'{-e,--ephemeral}'[ephemeral rootfs (overlay)]' \
  '(-i --inherit-env)'{-i,--inherit-env}'[inherit env vars]' \
  '*:: command :_command_names' && ret=0

return ret
