#compdef yuzu
# Documentation: (none - project was DMCA'd from GitHub 2024-03; no Debian manpage)
# Reference accessed: 2026-05-16
# Verified: manpages.debian.org/sid/yuzu/yuzu.6.en.html returns 404;
# manpages.ubuntu.com/manpages/jammy/man6/yuzu.6.html returns 404; original
# GitHub source DMCA'd. Tool kept per "do not delete files" directive with
# conservative completion only - Qt parser standard flags.

# yuzu: discontinued Nintendo Switch emulator (project ended 2024-03)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '*:Switch ROM:_files -g "*.(nsp|xci|nca|nso|nro)"' && ret=0
return ret
