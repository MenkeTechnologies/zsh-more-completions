#compdef iwasm
# Documentation: https://github.com/bytecodealliance/wasm-micro-runtime/blob/main/product-mini/platforms/posix/main.c
# iwasm - WebAssembly Micro Runtime (WAMR) command-line runtime

local ret=1

_arguments -s -S \
  '(-f --function)'{-f,--function}'[run named function rather than main]:function name' \
  '-v=[set log verbose level (0 to 5, default is 2)]:level' \
  '--interp[run the wasm app with interpreter mode]' \
  '--fast-jit[run the wasm app with fast jit mode]' \
  '--llvm-jit[run the wasm app with llvm jit mode]' \
  '--multi-tier-jit[run the wasm app with multi-tier jit mode]' \
  '--stack-size=[set maximum stack size in bytes (default 64 KB)]:bytes' \
  '--heap-size=[set maximum heap size in bytes]:bytes' \
  '--shared-heap-size=[create shared heap of n bytes and attach to the wasm app]:bytes' \
  '--jit-codecache-size=[set fast jit maximum code cache size in bytes]:bytes' \
  '--gc-heap-size=[set maximum gc heap size in bytes]:bytes' \
  '--llvm-jit-size-level=[set LLVM JIT size level (default 3)]:level' \
  '--llvm-jit-opt-level=[set LLVM JIT optimization level (default 3)]:level' \
  '--enable-segue[use segment register GS as base address of linear memory]' \
  '--enable-linux-perf[enable linux perf support (aot and llvm-jit)]' \
  '--repl[start a very simple REPL (read-eval-print-loop) mode]' \
  '--disable-bounds-checks[disable bounds checks for memory accesses]' \
  '*--env=[pass wasi environment variable key=value to the program]:key=value' \
  '*--dir=[grant wasi access to the given host directory]:dir:_files -/' \
  '*--addr-pool=[grant wasi access to the given network addresses]:addr' \
  '*--allow-resolve=[allow wasi network name resolution for the given domain]:domain' \
  '--native-lib=[register native libraries to the WASM module]:lib:_files' \
  '--module-path=[indicate a module search path (default current directory)]:path:_files -/' \
  '--max-threads=[set maximum thread number per cluster (default 4)]:n' \
  '--timeout=[set the maximum execution time in ms]:ms' \
  '-g=[set the debug server address (ip:port), default disabled]:ip:port' \
  '--gen-prof-file=[generate LLVM PGO profile file]:path:_files' \
  '--version[show version information]' \
  '*:wasm file:_files -g "*.wasm *.aot"' && ret=0

return ret
