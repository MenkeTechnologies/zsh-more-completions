#compdef tracetop
# Documentation: https://manpages.debian.org/testing/libtrace-tools/tracetop.1.en.html
# show top flows in a libtrace trace

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-H --libtrace-help)'{-H,--libtrace-help}'[display libtrace help]' \
  '(-f --filter)'{-f+,--filter=}'[count only packets that match the tcpdump style bpf filter]:bpf filter' \
  '(-s --snaplen)'{-s+,--snaplen=}'[snap length]:snaplen' \
  '(-p --promisc)'{-p+,--promisc=}'[promiscuous mode]:promisc' \
  '(-i --interval)'{-i+,--interval=}'[wait interval seconds between updates]:interval' \
  '--bits-per-second[display flow bandwidth as the number of bits per second]' \
  '--percent[display flow bytes and packets as a percentage of total traffic]' \
  '(-w --wide)'{-w,--wide}'[expand the display to fit IPv6 addresses]' \
  '*:uri:_files' && ret=0

return ret
