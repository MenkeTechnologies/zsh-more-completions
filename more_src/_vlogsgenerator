#compdef vlogsgenerator
# _vlogsgenerator — VictoriaLogs synthetic log generator (writes generated streams to stdout or an HTTP ingestion endpoint for load testing)
# upstream: https://github.com/VictoriaMetrics/VictoriaLogs
# Flags from app/vlogsgenerator/main.go on tip; all flags also bindable via VL_<flag> env.

_vlogsgenerator() {
    _arguments \
        '(- *)'{-h,-help,--help}'[show help]' \
        '-addr=[HTTP ingestion URL or "stdout"]:dest:' \
        '-workers=[number of parallel workers]:n:' \
        '-activeStreams=[active log streams to generate]:n:' \
        '-totalStreams=[total log streams (0 = same as -activeStreams)]:n:' \
        '-logsPerStream=[log entries per stream]:n:' \
        '-constFieldsPerLog=[constant-value fields per entry]:n:' \
        '-varFieldsPerLog=[unique-value fields per entry]:n:' \
        '-dictFieldsPerLog=[low-cardinality (<=8) fields per entry]:n:' \
        '-u8FieldsPerLog=[uint8 fields per entry]:n:' \
        '-u16FieldsPerLog=[uint16 fields per entry]:n:' \
        '-u32FieldsPerLog=[uint32 fields per entry]:n:' \
        '-u64FieldsPerLog=[uint64 fields per entry]:n:' \
        '-i64FieldsPerLog=[int64 fields per entry]:n:' \
        '-floatFieldsPerLog=[float64 fields per entry]:n:' \
        '-ipFieldsPerLog=[IPv4 fields per entry]:n:' \
        '-timestampFieldsPerLog=[ISO8601 timestamp fields per entry]:n:' \
        '-jsonFieldsPerLog=[JSON-object fields per entry]:n:' \
        '-start=[generation window start (RFC3339)]:ts:' \
        '-end=[generation window end (RFC3339)]:ts:' \
        '-statInterval=[stats publishing interval]:dur:' \
        '-version[show version and exit]'
}

_vlogsgenerator "$@"
