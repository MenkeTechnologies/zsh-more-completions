#compdef clang-tidy-cache

# Zsh completion for clang-tidy-cache - caching wrapper for clang-tidy

local -a arguments

arguments=(
  '--version[show version]'
  '-h[show help information]'
  '--help[show help information]'
  '--show-stats[show cache statistics]'
  '--clear-stats[clear cache statistics]'
  '--no-cache[disable caching for this run]'
  '*::clang-tidy args:_normal'
)

_arguments -s $arguments
