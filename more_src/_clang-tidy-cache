#compdef clang-tidy-cache
# Documentation: https://github.com/matus-chochlik/ctcache
# Reference accessed: 2026-05-17
# Verified: matus-chochlik/ctcache upstream — pure wrapper around
# clang-tidy. Has no flag surface of its own; all arguments after
# the real-clang-tidy binary path are passed through to clang-tidy.
# Configuration is via environment variables (CTCACHE_DIR,
# CTCACHE_HOST, CTCACHE_PORT, CTCACHE_DISABLE, CTCACHE_DUMP,
# CTCACHE_STRIP, CTCACHE_CLANG_TIDY).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --version, -h/--help, --show-stats, --clear-stats,
# --no-cache (none exist on ctcache itself).

local ret=1
_arguments -s -S \
  '1:real clang-tidy binary:_command_names -e' \
  '*::clang-tidy args:_normal' && ret=0
return ret
