#compdef maprot
# Documentation: https://www.ccp4.ac.uk/html/maprot.html
# CCP4: skew, rotate, average, and correlate electron-density maps

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'MAPIN[input crystal map]:map:_files -g "*.(map|ccp4)"' \
  'WRKIN[input starting work-map density]:map:_files -g "*.(map|ccp4)"' \
  'MSKIN[input mask for work map]:mask:_files' \
  'MAPOUT[output crystal map]:map:_files' \
  'WRKOUT[output work map with rotated density]:map:_files' \
  'CUTOUT[output map from density cutting]:map:_files' \
  '*:keyword:(MODE AVERAGE CELL GRID XYZLIM SYMMETRY SCALE RADIUS INVERT END)' && ret=0

return ret
