#compdef cql2csv cql2json
# Documentation: https://github.com/tenmax/cqlkit
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# tenmax/cqlkit ships two binaries: cql2csv and cql2json.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[contact points (comma separated)]:host:' \
  '-r+[Cassandra port]:port:' \
  {-q,--query=}'+[CQL query]:query:' \
  '-k+[keyspace]:keyspace:' \
  '-u+[username]:user:' \
  '-p+[password]:password:' \
  {-H,--no-header-row}'[omit header row]' \
  {-l,--linenumbers}'[add line number column]' \
  '(-P --parallel)'{-P+,--parallel=}'[parallelism level]:n:' \
  '--fetchSize=[fetch size]:n:' \
  '--consistency=[consistency level]:level:' \
  '--connect-timeout=[connect timeout seconds]:sec:' \
  '--request-timeout=[request timeout seconds]:sec:' \
  '--date-format=[date format]:fmt:' \
  '--cqlshrc=[alternative cqlshrc file]:file:_files' \
  '--query-partition-keys[query partition keys for a table]' \
  '--query-ranges[split CQL query by token ranges]' \
  '(-j --json-columns)'{-j+,--json-columns=}'[columns containing JSON]:cols:' \
  '*:CQL file:_files' && ret=0

return ret
