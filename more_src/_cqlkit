#compdef cqlkit

# https://github.com/tenmax/cqlkit — Cassandra CQL batch runner (`cqlkit -h`)
_arguments -s -S \
  '-h[help]' \
  '(-c --contact)'{-c,--contact}'*=-[contact points]:host:' \
  '(-k --keyspace)'{-k,--keyspace}'=-[default keyspace]:ks:' \
  '(-f --file)'{-f,--file}'=-[CQL script]:file:_files' \
  '*:CQL files:_files'
