#compdef fake-gcs-server

# https://github.com/fsouza/fake-gcs-server — GCS API emulator (flags from internal/config)

_arguments -s -S \
  '-backend=[storage backend]:backend:(memory filesystem)' \
  '-filesystem-root=[root directory for filesystem backend]:path:_files -/' \
  '-public-host=[public host for clients]:host:' \
  '-external-url=[external base URL for Location header]:url:' \
  '-scheme=[HTTP/HTTPS listen mode]:scheme:(http https both)' \
  '-host=[bind address]:host:' \
  '-data=[preload data directory]:path:_files -/' \
  '-cors-headers=[comma-separated extra CORS headers]:headers:' \
  '-port=[primary listen port]:port:' \
  '-port-http=[HTTP port when scheme is both]:port:' \
  '-event.pubsub-project-id=[GCP project for Pub/Sub events]:project:' \
  '-event.pubsub-topic=[Pub/Sub topic for events]:topic:' \
  '-event.bucket=[only emit events for this bucket]:bucket:' \
  '-event.object-prefix=[only emit events under this prefix]:prefix:' \
  '-event.list=[comma event list]:events:' \
  '-location=[default bucket location]:loc:' \
  '-cert-location=[TLS certificate path]:file:_files' \
  '-private-key-location=[TLS private key path]:file:_files' \
  '-log-level=[log level]:level:(debug info warning warn error)' \
  '-help[show Go flag usage]' && return 0
