#compdef tarsnap-keymgmt
# _tarsnap-keymgmt — generate/merge/split Tarsnap key files (Tarsnap/tarsnap)
# upstream: https://github.com/Tarsnap/tarsnap
# Flags from keymgmt/keymgmt.c (getopt).

_tarsnap-keymgmt() {
    _arguments \
        '(- *)--version[print version]' \
        '--outkeyfile=[new key file to create]:file:_files' \
        '--passphrased[passphrase-protect the new key]' \
        '--passphrase-mem=[max memory used for passphrase derivation]:bytes:' \
        '--passphrase-time=[max time used for passphrase derivation]:seconds:' \
        '-r[include read permission]' \
        '-w[include write permission]' \
        '-d[include delete permission]' \
        '--nuke[include nuke permission]' \
        '--keylist=[output the list of keys present in input files]:file:_files' \
        '--print-key-id=[print the machine key ID for KEYFILE]:file:_files' \
        '--print-key-permissions=[print the permissions present in KEYFILE]:file:_files' \
        '*:key file:_files'
}

_tarsnap-keymgmt "$@"
