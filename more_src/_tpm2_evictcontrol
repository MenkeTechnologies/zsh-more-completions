#compdef tpm2_evictcontrol
# _tpm2_evictcontrol — tpm2-software tpm2_evictcontrol make a transient TPM2 object persistent or evict a persistent object (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_evictcontrol() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-C+[hierarchy]:h:(o p owner platform)' \
        '--hierarchy=+[hierarchy]:h:(o p owner platform)' \
        '-P+[hierarchy auth]:str:' \
        '--auth=+[hierarchy auth]:str:' \
        '-c+[object context]:file:_files' \
        '--object-context=+[object context]:file:_files' \
        '-o+[output context]:file:_files' \
        '--output=+[output context]:file:_files' \
        '-S+[session]:str:' \
        '--session=+[session]:str:' \
        '-Q[do not output anything]' \
        '--cphash=+[cp hash file]:file:_files' \
        '*:persistent handle:'
}

_tpm2_evictcontrol "$@"
