#compdef nanopb_generator
# Documentation: https://github.com/nanopb/nanopb/blob/master/docs/reference.md
# nanopb_generator - generate nanopb C code from protobuf .pb files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-x[exclude file from generated include list]:file:_files' \
  '(-e --extension)'{-e,--extension}'[extension for generated files]:extension:' \
  '(-H --header-extension)'{-H,--header-extension}'[extension for header files]:extension:' \
  '(-S --source-extension)'{-S,--source-extension}'[extension for source files]:extension:' \
  '(-f --options-file)'{-f,--options-file}'[separate generator options file]:file:_files' \
  '*'{-I,--options-path,--proto-path}'[search path for .options and .proto files]:dir:_files -/' \
  '--error-on-unmatched[error on unmatched fields in options file]' \
  '--no-error-on-unmatched[do not error on unmatched fields]' \
  '(-D --output-dir)'{-D,--output-dir}'[output directory]:dir:_files -/' \
  '(-Q --generated-include-format)'{-Q,--generated-include-format}'[format for including other .pb.h files]:format:' \
  '(-L --library-include-format)'{-L,--library-include-format}'[format for including nanopb pb.h header]:format:' \
  '--strip-path[strip directory path from included .pb.h]' \
  '--no-strip-path[do not strip directory path]' \
  '--cpp-descriptors[generate C++ descriptors for type lookup]' \
  '(-T --no-timestamp)'{-T,--no-timestamp}'[do not add timestamp to preamble]' \
  '(-t --timestamp)'{-t,--timestamp}'[add timestamp to preamble]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all output except errors]' \
  '(-v --verbose)'{-v,--verbose}'[print additional information]' \
  '*-s[set generator option as OPTION:VALUE]:option:' \
  '*--protoc-opt=[pass option to protoc]:option:' \
  '--protoc-insertion-points[include insertion point comments]' \
  '(-C --c-style)'{-C,--c-style}'[use C naming convention]' \
  '--custom-style=[use custom naming convention MODULE.CLASS]:module:' \
  '*:proto file:_files -g "*.pb *.proto"' && ret=0

return ret
