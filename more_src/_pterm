#compdef pterm
# Documentation: https://man.archlinux.org/search?q=pterm
# Reference accessed: 2026-05-16

# pterm: terminate a running PRRTE daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '--system-server-first[contact system server first]' \
  '--system-server-only[only contact system server]' \
  '--namespace=[PRRTE namespace]:ns:' \
  '--pid=[PRRTE PID]:pid:' \
  '*::pterm args:_files' && ret=0
return ret
