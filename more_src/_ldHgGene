#compdef ldHgGene
# UCSC kent: load database with gene predictions from a gff file

local ret=1

_arguments -s -S \
  '-bin[add bin column (now the default)]' \
  '-nobin[do not add binning]' \
  '-exon=[set type field for exons to specific value]:type' \
  '-oldTable[do not overwrite what is already in table]' \
  '-noncoding[force whole prediction to be UTR]' \
  '-gtf[input is GTF, stop codon is not in CDS]' \
  '-predTab[input is already in genePredTab format]' \
  '-requireCDS[discard genes that do not have CDS annotation]' \
  '-out=[write genePred output instead of loading table]:file:_files' \
  '-genePredExt[create an extended genePred including frame and gene name]' \
  '-impliedStopAfterCds[implied stop codon in GFF/GTF after CDS]' \
  '1:database:' \
  '2:table:' \
  '*:gff file:_files -g "*.gff"' && ret=0

return ret
