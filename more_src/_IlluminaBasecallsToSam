#compdef IlluminaBasecallsToSam
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/illumina/IlluminaBasecallsToSam.java
# Picard: transforms raw Illumina sequencing data into an unmapped SAM, BAM or CRAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-BD --BASECALLS_DIR)'{-BD,--BASECALLS_DIR}'=[Illumina basecalls directory]:dir:_files -/' \
  '(-BCD --BARCODES_DIR)'{-BCD,--BARCODES_DIR}'=[directory with barcode files]:dir:_files -/' \
  '(-L --LANE)'{-L,--LANE}'=[lane number to process]:n:' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output SAM/BAM/CRAM file]:file:_files' \
  '--RUN_BARCODE=[barcode identifying the run]:s:' \
  '(-SA --SAMPLE_ALIAS)'{-SA,--SAMPLE_ALIAS}'=[sample name]:s:' \
  '(-LN --LIBRARY_NAME)'{-LN,--LIBRARY_NAME}'=[library identifier]:s:' \
  '(-ID --READ_GROUP_ID)'{-ID,--READ_GROUP_ID}'=[read group identifier]:s:' \
  '--SEQUENCING_CENTER=[name of sequencing center]:s:' \
  '--RUN_START_DATE=[start date of the run]:s:' \
  '--PLATFORM=[sequencing technology platform]:s:' \
  '--READ_STRUCTURE=[read structure describing logical reads]:s:' \
  '--LIBRARY_PARAMS=[tab-separated file of output/sample/library/barcode]:file:_files' \
  '--BARCODE_PARAMS=[deprecated name for LIBRARY_PARAMS]:file:_files' \
  '*--ADAPTERS_TO_CHECK=[adapter sequences to detect and clip]:a:' \
  '--FIVE_PRIME_ADAPTER=[custom 5-prime adapter sequence]:s:' \
  '--THREE_PRIME_ADAPTER=[custom 3-prime adapter sequence]:s:' \
  '--NUM_PROCESSORS=[number of threads to use]:n:' \
  '--FIRST_TILE=[starting tile for processing]:n:' \
  '--TILE_LIMIT=[maximum number of tiles to process]:n:' \
  '--PROCESS_SINGLE_TILE=[process a single tile only]:n:' \
  '--APPLY_EAMSS_FILTER=[apply EAMSS quality filtering]:b:(true false)' \
  '(-NONPF --INCLUDE_NON_PF_READS)'{-NONPF,--INCLUDE_NON_PF_READS}'=[include reads failing quality filter]:b:(true false)' \
  '(-IGNORE_UNEXPECTED --IGNORE_UNEXPECTED_BARCODES)'{-IGNORE_UNEXPECTED,--IGNORE_UNEXPECTED_BARCODES}'=[ignore reads with unknown barcodes]:b:(true false)' \
  '--MOLECULAR_INDEX_TAG=[tag for storing molecular indexes]:s:' \
  '--MOLECULAR_INDEX_BASE_QUALITY_TAG=[tag for molecular index qualities]:s:' \
  '*--TAG_PER_MOLECULAR_INDEX=[individual tags for each molecular index]:s:' \
  '--INCLUDE_BC_IN_RG_TAG=[include barcode in read group BC tag]:b:(true false)' \
  '--BARCODE_POPULATION_STRATEGY=[when to populate the BC tag]:s:' \
  '--SORT=[sort output by read name]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
