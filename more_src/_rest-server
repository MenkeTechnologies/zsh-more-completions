#compdef rest-server
# _rest-server — restic REST backend server (restic/rest-server)
# upstream: https://github.com/restic/rest-server
# Flags from cmd/rest-server/main.go (cobra/pflag).

_rest-server() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '--cpu-profile=[write CPU profile to file]:file:_files'
        '--debug[output debug messages]'
        '--listen=[listen address]:host\:port:'
        '--log=[write HTTP combined log to file (- for stdout)]:file:_files'
        '--max-size=[max repo size in bytes]:bytes:'
        '--path=[data directory]:dir:_files -/'
        '--tls[enable TLS]'
        '--tls-cert=[TLS certificate file]:file:_files -g "*.pem"'
        '--tls-key=[TLS key file]:file:_files -g "*.pem"'
        '--tls-min-ver=[TLS minimum version]:ver:(1.2 1.3)'
        '--no-auth[disable authentication]'
        '--htpasswd-file=[location of .htpasswd file]:file:_files'
        '--proxy-auth-username=[HTTP header containing the username for proxy-auth]:header:'
        '--no-verify-upload[skip upload integrity verification]'
        '--append-only[enable append-only mode]'
        '--private-repos[users can only access their private repo]'
        '--prometheus[enable Prometheus metrics]'
        '--prometheus-no-auth[disable auth for /metrics]'
        '--group-accessible-repos[allow filesystem group to access repo files]'
    )
    _arguments -s $args
}

_rest-server "$@"
