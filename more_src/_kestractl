#compdef kestractl kestra
# Documentation: https://man.archlinux.org/search?q=kestractl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:manage Kestra contexts and credentials'
  'flows:deploy and manage workflow definitions'
  'executions:trigger and monitor workflow runs'
  'namespaces:show namespaces'
  'kv:manage namespace key-value pairs'
  'nsfiles:manage namespace file storage'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:file:_files -g "*.{yaml,yml}"' \
  '--host=[Kestra host URL]:url:' \
  '--token=[Kestra API token]:token:' \
  '--basic-auth-username=[basic auth user]:user:' \
  '--basic-auth-password=[basic auth password]:pass:' \
  '--tenant=[Kestra tenant]:tenant:' \
  '--namespace=[default namespace]:namespace:' \
  '--insecure[skip TLS verify]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kestractl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (config)
        _arguments '*::sub:(add show use remove current)' && ret=0 ;;
      (flows)
        local -a flow_subs=(
          'list:list flows in a namespace'
          'ls:alias for list'
          'get:retrieve flow source'
          'show:alias for get'
          'describe:alias for get'
          'deploy:upload YAML workflows'
          'create:alias for deploy'
          'apply:alias for deploy'
          'validate:check flow definitions for errors'
          'export:export flows to YAML'
          'delete:delete a flow'
        )
        _describe -t fs 'flows subcommand' flow_subs && ret=0
        _arguments \
          '--namespace=[target namespace]:namespace:' \
          '--override[override existing flows]' \
          '--fail-fast[stop on first error]' \
          '*::file:_files -g "*.{yaml,yml}"' && ret=0 ;;
      (executions)
        local -a exec_subs=(
          'run:start a flow execution'
          'trigger:alias for run'
          'execute:alias for run'
          'get:view execution details'
          'show:alias for get'
          'describe:alias for get'
          'kill:cancel a running execution'
          'list:list executions'
        )
        _describe -t es 'executions subcommand' exec_subs && ret=0
        _arguments \
          '--namespace=[namespace]:namespace:' \
          '--flow=[flow id]:flow:' \
          '--inputs=[inputs JSON or YAML]:inputs:' \
          '--inputs-file=[inputs file]:file:_files' \
          '--labels=[labels k=v]:labels:' \
          '--wait[wait for completion]' && ret=0 ;;
      (namespaces)
        _arguments '*::sub:(list ls show)' && ret=0 ;;
      (kv)
        _arguments \
          '*::sub:(list get set update delete rm)' \
          '--namespace=[namespace]:namespace:' && ret=0 ;;
      (nsfiles)
        _arguments \
          '*::sub:(list ls get cat upload delete rm)' \
          '--namespace=[namespace]:namespace:' && ret=0 ;;
    esac ;;
esac

return ret
