#compdef kestractl
# Documentation: https://github.com/kestra-io/kestractl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:manage Kestra contexts and credentials'
  'flows:deploy and manage workflow definitions'
  'executions:trigger and monitor workflow runs'
  'namespaces:list namespaces'
  'kv:manage namespace key-value pairs'
  'nsfiles:manage namespace file storage'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--host=[Kestra host URL]:url:' \
  '(-t --token)'{-t+,--token=}'[Kestra API token]:token:' \
  '--tenant=[Kestra tenant]:tenant:' \
  '--header=[extra HTTP header (Key:Value)]:header:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table json)' \
  '--config=[config file path]:file:_files -g "*.{yaml,yml}"' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kestractl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (config)
        _arguments '*::sub:(add show use remove)' && ret=0 ;;
      (flows)
        local -a flow_subs=(
          'list:list flows in a namespace'
          'ls:alias for list'
          'get:retrieve flow source'
          'show:alias for get'
          'describe:alias for get'
          'deploy:upload YAML workflows'
          'create:alias for deploy'
          'apply:alias for deploy'
          'validate:check flow definitions for errors'
        )
        _describe -t fs 'flows subcommand' flow_subs && ret=0
        _arguments \
          '--namespace=[target namespace]:namespace:' \
          '--override[override existing flows]' \
          '--fail-fast[stop on first error]' \
          '*::file:_files -g "*.{yaml,yml}"' && ret=0 ;;
      (executions)
        local -a exec_subs=(
          'run:start a flow execution'
          'trigger:alias for run'
          'execute:alias for run'
          'get:view execution details'
          'show:alias for get'
          'describe:alias for get'
        )
        _describe -t es 'executions subcommand' exec_subs && ret=0
        _arguments \
          '--wait[wait for completion]' && ret=0 ;;
      (namespaces)
        _arguments \
          '*::sub:(list ls)' \
          '--query=[filter by namespace prefix]:query:' && ret=0 ;;
      (kv)
        _arguments '*::sub:(list get set update delete rm)' && ret=0 ;;
      (nsfiles)
        _arguments \
          '*::sub:(list ls get cat upload delete)' \
          '--path=[file path within namespace]:path:' \
          '--recursive[recurse into directories]' && ret=0 ;;
    esac ;;
esac

return ret
