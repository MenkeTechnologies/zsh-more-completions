#compdef tfwrapper
# Documentation: https://github.com/claranet/terraform-wrapper/blob/master/README.md
# Python wrapper for OpenTofu and Terraform that enforces best practices

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-c --confirm)'{-c,--confirm}'[automatically confirm actions]' \
  '(-a --account)'{-a,--account}'=[account identifier]:account' \
  '(-e --environment)'{-e,--environment}'=[environment name]:environment' \
  '(-r --region)'{-r,--region}'=[cloud region]:region' \
  '(-s --stack)'{-s,--stack}'=[stack name]:stack' \
  '(-p --plan)'{-p,--plan}'[use a saved plan file]' \
  '(-l --pipe-plan)'{-l,--pipe-plan}'[pipe plan output through a command]' \
  '--pipe-plan-command=[command used for piping plans]:command' \
  '1:command:((
    bootstrap\:"initialize a stack from templates"
    init\:"initialize Terraform configuration"
    plan\:"generate an execution plan"
    apply\:"apply changes to infrastructure"
    destroy\:"destroy managed infrastructure"
    console\:"interactive Terraform console"
    foreach\:"execute commands across multiple stacks"
    refresh\:"refresh state from remote resources"
    validate\:"validate Terraform configuration"
    import\:"import existing resources"
    output\:"display output values"
  ))' \
  '*::arg:_default' && ret=0

return ret
