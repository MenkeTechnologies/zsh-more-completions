#compdef pacini
# Source: https://github.com/VorpalBlade/vorpal-zsh-completions/blob/acd8f524a429fb3a8fab0423ae2cdc246d3daaa1/src/_pacini
# Repository: VorpalBlade/vorpal-zsh-completions (src/_pacini)

declare -a args
args=(
    '(-)--help[display help information]'
    '(-)--section-list[list configured sections]'
    '--section=[query options for a specific section]:<name>: '
    '--verbose[always show directive names]'
    '(-)--version[display version information]'
    ':file[File name]:_files'
    '*:directives: '
)
_arguments $args
