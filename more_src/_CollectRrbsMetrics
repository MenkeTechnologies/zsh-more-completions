#compdef CollectRrbsMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectRrbsMetrics
# Picard: collect metrics from reduced representation bisulfite sequencing (RRBS) data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[coordinate-sorted BAM/SAM of aligned reads]:bam:_files -g "*.(bam|sam)"' \
  {-M=,--METRICS_FILE_PREFIX=}'[base name for output files]:basename:' \
  {-R=,--REFERENCE=}'[reference sequence FASTA]:fasta:_files -g "*.(fa|fasta)"' \
  '--MINIMUM_READ_LENGTH=[minimum read length]:int:' \
  '--C_QUALITY_THRESHOLD=[base quality threshold for a C to be considered]:int:' \
  '--NEXT_BASE_QUALITY_THRESHOLD=[quality threshold for the base next to a C]:int:' \
  '--MAX_MISMATCH_RATE=[max mismatch fraction for a read to be considered (0-1)]:float:' \
  {-AS=,--ASSUME_SORTED=}'[assume input is coordinate sorted]:bool:(true false)' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
