#compdef dmsetup
# _dmsetup-cli — device-mapper low-level admin tool (LVM2 project); create/remove/control DM targets directly
# upstream: https://gitlab.com/lvmteam/lvm2

_dmsetup-cli() {
    local -a sub=(
        'create:create a device'
        'remove:remove a device'
        'remove_all:remove all devices'
        'suspend:suspend a device'
        'resume:resume a device'
        'load:load a new table'
        'clear:clear inactive table'
        'reload:reload table'
        'rename:rename a device'
        'message:send message to a target'
        'ls:list devices'
        'info:show device info'
        'deps:show device deps'
        'status:show device status'
        'table:show device table'
        'wait:wait for event'
        'mknodes:create device nodes'
        'udevcreatecookie:create udev cookie'
        'udevreleasecookie:release udev cookie'
        'udevcomplete:complete udev event'
        'udevcomplete_all:complete all udev events'
        'udevflags:print udev flags'
        'targets:print target info'
        'version:show version'
        'splitname:split major:minor'
        'measure:print device size'
        'stats:I/O statistics'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--checks[run sanity checks]' \
        '--columns[column output]' \
        '--exec+[exec command]:cmd:_command_names -e' \
        '--force[force]' \
        '--manglename+[mangle]:mode:(none hex auto)' \
        '--nameprefixes[print name=val prefixes]' \
        '--noheadings[no header]' \
        '--noflush[skip device flush]' \
        '--nolockfs[do not freeze fs]' \
        '--noopencount[ignore opens]' \
        '--notable[no table]' \
        '--noudevrules[no udev rules]' \
        '--noudevsync[no udev sync]' \
        '-o+[fields]:str:' \
        '--readahead+[read-ahead]:n:' \
        '--retry[retry on EBUSY]' \
        '-r[read only]' \
        '-S+[select]:str:' \
        '--showkeys[show keys]' \
        '--sort+[sort]:str:' \
        '-u+[uuid]:uuid:' \
        '--unbuffered[unbuffered output]' \
        '-y[yes]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dmsetup subcommand' sub ;;
        args)
            case $words[1] in
                create|remove|suspend|resume|load|clear|reload|rename|info|deps|status|table|wait|mknodes|measure) _arguments '*:device:' ;;
            esac
            ;;
    esac
}

_dmsetup-cli "$@"
