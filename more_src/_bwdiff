#compdef bwdiff
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=bwdiff&sektion=1
# BRL-CAD compare two black-and-white images

local ret=1

_arguments -s \
  '-m[take magnitude of pixel differences]' \
  '(-l -e -n)-g[greater-than relational comparison]' \
  '(-g -e -n)-l[less-than relational comparison]' \
  '(-g -l -n)-e[equal-to relational comparison]' \
  '(-g -l -e)-n[not-equal-to relational comparison]' \
  '-b[use file1 as lowered-intensity background]' \
  '1:file1.bw:_files' \
  '2:file2.bw:_files' && ret=0

return ret
