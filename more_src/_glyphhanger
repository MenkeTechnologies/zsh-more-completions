#compdef glyphhanger
# Documentation: https://github.com/zachleat/glyphhanger
# Determine which Unicode glyphs are used on a web page and subset fonts

local ret=1

_arguments -s -S \
  '--help[show usage details]' \
  '--version[display version information]' \
  '--string[output characters instead of Unicode code points]' \
  '--json[show results for each font-family on the page]' \
  '--family=[show results only for specific font-family names]:family' \
  '--subset=[select font files for subsetting]:glob:_files -g "*.(ttf|otf|woff|woff2)"' \
  '--whitelist=[add specific characters or unicode ranges]:chars' \
  '--US_ASCII[shortcut for all US-ASCII characters]' \
  '--LATIN[shortcut for all Latin characters]' \
  '--formats=[output formats: ttf, woff, woff2]:formats' \
  '--css[output a @font-face block]' \
  '--output=[output directory for created files]:dir:_files -/' \
  '--spider[gather URLs from local links on the page]' \
  '--spider-limit=[limit spider traversal (0 = unlimited)]:n' \
  '--onlyVisible[only subset visible text on the page]' \
  '--cssSelector=[limit results to text matching a CSS selector]:selector' \
  '--jsdom[use faster jsdom mode instead of headless Chrome]' \
  '*:url or file:_files' && ret=0

return ret
