#compdef s3_website
# Documentation: https://github.com/laurilehmijoki/s3_website
# s3_website deploy static sites to Amazon S3

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--headless[run without interactive prompts]' \
  '--autocreate-cloudfront-dist[create a CloudFront distribution]' \
  '--site=[website directory]:path:_files -/' \
  '--config-dir=[directory of s3_website.yml]:dir:_files -/' \
  '--force[update metadata of existing files]' \
  '--dry-run[simulate deployment]' \
  '1:command:(cfg push)' \
  '*::arg:_files' && ret=0

return ret
