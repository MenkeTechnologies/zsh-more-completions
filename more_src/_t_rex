#compdef t_rex
# Documentation: https://t-rex.tileserver.ch/doc/serve/
# t_rex - vector tile server publishing MVT tiles from your own data

local ret=1
local curcontext="$curcontext" state line

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 't_rex command' \
      'serve[start tile server]' \
      'generate[generate tiles to file cache]' \
      'genconfig[generate configuration template]' \
      'drilldown[determine number of features per tile]' && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s \
          '(-c --config)'{-c,--config}'=[load from custom config file]:file:_files' \
          '--datasource=[GDAL datasource specification]:ds' \
          '--dbconn=[PostGIS connection postgresql://USER@HOST/DBNAME]:conn' \
          '--qgs=[QGIS project file]:file:_files' \
          '--bind=[bind web server to this address]:address' \
          '--port=[bind web server to this port]:port' \
          '--cache=[use tile cache in DIR]:dir:_files -/' \
          '--clip=[clip geometries]:bool:(true false)' \
          '--simplify=[simplify geometries]:bool:(true false)' \
          '--no-transform=[do not transform to grid SRS]:bool:(true false)' \
          '--detect-geometry-types=[detect geometry types when undefined]:bool:(true false)' \
          '--openbrowser=[open backend URL in browser]:bool:(true false)' \
          '--loglevel=[log level]:level:(error warn info debug trace)' && ret=0
        ;;
      generate)
        _arguments -s \
          '(-c --config)'{-c,--config}'=[load from custom config file]:file:_files' \
          '--tileset=[tileset to generate]:name' \
          '--minzoom=[minimum zoom level]:zoom' \
          '--maxzoom=[maximum zoom level]:zoom' \
          '--extent=[extent of tiles (minx,miny,maxx,maxy)]:extent' \
          '--nodes=[number of generator nodes]:n' \
          '--nodeno=[number of this node (0 <= n < nodes)]:n' \
          '--progress=[show progress bar]:bool:(true false)' \
          '--overwrite=[overwrite existing tiles]:bool:(false true)' \
          '--loglevel=[log level]:level:(error warn info debug trace)' && ret=0
        ;;
    esac
    ;;
esac

return ret
