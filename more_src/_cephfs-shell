#compdef cephfs-shell
# Documentation: https://docs.ceph.com/en/latest/man/8/cephfs-shell/
# Interactive shell for navigating and manipulating a CephFS filesystem.

local ret=1

_arguments -s -S \
  '(-b --batch)'{-b+,--batch=}'[path to batch file]:file:_files' \
  '(-c --config)'{-c+,--config=}'[path to cephfs-shell.conf]:file:_files' \
  '(-f --fs)'{-f+,--fs=}'[name of filesystem to mount]:fs:' \
  '(-t --test)'{-t+,--test=}'[path to transcript(s) for testing]:file:_files' && ret=0

return ret
