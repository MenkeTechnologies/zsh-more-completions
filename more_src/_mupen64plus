#compdef mupen64plus
# Documentation: https://man.archlinux.org/search?q=mupen64plus
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--configdir=[config directory]:dir:_files -/' \
  '--datadir=[data directory]:dir:_files -/' \
  '--plugindir=[plugin directory]:dir:_files -/' \
  '--sshotdir=[screenshot directory]:dir:_files -/' \
  '--corelib=[core library file]:file:_files' \
  '--configdir=[config dir]:dir:_files -/' \
  '--gfx=[video plugin]:plugin:' \
  '--audio=[audio plugin]:plugin:' \
  '--input=[input plugin]:plugin:' \
  '--rsp=[RSP plugin]:plugin:' \
  '--emumode=[emulation mode]:mode:(0 1 2)' \
  '--testshots=[run frame test]:n:' \
  '--set=[set config option SECTION\[NAME\]=VALUE]:opt:' \
  '--cheats=[apply cheats]:list:' \
  '--saveinfo[print save info]' \
  '--osd[on-screen display]' \
  '--noosd[no OSD]' \
  '--fullscreen[fullscreen mode]' \
  '--windowed[windowed mode]' \
  '--resolution=[resolution WxH]:WxH:' \
  '--verbose[verbose]' \
  '*:rom:_files -g "*.{n64,z64,v64,rom}"' && ret=0

return ret
