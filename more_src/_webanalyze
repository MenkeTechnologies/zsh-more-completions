#compdef webanalyze
# Documentation: https://github.com/rverton/webanalyze
# Reference accessed: 2026-05-21
# Verified: upstream cmd/webanalyze/main.go flag definitions.

_arguments -s \
  '-output=[output format]:fmt:(stdout csv json)' \
  '-update[update technologies file]' \
  '-worker=[worker count]:n:' \
  '-apps=[apps file]:file:_files -g "*.json"' \
  '-host=[single URL]:url:' \
  '-hosts=[hosts file]:file:_files' \
  '-crawl=[crawl depth]:n:' \
  '-search[search subpages]' \
  '-silent[silent mode]' \
  '-redirect[follow redirects]'
