#compdef condor_submit_dag
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_submit_dag.html
# manage and queue jobs within a specified DAG for execution on remote machines

local ret=1

_arguments -s -S \
  '-help[display usage information]' \
  '-version[display version information]' \
  '-no_submit[produce the DAGMan submit file but do not submit it]' \
  '(-v -verbose)'{-v,-verbose}'[give verbose error messages]' \
  '(-f -force)'{-f,-force}'[do not fail if previous execution files are found]' \
  '-dagman[path to a condor_dagman executable]:path:_files' \
  '-MaxIdle[max number of idle jobs allowed before placing more]:N' \
  '-MaxJobs[max number of nodes that have placed jobs at any moment]:N' \
  '-MaxPre[max number of PRE scripts running at any moment]:N' \
  '-MaxPost[max number of POST scripts running at any moment]:N' \
  '-MaxHold[max number of HOLD scripts running at any moment]:N' \
  '-notification[set e-mail notification for DAGMan itself]:value:(Always Complete Error Never)' \
  '(-r -remote)'{-r,-remote}'[place DAGMan job on a remote schedd]:schedd_name' \
  '-debug[set the DAGMan debug log level]:level' \
  '-UseDagDir[execute each DAG from its own directory]' \
  '-outfile_dir[directory for the dagman.out debug log]:path:_files -/' \
  '-config[HTCondor configuration file for this DAGMan instance]:filename:_files' \
  '-Lockfile[file to write DAGMan process information]:filename:_files' \
  '-insert_sub_file[file of JDL commands to insert in the DAGMan job]:filename:_files' \
  '(-a -append)'{-a,-append}'[JDL command to insert into the DAGMan submit file]:command' \
  '-batch-name[set the JobBatchName for DAGMan and its jobs]:name' \
  '-AutoRescue[automatically detect rescue DAG files on startup]:value:(0 1)' \
  '-DoRescueFrom[rescue number to locate and restore state from]:N' \
  '-RescueFile[rescue file to restore state from]:filename:_files' \
  '-load_save[SAVE_POINT_FILE to restore state from]:filename:_files' \
  '-DoRecovery[startup in recovery mode from nodes.log]' \
  '-AllowVersionMismatch[allow version difference between dagman and the sub file]' \
  '-no_recurse[do not recursively pre-produce SUBDAG submit files]' \
  '-do_recurse[recursively pre-produce all SUBDAG submit files]' \
  '-update_submit[update existing DAGMan submit file]' \
  '-import_env[import the current shell environment into the submit file]' \
  '-include_env[comma separated env variables to add to getenv]:variables' \
  '-insert_env[delimited key=value pairs to set into the environment]:pairs' \
  '-valgrind[run DAGMan under valgrind]' \
  '-DontAlwaysRunPost[execute POST scripts even on PRE script failure]' \
  '-AlwaysRunPost[only execute POST scripts after a node jobs complete]' \
  '-priority[set the minimum JobPrio for jobs managed by DAGMan]:N' \
  '-schedd-daemon-ad-file[path to a daemon ad file for a schedd]:filename:_files' \
  '-schedd-address-file[path to an address file for a schedd]:filename:_files' \
  '-suppress_notification[suppress email for all jobs managed by DAGMan]' \
  '-dont_suppress_notification[allow email notifications for jobs]' \
  '-SubmitMethod[how DAGMan places managed jobs to the AP]:value:(0 1)' \
  '*:DAG file:_files' && ret=0

return ret
