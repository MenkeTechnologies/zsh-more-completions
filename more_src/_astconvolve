#compdef astconvolve
# Documentation: https://www.gnu.org/software/gnuastro/manual/html_node/Invoking-astconvolve.html
# astconvolve — convolve an input image with a kernel in spatial or frequency domain

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[only report errors, remain quiet about steps]' \
  '--cite[show BibTeX citation for this program]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and abort]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for this directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for this user]' \
  '--config[read configuration file immediately]:file:_files' \
  '--checkconfig[list all config files and variables read]' \
  '--lastconfig[do not parse any more configuration files]' \
  '--onlyversion[only run if program version matches]:version' \
  '(-N --numthreads)'{-N,--numthreads}'[number of CPU threads to use]:number' \
  '--minmapsize[minimum bytes to avoid automatic RAM usage]:size' \
  '--quietmmap[do not report memory-mapped file name and size]' \
  '--usage[give a short usage message]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[type of output]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--tableformat[output table format]:format:(txt fits-ascii fits-binary)' \
  '--wcslinearmatrix[WCS linear matrix of output]:matrix:(pc cd)' \
  '(-c --column)'{-c,--column}'[column name or number if input is a table]:column' \
  '--searchin[where to search for columns]:where:(name unit comment)' \
  '--stdintimeout[microseconds to wait for standard input]:microseconds' \
  '(-k --kernel)'{-k,--kernel}'[file name of kernel for convolution]:file:_files' \
  '(-u --khdu)'{-u,--khdu}'[HDU containing the kernel]:HDU' \
  '--kernelcolumn[column name or number if kernel is a table]:column' \
  '--nokernelflip[do not flip the kernel image]' \
  '--nokernelnorm[do not normalize the kernel image]' \
  '(-H --minsharpspec)'{-H,--minsharpspec}'[deconvolution minimum spectrum of sharp image]:value' \
  '(-d --domain)'{-d,--domain}'[convolution domain]:domain:(spatial frequency)' \
  '(-m --makekernel)'{-m,--makekernel}'[generate kernel from given inputs]:number' \
  '--noedgecorrection[do not apply edge correction in spatial domain]' \
  '(-C --checkfreqsteps)'{-C,--checkfreqsteps}'[view frequency domain steps]' \
  '--checktiles[display tile IDs in an image]' \
  '(-Z --tilesize)'{-Z,--tilesize}'[regular tile size on dimensions]:size' \
  '(-M --numchannels)'{-M,--numchannels}'[number of channels in each dimension]:number' \
  '(-F --remainderfrac)'{-F,--remainderfrac}'[fraction of remainder to split last tile]:fraction' \
  '--workoverch[work over channel edges]' \
  '--oneelempertile[display one element per tile]' \
  '--interpmetric[interpolation metric]:metric:(radial manhattan)' \
  '*:input:_files' && ret=0

return ret
