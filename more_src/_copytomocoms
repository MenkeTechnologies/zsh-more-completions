#compdef copytomocoms
# Documentation: https://bio3d.colorado.edu/imod/doc/man/copytomocoms.html
# copytomocoms - copy and set up command files for tomographic reconstruction

local ret=1

_arguments -s -S \
  '(-n --name)'{-n,-name}'[root name of data set]:name' \
  '(-sta --stackext)'{-sta,-stackext}'[extension of raw stack excluding the period]:ext' \
  '(-du --dual)'{-du,-dual}'[dual-axis data set]' \
  '(-m --montage)'{-m,-montage}'[data are montaged]' \
  '(-bac --backup)'{-bac,-backup}'[directory for backing up small files]:dir:_files -/' \
  '(-pi --pixel)'{-pi,-pixel}'[pixel size of images in nanometers]:size' \
  '(-go --gold)'{-go,-gold}'[size of gold beads in nanometers]:size' \
  '(-ro --rotation)'{-ro,-rotation}'[angle from vertical to the tilt axis]:angle' \
  '(-bro --brotation)'{-bro,-brotation}'[angle from vertical to the tilt axis for B axis]:angle' \
  '(-fi --firstinc)'{-fi,-firstinc}'[first tilt angle and tilt angle increment]:first,inc' \
  '(-bfi --bfirstinc)'{-bfi,-bfirstinc}'[first tilt angle and increment for B axis]:first,inc' \
  '(-use --userawtlt)'{-use,-userawtlt}'[take tilt angle from a .rawtlt file for A axis]' \
  '(-bu --buserawtlt)'{-bu,-buserawtlt}'[take tilt angle from a .rawtlt file for B axis]' \
  '(-e --extract)'{-e,-extract}'[extract tilt angles from data file for A axis]' \
  '(-be --bextract)'{-be,-bextract}'[extract tilt angles from data file for B axis]' \
  '(-a --angles)'{-a,-angles}'[complete list of tilt angles for A axis]:angles' \
  '(-ban --bangles)'{-ban,-bangles}'[complete list of tilt angles for B axis]:angles' \
  '(-t --twodir)'{-t,-twodir}'[tilt series taken in two directions]:angle' \
  '(-bt --btwodir)'{-bt,-btwodir}'[B axis tilt series was bi-directional]:angle' \
  '(-re --reversed)'{-re,-reversed}'[first acquired part is at higher angles]' \
  '(-bre --breversed)'{-bre,-breversed}'[first acquired part of B axis at higher angles]' \
  '(-do --dosesym)'{-do,-dosesym}'[tilt series taken with a dose-symmetric scheme]:angle' \
  '(-bd --bdosesym)'{-bd,-bdosesym}'[B axis taken with a dose-symmetric scheme]:angle' \
  '(-sk --skip)'{-sk,-skip}'[list of views to exclude from processing]:views' \
  '(-bs --bskip)'{-bs,-bskip}'[list of views to exclude for B axis]:views' \
  '(-di --distort)'{-di,-distort}'[correct image distortion with the given .idf]:file:_files' \
  '(-bi --binning)'{-bi,-binning}'[binning of the raw images]:binning' \
  '(-gr --gradient)'{-gr,-gradient}'[correct for magnification gradients]:file:_files' \
  '(-fo --focus)'{-fo,-focus}'[focus was adjusted between montage frames]' \
  '(-bfo --bfocus)'{-bfo,-bfocus}'[focus was adjusted between B axis montage frames]' \
  '(-v --voltage)'{-v,-voltage}'[microscope voltage in kV]:voltage' \
  '-Cs[spherical aberration]:value' \
  '(-ct --ctfnoise)'{-ct,-ctfnoise}'[configuration file listing noise files]:file:_files' \
  '(-de --defocus)'{-de,-defocus}'[defocus in nanometers (underfocus positive)]:defocus' \
  '(-CT --CTFfiles)'{-CT,-CTFfiles}'[just copy files for CTF plotting and correction]:value' \
  '(-fe --fei)'{-fe,-fei}'[set the standard pixel spacing in the header]' \
  '(-ch --change)'{-ch,-change}'[file with directives for changing parameters]:file:_files' \
  '(-o --one)'{-o,-one}'[one directive for changing parameters]:directive' \
  '(-sty --style)'{-sty,-style}'[naming style for output image files]:value' \
  '(-ha --halffloat)'{-ha,-halffloat}'[set output file mode to half-float]:value' \
  '(-pc --pcm)'{-pc,-pcm}'[name output command files with pcm extension]:value' \
  '(-x --xsize)'{-x,-xsize}'[X size of image data]:size' \
  '(-y --ysize)'{-y,-ysize}'[Y size of image data]:size' \
  '(-he --help)'{-he,-help}'[print help output]' \
  '-StandardInput[read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
