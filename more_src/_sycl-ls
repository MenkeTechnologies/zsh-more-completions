#compdef sycl-ls
# Documentation: https://github.com/intel/llvm/blob/sycl/sycl/doc/EnvironmentVariables.md
# sycl-ls - list SYCL devices available in the system

local ret=1

_arguments -s -S \
  '--verbose[print extended device, sub-device and architecture info]' \
  '--ignore-device-selectors[list all devices, ignoring ONEAPI_DEVICE_SELECTOR]' && ret=0

return ret
