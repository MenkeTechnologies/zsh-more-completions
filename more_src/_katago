#compdef katago

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'analysis:analyze SGF file'
  'benchmark:benchmark katago'
  'genconfig:generate config'
  'gtp:run as GTP engine'
  'match:match between two engines'
  'tuner:tune GPU performance'
  'version:show version'
  'evalsgf:evaluate SGF'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'katago command' commands && ret=0 ;;
  (args)
    _arguments \
      '-config=+[config file]:file:_files' \
      '-model=+[model file]:file:_files' \
      '*:file:_files -g "*.{sgf,gtp}"' && ret=0
    ;;
esac

return ret
