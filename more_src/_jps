#compdef jps
# Documentation: https://man.archlinux.org/search?q=jps
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)-help[show help]' \
  '-q[suppress class names and arguments]' \
  '-m[show main method arguments]' \
  '-l[show full class name]' \
  '-v[show JVM arguments]' \
  '-V[suppress class names and arguments]' \
  '*:hostid:_hosts'
