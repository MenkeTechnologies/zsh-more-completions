#compdef handlebars-cli
# _handlebars-cli — handlebars.js template precompiler CLI alias (handlebars.js team, JavaScript); commander
# upstream: https://github.com/handlebars-lang/handlebars.js

_handlebars-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[print AST]' \
        '--amd[wrap as AMD]' \
        '-c+[CommonJS export]:str:' \
        '--commonjs=+[CommonJS export]:str:' \
        '-f+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-i+[input file]:file:_files -g "*.hbs *.handlebars"' \
        '-k+[known helper]:list:' \
        '--known=+[known helper]:list:' \
        '-K[only allow known helpers]' \
        '--knownOnly[only allow known helpers]' \
        '-m[minimize template]' \
        '--min[minimize template]' \
        '-n+[handlebars namespace]:str:' \
        '--namespace=+[handlebars namespace]:str:' \
        '-p[partial mode]' \
        '--partial[partial mode]' \
        '-d[debug]' \
        '--data[allow data]' \
        '-e+[extension]:str:' \
        '--extension=+[extension]:str:' \
        '-r+[root path]:dir:_files -/' \
        '--root=+[root path]:dir:_files -/' \
        '-s[no source map]' \
        '--simple[no source map]' \
        '-N[exclude name]' \
        '--name=+[name]:str:' \
        '-M+[map file]:file:_files' \
        '--map=+[map file]:file:_files' \
        '*:template:_files -g "*.hbs *.handlebars"'
}

_handlebars-cli "$@"
