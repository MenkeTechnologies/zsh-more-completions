#compdef openctx
# Documentation: https://openctx.org/docs/protocol
# Reference accessed: 2026-05-20
# Verified: upstream protocol docs list meta, mentions, items, annotations.

# Zsh completion for openctx CLI
# https://openctx.org

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'meta:Return the provider metadata'
  'mentions:Search for @-mentionable items'
  'items:Fetch specific items/documents'
  'annotations:Retrieve code annotations'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'openctx command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (mentions|items|annotations)
        _arguments -s -S \
          '1:query/uri:' && ret=0
        ;;
      (meta)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
