#compdef esl-alipid
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-alipid.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-alipid: average pairwise identity of MSA sequences
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '--informat=[input alignment format]:fmt:(stockholm pfam a2m afa psiblast clustal phylip phylips)' \
  '--amino[assume protein]' \
  '--dna[assume DNA]' \
  '--rna[assume RNA]' \
  '*:alignment file:_files' && ret=0
return ret
