#compdef esl-alipid
# Documentation: https://man.archlinux.org/search?q=esl-alipid
# Reference accessed: 2026-05-16

# Easel esl-alipid: average pairwise identity of MSA sequences
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--informat[input format]:fmt:(stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--amino[assume protein]' \
  '--dna[assume DNA]' \
  '--rna[assume RNA]' \
  '*:alignment file:_files' && ret=0
return ret
