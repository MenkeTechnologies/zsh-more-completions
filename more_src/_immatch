#compdef immatch
# _immatch — match FITS image stars to a reference catalog (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from immatch.c (single-letter getopt-style).

_immatch() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-a+[initial rotation angle (deg)]:deg:' \
        '-b+[B1950 reference coords]:coords:' \
        '-c+[reference catalog]:cat:(ub1 ub2 ucac4 ucac3 ucac2 gsc2 gsc tycho2 tycho 2mass usno-b1 usno-a2 sao ppm act bsc hip)' \
        '-d+[DAOFIND star position file]:file:_files' \
        '-e+[WCS projection]:proj:(TAN SIN ARC STG ZEA AIT NCP CAR MER MOL TSC PCO BON COE COD COO COP HPX)' \
        '-f+[IRAF output format]:fmt:' \
        '-g+[Guide Star object class]:class:' \
        '-h+[maximum reference stars]:n:' \
        '-i+[image star minimum peak value]:val:' \
        '-j+[J2000 reference coords]:coords:' \
        '-k+[magnitude column in reference catalog]:n:' \
        '-l[left-right reflection before rotating]' \
        '-m+[limiting reference star magnitude]:mag:' \
        '-p+[initial plate scale (arcsec/pixel)]:scale:' \
        '-q[fit image to catalog magnitude]' \
        '*:FITS image:_files -g "*.(fits|fit|fts|imh)"'
}

_immatch "$@"
