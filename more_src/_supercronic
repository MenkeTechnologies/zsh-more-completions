#compdef supercronic
# Documentation: https://github.com/aptible/supercronic
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# aptible/supercronic — cron for containers. Single-dash flags per upstream README.

_arguments -s -S \
  '-debug[verbose logs for crontab/scheduling debugging]' \
  '-test[validate crontab syntax and exit]' \
  '-inotify[watch crontab with inotify and auto-reload]' \
  '-overlapping[allow overlapping job instances]' \
  '-split-logs[route stdout/stderr separately instead of merging on stderr]' \
  '-sentry-dsn=[Sentry DSN]:dsn:' \
  '-sentry-environment=[Sentry environment tag]:env:' \
  '-sentry-release=[Sentry release tag]:rel:' \
  '1:crontab file:_files'
