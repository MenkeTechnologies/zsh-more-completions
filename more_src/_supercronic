#compdef supercronic

# aptible/supercronic — cron for containers.

_arguments -s -S \
  '--debug[debug logs]' \
  '--quiet[warnings and above only]' \
  '--json[JSON log format]' \
  '--version[print version]' \
  '--test[validate crontab only]' \
  '--inotify[watch crontab with inotify]' \
  '--no-reap[disable child reaping]' \
  '--prometheus-listen-address=[Prometheus bind ip:port]:addr:' \
  '--split-logs[split stdout/stderr]' \
  '--passthrough-logs[raw child logs]' \
  '--sentry-dsn=[Sentry DSN]:dsn:' \
  '--sentry-environment=[Sentry environment]:env:' \
  '--sentry-release=[Sentry release]:rel:' \
  '--sentryDsn=[alias for --sentry-dsn]:dsn:' \
  '--overlapping[allow overlapping jobs]' \
  '1:crontab file:_files'
