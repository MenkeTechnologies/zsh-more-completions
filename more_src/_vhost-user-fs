#compdef vhost-user-fs virtiofsd
# Documentation: https://gitlab.com/virtio-fs/virtiofsd
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (virtiofsd Rust daemon).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--socket-path=[vhost-user socket path]:file:_files' \
  '--fd=[file descriptor for listening socket]:fd:' \
  '--shared-dir=[directory shared with the guest]:dir:_files -/' \
  '--cache=[cache policy]:mode:(auto always metadata never)' \
  '--sandbox=[isolation mechanism]:mode:(namespace chroot none)' \
  '--xattr[enable extended attributes]' \
  '--posix-acl[enable POSIX ACLs (implies xattr)]' \
  '--security-label[enable SELinux security labels (implies xattr)]' \
  '--writeback[enable writeback caching]' \
  '--allow-direct-io[honor O_DIRECT from guest]' \
  '--announce-submounts[tell guest which directories are mount points]' \
  '--readonly[prevent write accesses from the guest]' \
  '--thread-pool-size=[max thread pool size (0 disables)]:n:' \
  '--rlimit-nofile=[max file descriptors]:n:' \
  '--log-level=[log level]:level:(off error warn info debug trace)' \
  '--modcaps=[modify capability list]:caps:' && ret=0
return ret
