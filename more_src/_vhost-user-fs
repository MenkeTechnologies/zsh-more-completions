#compdef vhost-user-fs virtiofsd

# vhost-user-fs / virtiofsd: vhost-user filesystem daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--socket-path=[socket path]:file:_files' \
  '--fd=[file descriptor]:fd:' \
  '--shared-dir=[shared directory]:dir:_files -/' \
  '-o[options (key[=value],...)]:opts:' \
  '--cache=[cache mode]:mode:(none auto always metadata)' \
  '--sandbox=[sandbox mode]:mode:(namespace chroot none)' \
  '--xattr[enable xattrs]' \
  '--xattrmap=[xattr mapping]:map:' \
  '--posix-acl[enable POSIX ACLs]' \
  '--security-label[enable security labels]' \
  '--writeback[enable writeback caching]' \
  '--readdirplus[enable readdirplus]' \
  '--allow-direct-io[allow direct IO]' \
  '--announce-submounts[announce submounts]' \
  '--inode-file-handles=[inode file handles]:val:(never prefer mandatory)' \
  '--thread-pool-size=[thread pool size]:n:' \
  '--rlimit-nofile=[rlimit nofile]:n:' \
  '--syslog[log to syslog]' \
  '--log-level=[log level]:level:(off error warn info debug trace)' \
  '--seccomp=[seccomp mode]:mode:(none kill log trap)' \
  '*::vhost-user-fs args:_files' && ret=0
return ret
