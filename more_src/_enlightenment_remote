#compdef enlightenment_remote
# Documentation: https://github.com/Enlightenment/enlightenment
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# enlightenment_remote: control a running Enlightenment instance (ipc)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-bg-get[get background]' \
  '-bg-set[set background]:file:_files' \
  '-binding-mouse-add[add mouse binding]' \
  '-binding-mouse-del[delete mouse binding]' \
  '-binding-mouse-list[list mouse bindings]' \
  '-binding-key-add[add key binding]' \
  '-binding-key-del[delete key binding]' \
  '-binding-key-list[list key bindings]' \
  '-restart[restart enlightenment]' \
  '-exit[exit enlightenment]' \
  '-shutdown[shutdown enlightenment]' \
  '-default-engine-set[set default render engine]:engine:' \
  '-module-load[load module]:module:' \
  '-module-unload[unload module]:module:' \
  '*::enlightenment_remote args:_files' && ret=0
return ret
