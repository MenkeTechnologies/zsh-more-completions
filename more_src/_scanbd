#compdef scanbd
# Documentation: https://manpages.org/scanbd/8
# SANE scanner button daemon

local ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config=}'[use configfile instead of the default scanbd.conf]:file:_files' \
  '(-d --debug)'{-d-,--debug=-}'[turn debug mode on with optional level 1-7]::level:(1 2 3 4 5 6 7)' \
  '(-f --foreground)'{-f,--foreground}'[run scanbd in the foreground]' \
  '-m[run in manager mode (see scanbm)]' && ret=0

return ret
