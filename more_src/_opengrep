#compdef opengrep
# _opengrep — Opengrep open-source semgrep fork (Opengrep / Semgrep-OSS team, OCaml/Python); click
# upstream: https://github.com/opengrep/opengrep

_opengrep() {
    local -a sub=(
        'scan:run scan'
        'ci:run opengrep ci'
        'lsp:run LSP server'
        'login:authenticate'
        'logout:logout'
        'publish:publish a rule'
        'show:show config/rules'
        'test:run rule unit tests'
        'validate:validate rule yaml'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'opengrep subcommand' sub ;;
        args)
            case $words[1] in
                scan|ci) _arguments \
                    '--config=+[config rule set]:str:' \
                    '-c+[config rule set]:str:' \
                    '--pattern=+[pattern]:str:' \
                    '-e+[pattern]:str:' \
                    '--lang=+[language]:lang:(python javascript typescript go java ruby php c cpp csharp rust kotlin swift dockerfile yaml json terraform regex generic)' \
                    '-l+[language]:lang:(python javascript typescript go java ruby php c cpp csharp rust kotlin swift dockerfile yaml json terraform regex generic)' \
                    '--replacement=+[replacement]:str:' \
                    '--exclude=+[exclude pattern]:list:' \
                    '--include=+[include pattern]:list:' \
                    '--exclude-rule=+[exclude rule]:list:' \
                    '--no-git-ignore[no gitignore]' \
                    '--json[json output]' \
                    '--sarif[sarif output]' \
                    '--gitlab-sast[gitlab sast output]' \
                    '--gitlab-secrets[gitlab secrets output]' \
                    '--junit-xml[junit xml output]' \
                    '--emacs[emacs output]' \
                    '--vim[vim output]' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--error[exit nonzero on findings]' \
                    '--strict[strict]' \
                    '--max-target-bytes=+[max target bytes]:n:' \
                    '--timeout=+[per-rule timeout]:n:' \
                    '--timeout-threshold=+[timeout threshold]:n:' \
                    '--max-memory=+[max memory MB]:n:' \
                    '--severity=+[severity filter]:list:(INFO WARNING ERROR)' \
                    '--metrics=+[metrics]:m:(on off auto)' \
                    '--baseline-commit=+[baseline commit]:str:' \
                    '--enable-version-check[enable version check]' \
                    '--disable-version-check[disable version check]' \
                    '--enable-nosem[enable nosem comments]' \
                    '--disable-nosem[disable nosem comments]' \
                    '--autofix[autofix]' \
                    '--dryrun[dry run]' \
                    '--scan-unknown-extensions[scan unknown extensions]' \
                    '--oss-only[oss only]' \
                    '*:path:_files' ;;
                publish|validate|test) _arguments '*:file:_files' ;;
                show) _arguments \
                    '1:cmd:(supported-languages identity deployment scan-config rules dump-engine-path)' \
                    '*:arg:' ;;
                login|logout|lsp) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_opengrep "$@"
