#compdef roary
# roary — rapid large-scale prokaryotic pan genome analysis

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)'{-a,--check_dependancies}'[check all dependencies are installed]' \
  '(- *)--version[show version and exit]' \
  '(-f --output)'{-f,--output}'[output directory]:output dir:_files -/' \
  '(-e --create_svg)'{-e,--create_svg}'[create multiFASTA files for core genes and run MAFFT]' \
  '(-n --fast_core)'{-n,--fast_core}'[use CD-HIT for fast core gene alignment]' \
  '(-i --blastp_identity)'{-i,--blastp_identity}'[minimum percentage identity for BLASTp]:percent' \
  '(-cd --core_definition)'{-cd,--core_definition}'[core gene percentage threshold]:percent' \
  '(-g --group_limit)'{-g,--group_limit}'[maximum number of clusters]:limit' \
  '(-p --max_threads)'{-p,--max_threads}'[number of threads]:threads' \
  '(-v --verbose)'{-v,--verbose}'[verbose output to STDOUT]' \
  '(-r --create_plots)'{-r,--create_plots}'[create R plots]' \
  '(-s --dont_split_paralogs)'{-s,--dont_split_paralogs}'[do not split paralogs]' \
  '(-d --dont_delete_files)'{-d,--dont_delete_files}'[do not delete intermediate files]' \
  '(-t --translation_table)'{-t,--translation_table}'[translation table number]:table' \
  '(-y --yes)'{-y,--yes}'[say yes to all prompts]' \
  '(-b --blastp_exec)'{-b,--blastp_exec}'[path to blastp executable]:blastp:_files' \
  '(-m --makeblastdb_exec)'{-m,--makeblastdb_exec}'[path to makeblastdb executable]:makeblastdb:_files' \
  '(-qc --qc)'{-qc,--qc}'[run QC on the input GFF files]' \
  '(-k --kraken_db)'{-k,--kraken_db}'[path to Kraken database for QC]:kraken db:_files -/' \
  '(-iv --mcl_inflation)'{-iv,--mcl_inflation}'[MCL inflation value]:value' \
  '(-z --dont_delete_intermediate)'{-z,--dont_delete_intermediate}'[do not delete intermediate files]' \
  '(-ap --allow_paralogs)'{-ap,--allow_paralogs}'[allow paralogs in the pan genome]' \
  '*:GFF files:_files -g "*.gff(-.)"' \
  && ret=0

return ret
