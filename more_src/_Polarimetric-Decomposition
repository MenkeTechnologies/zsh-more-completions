#compdef Polarimetric-Decomposition
# Documentation: https://raw.githubusercontent.com/senbox-org/s1tbx/master/rstb/rstb-op-polarimetric-tools/src/main/java/org/csa/rstb/polarimetric/gpf/PolarimetricDecompositionOp.java
# ESA SNAP gpt Polarimetric-Decomposition operator - decompose polarimetric SAR data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-Pdecomposition=[decomposition type]:type' \
  '-PwindowSize=[the sliding window size]:size' \
  '-PoutputHAAlpha=[output entropy, anisotropy, alpha]:flag:(true false)' \
  '-PoutputBetaDeltaGammaLambda=[output beta, delta, gamma, lambda]:flag:(true false)' \
  '-PoutputAlpha123=[output alpha 1, 2, 3]:flag:(true false)' \
  '-PoutputLambda123=[output lambda 1, 2, 3]:flag:(true false)' \
  '-PoutputTouziParamSet0=[output psi, tau, alpha, phi]:flag:(true false)' \
  '-PoutputTouziParamSet1=[output psi1, tau1, alpha1, phi1]:flag:(true false)' \
  '-PoutputTouziParamSet2=[output psi2, tau2, alpha2, phi2]:flag:(true false)' \
  '-PoutputTouziParamSet3=[output psi3, tau3, alpha3, phi3]:flag:(true false)' \
  '-PoutputHuynenParamSet0=[output 2A0_b, B0_plus_B, B0_minus_B]:flag:(true false)' \
  '-PoutputHuynenParamSet1=[output A0, B0, B, C, D, E, F, G, H]:flag:(true false)' \
  '*:graph xml:_files' && ret=0

return ret
