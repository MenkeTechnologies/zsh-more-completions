#compdef coqui coqui-tts coqui-stt coqui-server
# _coqui — Coqui AI TTS multilingual text-to-speech and STT toolkit former Mozilla TTS continued (coqui-ai team, Python); argparse
# upstream: https://github.com/coqui-ai/TTS

_coqui() {
    local -a sub=(
        'tts:run text-to-speech synthesis'
        'list-models:list available models'
        'tts-server:start TTS HTTP server'
        'list-language-idxs:list language ids'
        'list-speaker-idxs:list speaker ids'
        'compute-statistics:compute audio statistics'
        'train:train a model'
        'train-tts:train TTS model'
        'train-vocoder:train vocoder'
        'train-encoder:train speaker encoder'
        'synthesize:synthesize from trained model'
        'eval:evaluate a model'
        'audio-tools:audio utility subcommands'
        'demo-server:start demo server'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--device=+[device]:d:(cpu cuda mps auto)' \
        '--use-cuda[use CUDA]' \
        '--model-name=+[model id]:str:' \
        '--model-path=+[checkpoint]:file:_files' \
        '--vocoder-name=+[vocoder model]:str:' \
        '--vocoder-path=+[vocoder checkpoint]:file:_files' \
        '--encoder-name=+[encoder]:str:' \
        '--encoder-path=+[encoder checkpoint]:file:_files' \
        '--config-path=+[config json]:file:_files -g "*.json *.yaml *.yml"' \
        '--vocoder-config-path=+[vocoder config]:file:_files -g "*.json *.yaml *.yml"' \
        '--config=+[config]:file:_files' \
        '-c+[config]:file:_files' \
        '--text=+[input text]:str:' \
        '-t+[input text]:str:' \
        '--out-path=+[output wav]:file:_files -g "*.wav"' \
        '-o+[output wav]:file:_files -g "*.wav"' \
        '--speaker-idx=+[speaker]:str:' \
        '--language-idx=+[language]:str:' \
        '--speaker-wav=+[speaker reference]:file:_files -g "*.wav *.mp3 *.flac"' \
        '--reference-wav=+[reference wav]:file:_files -g "*.wav *.mp3 *.flac"' \
        '--reference-speaker-idx=+[reference speaker]:str:' \
        '--capacitron-style-wav=+[style wav]:file:_files' \
        '--capacitron-style-text=+[style text]:str:' \
        '--list-speaker-idxs[list speakers]' \
        '--list-language-idxs[list languages]' \
        '--save-spectogram[save spectrogram]' \
        '--port=+[server port]:port:_ports' \
        '--host=+[server host]:host:_hosts' \
        '--debug[debug logging]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coqui subcommand' sub ;;
    esac
}

_coqui "$@"
