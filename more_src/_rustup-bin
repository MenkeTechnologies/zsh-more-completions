#compdef rustup
# _rustup-bin — Rust toolchain installer + version manager (Rust Project, Rust); manage rustc/cargo/std versions
# upstream: https://github.com/rust-lang/rustup

_rustup-bin() {
    local -a sub=(
        'check:check for updates'
        'completions:print shell completion'
        'component:component commands'
        'default:set default toolchain'
        'doc:open the docs'
        'dump-testament:print testament info'
        'help:show help'
        'install:install a toolchain'
        'man:open man page'
        'override:override toolchain for dir'
        'run:run command with toolchain'
        'self:self management'
        'set:set rustup settings'
        'show:show installed + active toolchains'
        'target:target commands'
        'toolchain:toolchain commands'
        'uninstall:uninstall a toolchain'
        'update:update toolchains'
        'which:print binary path'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '+toolchain[set toolchain for invocation]:toolchain:' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rustup subcommand' sub ;;
        args)
            case $words[1] in
                install|uninstall|default) _arguments \
                    '--force[force]' \
                    '--no-self-update[no self update]' \
                    '--force-non-host[allow non-host toolchain]' \
                    '*:toolchain:' ;;
                toolchain) _arguments \
                    '1:toolchain cmd:(install link list remove uninstall)' \
                    '*:toolchain:' ;;
                target) _arguments \
                    '1:target cmd:(add list remove)' \
                    '--toolchain+[toolchain]:toolchain:' \
                    '*:target:' ;;
                component) _arguments \
                    '1:component cmd:(add list remove)' \
                    '--toolchain+[toolchain]:toolchain:' \
                    '--target+[target]:target:' \
                    '*:component:' ;;
                override) _arguments \
                    '1:override cmd:(add list remove set unset)' \
                    '--nonexistent[allow nonexistent path]' \
                    '*:toolchain or dir:' ;;
                update) _arguments \
                    '--force[force]' \
                    '--no-self-update[no self update]' \
                    '*:toolchain:' ;;
                self) _arguments \
                    '1:self cmd:(uninstall update upgrade-data)' ;;
                set) _arguments \
                    '1:set cmd:(default-host profile auto-self-update)' \
                    '*:val:' ;;
                completions) _arguments \
                    '1:shell:(bash zsh fish powershell elvish)' \
                    '2:tool:(rustup cargo)' ;;
                which) _arguments \
                    '--toolchain+[toolchain]:toolchain:' \
                    '*:binary:' ;;
                show) _arguments '1:show what:(active-toolchain home keys profile)' ;;
            esac
            ;;
    esac
}

_rustup-bin "$@"
