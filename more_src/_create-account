#compdef create-account
# _create-account — create a Dendrite user account (element-hq/dendrite)
# upstream: https://github.com/element-hq/dendrite
# Flags from cmd/create-account/main.go.

_create-account() {
    _arguments \
        '-help[show help]' \
        '-username=[username localpart]:user:' \
        '-password=[account password]:password:' \
        '-passwordfile=[file containing the password]:file:_files' \
        '-passwordstdin[read password from stdin]' \
        '-admin[create an admin account]' \
        '-reset-password[deprecated]' \
        '-url=[homeserver URL (default http://localhost:8008)]:url:' \
        '-timeout=[HTTP client timeout (e.g. 30s)]:duration:' \
        '-config=[Dendrite config file]:file:_files -g "*.{yml,yaml}"'
}

_create-account "$@"
