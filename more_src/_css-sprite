#compdef css-sprite
# ============================================================================
# css-sprite - CSS image-sprite generator with
#               multi-preprocessor + retina +
#               base64 output (Node.js, MIT)
#
# Author : Alex Slansky (aslansky)
# Upstream: https://github.com/aslansky/css-sprite
# npm    : css-sprite (binary: css-sprite)
#
# `css-sprite` is a Node CLI that combines
# multiple source images into a single sprite
# sheet + generates corresponding CSS rules
# referencing the per-tile background-position
# offsets. The sprite-sheet technique was a
# canonical pre-HTTP/2 web optimization pattern
# (reduce HTTP request count by combining small
# icons + sprites into one large image). While
# HTTP/2 multiplexing reduced the need for
# sprite sheets, they remain useful for:
#   - Pixel-perfect alignment of UI icons
#   - Reduced CSS rule count (one
#     `background-image` rule + per-tile
#     position offsets)
#   - Retina-display support (2x source images
#     with auto-generated standard-resolution
#     fallback)
#   - Caching efficiency (one cacheable sprite
#     vs many small files)
#   - Embedded base64 sprites (single CSS file
#     with everything inline; useful for
#     email-template / data-URI scenarios)
#
# Architecture:
#   - vinyl-fs for cross-platform glob + stream
#     processing
#   - nomnom for CLI flag parsing
#   - lwip (Light Weight Image Processor) for
#     image manipulation
#   - color (Qix-/color) for sprite-background +
#     CSS-color generation
#   - Multi-preprocessor template support (CSS +
#     LESS + SASS + SCSS + Stylus)
#
# Use cases:
#   - Web-app icon-set bundling
#   - Email-template image embedding via base64
#   - CSS framework / design-system asset
#     pipeline
#   - Retina + standard sprite pairs for
#     responsive web design
#   - LESS/SASS/SCSS/Stylus mixin generation
#     for dynamic sprite reuse
#
# Usage:
#   css-sprite <out-dir> <src-glob>... [options]
#
# Positional arguments:
#   <out-dir>                      - directory
#                                     to write
#                                     sprite +
#                                     CSS output
#                                     (default
#                                     cwd)
#   <src-glob>...                  - source-
#                                     image glob
#                                     patterns
#                                     (repeatable)
#
# Flags (nomnom declarative):
#   -b, --base64                   - create CSS
#                                     with
#                                     base64-
#                                     encoded
#                                     inline
#                                     sprite (no
#                                     separate
#                                     image file
#                                     written)
#   -c, --css-image-path <path>    - HTTP path
#                                     to sprite
#                                     on the web
#                                     server
#                                     (default
#                                     `../
#                                     images`;
#                                     relative
#                                     to CSS
#                                     output or
#                                     absolute)
#   -f, --format <png|jpg>         - output
#                                     sprite
#                                     image
#                                     format
#                                     (default
#                                     png)
#   -n, --name <name>              - sprite file
#                                     name
#                                     without
#                                     extension
#                                     (default
#                                     sprite)
#   -p, --processor <type>         - CSS output
#                                     format
#                                     (css/
#                                     less/
#                                     sass/
#                                     scss/
#                                     stylus;
#                                     default
#                                     css)
#   -t, --template <file>          - custom
#                                     output
#                                     template
#                                     file
#                                     (overrides
#                                     --processor)
#   -r, --retina                   - generate
#                                     both
#                                     retina +
#                                     standard
#                                     sprites
#                                     (sources
#                                     must be
#                                     at retina
#                                     resolution)
#   -s, --style <file>             - CSS output
#                                     file path
#                                     (omit to
#                                     skip CSS
#                                     output)
#   -w, --watch                    - watch
#                                     source
#                                     globs +
#                                     regenerate
#                                     on change
#       --background <color>       - sprite
#                                     background
#                                     color in
#                                     hex
#                                     (default
#                                     #FFFFFF)
#       --cachebuster random       - append
#                                     random
#                                     query-
#                                     string to
#                                     sprite URL
#                                     in CSS
#                                     (cache-
#                                     busting)
#       --margin <px>              - margin
#                                     between
#                                     tiles in
#                                     px
#                                     (default
#                                     4)
#       --interpolation <algo>     - scaling
#                                     algorithm
#                                     for
#                                     retina
#                                     downscale
#                                     (nearest-
#                                     neighbor/
#                                     moving-
#                                     average/
#                                     linear/
#                                     grid/
#                                     cubic/
#                                     lanczos;
#                                     default
#                                     grid)
#       --opacity <0-100>          - sprite
#                                     background
#                                     opacity
#                                     (default
#                                     0 for png
#                                     / 100 for
#                                     jpg)
#       --orientation <type>       - sprite
#                                     image
#                                     layout
#                                     (vertical/
#                                     horizontal/
#                                     binary-
#                                     tree;
#                                     default
#                                     vertical)
#       --prefix <class>           - CSS class
#                                     prefix
#                                     (without
#                                     leading
#                                     `.`)
#       --no-sort                  - disable
#                                     sort
#                                     optimization
#                                     of
#                                     tile
#                                     layout
#
# Example invocations:
#   css-sprite dist 'src/icons/*.png'
#   css-sprite dist 'src/icons/*.png' \
#              -r -p scss --background '#f0f0f0'
#   css-sprite dist 'src/icons/*.png' \
#              -b --style dist/sprite.css
#   css-sprite dist 'src/icons/*.png' \
#              'src/buttons/*.png' \
#              -p stylus --orientation binary-tree
#   css-sprite dist 'src/icons/*.png' \
#              -w -p less --style dist/sprite.less
#
# The color lane is built on `color ^0.8.0`
# (declared verbatim at upstream package.json
# HEAD as a direct dep, imported as
# `var Color = require('color')` in lib/css-
# sprite.js, used to:
#   1. Parse the user-provided --background
#      hex color string
#   2. Compute background color + opacity
#      composition for the sprite-sheet PNG/JPG
#   3. Emit CSS background-color rules in the
#      generated stylesheet
# ), the canonical Node color manipulation
# library by Heather Arthur (Qix-) - github.com/
# Qix-/color.
#
# Heather Arthur (Qix-)'s Qix-/color is the
# de-facto canonical Node color manipulation
# library:
#   - 35,000,000+ weekly npm downloads
#   - Wraps the foundational microlibraries
#     of Heather's color ecosystem:
#     - color-name: CSS color name -> hex
#       mapping (red -> #ff0000, etc.)
#     - color-string: CSS color string
#       parsing (rgb() / hsl() / lab() /
#       hex / named)
#     - color-convert: comprehensive color-
#       space conversions
#   - Method-chaining fluent API for color
#     manipulation
#   - 30+ color manipulation methods (lighten +
#     darken + saturate + desaturate +
#     greyscale + negate + rotate + mix +
#     blend + ...)
#   - CSS string serialization in any supported
#     color space
#   - Type checking + safe color-space
#     conversions
#
# Qix-/color's distinguishing position vs Node
# color alternatives:
#   - color (Qix-): canonical; method-chaining
#     fluent API; wraps microlibs; THIS AXIS
#   - tinycolor2 (Brian Grinstead): popular
#     pre-color-package canonical; still widely
#     used in legacy projects
#   - chroma-js (Gregor Aisch): data-
#     visualization-focused; rich palette +
#     scale generation
#   - color2k: smaller bundle-size alternative
#     for client-side use
#   - colord: TypeScript-first modern
#     alternative
#   - culori: research-grade color science
#     (CAM02 + CAM16 + perceptual color
#     differences)
#
# Heather Arthur's broader Node ecosystem
# footprint (the Qix-/color microlib umbrella):
#   - Qix-/color (canonical Node color
#     manipulation; THIS AXIS)
#   - Qix-/color-name (CSS color name -> hex
#     mapping; foundation of every Node color
#     library)
#   - Qix-/color-string (CSS color string
#     parser)
#   - Qix-/color-convert (color-space
#     conversions)
#   - Qix-/color-name-list (broader CSS color
#     name + alias list)
#
# Arthur's role in the Node ecosystem is
# *binary-format + color-format microlib
# canonical infrastructure* - similar to:
#   - Bo Schwarzstein (Borewit; music-metadata
#     + peek-readable + strtok3 at Axis 271):
#     binary file format detection +
#     metadata extraction
#   - Sergey Belov + svgo team (svg/svgo at
#     Axis 264): SVG optimization microlibs
#   - Vitaly Puzrin + nodeca (Axis 262 YAML
#     and Axis 264 SVG indirectly): document
#     format parsing microlibs
#
# Arthur's canonical position is the *root of
# the Node color ecosystem* - color-name is
# used by every Node color library because it
# provides the canonical "red is #ff0000"
# mapping. color-string is used by every Node
# CSS parser because it provides the canonical
# rgb()/hsl() parsing logic.
#
# Multi-axis canonical-Node author/org cohort
# (now spanning 16 distinct individuals/orgs):
#   - Sindre Sorhus (chalk + ~1000 microlibs)
#   - Matt Ranney + Redis Inc. (node-redis)
#   - Brian Carlson (node-postgres)
#   - Andrey Sitnik (PostCSS + browserslist +
#     nanoid)
#   - Lovell Fuller (sharp)
#   - Paul Miller (noble umbrella)
#   - Devon Govett (foliojs umbrella +
#     lightningcss)
#   - Matteo Collina + mqttjs org (undici +
#     pino + fastify + MQTT.js)
#   - Isaac Z. Schlueter (3 axes: globbing,
#     TAR, INI)
#   - Vitaly Puzrin + nodeca (js-yaml +
#     markdown-it + pako + argparse + sax +
#     linkify-it)
#   - Sergey Belov + svgo team (svg/svgo)
#   - Matt Zabriskie + axios team (axios)
#   - Stuart Knightley (jszip)
#   - Justin Latimer (node-midi)
#   - Bo Schwarzstein / Borewit (music-metadata
#     umbrella)
#   - Heather Arthur / Qix- (color + color-name
#     + color-string + color-convert microlib
#     umbrella, THIS AXIS)
#
# css-sprite uses color in lib/css-sprite.js:
#   ```js
#   var Color = require('color');
#
#   function makeBackground(hex, opacity) {
#     var c = Color(hex);
#     if (opacity !== undefined) {
#       c.alpha(opacity / 100);
#     }
#     return c.rgbString();
#   }
#   ```
# This parses the user-supplied --background
# hex value + applies the --opacity setting +
# emits a CSS rgb()/rgba() string for the
# generated stylesheet.
#
# ----------------------------------------------------------------------------
# AXIS 272 :: Color manipulation + color space
#              conversion libraries (sRGB +
#              linear RGB + CIE XYZ + CIE Lab +
#              HSL + Oklab + Okhsl + color
#              difference + interpolation)
# Round 1516 :: TS-Node slot 3 of 4 :: CLOSES Axis 272
#                                       (265th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : Ogeon/palette              [R1514 _okolors]
#             (Erik Hedvall; type-safe
#              color space encoding;
#              first-class Oklab)
#   Go      : lucasb-eyer/go-colorful    [R1515 _termpicker]
#             (Lucas Beyer; comprehensive
#              CIE-correct manipulation;
#              substrate of every Go TUI
#              framework)
#   TS/Node : Qix-/color                 [R1516 THIS FILE]
#             (Heather Arthur; canonical
#              Node color manipulation;
#              35M+ weekly downloads;
#              wraps color-name + color-
#              string + color-convert
#              microlibs)
#
# Qix-/color closes Axis 272 with the
# *microlib-wrapper canonical* pattern. The
# three lanes demonstrate three distinct
# Node-canonical-library architectures:
#
#   - Rust (palette): type-safe encoding
#     prevents color-space coordinate mixing
#     at compile time
#   - Go (go-colorful): single canonical
#     package transitively depended on by
#     every Go TUI framework
#   - Node (color): thin wrapper around
#     specialized microlibs (color-name +
#     color-string + color-convert);
#     reflects Node's microlib culture
#
# Each lane's mechanism reflects the host
# ecosystem's typical packaging conventions:
#   - Rust: prefer comprehensive single-crate
#     coverage with type-safety
#   - Go: prefer comprehensive single-package
#     coverage with transitive dep dominance
#   - Node: prefer small composable microlibs
#     with thin wrapper ergonomics layer
#
# Cross-language interop at the sRGB hex code
# + RGB triple level - all three canonicals
# parse + emit identical hex / rgb() / hsl()
# strings. Lab + Oklab + Lch coordinates
# require FP precision but produce equivalent
# results within FP tolerances.
#
# Use-case spectrum across the three lanes:
#   - okolors (Rust, palette): image ->
#     palette extraction via Oklab k-means
#     clustering
#   - termpicker (Go, go-colorful):
#     interactive TUI color picker with
#     multi-space conversion + preview pane
#   - css-sprite (Node, color): CSS sprite-
#     sheet generator with background-color
#     + opacity composition
#
# Three lanes, three use-case shapes (palette
# extraction / interactive picking / CSS-
# pipeline generation), three packaging
# architectures (comprehensive type-safe Rust
# crate / comprehensive single Go package /
# Node microlib-wrapper pattern), all
# converging on the same color science +
# CIE/Oklab/sRGB conversion math.
#
# Axis 272 closes the round 1516 cycle - 265th
# axis closed total.
#
# Notable structural pattern across the
# *specialized-protocol/format canonical
# cluster* in Rust: each axis 268-272 has had
# a distinct specialized-protocol author:
#   - Axis 268 (INI) Rust: Y. T. Chung /
#     zonyitoo (rust-ini)
#   - Axis 269 (MIDI) Rust: Patrick Klein /
#     Boddlnagg (midir)
#   - Axis 270 (MQTT) Rust: Bytebeam Tech
#     (rumqtt)
#   - Axis 271 (Audio codec) Rust: Philip
#     Deljanov (Symphonia)
#   - Axis 272 (Color) Rust: Erik Hedvall /
#     Ogeon (palette)
#
# These specialized-protocol authors form a
# distinct cluster from the broader
# foundational-library authors (Tolnay +
# Crichton + Gallant + Reizner + McArthur).
# Each owns a specific format/protocol
# vertical without spanning multiple unrelated
# verticals. This is the largest single
# cluster in the Rust ecosystem by author
# count.
# ============================================================================

_css-sprite() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-b --base64)'{-b,--base64}'[create CSS with base64-encoded inline sprite]' \
        '(-c --css-image-path)'{-c,--css-image-path}'[HTTP path to sprite on web server]:path:' \
        '(-f --format)'{-f,--format}'[output sprite image format]:format:(png jpg)' \
        '(-n --name)'{-n,--name}'[sprite file name (no extension)]:name:' \
        '(-p --processor)'{-p,--processor}'[CSS output format]:type:(css less sass scss stylus)' \
        '(-t --template)'{-t,--template}'[custom output template file]:file:_files' \
        '(-r --retina)'{-r,--retina}'[generate both retina + standard sprites]' \
        '(-s --style)'{-s,--style}'[CSS output file path]:file:_files' \
        '(-w --watch)'{-w,--watch}'[watch source globs and regenerate on change]' \
        '--background=[sprite background color in hex]:color:' \
        '--cachebuster=[cache-buster strategy]:strategy:(random)' \
        '--margin=[margin between tiles in px]:px:' \
        '--interpolation=[retina downscale algorithm]:algo:(nearest-neighbor moving-average linear grid cubic lanczos)' \
        '--opacity=[sprite background opacity (0-100)]:opacity:' \
        '--orientation=[sprite image layout]:type:(vertical horizontal binary-tree)' \
        '--prefix=[CSS class prefix]:prefix:' \
        '--no-sort[disable sort optimization of tile layout]' \
        '(- *)'{-h,--help}'[print help]' \
        '*:src glob or out dir:_files'
}

_css-sprite "$@"
