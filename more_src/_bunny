#compdef bunny
# Documentation: https://docs.bunny.net/cli
# bunny.net CLI for managing bunny.net from the terminal

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--output=[format results]:format:(json csv markdown)' \
  '--profile=[switch between multiple accounts]:profile' \
  '*:command:((login\:"browser-based or API key authentication" logout\:"end current session" db\:"create and manage Bunny Databases" scripts\:"scaffold deploy and manage Edge Scripts" api\:"execute authenticated requests to bunny.net API" config\:"manage CLI configuration and named profiles"))' && ret=0

return ret
