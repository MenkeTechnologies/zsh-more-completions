#compdef ballista-scheduler
# Documentation: https://datafusion.apache.org/ballista/user-guide/deployment/quick-start.html
# Apache DataFusion Ballista distributed query scheduler process

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-n --namespace)'{-n,--namespace}'=[namespace for the ballista cluster]:namespace' \
  '--bind-host=[local host name or IP address to bind to]:host' \
  '--external-host=[host name or IP for executors to connect to]:host' \
  '(-p --bind-port)'{-p,--bind-port}'=[port to bind the scheduler gRPC service]:port' \
  '(-s --scheduler-policy)'{-s,--scheduler-policy}'=[task scheduling policy]:policy:(pull-staged push-staged)' \
  '--event-loop-buffer-size=[event loop buffer size for high throughput]:size' \
  '--finished-job-data-clean-up-interval-seconds=[interval for cleaning up finished job data]:seconds' \
  '--finished-job-state-clean-up-interval-seconds=[interval for cleaning up finished job state]:seconds' \
  '--task-distribution=[task distribution policy]:policy:(bias round-robin consistent-hash)' \
  '--advertise-flight-sql-endpoint=[route for proxying flight sql results via scheduler]:endpoint' \
  '--log-dir=[directory path for log files]:dir:_files -/' \
  '--print-thread-info=[print thread IDs and names in log files]:bool:(true false)' \
  '--log-level-setting=[log level configuration for modules]:level' \
  '--log-rotation-policy=[log rotation policy]:policy:(minutely hourly daily never)' \
  '--job-resubmit-interval-ms=[interval in ms before resubmitting unscheduled jobs]:ms' \
  '--executor-termination-grace-period=[grace period in seconds for executor termination]:seconds' \
  '--scheduler-event-expected-processing-duration=[expected scheduler event processing time in microseconds]:micros' \
  '--grpc-server-max-decoding-message-size=[maximum size of decoded gRPC messages]:bytes' \
  '--grpc-server-max-encoding-message-size=[maximum size of encoded gRPC messages]:bytes' \
  '--executor-timeout-seconds=[timeout before marking an executor as dead]:seconds' \
  '--expire-dead-executor-interval-seconds=[interval to check for dead executors]:seconds' \
  '--task-max-failures=[number of failures before task is considered failed]:count' \
  '--stage-max-failures=[number of failures before stage is considered failed]:count' \
  '--disable-rest-api=[disable the rest api]:bool:(true false)' \
  '--cors-allowed-origins=[comma-separated list of allowed CORS origins]:origins' \
  '--cors-allowed-methods=[comma-separated list of allowed CORS methods]:methods' && ret=0

return ret
