#compdef vvp

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-i[interactive mode]' \
  '-l+[log output to file]:log file:_files' \
  '-M+[add VPI module search directory]:directory:_directories' \
  '-m+[load VPI module]:module name' \
  '-n[do not execute \$finish]' \
  '-N[same as -n but also suppress \$stop]' \
  '-s[stop at time 0]' \
  '-v[verbose output]' \
  '+vcd[generate VCD output]' \
  '+vcd2fst[convert VCD to FST output]' \
  '+vcd-off[disable VCD output]' \
  '+fst+speed[optimize FST for speed]' \
  '+fst+parallel[enable parallel FST writing]' \
  '+fst+nodate[do not include date in FST]' \
  '+fst+notimescale[do not include timescale in FST]' \
  '1:simulation file:_files -g "*.(vvp|out)"' \
  '*:plusargs:' && ret=0

return ret
