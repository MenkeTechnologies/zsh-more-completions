#compdef freecadqt

# freecadqt: FreeCAD Qt GUI launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --console)'{-c,--console}'[console mode (no GUI)]' \
  '(-l --log-file)'{-l,--log-file=}'[log file]:file:_files' \
  '(-M --module-path)'{-M,--module-path=}'[module path]:dir:_files -/' \
  '*:FreeCAD file:_files -g "*.(FCStd|step|stp|iges|igs|brep|stl)"' && ret=0
return ret
