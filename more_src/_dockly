#compdef dockly
# Documentation: https://github.com/lirantal/dockly
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-s --socketPath)'{-s,--socketPath}'=[docker socket path]:path:_files' \
  '(-H --host)'{-H,--host}'=[remote docker daemon host]:host' \
  '(-P --port)'{-P,--port}'=[remote docker port]:port' \
  '(-T --protocol)'{-T,--protocol}'=[remote docker protocol]:protocol:(http https ssh)' \
  '--containerFilters=[filter displayed containers \(form-urlencoded\)]:filters' && return 0
