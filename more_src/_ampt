#compdef ampt
# Documentation: https://www.getampt.com/docs/
# Reference accessed: 2026-05-17
# Verified: getampt/ampt serverless cloud platform CLI. Real
# subcommands: login, deploy, share, run, export, import, version
# (and `dev` is the default with no args). Global flags: -h/--help,
# -v/--version, --region, --force.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:Authenticate with Ampt'
  'deploy:Deploy code to a permanent environment'
  'share:Create a temporary preview environment'
  'run:Run a script locally'
  'export:Export data from your sandbox'
  'import:Import data into your sandbox'
  'version:Show version information'
)

_arguments -s -S \
  '--help[show help message]' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ampt command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (deploy|share)
        _arguments -s -S \
          '--container[run in a containerized environment]' \
          '1:environment name:' && ret=0
        ;;
      (run)
        _arguments -s -S '1:script:' && ret=0
        ;;
      (export)
        _arguments -s -S \
          '(-o --overwrite)'{-o,--overwrite}'[overwrite existing file]' \
          '1:file:_files' && ret=0
        ;;
      (import)
        _arguments -s -S '1:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
