#compdef pto_template
# Documentation: https://wiki.panotools.org/Pto_template
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pto_template: apply a Hugin template to a .pto project
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output pto filename]:file:_files -g "*.pto"' \
  '--template=[template pto file (required)]:file:_files -g "*.pto"' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
