#compdef pto_template
# Documentation: https://man.archlinux.org/search?q=pto_template
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-o+[output project file]:file:_files -g "*.pto"' \
  '--template=[template]:file:_files -g "*.pto"' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
