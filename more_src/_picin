#compdef picin
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss148.html
# KAPPA: find the attributes of a picture interior to the current picture

local ret=1

_arguments -s \
  'CURRENT=[compare against the current picture first]:current:(TRUE FALSE)' \
  'DESCRIBE=[report a description of the Frame]:describe:(TRUE FALSE)' \
  'DEVICE=[graphics device to query]:device' \
  'EPOCH=[epoch for celestial coordinate systems]:epoch' \
  'FRAME=[coordinate Frame for reported bounds]:frame' \
  'NAME=[name of the picture to find]:name' \
  'REPORT=[report picture details]:report:(TRUE FALSE)' \
  '*:NDF:_files' && ret=0

return ret
