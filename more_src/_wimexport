#compdef wimexport
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-export.1.html
# wimexport — export an image from one WIM to another

local ret=1

_arguments -s -S \
  '--boot[mark the exported image as bootable]' \
  '--check[verify integrity and include integrity info in output]' \
  '--nocheck[exclude integrity info from the destination WIM]' \
  '--include-integrity[add integrity info without prior verification]' \
  '--compress=[set compression type and optional level]:type:(none XPRESS LZX LZMS)' \
  '--chunk-size=[set WIM compression chunk size]:size' \
  '--recompress[force recompression of all data]' \
  '--solid[create a solid archive for better compression]' \
  '--solid-compress=[set compression type for solid resources]:type:(none XPRESS LZX LZMS)' \
  '--solid-chunk-size=[set chunk size for solid resources]:size' \
  '--threads=[number of compression threads]:threads' \
  '--ref=[reference additional WIMs or split parts]:glob' \
  '--pipable[build destination as a pipable WIM]' \
  '--not-pipable[rebuild destination as a non-pipable WIM]' \
  '--wimboot[mark destination as WIMBoot-compatible]' \
  '*:WIM file:_files' && ret=0

return ret
