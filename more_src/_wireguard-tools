#compdef wg
# _wireguard-tools — WireGuard wg helper (configuration utility for the kernel WireGuard module; subcommands: show (default), showconf, set, setconf, addconf, syncconf, genkey, genpsk, pubkey, strip; positional argument is the wg interface (default all) followed by per-subcommand args)
# upstream: https://git.zx2c4.com/wireguard-tools
# Subcommands from wireguard-tools src/wg.c on tip.

_wireguard-tools() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'wg command' '(show showconf set setconf addconf syncconf genkey genpsk pubkey strip help)' ;;
        args)
            case $line[1] in
                show) _arguments \
                    '1:interface or all:_net_interfaces' \
                    '2:section:(private-key public-key listen-port fwmark peers preshared-keys endpoints allowed-ips latest-handshakes persistent-keepalive transfer dump)' ;;
                showconf|strip|addconf|syncconf|setconf) _arguments '1:interface:_net_interfaces' '2:file:_files -g "*.conf"' ;;
                set) _arguments '1:interface:_net_interfaces' '*:arg:' ;;
                pubkey|strip) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_wireguard-tools "$@"
