#compdef qstart
# _qstart-pbs — PBS qstart (server-side queue control: start a previously stopped PBS queue so its jobs may be scheduled and executed; positional argument is a list of queue names; admin-only command — runs as the PBS server's manager identity)
# upstream: https://github.com/openpbs/openpbs
# Argument shape from openpbs src/cmds/qstart.c on tip.

_qstart-pbs() {
    _arguments \
        '*:queue:'
}

_qstart-pbs "$@"
