#compdef maturin

# Zsh completion for maturin - Python/Rust build tool (PyO3)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[increase verbosity]' \
  '-q[decrease verbosity]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'build:build the crate into a Python package'
      'publish:build and publish the crate as a Python package'
      'develop:install the crate as a module in the virtualenv'
      'sdist:build a source distribution'
      'upload:upload Python packages to PyPI'
      'list-python:search and list available Python installations'
      'new:create a new maturin project'
      'init:initialize a maturin project in an existing directory'
      'generate-ci:generate CI configuration'
      'completions:generate shell completions'
    )
    _describe -t commands 'maturin commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      build)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-r --release)'{-r,--release}'[build artifacts in release mode]' \
          '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs:' \
          '--target=[build for target triple]:target:' \
          '--profile=[build with the specified profile]:profile:' \
          '--strip[strip output]' \
          '(-o --out)'{-o,--out}'[output directory]:directory:_directories' \
          '--sdist[also create a source distribution]' \
          '--compatibility=[manylinux compatibility]:compat:(linux manylinux2010 manylinux2014 manylinux_2_17 manylinux_2_24 manylinux_2_28 musllinux_1_1 musllinux_1_2)' \
          '-i[Python interpreter to use]:interpreter:_files' \
          '--interpreter=[Python interpreter to use]:interpreter:_files' \
          '--find-interpreter[find interpreters from the host machine]' \
          '-m[path to Cargo.toml]:file:_files' \
          '--manifest-path=[path to Cargo.toml]:file:_files' \
          '--features=[Cargo features to activate]:features:' \
          '--all-features[activate all Cargo features]' \
          '--no-default-features[disable default Cargo features]' \
          '--skip-auditwheel[skip auditwheel]' \
          '--zig[use zig as linker]' \
          '*:extra args:' && ret=0
        ;;
      publish)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-r --release)'{-r,--release}'[build artifacts in release mode]' \
          '--repository=[PyPI repository]:repo:' \
          '--repository-url=[repository URL]:url:' \
          '(-u --username)'{-u,--username}'[PyPI username]:username:' \
          '(-p --password)'{-p,--password}'[PyPI password]:password:' \
          '--skip-existing[skip existing files]' \
          '--target=[build for target triple]:target:' \
          '-m[path to Cargo.toml]:file:_files' \
          '--manifest-path=[path to Cargo.toml]:file:_files' \
          '--features=[Cargo features to activate]:features:' \
          '--all-features[activate all Cargo features]' \
          '--no-default-features[disable default Cargo features]' && ret=0
        ;;
      develop)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-r --release)'{-r,--release}'[build in release mode]' \
          '--strip[strip output]' \
          '-E[install extra requires]:extras:' \
          '--extras=[install extra requires]:extras:' \
          '--skip-install[skip pip install]' \
          '-m[path to Cargo.toml]:file:_files' \
          '--manifest-path=[path to Cargo.toml]:file:_files' \
          '--features=[Cargo features to activate]:features:' \
          '--all-features[activate all Cargo features]' \
          '--no-default-features[disable default Cargo features]' && ret=0
        ;;
      upload)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repository=[PyPI repository]:repo:' \
          '--repository-url=[repository URL]:url:' \
          '(-u --username)'{-u,--username}'[PyPI username]:username:' \
          '(-p --password)'{-p,--password}'[PyPI password]:password:' \
          '--skip-existing[skip existing files]' \
          '*:wheel files:_files -g "*.whl"' && ret=0
        ;;
      new|init)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--name=[package name]:name:' \
          '--bindings=[binding type]:type:(pyo3 cffi uniffi bin mixed)' \
          '--mixed[create src/lib.rs and python module]' \
          '1:path:_directories' && ret=0
        ;;
      generate-ci)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --out)'{-o,--out}'[output path]:path:_files' \
          '1:CI provider:(github)' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
