#compdef gmx-wheel
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-wheel.html
# gmx wheel: plot helical wheels

local ret=1

_arguments -s \
  '-f[generic data file]:file:_files' \
  '-o[encapsulated PostScript file]:file:_files' \
  '-r0[the first residue number in the sequence]:int:' \
  '-rot0[rotate around an angle initially]:real:' \
  '-T[plot a title in the wheel center]:string:' \
  '-nn[toggle residue numbers on/off]' && ret=0

return ret
