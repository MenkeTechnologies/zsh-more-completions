#compdef coverm
# Documentation: https://wwood.github.io/CoverM/
# CoverM - read coverage calculator for metagenomics

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'genome:calculate coverage of genomes'
      'contig:calculate coverage of contigs'
      'make:generate BAM files through alignment'
      'filter:filter alignments by identity'
      'cluster:dereplicate and cluster genomes'
      'shell-completion:generate shell completion scripts'
    )
    _describe -t commands 'coverm command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      genome|contig)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--full-help[show full help]' \
          '-1+[forward read files]:files:_files' \
          '-2+[reverse read files]:files:_files' \
          '(-c --coupled)'{-c,--coupled}'+[paired forward and reverse read files]:files:_files' \
          '--interleaved=[interleaved read files]:files:_files' \
          '--single=[unpaired read files]:files:_files' \
          '(-b --bam-files)'{-b,--bam-files}'+[reference-sorted BAM files]:files:_files' \
          '(-r --reference)'{-r,--reference}'+[reference fasta or index]:file:_files' \
          '(-p --mapper)'{-p,--mapper}'=[mapping software]:mapper:(minimap2-sr minimap2-ont minimap2-pb minimap2-no-preset bwa-mem bwa-mem2 strobealign)' \
          '--minimap2-params=[extra minimap2 parameters]:params' \
          '--bwa-params=[extra BWA parameters]:params' \
          '--strobealign-params=[extra strobealign parameters]:params' \
          '--sharded[choose best hits across references]' \
          '--min-read-aligned-length=[exclude reads below aligned bases]:len' \
          '--min-read-percent-identity=[exclude reads by percent identity]:pct' \
          '--min-read-aligned-percent=[exclude reads by aligned percent]:pct' \
          '--proper-pairs-only[require properly mapped pairs]' \
          '--exclude-supplementary[exclude supplementary alignments]' \
          '--include-secondary[include secondary alignments]' \
          '(-m --methods)'{-m,--methods}'+[coverage calculation methods]:method:(mean relative_abundance trimmed_mean coverage_histogram covered_bases covered_fraction variance length count reads_per_base rpkm tpm)' \
          '--min-covered-fraction=[minimum covered fraction]:frac' \
          '--contig-end-exclusion=[exclude bases at ends (default 75)]:bases' \
          '--trim-min=[minimum fraction for trimmed mean]:frac' \
          '--trim-max=[maximum fraction for trimmed mean]:frac' \
          '(-o --output-file)'{-o,--output-file}'=[output coverage file]:file:_files' \
          '--output-format=[output format]:format:(sparse dense)' \
          '--no-zeros[omit zero-coverage entries]' \
          '--bam-file-cache-directory=[directory for output BAM files]:dir:_files -/' \
          '--discard-unmapped[exclude unmapped reads from cached BAMs]' \
          '(-f --genome-fasta-files)'{-f,--genome-fasta-files}'+[individual genome fasta files]:files:_files' \
          '(-d --genome-fasta-directory)'{-d,--genome-fasta-directory}'=[directory of genome fastas]:dir:_files -/' \
          '(-x --genome-fasta-extension)'{-x,--genome-fasta-extension}'=[fasta extension in directory]:ext' \
          '(-s --separator)'{-s,--separator}'=[genome/contig name separator]:sep' \
          '--single-genome[all contigs from same genome]' \
          '--dereplicate[perform genome dereplication]' \
          '(-t --threads)'{-t,--threads}'=[number of threads]:threads' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(-q --quiet)'{-q,--quiet}'[suppress log messages]' && ret=0
        ;;
      cluster)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--full-help[show full help]' \
          '(-f --genome-fasta-files)'{-f,--genome-fasta-files}'+[individual genome fasta files]:files:_files' \
          '(-d --genome-fasta-directory)'{-d,--genome-fasta-directory}'=[directory of genome fastas]:dir:_files -/' \
          '(-x --genome-fasta-extension)'{-x,--genome-fasta-extension}'=[fasta extension (default fna)]:ext' \
          '--genome-fasta-list=[file with fasta paths]:file:_files' \
          '--checkm2-quality-report=[CheckM2 quality report]:file:_files' \
          '--checkm-tab-table=[CheckM tab table]:file:_files' \
          '--genome-info=[dRep genome info table]:file:_files' \
          '--min-completeness=[minimum completeness]:pct' \
          '--max-contamination=[maximum contamination]:pct' \
          '--ani=[ANI level for dereplication (default 95)]:ani' \
          '--min-aligned-fraction=[minimum aligned fraction (default 15)]:frac' \
          '--fragment-length=[FastANI fragment length (default 3000)]:len' \
          '--quality-formula=[genome quality scoring function]:formula' \
          '--precluster-ani=[minimum ANI for preclustering (default 90)]:ani' \
          '--precluster-method=[preclustering method]:method:(dashing finch skani)' \
          '--cluster-method=[ANI calculation method]:method:(fastani skani)' \
          '--output-cluster-definition=[output cluster definition file]:file:_files' \
          '--output-representative-fasta-directory=[symlink representatives dir]:dir:_files -/' \
          '--output-representative-list=[output representative paths file]:file:_files' \
          '(-t --threads)'{-t,--threads}'=[number of threads]:threads' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(-q --quiet)'{-q,--quiet}'[suppress log messages]' && ret=0
        ;;
      *)
        _arguments '(-h --help)'{-h,--help}'[show help]' '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
