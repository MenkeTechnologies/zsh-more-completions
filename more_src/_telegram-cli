#compdef telegram-cli

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '-u+[username]:user:_users' \
  '-k+[public key]:file:_files -g "*.pub"' \
  '-v[verbose]' \
  '-N[print message numbers]' \
  '-W[wait for connection]' \
  '-C[disable color]' \
  '-R[disable readline]' \
  '-d[daemon mode]' \
  '-L+[log file]:file:_files' \
  '-c+[config file]:file:_files' \
  '-p+[profile name]:p:' \
  '-l+[log level]:l:(0 1 2 3 4 5)' \
  '-D[disable link preview]' \
  '-P+[proxy]:proxy:' \
  '-Z+[port]:port:' \
  '-s+[lua script]:file:_files -g "*.lua"' \
  '-e+[execute command]:cmd:' \
  '-S[enable msg dump]' \
  '-w+[work dir]:dir:_files -/' \
  '-T[disable autoaccept invites]' \
  '-I[disable IPv6]' \
  '-f[disable file storage]' \
  '-B[binary mode]' \
  '*: :' && ret=0

return ret
