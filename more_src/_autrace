#compdef autrace
# _autrace — Linux audit autrace (trace a single process via the audit subsystem: writes syscall, fork, network and file-access records for one PID/program then exits; -r raw output, -h help; positional argument is the command to run with optional args; analyse the produced records with ausearch -p)
# upstream: https://github.com/linux-audit/audit-userspace
# Flags from linux-audit/audit-userspace src/autrace.c on tip.

_autrace() {
    _arguments \
        '-h[show help]' \
        '-r[raw output]' \
        '*::command:_command_names -e'
}

_autrace "$@"
