#compdef mafRanges
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: extract ranges of target (or query) coverage from maf as BED 3

local ret=1

_arguments -s -S \
  '-otherDb=[output ranges only for alignments including oDb (comma-separated)]:db' \
  '-notAllOGap[do not include bases for which all other species have a gap]' \
  '1:input maf:_files -g "*.maf"' \
  '2:db:' \
  '3:output bed:_files -g "*.bed"' && ret=0

return ret
