#compdef opa2
# _opa2 — CNCF Open Policy Agent opa2 CLI command-line frontend wrapping the Open Policy Agent OPA general-purpose policy engine that unifies policy enforcement across the stack open-source written in Go HashiCorp-Style Rego declarative-policy language deploy-as-sidecar daemon-mode policy decision evaluation bundle decision-log discovery enterprise-OPA-Plus Rego REPL parse eval run bench check fmt build deps test version sign capabilities exec inspect inspect-bundle (CNCF OPA Tim Hinrichs Styra team, Go); cobra
# upstream: https://www.openpolicyagent.org/

_opa2() {
    local -a sub=(
        'bench:benchmark a query'
        'build:build a policy bundle'
        'capabilities:print capabilities'
        'check:check Rego policies'
        'completion:generate shell completion'
        'deps:print policy dependencies'
        'eval:evaluate a Rego query'
        'exec:execute decisions over files'
        'fmt:format Rego files'
        'inspect:inspect a bundle'
        'parse:parse Rego files'
        'refactor:refactor Rego files'
        'run:start OPA server/REPL'
        'sign:generate signed bundle file'
        'test:run policy tests'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s+[server address]:str:' \
        '--server[run as server]' \
        '-a+[address]:str:' \
        '--addr=+[host:port]:_hosts' \
        '*--addr=+[host:port]:_hosts' \
        '--diagnostic-addr=+[host:port]:_hosts' \
        '--authentication=+[m]:m:(off token tls)' \
        '--authorization=+[m]:m:(off basic)' \
        '--tls-cert-file=+[file]:file:_files -g "*.pem *.crt"' \
        '--tls-private-key-file=+[file]:file:_files -g "*.pem *.key"' \
        '--tls-ca-cert-file=+[file]:file:_files -g "*.pem *.crt"' \
        '--tls-cert-refresh-period=+[d]:str:' \
        '--shutdown-grace-period=+[sec]:n:' \
        '--shutdown-wait-period=+[sec]:n:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config-file=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config-overrides=+[k=v]:str:' \
        '*--config-overrides=+[k=v]:str:' \
        '--config-overrides-file=+[file]:file:_files' \
        '-b+[bundle]:_files' \
        '--bundle[treat input as bundle]' \
        '-l+[log level]:l:(debug info error warn)' \
        '--log-level=+[l]:l:(debug info error warn)' \
        '--log-format=+[f]:f:(text json json-pretty)' \
        '--log-timestamp-format=+[fmt]:str:' \
        '--ready-timeout=+[sec]:n:' \
        '--exclude-files-verify=+[paths]:str:' \
        '--watch[watch files]' \
        '-w[watch files]' \
        '-d+[data file/dir]:_files' \
        '*-d+[data file/dir]:_files' \
        '--data=+[file]:_files' \
        '-i+[input file]:file:_files -g "*.json *.yaml"' \
        '--input=+[file]:file:_files -g "*.json *.yaml"' \
        '-f+[output format]:f:(json pretty values bindings source raw)' \
        '--format=+[fmt]:f:(json pretty values bindings source raw)' \
        '--explain=+[e]:e:(off full notes fails debug)' \
        '--metrics[show metrics]' \
        '--instrument[enable instrumentation]' \
        '--profile[profile evaluation]' \
        '--coverage[show test coverage]' \
        '--stdin[read query from stdin]' \
        '--stdin-input[read input from stdin]' \
        '--partial[do partial eval]' \
        '--unknowns=+[refs]:str:' \
        '*--unknowns=+[refs]:str:' \
        '--package=+[name]:str:' \
        '--schema=+[file]:file:_files -g "*.json"' \
        '--strict-builtin-errors[strict builtin errors]' \
        '--show-builtin-errors[show builtin errors]' \
        '--capabilities=+[file]:file:_files -g "*.json"' \
        '--ignore=+[paths]:str:' \
        '*--ignore=+[paths]:str:' \
        '--target=+[t]:t:(rego wasm plan)' \
        '-t+[target]:t:(rego wasm plan)' \
        '--optimize=+[N]:n:' \
        '-O+[optimize]:n:' \
        '--debug[debug bundle]' \
        '--entrypoint=+[ep]:str:' \
        '*-e+[entrypoint]:str:' \
        '--revision=+[rev]:str:' \
        '--scope=+[scope]:str:' \
        '--signing-alg=+[alg]:str:' \
        '--signing-key=+[file]:file:_files' \
        '--signing-plugin=+[name]:str:' \
        '--verification-key=+[file]:file:_files' \
        '--verification-key-id=+[id]:str:' \
        '--bundle-verification-skip-known-keys[skip known keys]' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'opa subcommand' sub ;;
        args)
            case $words[1] in
                eval|bench) _arguments '*:query:' ;;
                build|check|deps|fmt|inspect|parse|sign|test|refactor) _arguments '*:path:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_opa2 "$@"
