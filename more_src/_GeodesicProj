#compdef GeodesicProj
# Documentation: https://geographiclib.sourceforge.io/C++/doc/GeodesicProj.1.html
# GeographicLib: geodesic-based azimuthal, Cassini-Soldner, and gnomonic projections

local ret=1

_arguments -s -S \
  '-z[azimuthal equidistant projection centered at lat0 lon0]:lat0:' \
  '-c[Cassini-Soldner projection centered at lat0 lon0]:lat0:' \
  '-g[ellipsoidal gnomonic projection centered at lat0 lon0]:lat0:' \
  '-r[perform reverse projection]' \
  '-e[specify ellipsoid via equatorial radius and flattening]:a:' \
  '-w[toggle longitude-first flag]' \
  '-p[set output precision]:prec:' \
  '--comment-delimiter[set comment delimiter]:delim:' \
  '--version[print version and exit]' \
  '(-h --help)-h[print usage and exit]' \
  '(-h --help)--help[print full documentation and exit]' \
  '--input-file[read input from file]:infile:_files' \
  '--input-string[read input from string]:string:' \
  '--line-separator[set line separator character]:linesep:' \
  '--output-file[write output to file]:outfile:_files' && ret=0

return ret
