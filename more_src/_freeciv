#compdef freeciv freeciv-client freeciv-gtk3 freeciv-qt freeciv-sdl freeciv-gtk4

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --autoconnect)'{-a,--autoconnect}'[auto connect]' \
  '(-d --debug)'{-d,--debug}'+[debug level]:lvl:' \
  '(-l --log)'{-l,--log}'+[log file]:file:_files' \
  '(-m --meta)'{-m,--meta}'+[meta server]:srv:' \
  '(-n --name)'{-n,--name}'+[player name]:name:' \
  '(-p --port)'{-p,--port}'+[server port]:port:' \
  '(-s --server)'{-s,--server}'+[server addr]:host:_hosts' \
  '(-r --read)'{-r,--read}'+[script]:file:_files' \
  '(-S --sound)'{-S,--sound}'+[sound plugin]:plugin:' \
  '(-t --tiles)'{-t,--tiles}'+[tileset]:set:' \
  '(-w --warnings)'{-w,--warnings}'[show warnings]' \
  '(-F --Fatal)'{-F,--Fatal}'+[fatal log level]:lvl:' && ret=0

return ret
