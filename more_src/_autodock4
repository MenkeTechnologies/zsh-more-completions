#compdef autodock4
# Documentation: https://manpages.debian.org/testing/autodock/autodock4.1.en.html
# autodock4 - automated docking of a ligand to a macromolecule.

local ret=1

_arguments -s -S \
  '-p+[grid/docking parameter file (.dpf)]:file:_files' \
  '-l+[log file (.dlg)]:file:_files' \
  '-o[use old PDBQ format, charge q in columns 55-61]' \
  '-k[keep original residue numbers]' \
  '-i[ignore header-checking]' \
  '-t[parse the PDBQ file to check torsions, then stop]' \
  '-c+[command mode: command file or control program]:file:_files' \
  '*:file:_files' && ret=0

return ret
