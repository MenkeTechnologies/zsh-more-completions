#compdef SurfDsetInfo
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/SurfDsetInfo.html
# Display information about a surface dataset (SUMA)

local ret=1

_arguments -s -S \
  '(-h -help -HELP)'{-h,-help,-HELP}'[show help]' \
  '*-input[read a dataset as input]:dataset:_files' \
  '-novolreg[disregard surface volume transformations]' \
  '-noxform[disregard surface volume transformations]' \
  '-setenv[set an environment variable]:env:' \
  '-debug[set debug level (2 = full NIML)]:dbg:' \
  '-trace[enable input/output and memory tracing]' \
  '-TRACE[activate extreme-level tracing]' \
  '-nomall[disable memory tracing]' \
  '-yesmall[enable memory tracing (default)]' \
  '-h_view[open help in a text editor]' \
  '-h_web[open help in a web browser]' \
  '-h_find[search help output for keyword]:word:' \
  '-h_raw[display unedited help string]' \
  '-h_spx[help in Sphinx format]' \
  '-h_aspx[help in Sphinx format with autoformatting]' \
  '-all_opts[identify all available program options]' \
  '*:dataset:_files' && ret=0

return ret
