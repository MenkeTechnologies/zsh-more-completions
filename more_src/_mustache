#compdef mustache
# Documentation: https://github.com/janl/mustache.js/blob/master/bin/mustache
# Reference accessed: 2026-05-19
# Verified: upstream bin/mustache script source at the URL above.

# mustache(1) from janl/mustache.js: render a template against a view.
# Usage: mustache [-p partial]... <view> <template> [output]

_arguments -s \
  '*-p+[partial template file (repeatable)]:partial file:_files -g "*.{mustache,html,hbs}"' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:file:_files'
