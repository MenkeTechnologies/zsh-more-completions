#compdef mustache
# Documentation: https://github.com/janl/mustache.js
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-c --compile)'{-c,--compile}'=[compile template]:file:_files' \
  '(-t --tokens)'{-t,--tokens}'=[tokenize template]:file:_files' \
  '(-e --error)'{-e,--error}'[error on context miss]' \
  '*'{-r,--require}'=[require library]:lib:' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:file:_files'
