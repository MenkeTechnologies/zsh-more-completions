#compdef xrepo

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install packages'
  'remove:remove packages'
  'info:show package information'
  'fetch:fetch package library files'
  'search:search packages'
  'env:show environment for packages'
  'scan:scan for installed packages'
  'export:export packages'
  'import:import packages'
  'clean:clean package caches'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose output]' \
  '-D[diagnostic output]' \
  '-y[answer yes to all prompts]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'xrepo command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (install)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-f[force reinstall]' \
          '--mode[build mode]:mode:(release debug)' \
          '--plat[platform]:platform:(linux macosx windows android iphoneos)' \
          '--arch[architecture]:arch:(x86_64 arm64 i386)' \
          '--toolchain[toolchain]:toolchain:' \
          '*:package:' && ret=0
        ;;
      (search)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:keyword:' && ret=0
        ;;
      (info)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:package:' && ret=0
        ;;
      (remove)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:package:' && ret=0
        ;;
      (fetch)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--linkdirs[output link directories]' \
          '--includedirs[output include directories]' \
          '--links[output link libraries]' \
          '--cflags[output C flags]' \
          '--ldflags[output linker flags]' \
          '*:package:' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
