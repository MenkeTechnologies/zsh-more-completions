#compdef casdoor
# _casdoor — Casbin Casdoor OIDC/OAuth2/SAML IDaaS CLI alias (casdoor team, Go); custom argparse over REST API
# upstream: https://github.com/casdoor/casdoor

_casdoor() {
    local -a sub=(
        'serve:run the server'
        'login:save credentials'
        'logout:clear credentials'
        'whoami:show current user'
        'application:list:list applications'
        'application:get:get app'
        'application:create:create app'
        'application:update:update app'
        'application:delete:delete app'
        'user:list:list users'
        'user:get:get user'
        'user:create:create user'
        'user:update:update user'
        'user:delete:delete user'
        'user:set-password:set user password'
        'user:add-role:add role'
        'user:remove-role:remove role'
        'organization:list:list organizations'
        'organization:create:create org'
        'organization:delete:delete org'
        'role:list:list roles'
        'role:create:create role'
        'role:delete:delete role'
        'permission:list:list permissions'
        'permission:create:create permission'
        'permission:delete:delete permission'
        'provider:list:list providers'
        'provider:create:create provider'
        'provider:delete:delete provider'
        'token:list:list tokens'
        'token:revoke:revoke token'
        'token:introspect:introspect token'
        'webhook:list:list webhooks'
        'webhook:create:create webhook'
        'webhook:delete:delete webhook'
        'cert:list:list certs'
        'cert:create:create cert'
        'cert:delete:delete cert'
        'group:list:list groups'
        'group:create:create group'
        'group:delete:delete group'
        'enforcer:list:list casbin enforcers'
        'enforcer:create:create enforcer'
        'enforcer:delete:delete enforcer'
        'model:list:list models'
        'model:create:create model'
        'model:delete:delete model'
        'adapter:list:list adapters'
        'adapter:create:create adapter'
        'adapter:delete:delete adapter'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--endpoint=+[server URL]:url:_urls' \
        '--client-id=+[client id]:str:' \
        '--client-secret=+[client secret]:str:' \
        '--certificate=+[cert file]:file:_files' \
        '--organization=+[organization]:str:' \
        '--application=+[application]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'casdoor subcommand' sub ;;
        args)
            case $words[1] in
                user:create) _arguments \
                    '--name=+[username]:user:_users' \
                    '--password=+[password]:str:' \
                    '--email=+[email]:str:' \
                    '--organization=+[organization]:str:' \
                    '--display-name=+[display name]:str:' \
                    '--phone=+[phone]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_casdoor "$@"
