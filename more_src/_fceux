#compdef fceux fceux-sdl

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--xres+[X resolution]:n:' \
  '--yres+[Y resolution]:n:' \
  '--fullscreen+[fullscreen]:b:(0 1)' \
  '--video-driver+[video driver]:d:(opengl sdl)' \
  '--sound+[sound]:b:(0 1)' \
  '--soundq+[sound quality]:n:(0 1 2)' \
  '--soundrate+[sound rate]:n:(11025 22050 44100 48000 96000)' \
  '--soundvol+[sound volume]:n:' \
  '--volume+[volume]:n:' \
  '--input1+[input port 1]:i:(none gamepad zapper powerpad.0 powerpad.1 arkanoid)' \
  '--input2+[input port 2]:i:(none gamepad zapper powerpad.0 powerpad.1 arkanoid)' \
  '--input3+[input port 3]:i:' \
  '--input4+[input port 4]:i:' \
  '--inputcfg+[input config]:i:' \
  '--playmov+[play movie]:file:_files -g "*.fm2"' \
  '--readonly+[movie readonly]:b:(0 1)' \
  '--recordmov+[record movie]:file:_files' \
  '--pal+[PAL mode]:b:(0 1)' \
  '--newppu+[new PPU]:b:(0 1)' \
  '--frameskip+[frameskip]:n:' \
  '--clipsides+[clip sides]:b:(0 1)' \
  '--rp2mic+[mic input]:i:' \
  '--turboa+[turbo A]:b:(0 1)' \
  '--turbob+[turbo B]:b:(0 1)' \
  '--ggrom+[Game Genie ROM]:file:_files -g "*.nes"' \
  '--gg+[Game Genie]:b:(0 1)' \
  '--lua+[lua script]:file:_files -g "*.lua"' \
  '--periodicsaves+[periodic saves]:b:(0 1)' \
  '--inputlog+[input log]:file:_files' \
  '*: :_files -g "*.nes *.fds *.unf *.zip *.gz"' && ret=0

return ret
