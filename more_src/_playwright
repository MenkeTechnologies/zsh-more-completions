#compdef playwright npx-playwright

# Zsh completion for Playwright

_playwright() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'open:open page in browser'
    'codegen:open page and generate code for user actions'
    'install:install browsers'
    'install-deps:install system dependencies for browsers'
    'cr:open page in Chromium'
    'ff:open page in Firefox'
    'wk:open page in WebKit'
    'screenshot:capture a page screenshot'
    'pdf:save page as PDF'
    'show-trace:show trace viewer'
    'test:run tests'
    'show-report:show HTML test report'
    'merge-reports:merge reports from multiple shards'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'playwright command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        test)
          _arguments -s -S \
            '--browser=[browser to use]:browser:(chromium firefox webkit all)' \
            '--headed[run tests in headed mode]' \
            '--debug[debug tests]' \
            '-c+[configuration file]:config:_files -g "*.{ts,js,mjs}"' \
            '--config=[configuration file]:config:_files -g "*.{ts,js,mjs}"' \
            '--forbid-only[fail if test.only is found]' \
            '--fully-parallel[run all tests in parallel]' \
            '-g+[only run tests matching regex]:pattern:' \
            '--grep=[only run tests matching regex]:pattern:' \
            '--grep-invert=[skip tests matching regex]:pattern:' \
            '--global-timeout=[max total time in ms]:ms:' \
            '--timeout=[test timeout in ms]:ms:' \
            '-j+[number of parallel workers]:workers:' \
            '--workers=[number of parallel workers]:workers:' \
            '--list[list tests without running]' \
            '--max-failures=[stop after N failures]:count:' \
            '-x[stop after first failure]' \
            '--output=[artifacts directory]:directory:_files -/' \
            '--pass-with-no-tests[pass when no tests found]' \
            '--project=[only run tests from these projects]:project:' \
            '--quiet[suppress output]' \
            '--repeat-each=[run each test N times]:count:' \
            '--reporter=[reporter to use]:reporter:(dot line list json junit html blob)' \
            '--retries=[number of retries]:count:' \
            '--shard=[shard tests]:shard:' \
            '--trace=[force tracing mode]:mode:(on off retain-on-failure on-first-retry on-all-retries)' \
            '--ignore-snapshots[ignore snapshot expectations]' \
            '--update-snapshots[update snapshots]' \
            '-u[update snapshots]' \
            '--ui[run in UI mode]' \
            '--ui-host=[host for UI mode]:host:_hosts' \
            '--ui-port=[port for UI mode]:port:' \
            '--last-failed[run only last failed tests]' \
            '*:test files:_files -g "*.{spec,test}.{ts,js,mjs}"' \
            && ret=0
          ;;
        codegen)
          _arguments -s -S \
            '-o+[save script to file]:file:_files' \
            '--output=[save script to file]:file:_files' \
            '--target=[language]:language:(javascript typescript python python-async java csharp csharp-mstest csharp-nunit)' \
            '-b+[browser to use]:browser:(chromium firefox webkit)' \
            '--browser=[browser to use]:browser:(chromium firefox webkit)' \
            '--channel=[Chromium channel]:channel:' \
            '--color-scheme=[color scheme]:scheme:(dark light no-preference)' \
            '--device=[emulate a device]:device:' \
            '--geolocation=[geolocation]:lat,long:' \
            '--ignore-https-errors[ignore https errors]' \
            '--load-storage=[load storage state]:file:_files -g "*.json"' \
            '--save-storage=[save storage state]:file:_files -g "*.json"' \
            '--save-har=[save HAR file]:file:_files -g "*.har"' \
            '--proxy-server=[proxy server]:proxy:' \
            '--timezone=[timezone]:timezone:' \
            '--user-agent=[user agent]:user agent:' \
            '--viewport-size=[viewport size]:WxH:' \
            '1:URL:' \
            && ret=0
          ;;
        install)
          _arguments -s -S \
            '--with-deps[install system dependencies]' \
            '--force[force reinstall]' \
            '--dry-run[do not install, only report]' \
            '*:browser:(chromium firefox webkit msedge msedge-beta msedge-dev chrome chrome-beta chrome-canary)' \
            && ret=0
          ;;
        show-trace)
          _arguments -s -S \
            '1:trace file:_files -g "*.zip"' \
            && ret=0
          ;;
        show-report)
          _arguments -s -S \
            '--host=[host]:host:_hosts' \
            '--port=[port]:port:' \
            '1:report directory:_files -/' \
            && ret=0
          ;;
        screenshot|pdf)
          _arguments -s -S \
            '--wait-for-selector=[wait for selector]:selector:' \
            '--wait-for-timeout=[wait for timeout]:ms:' \
            '--full-page[capture full page]' \
            '1:URL:' \
            '2:output file:_files' \
            && ret=0
          ;;
        open|cr|ff|wk)
          _arguments -s -S \
            '--device=[emulate a device]:device:' \
            '--color-scheme=[color scheme]:scheme:(dark light no-preference)' \
            '--geolocation=[geolocation]:lat,long:' \
            '--ignore-https-errors[ignore https errors]' \
            '--load-storage=[load storage state]:file:_files -g "*.json"' \
            '--save-storage=[save storage state]:file:_files -g "*.json"' \
            '--proxy-server=[proxy server]:proxy:' \
            '--timezone=[timezone]:timezone:' \
            '--user-agent=[user agent]:user agent:' \
            '--viewport-size=[viewport size]:WxH:' \
            '1:URL:' \
            && ret=0
          ;;
        *)
          _arguments -s -S '--help[display help]' && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_playwright "$@"
