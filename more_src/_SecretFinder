#compdef SecretFinder
# Documentation: https://github.com/m4ll0k/SecretFinder
# python script that discovers sensitive data (API keys, tokens) in JavaScript files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-e --extract)'{-e,--extract}'[extract all javascript links located in a page and process it]' \
  '(-i --input)'{-i,--input}'+[input a URL, file or folder]:input:_files' \
  '(-o --output)'{-o,--output}'+[where to save the file, including file name]:file:_files' \
  '(-r --regex)'{-r,--regex}'+[RegEx for filtering found endpoints]:regex' \
  '(-b --burp)'{-b,--burp}'[support burp exported file]' \
  '(-c --cookie)'{-c,--cookie}'+[add cookies for authenticated JS files]:cookie' \
  '(-g --ignore)'{-g,--ignore}'+[ignore js url if it contains the provided string]:string' \
  '(-n --only)'{-n,--only}'+[process js url if it contains the provided string]:string' \
  '(-H --headers)'{-H,--headers}'+[set headers]:headers' \
  '(-p --proxy)'{-p,--proxy}'+[set proxy (host:port)]:proxy' && ret=0

return ret
