#compdef trnascan-se tRNAscan-SE
# tRNAscan-SE — tRNA detection in genomic sequences

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-E[use eukaryotic tRNA model (default)]' \
  '-B[search for bacterial tRNAs]' \
  '-A[search for archaeal tRNAs]' \
  '-G[use general tRNA model]' \
  '-I[search using Infernal]' \
  '-L[use legacy mode]' \
  '-O[use organellar tRNA model]' \
  '-M[use mitochondrial tRNA model]:source:(mammal vert)' \
  '(-o --output)'{-o,--output}'[output file]:output file:_files' \
  '(-f --struct)'{-f,--struct}'[secondary structure output file]:struct file:_files' \
  '(-m --stats)'{-m,--stats}'[summary statistics file]:stats file:_files' \
  '(-b --bed)'{-b,--bed}'[BED format output file]:bed file:_files' \
  '-j[GFF3 format output file]:gff file:_files' \
  '(-a --fasta)'{-a,--fasta}'[FASTA output of predicted tRNAs]:fasta file:_files' \
  '(-p --prefix)'{-p,--prefix}'[prefix for output file names]:prefix' \
  '(-H --breakdown)'{-H,--breakdown}'[show breakdown of structure component scores]' \
  '(-y --hitsrc)'{-y,--hitsrc}'[show origin of hits]' \
  '--detail[show detailed output]' \
  '--iscore[isotype-specific score threshold]:score' \
  '--brief[brief output format]' \
  '--thread[number of threads]:threads' \
  '(-d --progress)'{-d,--progress}'[display progress messages]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-Q --forceow)'{-Q,--forceow}'[force overwrite of output files]' \
  '--match[match score]:score' \
  '--pad[padding length]:length' \
  '*:input sequence file:_files' \
  && return 0
