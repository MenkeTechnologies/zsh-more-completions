#compdef aws-cdk
# _aws-cdk-cli — AWS Cloud Development Kit (Amazon Web Services, TypeScript); define cloud infra in code, synthesize to CloudFormation
# upstream: https://github.com/aws/aws-cdk

_aws-cdk-cli() {
    local -a sub=(
        'acknowledge:acknowledge a notice'
        'ack:acknowledge alias'
        'bootstrap:bootstrap account/region'
        'context:manage context'
        'deploy:deploy a stack'
        'destroy:destroy a stack'
        'diff:diff a stack'
        'docs:open docs'
        'doctor:run env doctor'
        'gc:garbage collect bootstrap'
        'help:show help'
        'import:import existing resource'
        'init:initialize new CDK project'
        'list:list stacks'
        'ls:list stacks (alias)'
        'metadata:print stack metadata'
        'migrate:migrate from cfn'
        'notices:show notices'
        'rollback:rollback failed deploy'
        'synth:synthesize CloudFormation'
        'synthesize:alias for synth'
        'version:show version'
        'watch:watch + redeploy'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '-a+[app command]:cmd:_command_names -e' \
        '--app+[app command]:cmd:_command_names -e' \
        '-c+[context key=value]:str:' \
        '--context+[context key=value]:str:' \
        '--profile+[AWS profile]:profile:' \
        '--proxy+[proxy URL]:url:_urls' \
        '--ca-bundle-path+[ca bundle]:file:_files' \
        '-i+[plugin]:plugin:' \
        '--plugin+[plugin]:plugin:' \
        '--ec2creds[force EC2 creds]' \
        '--version-reporting[version reporting]' \
        '--path-metadata[path metadata]' \
        '--asset-metadata[asset metadata]' \
        '-r+[role ARN]:arn:' \
        '--role-arn+[role ARN]:arn:' \
        '--toolkit-stack-name+[toolkit stack name]:str:' \
        '--staging[stage assets]' \
        '-o+[output dir]:dir:_files -/' \
        '--output+[output dir]:dir:_files -/' \
        '--notices+[notices]:bool:(true false)' \
        '--no-color[no color]' \
        '--json[json output]' \
        '--ignore-errors[ignore errors]' \
        '--debug[debug]' \
        '--trace[trace]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cdk subcommand' sub ;;
        args)
            case $words[1] in
                deploy|destroy|diff|synth|synthesize|watch) _arguments \
                    '*:stack:' \
                    '--require-approval+[require approval]:level:(any-change broadening never)' \
                    '--method+[deploy method]:method:(direct change-set prepare-change-set)' \
                    '--all[all stacks]' \
                    '-f[force]' \
                    '--force[force]' \
                    '--hotswap[hotswap]' \
                    '--watch[watch]' \
                    '--exclusively[only specified]' \
                    '-e[exclusively]' ;;
                init) _arguments '1:template:(app lib sample-app)' '*:language:(typescript javascript python java csharp fsharp go)' ;;
                bootstrap) _arguments '*:environments:' \
                    '--bootstrap-bucket-name+[bucket name]:str:' \
                    '--qualifier+[qualifier]:str:' \
                    '--bootstrap-customer-key+[KMS customer key]:str:' \
                    '--cloudformation-execution-policies+[execution policies]:str:' \
                    '--trust+[trust account]:str:' ;;
            esac
            ;;
    esac
}

_aws-cdk-cli "$@"
