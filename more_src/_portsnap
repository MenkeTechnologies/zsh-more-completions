#compdef portsnap
# _portsnap — FreeBSD Project portsnap CLI safe lightweight cross-checked-distributing-via-snapshot-server-FreeBSD-Ports-tree-update utility securely downloading current snapshot of the FreeBSD Ports tree extracting the difference verifying RSA-signed SHA256 metadata for the Ports-Collection-tree-update workflow on FreeBSD systems (FreeBSD team, C); getopt
# upstream: https://www.freebsd.org/

_portsnap() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d+[work dir]:dir:_files -/' \
        '-f+[config file]:file:_files' \
        '-I+[interface]:_net_interfaces' \
        '-k+[KEY]:str:' \
        '-l+[file]:file:_files' \
        '-p+[ports dir]:dir:_files -/' \
        '-s+[server]:_hosts' \
        '*:command:(fetch cron extract update alfred auto)'
}

_portsnap "$@"
