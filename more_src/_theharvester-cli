#compdef theharvester-cli theharvester theHarvester
# _theharvester-cli — Christian Martorella theharvester-cli CLI command-line frontend wrapping the theHarvester open-source OSINT email subdomain enumeration social-media-Open-Source-INTelligence reconnaissance tool gathering emails subdomains IPs URLs employee-names virtual-hosts open-ports banners ASN-information from search engines PGP key servers Shodan Censys Hunter.io DuckDuckGo Google Bing Baidu Brave OTX-AlienVault Anubis BeVigil BinaryEdge BraveSearch BufferOver C99 CRT-Sh DNSDumpster GitHub-Code RapidDNS Rocketreach (Christian Martorella ETH Zurich Edge Security team, Python); argparse
# upstream: https://github.com/laramies/theHarvester

_theharvester-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d+[domain]:str:' \
        '--domain=+[name]:str:' \
        '-l+[limit]:n:' \
        '--limit=+[N]:n:' \
        '-S+[start results]:n:' \
        '--start=+[N]:n:' \
        '-p[use proxies.yaml]' \
        '--proxies[use proxies]' \
        '-s[shodan API]' \
        '--shodan[shodan]' \
        '--screenshot=+[dir]:dir:_files -/' \
        '-v[verify hostname]' \
        '--virtual-host[virtual host]' \
        '-e+[DNS server]:_hosts' \
        '--dns-server=+[host]:_hosts' \
        '-t[do DNS TLD expansion]' \
        '--dns-tld[DNS TLD]' \
        '-r+[DNS resolve]:str:' \
        '--dns-resolve=+[ip]:str:' \
        '-n[do DNS brute force]' \
        '--dns-brute[DNS brute]' \
        '-c[do DNS lookup of all]' \
        '--dns-lookup[DNS lookup]' \
        '-f+[save HTML/XML output]:file:_files -g "*.html *.xml"' \
        '--filename=+[file]:file:_files -g "*.html *.xml"' \
        '-b+[source]:s:(anubis baidu bevigil binaryedge bing bingapi bravesearch bufferoverun brave c99 censys crtsh dnsdumpster duckduckgo fullhunt github-code hackertarget hunter hunterhow intelx myrumblesh netlas otx pentesttools projectdiscovery rapiddns rocketreach securityTrails shodan sitedossier subdomaincenter subdomainfinderc99 threatminer tomba urlscan virustotal yahoo zoomeye baidu all)' \
        '--source=+[s]:str:' \
        '-x[take screenshots]' \
        '*:args:'
}

_theharvester-cli "$@"
