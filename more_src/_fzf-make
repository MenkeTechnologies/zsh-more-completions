#compdef fzf-make

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-f+[specify Makefile path]:makefile:_files' \
  '--file=[specify Makefile path]:makefile:_files' \
  '-d+[specify working directory]:directory:_directories' \
  '--dir=[specify working directory]:directory:_directories' \
  '--history-limit=[maximum number of history entries]:number' \
  '--repeat[repeat mode after execution]' && return 0
