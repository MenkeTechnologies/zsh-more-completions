#compdef lindna
# Documentation: https://man.archlinux.org/search?q=lindna
# Reference accessed: 2026-05-16

# EMBOSS lindna: draw schematic restriction-enzyme map of linear DNA
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-inputfile=[lindna input definition file]:file:_files' \
  '-maxgroups=[maximum number of groups]:n:' \
  '-maxlabels=[maximum number of labels]:n:' \
  '-graphout=[graph output format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-ruler[draw a ruler]' \
  '-blocktype=[block fill style]:style:(Open Filled Outline)' \
  '-intersymbol=[symbol between adjacent blocks]:symbol:(Straight Up Down)' \
  '-intercolour=[colour for inter-block lines]:colour:' \
  '-interticks[draw ticks at block boundaries]' \
  '-gapsize=[gap between groups in pixels]:n:' \
  '-ticklines[draw tick lines]' \
  '-textheight=[label text height]:n:' \
  '-textlength=[label text length]:n:' \
  '-margin=[margin around plot]:n:' \
  '-tickheight=[tick height]:n:' \
  '-blockheight=[block height]:n:' \
  '-rangeheight=[range height]:n:' \
  '-gapgroup=[gap between groups]:n:' \
  '-postext=[position label text]:pos:(In Out Above Below)' \
  '*:lindna definition file:_files' && ret=0
return ret
