#compdef input-remapper input-remapper-control input-remapper-reader-service input-remapper-service

# Zsh completion for input-remapper - input device remapping

local curcontext="$curcontext" state line ret=1

if [[ $service == input-remapper-control ]]; then
  local -a commands=(
    'autoload:load the configured preset for all devices'
    'start:start injecting for a device'
    'stop:stop injecting for a device'
    'stop-all:stop all injections'
    'hello:check if the daemon is running'
    'is-active:check if a device is being injected'
  )

  _arguments -s -S \
    '1:command:->command' \
    '--device=[device name]:device' \
    '--preset=[preset name]:preset' \
    '--config-dir=[custom config directory]:directory:_files -/' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '*:: :->args' && ret=0

  case $state in
    (command)
      _describe -t commands 'input-remapper-control command' commands && ret=0
      ;;
  esac
elif [[ $service == input-remapper ]]; then
  _arguments -s -S \
    '(-d --debug)'{-d,--debug}'[enable debug mode]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' && ret=0
else
  _arguments -s -S \
    '(-d --debug)'{-d,--debug}'[enable debug mode]' \
    '(-h --help)'{-h,--help}'[show help]' && ret=0
fi

return ret
