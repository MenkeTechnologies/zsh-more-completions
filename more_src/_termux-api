#compdef termux-api
# Documentation: https://github.com/termux/termux-api-package
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for termux-api - Termux Android terminal API
# Note: Termux API is a collection of separate commands (termux-battery-status, etc.)
# This provides completion for the main termux-* API commands

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:command:_command_names -e' && ret=0

return ret
