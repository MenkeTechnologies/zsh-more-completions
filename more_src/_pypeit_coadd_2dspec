#compdef pypeit_coadd_2dspec
# Documentation: https://pypeit.readthedocs.io/en/release/scripts.html
# Coadd 2D spectra produced by PypeIt

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '--show[show the reduction steps]' \
  '--debug_offsets[show QA plots for debugging offset determination]' \
  '--peaks[show the peaks found by the object finding algorithm]' \
  '--basename=[basename of files to save parameters, spec1d, spec2d]:basename' \
  '--debug[show debug plots]' \
  '*:coadd2d file:_files' && ret=0

return ret
