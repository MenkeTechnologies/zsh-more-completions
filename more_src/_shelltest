#compdef shelltest
# Documentation: https://man.archlinux.org/search?q=shelltest
# Reference accessed: 2026-05-16

# Zsh completion for shelltest (shelltestrunner)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-j --threads)'{-j,--threads}'[parallel jobs]:n' \
  '--debug[debug]' \
  '*:shelltest file:_files' && ret=0

return ret
