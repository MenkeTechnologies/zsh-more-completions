#compdef release-it

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '--dry-run[do not touch or write anything]' \
  '--changelog[print changelog]' \
  '--release-version[print release version]' \
  '-i[increment]:level:(patch minor major prepatch preminor premajor prerelease)' \
  '--increment=[increment]:level:(patch minor major prepatch preminor premajor prerelease)' \
  '--ci[run in CI mode]' \
  '--only-version[print version without releasing]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '--no-npm[skip npm publish]' \
  '--no-git[skip git operations]' \
  '--no-github[skip GitHub release]' \
  '--no-gitlab[skip GitLab release]' \
  '--npm.tag=[npm dist-tag]:tag' \
  '--github.release[create GitHub release]' \
  '--github.autoGenerate[auto-generate release notes]' \
  '--preRelease=[pre-release tag]:tag:(alpha beta rc)' \
  '--git.requireCleanWorkingDir[require clean working directory]' \
  '--git.commitMessage=[commit message template]:message' \
  '--git.tagName=[tag name template]:name' \
  '*:version:(patch minor major)'
