#compdef shub
# Documentation: https://man.archlinux.org/search?q=shub
# Reference accessed: 2026-05-16

# Zsh completion for shub — Scrapinghub client

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-p --project)'{-p,--project}'[project ID]:id' \
  '(-k --apikey)'{-k,--apikey}'[API key]:key' && ret=0

return ret
