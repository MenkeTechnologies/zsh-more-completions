#compdef cacaplay
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/cacaplay.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cacaplay's upstream manpage documents no command-line options; the only
# argument is an optional FILE (use "-" for stdin). Driver selection is via
# the CACA_DRIVER environment variable.

_arguments -s -S \
  '*:caca animation file:_files'
