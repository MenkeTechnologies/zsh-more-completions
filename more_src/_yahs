#compdef yahs
# Documentation: https://github.com/c-zhou/yahs
# YaHS: yet another Hi-C scaffolding tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o+[prefix of the output files]:prefix' \
  '-r+[range of resolutions in ascending order]:resolutions' \
  '-R+[number of rounds to run for each resolution level]:rounds' \
  '-e+[restriction enzyme(s) used by the Hi-C experiment]:enzymes' \
  '-l+[minimum contig length included for scaffolding]:length' \
  '-q+[minimum read mapping quality]:mapq' \
  '-a+[AGP format file to do scaffolding]:file:_files' \
  '--file-type=[input file format]:type:(BAM BED PA5 BIN)' \
  '--no-contig-ec[skip initial assembly error correction]' \
  '--no-scaffold-ec[skip scaffolding error check in each round]' \
  '--no-mem-check[disable runtime memory checking]' \
  '--telo-motif=[telomeric motif]:motif' \
  '--read-length=[read length of the Hi-C data]:length' \
  '*:input:_files' && ret=0

return ret
