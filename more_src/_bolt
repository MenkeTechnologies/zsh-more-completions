#compdef bolt

# Zsh completion for bolt - Puppet Bolt task runner

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'apply:apply a Puppet manifest'
  'command:run a command remotely'
  'file:upload or download files'
  'group:show inventory group information'
  'guide:view guides for Bolt concepts'
  'inventory:show inventory information'
  'lookup:look up a value with Hiera'
  'module:manage Bolt modules'
  'plan:run and manage plans'
  'project:create and manage Bolt projects'
  'script:upload and run a script'
  'secret:create and manage secrets'
  'task:run and manage tasks'
)

local -a common_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)--version[show version]'
  '(-t --targets)'{-t,--targets}'[target nodes to run on]:targets:'
  '(-n --nodes)'{-n,--nodes}'[alias for targets]:nodes:'
  '(-q --query)'{-q,--query}'[PuppetDB query for targets]:query:'
  '--rerun[retry on nodes from last run]:filter:(success failure all)'
  '(-u --user)'{-u,--user}'[user to authenticate as]:user:'
  '(-p --password)'{-p,--password}'[password to authenticate with]:password:'
  '--private-key[path to private key for SSH]:key file:_files'
  '--host-key-check[check host keys with SSH]'
  '--no-host-key-check[do not check host keys with SSH]'
  '--ssl[use SSL with WinRM]'
  '--no-ssl[do not use SSL with WinRM]'
  '--ssl-verify[verify remote host SSL certificate with WinRM]'
  '--no-ssl-verify[do not verify remote host SSL certificate]'
  '--run-as[user to run as using privilege escalation]:user:'
  '--sudo-password[password for privilege escalation]:password:'
  '--sudo-executable[specify a sudo executable]:executable:_command_names'
  '(-c --concurrency)'{-c,--concurrency}'[maximum number of simultaneous connections]:number:'
  '(-i --inventoryfile)'{-i,--inventoryfile}'[path to inventory file]:file:_files'
  '(-m --modulepath)'{-m,--modulepath}'[list of directories containing modules]:path:_dir_list'
  '--project[path to Bolt project directory]:directory:_directories'
  '--configfile[path to Bolt config file]:file:_files'
  '--log-level[log level for console messages]:level:(trace debug info notice warn error fatal)'
  '--format[output format]:format:(human json rainbow)'
  '--color[use colored output]'
  '--no-color[do not use colored output]'
  '(-v --verbose)'{-v,--verbose}'[display verbose logging]'
  '--debug[display debug logging]'
  '--trace[display error stack traces]'
  '--noop[run in no-operation mode]'
)

_arguments -s -S \
  $common_flags \
  '1:subcommand:->subcommand' \
  '*:argument:->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'bolt subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      command)
        _arguments $common_flags \
          '1:action:(run)' \
          '2:command string:'
        ;;
      task)
        _arguments $common_flags \
          '1:action:(run show)' \
          '2:task name:'
        ;;
      plan)
        _arguments $common_flags \
          '1:action:(run show convert new)' \
          '2:plan name:'
        ;;
      script)
        _arguments $common_flags \
          '1:action:(run)' \
          '2:script file:_files'
        ;;
      file)
        _arguments $common_flags \
          '1:action:(upload download)' \
          '2:source:_files' \
          '3:destination:'
        ;;
      apply)
        _arguments $common_flags \
          '1:manifest:_files -g "*.pp"'
        ;;
      *)
        _arguments $common_flags
        ;;
    esac
    ;;
esac

return ret
