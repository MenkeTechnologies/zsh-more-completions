#compdef sigcleave
# Documentation: https://man.archlinux.org/search?q=sigcleave
# Reference accessed: 2026-05-16

# EMBOSS sigcleave: predict signal peptide cleavage sites in proteins
# using the von Heijne weight matrix method (eukaryote/prokaryote
# variants).
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-minweight=[minimum weight to report]:weight:' \
  '-prokaryote[use prokaryote signal-peptide matrix]' \
  '-outfile=[report output file]:file:_files' \
  '-rformat=[report output format]:format:(motif table excel feattable gff3 listfile pir simple swiss tagseq)' \
  '*:protein USA:_files' && ret=0

return ret
