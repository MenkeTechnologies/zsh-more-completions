#compdef cntb
# Documentation: https://man.archlinux.org/search?q=cntb
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'config:credential and config helpers'
      'completion:print shell completion script'
      'get:list or fetch resources'
      'create:create resources'
      'start:start instances'
      'stop:stop instances'
      'help:help'
    )
    _describe -t commands 'cntb command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      config)
        _arguments -s -S \
          '2:subcommand:(set-credentials)' \
          '*: : _default' \
          && ret=0
        ;;
      completion)
        _arguments -s -S '2:shell:(bash zsh fish powershell)' && ret=0
        ;;
      get|create|start|stop)
        _arguments -s -S '*: : _default' && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
