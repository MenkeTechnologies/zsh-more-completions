#compdef cntb
# Documentation: https://github.com/contabo/cntb
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cntb is the official Contabo cloud CLI.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--oauth2-clientid=[OAuth2 client id]:id:' \
  '--oauth2-client-secret=[OAuth2 client secret]:secret:' \
  '--oauth2-user=[Contabo user (email)]:user:' \
  '--oauth2-password=[Contabo user password]:password:' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'config:credential and config helpers'
      'completion:print shell completion script'
      'get:list or fetch resources'
      'create:create resources'
      'update:update resources'
      'delete:delete resources'
      'start:start instances'
      'stop:stop instances'
      'restart:restart instances'
      'reinstall:reinstall instances'
      'upgrade:upgrade instances'
      'cancel:cancel instances'
      'assign:assign resources'
      'unassign:unassign resources'
      'help:help'
    )
    _describe -t commands 'cntb command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      config)
        _arguments -s -S \
          '2:subcommand:(set-credentials)' \
          '*: : _default' \
          && ret=0
        ;;
      completion)
        _arguments -s -S '2:shell:(bash zsh fish powershell)' && ret=0
        ;;
      get|create|update|delete|start|stop|restart|reinstall|upgrade|cancel|assign|unassign)
        _arguments -s -S '*: : _default' && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
