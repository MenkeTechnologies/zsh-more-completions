#compdef preview_namelists
# Documentation: https://esmci.github.io/cime/versions/cesm2.2/html/Tools_user/preview_namelists.html
# CIME: generate component namelists for a case

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-d --debug)'{-d,--debug}'[print debug information to file]' \
  '(-v --verbose)'{-v,--verbose}'[add additional context to log messages]' \
  '(-s --silent)'{-s,--silent}'[print only warnings and error messages]' \
  '--component[build the namelist for this component only]:component' \
  '1:case directory:_files -/' && ret=0

return ret
