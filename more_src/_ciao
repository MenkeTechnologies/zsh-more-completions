#compdef ciao ciaoc ciao-shell ciao-prolog ciaopp lpdoc
# Documentation: https://ciao-lang.org/documentation.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ciao: Ciao Prolog top-level and bundle manager
local curcontext="$curcontext" state line ret=1
local -a commands

case $service in
  (ciao)
    commands=(
      'help:show help'
      'install:install bundle'
      'uninstall:uninstall bundle'
      'rescan-bundles:rescan bundles'
      'fetch:fetch a bundle'
      'rm:remove a bundle'
      'get:fetch and install bundle'
      'list:list bundles'
      'configure:configure bundle'
      'build:build bundle'
      'clean:clean bundle'
      'distclean:dist clean'
      'test:run tests'
      'doc:build documentation'
      'oc-cmd:run a command'
      'env:print environment'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '-v[verbose]' \
      '-q[quiet]' \
      '--version[show version]' \
      '1: :->cmd' \
      '*::arg:->args' && ret=0
    case $state in
      (cmd) _describe -t cmds 'ciao command' commands && ret=0 ;;
      (args) _files ;;
    esac ;;
  (ciaoc)
    _arguments -C \
      '-h[help]' \
      '-v[verbose]' \
      '-V[version]' \
      '-c[compile only]' \
      '-x[executable]' \
      '-e[executable]' \
      '-w[warnings as errors]' \
      '-s[static]' \
      '-d[dynamic]' \
      '-z[no main]' \
      '-l+[link with]:file:_files' \
      '-S+[stop after]:phase:' \
      '-o+[output]:file:_files' \
      '-op+[output prefix]:p:' \
      '-co+[compile output]:dir:_files -/' \
      '*: :_files -g "*.pl *.cpx"' && ret=0 ;;
  (ciao-shell|ciao-prolog)
    _arguments -C \
      '-h[help]' \
      '-l+[load file]:file:_files -g "*.pl"' \
      '-q[quiet]' \
      '-f[fast load]' \
      '*: :_files -g "*.pl"' && ret=0 ;;
  (ciaopp)
    _arguments -C \
      '-h[help]' \
      '-A[run analysis]' \
      '-O[run optimization]' \
      '-V[verify]' \
      '-T[test]' \
      '*: :_files -g "*.pl"' && ret=0 ;;
  (lpdoc)
    _arguments -C \
      '-h[help]' \
      '-c+[doc target format]:fmt:(html pdf info man texinfo manl ascii)' \
      '-t+[output type]:t:' \
      '-d+[output dir]:dir:_files -/' \
      '*: :_files -g "*.pl *.lpdoc *.cfg"' && ret=0 ;;
esac

return ret
