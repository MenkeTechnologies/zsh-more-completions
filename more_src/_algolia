#compdef algolia
# Documentation: https://man.archlinux.org/search?q=algolia
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'auth:authenticate'
  'profile:manage profiles'
  'describe:describe a resource'
  'open:open in browser'
  'application:application commands'
  'search:run a search'
  'indices:manage indices'
  'objects:manage objects'
  'apikeys:manage API keys'
  'settings:manage index settings'
  'rules:manage query rules'
  'synonyms:manage synonyms'
  'dictionary:manage dictionaries'
  'events:events analytics'
  'crawler:manage Crawler'
)

_arguments -C \
  '(-p --profile)'{-p,--profile}'=[profile name]:profile:' \
  '--application-id=[Algolia app id]:id:' \
  '--api-key=[API key]:key:' \
  '--admin-api-key=[admin API key (deprecated)]:key:' \
  '--search-hosts=[search hosts]:hosts:' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'algolia subcommand' subcommands && ret=0
    ;;
esac

return ret
