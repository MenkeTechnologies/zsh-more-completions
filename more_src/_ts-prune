#compdef ts-prune
# Documentation: https://man.archlinux.org/search?q=ts-prune
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-p --project)'{-p+,--project=}'[path to tsconfig.json]:file:_files -g "tsconfig*.json"' \
  '(-i --ignore)'{-i+,--ignore=}'[ignore pattern (regex)]:regex:' \
  '(-s --skip)'{-s+,--skip=}'[skip files pattern]:pattern:' \
  '(-e --error)'{-e,--error}'[exit with error code if unused exports found]' \
  '(-u --unusedInModule)'{-u,--unusedInModule}'[skip exports marked as used in module]' && ret=0

return ret
