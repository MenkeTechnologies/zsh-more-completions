#compdef sudivcor
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/amplitudes/sudivcor.c
# divergence (spreading) correction

local ret=1

_arguments -s -S \
  'trms=[times corresponding to rms velocities in vrms]:trms' \
  'vrms=[rms velocities corresponding to times in trms]:vrms' \
  'vfile=[binary file containing velocities vrms(t)]:file:_files' \
  '*:file:_files' && ret=0


return ret
