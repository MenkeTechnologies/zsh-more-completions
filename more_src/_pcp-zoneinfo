#compdef pcp-zoneinfo
# Documentation: https://man.archlinux.org/man/pcp-zoneinfo.1.en
# Report Performance Co-Pilot per-zone memory statistics

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[display version and exit]' \
  '(-a --archive)'{-a+,--archive=}'[fetch zoneinfo for a specified archive]:file:_files' \
  '(-s --samples)'{-s+,--samples=}'[number of samples to collect]:count' \
  '(-S --start)'{-S+,--start=}'[filter samples from the given time]:time' \
  '(-T --finish)'{-T+,--finish=}'[filter samples until the given time]:time' \
  '(-z --hostzone)'{-z,--hostzone}'[use timezone of metrics source host]' \
  '(-Z --timezone)'{-Z+,--timezone=}'[use specified timezone]:timezone' && ret=0

return ret
