#compdef gdal_create

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-of+[output format]:format:' \
  '-outsize+[output size]:width height:' \
  '-bands+[number of bands]:n:' \
  '-burn+[burn value]:value:' \
  '-ot+[data type]:type:(Byte Int8 UInt16 Int16 UInt32 Int32 UInt64 Int64 Float32 Float64 CInt16 CInt32 CFloat32 CFloat64)' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-a_srs+[assign SRS]:srs:' \
  '-a_ullr+[upper-left lower-right corners]:ulx uly lrx lry:' \
  '-a_nodata+[nodata value]:value:' \
  '-mo+[metadata option]:NAME=VALUE:' \
  '-q[quiet]' \
  '-if+[input format]:format:' \
  '1:filename:_files' && ret=0

return ret
