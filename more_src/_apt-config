#compdef apt-config
# Documentation: https://manpages.debian.org/unstable/apt/apt-config.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'shell:return values from configuration'
  'dump:dump configuration'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config-file)'{-c,--config-file=}'[config file]:file:_files' \
  '*-o+[set option name=value]:option:' \
  '--empty[only output empty]' \
  '--format=[output format]:format:' \
  '--include-file=[include file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'apt-config subcommand' subcommands && ret=0
    ;;
esac

return ret
