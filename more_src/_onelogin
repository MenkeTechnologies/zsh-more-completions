#compdef onelogin onelogin-cli
# _onelogin — OneLogin onelogin CLI command-line frontend to the OneLogin Workforce Identity Identity Access Management IAM REST API supporting user app role group privilege MFA event session-token SAML-OIDC-Single-Sign-On SSO directory sync SCIM provisioning trust-token-mapper smart-mfa (OneLogin team, Python); click
# upstream: https://developers.onelogin.com/

_onelogin() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'user:user operations'
        'app:app operations'
        'role:role operations'
        'group:group operations'
        'privilege:privilege operations'
        'mfa:multi-factor authentication'
        'event:event operations'
        'session:session token operations'
        'directory:directory operations'
        'mapper:mapper management'
        'risk:risk score'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--region=+[r]:r:(us eu)' \
        '--client-id=+[id]:str:' \
        '--client-secret=+[secret]:str:' \
        '--api-token=+[token]:str:' \
        '--subdomain=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'onelogin subcommand' sub ;;
        args)
            case $words[1] in
                user|app|role|group|privilege|mfa|directory|mapper) _arguments '1:op:(list get create update delete enable disable assign unassign)' '*:id:' ;;
            esac
            ;;
    esac
}

_onelogin "$@"
