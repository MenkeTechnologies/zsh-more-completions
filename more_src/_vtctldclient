#compdef vtctldclient

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'AddCellInfo:add a cell to topology'
  'AddCellsAlias:create a cells alias'
  'ApplyKeyspaceRoutingRules:apply keyspace routing rules'
  'ApplyRoutingRules:apply routing rules'
  'ApplyShardRoutingRules:apply shard routing rules'
  'ApplySchema:apply schema changes'
  'ApplyVSchema:apply VSchema'
  'Backup:backup a tablet'
  'BackupShard:backup a shard'
  'ChangeTabletTags:change tablet tags'
  'ChangeTabletType:change tablet type'
  'CheckThrottler:check throttler status'
  'CopySchemaShard:copy schema to a shard'
  'CreateKeyspace:create a keyspace'
  'CreateShard:create a shard'
  'DeleteCellInfo:delete a cell'
  'DeleteCellsAlias:delete a cells alias'
  'DeleteKeyspace:delete a keyspace'
  'DeleteShards:delete shards'
  'DeleteSrvVSchema:delete serving VSchema'
  'DeleteTablets:delete tablets'
  'DistributedTransaction:manage distributed transactions'
  'EmergencyReparentShard:emergency reparent shard'
  'ExecuteFetchAsApp:execute query as app user'
  'ExecuteFetchAsDBA:execute query as DBA user'
  'ExecuteHook:execute a hook on tablet'
  'ExecuteMultiFetchAsDBA:execute multiple queries as DBA'
  'FindAllShardsInKeyspace:find all shards in keyspace'
  'GenerateShardRanges:generate shard ranges'
  'GetBackups:list backups'
  'GetCellInfo:get cell info'
  'GetCellInfoNames:list cell names'
  'GetCellsAliases:list cells aliases'
  'GetFullStatus:get full tablet status'
  'GetKeyspace:get keyspace info'
  'GetKeyspaces:list keyspaces'
  'GetKeyspaceRoutingRules:get keyspace routing rules'
  'GetMirrorRules:get mirror rules'
  'GetPermissions:get tablet permissions'
  'GetRoutingRules:get routing rules'
  'GetSchema:get schema'
  'GetShard:get shard info'
  'GetShardReplication:get shard replication'
  'GetShardRoutingRules:get shard routing rules'
  'GetSrvKeyspaceNames:list serving keyspace names'
  'GetSrvKeyspaces:list serving keyspaces'
  'GetSrvVSchema:get serving VSchema'
  'GetSrvVSchemas:list serving VSchemas'
  'GetTablet:get tablet info'
  'GetTablets:list tablets'
  'GetTabletVersion:get tablet version'
  'GetThrottlerStatus:get throttler status'
  'GetTopologyPath:get topology path'
  'GetVSchema:get VSchema'
  'GetWorkflows:list workflows'
  'InitShardPrimary:initialize shard primary'
  'LegacyVtctlCommand:invoke legacy vtctl command'
  'LookupVindex:manage lookup vindexes'
  'Materialize:materialize tables'
  'Migrate:migrate workflow'
  'MoveTables:move tables between keyspaces'
  'Mount:manage mounts'
  'OnlineDDL:manage online DDL'
  'PingTablet:ping a tablet'
  'PlannedReparentShard:planned reparent shard'
  'RebuildKeyspaceGraph:rebuild keyspace graph'
  'RebuildVSchemaGraph:rebuild VSchema graph'
  'RefreshState:refresh tablet state'
  'RefreshStateByShard:refresh state by shard'
  'ReloadSchema:reload tablet schema'
  'ReloadSchemaKeyspace:reload schema for keyspace'
  'ReloadSchemaShard:reload schema for shard'
  'RemoveBackup:remove a backup'
  'RemoveKeyspaceCell:remove cell from keyspace'
  'RemoveShardCell:remove cell from shard'
  'ReparentTablet:reparent a tablet'
  'Reshard:reshard a workflow'
  'RestoreFromBackup:restore from backup'
  'RunHealthCheck:run health check'
  'SetKeyspaceDurabilityPolicy:set keyspace durability'
  'SetShardIsPrimaryServing:set shard primary serving'
  'SetShardTabletControl:set shard tablet control'
  'SetVtorcEmergencyReparent:set vtorc emergency reparent'
  'SetWritable:set tablet writable'
  'ShardReplicationFix:fix shard replication'
  'ShardReplicationPositions:show replication positions'
  'SleepTablet:sleep a tablet'
  'SourceShardAdd:add source shard'
  'SourceShardDelete:delete source shard'
  'StartReplication:start replication'
  'StopReplication:stop replication'
  'TabletExternallyReparented:report external reparent'
  'UpdateCellInfo:update cell info'
  'UpdateCellsAlias:update cells alias'
  'UpdateThrottlerConfig:update throttler config'
  'VDiff:diff workflow data'
  'Validate:validate topology'
  'ValidateKeyspace:validate keyspace'
  'ValidatePermissionsKeyspace:validate keyspace permissions'
  'ValidatePermissionsShard:validate shard permissions'
  'ValidateSchemaKeyspace:validate keyspace schema'
  'ValidateSchemaShard:validate shard schema'
  'ValidateShard:validate shard'
  'ValidateVersionKeyspace:validate keyspace version'
  'ValidateVersionShard:validate shard version'
  'Workflow:manage workflows'
  'WriteTopologyPath:write to topology path'
)

_arguments -C \
  '--action-timeout=[action timeout]:duration:' \
  '--compact[compact format for verbose output]' \
  '(- *)'{-h,--help}'[show help]' \
  '--server=[vtctld server]:server:' \
  '--topo-global-root=[topology root]:path:' \
  '--topo-global-server-address=[topology server addresses]:addrs:' \
  '--topo-implementation=[topology implementation]:impl:(etcd2 zk2 consul)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'vtctldclient command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (MoveTables)
        _values 'movetables action' \
          'cancel' 'complete' 'create' 'mirrortraffic' 'reversetraffic' \
          'show' 'start' 'status' 'stop' 'switchtraffic' && ret=0
        ;;
    esac
    ;;
esac

return ret
