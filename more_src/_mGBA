# Documentation: https://github.com/mgba-emu/mgba/blob/master/src/feature/commandline.c
# Reference accessed: 2026-05-16
# Verified: src/feature/commandline.c line 36 (long opts) + line 81
# (shortopts "b:c:C:hl:p:s:t:dg") + graphics subparser at line 312
# (GRAPHICS_OPTIONS "12345678f"). Same flags for SDL and Qt frontends.

# mGBA: Game Boy / Game Boy Advance emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)--version[print version and exit]' \
  '(-b --bios)'{-b,--bios=}'[GBA BIOS file]:file:_files -g "*.bin"' \
  '(-c --cheats)'{-c,--cheats=}'[apply cheat codes from a file]:file:_files' \
  '*'{-C,--config=}'[override config option]:OPTION=VALUE:' \
  '(-d --debug)'{-d,--debug}'[use command-line debugger]' \
  '(-g --gdb)'{-g,--gdb}'[start GDB session (port 2345)]' \
  '(-l --log-level)'{-l,--log-level=}'[log level mask]:n:' \
  '(-p --patch)'{-p,--patch=}'[apply patch file]:file:_files' \
  '(-s --frameskip)'{-s,--frameskip=}'[skip every N frames]:n:' \
  '(-t --savestate)'{-t,--savestate=}'[load savestate at start]:file:_files' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen]' \
  '-1[window scale 1x]' \
  '-2[window scale 2x]' \
  '-3[window scale 3x]' \
  '-4[window scale 4x]' \
  '-5[window scale 5x]' \
  '-6[window scale 6x]' \
  '-7[window scale 7x]' \
  '-8[window scale 8x]' \
  '*:ROM file:_files -g "*.(gba|gb|gbc|sgb|zip|7z)"' && ret=0
return ret
