#compdef spectre-meltdown-checker
# _spectre-meltdown-checker — speed47 Spectre/Meltdown vulnerability scanner CLI (speed47, Bash); custom argparse
# upstream: https://github.com/speed47/spectre-meltdown-checker

_spectre-meltdown-checker() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--batch=+[batch output]:b:(text nrpe prometheus json short)' \
        '--no-color[no color]' \
        '--no-explanations[no explanations]' \
        '--no-hw-check[no hardware check]' \
        '--no-sysfs[no sysfs]' \
        '--variant=+[only this variant]:v:(1 2 3 3a 4 l1tf mds taa itlb_multihit srbds zenbleed)' \
        '--update-mcedb[update microcode db]' \
        '--update-builtin-mcedb[update built-in microcode db]' \
        '--vmm=+[VMM mode]:vmm:(auto yes no)' \
        '--cpu[treat as host CPU only]' \
        '--coreos[CoreOS mode]' \
        '--paranoid[paranoid mode]' \
        '--explain[explain mitigations]' \
        '--kernel=+[kernel image]:file:_files' \
        '--config=+[config file]:file:_files' \
        '--map=+[kernel map]:file:_files' \
        '--no-intel-db[no intel microcode db]' \
        '--no-amd-db[no amd microcode db]' \
        '--allow-msr-write[allow MSR writes]' \
        '--allow-tools-installation[allow installing missing tools]' \
        '--target-uname=+[target kernel uname]:str:' \
        '--dump-mock-data[dump mock data]' \
        '--logfile=+[log file]:file:_files' \
        '*:arg:'
}

_spectre-meltdown-checker "$@"
