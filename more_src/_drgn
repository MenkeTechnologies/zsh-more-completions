#compdef drgn

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-p --pid)'{-p+,--pid=}'[debug running process]:pid:' \
  '(-c --core)'{-c+,--core=}'[debug core dump]:file:_files' \
  '(-k --kernel)'{-k,--kernel}'[debug running kernel]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-e --execute)'{-e+,--execute=}'[run code on startup]:code:' \
  '*--main-symbols-file=[main symbols file]:file:_files' \
  '*--extra-symbols-file=[extra symbols file]:file:_files' \
  '*--symbols=[symbols search path]:dir:_files -/' \
  '*--try-symbols-by=[try symbols method]:method:(file build-id debuglink procfs embedded-vdso reuse provided-debug-info debuginfod)' \
  '*--no-symbols-by=[skip symbols method]:method:(file build-id debuglink procfs embedded-vdso reuse provided-debug-info debuginfod)' \
  '*--debug-directory=[debug info directory]:dir:_files -/' \
  '--no-default-debug-directories[do not use default debug dirs]' \
  '*--kernel-directory=[kernel image search dir]:dir:_files -/' \
  '--no-default-kernel-directories[no default kernel dirs]' \
  '--debug-info-options=[debug info options]:opts:' \
  '--log-level=[log level]:lvl:(debug info warning error critical none)' \
  '*: :_files' && ret=0

return ret
