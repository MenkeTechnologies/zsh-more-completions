#compdef checkpto
# Documentation: https://man.archlinux.org/man/checkpto.1.en
# checkpto: inspect connectivity and info of a Hugin .pto project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--print-output-info[print more information about the output]' \
  '--print-lens-info[print more information about the lenses]' \
  '--print-stack-info[print more information about assigned stacks]' \
  '--print-image-info[print more information about images]' \
  '--create-missing-images[create placeholder images for non-existing images]' \
  '*:pto file:_files -g "*.pto"' && ret=0

return ret
