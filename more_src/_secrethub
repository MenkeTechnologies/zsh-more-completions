#compdef secrethub
# _secrethub — SecretHub secrets-management CLI (secrethub/secrethub-cli)
# upstream: https://github.com/secrethub/secrethub-cli
# Subcommands from internals/secrethub/app.go registerCommands().

_secrethub() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--config-dir=[SecretHub config directory (also SECRETHUB_CONFIG_DIR)]:dir:_files -/' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_secrethub_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                org|repo|service|account|credential|config|env|migrate|acl)
                    _arguments \
                        '1: :(create get list update delete invite member ls show purge fork link)' \
                        '*:arg:' && ret=0 ;;
                read|write|tree|ls|inspect|rm|mkdir|set|clear|audit|inject)
                    _arguments '*:secret path:' && ret=0 ;;
                run)
                    _arguments \
                        '--env=[secret env vars to inject (key=value, repeatable)]:env:' \
                        '*:command:' && ret=0 ;;
                generate)
                    _arguments \
                        '--length=[generated secret length]:length:' \
                        '--symbols[include symbols]' \
                        '1:secret path:' && ret=0 ;;
                init|signup|completion|clear-clipboard|keyring-clear|printenv) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_secrethub_commands] )) ||
_secrethub_commands() {
    local -a commands
    commands=(
        'org:manage SecretHub organizations'
        'repo:manage repositories'
        'service:manage service accounts'
        'account:manage your SecretHub account'
        'credential:manage local credentials'
        'config:show / edit local configuration'
        'env:manage environment-variable templates'
        'migrate:migrate from other secrets stores'
        'init:initialize a new SecretHub account / device'
        'signup:create a new SecretHub account'
        'acl:manage repository access-control lists'
        'read:read a secret value'
        'write:write / update a secret'
        'generate:generate a random secret and store it'
        'ls:list secrets and directories under a path'
        'mkdir:create a directory'
        'rm:remove a secret / directory'
        'tree:print a tree view of secrets'
        'inspect:print metadata for a secret'
        'audit:print the audit log for a secret / directory'
        'inject:render a template, substituting secrets'
        'run:run a command with secrets injected as env vars'
        'printenv:print the secret-injected environment'
        'clear:clear sensitive state from this session'
        'set:configure CLI defaults'
        'clear-clipboard:clear the secret previously copied to the clipboard'
        'keyring-clear:clear the OS keyring credential cache'
        'completion:emit shell completion script'
    )
    _describe -t commands 'secrethub command' commands
}

_secrethub "$@"
