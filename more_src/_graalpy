#compdef graalpy

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[program passed in as string]:command' \
  '-m+[run library module as a script]:module' \
  '-i[inspect interactively after running script]' \
  '-q[do not print version on interactive startup]' \
  '-u[unbuffered binary stdout and stderr]' \
  '-v[verbose, trace import statements]' \
  '-vv[very verbose]' \
  '-B[do not write .pyc files]' \
  '-b[issue warnings about str(bytes_instance)]' \
  '-bb[issue errors about str(bytes_instance)]' \
  '-d[enable debugging output]' \
  '-E[ignore PYTHON* environment variables]' \
  '-I[isolate from user site-packages and env vars]' \
  '-O[optimize generated bytecode slightly]' \
  '-OO[remove doc-strings in addition to -O]' \
  '-R[use hash randomization]' \
  '-s[do not add user site-packages to sys.path]' \
  '-S[do not imply import site on initialization]' \
  '-W+[warning control]:warning filter' \
  '-x[skip first line of source]' \
  '-X+[set implementation-specific option]:option' \
  '--check-hash-based-pycs=[control hash-based .pyc validation]:mode:(default always never)' \
  '--jvm[run on JVM]' \
  '--native[run as native image]' \
  '--python.EmulateJython[enable Jython emulation]' \
  '--python.ForceImportSite[force import of site module]' \
  '--python.PythonPath=[add to Python path]:path:_files' \
  '--python.PythonHome=[set Python home]:directory:_directories' \
  '--python.Executable=[set executable path]:path:_files' \
  '--experimental-options[allow experimental options]' \
  '--polyglot[enable polyglot support]' \
  '--engine.Mode=[engine mode]:mode:(default latency throughput)' \
  '*:script file:_files -g "*.py"' && ret=0

return ret
