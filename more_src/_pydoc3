#compdef pydoc3
# Documentation: https://docs.python.org/3/library/pydoc.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-k+[search documentation for keyword]:keyword:' \
  '-n+[start HTTP server with hostname]:hostname:_hosts' \
  '-p+[start HTTP server on port]:port:' \
  '-b[start HTTP server on arbitrary port and open browser]' \
  '-w+[write out HTML doc files for module]:module:' \
  '*:name (module/class/function or file path):' && ret=0

return ret
