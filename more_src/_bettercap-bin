#compdef bettercap
# _bettercap-bin — Bettercap MITM and recon framework (evilsocket, Go); modular network attacks + sniffing for authorized tests
# upstream: https://github.com/bettercap/bettercap

_bettercap-bin() {
    _arguments \
        '-h[show help]' \
        '-version[show version]' \
        '-eval+[startup commands]:cmds:' \
        '-caplet+[caplet file]:file:_files' \
        '-debug[debug output]' \
        '-silent[silent]' \
        '-iface+[interface]:iface:_net_interfaces' \
        '-no-history[disable history]' \
        '-no-style[disable colors]' \
        '-no-ui[do not start UI module]' \
        '-no-colors[disable colors]' \
        '-script+[script file]:file:_files' \
        '-cpu-profile+[CPU profile]:file:_files' \
        '-mem-profile+[memory profile]:file:_files' \
        '-env-file+[env file]:file:_files' \
        '-auto-start+[modules to auto-start]:modules:' \
        '-gateway-override+[gateway override]:ip:' \
        '-pcap-file+[pcap file]:file:_files' \
        '*:cmd:'
}

_bettercap-bin "$@"
