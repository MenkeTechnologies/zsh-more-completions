#compdef ttf2pt1
# Documentation: https://man.cx/ttf2pt1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# ttf2pt1: convert TrueType font to PostScript Type 1
# Verified flags from manpage; previous -h/-V/-A/-s/-t/-X/-o were either
# obsolete or not present in the manpage.

local curcontext="$curcontext" ret=1
_arguments -C \
  '-a[include all glyphs from source file]' \
  '-b[encode output as .pfb (binary)]' \
  '-d+[debugging suboptions]:opt:' \
  '-e[assemble result into ready .pfa file]' \
  '-F[force Unicode encoding, ignoring MS encodings]' \
  '-G+[file generation control suboptions]:opt:' \
  '-l+[extract fonts for specified language]:language' \
  '-L+[external map file for font extraction]:file:_files' \
  '-m+[resource limits (type=value)]:type=value' \
  '-O+[outline processing suboptions]:opt:' \
  '-p+[front-end parser]:parser:(ttf bdf ft)' \
  '-u+[mark font with UniqueID]:number' \
  '-v+[re-scale font to specified uppercase letter size]:size' \
  '-W+[warning verbosity 0-4]:level' \
  '*:TrueType font file:_files -g "*.(#i)ttf"' && ret=0
return ret
