#compdef ttf2pt1
# Documentation: https://man.archlinux.org/search?q=ttf2pt1
# Reference accessed: 2026-05-16

# ttf2pt1: convert TrueType font to PostScript Type 1
local curcontext="$curcontext" ret=1
_arguments -C \
  '-A[print short summary of glyph data]' \
  '-a[include all glyphs in output]' \
  '-b[generate binary PFB output]' \
  '-d[debug option (multiple)]:opt:' \
  '-e[encode the resulting Type 1 font]' \
  '-F[force conversion of poorly designed fonts]' \
  '-G[control how generated]:opt:' \
  '-h[print version and usage]' \
  '-l[Latin character set]:charset:' \
  '-L[load language map file]:file:_files' \
  '-m[parameter override]:param:' \
  '-O[optimization]:opt:' \
  '-o[output file]:file:_files' \
  '-p[language preprocessor]:lang:(latin1 plane+ russian adobestd custom-utf8)' \
  '-s[render as .afm/.pfa as in 24point font]' \
  '-t[show progressing status]' \
  '-u[generate Unicode-encoded font]:id:' \
  '-v[print verbose progress]' \
  '-V[print version]' \
  '-W[warning level]:n:' \
  '-X[platform/encoding]:val:' \
  '*:input TrueType font file:_files -g "*.(ttf|TTF)"' && ret=0
return ret
