#compdef pslPairs
# UCSC kent: join paired ends in psl alignments

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-max=[maximum length of clone sequence]:n:' \
  '-min=[minimum length of clone sequence]:n:' \
  '-slopval=[deviation from max/min clone lengths allowed]:n:' \
  '-nearTop=[maximum deviation from best match allowed]:frac:' \
  '-minId=[minimum pct ID of at least one end]:frac:' \
  '-minOrphanId=[minimum pct ID for orphan alignment]:frac:' \
  '-tInsert=[maximum insert bases allowed]:n:' \
  '-hardMax=[absolute maximum clone length for long report]:n:' \
  '-verbose[display all informational messages]' \
  '-noBin[do not include bin column in output]' \
  '-noRandom[do not include placements on random portions]' \
  '-slop[create .slop file of pairs within slop length]' \
  '-short[create .short file of pairs shorter than min]' \
  '-long[create .long file of pairs longer than max]' \
  '-mismatch[create .mismatch file of bad-orientation pairs]' \
  '-orphan[create .orphan file of unmatched ends]' \
  ':psl file:_files' \
  ':pair file:_files' \
  ':psl table name:' \
  ':out file prefix:_files' && ret=0

return ret
