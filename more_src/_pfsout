#compdef pfsout
# Documentation: https://resources.mpi-inf.mpg.de/pfstools/man1/pfsout.1.html
# read pfs frames from stdin and write them in the format set by the file extension

local ret=1

_arguments -s \
  '--frames=[frame range startframe:step:endframe]:range' \
  '*:output file:_files' && ret=0

return ret
