#compdef csi csi-5 chicken-csi

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)-version[show version]' \
  '(- *)-release[print release number]' \
  '-i[case-insensitive reading]' \
  '-case-insensitive[case-insensitive reading]' \
  '-k+[keyword style]:style:(prefix suffix none)' \
  '-keyword-style=[keyword style]:style:(prefix suffix none)' \
  '-no-parentheses-synonyms[disable parentheses synonyms]' \
  '-no-symbol-escape[disable symbol escapes]' \
  '-r5rs-syntax[strict R5RS syntax]' \
  '-n[do not load init file]' \
  '-no-init[do not load init file]' \
  '-q[quiet startup]' \
  '-quiet[quiet startup]' \
  '-w[disable warnings]' \
  '-no-warnings[disable warnings]' \
  '-b[batch mode]' \
  '-batch[batch mode]' \
  '-e+[evaluate expression]:expr:' \
  '-eval=[evaluate expression]:expr:' \
  '-p+[print expression]:expr:' \
  '-print=[print expression]:expr:' \
  '-P+[print to stderr]:expr:' \
  '-pretty-print=[pretty print]:expr:' \
  '*-R[require an extension]:ext:' \
  '*-require-extension=[require an extension]:ext:' \
  '*-I[include path]:dir:_files -/' \
  '*-include-path=[include path]:dir:_files -/' \
  '-D+[define a feature]:feat:' \
  '-feature=[define a feature]:feat:' \
  '-no-feature=[disable a feature]:feat:' \
  '-script[run as script]:file:_files -g "*.scm"' \
  '-s+[run script (batch -quiet -no-init)]:file:_files -g "*.scm"' \
  '-sx+[run script, show forms on stderr]:file:_files -g "*.scm"' \
  '-ss+[run script invoking main]:file:_files -g "*.scm"' \
  '*:scheme_file:_files -g "*.{scm,ss,sld}"' && ret=0

return ret
