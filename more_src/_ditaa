#compdef ditaa

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-o --overwrite)'{-o,--overwrite}'[overwrite existing output file]' \
  '(-s --scale)'{-s,--scale}'=[scale factor]:scale' \
  '(-e --encoding)'{-e,--encoding}'=[input file encoding]:encoding' \
  '(-A --no-antialias)'{-A,--no-antialias}'[disable antialiasing]' \
  '(-S --no-shadows)'{-S,--no-shadows}'[disable shadows]' \
  '(-E --no-separation)'{-E,--no-separation}'[disable shape separation]' \
  '(-r --round-corners)'{-r,--round-corners}'[use round corners]' \
  '(-t --tabs)'{-t,--tabs}'=[tab size]:size' \
  '(-b --background)'{-b,--background}'=[background color]:color' \
  '(-T --transparent)'{-T,--transparent}'[transparent background]' \
  '--svg[output SVG instead of PNG]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:input file:_files -g "*.{txt,ditaa,atxt}"' \
  '2:output file:_files -g "*.{png,svg}"' && ret=0

return ret
