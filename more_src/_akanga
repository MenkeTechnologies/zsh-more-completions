#compdef akanga
# _akanga — Akanga rc-based shell (Byron Rakitzis); minimal rc dialect, easier on UNIX than Plan 9
# upstream: https://github.com/wryun/es-shell

_akanga() {
    _arguments \
        '-c+[command]:code:' \
        '-d[debug]' \
        '-e[errexit]' \
        '-i[interactive]' \
        '-I[skip init]' \
        '-l[login shell]' \
        '-n[parse only]' \
        '-p[paranoid mode]' \
        '-s[read from stdin]' \
        '-v[verbose]' \
        '-x[xtrace]' \
        '*:script:_files'
}

_akanga "$@"
