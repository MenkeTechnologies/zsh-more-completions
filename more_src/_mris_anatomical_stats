#compdef mris_anatomical_stats
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_anatomical_stats
# FreeSurfer compute anatomical statistics for cortical surfaces

local ret=1

_arguments -s -S \
  '-i[only consider thicknesses in low/hi range]:thresh:' \
  '-l[limit calculations to specified label]:label file:_files' \
  '-t[use file for computing thickness statistics]:thickness file:_files' \
  '-a[compute properties per label in annotation file]:annotation file:_files' \
  '-b[tabular output]' \
  '-f[table output to tablefile]:tablefile:_files' \
  '-log[write stats to log file]:logfile:_files' \
  '-nsmooth[smooth thicknessmap N iterations before use]:#:' \
  '-c[output annotation colortable to text file]:ctab file:_files' \
  '-noglobal[do not compute global brain stats]' \
  '-th3[vertex-wise volume via three tetrahedra]' \
  '1:subject name:' \
  '2:hemisphere:(lh rh)' \
  '3::surface name:' && ret=0

return ret
