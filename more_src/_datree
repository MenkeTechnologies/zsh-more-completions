#compdef datree

local -a subcommands
subcommands=(
  'config:Configure Datree'
  'completion:Generate shell completion'
  'docs:Open documentation'
  'kustomize:Validate Kustomize output'
  'publish:Publish policies'
  'test:Test Kubernetes configuration files'
  'version:Show version'
  'help:Show help'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      test)
        _arguments \
          '(-h --help)'{-h,--help}'[Show help]' \
          '(-o --output)'{-o,--output}'[Output format]:format:(yaml json xml simple)' \
          '(-s --schema-version)'{-s,--schema-version}'[Kubernetes schema version]:version:' \
          '(-p --policy)'{-p,--policy}'[Policy name]:policy:' \
          '--policy-config=[Policy config file]:file:_files' \
          '--no-record[Do not record results]' \
          '--only-k8s-files[Only test Kubernetes files]' \
          '--ignore-missing-schemas[Ignore missing schemas]' \
          '--schema-location=[Custom schema location]:url:' \
          '--verbose[Verbose output]' \
          '*:files:_files'
        ;;
      config)
        _arguments \
          'set:Set configuration value' \
          'get:Get configuration value'
        ;;
      publish)
        _arguments \
          '1:policies file:_files'
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)'
        ;;
      kustomize)
        _arguments \
          'test:Test Kustomize output' \
          '(-o --output)'{-o,--output}'[Output format]:format:(yaml json xml simple)' \
          '*:path:_directories'
        ;;
    esac
    ;;
esac
