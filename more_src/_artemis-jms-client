#compdef artemis-jms-client
# Documentation: https://man.archlinux.org/search?q=artemis-jms-client
# Reference accessed: 2026-05-16

# artemis-jms-client: simple JMS test client shipped with Artemis
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--url=[broker URL]:url:' \
  '--user=[username]:user:_users' \
  '--password=[password]:password:' \
  '--queue=[queue]:queue:' \
  '--topic=[topic]:topic:' \
  '--produce[produce]' \
  '--consume[consume]' \
  '--count=[message count]:n:' \
  '*::artemis-jms-client args:_files' && ret=0
return ret
