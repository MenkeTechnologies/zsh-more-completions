  '(-i)'-i'[Specifies that the Illumina CASAVA identifiers should be processed. Th]' \
  '(-U --UMI)'{-U,--UMI}'[Migrate the UMI sequence from the last read name component to the UMI]' \
  '(--UMI-tag)'--UMI-tag'[Specifies which aux tag to place the UMI barcode into. default is `RX'\'']:TAG: ' \
  '(-N --name2)'{-N,--name2}'[Assume the read names are encoded in the SRA and ENA formats where the]' \
  '(--barcode-tag)'--barcode-tag'[Changes the auxiliary tag used for barcode sequence. Defaults to BC.]:TAG: ' \
  '(--quality-tag)'--quality-tag'[Changes the auxiliary tag used for barcode quality. Defaults to QT.]:TAG: ' \
  '(-oFILE)'-oFILE'[Output to FILE . By default output will be written to stdout.]:arg: ' \
