#compdef qcli

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-i[input file]:file:_files' \
  '--input[input file]:file:_files' \
  '-o[output file]:file:_files' \
  '--output[output file]:file:_files' \
  '-f[filter]:filter:(signalstats psnr ssim astats aphasemeter ebur128)' \
  '--filter[filter]:filter:(signalstats psnr ssim astats aphasemeter ebur128)' \
  '-p[create playback proxy file]' \
  '--playbackproxy[create playback proxy file]' \
  '*:files:_files' \
  && ret=0

return ret
