#compdef prometheus-nats-exporter
# _prometheus-nats-exporter — NATS Prometheus exporter (nats-io/prometheus-nats-exporter)
# upstream: https://github.com/nats-io/prometheus-nats-exporter
# Flags from main.go (flag).

_prometheus-nats-exporter() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-version[show version]' \
        '(-p -port)'{-p+,-port=}'[port to listen on]:port:' \
        '(-a -addr)'{-a+,-addr=}'[network host to listen on]:host:' \
        '-path=[scrape URL path]:path:' \
        '-ri=[retry interval (s)]:secs:' \
        '(-l -log)'{-l+,-log=}'[log file name]:file:_files' \
        '(-s -syslog)'{-s,-syslog}'[log to syslog]' \
        '(-r -remote_syslog)'{-r+,-remote_syslog=}'[remote syslog address]:addr:' \
        '-D[enable debug log level]' \
        '-V[enable trace log level]' \
        '-DV[enable debug+trace]' \
        '-connz[collect connection metrics]' \
        '-connz_detailed[collect detailed connection metrics]' \
        '-healthz[collect health metrics]' \
        '-healthz_js_enabled_only[health: JS enabled only]' \
        '-healthz_js_server_only[health: JS server only]' \
        '-gatewayz[collect gateway metrics]' \
        '-accstatz[collect accstatz metrics]' \
        '-accountz[collect account-detail metrics]' \
        '-leafz[collect leaf metrics]' \
        '-routez[collect route metrics]' \
        '-subz[collect subscription metrics]' \
        '-varz[collect general metrics]' \
        '-jsz=[JetStream metrics filter]:filter:(streams accounts consumers all)' \
        '-jsz_stream_meta_keys=[stream meta keys to include]:keys:'
}

_prometheus-nats-exporter "$@"
