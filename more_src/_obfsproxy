#compdef obfsproxy
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/obfsproxy.1.html
# Reference accessed: 2026-05-19
# Verified: obfsproxy upstream manpage. Real global flags:
# --log-file, --log-min-severity (error warning info debug),
# --no-log, --no-safe-logging, -h/--help. Subcommands: managed,
# dummy, b64, obfs2, obfs3, scramblesuit. Mode arg: server,
# ext_server, client, socks. Transport options: --dest, --dest-ip,
# --ext-cookie-file, --password (scramblesuit only).
# Corrected: removed fabricated --version, --data-dir, "notice"
# severity, "external" subcommand (real PT mode is "ext_server").

# obfsproxy: Tor pluggable transport
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'managed:managed mode (Tor controls obfsproxy)'
  'dummy:dummy pluggable transport'
  'b64:base64 transport'
  'obfs2:obfs2 transport'
  'obfs3:obfs3 transport'
  'scramblesuit:ScrambleSuit transport'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--log-file=[log file]:file:_files' \
  '--log-min-severity=[log level]:level:(error warning info debug)' \
  '--no-log[disable logging]' \
  '--no-safe-logging[disable safe logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'obfsproxy command' commands && ret=0 ;;
  args)
    _arguments \
      '--dest=[destination address]:addr:' \
      '--dest-ip=[destination IP]:ip:' \
      '--ext-cookie-file=[extended ORPort auth cookie file]:file:_files' \
      '--password=[shared secret (scramblesuit)]:password:' \
      '1:mode:(server ext_server client socks)' \
      '*: :_default' && ret=0
    ;;
esac
return ret
