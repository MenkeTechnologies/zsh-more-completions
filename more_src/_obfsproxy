#compdef obfsproxy

# obfsproxy: Tor pluggable transport (obfs2/obfs3/scramblesuit/obfs4)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--log-file=[log file]:file:_files' \
  '--log-min-severity=[log level]:level:(error warning notice info debug)' \
  '--no-log[disable logging]' \
  '--no-safe-logging[disable safe logging (allow sensitive log content)]' \
  '--data-dir=[state/log directory]:dir:_files -/' \
  '--version[show version]' \
  '*::obfsproxy mode and args (managed/external client/server):_files' && ret=0
return ret
