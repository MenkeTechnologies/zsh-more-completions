#compdef obfsproxy

# obfsproxy: Tor pluggable transport
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'dummy:dummy pluggable transport (testing)'
  'b64:base64 transport'
  'obfs2:obfs2 transport (deprecated)'
  'obfs3:obfs3 transport (deprecated)'
  'scramblesuit:ScrambleSuit transport'
  'managed:managed mode (run as Tor pluggable transport)'
  'external:external mode'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--log-file=[log file]:file:_files' \
  '--log-min-severity=[log level]:level:(error warning notice info debug)' \
  '--no-safe-logging[disable safe logging]' \
  '--data-dir=[data directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'obfsproxy command' commands && ret=0 ;;
esac
return ret
