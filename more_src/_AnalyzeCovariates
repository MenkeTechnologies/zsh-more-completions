#compdef AnalyzeCovariates
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/bqsr/AnalyzeCovariates.java
# GATK4: evaluate and compare base quality score recalibration tables

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-before --before-report-file)'{-before,--before-report-file}'[BQSR first-pass report file]:file:_files' \
  '(-after --after-report-file)'{-after,--after-report-file}'[BQSR second-pass report file]:file:_files' \
  '(-plots --plots-report-file)'{-plots,--plots-report-file}'[output PDF report location]:file:_files' \
  '(-csv --intermediate-csv-file)'{-csv,--intermediate-csv-file}'[csv intermediate file location]:file:_files' \
  '(-bqsr --bqsr)'{-bqsr,--bqsr}'[input covariates table for on-the-fly recalibration]:file:_files' \
  '--ignore-last-modification-times[suppress modification-time warnings]' \
  '*:options:_files' && ret=0

return ret
