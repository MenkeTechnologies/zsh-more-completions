#compdef bibtexu
# Documentation: bibtexu --help (TeX Live 2026)
# Source: Unicode-aware BibTeX with localization support.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-\?,--help}'[display help text]' \
    '(- *)'{-v,--version}'[report BibTeX version]' \
    '(-d --debug)'{-d+,--debug=}'[report debugging information]:type:(all csf io mem misc search)' \
    '(-s --statistics)'{-s,--statistics}'[report internal statistics]' \
    '(-t --trace)'{-t,--trace}'[report execution tracing]' \
    '(-l --language)'{-l+,--language=}'[use language LANG (e.g. fr)]:lang:' \
    '(-o --location)'{-o+,--location=}'[use location LOC (e.g. fr)]:loc:' \
    '(-B --big -H --huge -W --wolfgang --mstrings)'{-B,--big}'[same as --mstrings 10000]' \
    '(-B --big -H --huge -W --wolfgang --mstrings)'{-H,--huge}'[same as --mstrings 19000]' \
    '(-B --big -H --huge -W --wolfgang --mstrings)'{-W,--wolfgang}'[same as --mstrings 30000]' \
    '(-M --min_crossrefs)'{-M+,--min_crossrefs=}'[set min_crossrefs]:n:' \
    '(-B --big -H --huge -W --wolfgang)--mstrings=[allow N unique strings]:n:' \
    '1:aux file:_files -g "*.aux"' \
    && ret=0

return ret
