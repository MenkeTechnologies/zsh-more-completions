#compdef armada-scheduleringester scheduleringester
# _armada-scheduleringester — Armada scheduler ingester (Pulsar → PostgreSQL pipeline feeding the armada-scheduler job-DB)
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/scheduleringester/main.go on tip; runtime config is YAML-driven (./config/scheduleringester/config.yaml + --config overrides) with viper ARMADA_* env binding.

_armada-scheduleringester() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[YAML config file (repeat or comma-separate for multiple)]:file:_files'
}

_armada-scheduleringester "$@"
