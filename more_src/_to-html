#compdef to-html
# Source: https://github.com/Aloso/to-html
# Release asset: to-html-aarch64-apple-darwin.tar.gz
# Type: maintainer-shipped (GitHub release)
# Harvested: 2026-05-15

autoload -U is-at-least

_to-html() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-s+[The shell to run the command in. On macOS and FreeBSD, the shell has to support \`-c <command>\`]:SHELL:_default' \
'--shell=[The shell to run the command in. On macOS and FreeBSD, the shell has to support \`-c <command>\`]:SHELL:_default' \
'*-l+[Programs that have subcommands (which should be highlighted). Multiple arguments are separated with a comma, e.g. \`to-html -l git,cargo,npm "git checkout main"\`]:HIGHLIGHT:_default' \
'*--highlight=[Programs that have subcommands (which should be highlighted). Multiple arguments are separated with a comma, e.g. \`to-html -l git,cargo,npm "git checkout main"\`]:HIGHLIGHT:_default' \
'-p+[Prefix for CSS classes. For example, with the \`to-html\` prefix, the \`arg\` class becomes \`to-html-arg\`]:PREFIX:_default' \
'--prefix=[Prefix for CSS classes. For example, with the \`to-html\` prefix, the \`arg\` class becomes \`to-html-arg\`]:PREFIX:_default' \
'-t+[Set the terminal'\''s color theme \[default\: dark\]]:THEME:(light dark)' \
'--theme=[Set the terminal'\''s color theme \[default\: dark\]]:THEME:(light dark)' \
'-n[Do not run the commands, just emit the HTML for the command prompt]' \
'--no-run[Do not run the commands, just emit the HTML for the command prompt]' \
'-N[Do not show the command prompt]' \
'--no-prompt[Do not show the command prompt]' \
'-c[Print the (abbreviated) current working directory in the command prompt]' \
'--cwd[Print the (abbreviated) current working directory in the command prompt]' \
'-d[Output a complete HTML document, not just a \`<pre>\`]' \
'--doc[Output a complete HTML document, not just a \`<pre>\`]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'*::commands -- The command(s) to execute. Must be wrapped in quotes:_default' \
&& ret=0
}

(( $+functions[_to-html_commands] )) ||
_to-html_commands() {
    local commands; commands=()
    _describe -t commands 'to-html commands' commands "$@"
}

if [ "$funcstack[1]" = "_to-html" ]; then
    _to-html "$@"
else
    compdef _to-html to-html
fi
