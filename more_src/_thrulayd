#compdef thrulayd
# Documentation: https://thrulay-hd.sourceforge.net/docs/thrulayd.8.html
# thrulayd - network capacity tester (server part)

local ret=1

_arguments -s -S \
  '-w[window size of server listening socket (default 4194304)]:bytes' \
  '-p[server listening port (default 5003)]:port' \
  '-a[restrict client access by IP/CIDR]:addr' \
  '-c[run in foreground, log to stdout]' \
  '*::arg:_default' && ret=0

return ret
