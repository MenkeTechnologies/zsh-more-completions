#compdef waifu2x-ncnn-vulkan-extra
# Documentation: https://github.com/nihui/waifu2x-ncnn-vulkan
# waifu2x ncnn Vulkan image upscaler/denoiser (extra-models fork)

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose output]' \
  '-i+[input image path or directory]:input:_files' \
  '-o+[output image path or directory]:output:_files' \
  '-n+[denoise level (-1/0/1/2/3, default=0)]:noise:(-1 0 1 2 3)' \
  '-s+[upscale ratio (default=2)]:scale:(1 2 4 8 16 32)' \
  '-t+[tile size (>=32/0=auto)]:tile size' \
  '-m+[waifu2x model path]:model dir:_files -/' \
  '-g+[gpu device (-1=cpu, default=auto)]:gpu id' \
  '-j+[thread count for load:proc:save]:threads' \
  '-x[enable tta mode]' \
  '-f+[output image format]:format:(jpg png webp)' && ret=0

return ret
