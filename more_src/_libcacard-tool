#compdef libcacard-tool
# Documentation: https://man.archlinux.org/search?q=libcacard-tool
# Reference accessed: 2026-05-16

# libcacard-tool: helper utility for libcacard (CAC smart card emulation)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*::libcacard-tool args:_files' && ret=0
return ret
