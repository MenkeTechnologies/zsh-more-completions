#compdef sfpow
# Documentation: https://github.com/ahay/src/blob/master/system/generic/Mpow.c
# Madagascar: apply power gain

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  '*pow=[power on the n-th axis]:value' \
  'tpow=[power on the first axis]:value' \
  '*:RSF file:_files' && ret=0

return ret
