#compdef bird2 bird-2
# _bird2 — CZ.NIC Labs BIRD2 routing daemon for BGP OSPF RIP IS-IS Babel BFD and MRT alternative bin (CZ.NIC team, C); custom argparse
# upstream: https://gitlab.nic.cz/labs/bird

_bird2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "bird.conf *.conf"' \
        '-d[debug log to stderr]' \
        '-D+[debug log file]:file:_files' \
        '-f[run in foreground]' \
        '-g+[group]:group:_groups' \
        '-l[use local config]' \
        '-p[parse config only]' \
        '-P+[pid file]:file:_files' \
        '-s+[control socket]:file:_files' \
        '-u+[user]:user:_users' \
        '--config=+[config file]:file:_files' \
        '--debug=+[debug log file]:file:_files' \
        '--foreground[run in foreground]' \
        '--group=+[group]:group:_groups' \
        '--local[use local config]' \
        '--parse[parse config only]' \
        '--pid=+[pid file]:file:_files' \
        '--socket=+[control socket]:file:_files' \
        '--user=+[user]:user:_users' \
        '--nofork[do not detach]'
}

_bird2 "$@"
