#compdef sudatumfd
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/datuming/sudatumfd.c
# 2D zero-offset finite difference acoustic wave-equation datuming

local ret=1

_arguments -s -S \
  'nt=[number of time samples on each trace]:nt' \
  'nx=[number of receivers per shot gather]:nx' \
  'nsx=[number of shot gathers]:nsx' \
  'nz=[number of downward continuation depth steps]:nz' \
  'dz=[depth sampling interval (meters)]:dz' \
  'mx=[number of horizontal samples in the velocity model]:mx' \
  'mz=[number of vertical samples in the velocity model]:mz' \
  'vfile1=[velocity file used for thin-lens term]:vfile1:_files' \
  'vfile2=[velocity file used for diffraction term]:vfile2:_files' \
  'dx=[horizontal sampling interval (meters)]:dx' \
  'dt=[time sampling interval (seconds)]:dt' \
  'buff=[number of zero traces added to each side as a pad]:buff' \
  'tap_len=[taper length (number of traces)]:tap_len' \
  'x_0=[x coordinate of leftmost position in velocity model]:x_0' \
  '*:file:_files' && ret=0

return ret
