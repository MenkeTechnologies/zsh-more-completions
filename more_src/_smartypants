#compdef smartypants
# Documentation: https://pythonhosted.org/smartypants/command-line.html
# Translate plain ASCII punctuation into smart typographic HTML entities

local ret=1

_arguments -s -S \
  '(-a --attr)'{-a+,--attr=}'[tell smartypants how to translate]:attributes' \
  '(-s --skip)'{-s+,--skip=}'[skip specified HTML elements]:tags' \
  '-h[show help]' \
  '-v[show version]' \
  '*:file:_files' && ret=0

return ret
