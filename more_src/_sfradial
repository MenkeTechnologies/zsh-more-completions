#compdef sfradial
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mradial.c
# Madagascar: radial transform

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'inv=[if y, do inverse transform]:flag:(y n)' \
  'nw=[accuracy level]:level' \
  'tp=[time reference]:value' \
  'xp=[offset reference]:value' \
  'nx=[number of offsets (if inv=y)]:count' \
  'x0=[offset origin (if inv=y)]:value' \
  'dx=[offset sampling (if inv=y)]:value' \
  'nv=[number of velocities (if inv=n)]:count' \
  'vmin=[minimum velocity (if inv=n)]:velocity' \
  'vmax=[maximum velocity (if inv=n)]:velocity' \
  '*:RSF file:_files' && ret=0

return ret
