#compdef tlc
# Documentation: https://raw.githubusercontent.com/pmer/tla-bin/master/bin/tlc
# Reference accessed: 2026-05-27
# Verified: upstream tlc2.TLC.handleParameters() in tlaplus/tlaplus
#   tlatools/org.lamport.tlatools/src/tlc2/TLC.java

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print help and exit]' \
  '-config[TLC config file (default SPEC.cfg)]:config file:_files -g "*.cfg"' \
  '-deadlock[disable deadlock checking]' \
  '-difftrace[show only state diffs in error traces]' \
  '-cleanup[clean up metadir before running]' \
  '-nowarning[suppress warnings]' \
  '-suppressMessages[silence specific message codes]:codes (comma-separated):' \
  '-messagesAsErrors[treat specific message codes as fatal]:codes (comma-separated):' \
  '-gzip[compress checkpoint and state queue files]' \
  '-terse[do not expand values in error traces]' \
  '-continue[continue after invariant violation]' \
  '-view[apply VIEW to compute state hash]' \
  '-debug[print debugging output]' \
  '-inv[evaluate single invariant]:expression:' \
  '-invlevel[invariant level]:level:' \
  '-debugger[attach TLA+ debugger]:opts (port=N,nosuspend,nohalt):' \
  '-tool[run in tool mode for machine-readable output]' \
  '-generateSpecTE[generate trace exploration spec]:opts (nomonolith):' \
  '-noGenerateSpecTE[do not generate trace exploration spec]' \
  '-noTE[alias of -noGenerateSpecTE]' \
  '-noGenerateSpecTEBin[do not generate TE binary spec]' \
  '-noTEBin[alias of -noGenerateSpecTEBin]' \
  '-teSpecOutDir[output directory for TE spec]:directory:_files -/' \
  '-lncheck[liveness checking strategy]:strategy:(default final seqfinal)' \
  '-dump[dump reachable states]:file or "dot,file":_files' \
  '-loadTrace[load saved trace file]:format file:' \
  '-dumpTrace[dump current trace]:format file:' \
  '-postCondition[run postcondition operator]:mod!op:' \
  '-coverage[print coverage every N minutes]:minutes:' \
  '-checkpoint[checkpoint every N minutes (default 30)]:minutes:' \
  '-depth[search depth for DFID/simulate (default 100)]:depth:' \
  '-seed[seed for random simulation]:long:' \
  '-aril[secondary seed value]:long:' \
  '-maxSetSize[maximum set cardinality (default 1000000)]:size:' \
  '-recover[recover from checkpoint directory]:metadir:_files -/' \
  '-metadir[metadata directory (default SPEC-dir/states)]:directory:_files -/' \
  '-userFile[file for user Print output]:file:_files' \
  '-workers[number of worker threads or "auto" (default 1)]:workers:' \
  '-dfid[run iterative deepening to depth N]:depth:' \
  '-fp[fingerprint polynomial index]:index:' \
  '-fpmem[fingerprint table memory fraction or bytes (default 0.25)]:value:' \
  '-fpbits[bits to use for fingerprint addressing (default 1)]:bits:' \
  '-modelcheck[run in model-checking mode (default)]' \
  '-simulate[run in simulation mode]:opts (file=X,num=Y,stats=basic/full,sched=rl/rlaction):' \
  '-generate[run in generation mode]:opts (file=X,num=Y,stats=basic/full,sched=rl/rlaction):' \
  '*:spec:_files -g "*.tla"' && ret=0

return ret
