#compdef ffc dolfin-version dolfin-convert dolfin-order dolfin-plot
# Documentation: https://man.archlinux.org/search?q=ffc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (ffc)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-d --debug)'{-d,--debug}'[debug]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-o --output-directory)'{-o+,--output-directory=}'[output dir]:dir:_files -/' \
      '(-l --language)'{-l+,--language=}'[output language]:lang:(ufc dolfin)' \
      '(-r --representation)'{-r+,--representation=}'[representation]:r:(quadrature tensor uflacs auto)' \
      '(-O --optimize)'{-O,--optimize}'[optimize]' \
      '(-q --quadrature-rule)'{-q+,--quadrature-rule=}'[quadrature rule]:rule:' \
      '(-f --format)'{-f+,--format=}'[format]:fmt:' \
      '(-e --error-control)'{-e,--error-control}'[error control]' \
      '(-s --split)'{-s,--split}'[split header/source]' \
      '*: :_files -g "*.ufl *.form *.py"' && ret=0 ;;
  (dolfin-convert)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-i --input)'{-i+,--input=}'[input format]:f:(xml-old gmsh metis-graph scotch-graph diffpack abaqus)' \
      '(-o --output)'{-o+,--output=}'[output format]:f:(xml dolfin-xml h5)' \
      '*: :_files -g "*.xml *.msh *.dat *.exo *.h5"' && ret=0 ;;
  (dolfin-order|dolfin-plot|dolfin-version)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*: :_files' && ret=0 ;;
esac

return ret
