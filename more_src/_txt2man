#compdef txt2man
# Documentation: https://github.com/mvertes/txt2man
# Reference accessed: 2026-05-21
# Verified: upstream mvertes/txt2man script (getopts :d:hpTXr:s:t:v:P:I:B:).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-p[probe title, section name and volume]' \
  '-P+[set program string]:program string:' \
  '-t+[set title]:title:' \
  '-r+[set release]:release:' \
  '-s+[set section number]:section:(1 2 3 4 5 6 7 8)' \
  '-v+[set volume name]:volume:' \
  '-d+[set date]:date:' \
  '*-I+[italic words list]:words:' \
  '*-B+[bold words list]:words:' \
  '-T[preview using PAGER]' \
  '-X[preview using gxditview]' \
  '*:text file:_files' && ret=0

return ret
