#compdef txt2man
# Documentation: https://man.archlinux.org/search?q=txt2man
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-P+[set program string]:program string:' \
  '-t+[set title]:title:' \
  '-r+[set release]:release:' \
  '-s+[set section number]:section:(1 2 3 4 5 6 7 8)' \
  '-v+[set volume]:volume:' \
  '-d+[set date]:date:' \
  '-I+[italic words list]:words:' \
  '-B+[bold words list]:words:' \
  '-T[preprocess with tbl]' \
  '*:text file:_files' && ret=0

return ret
