#compdef spirv-cross
# Documentation: https://man.archlinux.org/search?q=spirv-cross
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--output[output file]:file:_files' \
  '--es[output GLSL ES]' \
  '--no-es[output desktop GLSL]' \
  '--version[GLSL version]:ver:' \
  '--dump-resources[dump resources]' \
  '--force-temporary[force temporary variables]' \
  '--vulkan-semantics[Vulkan semantics]' \
  '--separate-shader-objects[separate shader objects]' \
  '--flatten-ubo[flatten UBOs]' \
  '--fixup-clipspace[fixup clipspace]' \
  '--flip-vert-y[flip Y in vertex shader]' \
  '--iterations[N iterations]:n:' \
  '--cpp[output C++]' \
  '--msl[output MSL]' \
  '--msl-version[MSL version]:ver:' \
  '--msl-ios[target iOS MSL]' \
  '--msl-pad-fragment-output[pad MSL fragment output]' \
  '--msl-domain-lower-left[lower-left domain]' \
  '--msl-argument-buffers[use argument buffers]' \
  '--msl-shader-input[shader input]:input:' \
  '--hlsl[output HLSL]' \
  '--shader-model[HLSL shader model]:n:' \
  '--hlsl-enable-compat[enable HLSL compat]' \
  '--hlsl-flatten-matrix-vertex-input[flatten matrix vertex input]' \
  '--reflect[output JSON reflection]:format:(json)' \
  '--remove-unused-variables[remove unused variables]' \
  '--stage[shader stage]:stage:(vert frag tese tesc geom comp rgen rint rahit rchit rmiss rcall)' \
  '*:file:_files -g "*.{spv,glsl,vert,frag,tesc,tese,geom,comp,rgen,rint,rahit,rchit,rmiss,rcall}"' && ret=0

return ret
