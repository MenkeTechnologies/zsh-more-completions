#compdef spirv-cross
# Documentation: https://github.com/KhronosGroup/SPIRV-Cross
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--output[output file]:file:_files' \
  '--es[output GLSL ES]' \
  '--no-es[output desktop GLSL]' \
  '--version[GLSL version]:ver:' \
  '--force-temporary[force temporary variables]' \
  '--vulkan-semantics[emit separate image samplers for Vulkan GLSL]' \
  '--flip-vert-y[flip Y in vertex shader]' \
  '--cpp[output C++]' \
  '--msl[output MSL]' \
  '--hlsl[output HLSL]' \
  '--rename-interface-variable[rename I/O variables by location]:args:' \
  '*:file:_files -g "*.spv"' && ret=0

return ret
