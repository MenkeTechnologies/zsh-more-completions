#compdef eyaml-rotate-keys
# _eyaml-rotate-keys — rotate EYAML keys for encrypted YAML values (wwkimball/yamlpath)
# upstream: https://github.com/wwkimball/yamlpath
# Flags from yamlpath/commands/eyaml_rotate_keys.py (argparse).

_eyaml-rotate-keys() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-d --debug)'{-d,--debug}'[debug output]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-q --quiet)'{-q,--quiet}'[suppress informational output]' \
        '(-b --backup)'{-b,--backup}'[save backup YAML_FILE.bak]' \
        '(-x --eyaml)'{-x+,--eyaml=}'[eyaml binary]:path:_files' \
        '(-r --newprivatekey)'{-r+,--newprivatekey=}'[new EYAML private key]:file:_files' \
        '(-u --newpublickey)'{-u+,--newpublickey=}'[new EYAML public key]:file:_files' \
        '(-i --oldprivatekey)'{-i+,--oldprivatekey=}'[old EYAML private key]:file:_files' \
        '(-c --oldpublickey)'{-c+,--oldpublickey=}'[old EYAML public key]:file:_files' \
        '--frontmatter[parse Markdown frontmatter]' \
        '*:YAML file:_files -g "*.{yml,yaml}"'
}

_eyaml-rotate-keys "$@"
