#compdef secretspec
# Documentation: https://secretspec.dev/reference/cli/
# secretspec - declarative secrets management across environments and providers

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

local -a providers
providers=(keyring onepassword dotenv env pass lastpass protonpass gcsm awssm vault bws)

_secretspec_commands() {
  local -a commands
  commands=(
    'init:initialize a secretspec.toml from an existing .env'
    'config:manage user configuration and providers'
    'check:check that all required secrets are available'
    'get:get a secret value'
    'set:set a secret value'
    'run:run a command with secrets injected as env vars'
    'import:import secrets from another provider'
    'audit:show the audit log'
  )
  _describe -t commands 'secretspec command' commands
}

_arguments -C \
  '(-f --file)'{-f,--file=}'[path to secretspec.toml]:file:_files' \
  '--reason=[reason for accessing secrets (audit logging)]:reason:' \
  '1: :_secretspec_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          '--from=[source .env file path]:file:_files' && ret=0
        ;;
      config)
        _arguments -C '1: :->csub' '*::carg:->cargs' && ret=0
        case $state in
          csub)
            _values 'config command' \
              'init[initialize user configuration interactively]' \
              'show[show current configuration]' \
              'provider[manage configured providers]' && ret=0
            ;;
          cargs)
            if [[ $line[1] == provider ]]; then
              _values 'provider command' \
                'add[add a provider alias]' \
                'list[list configured provider aliases]' \
                'remove[remove a provider alias]' && ret=0
            fi
            ;;
        esac
        ;;
      check|run)
        _arguments -s -S \
          '(-p --provider)'{-p,--provider=}'[backend provider]:provider:($providers)' \
          '(-P --profile)'{-P,--profile=}'[profile selection]:profile:' \
          '*::command:_command_names -e' && ret=0
        ;;
      get|set)
        _arguments -s -S \
          '(-p --provider)'{-p,--provider=}'[backend provider]:provider:($providers)' \
          '(-P --profile)'{-P,--profile=}'[profile selection]:profile:' \
          '1:name:' \
          '2:value:' && ret=0
        ;;
      import)
        _arguments -s -S \
          '1:from provider:($providers)' && ret=0
        ;;
      audit)
        _arguments -s -S \
          '--project=[filter by project]:project:' \
          '--action=[filter by action type]:action:' \
          '(-n --tail)'{-n,--tail=}'[show last N entries]:n:' \
          '--json[output JSON Lines format]' && ret=0
        ;;
    esac
    ;;
esac

return ret
