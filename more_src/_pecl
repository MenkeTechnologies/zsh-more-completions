#compdef pecl
# _pecl — PHP PECL CLI (PEAR-derived package installer for PECL extensions; subcommands install/uninstall/upgrade/list/list-channels/list-upgrades/search/info/config-get/config-set/config-show/channel-discover/channel-update/clear-cache/run-scripts)
# upstream: https://github.com/pear/pear-core (PECL ships via PEAR)
# Subcommands from pear/pecl Console_GetOpts on tip.

_pecl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-c+[user config file]:file:_files' \
        '-C+[system config file]:file:_files' \
        '-d+[set runtime ini value]:key=value:' \
        '-D+[set runtime ini value]:key=value:' \
        '-y[assume yes]' \
        '-Z[no gzip]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'pecl command' \
                '(install uninstall upgrade upgrade-all list list-channels list-files list-upgrades search info download channel-discover channel-update channel-info channel-add channel-delete channel-login channel-logout channel-alias clear-cache config-get config-set config-show config-help config-create build cvsdiff cvspass cvstag makerpm package package-dependencies package-validate pickle remote-info remote-list remote-search run-scripts shell-test svntag update-channels)'
            ;;
        args) _arguments '*:package:' ;;
    esac
}

_pecl "$@"
