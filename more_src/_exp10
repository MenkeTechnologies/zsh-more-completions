#compdef exp10
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss45.html
# KAPPA: takes the base-10 exponential of each pixel of an NDF

local ret=1

_arguments -s \
  'IN=[input NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'TITLE=[title for the output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
