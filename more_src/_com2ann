#compdef com2ann
# Documentation: https://github.com/ilevkivskyi/com2ann
# com2ann - translate Python type comments to type annotations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --outfile)'{-o,--outfile}'[output file or directory]:outfile:_files' \
  '(-s --silent)'{-s,--silent}'[suppress summary output]' \
  '(-n --drop-none)'{-n,--drop-none}'[drop None assignment value if annotated by a type comment]' \
  '(-e --drop-ellipsis)'{-e,--drop-ellipsis}'[drop Ellipsis assignment value if annotated by a type comment]' \
  '(-i --add-future-imports)'{-i,--add-future-imports}'[add from __future__ import annotations to translated files]' \
  '(-w --wrap-signatures)'{-w,--wrap-signatures}'[wrap function headers longer than given length]:length:' \
  '(-v --python-minor-version)'{-v,--python-minor-version}'[Python 3 minor version for parsing files]:version:' \
  '*:infile:_files' && ret=0

return ret
