#compdef bioctl
# _bioctl — OpenBSD bioctl (manage RAID controllers via bio(4); -c creates a RAID volume of given level, -l lists chunks, -k keydisk, -p passfile, -r KDF rounds, -R replaces, -O sets offline, -H/-u hot-spare/unfailed, channel:target.lun targets disks)
# upstream: https://github.com/openbsd/src (sbin/bioctl)
# Flags from sbin/bioctl/bioctl.8 on tip.

_bioctl() {
    _arguments \
        '-d[detach]' \
        '-h[human-readable sizes]' \
        '-i[show device info]' \
        '-P[change passphrase]' \
        '-q[quiet]' \
        '-s[show key material]' \
        '-v[verbose]' \
        '-a+[alarm function]:alarm:(disable enable silence test)' \
        '-b+[channel:target.lun blink]:target:' \
        '-C+[creation flags]:flags:(force noauto cache)' \
        '-c+[RAID level]:level:(0 1 1C 4 5 6 C P RAID)' \
        '-H+[hot-spare]:target:' \
        '-k+[keydisk path]:file:_files' \
        '-l+[chunks list]:chunks:' \
        '-O+[offline target]:target:' \
        '-p+[passphrase file]:file:_files' \
        '-R+[replace chunk/target]:target:' \
        '-r+[KDF rounds]:rounds:' \
        '-t+[patrol function]:patrol:(disable enable auto manual)' \
        '-u+[unfail target]:target:' \
        '1:device:_files'
}

_bioctl "$@"
