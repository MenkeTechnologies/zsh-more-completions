#compdef agent-ctl kata-agent-ctl
# _agent-ctl — Kata Containers low-level Kata-agent test tool (clap CLI; speaks the agent ttRPC API directly)
# upstream: https://github.com/kata-containers/kata-containers
# Subcommands + flags from src/tools/agent-ctl/src/main.rs on tip.

_agent-ctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-l --log-level)'{-l,--log-level}'=[log level]:level:(trace debug info warn error critical)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                connect:'connect to an agent and issue API calls'
                'generate-cid':'generate a random container ID'
                'generate-sid':'generate a random sandbox ID'
                examples:'print canned EXAMPLES'
            )
            _describe -t commands 'agent-ctl subcommand' subs
            ;;
        args)
            case $line[1] in
                connect)
                    _arguments \
                        '--server-address=[server URI (vsock://CID:PORT | unix:///path | unix://@/abstract | file:///cfg)]:uri:' \
                        '--hybrid-vsock[use the Firecracker-style hybrid VSOCK protocol]' \
                        '--vm=[boot a test VM and connect to its agent]:hypervisor:(qemu clh fc dragonball)' \
                        '*--cmd=[agent API command (use "list" to enumerate)]:cmd:' \
                        '--container-id=[container ID context]:id:' \
                        '--sandbox-id=[sandbox ID context]:id:' \
                        '--bundle-dir=[OCI bundle directory]:dir:_files -/' \
                        '--config-file=[OCI config file (file:///...)]:uri:' \
                        '--timeout=[per-API call timeout]:s:'
                    ;;
            esac
            ;;
    esac
}

_agent-ctl "$@"
