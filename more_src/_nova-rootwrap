#compdef nova-rootwrap
# Documentation: https://docs.openstack.org/nova/latest/cli/nova-rootwrap.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nova-rootwrap: privileged operations helper.
# Usage: nova-rootwrap CONFIG_FILE COMMAND
# Per upstream docs no other flags are accepted.

local curcontext="$curcontext" ret=1
_arguments -C \
  '1:config file:_files' \
  '*::command: _command_names -e' && ret=0
return ret
