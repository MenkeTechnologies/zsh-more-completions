#compdef wimdir
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-dir.1.html
# wimdir — list the files in a WIM image

local ret=1

_arguments -s -S \
  '--path=[list files under PATH instead of the root directory]:path' \
  '--detailed[list detailed information about each file]' \
  '--one-file-only[list information about the specified file only]' \
  '--ref=[reference additional WIMs or split parts]:glob' \
  '*:WIM file:_files' && ret=0

return ret
