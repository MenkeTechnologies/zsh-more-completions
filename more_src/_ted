#compdef ted

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '--printRTF=+[print rtf to file]:file:_files -g "*.rtf"' \
  '--printPS=+[print ps to file]:file:_files -g "*.ps"' \
  '--printPDF=+[print pdf]:file:_files -g "*.pdf"' \
  '--printPlain=+[print plain text]:file:_files -g "*.txt"' \
  '--printAsHtml=+[print html]:file:_files -g "*.html"' \
  '--printExternal=+[external print]:cmd:' \
  '*:rtf file:_files -g "*.rtf"' && ret=0

return ret
