#compdef Ted ted
# Documentation: https://www.gsp.com/cgi-bin/man.cgi?section=1&topic=TED
# Reference accessed: 2026-05-21
# Verified: upstream Ted(1) man page.
# Removed from prior file: fabricated --printRTF, --printPS, --printPDF,
# --printPlain, --printAsHtml, --printExternal flags (none of these exist
# in upstream Ted; printing is done via --printToFile / --printToFilePaper
# / --printToPrinter / --printToPrinterPaper / --print / --printPaper).

local curcontext="$curcontext" ret=1

_arguments -C \
  '--version[print version]' \
  '--platform[print platform]' \
  '--build[print build info]' \
  '--fullVersion[print full version info]' \
  '--Find[find pattern in documents]:pattern:' \
  '--RegFind[regex find pattern in documents]:pattern:' \
  '--saveTo[convert between formats]:file:_files' \
  '--print[print to default printer]:file:_files -g "*.rtf"' \
  '--printPaper[print with paper size]:file:_files -g "*.rtf"' \
  '--printToPrinter[print to specific printer]:file:_files -g "*.rtf"' \
  '--printToPrinterPaper[print to printer with paper size]:file:_files -g "*.rtf"' \
  '--printToFile[convert to PostScript file]:file:_files -g "*.rtf"' \
  '--printToFilePaper[convert to PostScript with paper size]:file:_files -g "*.rtf"' \
  '--TtfToAfm[convert TrueType to AFM]:ttf:_files -g "*.ttf"' \
  '--AfmForFontFiles[generate AFM files for fonts]:fonts:_files -g "*.ttf"' \
  '--FontsDocuments[set fonts documents dir]:dir:_directories' \
  '--GSFontmapForFiles[Ghostscript Fontmap for files]:files:_files' \
  '--setProperty[set property name to value]:property:' \
  '*:rtf file:_files -g "*.rtf"' && ret=0

return ret
