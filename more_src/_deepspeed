#compdef deepspeed

# Zsh completion for Microsoft DeepSpeed

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--num_nodes=[number of nodes]:num' \
  '--num_gpus=[number of GPUs per node]:num' \
  '--hostfile=[path to hostfile]:hostfile:_files' \
  '--master_addr=[master node address]:address' \
  '--master_port=[master node port]:port' \
  '--include=[comma-separated list of devices to include]:devices' \
  '--exclude=[comma-separated list of devices to exclude]:devices' \
  '--no_ssh[do not use SSH for launching]' \
  '--no_ssh_check[do not check SSH connectivity]' \
  '--no_local_cuda[do not check local CUDA]' \
  '--launcher=[launcher to use]:launcher:(pdsh openmpi mvapich slurm)' \
  '--launcher_args=[extra arguments for launcher]:args' \
  '--force_multi[force multi-node launcher]' \
  '--save_pid[save process ID to file]' \
  '--enable_each_rank_log=[enable per-rank logging]:log_dir:_directories' \
  '--autotuning=[run autotuning]:mode:(tune run)' \
  '--bind_cores_to_rank[bind CPU cores to rank]' \
  '--bind_core_list=[list of cores to bind]:core_list' \
  '--ssh_port=[SSH port]:port' \
  '--deepspeed_config=[DeepSpeed config file]:config:_files -g "*.json"' \
  '--module[treat script as a Python module]' \
  '--no_python[do not use Python to launch script]' \
  '*:training script:_files -g "*.py"' && ret=0

return ret
