#compdef deepspeed
# Documentation: https://github.com/microsoft/DeepSpeed/blob/master/deepspeed/launcher/runner.py
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for Microsoft DeepSpeed launcher

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-H --hostfile)'{-H,--hostfile}'=[path to hostfile]:hostfile:_files' \
  '(-i --include)'{-i,--include}'=[hardware resources to include]:resources' \
  '(-e --exclude)'{-e,--exclude}'=[hardware resources to exclude]:resources' \
  '--num_nodes=[total number of worker nodes]:num' \
  '--num_gpus=[max GPUs per node]:num' \
  '--num_accelerators=[max accelerators per node]:num' \
  '--min_elastic_nodes=[minimum nodes for elastic training]:num' \
  '--max_elastic_nodes=[maximum nodes for elastic training]:num' \
  '--master_addr=[IP of node 0]:address' \
  '--master_port=[PyTorch distributed comm port]:port' \
  '--node_rank=[node ID in range [0:N)]:n' \
  '--ssh_port=[SSH port]:port' \
  '--no_ssh[launch without SSH setup]' \
  '--no_ssh_check[skip SSH validation]' \
  '--force_multi[force multi-node launcher]' \
  '--launcher=[backend launcher]:launcher:(pdsh openmpi mvapich slurm mpich impi)' \
  '--launcher_args=[extra arguments for launcher]:args' \
  '--module[treat script as a Python module]' \
  '--no_python[execute directly without python prefix]' \
  '--no_local_rank[do not pass local_rank arg]' \
  '--bind_cores_to_rank[bind ranks to specific cores]' \
  '--bind_core_list=[comma-separated cores to bind]:core_list' \
  '--venv_script=[virtual environment activation script]:file:_files' \
  '--save_pid[save launcher PID]' \
  '--enable_each_rank_log=[enable per-rank logging]:log_dir:_directories' \
  '--autotuning=[run autotuner]:mode:(tune run)' \
  '--elastic_training[enable elastic training]' \
  '--log_level=[runner log level]:level:(debug info warning error critical)' \
  '(-q --quiet)'{-q,--quiet}'[minimize output]' \
  '*:training script:_files -g "*.py"' && ret=0

return ret
