#compdef dblatex

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --backend)'{-b,--backend}'+[output backend]:backend:(pdftex dvips xetex luatex)' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-D --dump)'{-D,--dump}'[dump XML and stop]' \
  '(-e --encoding)'{-e,--encoding}'+[input encoding]:enc:' \
  '(-f --fig-format)'{-f,--fig-format}'+[figure format]:fmt:(eps pdf png svg)' \
  '(-i --texinputs)'{-i,--texinputs}'+[extra TEXINPUTS dir]:dir:_files -/' \
  '(-I --fig-path)'{-I,--fig-path}'+[figure search path]:path:_files -/' \
  '(-l --tex-path)'{-l,--tex-path}'+[TEX search path]:path:_files -/' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '(-p --xsl-user)'{-p,--xsl-user}'+[user XSL]:file:_files' \
  '(-P --param)'{-P,--param}'+[XSL parameter]:param:' \
  '(-r --xslt)'{-r,--xslt}'+[XSLT processor]:engine:(xsltproc 4xslt saxon)' \
  '(-s --texstyle)'{-s,--texstyle}'+[LaTeX style]:style:' \
  '(-t --type)'{-t,--type}'+[output type]:type:(pdf dvi ps tex)' \
  '(-T --doc-type)'{-T,--doc-type}'+[input doc type]:type:(db4 db5)' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-x --xslt-opts)'{-x,--xslt-opts}'+[extra XSLT options]:opts:' \
  '*:file:_files -g "*.xml"' && ret=0

return ret
