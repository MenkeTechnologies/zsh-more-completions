#compdef llvm-bitcode-strip
# _llvm-bitcode-strip — LLVM Mach-O bitcode stripper (LLVM project, C++); remove embedded LLVM bitcode from Mach-O binaries
# upstream: https://github.com/llvm/llvm-project

_llvm-bitcode-strip() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-h[show help]' \
        '-r[strip bitcode (default)]' \
        '-m[print Mach-O headers]' \
        '-q[quiet]' \
        '-v[verbose]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-arch+[arch]:arch:' \
        '*:file:_files'
}

_llvm-bitcode-strip "$@"
