#compdef cgenff
# Documentation: https://docs.silcsbio.com/2024.2/cgenff/usage.html
# CGenFF - assign CHARMM General Force Field atom types, charges and parameters

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help message and exit]' \
  '--version[display version and licensing information and exit]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all non-fatal warnings]' \
  '(-v --verbose)'{-v,--verbose}'[display more warning messages]' \
  '(-f --output-file)'{-f,--output-file}'[output destination]:output file:_files' \
  '(-m --message-file)'{-m,--message-file}'[where to write warning/error/debug messages]:message file:_files' \
  '(-a --all-parameters)'{-a,--all-parameters}'[copy existing parameters to the output]' \
  '(-i --input-format)'{-i,--input-format}'[input molecule format]:format:(mol2)' \
  '(-w --output-mol)'{-w,--output-mol}'[output processed Mol2 file after assigning parameters]:mol2 file:_files' \
  '(-x --split-output)'{-x,--split-output}'[split output into separate .rtf and .prm files]' \
  '(-z --keep-mol2-charge)'{-z,--keep-mol2-charge}'[keep charge values from Mol2 file]' \
  '(-b --bond-order)'{-b,--bond-order}'[force bond-order assignment from connectivity]' \
  '(-e --force-exhaustive)'{-e,--force-exhaustive}'[force exhaustive algorithm for new parameters]' \
  '(-s --server)'{-s,--server}'[run in server mode]' \
  '(-p --parameter-file)'{-p,--parameter-file}'[read in parameter files]:parameter file:_files' \
  '(-l --short-lone-pair)'{-l,--short-lone-pair}'[put halogen lonepair particles closer to the atom]' \
  '*:mol2 file:_files -g "*.(mol2|MOL2)"' && ret=0

return ret
