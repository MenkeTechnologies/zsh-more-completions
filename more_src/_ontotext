#compdef ontotext
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/ontotext.html
# Get ontology term(s) original full text

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-oboterms=[OBO term filename, format or reference]:file:_files' \
  '-outfile=[output ontology term file]:file:_files' \
  '-subclasses[include all sub-class terms of matches]' \
  '-obsolete[include obsolete terms]' \
  '-iformat1=[input OBO format]:format:' \
  '-iquery1=[input query fields or ID list]:query:' \
  '-idbname1=[user-provided database name]:name:' \
  '-odirectory2=[output directory]:dir:_files -/' \
  '-oformat2=[ontology term output format]:format:' \
  '-auto[turn off prompts]' \
  '-stdout[write output to stdout]' \
  '-version[show version]' \
  '*:OBO term file:_files' && ret=0

return ret
