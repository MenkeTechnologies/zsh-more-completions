#compdef raco

local -a _raco_cmds

_raco_cmds=(
  'check:check source files for errors'
  'docs:search and view documentation'
  'exe:create an executable from a Racket program'
  'expand:macro-expand a module'
  'make:compile source to bytecode'
  'pkg:manage packages'
  'planet:manage PLaneT packages (deprecated)'
  'read:read and print S-expressions'
  'scribble:process Scribble documentation'
  'setup:setup collections and packages'
  'test:run tests'
  'distribute:prepare an executable distribution'
  'ctool:compile C/C++ extensions'
  'decompile:decompile bytecode'
  'demod:decompose a module'
  'link:manage collection links'
  'unlink:remove collection links'
  'profile:profile a program'
  'cover:run test coverage'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmds' \
  '*:: :->args'

case "$state" in
  cmds)
    _describe -t commands 'raco command' _raco_cmds
    ;;
  args)
    case $words[1] in
      pkg)
        local -a pkg_cmds
        pkg_cmds=(
          'install:install packages'
          'update:update packages'
          'remove:remove packages'
          'show:show installed packages'
          'config:view or modify package configuration'
          'catalog-show:show information from a package catalog'
          'catalog-copy:copy a package catalog'
          'create:create a package archive'
          'migrate:migrate packages from one version to another'
          'catalog-archive:archive packages from a catalog'
          'empty-trash:delete packages that have been removed'
        )
        _describe -t commands 'pkg subcommand' pkg_cmds
        ;;
      test)
        _arguments \
          '-l[interpret arguments as library paths]' \
          '-c[interpret arguments as collection paths]' \
          '-p[interpret arguments as package names]' \
          '-j[number of concurrent test processes]:count:' \
          '--drdr[enable DrDr output format]' \
          '-s[specify a submodule to run]:submodule:' \
          '--timeout[set test timeout in seconds]:seconds:' \
          '-q[quiet mode, suppress output]' \
          '-v[verbose mode]' \
          '--table[show results as a table]' \
          '*:files:_files -g "*.rkt"'
        ;;
      setup)
        _arguments \
          '-j[number of parallel jobs]:count:' \
          '-l[only set up specified collections]' \
          '--clean[perform a clean setup]' \
          '--doc-index[only rebuild documentation index]' \
          '--no-docs[skip documentation building]' \
          '--no-info-domain[skip info-domain cache update]' \
          '--no-launcher[skip launcher creation]' \
          '--no-pkg-deps[skip package dependency checks]' \
          '--no-post-install[skip post-install actions]' \
          '--no-user[skip user-specific setup]' \
          '--only[only setup specified items]' \
          '--tidy[remove unneeded compiled files]' \
          '-v[verbose mode]' \
          '*:collections:'
        ;;
      exe)
        _arguments \
          '-o[output file name]:output file:_files' \
          '(-v --vv)'{-v,--vv}'[verbose mode]' \
          '--gui[generate a GUI executable]' \
          '--embed-dlls[embed DLLs into the executable]' \
          '--config-path[configuration path]:path:_directories' \
          '--collects-path[collects path]:path:_directories' \
          '--collects-dest[collects destination]:path:_directories' \
          '--ico[Windows icon file]:icon file:_files -g "*.ico"' \
          '--icns[macOS icon file]:icon file:_files -g "*.icns"' \
          '--orig-exe[use the original executable]:exe file:_files' \
          '*:source file:_files -g "*.rkt"'
        ;;
      make)
        _arguments \
          '-j[number of parallel jobs]:count:' \
          '--no-deps[do not compile dependencies]' \
          '-v[verbose mode]' \
          '*:source files:_files -g "*.rkt"'
        ;;
      docs)
        _arguments '*:search query:'
        ;;
      scribble)
        _arguments \
          '--html[generate HTML output]' \
          '--htmls[generate multiple HTML files]' \
          '--latex[generate LaTeX output]' \
          '--pdf[generate PDF output]' \
          '--text[generate text output]' \
          '--markdown[generate Markdown output]' \
          '--dest[destination directory]:directory:_directories' \
          '--dest-name[destination file name]:name:' \
          '--prefix[prefix file]:file:_files' \
          '--style[style file]:file:_files' \
          '--redirect-main[redirect main doc URL]:url:' \
          '--redirect[redirect URL]:url:' \
          '--info-out[info output file]:file:_files' \
          '--quiet[suppress output]' \
          '++extra[add extra file]:file:_files' \
          '*:source files:_files -g "*.scrbl"'
        ;;
      distribute)
        _arguments \
          '1:destination directory:_directories' \
          '*:executables:_files'
        ;;
      *)
        _arguments '*:files:_files'
        ;;
    esac
    ;;
esac
