#compdef mraa-gpio
# _mraa-gpio — Intel mraa-gpio CLI command-line wrapper around Intel libmraa I/O abstraction library performing list version set get monitor set-direction set-edge with raw mode bypassing pin mapping across supported Intel Galileo Edison Joule MinnowBoard ARM SBC boards (Intel team, C); custom argparse
# upstream: https://github.com/intel-iot-devkit/mraa

_mraa-gpio() {
    local -a sub=(
        'list:list pins'
        'version:print versions'
        'set:set output pin'
        'setraw:raw set'
        'get:get input pin'
        'getraw:raw get'
        'monitor:monitor pin level changes'
        'monitorraw:raw monitor'
        'set-direction:set pin direction'
        'set-edge:set edge trigger'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mraa-gpio subcommand' sub ;;
        args)
            case $words[1] in
                set|setraw|get|getraw|monitor|monitorraw) _arguments '1:pin:' '*:value:' ;;
                set-direction) _arguments '1:pin:' '2:direction:(in out out-high out-low)' ;;
                set-edge) _arguments '1:pin:' '2:edge:(none rising falling both)' ;;
            esac
            ;;
    esac
}

_mraa-gpio "$@"
