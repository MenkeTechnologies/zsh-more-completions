#compdef monmaptool
# Documentation: https://docs.ceph.com/en/latest/man/8/monmaptool/
# Ceph monitor cluster map manipulation tool.

local ret=1

_arguments -s -S \
  '--print[print a plaintext dump of the map]' \
  '--feature-list=[list enabled and available features]:format:' \
  '--create[create a new monitor map with a new UUID]' \
  '--clobber[create a new map in place of an existing one]' \
  '--generate[generate a new monmap from config or command line]' \
  '--filter-initial-members[filter map by mon initial members setting]' \
  '--add=[add a monitor with the specified ip:port]:name:' \
  '--addv=[add a monitor with the specified version:ip:port]:name:' \
  '--rm=[remove the named monitor from the map]:name:' \
  '--fsid=[set the fsid to the given uuid]:uuid:' \
  '--feature-set=[enable a feature]:feature:' \
  '--feature-unset=[disable a feature]:feature:' \
  '--enable-all-features[enable all supported features]' \
  '--set-min-mon-release=[set the min_mon_release]:release:' \
  '*:mapfile:_files' && ret=0

return ret
