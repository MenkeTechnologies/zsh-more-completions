#compdef deb-systemd-invoke
# Documentation: https://manpages.debian.org/testing/init-system-helpers/deb-systemd-invoke.1p.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--user[operate on user systemd instance]' \
  '--no-dbus[skip D-Bus for daemon-reload/reexec]' \
  '1:action:(start stop restart reload try-restart reload-or-restart reload-or-try-restart status is-active is-failed is-enabled enable disable mask unmask preset daemon-reload daemon-reexec)' \
  '*::unit:_systemd_units' && ret=0

return ret
