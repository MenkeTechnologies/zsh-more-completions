#compdef xfs_metadump
# _xfs_metadump — xfsprogs xfs_metadump (dump XFS metadata (no user data) to an image so it can be reproduced/analyzed without disclosing file contents; -o obfuscate filenames + attr values, -g show progress, -w log warnings, -e stop on error, -m max extent size MiB, positional source device + output file)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Flags from xfsprogs db/metadump.c on tip.

_xfs_metadump() {
    _arguments \
        '-V[show version]' \
        '-a[obfuscate data blocks too]' \
        '-e[stop on error]' \
        '-g[show progress]' \
        '-m+[max extent MiB]:mb:' \
        '-o[obfuscate filenames and attrs]' \
        '-w[log warnings]' \
        '-l+[external log device]:device:_files -g "/dev/*"' \
        '-F[force read of mounted device]' \
        '1:source device:_files -g "/dev/*"' \
        '2:metadata image:_files'
}

_xfs_metadump "$@"
