#compdef fiddler
# Documentation: https://man.archlinux.org/search?q=fiddler
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--port=[listen port]:port' \
  '--log-level=[log level]:level:(verbose information warning error)' && return 0
