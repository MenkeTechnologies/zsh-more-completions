#compdef hetro
# Csound heterodyne analysis for the adsyn generator

local ret=1

_arguments -s -S \
  '-s+[override input sampling rate]:srate' \
  '-c+[channel to analyze]:channel' \
  '-b+[begin time in seconds]:begin' \
  '-d+[duration in seconds]:duration' \
  '-f+[estimated starting fundamental frequency]:begfreq' \
  '-h+[number of harmonic partials sought]:partials' \
  '-M+[maximum amplitude summed across tracks]:maxamp' \
  '-m+[amplitude threshold for dormant tracks]:minamp' \
  '-n+[initial number of analysis breakpoints]:brkpts' \
  '-l+[low-pass Butterworth cutoff frequency]:cutfreq' \
  '*:soundfile:_files' && ret=0

return ret
