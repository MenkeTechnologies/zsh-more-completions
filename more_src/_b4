#compdef b4

# Zsh completion for b4 - helper for kernel patch-based workflows

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'mbox:download a thread as an mbox file'
  'am:create an mbox file ready for git-am'
  'shazam:apply patches directly to current tree'
  'pr:work with pull requests'
  'ty:create and send thank-you messages'
  'diff:show range-diff of two patch series'
  'kr:keyring operations'
  'prep:prepare patch series for submission'
  'send:send prepared patch series'
  'trailers:retrieve and apply trailers'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '--no-stdin[do not read from stdin]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'b4 subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (mbox|am|shazam)
        _arguments \
          '(-o --outdir)'{-o,--outdir}'[output directory]:directory:_files -/' \
          '(-m --use-hierarchical-matching)'{-m,--use-hierarchical-matching}'[use hierarchical matching]' \
          '-M[do not add link trailer]' \
          '-c[check newer versions]' \
          '-C[force reroll check]' \
          '(-n --mbox-name)'{-n,--mbox-name}'[output mbox name]:name:' \
          '(-p --use-project)'{-p,--use-project}'[use this project]:project:' \
          '(-g --guess-base)'{-g,--guess-base}'[try to guess the base of the series]' \
          '--guess-branch[branch to use for guessing base]:branch:' \
          '--cc-trailers[copy all cc trailers]' \
          '--no-cover[do not save cover letter]' \
          '--no-partial-reroll[do not process partial rerolls]' \
          '--sloppy-trailers[apply trailers without matching email]' \
          '-t[apply thread trailers]' \
          '-S[check for DKIM signatures]' \
          '-T[do not add trailers]' \
          '-l[add a link to lore.kernel.org]' \
          '-P[only check DKIM on patches]' \
          '-3[prepare for git-am 3-way merge]' \
          '1:message-id or URL:' && ret=0
        ;;
      (pr)
        _arguments \
          '(-o --outdir)'{-o,--outdir}'[output directory]:directory:_files -/' \
          '(-b --branch)'{-b,--branch}'[branch name]:branch:' \
          '1:message-id or URL:' && ret=0
        ;;
      (ty)
        _arguments \
          '(-o --outdir)'{-o,--outdir}'[output directory]:directory:_files -/' \
          '--gitdir[git directory]:directory:_files -/' \
          '(-a --auto)'{-a,--auto}'[auto-detect thank-you candidates]' \
          '(-b --branch)'{-b,--branch}'[branch to analyze]:branch:' \
          '(-s --send)'{-s,--send}'[send thank-you letters]' \
          '--since[only look at commits since]:date:' \
          '(-d --discard)'{-d,--discard}'[discard a thank-you letter]' \
          '-l[list pending thank-you letters]' && ret=0
        ;;
      (diff)
        _arguments \
          '(-o --outdir)'{-o,--outdir}'[output directory]:directory:_files -/' \
          '(-c --compare-to)'{-c,--compare-to}'[compare to this version]:version:' \
          '-g[guess the base of the series]' \
          '1:message-id or URL:' && ret=0
        ;;
      (prep)
        _arguments \
          '(-c --cover-letter)'{-c,--cover-letter}'[edit cover letter]' \
          '(-e --edit-cover)'{-e,--edit-cover}'[edit cover letter]' \
          '(-n --fork-point)'{-n,--fork-point}'[fork point]:commit:' \
          '--enroll-base[base branch]:branch:' \
          '--force-revision[force revision number]:number:' \
          '--set-prefixes[set subject prefixes]:prefixes:' \
          '--compare-to[compare against version]:version:' \
          '--manual-reroll[specify reroll version]:version:' \
          '--show-info[show series info]' \
          '--cleanup[clean up tracking data]' && ret=0
        ;;
      (send)
        _arguments \
          '-o[output to a directory]:directory:_files -/' \
          '--reflect[send to yourself first]' \
          '--no-sign[do not sign patches]' \
          '--resend[resend previously sent series]' && ret=0
        ;;
    esac
    ;;
esac

return ret
