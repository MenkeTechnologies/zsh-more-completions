#compdef subread-align subread-buildindex subjunc exactSNP sublong
# Documentation: upstream Subread package man pages at
# manpages.debian.org/bookworm/subread/
# Reference accessed: 2026-05-30 via WebFetch of
# {subread-align,subread-buildindex,subjunc,exactSNP,sublong}.1.en.html.
# Subread suite R102 — 5-stem multi-binary harvest covering the
# Subread read alignment/SNP/index toolkit. Existing coverage:
# featureCounts (`more_src/_featureCounts`). Subread-align and
# subjunc share substantial flag patterns since subjunc is a junc-
# tion-aware extension of subread-align.

local -a _shared_align_flags _orientations
_orientations=( ff fr rf )

# Shared between subread-align and subjunc (both aligners).
_shared_align_flags=(
  '-i+[base name of the index (required)]:index basename:'
  '-r+[input read file (FASTQ/FA, optionally gzipped)]:file:_files'
  '-o+[output file (BAM default)]:file:_files'
  '-R+[second read file (paired-end)]:file:_files'
  '--SAMinput[reads are in SAM format]'
  '--BAMinput[reads are in BAM format]'
  '--SAMoutput[write SAM instead of BAM]'
  '-P+[Phred offset]:offset:(3 6)'
  '-n+[number of subreads (default 10 for align, 14 for subjunc)]:N:'
  '-m+[consensus threshold for anchor read]:N:'
  '-p+[consensus threshold for non-anchor read]:N:'
  '-M+[max mismatches allowed (default 3)]:N:'
  '--multiMapping[report multi-mapping reads]'
  '-B+[max equally-best alignments to report (default 1)]:N:'
  '-I+[max indel length in bp (default 5)]:N:'
  '--complexIndels[detect proximal short indels]'
  '--trim5=[bases to trim from 5'\'' end]:N:'
  '--trim3=[bases to trim from 3'\'' end]:N:'
  '-d+[minimum fragment length (default 50)]:bp:'
  '-D+[maximum fragment length (default 600)]:bp:'
  '-S+[paired-end read orientation]:orientation:($_orientations)'
  '-T+[number of CPU threads (default 1)]:N:'
  '--rg-id=[read group ID]:id:'
  '--rg=[read group tag\:value pair]:tag\:value:'
  '--keepReadOrder[preserve input read order in output]'
  '--sortReadsByCoordinates[location-sorted BAM with BAI index]'
  '-b[convert color-space to base-space reads]'
  '-a+[annotation file (GTF/GFF/SAF)]:file:_files -g "*.(gtf|gff|gff3|saf)"'
  '-F+[annotation format]:format:(GTF SAF)'
  '-A+[chromosome alias file]:file:_files'
  '--gtfFeature=[GTF feature type (default exon)]:type:'
  '--gtfAttr=[GTF attribute type (default gene_id)]:attr:'
  '(- *)-v[show version]'
)

case $service in

  subread-align)
    # Main Subread aligner — for both RNA-seq and DNA-seq data.
    _arguments -s -S \
      $_shared_align_flags \
      '-t+[data type (0=RNA-seq, 1=genomic DNA-seq)]:type:(0 1)' \
      '--DPGapOpen=[gap-opening penalty (default -1)]:value:' \
      '--DPGapExt=[gap-extension penalty (default 0)]:value:' \
      '--DPMismatch=[mismatch penalty (default 0)]:value:' \
      '--DPMatch=[match score (default 2)]:value:' \
      '--sv[detect structural variants]'
    ;;

  subjunc)
    # Junction-aware variant of subread-align for RNA-seq with
    # exon-exon junction + fusion detection.
    _arguments -s -S \
      $_shared_align_flags \
      '--allJunctions[detect exon-exon junctions and fusions]'
    ;;

  subread-buildindex)
    # Build a Subread index from FASTA reference sequences.
    _arguments -s -S \
      '-o+[base name of the index (required)]:basename:' \
      '-F[build a full index (16bp subreads from every position)]' \
      '-B[create one block of index for max mapping speed]' \
      '-M+[memory size in megabytes (default 8000)]:MB:' \
      '-f+[threshold for removing uninformative subreads (default 100)]:N:' \
      '-c[build a color-space index]' \
      '(- *)-v[show version]' \
      '*:reference FASTA:_files -g "*.(fa|fasta|fna)"'
    ;;

  exactSNP)
    # Discover SNPs from read-mapping results (SAM/BAM input;
    # writes VCF).
    _arguments -s -S \
      '-i+[input alignment file (SAM/BAM)]:file:_files -g "*.(sam|bam)"' \
      '-g+[reference genome FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
      '-o+[output VCF file]:file:_files' \
      '-a+[annotated SNPs (VCF) for improved calling]:file:_files -g "*.vcf"' \
      '-b[input is in BAM format]' \
      '-Q+[Q-value cutoff for SNP calling (default 12)]:N:' \
      '-f+[minimum fraction of mismatched bases (0-1)]:f:' \
      '-n+[minimum number of mismatched bases (default 1)]:N:' \
      '-r+[minimum coverage (default 1)]:N:' \
      '-x+[max read depth (default 1000000)]:N:' \
      '-s+[minimum base quality (default 13)]:Phred:' \
      '-t+[bases trimmed from read ends (default 3)]:N:' \
      '-T+[number of threads (default 1)]:N:' \
      '-C+[directory for temporary files]:dir:_directories' \
      '(- *)-v[show version]'
    ;;

  sublong)
    # Long-read aligner for Nanopore/PacBio sequences. Index must
    # be a full index built with a single block (-F -B options to
    # subread-buildindex).
    _arguments -s -S \
      '-i+[base name of the index (full + single-block index)]:index basename:' \
      '-r+[input read file (FASTQ, optionally gzipped)]:file:_files' \
      '-o+[output file (BAM)]:file:_files' \
      '--SAMoutput[save results in SAM format]' \
      '-T+[CPU thread count (default 1)]:N:' \
      '-X[enable RNA-seq mode]' \
      '(- *)-v[show version]'
    ;;

esac
