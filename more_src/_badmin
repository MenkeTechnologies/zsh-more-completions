#compdef badmin

# badmin: LSF batch system administration
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '*:action:(ckconfig hclose hopen hghadd hghdel hghmod hist hstartup hshutdown hrestart mbdrestart mbdshutdown reconfig qact qclose qopen qhist qinact diagnose perfmon showstatus show)' && ret=0
return ret
