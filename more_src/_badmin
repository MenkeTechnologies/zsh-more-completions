#compdef badmin
# Documentation: https://www.ibm.com/docs/en/spectrum-lsf/10.1.0?topic=reference-badmin
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# badmin: LSF batch system administration
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '*:action:(ckconfig hclose hopen hghadd hghdel hghmod hist hstartup hshutdown hrestart mbdrestart mbdshutdown reconfig qact qclose qopen qhist qinact diagnose perfmon showstatus show)' && ret=0
return ret
