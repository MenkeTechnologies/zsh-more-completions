#compdef prototool
# Documentation: https://man.archlinux.org/search?q=prototool
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands break_subs config_subs

subcommands=(
  'compile:compile protos'
  'generate:generate code (alias gen)'
  'gen:generate code'
  'lint:lint protos'
  'format:format protos'
  'create:create new proto'
  'files:list proto files'
  'descriptor-set:write FileDescriptorSet'
  'break:check breaking changes'
  'grpc:invoke gRPC method'
  'config:config commands'
  'version:print version'
)

break_subs=('check:detect breaking changes' 'descriptor-set:write descriptor set')

config_subs=('init:initialize config')

_arguments -C \
  '--cache-path=[cache path]:dir:_files -/' \
  '--config-data=[inline config]:json:' \
  '--debug[debug]' \
  '--disable-format[disable format check]' \
  '--disable-lint[disable lint]' \
  '*--excludes=[exclude path]:path:' \
  '--fail-on-warnings[fail on warnings]' \
  '--json[JSON output]' \
  '--print-fields=[fields to print]:fields:' \
  '--dry-run[dry run]' \
  '-o=[output dir]:dir:_files -/' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'prototool subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (break)
        _describe -t break_subs 'break action' break_subs && ret=0
        ;;
      (config)
        _describe -t config_subs 'config action' config_subs && ret=0
        ;;
    esac
    ;;
esac

return ret
