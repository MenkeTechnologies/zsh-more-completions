#compdef qrun
# Documentation: https://docs.adaptivecomputing.com/torque/4-0-2/Content/topics/commands/qrun.htm
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-H)-a[run the job asynchronously]' \
  '(-a)-H+[host on which to run the job]:host:_hosts' \
  '*:job_id:' && ret=0

return ret
