#compdef sdf2fps
# Documentation: https://chemfp.readthedocs.io/en/latest/tools.html
# chemfp tool to extract fingerprints from SD files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--pubchem[extract PubChem/CACTVS fingerprints from SD tags]' \
  '--id-tag=[SD data field containing record identifier]:tag:' \
  '-o+[output file]:file:_files' \
  '--no-progress[disable progress bar display]' \
  '*:SD file:_files' && ret=0

return ret
