#compdef biomejs
# Documentation: https://biomejs.dev/reference/cli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# biomejs is an alternate name sometimes used for the biome binary —
# delegate to the _biome completion when available.

if (( $+functions[_biome] )); then
  _biome "$@"
else
  _message 'biome CLI (see _biome for completions)'
fi
