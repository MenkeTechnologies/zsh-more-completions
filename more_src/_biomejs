#compdef biome

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--colors=[color mode]:mode:(off force)' \
  '--use-server[use running daemon]' \
  '--log-level=[log level]:level:(none debug info warn error)' \
  '--log-kind=[log kind]:kind:(compact pretty)' \
  '--config-path=[path to config file]:path:_files' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:run checks on files'
      'lint:run linter on files'
      'format:format files'
      'ci:run checks for CI'
      'init:initialize Biome config'
      'lsp-proxy:start LSP proxy'
      'migrate:migrate configuration'
      'search:search for patterns'
      'rage:print diagnostic information'
      'start:start the daemon'
      'stop:stop the daemon'
      'explain:explain a rule'
    )
    _describe -t commands 'biome command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      check|lint|format|ci)
        _arguments -s -S \
          '--apply[apply safe fixes]' \
          '--apply-unsafe[apply all fixes including unsafe]' \
          '--changed[only process changed files]' \
          '--since=[base branch for changed files]:branch' \
          '--staged[only process staged files]' \
          '--no-errors-on-unmatched[do not error on unmatched files]' \
          '--error-on-warnings[error if warnings are found]' \
          '--write[write changes to files]' \
          '--fix[synonym for --write]' \
          '--reporter=[reporter format]:format:(summary json json-pretty github junit)' \
          '--max-diagnostics=[max diagnostics to show]:count' \
          '--stdin-file-path=[path for stdin input]:path:_files' \
          '*:file:_files' && ret=0
        ;;
      init)
        _arguments -s -S \
          '--jsonc[use JSONC format for config]' && ret=0
        ;;
    esac
    ;;
esac

return ret
