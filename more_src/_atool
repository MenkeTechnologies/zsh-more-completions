#compdef atool aunpack apack als acat adiff arepack

# Zsh completion for atool (archive manager wrapper)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-l[list contents of archive]' \
  '-x[extract archive]' \
  '-a[create archive]' \
  '-c[display file from archive on stdout]' \
  '-d[show differences between archives]' \
  '-r[repack archive to different format]' \
  '-q[decrease verbosity]' \
  '-v[increase verbosity]' \
  '-f[force overwrite of local files]' \
  '-F+[specify archive format]:format:(tar tar.gz tar.bz2 tar.lz tar.xz tar.zst zip 7z rar lha cpio arj arc)' \
  '-D[extract to subdirectory]' \
  '-e[do not extract into subdirectory]' \
  '-E+[specify default behavior for extracting]:default:(never always auto)' \
  '-X+[exclude pattern]:pattern' \
  '-p+[path to extract to]:directory:_directories' \
  '-o+[additional option for compressor]:option' \
  '-S[simulate, show commands without executing]' \
  '--save-outdir=[save output directory name to file]:file:_files' \
  '--each[extract each archive to separate directory]' \
  '--subdir[always extract to subdirectory]' \
  '*:archive:_files -g "*.{tar,tar.gz,tgz,tar.bz2,tbz2,tar.xz,txz,tar.zst,zip,7z,rar,lha,lzh,cpio,arj,arc,gz,bz2,xz,zst,lz,Z,rpm,deb}"' && ret=0

return ret
