#compdef llvm-cat
# _llvm-cat — LLVM bitcode concatenator (LLVM project, C++); concatenate LLVM bitcode files
# upstream: https://github.com/llvm/llvm-project

_llvm-cat() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '-b[binary cat]' \
        '*:file:_files -g "*.bc"'
}

_llvm-cat "$@"
