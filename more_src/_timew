#compdef timew

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'cancel:cancel active time tracking'
      'continue:resume tracking of closed interval'
      'day:show day chart'
      'delete:delete an interval'
      'diagnostics:show diagnostic information'
      'export:export tracked time as JSON'
      'extensions:list available extensions'
      'gaps:display gaps in tracked time'
      'get:get configuration value'
      'help:display help'
      'join:join two intervals'
      'lengthen:lengthen an interval'
      'modify:change start/end of an interval'
      'month:show month chart'
      'move:change start of an interval'
      'report:run an extension report'
      'resize:set interval duration'
      'shorten:shorten an interval'
      'show:show configuration'
      'split:split an interval'
      'start:start time tracking'
      'stop:stop time tracking'
      'summary:display time tracking summary'
      'tag:add tag to interval'
      'tags:display list of tags'
      'track:add completed time tracking'
      'undo:undo last command'
      'untag:remove tag from interval'
      'week:show week chart'
    )
    _describe -t commands 'timew command' commands && ret=0
    ;;
  args)
    case $line[1] in
      start|stop|continue|track|tag|untag)
        _arguments '*:tag' && ret=0
        ;;
      summary|day|week|month|export|gaps)
        _arguments \
          ':range or tag' \
          '--ids[show interval IDs]' && ret=0
        ;;
      delete|join|lengthen|modify|move|shorten|split|resize)
        _arguments \
          ':interval ID (@number)' && ret=0
        ;;
      get)
        _arguments '1:configuration key' && ret=0
        ;;
      report)
        _arguments '1:report name' && ret=0
        ;;
      help)
        _arguments '1:command:($commands)' && ret=0
        ;;
    esac
    ;;
esac

return ret
