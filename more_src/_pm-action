#compdef pm-action

# pm-action: pm-utils helper to invoke suspend/hibernate scripts
local curcontext="$curcontext" ret=1
_arguments -C \
  '--quirks[quirks string]:quirks:' \
  '--store-quirks-as-lkw[store quirks for late-kernel-warning]' \
  '--log-file[log file]:file:_files' \
  '*:action and args:(hibernate suspend suspend-hybrid)' && ret=0
return ret
