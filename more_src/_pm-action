#compdef pm-action
# Documentation: https://man.archlinux.org/search?q=pm-action
# Reference accessed: 2026-05-16

# pm-action: pm-utils helper to invoke suspend/hibernate/etc.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--quirk-dpms-on[apply quirk dpms-on]' \
  '--quirk-dpms-suspend[apply quirk dpms-suspend]' \
  '--quirk-radeon-off[apply quirk radeon-off]' \
  '--quirk-reset-brightness[apply quirk reset-brightness]' \
  '--quirk-s3-bios[apply quirk s3-bios]' \
  '--quirk-s3-mode[apply quirk s3-mode]' \
  '--quirk-save-pci[apply quirk save-pci]' \
  '--quirk-vbe-post[apply quirk vbe-post]' \
  '--quirk-vbemode-restore[apply quirk vbemode-restore]' \
  '--quirk-vbestate-restore[apply quirk vbestate-restore]' \
  '--quirk-vga-mode-3[apply quirk vga-mode-3]' \
  '--store-quirks-as-lkw[remember quirks for laptop]' \
  '--no-quirks[disable all quirks]' \
  '1:action:(suspend hibernate suspend-hybrid powersave-on powersave-off true)' \
  '*::pm-action args:_files' && ret=0
return ret
