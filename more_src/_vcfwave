#compdef vcfwave
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfwave.md
# vcflib: decompose complex variants into primitives using BiWFA alignment

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --wf-params)'{-p,--wf-params}'[use the given BiWFA params (match,mismatch,gap1-open,gap1-ext,gap2-open,gap2-ext)]:params' \
  '(-f --tag-parsed)'{-f,--tag-parsed}'[annotate decomposed records with source record position (default ORIGIN)]:flag' \
  '(-L --max-length)'{-L,--max-length}'[do not manipulate records longer than LEN]:len' \
  '(-K --inv-kmer)'{-K,--inv-kmer}'[k-mer length for inversion detection sketching (default 17)]:K' \
  '(-I --inv-min)'{-I,--inv-min}'[minimum allele length for inverted alignment (default 64)]:len' \
  '(-t --threads)'{-t,--threads}'[use this many threads for variant decomposition]:N' \
  '--quiet[do not display progress bar]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '*:vcf file:_files' && ret=0

return ret
