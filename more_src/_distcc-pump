#compdef distcc-pump
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/distcc-pump.1.html
# distcc-pump - accelerate remote compilation with distcc pump mode

local ret=1

_arguments -s -S \
  '(- *)--help[display summary instructions]' \
  '(- *)--startup[start an include server and print env var settings]' \
  '(- *)--shutdown[shut down an include server started with --startup]' \
  '*::build command:_command_names -e' && ret=0

return ret
