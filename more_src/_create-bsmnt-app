#compdef create-bsmnt-app
# Documentation: https://www.npmjs.com/package/create-bsmnt-app
# Reference accessed: 2026-05-24
# Verified: npm view create-bsmnt-app bin; npx create-bsmnt-app --help output.

# Zsh completion for create-bsmnt-app - Basement studio Next.js stack scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--no-git[skip git repository initialization]' \
  '--no-install[skip package manager install]' \
  '(-y --default)'{-y,--default}'[use all default bootstrap options]' \
  '--CI[run in CI mode with non-interactive defaults]' \
  '--tailwind=[install Tailwind CSS]:bool:(true false)' \
  '--creative-stack=[install 3D creative stack]:bool:(true false)' \
  '--basehub=[install BaseHub CMS integration]:bool:(true false)' \
  '(-i --import-alias)'{-i,--import-alias}'[use a custom import alias]' \
  '--app-router=[use Next.js App Router]:bool:(true false)' \
  '(-v --version)'{-v,--version}'[display version number]' \
  '(-h --help)'{-h,--help}'[display help]' \
  ':project directory:_directories' && ret=0

return ret
