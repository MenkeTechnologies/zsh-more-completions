#compdef notes
# Documentation: https://github.com/rhysd/notes-cli
# notes - small markdown note taking CLI (rhysd/notes-cli)

local ret=1
local line

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-A --always-color)'{-A,--always-color}'[force colored output]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'new:create a new note'
      'list:list notes'
      'ls:list notes'
      'categories:list all categories'
      'tags:list all tags'
      'save:commit and push notes to git'
      'config:show configuration'
      'selfupdate:update the executable'
    )
    _describe -t commands 'notes command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      list|ls)
        _arguments -s \
          '(-c --category)'{-c,--category}'=[filter by category]:category:' \
          '(-t --tag)'{-t,--tag}'=[filter by tag]:tag:' \
          '(-r --relative)'{-r,--relative}'[show relative paths]' \
          '(-o --oneline)'{-o,--oneline}'[one-line format per note]' \
          '(-f --full)'{-f,--full}'[display full note information]' \
          '(-s --sort)'{-s,--sort}'=[sort order]:sort:(created modified)' \
          '(-e --edit)'{-e,--edit}'[open notes with editor]' && ret=0
        ;;
      new)
        _arguments -s \
          '--no-inline-input[do not read note body from stdin]' \
          '*:category/filename/tags:' && ret=0
        ;;
      selfupdate)
        _arguments -s '--dry[check for updates without installing]' && ret=0
        ;;
    esac
    ;;
esac

return ret
