#compdef hgLoadWiggle
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: load a wiggle track definition into the database

local ret=1

_arguments -s -S \
  '-noBin[suppress bin field]' \
  '-noLoad[do not load table, only create .tab file]' \
  '-noHistory[do not add history table comments]' \
  '-oldTable[add to existing table]' \
  '-tab[separate by tabs rather than space]' \
  '-pathPrefix=[.wib file path prefix to use]:prefix' \
  '-chromInfoDb=[database to extract chromInfo size information]:db' \
  '-maxChromNameLength=[max chromName length to avoid chromInfo lookup]:n' \
  '-tmpDir=[directory for temporary .tab file]:dir:_files -/' \
  '-verbose=[verbosity level]:n' \
  '1:database:' \
  '2:track:' \
  '*:wig file:_files -g "*.wig"' && ret=0

return ret
