#compdef GNPSExport
# OpenMS TOPP: export MS/MS data to GNPS molecular networking format

local ret=1

_arguments -s -S \
  '-in_cm[input consensusXML file with peptide annotations]:file:_files' \
  '*-in_mzml[original mzML files with MS/MS spectra]:file:_files' \
  '-out[output MGF file]:output file:_files' \
  '-out_quantification[feature quantification table (TXT)]:file:_files' \
  '-out_pairs[supplementary pairs table (CSV)]:file:_files' \
  '-out_meta_values[metadata value file (TSV)]:file:_files' \
  '-output_type[specificity level]:type:(merged_spectra most_intense)' \
  '-peptide_cutoff[most intense peptides per consensus element]:n:' \
  '-ms2_bin_size[fragment ion bin size in Da]:value:' \
  '-merged_spectra:cos_similarity[cosine similarity threshold]:value:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
