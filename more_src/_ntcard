#compdef ntcard
# Documentation: https://github.com/bcgsc/ntCard
# ntCard: streaming algorithm for cardinality estimation of k-mers

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --threads)'{-t+,--threads=}'[number of parallel threads]:threads' \
  '(-k --kmer)'{-k+,--kmer=}'[k-mer length]:kmer' \
  '(-c --cov)'{-c+,--cov=}'[maximum k-mer coverage in output]:coverage' \
  '(-p --pref)'{-p+,--pref=}'[prefix for output file names]:prefix' \
  '(-o --output)'{-o+,--output=}'[single output file name]:file:_files' \
  '--version[show version]' \
  '*:input file:_files' && ret=0

return ret
