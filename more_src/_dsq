#compdef dsq
# Documentation: https://github.com/multiprocessio/dsq/blob/main/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-s --stdin)'{-s,--stdin}'[read from stdin with format]:format:(csv tsv json newline-delimited-json parquet)' \
  '(-p --pretty)'{-p,--pretty}'[pretty print output]' \
  '(-c --cache)'{-c,--cache}'[enable caching]' \
  '(-C --convert)'{-C,--convert}'[convert input to format]:format:(csv json parquet)' \
  '--schema[print schema of input files]' \
  '--no-input[run query without input files]' \
  '*:file:_files' && ret=0
return ret
