#compdef nrfutil

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'device:list/program/recover/erase/reset Nordic devices'
  'nrf5sdk-tools:legacy nRF5 SDK DFU and key management'
  'completion:generate shell completion'
  'install:install command modules'
  'upgrade:upgrade command modules'
  'list:list installed modules'
  'search:search modules'
  'self-upgrade:update nrfutil itself'
  'toolchain-manager:manage toolchains'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--json[JSON output]' \
  '--log-level=[log level]:level:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'nrfutil subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (device)
        _values 'device action' \
          'list' 'program' 'recover' 'erase' 'reset' 'read' \
          'x-provision-keys' 'x-provision-nrf5340-keys' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
