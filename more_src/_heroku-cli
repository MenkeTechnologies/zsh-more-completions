#compdef heroku-cli
# _heroku-cli — Salesforce Heroku PaaS CLI alias (heroku team, TypeScript); oclif
# upstream: https://github.com/heroku/cli

_heroku-cli() {
    local -a sub=(
        'access:manage app access'
        'access:add:add collaborator'
        'access:remove:remove collaborator'
        'access:update:update permissions'
        'addons:manage add-ons'
        'addons:attach:attach an existing add-on'
        'addons:create:create add-on'
        'addons:destroy:destroy add-on'
        'addons:detach:detach add-on'
        'addons:docs:open add-on docs'
        'addons:downgrade:downgrade add-on'
        'addons:info:show add-on info'
        'addons:list:list add-ons'
        'addons:open:open add-on dashboard'
        'addons:plans:list plans'
        'addons:rename:rename add-on'
        'addons:services:list add-on services'
        'addons:upgrade:upgrade add-on'
        'addons:wait:wait for add-on'
        'apps:manage apps'
        'apps:create:create app'
        'apps:destroy:destroy app'
        'apps:errors:show errors'
        'apps:favorites:list favorites'
        'apps:info:show app info'
        'apps:join:join app'
        'apps:leave:leave app'
        'apps:lock:lock app'
        'apps:open:open app in browser'
        'apps:permissions:show permissions'
        'apps:rename:rename app'
        'apps:stacks:list stacks'
        'apps:stacks:set:set stack'
        'apps:transfer:transfer app'
        'apps:unlock:unlock app'
        'auth:auth commands'
        'auth:login:login'
        'auth:logout:logout'
        'auth:token:print token'
        'auth:whoami:show user'
        'autocomplete:set up autocomplete'
        'buildpacks:manage buildpacks'
        'buildpacks:add:add buildpack'
        'buildpacks:clear:clear buildpacks'
        'buildpacks:info:show buildpack info'
        'buildpacks:install:install buildpack'
        'buildpacks:remove:remove buildpack'
        'buildpacks:search:search buildpacks'
        'buildpacks:set:set buildpack'
        'buildpacks:versions:list versions'
        'certs:cert commands'
        'certs:add:add cert'
        'certs:remove:remove cert'
        'certs:info:show cert info'
        'certs:auto:auto cert mgmt'
        'certs:auto:enable:enable auto certs'
        'certs:auto:disable:disable auto certs'
        'certs:auto:refresh:refresh auto certs'
        'certs:generate:generate cert'
        'certs:rollback:rollback cert'
        'ci:CI commands'
        'config:show config'
        'config:edit:edit config'
        'config:get:get config'
        'config:set:set config'
        'config:unset:unset config'
        'create:create app'
        'destroy:destroy app'
        'domains:list domains'
        'domains:add:add domain'
        'domains:remove:remove domain'
        'drains:list drains'
        'drains:add:add drain'
        'drains:remove:remove drain'
        'dyno:scale:scale dynos'
        'dyno:restart:restart dynos'
        'dyno:stop:stop dyno'
        'features:list features'
        'features:enable:enable feature'
        'features:disable:disable feature'
        'features:info:feature info'
        'fork:fork app'
        'git:remote:add heroku git remote'
        'git:clone:clone app via git'
        'help:show help'
        'keys:list ssh keys'
        'keys:add:add ssh key'
        'keys:remove:remove ssh key'
        'labs:list labs features'
        'local:run app locally'
        'local:start:start local app'
        'local:version:show foreman version'
        'login:login'
        'logout:logout'
        'logs:show logs'
        'maintenance:show maintenance status'
        'maintenance:on:enable maintenance'
        'maintenance:off:disable maintenance'
        'members:list members'
        'members:add:add member'
        'members:remove:remove member'
        'members:set:set member role'
        'notifications:list notifications'
        'open:open app in browser'
        'orgs:list teams'
        'pg:postgres commands'
        'pg:backups:list backups'
        'pg:backups:capture:capture backup'
        'pg:backups:restore:restore backup'
        'pg:credentials:credentials'
        'pg:info:postgres info'
        'pg:promote:promote db'
        'pg:psql:open psql'
        'pg:reset:reset db'
        'pg:wait:wait for pg'
        'pipelines:list pipelines'
        'pipelines:create:create pipeline'
        'pipelines:promote:promote app'
        'pipelines:destroy:destroy pipeline'
        'pipelines:rename:rename pipeline'
        'plugins:list plugins'
        'plugins:install:install plugin'
        'plugins:uninstall:uninstall plugin'
        'plugins:update:update plugins'
        'ps:show process info'
        'ps:exec:exec into dyno'
        'ps:type:set dyno type'
        'ps:scale:scale dynos'
        'ps:restart:restart dynos'
        'ps:stop:stop dyno'
        'ps:wait:wait for dyno'
        'redis:redis commands'
        'redis:cli:open redis cli'
        'redis:info:redis info'
        'redis:credentials:credentials'
        'redis:maxmemory:set maxmemory policy'
        'releases:show releases'
        'releases:rollback:rollback release'
        'releases:info:show release'
        'reviewapps:list:list review apps'
        'run:run command'
        'run:detached:run detached'
        'sessions:list sessions'
        'spaces:list spaces'
        'sso:open SSO panel'
        'status:check status'
        'teams:list teams'
        'update:update CLI'
        'version:show version'
        'webhooks:list webhooks'
        'webhooks:add:add webhook'
        'webhooks:remove:remove webhook'
        'whoami:show user'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--app=+[app]:str:' \
        '-a+[app]:str:' \
        '--remote=+[remote]:str:' \
        '-r+[remote]:str:' \
        '--team=+[team]:str:' \
        '-t+[team]:str:' \
        '--json[json output]' \
        '--confirm=+[confirm]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'heroku subcommand' sub ;;
        args)
            case $words[1] in
                autocomplete) _arguments '1:shell:(bash zsh)' ;;
                logs) _arguments \
                    '--num=+[lines]:n:' \
                    '-n+[lines]:n:' \
                    '--tail[tail]' \
                    '-t[tail]' \
                    '--dyno=+[dyno]:str:' \
                    '-d+[dyno]:str:' \
                    '--source=+[source]:str:' \
                    '-s+[source]:str:' \
                    '--ps=+[ps]:str:' \
                    '--force-colors[force colors]' ;;
            esac
            ;;
    esac
}

_heroku-cli "$@"
