#compdef impacket-nmapAnswerMachine

# Impacket nmapAnswerMachine.py: respond to Nmap probes (decoy machine)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-ip[interface IP]:ip:' \
  '-mac[interface MAC]:mac:' \
  '-iface[network interface]:iface:' \
  '*::nmapAnswerMachine args:_files' && ret=0
return ret
