#compdef ldns-compare-zones
# _ldns-compare-zones — NLnet Labs ldns-compare-zones (diff two zonefiles; reports inserted, deleted, changed, unchanged records)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-compare-zones.c usage on tip.

_ldns-compare-zones() {
    _arguments \
        '-h[show help]' \
        '-v[show version and exit]' \
        '-i[print inserted records]' \
        '-d[print deleted records]' \
        '-c[print changed records]' \
        '-u[print unchanged records]' \
        '-U[print unchanged records in changed names]' \
        '-a[print all differences (-i -d -c)]' \
        '-s[do not exclude SOA from comparison]' \
        '-Z[exclude ZONEMD records from comparison]' \
        '-z[do not sort zones before compare]' \
        '-e[exit status 2 on changed zones]' \
        '1:zonefile1:_files' \
        '2:zonefile2:_files'
}

_ldns-compare-zones "$@"
