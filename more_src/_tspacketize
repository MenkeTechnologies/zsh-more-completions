#compdef tspacketize
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tspacketize.cpp
# tspacketize - packetize PSI/SI sections into a transport stream PID

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--binary[treat all input files as binary]' \
  '(-b --bitrate)'{-b,--bitrate}'=[bitrate of the target PID in bits/second]:bitrate:' \
  '(-c --continuous)'{-c,--continuous}'[continuous packetization]' \
  '(-f --force-crc)'{-f,--force-crc}'[force recomputation of CRC32 in long sections]' \
  '(-j --json)'{-j,--json}'[treat all input files as JSON]' \
  '(-o --output)'{-o,--output}'=[output file name for TS packets]:file:_files' \
  '(-p --pid)'{-p,--pid}'=[PID of the output TS packets (required)]:pid:' \
  '(-s --stuffing)'{-s,--stuffing}'[insert stuffing at end of each section]' \
  '(-x --xml)'{-x,--xml}'[treat all input files as XML]' \
  '*:section file:_files -g "*.bin *.xml *.json"' && ret=0

return ret
