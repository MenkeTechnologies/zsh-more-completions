#compdef hpcrun hpcstruct hpcprof hpcprof-mpi hpcclient hpctoolkit hpcserver hpctraceviewer hpcviewer
# _hpctoolkit — Rice University HPCToolkit performance analysis suite for HPC applications hpcrun hpcstruct hpcprof (rice-hpctoolkit team, C++); getopt
# upstream: https://github.com/HPCToolkit/hpctoolkit

_hpctoolkit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '-V[show version]' \
        '--version[show version]' \
        '-e+[event]:str:' \
        '--event=+[event]:str:' \
        '-t[trace]' \
        '--trace[trace]' \
        '-l[list]' \
        '--list-events[list]' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '-r+[results dir]:dir:_files -/' \
        '--results=+[results dir]:dir:_files -/' \
        '-I+[include path]:dir:_files -/' \
        '--include=+[include path]:dir:_files -/' \
        '-c+[count]:n:' \
        '--count=+[count]:n:' \
        '-d+[delay sec]:n:' \
        '--delay=+[delay sec]:n:' \
        '-T+[threshold]:n:' \
        '--threshold=+[threshold]:n:' \
        '-S+[symbol]:str:' \
        '--symbol=+[symbol]:str:' \
        '-M+[measurement dir]:dir:_files -/' \
        '--measurement-dir=+[measurement dir]:dir:_files -/' \
        '-j+[threads]:n:' \
        '--jobs=+[threads]:n:' \
        '--metric-db=+[bool]:b:(yes no)' \
        '--no-trace[no trace]' \
        '--include-source=+[bool]:b:(yes no)' \
        '--name=+[binary name]:str:' \
        '--show=+[mode]:str:' \
        '--print-fail-info[print fail info]' \
        '--retain-recursion[retain recursion]' \
        '-y+[overlap]:n:' \
        '-x+[no-callstack]:n:' \
        '*:executable:_command_names'
}

_hpctoolkit "$@"
