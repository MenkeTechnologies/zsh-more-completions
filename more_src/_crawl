#compdef crawl
# Documentation: https://manpages.debian.org/bookworm/crawl/crawl.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm crawl(6) manpage SYNOPSIS (single-dash long flags).

# Dungeon Crawl Stone Soup: turn-based roguelike
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-name[character name]:name:' \
  '-species[character species]:species:' \
  '-background[character background]:background:' \
  '-plain[plain ASCII mode]' \
  '-dir[crawl install directory]:dir:_files -/' \
  '-rc[init file (.crawlrc)]:file:_files' \
  '-rcdir[directory for rc files]:dir:_files -/' \
  '-macro[macro file]:file:_files' \
  '-morgue[morgue file directory]:dir:_files -/' \
  '-scorefile[score file]:file:_files' \
  '-scores[show N high scores]:n:' \
  '-tscores[show N terse scores]:n:' \
  '-vscores[show N verbose scores]:n:' \
  '-seed[start with RNG seed]:num:' \
  '-script[run script]:file:_files' \
  '-sprint[start in Sprint mode]' \
  '-sprint-map[Sprint map]:map:' \
  '-arena[monsters vs monsters (arena:map)]:spec:' \
  '-test[run tests]' \
  '-builddb[build database]' \
  '-extra-opt-first[option to apply first]:optname=optval:' \
  '-extra-opt-last[option to apply last]:optname=optval:' \
  '*::extra args:_files' && ret=0
return ret
