#compdef phockup

# phockup — photo organizer by EXIF date (`phockup --help` IvanSanchez variant).

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-m,--move}'[move instead of copy]' \
  {-r,--rename}'[rename pattern]:pattern' \
  {-t,--timestamp}"=[prefer file mtime over EXIF]:bool" \
  '1:input directory:_files -/' \
  '2:output directory:_files -/' && ret=0

return ret
