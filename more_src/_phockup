#compdef phockup
# Documentation: https://github.com/ivandokov/phockup
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# phockup: media organizer by EXIF date.

local ret=1

_arguments -s -S \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --date)'{-d,--date=}'[output date format]:format:' \
  '--output-prefix=[output path prefix]:prefix:' \
  '--output-suffix=[output path suffix]:suffix:' \
  '--from-date=[process files newer than YYYY-MM-DD]:date:' \
  '--to-date=[process files older than YYYY-MM-DD]:date:' \
  '(-r --regex)'{-r,--regex=}'[regex to extract date from filename]:regex:' \
  '(-t --timestamp)'{-t,--timestamp}'[use mtime when EXIF date missing]' \
  '(-m --move)'{-m,--move}'[move instead of copy]' \
  '(-l --link)'{-l,--link}'[create hard links instead of copy]' \
  '(-o --original-names)'{-o,--original-names}'[keep original filenames]' \
  '--file-type=[restrict file type]:type:(image video)' \
  '(-f --date-field)'{-f,--date-field=}'[EXIF date field]:field:' \
  '(-y --dry-run)'{-y,--dry-run}'[show changes without executing]' \
  '--log=[log output file]:file:_files' \
  '--quiet[suppress output except errors]' \
  '--progress[show progress bar only]' \
  '--maxdepth=[limit directory traversal depth]:n:' \
  '--max-concurrency=[concurrent processing threads]:n:' \
  '1:input directory:_files -/' \
  '2:output directory:_files -/' && ret=0

return ret
