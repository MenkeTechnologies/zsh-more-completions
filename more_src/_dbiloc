#compdef dbiloc
# Documentation: https://emboss.bioinformatics.nl/cgi-bin/emboss/help/dbiloc
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# EMBOSS dbiloc: build EMBOSS index for a local-list format database
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-dbname=[database name]:name:' \
  '-directory=[directory of local files]:dir:_files -/' \
  '-filenames=[file pattern]:pattern:' \
  '-fields=[index fields]:fields:' \
  '-release=[release]:release:' \
  '-date=[date]:date:' \
  '-exclude=[exclude patterns]:patterns:' \
  '-indexoutdir=[output index dir]:dir:_files -/' \
  '-cleanup[delete temp files]' \
  '*:database name:' && ret=0
return ret
