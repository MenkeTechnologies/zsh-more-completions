#compdef supervisord

# Zsh completion for supervisord - process manager daemon

_arguments -s -S \
  '(-c --configuration)'{-c+,--configuration=}'[config file path]:config file:_files' \
  '(-n --nodaemon)'{-n,--nodaemon}'[run in foreground]' \
  '(-s --silent)'{-s,--silent}'[no output directed to stdout]' \
  '(-u --user)'{-u+,--user=}'[UNIX username or numeric ID]:user:_users' \
  '(-m --umask)'{-m+,--umask=}'[umask of the daemon process]:umask:' \
  '(-d --directory)'{-d+,--directory=}'[directory to chdir to]:directory:_files -/' \
  '(-l --logfile)'{-l+,--logfile=}'[activity log path]:log file:_files' \
  '(-y --logfile_maxbytes)'{-y+,--logfile_maxbytes=}'[max log file size]:bytes:' \
  '(-z --logfile_backups)'{-z+,--logfile_backups=}'[number of log backups]:count:' \
  '(-e --loglevel)'{-e+,--loglevel=}'[log level]:level:(critical error warn info debug trace blather)' \
  '(-j --pidfile)'{-j+,--pidfile=}'[PID file path]:pid file:_files' \
  '(-i --identifier)'{-i+,--identifier=}'[supervisor identifier]:identifier:' \
  '(-q --childlogdir)'{-q+,--childlogdir=}'[child log directory]:directory:_files -/' \
  '(-k --nocleanup)'{-k,--nocleanup}'[prevent cleanup of child log files]' \
  '(-a --minfds)'{-a+,--minfds=}'[minimum file descriptors]:count:' \
  '(-t --strip_ansi)'{-t,--strip_ansi}'[strip ANSI escape sequences from child logs]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
