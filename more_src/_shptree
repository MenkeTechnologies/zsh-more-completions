#compdef shptree
# Documentation: https://mapserver.org/utilities/shptree.html
# Create a quadtree-based spatial index (.qix) for a shapefile

local ret=1

_arguments -s \
  '1:shapefile:_files -g "*.shp"' \
  '2:depth (max tree depth, 0 = auto):' \
  '3:index format:(NL NM N L M)' && ret=0

return ret
