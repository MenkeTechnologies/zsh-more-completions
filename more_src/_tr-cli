#compdef tr-cli
# _tr-cli — GNU coreutils tr translate or delete characters CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_tr-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[complement set1]' \
        '-C[complement set1]' \
        '--complement[complement set1]' \
        '-d[delete characters in set1]' \
        '--delete[delete characters in set1]' \
        '-s[squeeze repeats]' \
        '--squeeze-repeats[squeeze repeats]' \
        '-t[truncate set1 to length of set2]' \
        '--truncate-set1[truncate set1 to length of set2]' \
        '*:set1 set2:'
}

_tr-cli "$@"
