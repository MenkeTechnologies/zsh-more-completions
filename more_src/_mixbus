#compdef mixbus Mixbus
# Documentation: https://man.archlinux.org/search?q=mixbus
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --bypass-plugins)'{-b,--bypass-plugins}'[bypass plugins]' \
  '(-c --name)'{-c,--name}'+[session name]:name:' \
  '(-d --disable-plugins)'{-d,--disable-plugins}'[disable plugins]' \
  '(-n --no-splash)'{-n,--no-splash}'[no splash]' \
  '(-N --new)'{-N,--new}'+[new session]:name:' \
  '(-T --template)'{-T,--template}'+[template]:tpl:' \
  '*:session:_files -g "*.ardour"' && ret=0

return ret
