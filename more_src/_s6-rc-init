#compdef s6-rc-init
# Documentation: https://www.skarnet.org/software/s6-rc/s6-rc-init.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[path to compiled service database]:database directory:_files -/' \
  '-l[path to live state directory]:live directory:_files -/' \
  '-t+[timeout for supervisor startup in milliseconds]:timeout' \
  '-b[blocking mode]' \
  '-p[set initial permissions on the live directory]:permissions' \
  '1:scan directory:_files -/' && ret=0

return ret
