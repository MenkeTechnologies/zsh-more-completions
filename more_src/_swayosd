#compdef swayosd swayosd-server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-s[style file]:css file:_files' \
  '-t[display timeout in milliseconds]:timeout:' \
  '--top-margin[margin from top]:margin:' \
  '--max-volume[maximum volume percentage]:percent:' && ret=0

return ret
