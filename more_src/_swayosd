#compdef swayosd-server swayosd-client swayosd-libinput-backend swayosd
# Documentation: https://man.archlinux.org/search?q=swayosd-server
# Reference accessed: 2026-05-16

# ErikReider/SwayOSD — src/args.rs (clap) + src/input-backend/main.rs (no argv)

local ret=1

case $service in
  swayosd-libinput-backend)
    # Seat-bound libinput loop; configuration only via files / DBus.
    return 0
    ;;
  swayosd-server|swayosd)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[help]' \
      '--version[version]' \
      '--config=[user config path]:file:_files' \
      '(-s --style)'{-s,--style=}'[CSS path overriding defaults]:file:_files' \
      '--top-margin=[OSD vertical position 0.0–1.0]:frac:' && ret=0
    ;;
  swayosd-client)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[help]' \
      '--version[version]' \
      '--config=[user config path]:file:_files' \
      '--monitor=[focused output name]:output:' \
      '--caps-lock[show caps-lock indicator]' \
      '--caps-lock-led=[LED name under /sys/class/leds]:led:' \
      '--num-lock[show num-lock indicator]' \
      '--num-lock-led=[LED name]:led:' \
      '--scroll-lock[show scroll-lock indicator]' \
      '--scroll-lock-led=[LED name]:led:' \
      '--output-volume=[sink volume raise|lower|mute-toggle|±step]:op:' \
      '--input-volume=[source volume raise|lower|mute-toggle|±step]:op:' \
      '--max-volume=[clamp max output volume]:pct:' \
      '--device=[pulse sink/source or brightness device]:dev:' \
      '--brightness=[backlight raise|lower|±step]:op:' \
      '--min-brightness=[minimum brightness percent]:pct:' \
      '--playerctl=[media key play-pause|play|pause|stop|next|prev|shuffle]:cmd:' \
      '--player=[playerctl target auto|all|shift|unshift|<name>]:player:' \
      '--custom-message=[freedesktop notification body]:text:' \
      '--custom-icon=[freedesktop icon name]:icon:' \
      '--custom-progress=[progress 0.0–1.0]:frac:' \
      '--custom-segmented-progress=[value\:segments]:seg:' \
      '--custom-progress-text=[label for custom progress]:text:' && ret=0
    ;;
  *)
    return 1
    ;;
esac

return ret
