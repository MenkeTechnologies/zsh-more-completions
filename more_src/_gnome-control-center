#compdef gnome-control-center
# _gnome-control-center — GNOME gnome-control-center (Settings app launcher; positional panel name opens directly to that pane, --list dumps registered panels, --search filters them, --version prints version)
# upstream: https://gitlab.gnome.org/GNOME/gnome-control-center
# Flags from gnome-control-center shell/cc-application.c on tip.

_gnome-control-center() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--list[list panels]' \
        '--overview[show overview]' \
        '--search+[search panels]:query:' \
        '--verbose[verbose]' \
        '1:panel:(applications background bluetooth color datetime default-apps display info-overview keyboard mouse multitasking network notifications online-accounts power printers privacy region search sharing sound thunderbolt universal-access user-accounts wacom wifi wwan)' \
        '*:arg:'
}

_gnome-control-center "$@"
