#compdef cargo-leptos

# Zsh completion for cargo-leptos - Rust web framework CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_cargo_leptos_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '(-r --release)'{-r,--release}'[build in release mode]'
  '--hot-reload[enable hot reloading]'
  '(-p --project-path)'{-p,--project-path}'[path to project]:directory:_directories'
  '--bin-features=[features for the server binary]:features:'
  '--lib-features=[features for the WASM library]:features:'
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]'
)

_arguments -s -S -C \
  "${_cargo_leptos_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'new:Create a new Leptos project'
      'build:Build the project'
      'serve:Build and serve the project'
      'test:Run tests'
      'watch:Watch for changes and rebuild'
      'end2end:Run end-to-end tests'
      'init:Initialize a Leptos project in the current directory'
    )
    _describe -t commands 'cargo-leptos commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      new)
        _arguments -s -S \
          "${_cargo_leptos_global_flags[@]}" \
          '--git=[Git repository template URL]:url:' \
          '--path=[local template path]:directory:_directories' \
          '1:project name:' && ret=0
        ;;
      build)
        _arguments -s -S \
          "${_cargo_leptos_global_flags[@]}" \
          '--precompress[precompress static files]' \
          '--package=[package to build]:package:' \
          '--features=[features to enable]:features:' && ret=0
        ;;
      serve)
        _arguments -s -S \
          "${_cargo_leptos_global_flags[@]}" \
          '--precompress[precompress static files]' \
          '--package=[package to build]:package:' \
          '--features=[features to enable]:features:' \
          '--port=[port to listen on]:port:' && ret=0
        ;;
      test)
        _arguments -s -S \
          "${_cargo_leptos_global_flags[@]}" \
          '--package=[package to test]:package:' && ret=0
        ;;
      watch)
        _arguments -s -S \
          "${_cargo_leptos_global_flags[@]}" \
          '--precompress[precompress static files]' \
          '--package=[package to build]:package:' \
          '--features=[features to enable]:features:' \
          '--port=[port to listen on]:port:' && ret=0
        ;;
      end2end)
        _arguments -s -S \
          "${_cargo_leptos_global_flags[@]}" \
          '--package=[package to test]:package:' && ret=0
        ;;
      init)
        _arguments -s -S \
          "${_cargo_leptos_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
