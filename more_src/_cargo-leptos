#compdef cargo-leptos

# Zsh completion for cargo-leptos (Leptos web framework CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '-v[Use verbose output]' \
  '--verbose[Use verbose output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'new:Create a new Leptos project'
      'build:Build the server and client'
      'serve:Build and serve the project'
      'watch:Build, serve, and watch for changes'
      'test:Run tests'
      'end2end:Run end-to-end tests'
    )
    _describe -t commands 'cargo-leptos command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      new)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--git=[Git repository template URL]:url' \
          '--path=[Local template path]:path:_directories' \
          '1:name' && ret=0
        ;;
      build)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--release[Build in release mode]' \
          '--precompress[Precompress static files]' \
          '-p+[Package to build]:package' \
          '--package=[Package to build]:package' \
          '--features=[Features to enable]:features' \
          '--lib-features=[Lib features to enable]:features' \
          '--bin-features=[Bin features to enable]:features' && ret=0
        ;;
      serve|watch)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--release[Build in release mode]' \
          '--hot-reload[Enable hot reloading]' \
          '--precompress[Precompress static files]' \
          '-p+[Package to build]:package' \
          '--package=[Package to build]:package' \
          '--features=[Features to enable]:features' \
          '--port=[Server port]:port' && ret=0
        ;;
      test|end2end)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--release[Build in release mode]' \
          '-p+[Package to test]:package' \
          '--package=[Package to test]:package' && ret=0
        ;;
    esac
    ;;
esac

return ret
