autoload -U is-at-least

_radioboat() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-c+[]:CONFIG:_default' \
'--config=[]:CONFIG:_default' \
'--ui-size=[]:UI_SIZE:(full small)' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_radioboat_commands" \
"*::: :->radioboat" \
&& ret=0
    case $state in
    (radioboat)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:radioboat-command-$line[1]:"
        case $line[1] in
            (config-edit)
_arguments "${_arguments_options[@]}" : \
'-c+[]:CONFIG:_default' \
'--config=[]:CONFIG:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_radioboat__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:radioboat-help-command-$line[1]:"
        case $line[1] in
            (config-edit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_radioboat_commands] )) ||
_radioboat_commands() {
    local commands; commands=(
'config-edit:Open config file in \$EDITOR' \
'completion:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'radioboat commands' commands "$@"
}
(( $+functions[_radioboat__completion_commands] )) ||
_radioboat__completion_commands() {
    local commands; commands=()
    _describe -t commands 'radioboat completion commands' commands "$@"
}
(( $+functions[_radioboat__config-edit_commands] )) ||
_radioboat__config-edit_commands() {
    local commands; commands=()
    _describe -t commands 'radioboat config-edit commands' commands "$@"
}
(( $+functions[_radioboat__help_commands] )) ||
_radioboat__help_commands() {
    local commands; commands=(
'config-edit:Open config file in \$EDITOR' \
'completion:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'radioboat help commands' commands "$@"
}
(( $+functions[_radioboat__help__completion_commands] )) ||
_radioboat__help__completion_commands() {
    local commands; commands=()
    _describe -t commands 'radioboat help completion commands' commands "$@"
}
(( $+functions[_radioboat__help__config-edit_commands] )) ||
_radioboat__help__config-edit_commands() {
    local commands; commands=()
    _describe -t commands 'radioboat help config-edit commands' commands "$@"
}
(( $+functions[_radioboat__help__help_commands] )) ||
_radioboat__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'radioboat help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_radioboat" ]; then
    _radioboat "$@"
else
    compdef _radioboat radioboat
fi
