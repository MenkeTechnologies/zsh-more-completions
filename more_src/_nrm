#compdef nrm
# Documentation: https://man.archlinux.org/search?q=nrm
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'ls:list available registries'
  'use:use a registry'
  'add:add custom registry'
  'set:set custom registry attribute'
  'rename:rename custom registry'
  'del:delete custom registry'
  'home:open registry homepage'
  'test:show response time of registries'
  'help:show help'
  'login:set authentication for registry'
  'current:show current registry'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'nrm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (use|del|home|rename|set|login|test)
        _values 'registry' 'npm' 'yarn' 'tencent' 'cnpm' 'taobao' 'npmMirror' 'huawei' && ret=0 ;;
      (add)
        _arguments \
          '1:registry name:' \
          '2:registry URL:' \
          '*:home URL:' && ret=0 ;;
      (set)
        _arguments \
          '-a+[attribute name]:attr:' \
          '-v+[value]:val:' \
          '*:registry:' && ret=0 ;;
    esac ;;
esac

return ret
