#compdef photoprism

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config-file[config file path]:file:_files' \
  '--config-path[config path]:dir:_directories' \
  '--originals-path[originals path]:dir:_directories' \
  '--storage-path[storage path]:dir:_directories' \
  '--import-path[import path]:dir:_directories' \
  '--sidecar-path[sidecar path]:dir:_directories' \
  '--assets-path[assets path]:dir:_directories' \
  '--cache-path[cache path]:dir:_directories' \
  '--temp-path[temporary path]:dir:_directories' \
  '--backup-path[backup path]:dir:_directories' \
  '--log-level[log level]:level:(trace debug info warning error fatal panic)' \
  '--log-filename[log file path]:file:_files' \
  '--pid-filename[PID file path]:file:_files' \
  '--detect-nsfw[flag NSFW photos]' \
  '--upload-nsfw[allow NSFW uploads]' \
  '--admin-password[initial admin password]:password' \
  '--database-driver[database driver]:driver:(mysql sqlite3)' \
  '--database-dsn[database connection string]:dsn' \
  '--database-server[database server]:server' \
  '--database-name[database name]:name' \
  '--database-user[database user]:user' \
  '--database-password[database password]:password' \
  '--http-host[HTTP server host]:host' \
  '--http-port[HTTP server port]:port' \
  '--http-mode[HTTP server mode]:mode:(release debug test)' \
  '--site-url[public site URL]:url' \
  '--site-title[site title]:title' \
  '--site-caption[site caption]:caption' \
  '--site-description[site description]:description' \
  '--site-author[site author]:author' \
  '--workers[maximum number of indexing workers]:workers' \
  '--disable-webdav[disable WebDAV]' \
  '--disable-settings[disable settings UI]' \
  '--disable-tensorflow[disable TensorFlow]' \
  '--disable-faces[disable face detection]' \
  '--disable-raw[disable RAW conversion]' \
  '--disable-exiftool[disable ExifTool]' \
  '--disable-ffmpeg[disable FFmpeg]' \
  '--read-only[disable import, upload, and delete]' \
  '--experimental[enable experimental features]' \
  '--debug[enable debug mode]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'start:start the web server'
      'stop:stop the web server'
      'status:check server status'
      'index:index originals'
      'import:import files to originals'
      'copy:copy files to originals'
      'purge:remove missing files from index'
      'cleanup:remove orphaned index entries and thumbnails'
      'optimize:optimize index and thumbnails'
      'moments:update album moments'
      'places:fetch updated location data'
      'config:show config options and values'
      'backup:create a database backup'
      'restore:restore database from backup'
      'reset:reset database and delete album settings'
      'migrate:run database migrations'
      'users:manage user accounts'
      'passwd:change user password'
      'thumbs:generate thumbnails'
      'convert:convert RAW and video files'
      'faces:manage face clusters'
      'version:show version information'
    )
    _describe -t commands 'photoprism command' commands
    ;;
  args)
    case $words[1] in
      index)
        _arguments -s -S \
          '--cleanup[remove orphaned entries after indexing]' \
          '-f[rescan all files]' \
          '--force[rescan all files]' \
          '*:directory:_directories' && ret=0
        ;;
      import|copy)
        _arguments -s -S \
          '-f[force re-import]' \
          '--force[force re-import]' \
          '*:directory:_directories' && ret=0
        ;;
      backup)
        _arguments -s -S \
          '-f[overwrite existing backup file]' \
          '--force[overwrite existing backup file]' \
          '--index[include search index]' \
          '1:backup file:_files' && ret=0
        ;;
      restore)
        _arguments -s -S \
          '-f[replace existing data]' \
          '--force[replace existing data]' \
          '--index[include search index]' \
          '1:backup file:_files' && ret=0
        ;;
      passwd)
        _arguments '1:username:' && ret=0
        ;;
    esac
    ;;
esac

return ret