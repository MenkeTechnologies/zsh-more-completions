#compdef oils-for-unix osh ysh
# Documentation: https://man.archlinux.org/search?q=oils-for-unix
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-c[run command string]:command:' \
  '-i[interactive mode]' \
  '-l[login shell]' \
  '-n[parse only, do not execute]' \
  '-x[trace execution]' \
  '-v[verbose execution]' \
  '*-O+[enable shopt option]:opt:(strict_arith strict_argv strict_array strict_control_flow strict_errexit strict_glob strict_nameref strict_parse_slice strict_tilde strict_word_eval strict:all simple_word_eval parse_at parse_brace parse_equals parse_paren parse_proc parse_triple_quote ysh:upgrade ysh:all errexit nounset pipefail xtrace inherit_errexit)' \
  '*+O+[disable shopt option]:opt:(strict_arith strict_argv strict_array strict_control_flow strict_errexit strict_glob strict_nameref strict_parse_slice strict_tilde strict_word_eval strict:all simple_word_eval parse_at parse_brace parse_equals parse_paren parse_proc parse_triple_quote ysh:upgrade ysh:all errexit nounset pipefail xtrace inherit_errexit)' \
  '--ast-format=[AST output format]:format:(text none abbrev-text abbrev-html html)' \
  '--debug-file=[debug log file]:file:_files' \
  '--xtrace-to-debug-file[send xtrace to debug file]' \
  '--rcfile=[interactive init file]:file:_files' \
  '--norc[do not read rcfile]' \
  '--eval=[eval file before script]:file:_files' \
  '*:script_or_arg:_files' && ret=0

return ret
