#compdef bbcp
# Documentation: https://www.slac.stanford.edu/~abh/bbcp/
# High-speed parallel file copy tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[append mode]' \
  '-B[I/O buffer size]:buffer size:' \
  '-b+[transfer buffer size per stream]:buffer size:' \
  '-C[config file]:config file:_files' \
  '-D[debug level]:level:(0 1 2 3)' \
  '-d[create target directory path]' \
  '-e[error disposition]:disposition:' \
  '-E[program for source login]:program:_command_names' \
  '-f[force overwrite of existing files]' \
  '-F[fixed port number]:port:' \
  '-g[group for target files]:group:_groups' \
  '-G[globus compatibility mode]' \
  '-i[identity file for ssh]:identity file:_files' \
  '-I[use indirect data connection]' \
  '-k[keep partially transferred files]' \
  '-K[checksum type]:type:(md5 a32)' \
  '-l[log file]:log file:_files' \
  '-L[limit transfer speed]:speed:' \
  '-m[mode for target files]:mode:' \
  '-n[do not create target directory]' \
  '-N[network interface]:interface:' \
  '-o[use ordered network connections]' \
  '-O[omit files]:pattern:' \
  '-p[preserve source mode, ownership, and timestamps]' \
  '-P+[number of parallel streams]:streams:' \
  '-q[quiet mode]' \
  '-r[recursive copy]' \
  '-R[retry on transient errors]:retries:' \
  '-s+[number of network streams]:streams:' \
  '-S[command for target login]:command:' \
  '-T[target config file]:target config:_files' \
  '-u[unlink target before copy]' \
  '-U[unlink source after copy]' \
  '-v[verbose mode]' \
  '-V[very verbose mode]' \
  '-w+[window size]:window size:' \
  '-W[use TCP window scaling]' \
  '-x[set progress reporting rate]:rate:' \
  '-y+[file ordering]:order:(n m s)' \
  '-z[use reverse connection for data]' \
  '-Z[ssh authentication]:auth type:' \
  '-4[force IPv4]' \
  '-6[force IPv6]' \
  '--port[port number]:port:' \
  '*:source/target:_files' && ret=0

return ret
