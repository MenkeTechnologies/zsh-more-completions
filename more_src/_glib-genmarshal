#compdef glib-genmarshal
# Documentation: glib-genmarshal --help (GLib)
# Source: GLib glib-genmarshal — generate signal marshallers for GObject.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help and exit]' \
    '(- *)'{-v,--version}'[show version and exit]' \
    '--prefix=[marshaller prefix]:string:' \
    '--output=[write output to FILE]:file:_files' \
    '--skip-source[skip source-location comments]' \
    '--internal[mark generated functions as internal]' \
    '--valist-marshallers[generate va_list marshallers]' \
    '--g-fatal-warnings[treat warnings as fatal]' \
    '*--include-header=[include header in body]:header:_files -g "*.h"' \
    '--pragma-once[use #pragma once as inclusion guard]' \
    '*-D+[C preprocessor define]:NAME[=VALUE]:' \
    '*-U+[C preprocessor undefine]:NAME:' \
    '--prototypes[generate marshaller prototypes in C]' \
    '(--header --body)--header[generate C headers]' \
    '(--header --body)--body[generate C code]' \
    '(--stdinc --nostdinc)--stdinc[include standard marshallers]' \
    '(--stdinc --nostdinc)--nostdinc[use standard marshallers]' \
    '(--quiet --verbose)--quiet[only print warnings and errors]' \
    '(--quiet --verbose)--verbose[verbose / include debugging info]' \
    '*:marshaller list file (or "-"):_files' \
    && ret=0

return ret
