#compdef drawsig
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss35.html
# KAPPA: draws +/-n standard-deviation lines on a line plot

local ret=1

_arguments -s \
  'AXIS=[axis on which to draw the lines]:axis' \
  'COMP=[array component to use]:comp:(Data Variance Error)' \
  'DEVICE=[graphics device]:device' \
  'NSIGMA=[multiples of standard deviation]:n' \
  'STYLE=[plotting style for the lines]:style' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
