#compdef xcbeautify-cli
# _xcbeautify-cli — cpisciotta xcbeautify Xcode build output formatter CLI alias (Charles Pisciotta / cpisciotta, Swift); custom argparse
# upstream: https://github.com/cpisciotta/xcbeautify

_xcbeautify-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--disable-colored-output[disable colored output]' \
        '--disable-logging[disable logging]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--quieter[quieter]' \
        '-Q[quieter]' \
        '--is-ci[is CI environment]' \
        '--renderer=+[renderer]:r:(terminal github-actions teamcity azure-devops-pipelines)' \
        '-r+[renderer]:r:(terminal github-actions teamcity azure-devops-pipelines)' \
        '--report=+[report type]:t:(html json junit sonar)' \
        '--report-path=+[report path]:dir:_files -/' \
        '--report-filename=+[report filename]:str:' \
        '--preserve-unbeautified[preserve unbeautified]' \
        '-p[preserve unbeautified]' \
        '--summary[show summary]' \
        '*:arg:'
}

_xcbeautify-cli "$@"
