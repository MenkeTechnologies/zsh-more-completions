#compdef varnishlog

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-a[append to file when using -w]' \
  '-A[print records as text lines]' \
  '-b[only show backend communication]' \
  '-c[only show client communication]' \
  '-C[use caseless regular expressions]' \
  '-d[process old log entries on startup]' \
  '-g+[grouping of records]:group:(raw vxid request session)' \
  '-i+[include tag pattern]:tag' \
  '-I+[include regex for tag content]:regex' \
  '-k+[process only N log transactions]:num' \
  '-L+[upper limit of incomplete transactions]:limit' \
  '-n+[specify varnishd instance name]:name' \
  '-N+[specify VSM file]:file:_files' \
  '-P+[write PID to file]:pidfile:_files' \
  '-q+[VSL query string]:query' \
  '-r+[read log entries from file]:file:_files' \
  '-R+[rate limit]:limit' \
  '-t+[timeout before dying on -d]:seconds' \
  '-T+[timeout for incomplete transactions]:seconds' \
  '-v[invert tag filtering]' \
  '-w+[write output to file]:file:_files' \
  '-x+[exclude tag pattern]:tag' \
  '-X+[exclude regex for tag content]:regex' && ret=0

return ret
