#compdef redress
# Documentation: https://github.com/goretk/redress
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. Modern redress is a cobra-style
# subcommand CLI; the legacy single-flag interface was replaced.

# Zsh completion for redress - reverse-engineer Go binaries (goretk/redress)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'info:print summary information about the binary'
  'packages:list packages used in the binary'
  'types:list and extract type definitions'
  'source:reconstruct source code layout projection'
  'gomod:display Go module information'
  'moduledata:show sections extracted from moduledata structure'
  'r2:integration with radare2 via r2pipe'
  'version:show redress version'
  'completion:generate shell autocompletion'
  'help:get help on any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  command)
    _describe -t commands 'redress command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      packages)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--unknown[include unclassified packages]' \
          '--std[include standard library packages]' \
          '--vendor[include third-party vendor packages]' \
          '--filepath[show folder paths]' \
          '1:go binary:_files' && ret=0
        ;;
      types)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--std[include standard library types]' \
          '--vendor[include vendor types]' \
          '--methods[show method definitions]' \
          '1:subset:(interface struct all)' \
          '2:go binary:_files' && ret=0
        ;;
      source)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--std[include standard library packages]' \
          '--vendor[include vendor packages]' \
          '--unknown[include unclassified packages]' \
          '1:go binary:_files' && ret=0
        ;;
      r2)
        local -a r2_cmds=(
          'init:perform initial analysis'
          'type:print type definition for a given address'
          'line:annotate functions with source lines'
          'strarr:print string arrays'
        )
        _describe -t commands 'r2 subcommand' r2_cmds && ret=0
        ;;
      info|gomod|moduledata)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:go binary:_files' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
