#compdef bam2bed
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/file-management/conversion/bam2bed.html
# convert BAM alignments to sorted BED (bedops)

local ret=1

_arguments -s -S \
  '--keep-header[preserve header data as BED elements named _header]' \
  '--split[split N-CIGAR reads into separate BED elements]' \
  '--all-reads[include both unmapped and mapped reads]' \
  '--do-not-sort[prevent automatic sorting of converted output]' \
  '--max-mem[limit sort memory usage]:mem' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
