#compdef SurfClust
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/SurfClust.html
# Find clusters of activation on a surface

local ret=1

_arguments -s \
  '-spec[surface spec file]:spec file:_files' \
  '-surf_A[input surface name]:surface' \
  '-i[full path to surface file]:surface:_files' \
  '-input[input dataset and column index]:dataset:_files' \
  '-rmm[max distance between activated nodes]:dist' \
  '-amm2[minimum cluster area threshold]:area' \
  '-n[minimum node count threshold]:count' \
  '-thresh_col[column to use for thresholding]:col' \
  '-thresh[minimum value threshold]:thresh' \
  '-athresh[absolute value threshold]:thresh' \
  '-ir_range[include nodes within value range]:range' \
  '-ex_range[include nodes outside value range]:range' \
  '-prefix[output filename prefix]:prefix' \
  '-out_clusterdset[output filtered dataset]' \
  '-out_roidset[output ROI dataset with cluster ranks]' \
  '-out_fulllist[output values for all nodes]' \
  '-prepend_node_index[add node indices to column 0]' \
  '-sort_none[disable cluster sorting]' \
  '-sort_n_nodes[sort clusters by node count]' \
  '-sort_area[sort clusters by area]' \
  '-update[show progress at percent intervals]:percent' \
  '-no_cent[skip central node calculation]' \
  '-cent[calculate central nodes]' \
  '-novolreg[ignore volume transforms]' \
  '-noxform[same as -novolreg]' \
  '-setenv[set environment variable]:var' && ret=0

return ret
