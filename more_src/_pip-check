#compdef pip-check
# Documentation: https://github.com/bartTC/pip-check
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(-a --ascii)'{-a,--ascii}'[display results as ASCII table]' \
  '(-c --cmd)'{-c,--cmd}'[specify the pip executable]:pip cmd:_command_names' \
  '(-l --local)'{-l,--local}'[show only virtualenv-installed packages]' \
  '(-r --not-required)'{-r,--not-required}'[list packages not required by other installed packages]' \
  '(-f --full-version)'{-f,--full-version}'[display complete version strings]' \
  '(-H --hide-unchanged)'{-H,--hide-unchanged}'[exclude unchanged packages from output]' \
  '(-u --show-update)'{-u,--show-update}'[display upgrade instructions for updatable packages]' \
  '(-U --user)'{-U,--user}'[show only user-installed packages]' && ret=0

return ret
