#compdef ffcvt
# Documentation: https://github.com/suntong/ffcvt
# ffmpeg convert wrapper tool

local ret=1

_arguments -s \
  '-cfg[cfg file to define your own targets]:file:_files' \
  '-t[target type (webm/x265-opus/x264-mp3/wx/youtube/copy)]:target:' \
  '-ves[video encoding method set]:set:' \
  '-aes[audio encoding method set]:set:' \
  '-ses[subtitle encoding method set]:set:' \
  '-vep[video encoding method prepend]:str:' \
  '-aep[audio encoding method prepend]:str:' \
  '-sep[subtitle encoding method prepend]:str:' \
  '-vea[video encoding method append]:str:' \
  '-aea[audio encoding method append]:str:' \
  '-abr[audio bitrate]:bitrate:' \
  '-crf[the CRF value (0-51)]:crf:' \
  '-d[directory that holds input files]:dir:_files -/' \
  '-f[input file name]:file:_files' \
  '-sym[symlinks will be processed as well]' \
  '-exts[extension list for files to be queued]:exts:' \
  '-suf[suffix to the output file names]:suffix:' \
  '-ext[extension for the output file]:ext:' \
  '-w[work directory that holds output files]:dir:_files -/' \
  '-ac[copy audio codec]' \
  '-vc[copy video codec]' \
  '-an[no audio, output video only]' \
  '-vn[no video, output audio only]' \
  '-vss[video: same size]' \
  '-C[cut segment(s) out to keep]:range:' \
  '-Cut[cut segment(s) out to keep]:range:' \
  '-S[split video into multiple segments]:seg:' \
  '-Seg[split video into multiple segments]:seg:' \
  '-Speed[speed up/down video playback speed]:speed:' \
  '-K[add a karaoke audio track to .mp4 MTV]' \
  '-karaoke[add a karaoke audio track to .mp4 MTV]' \
  '-tkf[transpose song key from]:key:' \
  '-tkt[transpose song key to]:key:' \
  '-tkb[transpose song by chromatic scale]:steps:' \
  '-lang[language selection for audio stream extraction]:lang:' \
  '-sel[subtitle encoding language]:lang:' \
  '-o[more options passed to ffmpeg]:opts:' \
  '-ato-opus[audio encode to opus using -abr]' \
  '-vto-x265[video encode to x265 using -crf]' \
  '-p[par2create, create par2 files]' \
  '-nc[no clobber, skip already converted]' \
  '-bt[breath time between conversions]:duration:' \
  '-maxc[max conversions done each run]:n:' \
  '-n[no exec, dry run]' \
  '-force[overwrite any existing non-empty file]' \
  '-debug[debugging level]:level:' \
  '-ffmpeg[ffmpeg program executable name]:prog:' \
  '-ffprobe[ffprobe program executable name]:prog:' \
  '-version[print version then exit]' && ret=0

return ret
