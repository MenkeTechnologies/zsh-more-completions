#compdef doas

# Zsh completion for doas - execute command as another user

_arguments -s -S \
  '-C[check configuration file and exit]:config file:_files' \
  '-L[clear any persisted authentication]' \
  '-n[non-interactive mode]' \
  '-s[run the user shell]' \
  '-u[target user]:user:_users' \
  '1:command:_command_names -e' \
  '*::arguments:_normal'
