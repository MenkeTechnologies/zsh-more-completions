#compdef doas
# Documentation: https://man.openbsd.org/doas.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# doas — execute commands as another user (OpenBSD's sudo alternative).

_arguments -s -S \
  '-a[authentication style]:style:' \
  '-C[check configuration file and exit]:config file:_files' \
  '-L[clear any persisted authentication]' \
  '-n[non-interactive mode]' \
  '-s[run the user shell]' \
  '-u[target user]:user:_users' \
  '1:command:_command_names -e' \
  '*::arguments:_normal'
