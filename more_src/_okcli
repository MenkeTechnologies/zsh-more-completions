#compdef okcli
# Documentation: https://github.com/man-group/okcli
# okcli - Oracle DB command line client with autocompletion and syntax highlighting

local ret=1

_arguments -s \
  '(-h --host)'{-h,--host}'[database host address]:host:_hosts' \
  '(-P --port)'{-P,--port}'[port number]:port' \
  '(-u --user)'{-u,--user}'[username]:user' \
  '(-p --password)'{-p,--password}'[password]:password' \
  '(-D --database)'{-D,--database}'[database/schema]:database' \
  '(-R --prompt)'{-R,--prompt}'[custom prompt format]:prompt' \
  '(-l --logfile)'{-l,--logfile}'[log queries and results to file]:file:_files' \
  '--okclirc[configuration file location]:file:_files' \
  '--auto-vertical-output[auto switch to vertical when too wide]' \
  '(-t --table)'{-t,--table}'[display batch output in table format]' \
  '--csv[display batch output in CSV format]' \
  '--warn[warn on destructive queries]' \
  '--no-warn[do not warn on destructive queries]' \
  '--login-path[read named path from login file]:path' \
  '(-e --execute)'{-e,--execute}'[execute command and quit]:command' \
  '(-@ --filename)'{-@,--filename}'[execute SQL commands from file]:file:_files' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--help[show help]' \
  '*:argument:_files' && ret=0

return ret
