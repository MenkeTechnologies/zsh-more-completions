#compdef pdb_rplchain
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Performs in-place replacement of a chain identifier by another

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[chain replacement in from:to form, e.g. -A:B]:from\:to' \
  '*:PDB file:_files' && ret=0

return ret
