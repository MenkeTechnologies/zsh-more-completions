#compdef relay
# Documentation: https://man.archlinux.org/search?q=relay
# Reference accessed: 2026-05-16

# Zsh completion for relay (gitlab.com/relay-mail/rust/cli).

local -a cmds
cmds=(
  'claim:claim identity on agent'
  'claim-inbox:claim inbox for identity'
  'identities:list local identities'
  'identity:import export or view identity'
  'messages:list inbox messages'
  'read:read message by GID'
  'send:send message to user'
  'wipeout:delete all local data'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :{_describe '\''command'\'' cmds}' \
  '*::arguments:_default'
