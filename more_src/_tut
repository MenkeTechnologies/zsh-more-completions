#compdef tut

# completions for tut - a TUI for Mastodon

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
  '(-u --user)'{-u,--user}'[user for multi-account]:user' \
  '--new-user[add a new user]'