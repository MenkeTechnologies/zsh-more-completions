#compdef tut

# Zsh completion for tut - TUI for Mastodon

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[specify config path]:config file:_files' \
  '(-u --user)'{-u,--user}'[specify user account]:user account' \
  '(-n --new-user)'{-n,--new-user}'[add a new user account]'
