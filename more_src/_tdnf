#compdef tdnf

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'autoerase:auto remove packages'
  'check:check rpm db'
  'check-update:check for updates'
  'clean:remove cached files'
  'distro-sync:synchronize to repo state'
  'downgrade:downgrade package'
  'erase:remove packages'
  'help:show help'
  'history:show transaction history'
  'info:package info'
  'install:install package'
  'list:list available/installed/etc packages'
  'makecache:update cache'
  'mark:mark install reason'
  'provides:find packages providing'
  'reinstall:reinstall packages'
  'remove:remove packages'
  'repolist:list repositories'
  'repoquery:query packages from repos'
  'repository-packages:operate on repo packages'
  'search:search packages'
  'update:update packages'
  'updateinfo:show update advisories'
  'upgrade:upgrade packages'
  'upgrade-to:upgrade to specific version'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-y --assumeyes)'{-y,--assumeyes}'[assume yes]' \
  '--assumeno[assume no]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '--installroot=[installroot]:dir:_files -/' \
  '--releasever=[release version]:ver:' \
  '--exclude=[exclude packages csv]:list:' \
  '--enablerepo=[enable repo]:repo:' \
  '--disablerepo=[disable repo]:repo:' \
  '--repofrompath=[id,baseurl path]:spec:' \
  '--repo=[only this repo csv]:list:' \
  '--refresh[force refresh metadata]' \
  '--allowerasing[allow erasing for resolution]' \
  '--best[try newest only]' \
  '--cacheonly[use cache only]' \
  '--debugsolver[debug solver]' \
  '--downloadonly[download only]' \
  '--downloaddir=[download dir]:dir:_files -/' \
  '--reboot-required[show if reboot needed]' \
  '--rpmverbosity=[rpm verbosity]:lvl:(emergency alert critical error warn notice info debug)' \
  '--security[security updates only]' \
  '--sec-severity=[severity]:sev:' \
  '--bugfix[bugfix updates only]' \
  '--enhancement[enhancement updates only]' \
  '--newpackage[new package updates]' \
  '--obsoletes[obsolete packages]' \
  '--noplugins[disable plugins]' \
  '--nogpgcheck[skip GPG check]' \
  '--skip-broken[skip broken deps]' \
  '--skip-conflicts[skip conflicts]' \
  '--skip-digest-check[skip digest check]' \
  '--skip-obsoletes[skip obsoletes]' \
  '--skip-signature[skip signature check]' \
  '--testonly[only test]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tdnf command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (list) _values 'list type' 'all' 'installed' 'available' 'updates' 'upgrades' 'extras' 'obsoletes' 'recent' && ret=0 ;;
      (clean) _values 'what' 'all' 'packages' 'metadata' 'dbcache' && ret=0 ;;
    esac ;;
esac

return ret
