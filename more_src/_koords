#compdef koords
# Documentation: https://www.atnf.csiro.au/computing/software/karma/user-manual/node3.html
# Karma interactive co-ordinate system placement on images

local ret=1

_arguments -s \
  '-private_cmap[use a private colourmap for the PseudoColour window]' \
  '-num_colours[number of colour cells to allocate (minimum 2)]:count' \
  '-cmap_master[share colourmap with another Karma tool]:host\:port' \
  '-fullscreen[make the image display window fill the entire screen]' \
  '-display[X display to use]:display:_x_display' \
  '-geometry[window size and position]:geometry:_x_geometry' \
  '-xrm[set an X resource string]:resource' \
  '*:file:_files' && ret=0

return ret
