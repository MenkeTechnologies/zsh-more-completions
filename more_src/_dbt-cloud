#compdef dbt-cloud

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'account:retrieve account information'
  'audit-log:retrieve audit logs (Enterprise only)'
  'project:manage dbt Cloud projects'
  'environment:manage environments'
  'connection:manage database connections'
  'job:manage jobs'
  'run:manage and inspect job runs'
  'metadata:query the Metadata API (GraphQL)'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--api-key=[dbt Cloud API token (env DBT_CLOUD_API_KEY)]:token:' \
  '--account-id=[dbt Cloud account id (env DBT_CLOUD_ACCOUNT_ID)]:id:' \
  '--host=[dbt Cloud host URL]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'dbt-cloud command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (account)
        _arguments '*::sub:(get list)' && ret=0 ;;
      (audit-log)
        _arguments '*::sub:(get)' && ret=0 ;;
      (project)
        _arguments '*::sub:(create delete get list update)' && ret=0 ;;
      (environment)
        _arguments '*::sub:(create delete get list)' && ret=0 ;;
      (connection)
        _arguments '*::sub:(create delete get list)' && ret=0 ;;
      (job)
        local -a job_subs=(
          'create:create a new job'
          'delete:delete a job'
          'delete-all:delete multiple jobs'
          'export:export job to JSON'
          'get:get job details'
          'import:import job from JSON'
          'list:list jobs'
          'run:trigger a job run'
        )
        _describe -t jcmds 'job subcommand' job_subs && ret=0
        case $words[2] in
          (run)
            _arguments \
              '--job-id=[job id]:id:' \
              '--cause=[trigger reason]:cause:' \
              '--wait[wait for completion]' \
              '--steps-override=[override steps]:steps:' \
              '--git-branch=[git branch]:branch:' \
              '--git-sha=[git sha]:sha:' \
              '--schema-override=[schema override]:schema:' && ret=0 ;;
          (export|import)
            _arguments '*::file:_files -g "*.json"' && ret=0 ;;
        esac ;;
      (run)
        local -a run_subs=(
          'cancel:cancel an active run'
          'cancel-all:cancel multiple runs'
          'get:get run details'
          'get-artifact:download run artifact'
          'list:list runs'
          'list-artifacts:list artifacts for a run'
        )
        _describe -t rcmds 'run subcommand' run_subs && ret=0 ;;
      (metadata)
        _arguments \
          '*::sub:(query)' \
          '--query=[GraphQL query]:query:' \
          '--query-file=[GraphQL query file]:file:_files' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
