#compdef AccumulateVariantCallingMetrics
# Documentation: https://github.com/broadinstitute/picard/blob/master/src/main/java/picard/vcf/AccumulateVariantCallingMetrics.java
# Combines multiple Variant Calling Metrics files into a single file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{--INPUT,-I}'=[input metrics file basenames]:value:_files' \
  '(--OUTPUT -O)'{--OUTPUT,-O}'=[output file basename]:value:_files' \
  '*:argument:_files' && ret=0

return ret
