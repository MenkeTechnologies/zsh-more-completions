#compdef sky_ng_sim
# Documentation: https://healpix.sourceforge.io/html/fac_sky_ng_sim.htm
# HEALPix: simulate a non-Gaussian CMB sky

local ret=1

_arguments -s -S \
  '(-d --double -s --single)'{-d,--double}'[use double precision]' \
  '(-d --double -s --single)'{-s,--single}'[use single precision (default)]' \
  '*:parameter file:_files' && ret=0

return ret
