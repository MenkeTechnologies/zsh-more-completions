#compdef rsgistranslate2cog
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgistranslate2cog RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[The input image file]:value:_files' \
  '(-o --output)'{-o,--output}'[The output image (GTIFF) file.]:value:_files' \
  '*:file:_files' && ret=0

return ret
