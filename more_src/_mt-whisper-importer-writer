#compdef mt-whisper-importer-writer
# Documentation: https://github.com/grafana/metrictank
# Receive metrictank chunks from a whisper importer reader and write to the store

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-config=[configuration file path]:_files' \
  '-exit-on-error[exit when an error occurs]' \
  '-http-endpoint=[HTTP endpoint to listen on]:addr' \
  '-log-level=[logging level]:level:(panic fatal error warning info debug)' \
  '-num-partitions=[number of partitions]:n' \
  '-partition-scheme=[partitioning method]:scheme:(byOrg bySeries bySeriesWithTags bySeriesWithTagsFnv)' \
  '-uri-path=[URI path for chunk posting]:path' && ret=0

return ret
