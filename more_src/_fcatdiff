#compdef fcatdiff
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fcatdiff.txt
# Compare specified columns of a FITS file and report row differences

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "outfile=[output FITS file]:file:_files" \
  "keywords=[keywords to copy]:" \
  "copyover=[copy non-differing rows]:bool:(yes no)" \
  "exclude=[columns to exclude]:" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
