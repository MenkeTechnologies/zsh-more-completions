#compdef iconv3
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Apply a 3x3 convolution filter to an image

local ret=1

_arguments -s -S \
  'IMAGE=[image to be filtered]:image:_files' \
  'CENTER=[central value of 3x3 convolution array]:center:' \
  'EDGE=[edge value of 3x3 convolution array]:edge:' \
  'OUTPUT=[resulting filtered image]:output:_files' \
  '*:NDF data file:_files' && ret=0

return ret
