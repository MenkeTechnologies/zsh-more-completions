#compdef fgflag
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/fgflag.html
# Apply an AIPS flagging table to visibility data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'select=[select keyword]:select:' \
  'fgtable=[fgtable keyword]:fgtable:' \
  '*:visibility dataset:_files' && ret=0

return ret
