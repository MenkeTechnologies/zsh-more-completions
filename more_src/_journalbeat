#compdef journalbeat
# _journalbeat — Elastic journalbeat (deprecated Elastic Beat shipping systemd journal events; subcommands: run, setup, test, version, export, completion, help; -c config file, -d debug selectors, -E key=value override, --path.config/data/logs/home directory overrides; replaced upstream by Filebeat's journald input)
# upstream: https://github.com/elastic/beats (deprecated)
# Subcommands from elastic/beats journalbeat/cmd on tip.

_journalbeat() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.yml"' \
        '-d+[debug selectors]:selectors:' \
        '*-E+[key=value]:setting:' \
        '--path.config+[config path]:dir:_files -/' \
        '--path.data+[data path]:dir:_files -/' \
        '--path.logs+[logs path]:dir:_files -/' \
        '--path.home+[home path]:dir:_files -/' \
        '-e[stderr logging]' \
        '-v[verbose]' \
        '--strict.perms=*[strict perms]:bool:(true false)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'journalbeat command' '(run setup test version export completion help)' ;;
        args)
            case $line[1] in
                setup) _describe -t commands 'setup target' '(dashboards index-management pipelines policy template)' ;;
                test) _describe -t commands 'test target' '(config output)' ;;
                export) _describe -t commands 'export target' '(config index-pattern template ilm-policy)' ;;
                completion) _arguments '1:shell:(bash zsh)' ;;
            esac
            ;;
    esac
}

_journalbeat "$@"
