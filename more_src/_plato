#compdef plato
# Documentation: https://github.com/es-analysis/plato
# plato - JavaScript source code visualization, static analysis, and complexity tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print the version]' \
  '(-d --dir)'{-d,--dir}'=[output directory (required)]:dir:_files -/' \
  '(-r --recurse)'{-r,--recurse}'[recursively search directories]' \
  '(-l --jshint)'{-l,--jshint}'=[specify a jshintrc file for JSHint linting]:file:_files' \
  '(-e --eslint)'{-e,--eslint}'=[specify an eslintrc file for ESLint linting]:file:_files' \
  '(-x --exclude)'{-x,--exclude}'=[file exclusion regex]:regex' \
  '(-t --title)'{-t,--title}'=[title of the report]:title' \
  '(-D --date)'{-D,--date}'=[time to use as the report date]:date' \
  '(-n --noempty)'{-n,--noempty}'[skip empty lines from line count]' \
  '(-q --quiet)'{-q,--quiet}'[reduce output to errors only]' \
  '*:input file:_files' && ret=0

return ret
