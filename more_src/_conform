#compdef conform

# Zsh completion for conform (policy enforcement for git)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'enforce:Enforce policies on the repository'
      'server:Run the server for CI integration'
    )
    _describe -t commands 'conform command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      enforce)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--commit-msg-file=[Path to commit message file]:file:_files' \
          '--base-branch=[Base branch for comparison]:branch' \
          '--revision=[Specific revision to check]:revision' \
          '--reporter=[Report format]:reporter:(none summary github)' && ret=0
        ;;
      server)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--listen=[Listen address]:address' \
          '--port=[Listen port]:port' && ret=0
        ;;
    esac
    ;;
esac

return ret
