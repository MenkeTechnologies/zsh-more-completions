#compdef sustatic
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/statics/sustatic.c
# elevation static corrections

local ret=1

_arguments -s -S \
  'v0=[weathering velocity]:v0' \
  'v1=[subweathering velocity]:v1' \
  'hdrs=[statics source: 0=calc 1=headers 2=files 3=suresstat]:hdrs:(0 1 2 3)' \
  'sign=[apply or negate static correction]:sign:(1 -1)' \
  'sou_file=[input file for source statics (ms)]:file:_files' \
  'rec_file=[input file for receiver statics (ms)]:file:_files' \
  'ns=[number of sources]:ns' \
  'nr=[number of receivers]:nr' \
  'no=[number of offsets]:no' \
  '*:file:_files' && ret=0


return ret
