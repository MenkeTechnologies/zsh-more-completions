(( $+functions[_octocode_commands] )) ||
_octocode_commands() {
    local commands; commands=(
'index:Index the current directory'\''s codebase' \
'search:Search the codebase with a natural language query' \
'view:View file signatures (functions, methods, etc.)' \
'watch:Watch for changes in the codebase and reindex automatically' \
'config:Generate a default configuration file' \
'grep:Structural code search using AST patterns (ast-grep syntax)' \
'graphrag:Query and explore the code relationship graph (GraphRAG)' \
'mcp:Start MCP (Model Context Protocol) server' \
'mcp-proxy:Start MCP proxy server for multiple repositories' \
'stats:Show index statistics and health' \
'explain:Explain code using indexed context and AI' \
'diff:Analyze code changes with AI-powered behavioral summary' \
'clear:Clear database tables (useful for debugging)' \
'branch:Manage branch delta indexes (list, info, delete, prune)' \
'commit:Generate and create git commit with AI assistance' \
'review:Review staged changes for best practices and potential issues' \
'release:Create a new release with AI-powered version calculation and changelog generation' \
'format:Format code according to .editorconfig rules' \
'logs:View MCP server logs' \
'models:Model management and discovery commands' \
'completion:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'octocode commands' commands "$@"
}
(( $+functions[_octocode__subcmd__branch_commands] )) ||
_octocode__subcmd__branch_commands() {
    local commands; commands=(
'list:List all indexed branch deltas' \
'info:Show info about a branch delta index' \
'delete:Delete a branch delta index' \
'prune:Remove indexes for branches that no longer exist in git or are merged' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'octocode branch commands' commands "$@"
}
(( $+functions[_octocode__subcmd__branch__subcmd__delete_commands] )) ||
_octocode__subcmd__branch__subcmd__delete_commands() {
