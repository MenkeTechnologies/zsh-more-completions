#compdef abipkgdiff
# Documentation: https://sourceware.org/libabigail/manual/abipkgdiff.html
# libabigail tool to compare the ABIs of binaries in two packages

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debug-info-pkg1[first debug info package]:file:_files' \
  '--debug-info-pkg2[second debug info package]:file:_files' \
  '--devel-pkg1[first development package]:file:_files' \
  '--devel-pkg2[second development package]:file:_files' \
  '--drop-private-types[exclude types not in headers]' \
  '--fail-no-dbg[fail if no debug info is found]' \
  '*--suppressions[suppression specification file]:file:_files' \
  '--no-default-suppression[do not load default suppressions]' \
  '--no-abignore[do not load in-package suppressions]' \
  '--dso-only[compare only shared libraries]' \
  '--private-dso[compare private shared libraries too]' \
  '--no-added-binaries[do not show added binaries]' \
  '--no-added-syms[do not show added symbols]' \
  '--no-unreferenced-symbols[do not show unreferenced symbols]' \
  '--no-linkage-name[do not display linkage names]' \
  '(-l --leaf-changes-only)'{-l,--leaf-changes-only}'[emit only leaf changes]' \
  '(-f --full-impact)'{-f,--full-impact}'[emit a full impact report]' \
  '--impacted-interfaces[show impacted interfaces]' \
  '--harmless[display only the harmless changes]' \
  '--redundant[display redundant changes]' \
  '--show-identical-binaries[show binaries with no ABI change]' \
  '--no-show-locs[do not show source locations]' \
  '--no-show-relative-offset-changes[do not show relative offset changes]' \
  '--verbose[enable verbose logging]' \
  '--verbose-diff[verbose diff output]' \
  '--keep-tmp-files[do not delete temporary files]' \
  '--self-check[perform a self check]' \
  '--set1[set name for first package]:name' \
  '--set2[set name for second package]:name' \
  '(-w --linux-kernel-abi-whitelist)'{-w,--linux-kernel-abi-whitelist}'[kernel ABI whitelist]:file:_files' \
  '--wp[kernel ABI whitelist package]:file:_files' \
  '*:package:_files' && ret=0

return ret
