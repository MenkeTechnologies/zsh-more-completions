#compdef jug
# Documentation: https://jug.readthedocs.io/en/latest/subcommands.html
# Task-based parallelization framework for Python

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--jugdir=[directory holding the computation results]:dir:_files -/' \
  '--verbose=[set the logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--short[reduce status output]' \
  '--aggressive-unload[aggressively unload results from memory]' \
  '--pdb[drop into the debugger on error]' \
  '--debug[enable debug mode]' \
  '--will-cite[acknowledge citation request without prompting]' \
  '1:command:((
    execute\:"execute all tasks in the jugfile"
    status\:"print the status of the computation"
    check\:"exit 0 if all tasks have run, 1 otherwise"
    invalidate\:"invalidate results of the given task groups"
    cleanup\:"remove store elements not used by the jugfile"
    shell\:"drop into an IPython shell with the jugfile loaded"
    sleep-until\:"wait until all tasks are completed"
    demo\:"run a built-in demonstration"
    webstatus\:"serve a web-based status page"
    install-skills\:"copy the bundled jug assistant skill to a directory"
  ))' \
  '*::arg:_files -g "*.py"' && ret=0

return ret
