#compdef ExtractOriginalAlignmentRecordsByNameSpark
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/spark/sv/utils/ExtractOriginalAlignmentRecordsByNameSpark.java
# GATK Spark: extract reads whose names appear in a given list

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  {-f,--read-name-file=}'[file containing list of read names]:file:_files' \
  {-v,--invert-match}'[invert the list, filtering out matching read names]' \
  {-O,--output=}'[file to write reads to]:file:_files' \
  '*:argument:_files' && ret=0

return ret
