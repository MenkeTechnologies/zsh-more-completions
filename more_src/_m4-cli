#compdef m4-cli
# _m4-cli — GNU m4 macro processor CLI alias (GNU team, C); custom argparse
# upstream: https://www.gnu.org/software/m4/

_m4-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-G[no GNU extensions]' \
        '--traditional[no GNU extensions]' \
        '-E[treat warnings as errors]' \
        '--fatal-warnings[treat warnings as errors]' \
        '-Q[suppress warnings about missing macro args]' \
        '--quiet[suppress warnings]' \
        '--silent[suppress warnings]' \
        '-D+[macro=value]:str:' \
        '--define=+[macro=value]:str:' \
        '-I+[include directory]:dir:_files -/' \
        '--include=+[include directory]:dir:_files -/' \
        '-s[generate sync lines]' \
        '--synclines[generate sync lines]' \
        '-U+[undefine macro]:str:' \
        '--undefine=+[undefine macro]:str:' \
        '-t+[trace macro]:str:' \
        '--trace=+[trace macro]:str:' \
        '-d+[debug level]:str:' \
        '--debug=+[debug level]:str:' \
        '--debugfile=+[file]:file:_files' \
        '-l+[stack trace lines]:n:' \
        '--arglength=+[arglength]:n:' \
        '-F+[stack trace lines]:n:' \
        '--freeze-state=+[file]:file:_files' \
        '-R+[reload state file]:file:_files' \
        '--reload-state=+[file]:file:_files' \
        '-e[interactive]' \
        '--interactive[interactive]' \
        '-P[prefix-builtins]' \
        '--prefix-builtins[prefix-builtins]' \
        '-H+[hashsize]:n:' \
        '--hashsize=+[hashsize]:n:' \
        '-N+[diversions]:n:' \
        '--diversions=+[diversions]:n:' \
        '-B+[bufsize]:n:' \
        '--nesting-limit=+[limit]:n:' \
        '-L+[nesting limit]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-G[no GNU extensions]' \
        '*:files:_files -g "*.{m4,ac,in,mc}"'
}

_m4-cli "$@"
