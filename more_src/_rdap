#compdef rdap

# https://github.com/openrdap/rdap — kingpin/v2 (usage in cli.go)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose on stderr]' \
  '(-T --timeout)'{-T+,--timeout=}'[timeout seconds]:secs:' \
  '(-k --insecure)'{-k,--insecure}'[skip TLS verification]' \
  '--text[plain text tree output]' \
  '(-w --whois)'{-w,--whois}'[WHOIS-style domain output]' \
  '(-j --json)'{-j,--json}'[pretty JSON]' \
  '(-r --raw)'{-r,--raw}'[raw server payload]' \
  '(-s --server)'{-s+,--server=}'[explicit RDAP server URL]:url:' \
  '(-t --type)'{-t+,--type=}'[force query type]:type:(ip domain autnum nameserver entity help url domain-search domain-search-by-nameserver domain-search-by-nameserver-ip nameserver-search nameserver-search-by-ip entity-search entity-search-by-handle)' \
  '--cache-dir=[bootstrap cache dir]:dir:_directories' \
  '--bs-url=[IANA bootstrap JSON URL]:url:' \
  '--bs-ttl=[bootstrap cache TTL seconds]:secs:' \
  '(-P --p12)'{-P+,--p12=}'[PKCS#12 client cert path]:file:_files' \
  '(-C --cert)'{-C+,--cert=}'[PEM client certificate]:file:_files' \
  '(-K --key)'{-K+,--key=}'[PEM private key]:file:_files' \
  '*:DOMAIN|IP|ASN|ENTITY|NS|RDAP-URL:_default'
