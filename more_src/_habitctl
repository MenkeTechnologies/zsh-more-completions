#compdef habitctl
# Documentation: https://github.com/blinry/habitctl
# Terminal habit tracker

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'log:interactively log habits for today'
      'todo:show unlogged habits for today'
      'status:show habit status and streaks'
      'edit:edit habits file'
      'edith:edit habit log file'
      'help:show help'
    )
    _describe -t commands 'habitctl command' commands && ret=0
    ;;
esac

return ret
