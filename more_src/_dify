#compdef dify
# Documentation: https://man.archlinux.org/search?q=dify
# Reference accessed: 2026-05-16

# Zsh completion for Dify CLI
# https://github.com/langgenius/dify

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'plugin:Manage Dify plugins'
  'version:Show version'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'dify command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (plugin)
        _arguments -s -S \
          '1:subcommand:(init package lint)' && ret=0
        ;;
    esac
    ;;
esac

return ret
