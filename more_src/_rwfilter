#compdef rwfilter rwstats rwsort rwuniq rwcat rwcount rwfileinfo rwgroup
# Documentation: https://tools.netsa.cert.org/silk/rw{filter,stats,sort,uniq,cat,count,fileinfo,group}.html
# Reference accessed: 2026-05-30
# SiLK — CERT NetSA's System for Internet-Level Knowledge. Flow-record
# analysis suite for IPFIX/NetFlow. The 8 rw* tools share an output
# framework but each has its own selection/aggregation surface; multi-stem
# dispatch on $service.

local curcontext="$curcontext" state line ret=1

# Shared output / config flags that appear in most tools.
local -a _io
_io=(
  '--output-path=[output path (default stdout)]:path:_files'
  '*--xargs=-[read filenames from FILE (or stdin)]:file:_files'
  '--print-filenames[print processed file names]'
  '--compression-method=[output compression]:method:(none zlib lzo1x snappy best)'
  '--note-add=[add annotation to output header]:note:'
  '--note-file-add=[add file contents as annotation]:file:_files'
  '--site-config-file=[SiLK site config]:file:_files'
  '*--plugin=[load C plugin]:plugin:_files'
  '*--pmap-file=[prefix-map file (MAPNAME:PATH)]:spec:'
  '*--python-file=[load Python field code]:file:_files -g "*.py"'
  '--temp-directory=[temp file location]:dir:_files -/'
  '(- *)--help[show help]'
  '(- *)--version[show version]'
  '(- *)--help-fields[show field descriptions]'
)

case $service in

  rwfilter)
    _arguments -s -S \
      $_io \
      '--start-date=[selection start (YYYY/MM/DD[:HH])]:date:' \
      '--end-date=[selection end (YYYY/MM/DD[:HH])]:date:' \
      '--data-rootdir=[override data repo location]:dir:_files -/' \
      '--class=[traffic class]:class:' \
      '--type=[flow direction/types]:type:' \
      '--flowtypes=[combined class/type]:flowtype:' \
      '--sensors=[collection sensors]:sensors:' \
      '*--scidr=[source CIDR]:cidr:' \
      '*--dcidr=[destination CIDR]:cidr:' \
      '*--any-cidr=[either-side CIDR]:cidr:' \
      '*--not-scidr=[exclude source CIDR]:cidr:' \
      '*--not-dcidr=[exclude destination CIDR]:cidr:' \
      '*--saddress=[source address (CIDR/wildcard)]:addr:' \
      '*--daddress=[destination address]:addr:' \
      '*--any-address=[either-side address]:addr:' \
      '*--sipset=[source IPset file]:file:_files' \
      '*--dipset=[destination IPset file]:file:_files' \
      '*--anyset=[either-side IPset file]:file:_files' \
      '--sport=[source port range]:range:' \
      '--dport=[destination port range]:range:' \
      '--aport=[any port range]:range:' \
      '--protocol=[IP protocol]:proto:' \
      '--icmp-type=[ICMP type]:type:' \
      '--icmp-code=[ICMP code]:code:' \
      '--flags-all=[TCP flags across all pkts]:flags:' \
      '--flags-initial=[TCP flags in first pkt]:flags:' \
      '--flags-session=[TCP flags excluding first pkt]:flags:' \
      '--bytes=[byte count range]:range:' \
      '--packets=[packet count range]:range:' \
      '--bytes-per-packet=[avg bytes-per-packet]:range:' \
      '--stime=[start-time range]:range:' \
      '--etime=[end-time range]:range:' \
      '--active-time=[active-time range]:range:' \
      '--duration=[flow duration range (seconds)]:range:' \
      '--pass-destination=[records matching ALL filters]:path:_files' \
      '--fail-destination=[records failing ANY filter]:path:_files' \
      '--all-destination=[all records regardless]:path:_files' \
      '--print-statistics[summary line of record counts]' \
      '--print-volume-statistics[detailed packet/byte breakdown]' \
      '--max-pass-records=[limit pass-records output]:N:' \
      '--max-fail-records=[limit fail-records output]:N:' \
      '--tuple-file=[multi-field text match file]:file:_files' \
      '--python-expr=[Python filter expression]:expr:' \
      '--threads=[parallel workers]:N:' \
      '--dry-run[validate args without running]' \
      '*:input file:_files' \
      && ret=0
    ;;

  rwstats)
    _arguments -s -S \
      $_io \
      '--fields=[bin key fields (required for Top-N)]:fields:' \
      '--values=[aggregate computations per bin]:values:' \
      '--count=[print top/bottom N bins (0=all)]:N:' \
      '--threshold=[print bins exceeding value]:value:' \
      '--percentage=[print bins with >= N% volume]:percent:' \
      '(--top --bottom)--top[decreasing order (default)]' \
      '(--top --bottom)--bottom[increasing order]' \
      '--no-titles[suppress section + column headers]' \
      '--column-separator=[column delimiter (default |)]:char:' \
      '*:input file:_files' \
      && ret=0
    ;;

  rwsort)
    _arguments -s -S \
      $_io \
      '--fields=[sort fields (comma-separated)]:fields:' \
      '--presorted-input[merge-sort previously-sorted files]' \
      '--reverse[reverse sort (largest first)]' \
      '--sort-buffer-size=[max buffer size (default ~2GB)]:size:' \
      '*:input file:_files' \
      && ret=0
    ;;

  rwuniq)
    _arguments -s -S \
      $_io \
      '--fields=[binning key fields (required)]:fields:' \
      '--values=[aggregate fields]:values:' \
      '--threshold=[FIELD=MIN[-MAX] filter]:spec:' \
      '--presorted-input[assume sorted input]' \
      '--sort-output[sort results by key]' \
      '--copy-input=[copy binary input to file]:file:_files' \
      '--bin-time=-[align times to N-sec boundary]:seconds:' \
      '--nano-value-times[use nanosecond precision]' \
      '--timestamp-format=[time display format]:fmt:' \
      '--epoch-time[display as epoch seconds]' \
      '--ip-format=[IP address display]:fmt:(canonical decimal hex any-cidr force-ipv6)' \
      '--integer-ips[show IPs as decimal integers]' \
      '--zero-pad-ips[pad IPv4 to 3-3-3-3]' \
      '--no-titles[omit column headers]' \
      '--no-columns[disable fixed-width formatting]' \
      '--column-separator=[column delimiter]:char:' \
      '--delimited=-[delimited output (custom char)]:char:' \
      '*:input file:_files' \
      && ret=0
    ;;

  rwcat)
    _arguments -s -S \
      $_io \
      '--byte-order=[output byte order]:order:(native big little)' \
      '--ipv4-output[convert to IPv4-only output]' \
      '*:input file:_files' \
      && ret=0
    ;;

  rwcount)
    _arguments -s -S \
      $_io \
      '--bin-size=[time-bin size (seconds, default 30)]:seconds:' \
      '--load-scheme=[bin-load distribution scheme]:scheme:(start-time end-time middle duration time-proportional minimum-volume maximum-volume)' \
      '--start-time=[count window start]:time:' \
      '--end-time=[count window end]:time:' \
      '--skip-zeroes[omit bins with zero count]' \
      '--no-titles[suppress titles]' \
      '--column-separator=[column delimiter]:char:' \
      '*:input file:_files' \
      && ret=0
    ;;

  rwfileinfo)
    _arguments -s -S \
      $_io \
      '--fields=[which info fields to display]:fields:' \
      '--summary[print summary line per file]' \
      '--no-titles[suppress field labels]' \
      '*:silk file:_files' \
      && ret=0
    ;;

  rwgroup)
    _arguments -s -S \
      $_io \
      '--id-fields=[group key fields]:fields:' \
      '--delta-field=[time-delta field]:field:' \
      '--delta-value=[max gap in delta-field]:value:' \
      '--rec-threshold=[min records per group]:N:' \
      '--objective[objective grouping]' \
      '--summarize[emit per-group summary record]' \
      '*:input file:_files' \
      && ret=0
    ;;

esac

return ret
