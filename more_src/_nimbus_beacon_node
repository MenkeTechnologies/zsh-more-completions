#compdef nimbus_beacon_node nimbus-eth2 nimbus_validator_client

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'deposits:manage validator deposits'
  'wallets:manage Nimbus wallets'
  'record:manage ENRs'
  'web3:web3 helpers'
  'slashingdb:slashing database utilities'
  'trustedNodeSync:trusted node sync helpers'
  'createTestnet:create a testnet'
  'createTestnetFile:write a testnet preset file'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config-file=[config file (TOML)]:file:_files -g "*.toml"' \
  '--log-level=[log level]:level:(INFO DEBUG TRACE NOTICE WARN ERROR FATAL NONE)' \
  '--log-format=[log format]:fmt:(auto colors nocolors json none)' \
  '--log-file=[log file]:file:_files' \
  '--data-dir=[data directory]:dir:_files -/' \
  '--validators-dir=[validators directory]:dir:_files -/' \
  '--secrets-dir=[secrets directory]:dir:_files -/' \
  '--network=[network name or path]:net:(mainnet hoodi sepolia gnosis chiado holesky goerli)' \
  '--tcp-port=[libp2p TCP port]:port:' \
  '--udp-port=[libp2p UDP port]:port:' \
  '--max-peers=[max peers]:n:' \
  '--listen-address=[listen address]:host:' \
  '--enr-auto-update[auto-update ENR]' \
  '--nat=[NAT mode]:mode:(any none extip:IP upnp pmp)' \
  '--discv5=[enable discovery v5]:bool:(true false)' \
  '*--bootstrap-node=[bootstrap node (ENR)]:enr:' \
  '*--direct-peer=[direct peer multiaddr]:peer:' \
  '--web3-url=[execution layer URL(s)]:url:' \
  '*--el=[execution layer endpoint]:url:' \
  '--rest=[enable REST API]:bool:(true false)' \
  '--rest-address=[REST listen address]:host:' \
  '--rest-port=[REST listen port]:port:' \
  '*--rest-allow-origin=[allowed REST origin]:origin:' \
  '--metrics=[enable metrics]:bool:(true false)' \
  '--metrics-address=[metrics address]:host:' \
  '--metrics-port=[metrics port]:port:' \
  '--jwt-secret=[JWT secret file]:file:_files' \
  '--suggested-fee-recipient=[fee recipient address]:addr:' \
  '--in-process-validators=[run validators in-process]:bool:(true false)' \
  '--non-interactive[run non-interactively]' \
  '--graffiti=[graffiti]:graffiti:' \
  '--subscribe-all-subnets=[subscribe to all subnets]:bool:(true false)' \
  '--num-threads=[worker threads]:n:' \
  '--validator-monitor-auto[auto-monitor active validators]' \
  '*--validator-monitor-pubkey=[monitor specific pubkey]:pubkey:' \
  '*--trusted-block-root=[trusted block root for checkpoint sync]:root:' \
  '--external-beacon-api-url=[external Beacon API URL]:url:' \
  '--validator-client-only[run validator-only mode]' \
  '--debug-forkchoice-version=[forkchoice version]:ver:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'nimbus command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deposits)
        _arguments '*::sub:(import exit)' && ret=0 ;;
      (wallets)
        _arguments '*::sub:(list create restore)' && ret=0 ;;
      (record)
        _arguments '*::sub:(create print)' && ret=0 ;;
      (slashingdb)
        _arguments '*::sub:(import export)' && ret=0 ;;
      (trustedNodeSync)
        _arguments \
          '--trusted-node-url=[trusted node URL]:url:' \
          '--state-id=[state id]:state:' && ret=0 ;;
    esac ;;
esac

return ret
