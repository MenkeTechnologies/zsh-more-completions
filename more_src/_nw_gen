#compdef nw_gen
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: generate random trees.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-g[geometric tree model instead of time-limited]' \
  '-d+[maximum depth/time (time-limited, default 3.0)]:float:' \
  '-l+[average branch length (time-limited, default 1.0)]:float:' \
  '-p+[probability a node has two children (geometric)]:float:' \
  '-s+[PRNG seed (default current time)]:int:' && ret=0

return ret
