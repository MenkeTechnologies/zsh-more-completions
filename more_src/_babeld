#compdef babeld
# Documentation: https://github.com/jech/babeld
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)-V[show version]' \
  '-m[multicast address]:addr:' \
  '-p[port]:port:' \
  '-S[state file]:file:_files' \
  '-h[hello interval]:seconds:' \
  '-H[wired hello interval]:seconds:' \
  '-M[half-time]:seconds:' \
  '-z[diversity routing kind[,factor]]:kind:' \
  '-k[kernel route priority]:prio:' \
  '-A[allow duplicating external routes prio]:prio:' \
  '-l[carrier-sense interface state]' \
  '-w[treat all interfaces as wireless]' \
  '-s[skip split-horizon on wired]' \
  '-r[random router-id]' \
  '-d[debug level]:n:' \
  '-g[read-only local config server]:port|path:' \
  '-G[read-write local config server]:port|path:' \
  '-t[install table]:table:' \
  '*-T[export-from table]:table:' \
  '*-c[config file]:file:_files' \
  '*-C[inline config statement]:stmt:' \
  '-D[daemonize]' \
  '-L[log file]:file:_files' \
  '-I[pid file]:file:_files' \
  '*:interface:_net_interfaces'
