#compdef almond
# ============================================================================
#  _almond — almond: A Scala kernel for Jupyter
#
#  Source-direct extraction from
#    https://github.com/almond-sh/almond/blob/main/modules/scala/launcher/src/main/scala/almond/launcher/LauncherOptions.scala
#    https://github.com/almond-sh/almond/blob/main/modules/echo/src/main/scala/almond/echo/EchoKernel.scala
#    https://github.com/alexarchambault/case-app (the case-app library
#    by Alex Archambault)
#
#  Maintained by almond-sh org (almond-sh/almond).  1622 GH stars.
#  almond is a Scala kernel for Jupyter — runs Scala 2.13 / 3.x code
#  cells inside Jupyter notebooks with full type checking, REPL
#  features, classpath/Ivy/Maven dependency resolution via coursier,
#  ammonite-style import-magic, variable inspector, ZeroMQ messaging.
#  Sister tools: scala-cli (in corpus, also caseapp-based), ammonite
#  (in corpus), coursier (in corpus, also caseapp-based), mill (in
#  corpus, caseapp-based), scalafmt (in corpus, caseapp-based).
#
#  CLI library taxonomy update: 4th Scala CLI library — Alex
#  Archambault's **case-app** (alexarchambault/case-app).  Scala
#  ecosystem now has 4 documented CLI libraries (R346 mainargs +
#  R360 scopt + earlier scallop + R370 case-app).
#
#  case-app (alexarchambault/case-app) is the canonical Scala CLI
#  library by Alex Archambault — used by scala-cli, coursier, mill,
#  ammonite, scalafmt, almond, bsp4j, scalameta tools, and most of
#  the modern Scala ecosystem's CLI tools.  ANNOTATION-DRIVEN CASE
#  CLASS DERIVATION — define a `case class` with default values for
#  each option, annotate fields with `@HelpMessage`/`@ValueDescription`/
#  `@ExtraName`/`@Hidden`/`@Recurse`/`@Name`, extend `CaseApp[T]`
#  and case-app derives the entire parser at compile time via Scala
#  macro / Mirror.
#
#  case-app API:
#    import caseapp._
#
#    final case class Options(
#      @HelpMessage("Show verbose output")
#      @ExtraName("V")
#        verbose: Boolean = false,
#      @HelpMessage("Output file")
#      @ValueDescription("/path/to/file")
#      @ExtraName("o")
#        output: Option[String] = None,
#      @HelpMessage("Source files")
#        input: List[String] = Nil,
#      @Recurse
#        commonOpts: CommonOptions = CommonOptions(),
#      @Hidden
#        debugMode: Boolean = false
#    )
#
#    object MyApp extends CaseApp[Options] {
#      def run(options: Options, args: RemainingArgs): Unit = {
#        if (options.verbose) println("verbose mode")
#        // ...
#      }
#    }
#
#  case-app distinctive features:
#    - ANNOTATION-DRIVEN CASE CLASS DERIVATION — define `case class` with
#      default values for each option; case-app derives parser via Scala
#      macro / Mirror at compile time
#    - `@HelpMessage("...")` — annotation for help text (per option)
#    - `@ValueDescription("...")` — annotation for VALUE PLACEHOLDER
#      shown in help (e.g. `<file>`, `<int>`, `<KEY=VALUE>`)
#    - `@ExtraName("...")` — annotation for ADDITIONAL name aliases
#      (multiple `@ExtraName` annotations supported per field)
#    - `@Name("...")` — annotation for SHORT NAME (single char)
#    - `@Hidden` — annotation to EXCLUDE from default help output
#    - `@Recurse` — annotation to NEST another options case class
#      (compositional parsers — recursive flattening)
#    - `@Tag("...")` — annotation for SECTION GROUPING in help
#    - `@Group("...")` — annotation for SECTION HEADING
#    - `@CommandName("...")` — annotation for SUBCOMMAND name override
#      (when used as Command[T] in CommandsEntryPoint)
#    - `@Inline` — annotation to INLINE another case class without
#      sub-group prefix
#    - AUTOMATIC kebab-case derivation — `extraClassPath` → `--extra-class-path`
#    - `CaseApp[T]` BASE TRAIT — extend with `def run(opts: T, args:
#      RemainingArgs): Unit` to make an executable
#    - `Command[T]` BASE TRAIT — for individual subcommands within a
#      `CommandsEntryPoint`
#    - `CommandsEntryPoint` BASE TRAIT — for multi-command CLIs with
#      `commands: Seq[Command[_]]`
#    - `Option[T]` field type — OPTIONAL value (caller may pass `--opt
#      value` or omit)
#    - `List[T]` field type — REPEATABLE option (caller passes
#      `--opt value1 --opt value2 ...`)
#    - `Boolean` field type — FLAG (no value; `--opt` enables)
#    - `Option[Boolean]` field type — TRI-STATE flag (true/false/unset
#      via `--opt=true` / `--opt=false` / omitted)
#    - REMAINING ARGS via `RemainingArgs` parameter passed to `run` —
#      gives access to positional args + args after `--`
#    - PEELED RESULTS via case class derivation — NO MUTATION; immutable
#      option struct returned from parser
#    - DEFAULT --help / --version / --usage built-in to CaseApp
#  Distinct from R346 Scala lihaoyi/mainargs (PARAMETER BINDING via
#  `@main` method parameters with default values), R360 Scala scopt
#  (DSL BUILDER `OptionParser` with chained `.opt[X]("name")` /
#  `.action`/`.text`), Scala scallop (DSL with `val opt = opt[X](...)`),
#  R275 Rust clap-derive (struct + clap-derive macro — closest analog
#  but Rust language), R363 D andrey-zherikov/argparse (D's UDA-based
#  derivation — different language).  case-app's approach: CASE CLASS
#  + RICH ANNOTATIONS + SCALA MACRO DERIVATION + IMMUTABLE OPTION
#  STRUCT + COMPOSABLE @Recurse — corpus's **first documented
#  annotation-driven-case-class-derivation-for-Scala CLI library**.
#  Brings cross-language CLI library taxonomy variant count to 109;
#  Scala ecosystem now has 4 documented CLI libraries.
#
#  Surface (verbatim from LauncherOptions.scala fields, automatic
#  kebab-case derivation applied):
#
#  Options (all from LauncherOptions case class):
#    --install                            Install the Jupyter kernel
#    --log LEVEL                          Log level (debug/info/warn/error)
#    --connection-file FILE               Jupyter connection file path
#    --variable-inspector true|false      Enable variable inspector
#    --toree-magics true|false            Enable Apache Toree magics
#    --toree-api true|false               Enable Apache Toree API
#    --toree-compatibility true|false     Enable Apache Toree compat
#    --color true|false                   Enable ANSI color output
#    --log-to FILE                        Send log to file (not stderr)
#                                         (ValueDescription: /path/to/log-file)
#    --scala VERSION                      Scala version (e.g. 3.3.4)
#    --extra-class-path PATH              Extra classpath entry (repeatable)
#    --extra-cp PATH                      Alias for --extra-class-path
#    --extraClasspath PATH                Alias for --extra-class-path
#    --predef PATH                        Predef script path (repeatable)
#    --extra-startup-class-path PATH      Extra startup classpath (repeatable)
#    --shared-dependencies DEP            Shared dependency (repeatable)
#    --compile-only true|false            Compile only, no execution
#    --java-opt OPT                       Java VM option (repeatable)
#    --quiet true|false                   Suppress non-essential output
#    --silent-imports true|false          Suppress import echoing
#    --use-notebook-coursier-logger true|false   Use notebook coursier logger
#    --custom-directive-group PREFIX:CMD  Custom directive group (repeatable)
#    --linger DURATION                    Client linger time (Hidden)
#    --bind-to-random-ports true|false    Bind to random available ports
#                                         if zero-d ports in connection file
#    --wrapper-name NAME                  Class name to wrap user code (Hidden)
#    --pkg-name NAME                      Package name for user code (Hidden)
#    --output-directory PATH              Output directory
#    --outputDir PATH                     Alias for --output-directory
#    --tmp-output-directory true|false    Use tmp output directory
#    --tmpOutputDir VAL                   Alias for --tmp-output-directory
#    --log-code true|false                Log user code (Hidden)
#
#  case-app built-in flags (always present):
#    --help, -h                           Show help
#    --usage                              Show short usage
#    --version                            Show version
#
#  Install subcommand options (from InstallOptions via @Recurse):
#    --jupyter-path PATH                  Jupyter kernels.d directory
#    --global                             Install kernel globally
#    --force                              Overwrite existing kernel
#    --id ID                              Kernel ID
#    --display-name NAME                  Kernel display name
#    --language LANG                      Kernel language (Scala/...)
#    --copy-launcher true|false           Copy launcher binary
#    --module-path PATH                   Module path
#
#  Dup-skipped neighbors during hunt (in corpus, also caseapp-based,
#  already documented):
#    - scala-cli (Scala 3 official CLI — IN CORPUS via _scala-cli)
#    - coursier / cs (Scala launcher — IN CORPUS via _coursier)
#    - mill (Scala build tool — IN CORPUS via _mill)
#    - ammonite / amm (Scala REPL — IN CORPUS via _ammonite)
#    - scalafmt (Scala formatter — IN CORPUS via _scalafmt)
#    - bloop (Scala build server — IN CORPUS via _bloop)
# ============================================================================

_almond() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--install[install the Jupyter kernel]' \
    '--log[log level]:level:(debug info warn error)' \
    '--connection-file[Jupyter connection file path]:file:_files' \
    '--variable-inspector[enable variable inspector]:flag:(true false)' \
    '--toree-magics[enable Apache Toree magics]:flag:(true false)' \
    '--toree-api[enable Apache Toree API]:flag:(true false)' \
    '--toree-compatibility[enable Apache Toree compatibility]:flag:(true false)' \
    '--color[enable ANSI color output]:flag:(true false)' \
    '--log-to[send log to file (rather than stderr)]:file:_files' \
    '--scala[Scala version (e.g. 3.3.4)]:version' \
    '*--extra-class-path[extra classpath entry]:path:_files' \
    '*--extra-cp[alias for --extra-class-path]:path:_files' \
    '*--extraClasspath[alias for --extra-class-path]:path:_files' \
    '*--predef[predef script path]:file:_files' \
    '*--extra-startup-class-path[extra startup classpath entry]:path:_files' \
    '*--shared-dependencies[shared dependency]:dep' \
    '--compile-only[compile only, no execution]:flag:(true false)' \
    '*--java-opt[Java VM option]:opt' \
    '--quiet[suppress non-essential output]:flag:(true false)' \
    '--silent-imports[suppress import echoing]:flag:(true false)' \
    '--use-notebook-coursier-logger[use notebook coursier logger]:flag:(true false)' \
    '*--custom-directive-group[custom directive group prefix:command]:group' \
    '--linger[client linger time (e.g. 5 seconds, Inf)]:duration' \
    '--bind-to-random-ports[bind to random available ports if zero-d in connection file]:flag:(true false)' \
    '--wrapper-name[class name to wrap user code]:name' \
    '--pkg-name[package name for user code]:name' \
    '--output-directory[output directory]:path:_directories' \
    '--outputDir[alias for --output-directory]:path:_directories' \
    '--tmp-output-directory[use tmp output directory]:flag:(true false)' \
    '--tmpOutputDir[alias for --tmp-output-directory]:flag:(true false)' \
    '--log-code[log user code]:flag:(true false)' \
    '--jupyter-path[Jupyter kernels.d directory]:path:_directories' \
    '--global[install kernel globally]' \
    '--force[overwrite existing kernel]' \
    '--id[kernel ID]:id' \
    '--display-name[kernel display name]:name' \
    '--language[kernel language]:lang' \
    '--copy-launcher[copy launcher binary]:flag:(true false)' \
    '--module-path[module path]:path:_directories' \
    '(- *)'{--help,-h}'[show help]' \
    '(- *)--usage[show short usage]' \
    '(- *)--version[show version]'
}

_almond "$@"
