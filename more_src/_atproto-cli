#compdef atproto-cli
# _atproto-cli — Bluesky AT Protocol CLI alias (bluesky-social team, TypeScript); commander
# upstream: https://github.com/bluesky-social/atproto

_atproto-cli() {
    local -a sub=(
        'login:login to PDS'
        'logout:logout'
        'session:get current session'
        'session:refresh:refresh session'
        'account:create:create account'
        'account:get:get account info'
        'account:request-password-reset:request password reset'
        'account:reset-password:reset password'
        'account:delete:delete account'
        'account:request-delete:request account deletion'
        'account:update-handle:update handle'
        'account:update-email:update email'
        'feed:get-timeline:get timeline'
        'feed:get-author-feed:get user feed'
        'feed:get-likes:get likes'
        'feed:get-reposts:get reposts'
        'feed:get-post-thread:get thread'
        'feed:search-posts:search posts'
        'post:create:create post'
        'post:delete:delete post'
        'post:like:like post'
        'post:unlike:unlike post'
        'post:repost:repost'
        'post:unrepost:unrepost'
        'reply:create:reply to post'
        'graph:get-followers:get followers'
        'graph:get-follows:get follows'
        'graph:follow:follow user'
        'graph:unfollow:unfollow user'
        'graph:block:block user'
        'graph:unblock:unblock user'
        'graph:mute:mute user'
        'graph:unmute:unmute user'
        'graph:list:get list'
        'graph:list-create:create list'
        'graph:list-delete:delete list'
        'identity:resolve:resolve handle'
        'identity:update-handle:update handle'
        'profile:get:get profile'
        'profile:update:update profile'
        'notifications:list:list notifications'
        'notifications:update-seen:mark notifications seen'
        'notifications:count:get unread count'
        'blob:upload:upload blob'
        'blob:get:get blob'
        'repo:list-records:list records'
        'repo:get-record:get record'
        'repo:create-record:create record'
        'repo:put-record:update record'
        'repo:delete-record:delete record'
        'repo:apply-writes:apply writes batch'
        'repo:describe:describe repo'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--service=+[PDS service URL]:url:_urls' \
        '--identifier=+[handle or did]:str:' \
        '--password=+[app password]:str:' \
        '--access-jwt=+[access jwt]:str:' \
        '--refresh-jwt=+[refresh jwt]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'atproto subcommand' sub ;;
        args)
            case $words[1] in
                post:create|reply:create) _arguments \
                    '--text=+[text]:str:' \
                    '-t+[text]:str:' \
                    '--text-file=+[text file]:file:_files' \
                    '*--image=+[image]:file:_files' \
                    '--alt-text=+[alt text]:str:' \
                    '--lang=+[language code]:str:' \
                    '--reply-to=+[reply uri]:str:' \
                    '--reply-root=+[root uri]:str:' ;;
                post:like|post:unlike|post:repost|post:unrepost|post:delete) _arguments '1:uri:' ;;
                graph:follow|graph:unfollow|graph:block|graph:unblock|graph:mute|graph:unmute|identity:resolve) _arguments '1:handle or did:' ;;
                feed:get-author-feed|feed:get-likes|feed:get-reposts) _arguments '1:actor:' '--limit=+[limit]:n:' '--cursor=+[cursor]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_atproto-cli "$@"
