#compdef elsize
# estimate the effective electrostatic size of a structure

local ret=1

_arguments -s -S \
  '-det[electrostatic size from inertia-tensor determinant (default)]' \
  '-ell[exact electrostatic size of the effective ellipsoid]' \
  '-elf[elementary-function approximation to the ellipsoid size]' \
  '-abc[print the semiaxes of the effective ellipsoid]' \
  '-tab[print all values in table format]' \
  '-hea[print table with a header]' \
  '-deb[print additional debug information]' \
  '-xyz[input is plain XYZ rather than PQR format]' \
  '*:input file:_files -g "*.(pqr|xyz)"' && ret=0

return ret
