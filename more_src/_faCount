#compdef faCount
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# count base statistics and CpGs in fa or 2bit files

local ret=1

_arguments -s -S \
  '-summary[show only summary statistics]' \
  '-dinuc[include statistics on dinucleotide frequencies]' \
  '-strands[count bases on both strands]' \
  '*:fasta or 2bit file:_files -g "*.(fa|fasta|2bit)"' && ret=0

return ret
