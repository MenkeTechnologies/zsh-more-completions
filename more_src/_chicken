#compdef chicken
# Documentation: https://wiki.call-cc.org/man/5/Using%20the%20compiler
# Reference accessed: 2026-05-27
# Verified: upstream CHICKEN Scheme wiki "Using the compiler" manual
#           (chicken-core batch-driver.scm option list)

# Zsh completion for the chicken Scheme-to-C compiler. chicken is a
# single-binary compiler with no subcommands.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-analyze-only[stop compilation after first analysis pass]' \
  '-block[enable block compilation]' \
  '-case-insensitive[read symbols case-insensitively]' \
  '-check-syntax[abort after macro-expansion and syntax checks]' \
  '-clustering[combine local procedures into dispatch loops]' \
  '-compile-syntax[make macros also available at run time]' \
  '-consult-inline-file[load cross-module inline definitions from FILENAME]:file:_files' \
  '-consult-types-file[load additional type database from FILENAME]:file:_files' \
  '-debug[enable compiler debugging modes]:modes:' \
  '-debug-level[select amount of debug-information]:level:(0 1 2 3)' \
  '-disable-interrupts[disable interrupt checks in this unit]' \
  '-disable-stack-overflow-checks[disable stack overflow detection]' \
  '-dynamic[compile for dynamic loading]' \
  '-emit-all-import-libraries[emit import libraries for all modules]' \
  '-emit-external-prototypes-first[emit define-external prototypes first]' \
  '-emit-import-library[emit MODULE.import.scm for the given module]:module:' \
  '-emit-inline-file[write globally-inlinable procedures to FILENAME]:file:_files' \
  '-emit-link-file[write statically linked extension list to FILENAME]:file:_files' \
  '-emit-types-file[write user-defined type information to FILENAME]:file:_files' \
  '-epilogue[include FILENAME at end of source]:file:_files' \
  '-explicit-use[disable automatic use of library, eval and expand]' \
  '*-extend[load Scheme file before compilation]:file:_files' \
  '-feature[register SYMBOL as a cond-expand feature]:symbol:' \
  '-fixnum-arithmetic[assume all arithmetic uses fixnums]' \
  '-heap-size[set fixed heap size]:bytes:' \
  '(- *)-help[print help and exit]' \
  '-ignore-repository[do not load extensions from the repository]' \
  '*-include-path[add an include search path]:path:_files -/' \
  '-inline[enable procedure inlining]' \
  '-inline-global[enable cross-module inlining]' \
  '-inline-limit[max size of inlinable procedure]:threshold:' \
  '-keep-shadowed-macros[do not remove shadowed macro definitions]' \
  '-keyword-style[keyword syntax style]:style:(prefix suffix none)' \
  '-link[link extension NAME with the compiled program]:name:' \
  '-local[assume toplevel vars not modified externally]' \
  '-lfa2[run an additional lightweight flow-analysis pass]' \
  '-module[wrap compiled code in an implicit module NAME]:name:' \
  '-no-argc-checks[disable argument count checks]' \
  '-no-bound-checks[disable bound variable checks]' \
  '-no-feature[disable predefined feature-identifier SYMBOL]:symbol:' \
  '-no-lambda-info[do not emit lambda info]' \
  '-no-module-registration[do not generate module-registration code]' \
  '-no-parentheses-synonyms[disable [] and {} list delimiters]' \
  '-no-procedure-checks[disable procedure call checks]' \
  '-no-procedure-checks-for-usual-bindings[disable proc checks for usual bindings]' \
  '-no-procedure-checks-for-toplevel-bindings[disable proc checks for toplevel bindings]' \
  '-no-symbol-escape[disable escaped symbols |...|]' \
  '-no-trace[disable tracing information]' \
  '-no-usual-integrations[allow redefinition of standard procedures]' \
  '-no-warnings[disable compiler warnings]' \
  '-nursery[set first-generation heap size]:bytes:' \
  '-optimize-leaf-routines[enable leaf routine optimization]' \
  '-optimize-level[enable optimization level]:level:(0 1 2 3 4 5)' \
  '-output-file[write generated C file to FILENAME]:file:_files' \
  '*-postlude[append EXPRESSIONS after toplevel]:expressions:' \
  '*-prelude[prepend EXPRESSIONS before toplevel]:expressions:' \
  '-profile[instrument source code for profiling]' \
  '-accumulate-profile[like -profile but append to existing PROFILE file]' \
  '-profile-name[name of the generated profile information file]:file:_files' \
  '*-prologue[include FILENAME at start of source]:file:_files' \
  '-r5rs-syntax[disable CHICKEN R5RS syntax extensions]' \
  '-raw[disable implicit Scheme library code]' \
  '-regenerate-import-libraries[always emit new import libraries]' \
  '-require-extension[load extension NAME before compilation]:name:' \
  '-setup-mode[search current directory first for extensions]' \
  '-specialize[enable simple flow analysis for type-directed opts]' \
  '-stack-size[set first heap generation stack size]:bytes:' \
  '-static[link extensions statically when possible]' \
  '-strict-types[assume variable types do not change]' \
  '-to-stdout[write compiled code to stdout]' \
  '-unit[compile this file as library unit NAME]:name:' \
  '-unroll-limit[direct recursive call unroll limit]:limit:' \
  '-unsafe[disable runtime safety checks]' \
  '-uses[use definitions from library unit NAME]:name:' \
  '-verbose[enable output of informational notes]' \
  '(- *)-version[print version and exit]' \
  '*:Scheme source file:_files -g "*.(scm|ss|sld)(-.)"' && ret=0

return ret
