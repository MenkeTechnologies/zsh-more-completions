#compdef list_events
# Documentation: https://www.desy.de/~twhite/crystfel/manual-list_events.html
# Expand a file list into a list of events using the geometry (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-i --input)'{-i+,--input=}'[read input filenames from file]:file:_files' \
  '(-g --geometry)'{-g+,--geometry=}'[read data layout/geometry from file]:file:_files' \
  '(-o --output)'{-o+,--output=}'[write event list to file]:file:_files' && ret=0

return ret
