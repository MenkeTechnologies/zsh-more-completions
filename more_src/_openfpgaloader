#compdef openFPGALoader openfpgaloader
# _openfpgaloader — Trabucayre openFPGALoader CLI universal cross-vendor FPGA bitstream loader speaking JTAG SPI DFU SVF for Lattice Xilinx Intel Gowin Anlogic Cologne Efinix Microchip targets over FTDI Black Magic Probe USB-Blaster JLink (Gwenhael Goavec-Merou team, C++); custom argparse
# upstream: https://github.com/trabucayre/openFPGALoader

_openfpgaloader() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-b+[board]:b:(arty arty-a7-35t arty-a7-100t arty-s7-25 arty-s7-50 basys3 colorlight-i5 colorlight-i9 cmod-a7-35 cmod-a7-15 ecpix5 fomu-pvt fomu-evt fomu-hacker ice40_generic ice40hx8k-evb icebreaker icefun icestick icesugar icesugar-nano kintex7_310t machxo2-mini machxo3-starter olimex-stm32-jlink olimex-h405 olimex-h407 olinuxino-pn7150 orangecrab tang-nano-1 tang-nano-4 tang-nano-9 tang-nano-20 tang-primer-20 tang-primer-25 ulx3s xula2 zc702 zedboard zybo)' \
        '-c+[cable]:c:(anlogicCable arm-usb-tiny-h arm-usb-ocd-h cmsisdap_v2 ch347_jtag digilent ft2232 ft231X ft232 ft232RL gatemate_pgm jlink ji2c jtag-smt2-nc gwu2x usb-blaster usb-blaster-ii xvc-client dirtyjtag stlink-dap c232hm)' \
        '-d+[device path]:file:_files -g "/dev/*"' \
        '-D[detect chain]' \
        '--detect[detect chain]' \
        '-f[flash]' \
        '--write-flash[write SPI flash]' \
        '--read-flash[read SPI flash]' \
        '--write-sram[write FPGA SRAM]' \
        '--unprotect-flash[unprotect SPI flash]' \
        '--protect-flash=+[BP bytes]:str:' \
        '--bulk-erase[bulk erase flash]' \
        '-o+[offset]:str:' \
        '--offset=+[offset]:str:' \
        '-F+[freq Hz]:n:' \
        '--freq=+[freq Hz]:n:' \
        '--ftdi-channel=+[channel]:c:(A B C D)' \
        '--ftdi-serial=+[serial]:str:' \
        '--ft231x[FT231X mode]' \
        '--vid=+[USB VID]:str:' \
        '--pid=+[USB PID]:str:' \
        '--cable-index=+[idx]:n:' \
        '--bus=+[bus]:n:' \
        '--device=+[USB device]:n:' \
        '--ip=+[host]:host:' \
        '--probe-firmware=+[file]:file:_files' \
        '-r[reset]' \
        '--reset[reset]' \
        '--scan-usb[scan USB]' \
        '--list-cables[list cables]' \
        '--list-boards[list boards]' \
        '--list-fpga[list FPGAs]' \
        '--read-register=+[reg]:str:' \
        '--write-register=+[reg=value]:str:' \
        '--idcode=+[idcode hex]:str:' \
        '--svf=+[svf out]:file:_files -g "*.svf"' \
        '*:bitstream:_files -g "*.bit *.bin *.svf *.jed *.fs *.fsb *.rbf *.mcs *.dfu *.pof *.jic"'
}

_openfpgaloader "$@"
