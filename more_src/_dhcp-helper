#compdef dhcp-helper
# _dhcp-helper — Simon Kelley dhcp-helper DHCP/BOOTP relay agent for forwarding DHCP packets between interfaces (thekelleys team, C); custom argparse
# upstream: https://thekelleys.org.uk/dhcp-helper/

_dhcp-helper() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-d[debug mode]' \
        '-l[disable proxying]' \
        '-n[no daemon mode]' \
        '-P+[pid file]:file:_files' \
        '-r+[receive on interfaces]:str:' \
        '-s+[send server]:host:_hosts' \
        '-S+[server alias]:str:' \
        '-u+[run as user]:user:_users' \
        '-b+[broadcast]:str:' \
        '-i+[include interface]:str:' \
        '-x+[exclude interface]:str:' \
        '-c+[max hop count]:n:'
}

_dhcp-helper "$@"
