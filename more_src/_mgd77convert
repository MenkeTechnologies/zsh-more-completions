#compdef mgd77convert
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/mgd77 — convert MGD77 cruise data between file formats

local ret=1

_arguments -s \
  '-F+[input format a|c|m|t]:format:(a c m t)' \
  '-T+[output format a|c|m|t (+f force)]:format:(a c m t)' \
  '-C[convert NCEI two-file (.h77/.a77) to single file]' \
  '-D[use 4-byte integers for grav/mag/depth]' \
  '-L+[verification reporting level w|e (+l stdout)]:level:_default' \
  '*-V[verbose (stackable)]' \
  '*:cruise id:_files' \
  && ret=0

return ret
