#compdef cobblerd
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/cobblerd.1.html
# Reference accessed: 2026-05-17
# Verified: Ubuntu cobblerd(1) manpage option list (-h/--help,
# -B/--daemonize, -F/--no-daemonize, -f/--log-file, -l/--log-level).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --version, -d/--debug, -l (as syslog), --log,
# --logfile, --pidfile, --disable-acl, --reload-templates (none
# of these appear in the official manpage).

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-B --daemonize)'{-B,--daemonize}'[run as daemon]' \
  '(-F --no-daemonize)'{-F,--no-daemonize}'[run in foreground]' \
  '(-f --log-file)'{-f+,--log-file=}'[log file name]:file:_files' \
  '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(INFO WARNING ERROR CRITICAL)' && ret=0
return ret
