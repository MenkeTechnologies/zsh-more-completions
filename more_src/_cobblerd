#compdef cobblerd

# cobblerd: Cobbler provisioning server daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '-F[run in foreground (no daemon)]' \
  '--no-fork[run in foreground (no daemon)]' \
  '-d[debug logging]' \
  '--debug[debug logging]' \
  '-l[log to syslog]' \
  '--log=[log to file]:file:_files' \
  '--logfile=[log to file]:file:_files' \
  '--pidfile=[PID file]:file:_files' \
  '--disable-acl[disable HTTP basic auth]' \
  '--reload-templates[reload templates without restart]' \
  '*::cobblerd extra args:_files' && ret=0
return ret
