#compdef cobblerd

# cobblerd: Cobbler provisioning server daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-B --no-fork)'{-B,--no-fork}'[do not daemonise]' \
  '(-F --no-fork-debug)'{-F,--no-fork-debug}'[no fork, with debug logging]' \
  '(-d --daemonize)'{-d,--daemonize}'[run as daemon (default)]' \
  '(-l --log-level)'{-l,--log-level=}'[log verbosity]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files -g "*.yaml"' \
  '(--disable-internal-tftp-server)--disable-internal-tftp-server[disable built-in TFTP]' \
  '*::cobblerd args:_files' && ret=0
return ret
