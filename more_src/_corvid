_corvid() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_corvid_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                new)
                    _arguments \
                        ':project name:' && ret=0 ;;
                check)
                    _arguments \
                        ':Corvid source file:_files -g "*.cor"' && ret=0 ;;
                build)
                    _arguments \
                        '--target=[output target (default python)]:target:(python native server wasm cdylib staticlib)' \
                        '--with-tools-lib=[compiled tool staticlib path]:path:_files' \
                        '--header[emit companion C header]' \
                        '--abi-descriptor[emit ABI descriptor (cdylib only)]' \
                        '--all-artifacts[emit every supported companion artifact]' \
                        '--sign=[sign cdylib ABI descriptor with ed25519 key]:key path:_files' \
                        '--key-id=[opaque key identifier]:keyid:' \
                        ':Corvid source file (default src/main.cor):_files -g "*.cor"' && ret=0 ;;
                run)
                    _arguments \
                        '--target=[output target]:target:(python native server wasm cdylib)' \
                        ':Corvid source file (default src/main.cor):_files -g "*.cor"' && ret=0 ;;
                test)
                    _arguments \
                        ':file or suite (dimensions/spec/rewrites/adversarial):' && ret=0 ;;
                replay|eval)
                    _arguments \
                        '--model=[differential replay against different model]:model id:' \
                        '--swap-model=[retrospective model-migration analysis]:model id:' \
                        ':trace file or id:' && ret=0 ;;
                abi)
                    _arguments \
                        '1:abi subcommand:(dump)' \
                        '*:library path:_files' && ret=0 ;;
                trace)
                    _arguments \
                        '1:trace subcommand:(list show dag)' \
                        '*:trace id:' && ret=0 ;;
                claim)
                    _arguments \
                        '--explain=[explain guarantees claimed by cdylib]:lib path:_files' && ret=0 ;;
                add|remove|update|add-dimension|verify|effect-diff|repl|routing-report|cost-frontier|tour|import-summary)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_corvid_commands] )) ||
_corvid_commands() {
    local -a commands
    commands=(
        'new:scaffold a new Corvid project'
        'check:type-check a Corvid source file'
        'build:compile a Corvid source file'
        'run:compile and run a Corvid source file'
        'repl:start the interactive REPL'
        'test:run Corvid tests / verification suites'
        'verify:cross-tier effect-profile verification'
        'effect-diff:diff composed effect profiles between revisions'
        'add:add a package dependency'
        'remove:remove a package dependency'
        'update:refresh a package dependency'
        'add-dimension:install a dimension from the effect registry'
        'routing-report:aggregate dispatch traces into routing guidance'
        'cost-frontier:compute prompt cost/quality Pareto frontier'
        'tour:open runnable demos for Corvid inventions'
        'import-summary:inspect imported module semantic contracts'
        'eval:retrospective model-migration analysis'
        'replay:re-execute a recorded trace deterministically'
        'abi:inspect the embedded ABI/capability catalog'
        'trace:trace inspection (list/show/dag)'
        'claim:explain guarantees claimed by a cdylib'
        'app:application management'
        'approvals:approval workflow'
        'approver:approver card management'
        'audit:audit log'
        'auth:authentication management'
        'bench:benchmark'
        'bind:binding'
        'bundle:bundle commands'
        'capsule:capsule commands'
        'connectors:connector management (oauth)'
        'contract:contract commands'
        'deploy:deploy commands'
        'doctor:diagnostic'
        'jobs:job management (explain)'
        'lineage:provenance lineage'
        'migrate:migration commands'
        'observe:observability'
        'ops:operations'
        'package:package management'
        'receipt:receipt commands (verify-abi)'
        'release:release commands'
        'review-queue:review-queue commands'
        'serve:HTTP service hosting'
        'upgrade:upgrade commands'
    )
    _describe -t commands 'corvid command' commands
}

_corvid "$@"
