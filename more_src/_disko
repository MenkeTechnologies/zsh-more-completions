#compdef disko

# Zsh completion for disko (NixOS disk partitioning)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '--version[Print version]' \
  '--debug[Enable debug output]' \
  '--dry-run[Show commands without executing]' \
  '--no-deps[Do not handle dependencies]' \
  '--root-mountpoint=[Root mountpoint]:dir:_directories' \
  '--mode=[Operation mode]:mode:(format mount disko destroy)' \
  '--flake=[Flake reference for disko config]:flake' \
  '--arg=[Pass argument to Nix expression]:arg' \
  '--argstr=[Pass string argument to Nix expression]:arg' \
  '--show-trace[Show Nix evaluation trace on error]' \
  '1:disko-config:_files -g "*.nix"' && ret=0

return ret
