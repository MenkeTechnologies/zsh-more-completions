#compdef tgtadm
# Documentation: https://man.archlinux.org/search?q=tgtadm
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-C --control-port)'{-C,--control-port}'+[control port]:port:' \
  '(-L --lld)'{-L,--lld}'+[low-level driver]:driver:(iscsi iser fc)' \
  '(-o --op)'{-o,--op}'+[operation]:op:(new delete bind unbind show update stats)' \
  '(-m --mode)'{-m,--mode}'+[object mode]:mode:(target lu account portal session connection sys)' \
  '(-t --tid)'{-t,--tid}'+[target ID]:tid:' \
  '(-T --targetname)'{-T,--targetname}'+[target IQN]:iqn:' \
  '(-Y --type)'{-Y,--type}'+[device type]:type:(disk tape ssc cd changer mmc osd pt)' \
  '(-B --bstype)'{-B,--bstype}'+[backend driver]:bstype:(rdwr aio sg ssc smc)' \
  '(-E --bsoflags)'{-E,--bsoflags}'+[backend open flags]:flags:(sync direct)' \
  '(-b --backing-store)'{-b,--backing-store}'+[backing store file]:file:_files' \
  '(-l --lun)'{-l,--lun}'+[LUN number]:lun:' \
  '(-I --initiator-address)'{-I,--initiator-address}'+[initiator IP]:ip:' \
  '(-Q --initiator-name)'{-Q,--initiator-name}'+[initiator IQN]:iqn:' \
  '(-n --name)'{-n,--name}'+[parameter name]:name:' \
  '(-v --value)'{-v,--value}'+[parameter value]:value:' \
  '(-u --user)'{-u,--user}'+[CHAP username]:user:' \
  '(-p --password)'{-p,--password}'+[CHAP password]:pw:' \
  '(-O --outgoing)'{-O,--outgoing}'[CHAP outgoing direction]' \
  '(-f --force)'{-f,--force}'[force operation]' && ret=0

return ret
