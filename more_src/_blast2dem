#compdef blast2dem
# Documentation: https://github.com/LAStools/LAStools
# LAStools: rasterize very large LAS/LAZ files into a DEM via streaming TIN

local ret=1

_arguments -s -S \
  '-help[show help documentation]' \
  '-version[display version number]' \
  '-gui[launch graphical interface]' \
  '-demo[run in demo mode]' \
  '-v[verbose output mode]' \
  '-step+[grid cell size (default 1)]:size' \
  '-grid+[raster with specified step size]:size' \
  '-ncols+[maximum number of output columns]:n' \
  '-nrows+[maximum number of output rows]:n' \
  '-ll+[lower-left corner coordinates x y]:x' \
  '-kill+[omit triangles with edges exceeding length]:meters' \
  '-elevation[use elevation values for coloring]' \
  '-slope[apply slope-based coloring]' \
  '-intensity[raster intensity values]' \
  '-hillshade[apply hillside shading]' \
  '-gray[grayscale coloring]' \
  '-false[false-color mapping]' \
  '-rgb[use RGB values when available]' \
  '-light+[light direction for hillshade x y z]:x' \
  '-invert_ramp[reverse color ramp direction]' \
  '-nbits+[bit depth for elevation representation]:n' \
  '-compute_min_max[auto-calculate color mapping range]' \
  '-set_min_max+[define custom min/max values]:min' \
  '*-keep_class+[retain points matching class]:code' \
  '-first_only[process only first returns]' \
  '-elevation_feet[express elevation in feet]' \
  '*-i+[input file(s) or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-merged[combine multiple input files]' \
  '-o+[output file]:output:_files' \
  '-oasc[save as ASCII]' \
  '-obil[save as BIL]' \
  '-otif[save as GeoTIFF]' \
  '-opng[save as PNG]' \
  '-ojpg[save as JPG]' \
  '-oimg[save as IMG]' \
  '-odtm[save as DTM]' \
  '-oxyz[save as XYZ text]' \
  '-cores+[parallel processing using multiple cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
