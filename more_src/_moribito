#compdef moribito
# Documentation: https://github.com/ericschmar/moribito
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# moribito - TUI for LDAP browsing and querying (Go, BubbleTea).
local curcontext="$curcontext" ret=1

_arguments -s \
  '-help[show help]' \
  '-host=[LDAP server hostname]:host:_hosts' \
  '-base-dn=[base distinguished name for queries]:dn' \
  '-user=[bind user for authentication]:user' \
  '-config=[path to configuration file]:file:_files' \
  '-check-updates[check for newer releases from GitHub]' \
  '--create-config[generate a configuration file interactively]' \
  '--page-size=[pagination size, overrides config]:size' && ret=0

return ret
