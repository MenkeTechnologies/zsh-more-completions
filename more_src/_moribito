#compdef moribito
# Documentation: https://man.archlinux.org/search?q=moribito
# Reference accessed: 2026-05-16

# Zsh completion for moribito — LDAP TUI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-H --host)'{-H,--host}'[LDAP host]:host' \
  '(-D --binddn)'{-D,--binddn}'[bind DN]:dn' \
  '(-b --base)'{-b,--base}'[search base]:dn' && ret=0

return ret
