#compdef incus

_incus_commands() {
  local -a commands=(
    'launch:Create and start containers or VMs'
    'init:Create containers or VMs'
    'start:Start instances'
    'stop:Stop instances'
    'restart:Restart instances'
    'delete:Delete instances'
    'exec:Execute commands in instances'
    'shell:Open a shell in an instance'
    'console:Attach to instance console'
    'list:List instances'
    'info:Show instance info'
    'config:Manage instance configuration'
    'copy:Copy instances'
    'move:Move instances'
    'rename:Rename instances'
    'snapshot:Manage snapshots'
    'restore:Restore instance snapshots'
    'publish:Publish instances as images'
    'file:Manage files in instances'
    'image:Manage images'
    'network:Manage networks'
    'storage:Manage storage pools and volumes'
    'profile:Manage profiles'
    'project:Manage projects'
    'cluster:Manage cluster members'
    'remote:Manage remotes'
    'operation:List and manage operations'
    'monitor:Monitor events'
    'alias:Manage command aliases'
    'admin:Admin commands'
    'warning:Manage warnings'
    'rebuild:Rebuild instances'
    'pause:Pause instances'
    'top:Show resource usage'
    'version:Print version'
    'help:Show help'
    'completion:Generate shell completion'
  )
  _describe -t commands 'incus command' commands
}

_incus() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '--version[Print version]' \
    '--debug[Enable debug mode]' \
    '--verbose[Enable verbose mode]' \
    '--force-local[Force using the local unix socket]' \
    '--project[Override project]:project:' \
    '--all[Show all instances]' \
    '1:command:_incus_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        launch|init)
          _arguments \
            '(-p --profile)'{-p,--profile}'[Profile]:profile:' \
            '(-c --config)'{-c,--config}'[Config key=value]:config:' \
            '(-n --network)'{-n,--network}'[Network]:network:' \
            '(-s --storage)'{-s,--storage}'[Storage pool]:pool:' \
            '--type[Instance type]:type:(container virtual-machine)' \
            '--vm[Create a virtual machine]' \
            '--empty[Create an empty instance]' \
            '--no-profiles[Do not apply default profiles]' \
            '1:image:' \
            '2:name:'
          ;;
        exec)
          _arguments \
            '--mode[Execution mode]:mode:(interactive non-interactive)' \
            '(-t --force-interactive)'{-t,--force-interactive}'[Force pseudo-terminal]' \
            '(-T --force-noninteractive)'{-T,--force-noninteractive}'[Disable pseudo-terminal]' \
            '--env[Environment variable]:env:' \
            '--cwd[Working directory]:dir:' \
            '-n[Disable stdin]' \
            '1:instance:' \
            '*:command:'
          ;;
        start|stop|restart|delete|pause)
          _arguments \
            '--all[Apply to all instances]' \
            '(-f --force)'{-f,--force}'[Force operation]' \
            '--timeout[Timeout in seconds]:seconds:' \
            '*:instance:'
          ;;
        list)
          _arguments \
            '(-f --format)'{-f,--format}'[Output format]:format:(table json csv yaml compact)' \
            '(-c --columns)'{-c,--columns}'[Columns to show]:columns:' \
            '--fast[Reduced output]' \
            '--all-projects[Show all projects]' \
            '*:filter:'
          ;;
        file)
          local -a subcommands=(
            'push:Push files to instance'
            'pull:Pull files from instance'
            'delete:Delete files in instance'
            'edit:Edit files in instance'
            'mount:Mount instance filesystem'
          )
          _describe -t subcommands 'file subcommand' subcommands
          ;;
        image)
          local -a subcommands=(
            'list:List images'
            'copy:Copy images'
            'delete:Delete images'
            'edit:Edit image properties'
            'export:Export images'
            'import:Import images'
            'info:Show image info'
            'alias:Manage image aliases'
            'refresh:Refresh images'
          )
          _describe -t subcommands 'image subcommand' subcommands
          ;;
        network)
          local -a subcommands=(
            'list:List networks'
            'create:Create a network'
            'delete:Delete a network'
            'edit:Edit a network'
            'show:Show network config'
            'set:Set network config'
            'unset:Unset network config'
            'attach:Attach network to instance'
            'detach:Detach network from instance'
            'acl:Manage network ACLs'
            'forward:Manage network forwards'
            'zone:Manage network zones'
          )
          _describe -t subcommands 'network subcommand' subcommands
          ;;
        storage)
          local -a subcommands=(
            'list:List storage pools'
            'create:Create a storage pool'
            'delete:Delete a storage pool'
            'edit:Edit a storage pool'
            'show:Show storage pool config'
            'set:Set storage pool config'
            'volume:Manage storage volumes'
            'bucket:Manage storage buckets'
          )
          _describe -t subcommands 'storage subcommand' subcommands
          ;;
        profile)
          local -a subcommands=(
            'list:List profiles'
            'create:Create a profile'
            'delete:Delete a profile'
            'edit:Edit a profile'
            'show:Show profile details'
            'set:Set profile config'
            'add:Add profile to instance'
            'remove:Remove profile from instance'
            'copy:Copy a profile'
            'rename:Rename a profile'
          )
          _describe -t subcommands 'profile subcommand' subcommands
          ;;
        config)
          local -a subcommands=(
            'set:Set instance config'
            'unset:Unset instance config'
            'get:Get instance config'
            'show:Show instance config'
            'edit:Edit instance config'
            'device:Manage instance devices'
            'metadata:Manage instance metadata'
            'template:Manage instance templates'
            'trust:Manage trust store'
          )
          _describe -t subcommands 'config subcommand' subcommands
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish)'
          ;;
      esac
      ;;
  esac
}

_incus "$@"
