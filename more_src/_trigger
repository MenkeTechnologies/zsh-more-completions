#compdef trigger
# Documentation: https://github.com/triggerdotdev/trigger.dev
# Reference accessed: 2026-05-23
# Verified: trigger.dev npm package trigger --help.

# Zsh completion for trigger - Trigger.dev background tasks CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'trigger command' \
      'login[authenticate with Trigger.dev]' \
      'init[initialize project for Trigger.dev]' \
      'dev[run tasks locally]' \
      'env[manage environment variables]' \
      'deploy[deploy project to cloud]' \
      'promote[promote deployed version]' \
      'whoami[show logged-in user and project]' \
      'logout[logout of Trigger.dev]' \
      'list-profiles[list CLI profiles]' \
      'switch[switch default CLI profile]' \
      'update[update @trigger.dev packages]' \
      'preview[modify preview branches]' \
      'mcp[run MCP server]' \
      'install-mcp[install Trigger.dev MCP server]' \
      'install-rules[install Trigger.dev agent rules]' && ret=0
    ;;
  args)
    case $line[1] in
      env)
        if (( CURRENT == 2 )); then
          _values 'env command' 'list' 'get' 'pull' && ret=0
        fi
        ;;
      deploy)
        _arguments \
          '(-e --env)'{-e+,--env=}'[deploy environment]:env:(prod staging preview)' \
          '(-b --branch)'{-b+,--branch=}'[preview branch]:branch:' \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-p --project-ref)'{-p+,--project-ref=}'[project ref]:ref:' && ret=0
        ;;
      dev)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '--env-file[env file path]:file:_files' \
          '--mcp[start MCP server]' \
          '--mcp-port[MCP server port]:port:' && ret=0
        ;;
    esac
    ;;
esac

return ret
