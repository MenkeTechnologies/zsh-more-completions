#compdef refmac5
# Documentation: https://www.ccp4.ac.uk/html/refmac5.html
# refmac5 — macromolecular refinement (CCP4)

local ret=1

_arguments -s -S \
  'HKLIN[input reflection MTZ]:file:_files -g "*.mtz"' \
  'HKLOUT[output reflection MTZ]:file:_files -g "*.mtz"' \
  'XYZIN[input coordinates PDB/mmCIF]:file:_files -g "*.(pdb|cif|ent)"' \
  'XYZOUT[output coordinates]:file:_files -g "*.(pdb|cif|ent)"' \
  'LIBIN[input ligand dictionary]:file:_files -g "*.cif"' \
  'LIBOUT[output ligand dictionary]:file:_files -g "*.cif"' \
  'TLSIN[input TLS parameters]:file:_files' \
  'TLSOUT[output TLS parameters]:file:_files' \
  'LABIN[input MTZ column labels]:labels:' \
  'NCYC[number of refinement cycles]:n:' \
  'REFI[refinement parameters]:opt:' \
  'SCAL[scale parameters]:opt:' \
  'SOLV[bulk solvent parameters]:opt:' \
  'WEIG[X-ray vs geometry weight]:opt:' \
  'MAKE[restraint generation options]:opt:' \
  'MONI[monitoring level]:opt:' \
  'END[terminate keyword input]' \
  '*:argument:_files' && ret=0

return ret
