#compdef containerd-shim-runc-v2
# _containerd-shim-runc-v2 — containerd v2 runc shim (binary that containerd execs per task; rarely invoked by humans)
# upstream: https://github.com/containerd/containerd
# Flags from pkg/shim/shim.go on tip; positional action: start / delete (else: serve task RPC over the socket).

_containerd-shim-runc-v2() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show the shim version and exit]' \
        '--debug[enable debug output in logs]' \
        '--info[print the shim info protobuf to stdout and exit]' \
        '--namespace=[namespace that owns the shim]:ns:' \
        '--id=[id of the task]:id:' \
        '--socket=[socket path to serve]:socket:_files' \
        '--debug-socket=[debug socket path to serve]:socket:_files' \
        '--bundle=[path to the bundle (only with delete)]:dir:_files -/' \
        '--address=[gRPC address back to main containerd]:addr:' \
        '--publish-binary=[binary used to publish events back to containerd]:bin:_command_names -e' \
        '1::action:(start delete)'
}

_containerd-shim-runc-v2 "$@"
