#compdef bibtex2html bib2bib aux2bib
# Documentation: https://man.archlinux.org/search?q=bibtex2html
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '(-s --style)'{-s+,--style=}'[bibliography style]:style:(plain alpha abbrv unsrt)' \
  '(-c --citefile)'{-c+,--citefile=}'[citation file]:file:_files -g "*.aux"' \
  '(-d --sort-by-date)'{-d,--sort-by-date}'[sort by date]' \
  '(-a --sort-as-bibtex)'{-a,--sort-as-bibtex}'[sort as BibTeX]' \
  '(-u --unsorted)'{-u,--unsorted}'[unsorted]' \
  '(-r --reverse-sort)'{-r,--reverse-sort}'[reverse sort]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-f --field)'{-f+,--field=}'[print extra field]:field:' \
  '--no-fields[print no fields]' \
  '--header=[HTML header file]:file:_files' \
  '--footer=[HTML footer file]:file:_files' \
  '(-noabstract --no-abstract)'{-noabstract,--no-abstract}'[do not print abstracts]' \
  '(-nokeywords --no-keywords)'{-nokeywords,--no-keywords}'[do not print keywords]' \
  '(-nokeys --no-keys)'{-nokeys,--no-keys}'[do not print keys]' \
  '(-nodoc --no-doc)'{-nodoc,--no-doc}'[no document, only bib entries]' \
  '(-nofooter --no-footer)'{-nofooter,--no-footer}'[no footer]' \
  '(-noheader --no-header)'{-noheader,--no-header}'[no header]' \
  '(-nf)-nf[insert link to extra file]:field:' \
  '(-multiple)-multiple[output one HTML per entry]' \
  '(-single)-single[single HTML output]' \
  '(-suffix)-suffix[output file suffix]:ext:' \
  '(-debug)-debug[debug mode]' \
  '(-w --warn-error)'{-w,--warn-error}'[exit on warnings]' \
  '(-nobibsource)-nobibsource[do not include bibsource]' \
  '(-noabstract)-noabstract[no abstracts]' \
  '(-named-field)-named-field[set named field]:name:: :file:_files' \
  '(-revkeys)-revkeys[reverse-sort by key]' \
  '(-i --ignore-errors)'{-i,--ignore-errors}'[ignore parsing errors]' \
  '*:bib file:_files -g "*.bib *.bbl"' && ret=0

return ret
