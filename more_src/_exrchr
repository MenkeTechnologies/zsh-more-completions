#compdef exrchr
# Documentation: https://linux.die.net/man/1/exrchr
# exrtools: spatially-varying chromatic adaptation for OpenEXR images

local ret=1

_arguments -s -S \
  '1:input.exr:_files -g "*.exr"' \
  '2:blur.exr:_files -g "*.exr"' \
  '3:output.exr:_files -g "*.exr"' \
  '4:degree of adaptation (0 to 1):' && ret=0

return ret
