#compdef go-callvis

_go-callvis() {
  _arguments \
    '(-h --help)'{-h,--help}'[Show help]' \
    '-focus[Focus on specific package]:package:' \
    '-group[Grouping functions by]:group:_values -s , group pkg type' \
    '-ignore[Ignore packages matching prefix]:prefix:' \
    '-include[Include packages matching prefix]:prefix:' \
    '-limit[Limit packages to prefix]:prefix:' \
    '-minlen[Minimum edge length]:length:' \
    '-nodesep[Minimum space between nodes]:sep:' \
    '-nointer[Omit calls to unexported functions]' \
    '-nostd[Omit calls to standard library]' \
    '-format[Output format]:format:(svg png jpg gif)' \
    '-file[Output file path]:file:_files' \
    '-http[HTTP service address]:address:' \
    '-skipbrowser[Skip opening browser]' \
    '-algo[Call graph algorithm]:algo:(cha rta pta vta static)' \
    '-tests[Include test functions]' \
    '-debug[Enable debug mode]' \
    '-version[Print version]' \
    '*:package:_files'
}

_go-callvis "$@"
