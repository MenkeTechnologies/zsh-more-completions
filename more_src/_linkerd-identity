#compdef linkerd-identity
# Documentation: https://github.com/linkerd/linkerd2/blob/main/controller/cmd/identity/main.go
# Reference accessed: 2026-05-19
# Verified: linkerd/linkerd2 controller/cmd/identity/main.go.
# Internal control-plane binary using Go `flag` (single-dash long names).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated GNU-style `--` long options (Go `flag` uses single-dash);
# fabricated --log-format/--log-level/--trace-collector/--enable-h2-upgrade/
# --default-opaque-ports (not in this binary's flag table).

# linkerd-identity: control plane identity (mTLS) issuer service
local curcontext="$curcontext" ret=1
_arguments -C \
  '-addr=[bind address (default :8080)]:addr:' \
  '-admin-addr=[admin HTTP server address (default :9990)]:addr:' \
  '-kubeconfig=[path to kube config]:file:_files' \
  '-controller-namespace=[namespace in which Linkerd is installed]:ns:' \
  '-identity-scheme=[scheme used for the identity issuer secret format]:scheme:' \
  '-identity-trust-domain=[name suffix used for identities]:domain:' \
  '-identity-issuance-lifetime=[duration the issuer should certify identity for]:duration:' \
  '-identity-clock-skew-allowance=[time to allow for clock skew within the cluster]:duration:' \
  '-enable-pprof[enable pprof endpoints on the admin server]' \
  '-kube-apiclient-qps=[maximum QPS sent to the kube-apiserver before throttling]:n:' \
  '-kube-apiclient-burst=[burst value over kube-apiclient-qps]:n:' \
  '-issuer=[path to directory containing issuer credentials]:dir:_files -/' && ret=0
return ret
