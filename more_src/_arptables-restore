#compdef arptables-restore
# _arptables-restore — netfilter arptables-restore (load a previously saved arptables ruleset back into the kernel; -c restore counters, -n skip table flush, -t TABLE limit to a table, -v verbose, -V version; reads input from stdin or a positional file)
# upstream: https://git.netfilter.org/arptables
# Flags from netfilter/arptables arptables-restore.c on tip.

_arptables-restore() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c[restore counters]' \
        '-n[no flush]' \
        '-t+[table]:table:(filter)' \
        '-v[verbose]' \
        '*:file:_files'
}

_arptables-restore "$@"
