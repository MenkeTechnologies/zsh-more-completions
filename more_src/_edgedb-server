#compdef edgedb-server
# Documentation: https://man.archlinux.org/search?q=edgedb-server
# Reference accessed: 2026-05-16

# edgedb-server: EdgeDB / Gel server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--version[show version]' \
  '-D[data directory]:dir:_files -/' \
  '--data-dir=[data directory]:dir:_files -/' \
  '--config-file=[config file]:file:_files' \
  '--bind-address=[bind address]:addr:' \
  '--port=[port]:port:' \
  '--background[run in background]' \
  '--pidfile-dir=[PID file dir]:dir:_files -/' \
  '--daemon-user=[run as user]:user:_users' \
  '--daemon-group=[run as group]:group:_groups' \
  '--bootstrap-only[run bootstrap then exit]' \
  '--bootstrap-script=[bootstrap script]:file:_files' \
  '--bootstrap-command=[bootstrap command]:cmd:' \
  '--default-auth-method=[default auth]:method:(SCRAM Trust JWT mTLS)' \
  '--allow-insecure-binary-clients[allow insecure binary]' \
  '--allow-insecure-http-clients[allow insecure HTTP]' \
  '--testmode[test mode]' \
  '--instance-name=[instance name]:name:' \
  '--readiness-state-file=[readiness state file]:file:_files' \
  '--tls-cert-file=[TLS cert file]:file:_files' \
  '--tls-key-file=[TLS key file]:file:_files' \
  '--auto-shutdown-after=[auto shutdown after]:seconds:' \
  '--log-level=[log level]:level:(silent error warn info debug)' \
  '--log-to=[log destination]:dest:' \
  '--emit-server-status=[emit status to file/URI]:dest:' \
  '*::edgedb-server args:_files' && ret=0
return ret
