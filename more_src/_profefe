#compdef profefe
# Documentation: https://github.com/profefe/profefe
# profefe - continuous profiling collector server

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-addr=[server listening address]:address:' \
  '-storage-type=[backend storage type]:type:(badger s3 gcs clickhouse)' \
  '-badger.dir=[directory for BadgerDB storage]:dir:_files -/' \
  '*:arg:_files' && ret=0

return ret
