#compdef slush
# Documentation: https://github.com/slushjs/slush
# Slush - the streaming scaffolding system (gulp generators)

local ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[display slush, gulp and generator versions]' \
  '--tasks[list available tasks within a generator]' \
  '*:generator\:tasks:' && ret=0

return ret
