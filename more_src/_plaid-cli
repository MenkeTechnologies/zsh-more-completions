#compdef plaid-cli plaid
# Documentation: https://man.archlinux.org/search?q=plaid-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'accounts:show accounts for institution'
  'alias:assign name to linked bank account'
  'aliases:show all aliases'
  'link:connect a bank account via Plaid Link'
  'tokens:show access tokens and Item IDs'
  'transactions:retrieve transaction history'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config=[config file]:file:_files -g "*.toml"' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'plaid-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (transactions)
        _arguments \
          '--from=[start date YYYY-MM-DD]:date:' \
          '--to=[end date YYYY-MM-DD]:date:' \
          '--output-format=[output format]:fmt:(csv json yaml)' \
          '--account-id=[account id]:id:' \
          '--currency-code=[ISO currency]:code:' \
          '*: :' && ret=0 ;;
      (link|accounts|tokens) _arguments '*: :' && ret=0 ;;
    esac ;;
esac

return ret
