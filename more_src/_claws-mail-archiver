#compdef claws-mail-archiver
# Documentation: https://www.claws-mail.org/plugin.php?plugin=archive
# Reference accessed: 2026-05-16
# Verified: Claws Mail "archive" plugin documentation page on
# claws-mail.org. The archiver is a Claws Mail plugin (loaded into the
# claws-mail process), not a standalone CLI. It has no separate binary,
# no command-line flags, and is configured exclusively through the
# Claws Mail GUI. Conservative stub retained per "do not delete files"
# directive.
# Removed from prior file: fabricated -h/-V flags and bogus
# man.archlinux.org search URL.

# claws-mail-archiver: Claws Mail plugin (GUI-only; not a standalone CLI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:arg:_files' && ret=0
return ret
