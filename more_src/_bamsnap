#compdef bamsnap
# Documentation: https://bamsnap.readthedocs.io/en/latest/
# bamsnap - lightweight viewer for sequencing reads in BAM files

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[display program version]' \
  '-bam[bam or cram file(s)]:bam:_files' \
  '-bamlist[list file with bam/cram file paths]:list:_files' \
  '-title[title (name) of bam/cram file(s)]:title' \
  '-no_title[do not draw label]' \
  '-title_fontsize[font size of title]:size' \
  '-pos[genomic position (ex. 1:816687-818057)]:pos' \
  '-vcf[list file with genomic positions in VCF format]:vcf:_files' \
  '-bed[list file with genomic positions in BED format]:bed:_files' \
  '-out[output file or title of output file]:out:_files' \
  '-imagetype[output file type]:type:(png jpg)' \
  '-conf[configuration file]:conf:_files' \
  '-ref[reference sequence fasta file]:fasta:_files' \
  '-ref_index_rebuild[rebuild fasta index file]' \
  '-refversion[reference version]:version:(hg19 hg38)' \
  '-margin[genomic margin size]:margin' \
  '-save_image_only[save image only]' \
  '-image_dir_name[image directory name]:dir:_files -/' \
  '-zipout[make a single zip file]' \
  '-separator_height[separator height]:height' \
  '-process[number of processes for multi-processing]:n' \
  '-draw[track composition]:tracks' \
  '-bamplot[track composition of bamplot]:tracks' \
  '-width[image width in px]:width' \
  '-height[image height in px]:height' \
  '-bgcolor[background color]:color' \
  '-plot_margin_top[top margin of plot]:px' \
  '-plot_margin_bottom[bottom margin of plot]:px' \
  '-plot_margin_left[left margin of plot]:px' \
  '-plot_margin_right[right margin of plot]:px' \
  '-border[draw border in plot]' \
  '-grid[draw grid in plot]:size' \
  '-read_thickness[read thickness in px]:px' \
  '-read_gap_height[read gap height in px]:px' \
  '-read_gap_width[min read gap width in px]:px' \
  '-read_bgcolor[read background color]:color' \
  '-read_color[read color]:color' \
  '-read_pos_color[positive strand read color]:color' \
  '-read_neg_color[negative strand read color]:color' \
  '-read_color_deletion[read color of deletion]:color' \
  '-read_color_inversion[read color of inversion]:color' \
  '-insert_size_del_threshold[insert size threshold for deletion]:n' \
  '-insert_size_ins_threshold[insert size threshold for insertion]:n' \
  '-read_group[read group]:group:(strand)' \
  '-read_color_by[read color by]:by:(strand interchrom)' \
  '-show_soft_clipped[show soft clipped part]' \
  '-show_hard_clipped[show hard clipped part]' \
  '-show_clipped[show soft and hard clipped part]' \
  '-center_line[draw center line]' \
  '-no_target_line[do not draw target line]' \
  '-base_fontsize[font size of base track]:size' \
  '-base_height[base track height]:height' \
  '-coverage_height[coverage track height]:height' \
  '-coverage_fontsize[coverage font size]:size' \
  '-coverage_vaf[coverage VAF threshold]:vaf' \
  '-coverage_color[coverage color]:color' \
  '-coverage_bgcolor[coverage track background color]:color' \
  '-heatmap_height[coverage heatmap height]:height' \
  '-heatmap_bgcolor[coverage heatmap background color]:color' \
  '-gene_height[gene track height]:height' \
  '-gene_fontsize[font size of gene track]:size' \
  '-gene_pos_color[positive strand gene color]:color' \
  '-gene_neg_color[negative strand gene color]:color' \
  '-coordinates_height[coordinate height]:height' \
  '-coordinates_fontsize[coordinate font size]:size' \
  '-coordinates_axisloc[coordinate axis location]:loc:(top bottom middle)' \
  '-coordinates_bgcolor[coordinate background color]:color' \
  '-coordinates_labelcolor[coordinate label color]:color' \
  '-separated_bam[draw a plot for each bam]' \
  '-silence[do not print any log]' \
  '-debug[turn on debugging mode]' && ret=0

return ret
