#compdef easyjson
# Documentation: https://github.com/mailru/easyjson
# easyjson: fast JSON marshaler/unmarshaler code generator for Go

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '-all[generate marshalers/unmarshalers for all structs in a file]' \
  '-pkg[process the whole package instead of just the given file]' \
  '-build_tags=[build tags to add to the generated file]:tags' \
  '-gen_build_flags=[build flags when running the generator while bootstrapping]:flags' \
  '-byte[use simple bytes instead of Base64Bytes for byte slices]' \
  '-snake_case[use snake_case names instead of CamelCase]' \
  '-lower_camel_case[use lowerCamelCase instead of CamelCase]' \
  '-omit_empty[omit empty fields by default]' \
  '-disallow_unknown_fields[return an error if an unknown field appears in JSON]' \
  '-disable_members_unescape[disable unescaping of \uXXXX sequences in member names]' \
  '-no_std_marshalers[do not generate MarshalJSON/UnmarshalJSON funcs]' \
  '-stubs[only generate stubs for marshaler/unmarshaler funcs]' \
  '-noformat[do not run gofmt -w on the output file]' \
  '-output_filename=[name of the output file]:file:_files' \
  '-leave_temps[do not delete temporary files]' \
  '*:file:_files' && ret=0

return ret
