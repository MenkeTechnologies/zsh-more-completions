#compdef bamdst
# Documentation: https://github.com/shiquan/bamdst
# a lightweight BAM depth statistics tool for target regions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message]' \
  '(-o --outdir)'{-o,--outdir}'=[output directory]:dir:_files -/' \
  '(-p --bed)'{-p,--bed}'=[probe/target regions BED file]:file:_files' \
  '(-f --flank)'{-f,--flank}'=[flanking bases to extend regions]:n' \
  '-q[MAPQ quality cutoff]:n' \
  '--maxdepth=[maximum depth for plots]:n' \
  '--cutoffdepth=[custom depth thresholds]:csv' \
  '--depthratio=[ratios of average depth]:csv' \
  '--isize=[max insert size for plots]:n' \
  '--uncover=[depth threshold for uncovered regions]:n' \
  '--bamout=[export overlapping reads to BAM]:file:_files' \
  '(-F --format)'{-F,--format}'=[output report format]:format:(txt csv json)' \
  '-1[treat BED as 1-based]' \
  '*:bam file:_files' && ret=0

return ret
