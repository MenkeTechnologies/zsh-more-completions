#compdef ssage
# Documentation: https://github.com/AnswerDotAI/shell_sage
# ShellSage - terminal-based AI assistant with tmux context awareness

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '--model=[specify the LLM model to use]:model:' \
  '--vendor_name=[set the API provider]:vendor:' \
  '--base_url=[provide an alternative API endpoint URL]:url:' \
  '--api_key=[override the default API key]:key:' \
  '--pid=[reference a specific tmux pane by ID]:pane id:' \
  '--mode=[set output style]:mode:(default sassy)' \
  '--history_lines=[terminal history lines to include]:lines:' \
  '--code_theme=[syntax highlighting theme]:theme:' \
  '--code_lexer=[default code block language]:lexer:' \
  '--search=[enable web search capability]:effort:(l m h)' \
  '--think[enable reasoning mode]' \
  '--trust=[comma-delimited list of tools to auto-approve]:tools:' \
  '*:query:' && ret=0

return ret
