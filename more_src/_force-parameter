#compdef force-parameter
# Documentation: https://force-eo.readthedocs.io/en/latest/components/auxilliary/parameter.html
# FORCE parameter file generator

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-v)-v[show version]' \
  '(-i)-i[show program purpose]' \
  '(-m)-m[show available modules]' \
  '(-c)-c[generate compact parameter file without comments]' \
  '1:parameter file:_files' \
  '2:module:' && ret=0

return ret
