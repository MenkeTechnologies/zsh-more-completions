#compdef calicoq
# Documentation: https://docs.tigera.io/calico-enterprise/latest/reference/clis/calicoq/overview
# Calico policy inspection tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[log debugging information to stderr]' \
  '(-c --config)'{-c,--config=}'[path to connection configuration file]:config:_files' \
  '(-o --output)'{-o,--output=}'[output format]:format:(yaml json ps)' \
  '(-s --hide-selectors)'{-s,--hide-selectors}'[do not show detailed selector expressions]' \
  '(-r --hide-rule-matches)'{-r,--hide-rule-matches}'[do not show policies/profiles whose rule selectors match]' \
  '1:command:(eval policy endpoint host version)' \
  '*::arg:_default' && ret=0

return ret
