#compdef rgsproc
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/rgsproc/node26.html
# XMM-Newton SAS: interactive version of the RGS pipeline

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--entrystage=[processing start point]:stage:' \
  '--finalstage=[final processing stage]:stage:' \
  '--withinstexpids=[filter to specific exposures]:flag:(yes no)' \
  '--instexpids=[instrument-exposure identifiers]:ids:' \
  '--orders=[reflection orders to process]:orders:' \
  '--withprefix=[enable custom filename prefix]:flag:(yes no)' \
  '--prefix=[custom prefix string]:prefix:' \
  '--expunge=[intermediate datasets to delete]:datasets:' \
  '--timestep=[attitude time-series resolution]:step:' \
  '--driftlimit=[attitude drift threshold]:limit:' \
  '--calcoffsets=[compute pulse-height offsets]:flag:(yes no)' \
  '--withepicset=[include EPIC sources]:flag:(yes no)' \
  '--epicset=[EPIC source catalog]:file:_files' \
  '--withsrc=[add user-defined source]:flag:(yes no)' \
  '--srclabel=[source label]:label:' \
  '--srcra=[source right ascension]:ra:' \
  '--srcdec=[source declination]:dec:' \
  '--withgain=[energy gain calibration]:flag:(yes no)' \
  '--withcti=[CTI calibration]:flag:(yes no)' \
  '--badpixalgo=[bad pixel algorithm]:algo:' \
  '--betabinning=[dispersion channel definition]:def:' \
  '--xdispbinning=[cross-dispersion definition]:def:' \
  '--withheliocentriccorr=[heliocentric velocity correction]:flag:(yes no)' \
  '--withsunanglecorr=[sun angle correction]:flag:(yes no)' \
  '--auxgtitables=[auxiliary GTI tables]:tables:' \
  '--withcombmap=[output combined exposure map]:flag:(yes no)' \
  '--rejflags=[event rejection flags]:flags:' \
  '--spatialres=[region vertex spacing]:res:' \
  '--orderres=[order region spacing]:res:' \
  '--xpsfincl=[PSF inclusion coverage percentage]:pct:' \
  '--xpsfexcl=[PSF exclusion coverage percentage]:pct:' \
  '--pdistincl=[pulse-height distribution coverage]:pct:' \
  '--spectrumbinning=[spectrum binning type]:type:' \
  '--bkgcorrect=[apply background correction]:flag:(yes no)' \
  '--withbkgset=[output background spectra]:flag:(yes no)' \
  '--rebin=[channel rebinning factor]:factor:' \
  '--withbackgroundmodel=[generate background template]:flag:(yes no)' \
  '--witharffile=[create independent ARF/RMF]:flag:(yes no)' \
  '--rmfbins=[response matrix energy bins]:bins:' \
  '--withmirrorpsf=[include mirror PSF]:flag:(yes no)' \
  '--mergeorders=[combine all spectra]:flag:(yes no)' \
  '--flxformat=[output format]:format:(dal ascii qdp)' \
  '--flxmode=[output units]:mode:(wavelength energy)' \
  '--timebinsize=[time bin size]:size:' \
  '--withbkgsubtraction=[enable background subtraction]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
