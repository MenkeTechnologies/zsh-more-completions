  '--sccm-dp-extensions=[file extensions to search for]:extensions:' \
  '--sccm-dp-files=[file containing URLs to download]:file:_files' \
  '--mssql-db=[database for MSSQL relay]:db:' \
  '*:target:_hosts' && ret=0

return ret
