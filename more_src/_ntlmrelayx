  '(-q --query)'{-q+,--query=}'[MSSQL query to execute]:query:' \
  '-machine-account=[domain machine account]:account:' \
  '-machine-hashes=[machine NTLM hashes]:hashes:' \
  '-domain=[domain FQDN or IP]:domain:' \
  '-remove-target[remove target from challenge message]' \
  '(-k --keyword)'{-k+,--keyword=}'[IMAP search keyword]:keyword:' \
  '(-m --mailbox)'{-m+,--mailbox=}'[mailbox to dump]:mailbox:' \
