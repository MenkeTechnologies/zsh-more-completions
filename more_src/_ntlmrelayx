#compdef ntlmrelayx ntlmrelayx.py
# Documentation: https://github.com/fortra/impacket/blob/master/examples/ntlmrelayx.py
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-debug[turn debug output on]' \
  '-t+[target to relay to]:target:' \
  '-tf+[file with target list]:file:_files' \
  '-w[watch targets file for changes]' \
  '-ts[add timestamp to output]' \
  '-ip+[IP address to listen on]:ip:_hosts' \
  '-6[listen on IPv6]' \
  '-wh+[WPAD host]:host:_hosts' \
  '-wa+[WPAD auth type]:type:(NTLM Basic)' \
  '-wp+[WPAD port]:port:' \
  '-of+[output file]:file:_files' \
  '-codec=[output codec]:codec:' \
  '-smb2support[enable SMB2 support]' \
  '-ntlmchallenge=[NTLM challenge]:challenge:' \
  '-socks[enable SOCKS proxy]' \
  '--no-smb-server[do not start SMB server]' \
  '--no-http-server[do not start HTTP server]' \
  '--no-wcf-server[do not start WCF server]' \
  '--no-raw-server[do not start raw server]' \
  '-e+[file to execute on target]:file:_files' \
  '-c+[command to execute on target]:command:' \
  '--enum-local-admins[enumerate local admins]' \
  '-l+[loot directory]:dir:_files -/' \
  '--remove-mic[remove MIC from security blob]' \
  '--no-da[do not check domain admin]' \
  '--no-acl[do not modify ACLs]' \
  '--no-validate-privs[do not validate privileges]' \
  '--escalate-user=[user to escalate]:user:' \
  '--add-computer=[add computer account]:name:' \
  '--delegate-access[add delegation rights]' \
  '--dump-laps[dump LAPS passwords]' \
  '--dump-gmsa[dump gMSA passwords]' \
  '--dump-adcs[dump AD CS templates]' \
  '--adcs[enable AD CS relay attack]' \
  '--template=[AD CS template]:template:' \
  '--shadow-credentials[set shadow credentials]' \
  '--shadow-target=[shadow credentials target]:target:' \
  '-i[launch interactive SMB client shell]' \
  '*:target:_hosts' && ret=0

return ret
