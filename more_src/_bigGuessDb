#compdef bigGuessDb
# Documentation: https://github.com/ucscGenomeBrowser/kent/blob/master/src/utils/bigGuessDb/bigGuessDb
# given a bigBed, bigWig, or VCF file or URL, guess the assembly based on chrom names and sizes

local ret=1

_arguments -s -S \
  '(-d --debug)'{-d,--debug}'[show debug messages]' \
  '--index[UCSC staff: build an index of all chromSizes from /hive/data/genomes]' \
  '(-b --best)'{-b,--best}'[print only the single best matching assembly]' \
  '(-i --indexFile)'{-i,--indexFile}'=[use specified index file (default bigGuessDb.txt.gz)]:index file:_files' \
  '--fromFile=[read URLs to process from input file]:file:_files' \
  '*:inFile:_files' && ret=0

return ret
