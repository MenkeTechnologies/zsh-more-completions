#compdef tmuxai
# Documentation: https://github.com/alvinunreal/tmuxai
# tmuxai - AI-powered non-intrusive terminal assistant for tmux

local ret=1

_arguments -s -S \
  '--model=[model configuration to use]:model:' \
  '--kb=[load knowledge bases (comma-separated)]:knowledge bases:' \
  '--exec-pane=[force a tmux pane for command execution]:pane id:' \
  '--read-panes=[restrict read context to pane ids (comma-separated)]:pane ids:' \
  '--yolo[skip all confirmation prompts]' \
  '-f+[load initial task from a file]:file:_files' \
  '*:message:' && ret=0

return ret
