#compdef capsule-proxy
# _capsule-proxy — Capsule multi-tenancy Kubernetes API server proxy
# upstream: https://github.com/projectcapsule/capsule-proxy
# Flags from main.go on tip.

_capsule-proxy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--webhook-port=[webhook bind port]:port:' \
        '--enable-leader-election[enable leader election]' \
        '--metrics-addr=[metrics bind host\:port]:host\:port:' \
        '--allowed-paths=[csv of URL paths not inspected]:csv:' \
        '--trusted-proxy-cidrs=[csv of CIDR ranges of trusted forwarding proxies]:csv:' \
        '--xfcc-header-name=[forwarded-client-cert header name]:header:' \
        '--capsule-configuration-name=[CapsuleConfiguration CR name]:name:' \
        '*--ignored-user-group=[group name to bypass (repeatable)]:group:' \
        '*--ignored-impersonation-group=[group name excluded from impersonation]:group:' \
        '--impersonation-group-regexp=[regex matching groups considered for impersonation]:regex:' \
        '--listening-port=[HTTP listen port]:port:' \
        '--oidc-username-claim=[OIDC field used as username]:claim:' \
        '--enable-reflector[enable rolebinding reflector]' \
        '--enable-pprof[enable pprof endpoint]' \
        '--enable-ssl=[bind on HTTPS]:bool:(true false)' \
        '--ssl-cert-path=[TLS certificate path]:file:_files' \
        '--ssl-key-path=[TLS certificate key path]:file:_files' \
        '--rolebindings-resync-period=[rolebinding reflector resync period]:dur:' \
        '*--auth-preferred-types=[auth types]:type:(BearerToken TLSCertificate XForwardedClientCert)' \
        '--disable-caching=[disable go-client caching]:bool:(true false)' \
        '--client-connection-qps=[QPS for K8s API]:f:' \
        '--client-connection-burst=[burst for K8s API]:n:' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_capsule-proxy "$@"
