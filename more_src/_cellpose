#compdef cellpose
# Documentation: https://cellpose.readthedocs.io/en/latest/cli.html
# cellpose: cellular segmentation command line interface

local ret=1

_arguments -s \
  '--version[show cellpose version info]' \
  '--verbose[show running info and settings and save to log]' \
  '--Zstack[run GUI in 3D mode]' \
  '--use_gpu[use gpu or mps if torch with cuda installed]' \
  '--gpu_device=[which gpu device to use in pytorch]:device:' \
  '--dir=[folder containing data to run or train on]:dir:_files -/' \
  '--image_path=[run on single image instead of folder]:image:_files' \
  '--look_one_level_down[run processing on all subdirectories]' \
  '--img_filter=[end string for images to run on]:filter:' \
  '--channel_axis=[axis of image corresponding to channels]:axis:' \
  '--z_axis=[axis of image corresponding to Z dimension]:axis:' \
  '--pretrained_model=[path to model for segmentation or training start]:model:' \
  '--add_model=[copy model to hidden .cellpose folder]:model:_files' \
  '--transformer[use transformer backbone]' \
  '--no_norm[do not normalize images]' \
  '--norm_percentile=[set norm percentile (two float values)]:percentile:' \
  '--do_3D[process images as 3D stacks]' \
  '--diameter=[resize cells to the training diameter]:diameter:' \
  '--stitch_threshold=[compute masks in 2D then stitch with IoU]:threshold:' \
  '--min_size=[minimum number of pixels per mask]:size:' \
  '--flow3D_smooth=[stddev of gaussian for smoothing dP in 3D]:value:' \
  '--flow_threshold=[flow error threshold]:threshold:' \
  '--cellprob_threshold=[cellprob threshold]:threshold:' \
  '--niter=[number of iterations for dynamics]:iterations:' \
  '--anisotropy=[anisotropy of volume in 3D]:value:' \
  '--exclude_on_edges[discard masks which touch edges of image]' \
  '--augment[tile image with overlapping tiles and flip regions]' \
  '--batch_size=[inference batch size]:size:' \
  '--no_resample[disable flows/cellprob resampling to original size]' \
  '--no_interp[do not interpolate when running dynamics]' \
  '--save_png[save masks as png]' \
  '--save_tif[save masks as tif]' \
  '--output_name=[suffix for saved masks]:name:' \
  '--no_npy[suppress saving of npy]' \
  '--savedir=[folder to save segmentation results]:dir:_files -/' \
  '--dir_above[save output folders adjacent to image folder]' \
  '--in_folders[save output in folders]' \
  '--save_flows[save RGB images of flows when masks]' \
  '--save_outlines[save RGB outline images when masks]' \
  '--save_rois[save ImageJ compatible ROI archive]' \
  '--save_txt[enable txt outlines for ImageJ]' \
  '--save_mpl[save a figure of image/mask/flows using matplotlib]' \
  '--train[train network using images in dir]' \
  '--test_dir=[folder containing test data]:dir:_files -/' \
  '--file_list=[path to list of files for training and testing]:file:_files' \
  '--mask_filter=[end string for masks to run on]:filter:' \
  '--learning_rate=[learning rate]:rate:' \
  '--weight_decay=[weight decay]:decay:' \
  '--n_epochs=[number of epochs]:epochs:' \
  '--train_batch_size=[training batch size]:size:' \
  '--bsize=[block size for tiles]:size:' \
  '--nimg_per_epoch=[number of train images per epoch]:n:' \
  '--nimg_test_per_epoch=[number of test images per epoch]:n:' \
  '--min_train_masks=[minimum masks a training image must have]:n:' \
  '--save_every=[number of epochs to skip between saves]:n:' \
  '--save_each[save each epoch]' \
  '--model_name_out=[name of model to save as]:name:' && ret=0

return ret
