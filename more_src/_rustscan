#compdef rustscan

# Zsh completion for rustscan - fast port scanner

_arguments -s -S \
  '(-a --addresses)'{-a,--addresses}'[addresses to scan]:addresses:' \
  '(-p --ports)'{-p,--ports}'[ports to scan]:ports:' \
  '(-r --range)'{-r,--range}'[range of ports to scan]:range:' \
  '--exclude-ports[ports to exclude from scan]:ports:' \
  '(-b --batch-size)'{-b,--batch-size}'[number of sockets opened at the same time]:size:' \
  '(-t --timeout)'{-t,--timeout}'[timeout before a port is assumed open]:milliseconds:' \
  '--tries[number of times to try before giving up]:N:' \
  '(-u --ulimit)'{-u,--ulimit}'[automatically increase maximum open files]:N:' \
  '(-q --quiet)'{-q,--quiet}'[decrease level of verbosity]' \
  '--no-config[use custom values without config file]' \
  '--top[scan only the top 1000 ports]' \
  '(-n --no-nmap)'{-n,--no-nmap}'[disable nmap follow-up scan]' \
  '(-g --greppable)'{-g,--greppable}'[greppable output mode]' \
  '--accessible[enable accessible mode (removes colors)]' \
  '(-o --open)'{-o,--open}'[only output open ports]' \
  '--scripts[nmap scripts to run]:scripts:' \
  '--command[command to run after the scan]:cmd:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:address:_hosts'
