#compdef rollbar-cli2
# _rollbar-cli2 — Rollbar rollbar-cli2 CLI command-line frontend wrapping the Rollbar continuous code improvement platform error monitoring CLI providing login deploy notify source-map upload-source-map version environment access-token project rql-query item occurrence team user notification-channel rule webhook integration suspect-deploy revert-deploy AI-assisted-debugging (Rollbar team, Go); cobra
# upstream: https://rollbar.com/

_rollbar-cli2() {
    local -a sub=(
        'login:authenticate'
        'whoami:show identity'
        'deploy:report a deploy'
        'notify:notify an event'
        'source-map:source map operations'
        'upload-source-map:upload source map'
        'project:project operations'
        'access-token:access token operations'
        'item:item operations'
        'occurrence:occurrence operations'
        'team:team operations'
        'user:user operations'
        'rule:rule operations'
        'notification-channel:notification channel operations'
        'rql:run RQL query'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--access-token=+[token]:str:' \
        '--server-side-token=+[token]:str:' \
        '--post-server-item-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--environment=+[env]:str:' \
        '-e+[env]:str:' \
        '--code-version=+[v]:str:' \
        '--source-map-url=+[url]:str:' \
        '--minified-url=+[url]:str:' \
        '--platform=+[p]:p:(browser node android ios osx unity client server)' \
        '--framework=+[f]:str:' \
        '--language=+[lang]:str:' \
        '--revision=+[sha]:str:' \
        '--rollbar-username=+[user]:_users' \
        '--local-username=+[user]:_users' \
        '--comment=+[text]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rollbar subcommand' sub ;;
        args)
            case $words[1] in
                deploy) _arguments '*:revision:' ;;
                source-map|upload-source-map) _arguments '*:file:_files -g "*.map *.js"' ;;
                project|access-token|item|occurrence|team|user|rule|notification-channel) _arguments '1:op:(list get create update delete)' '*:id:' ;;
            esac
            ;;
    esac
}

_rollbar-cli2 "$@"
