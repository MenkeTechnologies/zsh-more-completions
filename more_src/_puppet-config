#compdef puppet-config
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/config.md
# puppet config - examine and modify settings in puppet.conf

local ret=1

_arguments -s -S \
  '--render-as=[output render format]:format:(json s yaml console dot)' \
  '--verbose[whether to log verbosely]' \
  '--debug[whether to log debug information]' \
  '--section=[section of puppet.conf to interact with]:section:(main server agent user)' \
  '1:action:(print set delete)' \
  '*::setting:' && ret=0

return ret
