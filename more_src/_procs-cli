#compdef procs
# Documentation: https://man.archlinux.org/search?q=procs
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --and)'{-a,--and}'[AND filters]' \
  '(-o --or)'{-o,--or}'[OR filters]' \
  '(-d --nand)'{-d,--nand}'[NAND filters]' \
  '(-r --nor)'{-r,--nor}'[NOR filters]' \
  '--color=[color]:c:(auto always disable)' \
  '--theme=[theme]:t:(auto dark light)' \
  '(-c --config)'{-c+,--config=}'[config path]:file:_files -g "*.toml"' \
  '--config-schema[print config schema]' \
  '(-i --insert)*'{-i+,--insert=}'[insert column]:col:' \
  '--load-config[load config]' \
  '--no-header[no header]' \
  '(-p --pager)'{-p+,--pager=}'[pager]:p:(auto always disable)' \
  '(-s --sortd)'{-s+,--sortd=}'[sort column descending]:col:' \
  '--sorta=[sort column ascending]:col:' \
  '(-T --tree)'{-T,--tree}'[tree view]' \
  '(-W --watch)'{-W+,--watch=}'[watch interval s]:s:' \
  '--watch-interval=[interval ms]:ms:' \
  '(-w --word-regexp)'{-w,--word-regexp}'[word regex]' \
  '(-t --tcp)'{-t,--tcp}'[show TCP info]' \
  '(-u --udp)'{-u,--udp}'[show UDP info]' \
  '--gen-completion=[generate completion]:shell:(bash zsh fish powershell elvish)' \
  '--use-config=[use built-in config]:c:(default large)' \
  '*:keyword:' && ret=0

return ret
