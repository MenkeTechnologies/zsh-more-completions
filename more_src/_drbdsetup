#compdef drbdsetup
# _drbdsetup — DRBD distributed replicated block device low-level setup CLI (LINBIT, C); custom argparse
# upstream: https://github.com/LINBIT/drbd-utils

_drbdsetup() {
    local -a sub=(
        'attach:attach lower device'
        'connect:connect to peer'
        'detach:detach lower device'
        'disconnect:disconnect from peer'
        'disk-options:set disk options'
        'down:bring resource down'
        'events:wait for events'
        'events2:wait for events v2'
        'invalidate:invalidate local data'
        'invalidate-remote:invalidate remote data'
        'net-options:set net options'
        'new-current-uuid:generate new uuid'
        'new-minor:create minor'
        'new-peer:create peer'
        'new-resource:create resource'
        'outdate:outdate disk'
        'pause-sync:pause sync'
        'peer-device-options:set peer device options'
        'primary:make primary'
        'resize:resize device'
        'resource-options:set resource options'
        'resume-io:resume IO'
        'resume-sync:resume sync'
        'role:show role'
        'secondary:make secondary'
        'show:show state'
        'show-gi:show generation identifiers'
        'state:show state v1'
        'status:show short status'
        'suspend-io:suspend IO'
        'up:bring resource up'
        'verify:run online verify'
        'wait-connect-resource:wait for resource connect'
        'wait-connect-volume:wait for volume connect'
        'wait-sync-volume:wait for volume sync'
        'wait-sync-resource:wait for resource sync'
        'wait-sync-connection:wait for connection sync'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'drbdsetup subcommand' sub ;;
    esac
}

_drbdsetup "$@"
