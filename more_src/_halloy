#compdef halloy
# Documentation: https://man.archlinux.org/search?q=halloy
# Reference accessed: 2026-05-16

_arguments \
  '-c[path to configuration file]:file:_files -g "*.{toml,yaml,yml}"' \
  '--config[path to configuration file]:file:_files -g "*.{toml,yaml,yml}"' \
  '-h[display help]' \
  '--help[display help]' \
  '-V[display version]' \
  '--version[display version]'
