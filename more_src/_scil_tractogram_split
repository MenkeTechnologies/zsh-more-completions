#compdef scil_tractogram_split
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_tractogram_split.html
# Split a tractogram into multiple files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--nb_chunks)--chunk_size=[max number of streamlines per output file]:size' \
  '(--chunk_size)--nb_chunks=[divide tractogram into N equal parts]:n' \
  '--split_per_cluster[use Quickbundles clustering for splitting]' \
  '--do_not_randomize[split sequentially rather than using random indices]' \
  '*--qbx_thresholds[Quickbundles threshold values]:threshold' \
  '--seed=[random seed for reproducible splitting]:seed' \
  '--reference=[reference anatomy for tck/vtk/fib/dpy]:nifti:_files -g "*.nii *.nii.gz"' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[force overwrite of output files]' \
  '1:in_tractogram:_files' \
  '2:out_prefix:' && ret=0

return ret
