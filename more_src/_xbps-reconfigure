#compdef xbps-reconfigure
# Documentation: https://man.voidlinux.org/xbps-reconfigure.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[reconfigure all packages]' \
  '(-C --config)'{-C,--config}'+[path to XBPS configuration directory]:dir:_directories' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '(-f --force)'{-f,--force}'[force reconfiguration]' \
  '*'{-i,--ignore}'+[ignore PKG when used with -a]:pkg:' \
  '(-r --rootdir)'{-r,--rootdir}'+[target root directory]:dir:_directories' \
  '(-x --deps)'{-x,--deps}'[configure PKG and its direct dependencies]' \
  '--fulldeptree[configure full dependency tree (with -x)]' \
  '(-v --verbose)'{-v,--verbose}'[verbose messages]' \
  '*:package: ' && ret=0

return ret
