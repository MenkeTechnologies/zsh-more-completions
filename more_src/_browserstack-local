#compdef BrowserStackLocal browserstack-local
# _browserstack-local — BrowserStack BrowserStackLocal CLI cross-platform binary creating a secure tunnel between BrowserStack cloud-running browsers and a developer-machine local web server to test internal staging localhost-applications private-networks intranet sites without firewall changes (BrowserStack team, C++); custom argparse
# upstream: https://www.browserstack.com/local-testing

_browserstack-local() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--key=+[access key]:str:' \
        '-k+[access key]:str:' \
        '--local-identifier=+[name]:str:' \
        '--folder=+[dir]:dir:_files -/' \
        '-f+[dir]:dir:_files -/' \
        '--force[force kill existing]' \
        '--only=+[host:port:ssl]:str:' \
        '--only-automate[only automate]' \
        '--proxy-host=+[host]:_hosts' \
        '--proxy-port=+[port]:n:' \
        '--proxy-user=+[user]:str:' \
        '--proxy-pass=+[password]:str:' \
        '--force-proxy[force proxy]' \
        '--force-local[force local]' \
        '--include-hosts=+[list]:str:' \
        '--exclude-hosts=+[list]:str:' \
        '--include-https-only[include only HTTPS]' \
        '--no-ssl-verify[no ssl verify]' \
        '--log-file=+[file]:file:_files' \
        '--pidfile=+[file]:file:_files' \
        '-d+[daemon command]:c:(start stop status)' \
        '--daemon=+[cmd]:c:(start stop status)' \
        '--up-stream=+[host:port]:str:' \
        '*::'
}

_browserstack-local "$@"
