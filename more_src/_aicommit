#compdef aicommit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--openai-key=[OpenAI API key]:key:' \
  '--openai-base-url=[OpenAI compatible API base URL]:url:_urls' \
  '(-m --model)'{-m+,--model=}'[model id]:model:' \
  '--save-key[store API key in local config and exit]' \
  '(-d --dry)'{-d,--dry}'[print message without committing]' \
  '(-a --amend)'{-a,--amend}'[amend the latest commit]' \
  '*(-c --context)'{-c+,--context=}'[extra textual context for the message]:context:' \
  '1: :->first' && ret=0

case $state in
  (first)
    _alternative \
      'subcommands:subcommand:(version)' \
      'revisions:git revision:_git_refs' && ret=0
    ;;
esac

return ret
