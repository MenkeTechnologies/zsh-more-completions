(( $+functions[_kin_commands] )) ||
_kin_commands() {
    local commands; commands=(
'split:Opens \$EDITOR to manage branches in a stack of commits' \
'push:Pushes all branches with upstreams (atomic, force-with-lease)' \
'pr:Create/update PRs for stack branches, or open existing PRs in the browser' \
'checkout:Interactive branch checkout' \
'move:Move current branch stack onto another branch' \
'reorder:Reorder the current stack by editing branch parents' \
'sync:Rebase the current stack onto the upstream branch in one pass' \
'restack:Repair stack dependencies by rebasing detached children onto the current branch' \
'run:Run a command on each branch in the stack' \
'commit:Commits and rebases dependent branches' \
'continue:Continue an in-progress Kindra operation' \
'abort:Abort an in-progress Kindra operation' \
'status:Show the status of an in-progress Kindra operation' \
'tree:Visualize the stack tree' \
'worktree:Manage Kindra worktrees' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'kin commands' commands "$@"
}
(( $+functions[_kin__abort_commands] )) ||
_kin__abort_commands() {
    local commands; commands=()
    _describe -t commands 'kin abort commands' commands "$@"
}
