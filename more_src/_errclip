#compdef errclip
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss38.html
# KAPPA: removes pixels with large errors from an NDF

local ret=1

_arguments -s \
  'IN=[input NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'MODE=[criterion for clipping]:mode:(Signal-to-noise Error Variance)' \
  'LIMIT=[clipping limit]:value' \
  'TITLE=[title for the output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
