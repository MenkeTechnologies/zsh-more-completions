#compdef sl

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'add:add files to be tracked'
      'amend:amend the current commit'
      'bookmark:manage bookmarks'
      'clean:remove untracked files'
      'clone:clone a repository'
      'commit:create a new commit'
      'config:show or modify configuration'
      'diff:show changes in working directory'
      'fold:fold commits into one'
      'goto:move working directory to a commit'
      'ghstack:push commits as GitHub PR stack'
      'hide:hide a commit'
      'init:initialize a new repository'
      'log:show commit history'
      'metaedit:edit commit message'
      'next:move to next commit'
      'prev:move to previous commit'
      'pr:manage pull requests'
      'pull:pull changes from remote'
      'push:push changes to remote'
      'rebase:rebase commits'
      'remove:remove files from tracking'
      'revert:revert a commit'
      'shelve:stash changes temporarily'
      'show:show commit details'
      'split:split a commit into parts'
      'status:show working directory status'
      'uncommit:undo the last commit'
      'unshelve:restore stashed changes'
      'web:open interactive smartlog'
    )
    _describe -t commands 'sl command' commands && ret=0
    ;;
  args)
    case $line[1] in
      commit)
        _arguments \
          '-m[commit message]:message' \
          '-A[add all untracked files]' \
          '--amend[amend current commit]' && ret=0
        ;;
      goto)
        _arguments '1:revision' && ret=0
        ;;
      log)
        _arguments \
          '-r[revision range]:range' \
          '--graph[show graph]' \
          '-T[template]:template' \
          '-l[limit]:count' && ret=0
        ;;
      diff)
        _arguments \
          '-r[revision]:rev' \
          '--stat[show diffstat]' \
          '*:file:_files' && ret=0
        ;;
      rebase)
        _arguments \
          '-s[source revision]:rev' \
          '-d[destination revision]:rev' && ret=0
        ;;
      bookmark)
        _arguments \
          '-r[revision]:rev' \
          '-d[delete bookmark]:bookmark' \
          '-m[rename bookmark]:bookmark' \
          '1:name' && ret=0
        ;;
      clone)
        _arguments '1:repository:_urls' '2:directory:_directories' && ret=0
        ;;
      push)
        _arguments \
          '--to[push to bookmark]:bookmark' \
          '-r[revision]:rev' \
          '--force[force push]' && ret=0
        ;;
    esac
    ;;
esac

return ret
