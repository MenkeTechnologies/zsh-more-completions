#compdef tabby-cli tabby
# Documentation: https://man.archlinux.org/search?q=tabby-cli
# Reference accessed: 2026-05-16

# tabby: self-hosted AI coding assistant
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'serve:run the Tabby server'
  'download:download a model'
  'scheduler:run the scheduler'
  'completion:get completion (debug)'
  'worker:run worker'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'tabby command' commands && ret=0 ;;
esac
return ret
