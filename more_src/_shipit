#compdef shipit
# Documentation: https://github.com/shipitjs/shipit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--shipitfile=[specify path to Shipitfile]:file:_files -g "*.js"' \
  '--require=[require module before loading Shipitfile]:module:' \
  '--tasks[list available tasks]' \
  '1:environment:' \
  '*:task:' && ret=0

return ret
