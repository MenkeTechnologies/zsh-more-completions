#compdef prterun

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-n+,--np=}'[number of processes]:n:' \
  '--host=[host list]:hosts:_hosts' \
  '--hostfile=[host file]:file:_files' \
  '*-x+[export environment variable]:var:' \
  '--bind-to=[binding policy]:policy:(none core hwthread l1cache l2cache l3cache numa socket node)' \
  '--map-by=[mapping policy]:policy:(slot hwthread core l1cache l2cache l3cache numa socket node)' \
  {-v,--verbose}'[verbose output]' \
  '*::command:_normal' && ret=0

return ret
