#compdef regula

# Regula policy engine completion

_regula_subcommands() {
  local -a subcmds=(
    'run:Evaluate rules against infrastructure'
    'write-test-inputs:Write test inputs for rules'
    'repl:Start an interactive REPL'
    'init:Initialize a new Regula project'
    'test:Run tests on rules'
    'version:Print the version'
  )
  _describe -t commands 'regula subcommand' subcmds
}

_regula() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:_regula_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        run)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            {-f,--format}'=[output format]:format:(text json table junit tap compact sarif none)' \
            {-i,--input-type}'=[input type]:type:(auto tf-plan cfn tf k8s)' \
            {-s,--severity}'=[minimum severity]:severity:(informational low medium high critical)' \
            '--no-built-in-rules[disable built-in rules]' \
            '*--include=[include rules from path]:path:_files' \
            '*--exclude=[exclude rules by ID]:rule id' \
            '*--only=[only run specific rules]:rule id' \
            '--sync[sync remote resources]' \
            '*:input paths:_files'
          ;;
        write-test-inputs)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '*:input paths:_files'
          ;;
        repl)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        init)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        test)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '*:input paths:_files'
          ;;
      esac
      ;;
  esac
}

_regula "$@"
