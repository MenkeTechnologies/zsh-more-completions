#compdef xsv2
# Documentation: https://man.archlinux.org/search?q=xsv2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'cat:concatenate CSV files by row/column'
  'count:count rows'
  'fixlengths:pad rows to equal column count'
  'flatten:flatten records vertically'
  'fmt:reformat CSV'
  'frequency:frequency distribution'
  'headers:show headers'
  'help:show help'
  'index:create row index'
  'input:read potentially malformed CSV'
  'join:join rows'
  'partition:partition by column'
  'sample:randomly sample rows'
  'reverse:reverse row order'
  'search:search rows'
  'select:select columns'
  'slice:slice rows'
  'sort:sort by columns'
  'split:split into chunks'
  'stats:compute statistics'
  'table:format as table'
  'transpose:transpose rows/columns'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'xsv2 command' commands && ret=0 ;;
esac

return ret
