#compdef butane

# Zsh completion for butane - Fedora/RHEL CoreOS config transpiler

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --files-dir)'{-d,--files-dir}'[directory for local file references]:directory:_files -/' \
  '(-o --output)'{-o,--output}'[write output to file]:file:_files' \
  '(-p --pretty)'{-p,--pretty}'[output formatted JSON]' \
  '(-r --raw)'{-r,--raw}'[never wrap the output in a JSON object]' \
  '(-s --strict)'{-s,--strict}'[fail on any warning]' \
  '*:Butane config file:_files -g "*.bu *.yaml *.yml"'
