#compdef xte
# Documentation: https://man.archlinux.org/search?q=xte
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-x --display)'{-x+,--display=}'[X display]:display:' \
  '(-d --delay)'{-d+,--delay=}'[ms delay between keys]:ms:' \
  '*: :' && ret=0

return ret
