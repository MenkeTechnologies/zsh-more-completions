#compdef tsplay
# _tsplay — TSDuck tsplay MPEG-2 TS file player that paces output at the stream bitrate to UDP/IP RTP HLS DVB-ASI Dektec SRT or RIST sinks (tsduck team, C++); custom argparse
# upstream: https://github.com/tsduck/tsduck

_tsplay() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--version[show version]' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-b+[bitrate bps]:n:' \
        '--bitrate=+[bitrate bps]:n:' \
        '--bitrate-from-pcr[use PCR bitrate]' \
        '--bitrate-from-dts[use DTS bitrate]' \
        '-O+[output plugin]:p:(file udp ip http https rist srt dektec hides null fork)' \
        '--output=+[output plugin]:p:(file udp ip http https rist srt dektec hides null fork)' \
        '-c+[N loops]:n:' \
        '--loop=+[N loops]:n:' \
        '-f[infinite loop]' \
        '--forever[infinite loop]' \
        '--first-packet=+[N]:n:' \
        '--packet-count=+[N]:n:' \
        '--time-interval=+[seconds]:n:' \
        '--start-position=+[seconds]:f:' \
        '--max-flushed-packets=+[N]:n:' \
        '--max-input-packets=+[N]:n:' \
        '--initial-input-packets=+[N]:n:' \
        '--lossless[lossless]' \
        '--no-monitor[no monitor]' \
        '--monitor[monitor]' \
        '--pcr-restamp[restamp PCR]' \
        '--continuity-restamp[restamp continuity counter]' \
        '*:input ts file:_files -g "*.ts *.m2ts *.mpeg *.mpg"'
}

_tsplay "$@"
