#compdef rmw
# Documentation: https://theimpossibleastronaut.com/rmw-website/rmw_man.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for rmw - safe-remove utility (trash)
# Upstream: https://github.com/theimpossibleastronaut/rmw

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[alternate config file]:config file:_files' \
  '(-f --force)'{-f,--force}'[allow purging of expired files]' \
  '(-r -R --recursive)'{-r,-R,--recursive}'[recursive operation]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-s --select)'{-s,--select}'[select files to restore interactively]' \
  '(-u --undo-last)'{-u,--undo-last}'[restore files from last rmw operation]' \
  '(-m --most-recent-list)'{-m,--most-recent-list}'[list most recently removed files]' \
  '(-g --purge)'{-g-,--purge=-}'[purge expired files; optional N_DAYS]:N_DAYS:' \
  '(-z --restore)'{-z,--restore}'[restore items from waste]:files:_files' \
  '(-o --orphaned)'{-o,--orphaned}'[check for orphaned files]' \
  '(-l --list)'{-l,--list}'[list waste directories]' \
  '--top-level-bypass[bypass top-level file protection]' \
  '(-w --warranty)'{-w,--warranty}'[display warranty information]' \
  '--empty[empty all waste directories]' \
  '*:files:_files'
