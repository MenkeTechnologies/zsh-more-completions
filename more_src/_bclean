#compdef bclean
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Clean an image of bad rows and cosmic rays

local ret=1

_arguments -s -S \
  'IMAGE=[image to be cleaned]:image:_files' \
  'OUTPUT=[resulting cleaned image]:output:_files' \
  'CRSIG=[cosmic ray search sigma threshold]:crsig:' \
  'CRFACT=[cosmic ray factor above neighbour average]:crfact:' \
  'CRMINV=[cosmic ray minimum value threshold]:crminv:' \
  'CRSHARPNESS=[cosmic ray core/wing sharpness ratio]:crsharpness:' \
  'BRFACT=[bad row search factor]:brfact:' \
  'BRPASS=[number of bad row detection passes]:brpass:' \
  'DEGFIX=[degree of interpolation polynomial]:degfix:' \
  'NBROWS=[number of bad rows to clean]:nbrows:' \
  'BROWS=[specific row numbers to clean]:brows:' \
  'AUTOROW=[enable automatic bad row detection]:autorow:(TRUE FALSE)' \
  'FIX=[correct rather than flag bad areas]:fix:(TRUE FALSE)' \
  'SHARPNESS=[enable sharpness test]:sharpness:(TRUE FALSE)' \
  'TEXTFILE=[produce BCLEAN.LIS results file]:textfile:(TRUE FALSE)' \
  'DIRECTION=[interpolation direction]:direction:(0 1 -1)' \
  '*:NDF data file:_files' && ret=0

return ret
