#compdef tsv-sample

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-n+[number of rows]:count' \
  '--num=[number of rows]:count' \
  '-p+[sampling probability]:probability' \
  '--prob=[sampling probability]:probability' \
  '-k+[key fields for stratified sampling]:fields' \
  '--key-fields=[key fields]:fields' \
  '-d+[delimiter]:delimiter' \
  '--delimiter=[delimiter]:delimiter' \
  '--header[input has header]' \
  '-s+[random seed]:seed' \
  '--seed=[random seed]:seed' \
  '--replace[sample with replacement]' \
  '*:file:_files' && return 0
