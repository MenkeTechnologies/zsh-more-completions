#compdef foamUnMergeCase
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamUnMergeCase — reverse of foamMergeCase, separate child overlay from base case.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-help -h)'{-help,-h}'[print usage]' \
    '*:base case then child case:_directories' \
    && ret=0

return ret
