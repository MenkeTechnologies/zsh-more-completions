#compdef drawbot drawbot-cli
# _drawbot — Just van Rossum DrawBot Python scriptable 2D-graphics environment CLI for executing .py drawing scripts into PNG PDF SVG MP4 GIF animation outputs via Quartz CoreText (typemytype team, Python); argparse
# upstream: https://github.com/typemytype/drawbot

_drawbot() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output file]:file:_files -g "*.pdf *.png *.jpg *.jpeg *.svg *.tiff *.tif *.gif *.mov *.mp4 *.bmp *.icns"' \
        '--output=+[output file]:file:_files -g "*.pdf *.png *.jpg *.jpeg *.svg *.tiff *.tif *.gif *.mov *.mp4 *.bmp *.icns"' \
        '-f+[output format]:f:(pdf png jpg jpeg svg tiff gif mov mp4 bmp icns)' \
        '--format=+[output format]:f:(pdf png jpg jpeg svg tiff gif mov mp4 bmp icns)' \
        '--page=+[page idx]:n:' \
        '--multipage[multipage]' \
        '--no-multipage[no multipage]' \
        '--imageResolution=+[dpi]:n:' \
        '-r+[dpi]:n:' \
        '--width=+[N]:n:' \
        '-W+[N]:n:' \
        '--height=+[N]:n:' \
        '-H+[N]:n:' \
        '--seed=+[N]:n:' \
        '--cwd=+[dir]:dir:_files -/' \
        '--norebuild[no rebuild]' \
        '--no-show[no show]' \
        '--frame=+[N]:n:' \
        '--variables=+[KEY=VALUE csv]:str:' \
        '*:DrawBot script:_files -g "*.py *.drawbot"'
}

_drawbot "$@"
