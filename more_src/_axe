#compdef axe
# Documentation: https://github.com/jrswab/axe
# Reference accessed: 2026-05-22
# Verified: cmd/root.go, agents.go, config.go, run.go, gc.go, version.go.

# Zsh completion for axe - TOML-defined LLM agent runner CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'axe command' \
      'run[run an agent by name]' \
      'agents[manage agent TOML configs]' \
      'config[manage axe configuration]' \
      'gc[analyze and trim agent memory]' \
      'version[print version]' && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments \
          '--skill[override agent skill path]:path:_files' \
          '--workdir[override working directory]:directory:_directories' \
          '--agents-dir[extra agents search directory]:directory:_directories' \
          '--model[override provider/model]:model:' \
          '--timeout[request timeout in seconds]:sec:' \
          '--dry-run[show context without calling LLM]' \
          '(-v --verbose)'{-v,--verbose}'[debug info to stderr]' \
          '--json[JSON output with metadata]' \
          '(-p --prompt)'{-p,--prompt}'[inline user message]:prompt:' \
          '--max-tokens[maximum total tokens]:tokens:' \
          '--artifact-dir[artifact directory]:directory:_directories' \
          '--keep-artifacts[preserve artifact directories]' \
          '--stream[stream LLM responses]' \
          '1:agent:' && ret=0
        ;;
      agents)
        case $line[2] in
          list)
            _arguments '--agents-dir[extra agents directory]:directory:_directories' && ret=0
            ;;
          show|init|edit)
            _arguments \
              '--agents-dir[extra agents directory]:directory:_directories' \
              '1:agent:' && ret=0
            ;;
          *)
            _values 'agents action' list show init edit && ret=0
            ;;
        esac
        ;;
      config)
        _values 'config action' path init && ret=0
        ;;
      gc)
        _arguments \
          '--dry-run[analyze without trimming]' \
          '--all[run on all memory-enabled agents]' \
          '--model[override model for analysis]:model:' \
          '--agents-dir[extra agents directory]:directory:_directories' \
          '1:agent:' && ret=0
        ;;
    esac
    ;;
esac

return ret
