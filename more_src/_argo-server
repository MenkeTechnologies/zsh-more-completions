#compdef argo-server
# Documentation: https://argo-workflows.readthedocs.io/en/latest/cli/argo_server/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# argo-server: Argo Workflows API/UI server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-v[count verbose]' \
  '--gloglevel=[glog level]:n:' \
  '--loglevel=[log level]:level:(panic fatal error warn info debug trace)' \
  '--log-format=[log format]:fmt:(text json)' \
  '--auth-mode=[auth modes]:modes:(server hybrid client sso)' \
  '--config-map=[name of config map]:cm:' \
  '--namespaced[namespaced operation]' \
  '--managed-namespace=[managed namespace]:ns:' \
  '--namespace=[k8s namespace]:ns:' \
  '--secure[use HTTPS]' \
  '--tls-certificate-secret-name=[TLS cert secret]:name:' \
  '--access-control-allow-origin=[CORS allow origin]:origin:' \
  '--basehref=[UI base href]:path:' \
  '--browser[open browser on start]' \
  '--port=[HTTP port]:port:' \
  '--event-async-dispatch[async event dispatch]' \
  '--event-operation-queue-size=[event queue size]:n:' \
  '--event-worker-count=[event worker count]:n:' \
  '--hsts[enable HSTS]' \
  '--x-frame-options=[X-Frame-Options value]:value:' \
  '--allowed-link-protocol=[allowed link protocols]:protocols:' \
  '--api-rate-limit=[API rate limit per second]:n:' \
  '--enable-pprof[enable pprof endpoints]' \
  '*::argo-server args:_files' && ret=0
return ret
