#compdef banshee
# Documentation: https://bansheemediaplayer.github.io/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--show[show main window]' \
  '--hide[hide main window]' \
  '--toggle[toggle main window]' \
  '--present[present main window]' \
  '--query-current-track[current track]' \
  '--query-current-state[current state]' \
  '--query-can-play[can play]' \
  '--query-can-pause[can pause]' \
  '--query-position[current position]' \
  '--query-volume[current volume]' \
  '--query-shuffle[shuffle mode]' \
  '--query-repeat[repeat mode]' \
  '--play[play]' \
  '--pause[pause]' \
  '--play-pause[toggle play/pause]' \
  '--next[next track]' \
  '--previous[previous track]' \
  '--stop[stop]' \
  '--restart-or-previous[restart or previous]' \
  '--enqueue=+[queue file]:file:_files' \
  '--play-enqueued=+[play queued]:file:_files' \
  '--set-volume=+[set volume]:n:' \
  '--set-position=+[seek]:ms:' \
  '--set-rating=+[set rating]:n:' \
  '--debug[debug]' \
  '--no-plugins[no plugins]' \
  '*:file:_files' && ret=0

return ret
