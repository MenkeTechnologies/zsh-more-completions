#compdef bhdump
# Documentation: https://github.com/sagikazarmark/bhdump
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: cargo binstall bhdump@0.0.1
# Probed via: completions zsh

autoload -U is-at-least

_bhdump() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'*-b+[Include only these browsers (can be repeated)]:BROWSERS:_default' \
'*--browser=[Include only these browsers (can be repeated)]:BROWSERS:_default' \
'*-p+[Include only these profiles (can be repeated, case-insensitive)]:PROFILES:_default' \
'*--profile=[Include only these profiles (can be repeated, case-insensitive)]:PROFILES:_default' \
'-f+[Output format\: json, jsonl, csv, tsv]:FORMAT:_default' \
'--format=[Output format\: json, jsonl, csv, tsv]:FORMAT:_default' \
'-o+[Output file (default\: stdout)]:OUTPUT:_default' \
'--output=[Output file (default\: stdout)]:OUTPUT:_default' \
'--since=[Only entries after this time (ISO 8601, relative, or natural language)]:SINCE:_default' \
'--before=[Only entries before this time (ISO 8601, relative, or natural language)]:BEFORE:_default' \
'-w+[Filter entries with a CEL expression (e.g. '\''url.contains("github")'\'')]:EXPR:_default' \
'--where=[Filter entries with a CEL expression (e.g. '\''url.contains("github")'\'')]:EXPR:_default' \
'-s+[Sort order\: field name, prefix with - for descending (e.g. -visit_count)]:SORT:_default' \
'--sort=[Sort order\: field name, prefix with - for descending (e.g. -visit_count)]:SORT:_default' \
'--limit=[Maximum number of entries to return]:LIMIT:_default' \
'--dedup[Deduplicate by URL (keep most recent)]' \
'--include-internal[Include browser-internal URLs (chrome\://, about\:, etc.)]' \
'--include-noise[Include noise domains (auth, tracking, redirects, CDNs, etc.)]' \
'--visits[Output individual visits instead of per-URL summary]' \
'*-v[Increase verbosity]' \
'*--verbose[Increase verbosity]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::since_positional -- Shorthand for --since (e.g. "today", "3 days ago", "last friday", "7d"):_default' \
":: :_bhdump_commands" \
"*::: :->bhdump" \
&& ret=0
    case $state in
    (bhdump)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:bhdump-command-$line[2]:"
        case $line[2] in
            (dump)
_arguments "${_arguments_options[@]}" : \
'*-b+[Include only these browsers (can be repeated)]:BROWSERS:_default' \
'*--browser=[Include only these browsers (can be repeated)]:BROWSERS:_default' \
'*-p+[Include only these profiles (can be repeated, case-insensitive)]:PROFILES:_default' \
'*--profile=[Include only these profiles (can be repeated, case-insensitive)]:PROFILES:_default' \
'-f+[Output format\: json, jsonl, csv, tsv]:FORMAT:_default' \
'--format=[Output format\: json, jsonl, csv, tsv]:FORMAT:_default' \
'-o+[Output file (default\: stdout)]:OUTPUT:_default' \
'--output=[Output file (default\: stdout)]:OUTPUT:_default' \
'--since=[Only entries after this time (ISO 8601, relative, or natural language)]:SINCE:_default' \
'--before=[Only entries before this time (ISO 8601, relative, or natural language)]:BEFORE:_default' \
'-w+[Filter entries with a CEL expression (e.g. '\''url.contains("github")'\'')]:EXPR:_default' \
'--where=[Filter entries with a CEL expression (e.g. '\''url.contains("github")'\'')]:EXPR:_default' \
'-s+[Sort order\: field name, prefix with - for descending (e.g. -visit_count)]:SORT:_default' \
'--sort=[Sort order\: field name, prefix with - for descending (e.g. -visit_count)]:SORT:_default' \
'--limit=[Maximum number of entries to return]:LIMIT:_default' \
'--dedup[Deduplicate by URL (keep most recent)]' \
'--include-internal[Include browser-internal URLs (chrome\://, about\:, etc.)]' \
'--include-noise[Include noise domains (auth, tracking, redirects, CDNs, etc.)]' \
'--visits[Output individual visits instead of per-URL summary]' \
'*-v[Increase verbosity]' \
'*--verbose[Increase verbosity]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::since_positional -- Shorthand for --since (e.g. "today", "3 days ago", "last friday", "7d"):_default' \
&& ret=0
;;
(browsers)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':expression -- CEL expression to validate (e.g. '\''url.contains("github")'\''):_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_bhdump__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:bhdump-help-command-$line[1]:"
        case $line[1] in
            (dump)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(browsers)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_bhdump_commands] )) ||
_bhdump_commands() {
    local commands; commands=(
'dump:Export browser history' \
'browsers:List detected browsers and profiles' \
'completions:Generate shell completions' \
'validate:Validate a CEL filter expression' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'bhdump commands' commands "$@"
}
(( $+functions[_bhdump__browsers_commands] )) ||
_bhdump__browsers_commands() {
    local commands; commands=()
    _describe -t commands 'bhdump browsers commands' commands "$@"
}
(( $+functions[_bhdump__completions_commands] )) ||
_bhdump__completions_commands() {
    local commands; commands=()
    _describe -t commands 'bhdump completions commands' commands "$@"
}
(( $+functions[_bhdump__dump_commands] )) ||
_bhdump__dump_commands() {
    local commands; commands=()
    _describe -t commands 'bhdump dump commands' commands "$@"
}
(( $+functions[_bhdump__help_commands] )) ||
_bhdump__help_commands() {
    local commands; commands=(
'dump:Export browser history' \
'browsers:List detected browsers and profiles' \
'completions:Generate shell completions' \
'validate:Validate a CEL filter expression' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'bhdump help commands' commands "$@"
}
(( $+functions[_bhdump__help__browsers_commands] )) ||
_bhdump__help__browsers_commands() {
    local commands; commands=()
    _describe -t commands 'bhdump help browsers commands' commands "$@"
}
(( $+functions[_bhdump__help__completions_commands] )) ||
_bhdump__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'bhdump help completions commands' commands "$@"
}
(( $+functions[_bhdump__help__dump_commands] )) ||
_bhdump__help__dump_commands() {
    local commands; commands=()
    _describe -t commands 'bhdump help dump commands' commands "$@"
}
(( $+functions[_bhdump__help__help_commands] )) ||
_bhdump__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'bhdump help help commands' commands "$@"
}
(( $+functions[_bhdump__help__validate_commands] )) ||
_bhdump__help__validate_commands() {
    local commands; commands=()
    _describe -t commands 'bhdump help validate commands' commands "$@"
}
(( $+functions[_bhdump__validate_commands] )) ||
_bhdump__validate_commands() {
    local commands; commands=()
    _describe -t commands 'bhdump validate commands' commands "$@"
}

if [ "$funcstack[1]" = "_bhdump" ]; then
    _bhdump "$@"
else
    compdef _bhdump bhdump
fi
