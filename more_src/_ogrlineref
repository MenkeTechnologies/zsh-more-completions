#compdef ogrlineref

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-progress[display progress]' \
  '-quiet[quiet]' \
  '-f+[output format]:format:' \
  '*-dsco+[dataset creation option]:NAME=VALUE:' \
  '*-lco+[layer creation option]:NAME=VALUE:' \
  '-create[create reference table from input vector]' \
  '-l+[input lines layer]:layer:' \
  '-p+[input points layer]:layer:' \
  '-r+[reference table layer]:layer:' \
  '-o+[output filename]:file:_files' \
  '-mb+[m field name]:name:' \
  '-pn+[part field name]:name:' \
  '-name+[reference name field]:name:' \
  '-step+[step]:value:' \
  '-get_pos[output position from m]' \
  '-get_coord[output coordinates from position]' \
  '-x+[X coord]:x:' \
  '-y+[Y coord]:y:' \
  '-m+[position M]:m:' \
  '-mb+[begin position]:value:' \
  '-me+[end position]:value:' \
  '-get_subline[output subline]' && ret=0

return ret
