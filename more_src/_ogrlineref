#compdef ogrlineref
# Documentation: https://gdal.org/programs/ogrlineref.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--help-general[show generic GDAL options]' \
  '-progress[display progress]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '-f+[output format]:format:' \
  '*-dsco+[dataset creation option]:NAME=VALUE:' \
  '*-lco+[layer creation option]:NAME=VALUE:' \
  '-create[create reference table from input vector]' \
  '-l+[input lines datasource]:datasource:_files' \
  '-ln+[lines layer name]:layer:' \
  '-lf+[field name for separating lines]:field:' \
  '-p+[input reference points datasource]:datasource:_files' \
  '-pn+[points layer name]:layer:' \
  '-pm+[distance field name]:name:' \
  '-pf+[field name for mapping points to lines]:field:' \
  '-r+[linear reference datasource]:datasource:_files' \
  '-rn+[reference table layer name]:layer:' \
  '-o+[output datasource]:file:_files' \
  '-on+[output layer name]:layer:' \
  '-of+[field name for unique values]:field:' \
  '-s+[part step in linear units]:value:' \
  '-get_pos[output position from m]' \
  '-get_coord[output coordinates from position]' \
  '-x+[X coord]:x:' \
  '-y+[Y coord]:y:' \
  '-m+[input linear distance]:m:' \
  '-mb+[begin linear distance]:value:' \
  '-me+[end linear distance]:value:' \
  '-get_subline[output subline]' && ret=0

return ret
