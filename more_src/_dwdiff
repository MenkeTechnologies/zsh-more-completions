#compdef dwdiff

# Zsh completion for dwdiff (word-level diff program)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-1 --no-deleted)'{-1,--no-deleted}'[suppress words deleted from first file]' \
  '(-2 --no-inserted)'{-2,--no-inserted}'[suppress words inserted in second file]' \
  '(-3 --no-common)'{-3,--no-common}'[suppress words common to both files]' \
  '(-A --aggregate-changes)'{-A,--aggregate-changes}'[aggregate changes]' \
  '(-c --color)'{-c,--color}'[use color output]' \
  '(-C --context)'{-C,--context}'[show context lines]:number of lines' \
  '(-d --delimiter)'{-d,--delimiter}'[specify delimiters]:delimiter characters' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[ignore case differences]' \
  '(-l --line-numbers)'{-l,--line-numbers}'[show line numbers]' \
  '(-L --no-line-numbers)'{-L,--no-line-numbers}'[suppress line numbers in context mode]' \
  '(-m --match)'{-m,--match}'[specify minimum match percentage]:percentage' \
  '(-n --autopager)'{-n,--autopager}'[start a pager automatically]' \
  '(-p --punctuation)'{-p,--punctuation}'[treat punctuation as delimiters]' \
  '(-P --program)'{-P,--program}'[use external diff program]:program:_command_names' \
  '(-R --repeat-markers)'{-R,--repeat-markers}'[repeat markers at start of each line]' \
  '(-s --statistics)'{-s,--statistics}'[show statistics at end]' \
  '(-S --paragraph-separator)'{-S,--paragraph-separator}'[treat paragraph separators as delimiters]' \
  '(-u --diff-input)'{-u,--diff-input}'[read unified diff input]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-w --start-delete)'{-w,--start-delete}'[string to mark start of deleted text]:string' \
  '(-x --stop-delete)'{-x,--stop-delete}'[string to mark end of deleted text]:string' \
  '(-y --start-insert)'{-y,--start-insert}'[string to mark start of inserted text]:string' \
  '(-z --stop-insert)'{-z,--stop-insert}'[string to mark end of inserted text]:string' \
  '--wdiff-output[produce wdiff-compatible output]' \
  '--less-mode[set pager-friendly markers]' \
  '1:first file:_files' \
  '2:second file:_files' && ret=0

return ret
