#compdef mb mountebank

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'start:Start the mountebank server'
      'stop:Stop a running mountebank server'
      'restart:Restart the mountebank server'
      'save:Save current imposters to a file'
      'replay:Switch to replay mode'
      'help:Show help'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '--port+[port to listen on]:port:' \
          '--host+[host to bind to]:host:_hosts' \
          '--configfile+[imposters config file]:file:_files' \
          '--noParse[do not parse request bodies]' \
          '--noLogFile[do not create log file]' \
          '--logLevel+[log level]:level:(debug info warn error)' \
          '--loglevel+[log level]:level:(debug info warn error)' \
          '--allowInjection[allow JavaScript injection]' \
          '--localOnly[only accept requests from localhost]' \
          '--ipWhitelist+[pipe-delimited IP whitelist]:ips:' \
          '--mock[remember requests for verification]' \
          '--debug[include debug information in responses]' \
          '--pidfile+[PID file path]:file:_files' \
          '--origin[allow all CORS origins]' \
          '--protofile+[custom protocol implementation]:file:_files' \
          '--datadir+[data directory for persistence]:dir:_files -/' \
          '--rcfile+[rc file path]:file:_files' && ret=0
        ;;
      (save)
        _arguments \
          '--savefile+[file to save to]:file:_files' \
          '--port+[port of running instance]:port:' && ret=0
        ;;
      (stop|restart)
        _arguments \
          '--pidfile+[PID file path]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
