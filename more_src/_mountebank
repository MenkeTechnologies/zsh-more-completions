#compdef mb mountebank
# Documentation: https://github.com/bbyars/mountebank/blob/master/src/cli/cli.js
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'start:Start the mountebank server'
      'stop:Stop a running mountebank server'
      'restart:Restart the mountebank server'
      'save:Save current imposters to a file'
      'replay:Switch to replay mode (remove proxies)'
      'help:Show help'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (start|restart)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port to listen on]:port:' \
          '(-h --host)'{-h+,--host=}'[host to bind to]:host:_hosts' \
          '--configfile=[imposters config file]:file:_files' \
          '--noParse[do not parse imposter config as template]' \
          '--formatter=[formatter package]:formatter:' \
          '--datadir=[data directory for persistence]:dir:_files -/' \
          '--impostersRepository=[imposters repository module]:module:' \
          '--nologfile[do not create log file]' \
          '--logfile=[log file path]:file:_files' \
          '--loglevel=[log level]:level:(debug info warn error)' \
          '--log=[log configuration JSON]:json:' \
          '(-i --allowInjection)'{-i,--allowInjection}'[allow JavaScript injection]' \
          '(-l --localOnly)'{-l,--localOnly}'[only accept requests from localhost]' \
          '(-w --ipWhitelist)'{-w+,--ipWhitelist=}'[pipe-delimited IP whitelist]:ips:' \
          '(-m --mock)'{-m,--mock}'[remember requests for verification]' \
          '(-d --debug)'{-d,--debug}'[include debug information in responses]' \
          '--protofile=[custom protocol implementation]:file:_files' \
          '(-o --origin)'{-o+,--origin=}'[allowed CORS origin]:origin:' \
          '--apikey=[API key for protected endpoints]:key:' \
          '--pidfile=[PID file path]:file:_files' \
          '--rcfile=[rc file path]:file:_files' && ret=0
        ;;
      (save)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port of running instance]:port:' \
          '(-h --host)'{-h+,--host=}'[host of running instance]:host:_hosts' \
          '--savefile=[file to save to]:file:_files' \
          '(-r --removeProxies)'{-r,--removeProxies}'[strip proxy responses]' \
          '--pidfile=[PID file path]:file:_files' \
          '--rcfile=[rc file path]:file:_files' && ret=0
        ;;
      (stop|replay)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port of running instance]:port:' \
          '(-h --host)'{-h+,--host=}'[host of running instance]:host:_hosts' \
          '--pidfile=[PID file path]:file:_files' \
          '--rcfile=[rc file path]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
