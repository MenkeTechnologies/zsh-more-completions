#compdef haddock-ghc-9.14.1

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-B+[GHC lib dir]:dir:_files -/' \
  {-o+,--odir=}'[output directory]:dir:_files -/' \
  {-l+,--lib=}'[Haddock auxiliary files location]:dir:_files -/' \
  '*'{-i+,--read-interface=}'[read interface from FILE]:file:_files' \
  {-D+,--dump-interface=}'[write interface to FILE]:file:_files' \
  '--show-interface=[print interface in human readable form]:file:_files' \
  '--no-compilation[never compile, just read .hi files]' \
  '--incremental=[generate doc for a single module]:module:' \
  '--html[output HTML]' \
  '--latex[output LaTeX]' \
  '--hoogle[output for Hoogle]' \
  '--source-base=[source base URL]:url:' \
  '--source-module=[source module URL pattern]:url:' \
  '--source-entity=[source entity URL pattern]:url:' \
  '*-w+[ignore warnings]:warning:' \
  '*--gen-contents[generate index page]' \
  '*--gen-index[generate contents page]' \
  '--use-contents=[use existing contents]:url:' \
  '--use-index=[use existing index]:url:' \
  '*:source file:_files -g "*.(hs|lhs|hi)"' && ret=0

return ret
