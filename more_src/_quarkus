#compdef quarkus
# Documentation: https://quarkus.io/guides/cli-tooling
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local -a _quarkus_commands
_quarkus_commands=(
  'create:create a new project'
  'build:build your application'
  'dev:run in development mode'
  'test:continuous testing mode'
  'extension:manage extensions'
  'ext:manage extensions (alias)'
  'image:build container image'
  'deploy:deploy application'
  'registry:manage extension registries'
  'info:display project information'
  'update:update Quarkus version'
  'plugin:manage CLI plugins'
  'version:display CLI version'
  'completion:generate shell completion'
  'help:display help'
)

_arguments -C \
  '(-e --errors)'{-e,--errors}'[display full error stacktrace]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--verbose[verbose output]' \
  '--refresh[refresh local extension registry cache]' \
  '--config=[config file]:file:_files' \
  '*-D=[Java system property]:key=value:' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'quarkus commands' _quarkus_commands
    ;;
  args)
    case "$words[1]" in
      create)
        _arguments \
          '1:subcommand:(app cli extension)' \
          '--group-id=[group id]:groupId' \
          '--artifact-id=[artifact id]:artifactId' \
          '--version=[version]:version' \
          '--package-name=[package name]:package' \
          '--extensions=[extensions to add]:extensions' \
          '--stream=[Quarkus stream]:stream' \
          '--java=[Java version]:version:(11 17 21)' \
          '--no-code[do not generate starter code]' \
          '--dry-run[show what would happen]' \
          '--output-directory=[output directory]:dir:_directories'
        ;;
      build)
        _arguments \
          '--clean[clean build]' \
          '--native[build a native executable]' \
          '--offline[work offline]' \
          '*-D=[system property]:key=value:' \
          '--no-tests[skip tests]'
        ;;
      dev)
        _arguments \
          '--clean[clean before dev]' \
          '--offline[work offline]' \
          '*-D=[system property]:key=value:'
        ;;
      extension|ext)
        _arguments \
          '1:subcommand:(add remove list categories)' \
          '(-i --installable)'{-i,--installable}'[list installable extensions]' \
          '(-s --search)'{-s,--search}'=[search]:term:' \
          '--name=[name format]:format:' \
          '--concise[concise output]' \
          '--full[full output]' \
          '--origins[show origins]' \
          '--platform=[platform]:platform' \
          '--stream=[stream]:stream' \
          '*:extension name'
        ;;
      deploy)
        _arguments \
          '1:target:(kubernetes openshift knative kind minikube)' \
          '*-D=[system property]:key=value:'
        ;;
      image)
        _arguments \
          '1:subcommand:(build push)' \
          '--builder-image=[builder image]:image:' \
          '--registry=[registry]:registry' \
          '--registry-username=[username]:user:' \
          '--registry-password-stdin[read password from stdin]'
        ;;
      update)
        _arguments \
          '--stream=[target stream]:stream' \
          '--platform-version=[platform version]:version' \
          '--no-rewrite[do not rewrite sources]'
        ;;
      completion)
        _arguments \
          '1:shell:(bash zsh)'
        ;;
    esac
    ;;
esac
