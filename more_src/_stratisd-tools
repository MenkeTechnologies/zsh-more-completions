#compdef stratisd-tools
# _stratisd-tools — wrapper for stratisd debug subtools (stratis-storage/stratisd)
# upstream: https://github.com/stratis-storage/stratisd
# Subcommands from src/bin/tools/cmds.rs (clap builder).

_stratisd-tools() {
    _arguments \
        '1:executable:(stratis-dumpmetadata stratis-checkmetadata stratis-printmetadata stratis-legacy-pool)' \
        '*::args:_normal'
}

_stratisd-tools "$@"
