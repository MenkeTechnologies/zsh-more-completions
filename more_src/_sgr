#compdef sgr
# Documentation: https://github.com/splitgraph/sgr
# Reference accessed: 2026-05-21
# Verified: upstream splitgraph/commandline/__init__.py at the URL above.

# Zsh completion for sgr - Splitgraph CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'sgr' \
      checkout commit tag import reindex log diff object objects show table \
      sql status engine mount rm init cleanup prune config dump eval upgrade \
      clone pull push upstream build dependents provenance rebuild example \
      csv cloud singer && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
