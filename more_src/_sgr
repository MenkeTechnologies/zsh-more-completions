#compdef sgr

# Zsh completion for sgr — Splitgraph client

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'sgr' mount clone commit push pull sql rebuild init staging login logout engine version && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
