#compdef studio
# Documentation: https://www.jetbrains.com/help/idea/working-with-the-ide-features-from-command-line.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: the "studio" command may refer to Android Studio, RStudio, or other
# IDE launchers; documented JetBrains Toolbox launcher options are limited.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--wait[wait for files to be closed before returning]' \
  '--nosplash[do not show splash screen]' \
  '--dontReopenProjects[show welcome screen instead of reopening projects]' \
  '--disableNonBundledPlugins[launch without manually installed plugins]' \
  '1: :->cmd' \
  '*:files or directories:_files' && ret=0

case $state in
  (cmd)
    local -a commands=(
      'diff:show differences between two files'
      'merge:open the merge dialog'
      'format:apply code style formatting'
      'inspect:run code inspection on a project'
      'installPlugins:install plugins from JetBrains Marketplace'
    )
    _describe -t cmds 'studio subcommand' commands
    _files && ret=0 ;;
esac

return ret
