#compdef aisleriot sol
# Documentation: https://gitlab.gnome.org/GNOME/aisleriot
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--variation=+[game variation]:game:' \
  '--freecell[start with freecell]' \
  '--display=+[X display]:disp:' && ret=0

return ret
