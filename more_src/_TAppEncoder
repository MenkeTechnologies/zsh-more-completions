#compdef TAppEncoder
# Documentation: https://vcgit.hhi.fraunhofer.de/jvet/HM/-/raw/master/doc/software-manual.tex
# HEVC Test Model (HM) reference encoder

local ret=1

_arguments -s -S \
  '--help[show parameter usage information]' \
  '*-c+[configuration file]:file:_files' \
  '(-i --InputFile)'{-i+,--InputFile=}'[input video file (raw planar YUV)]:file:_files' \
  '(-b --BitstreamFile)'{-b+,--BitstreamFile=}'[output coded bitstream file]:file:_files' \
  '(-o --ReconFile)'{-o+,--ReconFile=}'[output reconstructed video file]:file:_files' \
  '(-wdt --SourceWidth)'{-wdt+,--SourceWidth=}'[input width in luma samples]:width' \
  '(-hgt --SourceHeight)'{-hgt+,--SourceHeight=}'[input height in luma samples]:height' \
  '(-cf --ChromaFormatIDC)'{-cf+,--ChromaFormatIDC=}'[chroma format]:fmt:(400 420 422 444)' \
  '--InputChromaFormat=[chroma format of input]:fmt:(400 420 422 444)' \
  '(-q --QP)'{-q+,--QP=}'[base quantization parameter]:qp' \
  '(-f --FramesToBeEncoded)'{-f+,--FramesToBeEncoded=}'[number of frames to encode (0=all)]:n' \
  '(-fs --FrameSkip)'{-fs+,--FrameSkip=}'[frames to skip at beginning]:n' \
  '(-fr --FrameRate)'{-fr+,--FrameRate=}'[input video frame rate]:rate' \
  '(-ip --IntraPeriod)'{-ip+,--IntraPeriod=}'[intra frame period (-1=infinite)]:period' \
  '(-g --GOPSize)'{-g+,--GOPSize=}'[cyclic GOP structure size]:size' \
  '(-dr --DecodingRefreshType)'{-dr+,--DecodingRefreshType=}'[decoding refresh type]:type:(0 1 2 3)' \
  '(-s --MaxCUSize)'{-s+,--MaxCUSize=}'[maximum coding unit size]:size' \
  '(-sr --SearchRange)'{-sr+,--SearchRange=}'[motion estimation search range]:range' \
  '--InputBitDepth=[bit depth of input video]:depth' \
  '--InternalBitDepth=[bit depth used for coding]:depth' \
  '(-d --OutputBitDepth)'{-d+,--OutputBitDepth=}'[bit depth of reconstructed output]:depth' \
  '--Profile=[profile compliance]:profile:(main main10 main-RExt)' \
  '--Level=[level compliance]:level' \
  '--SliceMode=[slice partitioning method]:mode' \
  '--SEIDecodedPictureHash=[decoded picture hash SEI]:hash:(0 1 2 3)' \
  '--SummaryOutFilename=[summary output file]:file:_files' \
  '--FieldCoding[enable field-based coding]' \
  '*:file:_files' && ret=0

return ret
