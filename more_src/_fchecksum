#compdef fchecksum
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fchecksum.txt
# Verify or update the checksum keywords in a FITS file

local ret=1

_arguments -s \
  "infile=[input FITS file]:file:_files" \
  "update=[update the checksum keywords]:bool:(yes no)" \
  "datasum=[compute DATASUM keyword only]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
