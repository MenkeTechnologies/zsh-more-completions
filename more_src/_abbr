#compdef abbr
# Documentation: https://zsh-abbr.olets.dev/commands.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_abbr() {
    local -a commands
    commands=(
        'add:Add a new abbreviation'
        'list:List all abbreviations'
        'erase:Remove an abbreviation'
        'rename:Rename an existing abbreviation'
        'import-aliases:Convert zsh aliases to abbreviations'
        'import-git-aliases:Convert Git aliases to abbreviations'
        'import-fish:Import abbreviations from fish shell'
        'help:Display help'
    )

    if (( CURRENT == 2 )); then
        _describe -t commands 'abbr commands' commands
    else
        case $words[2] in
            add|list|erase|rename)
                _arguments -s \
                    '(-U --user)'{-U,--user}'[Persistent abbreviation]' \
                    '(-S --session)'{-S,--session}'[Session-only abbreviation]' \
                    '(-r --regular)'{-r,--regular}'[Regular abbreviation (command position)]' \
                    '(-g --global)'{-g,--global}'[Global abbreviation]' \
                    '--force[Overwrite existing]' \
                    '--quiet[Reduce output]' \
                    '--dry-run[Show changes without applying]'
                ;;
            import-fish)
                _arguments ':fish config file:_files'
                ;;
        esac
    fi
}

_abbr "$@"
