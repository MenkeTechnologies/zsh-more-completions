#compdef balloons
# _balloons — Intel NRI Balloons CPU/topology resource policy plugin (containers/nri-plugins)
# upstream: https://github.com/containers/nri-plugins
# Flag surface comes from pkg/agent/agent.go + pkg/resmgr/flags.go on tip; cmd/plugins/balloons/main.go calls flag.Parse() with no additional locals.

_balloons() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config-namespace=[k8s namespace holding the policy config]:ns:' \
        '--config-group-label=[node label key used to select the config group]:label:' \
        '--config-file=[local fallback config file]:file:_files' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--host-root=[host root mount path]:dir:_files -/' \
        '--nri-plugin-name=[plugin name to register to NRI]:name:' \
        '--nri-plugin-index=[plugin index to register to NRI]:n:' \
        '--nri-socket=[path to the NRI socket]:socket:_files' \
        '--pid-file=[pid file path]:file:_files' \
        '--state-dir=[state directory]:dir:_files -/'
}

_balloons "$@"
