#compdef conntrack-cli
# _conntrack-cli — Pablo Neira conntrack-tools userspace tools for netfilter connection tracking CLI alias (netfilter team, C); custom argparse
# upstream: https://git.netfilter.org/conntrack-tools/

_conntrack-cli() {
    local -a sub=(
        'list:list all conntrack entries'
        'get:show one conntrack entry'
        'delete:delete entries'
        'create:create a new entry'
        'update:update an existing entry'
        'event:show real-time events'
        'flush:flush all entries'
        'count:show entries count'
        'stats:show stats'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-L:list[list]' \
        '-G:get[get]' \
        '-D:delete[delete]' \
        '-I:create[create new entry]' \
        '-U:update[update]' \
        '-E:event[event]' \
        '-F:flush[flush]' \
        '-C:count[count]' \
        '-S:stats[stats]' \
        '-z[zero counters]' \
        '-o+[output mode]:m:(extended xml timestamp id ktimestamp save)' \
        '-i+[id]:str:' \
        '-j[connection mark]' \
        '-e+[events]:e:(NEW UPDATES DESTROY ALL)' \
        '-b+[event buffer size]:n:' \
        '-w+[zone direction]:str:' \
        '--zone=+[zone]:str:' \
        '-p+[proto]:p:(tcp udp udplite icmp icmpv6 sctp dccp gre)' \
        '--protonum=+[proto]:p:(tcp udp udplite icmp icmpv6 sctp dccp gre)' \
        '--protocol=+[proto]:p:(tcp udp udplite icmp icmpv6 sctp dccp gre)' \
        '-s+[src ip]:str:' \
        '--src=+[src ip]:str:' \
        '--orig-src=+[src ip]:str:' \
        '-d+[dst ip]:str:' \
        '--dst=+[dst ip]:str:' \
        '--orig-dst=+[dst ip]:str:' \
        '-r+[reply src]:str:' \
        '--reply-src=+[reply src]:str:' \
        '-q+[reply dst]:str:' \
        '--reply-dst=+[reply dst]:str:' \
        '--sport=+[src port]:port:' \
        '--orig-port-src=+[src port]:port:' \
        '--dport=+[dst port]:port:' \
        '--orig-port-dst=+[dst port]:port:' \
        '--state=+[tcp state]:s:(NONE SYN_SENT SYN_RECV ESTABLISHED FIN_WAIT CLOSE_WAIT LAST_ACK TIME_WAIT CLOSE LISTEN)' \
        '--status=+[status]:str:' \
        '--timeout=+[seconds]:n:' \
        '--mark=+[mark/mask]:str:' \
        '--use-mark=+[mark]:str:' \
        '--label=+[label]:str:' \
        '--label-add=+[label]:str:' \
        '--label-del=+[label]:str:' \
        '--family=+[family]:f:(ipv4 ipv6)' \
        '-f+[family]:f:(ipv4 ipv6)' \
        '--max-src-objects=+[n]:n:' \
        '--max-dst-objects=+[n]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'conntrack subcommand' sub ;;
    esac
}

_conntrack-cli "$@"
