#compdef email2phonenumber email2phonenumber.py
# Documentation: https://github.com/martinvigo/email2phonenumber
# OSINT: obtain a target's phone number from an email address.

local ret=1
local -a subcmds

subcmds=(
  'scrape:scrape phone number digits from password reset pages'
  'generate:generate a phone number dictionary from a mask'
  'bruteforce:bruteforce phone numbers via password resets'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds) _describe -t commands 'email2phonenumber command' subcmds && ret=0 ;;
  args)
    case $line[1] in
      scrape)
        _arguments -s \
          '-e+[victim email address]:email:_email_addresses' \
          '-p+[file with list of https proxies]:file:_files' \
          '-q[scrape services that do not alert the victim]' && ret=0 ;;
      generate)
        _arguments -s \
          '-m+[masked 10-digit US phone number (e.g. 555XXX1234)]:mask:' \
          '-o+[output the list to a dictionary file]:file:_files' \
          '-q[use services that do not alert the victim]' \
          '-p+[file with list of https proxies]:file:_files' && ret=0 ;;
      bruteforce)
        _arguments -s \
          '-e+[victim email address]:email:_email_addresses' \
          '-m+[masked 10-digit US phone number (e.g. 555XXX1234)]:mask:' \
          '-d+[file with list of numbers to try]:file:_files' \
          '-p+[file with list of https proxies]:file:_files' \
          '-q[use services that do not alert the victim]' \
          '-v[verbose output]' && ret=0 ;;
    esac ;;
esac

return ret
