#compdef virtctl

# Zsh completion for virtctl - KubeVirt CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'addvolume:add a volume to a running VM'
  'console:connect to a serial console'
  'create:create a resource from a manifest'
  'credentials:manage VM credentials'
  'expand:expand instancetype and preference'
  'expose:expose a VM or VMI as a service'
  'fslist:list filesystems in a guest'
  'guestosinfo:show guest OS info'
  'image-upload:upload a VM image'
  'migrate:migrate a VM'
  'migrate-cancel:cancel a VM migration'
  'pause:pause a VM'
  'permitted-devices:list permitted devices'
  'port-forward:forward local ports to a VM'
  'removevolume:remove a volume from a running VM'
  'restart:restart a VM'
  'scp:SCP files to/from a VM'
  'soft-reboot:soft reboot a VM'
  'ssh:SSH into a VM'
  'start:start a VM'
  'stop:stop a VM'
  'unpause:unpause a VM'
  'usbredir:redirect USB device to a VM'
  'userlist:list users in a guest'
  'version:show version'
  'vnc:open a VNC connection'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig[path to kubeconfig]:file:_files' \
  '(-n --namespace)'{-n,--namespace}'[namespace]:namespace' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'virtctl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      start|stop|restart|pause|unpause|migrate|migrate-cancel|soft-reboot)
        _arguments '1:VM name' && ret=0
        ;;
      console)
        _arguments \
          '--timeout[connection timeout]:seconds' \
          '1:VMI name' && ret=0
        ;;
      ssh)
        _arguments \
          '(-l --local-ssh)'{-l,--local-ssh}'[use local SSH client]' \
          '(-p --port)'{-p,--port}'[SSH port]:port' \
          '--username[SSH username]:username' \
          '-i[identity file]:file:_files' \
          '(-c --command)'{-c,--command}'[remote command]:command' \
          '1:VMI name' && ret=0
        ;;
      scp)
        _arguments \
          '-r[recursive copy]' \
          '1:source' \
          '2:destination' && ret=0
        ;;
      expose)
        _arguments \
          '--name[service name]:name' \
          '--port[service port]:port' \
          '--target-port[target port]:port' \
          '--type[service type]:type:(ClusterIP NodePort LoadBalancer)' \
          '--protocol[protocol]:protocol:(TCP UDP)' \
          '1:resource type:(vm vmi)' \
          '2:resource name' && ret=0
        ;;
      vnc)
        _arguments \
          '--proxy-only[run proxy without launching viewer]' \
          '--port[local port]:port' \
          '1:VMI name' && ret=0
        ;;
      image-upload)
        _arguments \
          '--image-path[path to image]:file:_files' \
          '--pvc-name[PVC name]:name' \
          '--pvc-size[PVC size]:size' \
          '--storage-class[storage class]:class' \
          '--access-mode[access mode]:mode:(ReadWriteOnce ReadOnlyMany ReadWriteMany)' \
          '--insecure[allow insecure connections]' \
          '--no-create[do not create PVC]' \
          '--uploadproxy-url[upload proxy URL]:url' && ret=0
        ;;
    esac
    ;;
esac

return ret
