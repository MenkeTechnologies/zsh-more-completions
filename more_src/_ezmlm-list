#compdef ezmlm-list
# Documentation: https://man.archlinux.org/search?q=ezmlm-list
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-d[show digest list]' \
  '-D[show normal list]' \
  '-n[no sub/unsub]' \
  '-N[allow sub/unsub]' \
  '1:dir:_files -/' \
  '2:base:' && ret=0

return ret
