#compdef git-publish
# Documentation: https://github.com/stefanha/git-publish
# git publish — prepare and store patch revisions as git tags and send them by email.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--annotate[review and edit each patch email]' \
  '(-b --base)'{-b+,--base=}'[branch which this is based off]:branch:__git_branch_names' \
  '--blurb-template=[template for blurb]:template:' \
  '*--cc=[specify a Cc: email recipient]:email:' \
  '--cc-cmd=[command whose output to add to the cc list]:command:' \
  '(--check-url --no-check-url)--no-check-url[skip publicly accessible pull request URL check]' \
  '(--check-url --no-check-url)--check-url[check pull request URLs are publicly accessible]' \
  '--skip=[unselect the first N patch emails]:N:' \
  '--edit[edit message but do not tag a new version]' \
  '(--inspect-emails --no-inspect-emails)--no-inspect-emails[no confirmation before sending emails]' \
  '(--inspect-emails --no-inspect-emails)--inspect-emails[show confirmation before sending emails]' \
  '(-n --number)'{-n+,--number=}'[version number]:number:' \
  '(-m --message --cover-letter --no-message --no-cover-letter)'{--no-message,--no-cover-letter}'[do not add a message]' \
  '(-m --message --cover-letter --no-message --no-cover-letter)'{-m,--message,--cover-letter}'[add a message]' \
  '--no-cover-info[do not append comments info when editing the cover letter]' \
  '--no-binary[do not output contents of changes in binary files]' \
  '(-p --profile)'{-p+,--profile=}'[select default settings profile]:profile:' \
  '--pull-request[tag and send as a pull request]' \
  '(--sign-pull --no-sign-pull)--sign-pull[sign tag when sending pull request]' \
  '(--sign-pull --no-sign-pull)--no-sign-pull[do not sign tag when sending pull request]' \
  '(-k --keyid)'{-k+,--keyid=}'[GPG key to use when signing pull request tag]:keyid:' \
  '--subject-prefix=[set the email Subject: header prefix]:prefix:' \
  '--clear-subject-prefix[clear the per-branch subject prefix]' \
  '--setup[add git alias in ~/.gitconfig]' \
  '(-t --topic)'{-t+,--topic=}'[topic name]:topic:' \
  '*--to=[specify a primary email recipient]:email:' \
  '(-s --signoff)'{-s,--signoff}'[add Signed-off-by: to commits when emailing]' \
  '--notes[append the commit notes after the three-dash line]' \
  '--suppress-cc=[override auto-cc when sending email]:value:' \
  '(-v --verbose)'{-v,--verbose}'[show executed git commands]' \
  '--forget-cc[forget all previous CC emails]' \
  '--override-to[ignore any profile or saved TO emails]' \
  '--override-cc[ignore any profile or saved CC emails]' \
  '(-R --in-reply-to)'{-R+,--in-reply-to=}'[In-Reply-To: of the cover letter or single patch]:msgid:' \
  '(--thread --no-thread)--no-thread[do not add In-Reply-To: headers to any email]' \
  '(--thread --no-thread)--thread[add In-Reply-To: headers to sent emails]' \
  '*'{-H+,--add-header=}'[custom header to pass to git-send-email]:header:' \
  '(-S --separate-send)'{-S,--separate-send}'[send patches using separate git-send-email cmd]' \
  '*--send-email-args=[argument forwarded to git-send-email]:arg:' && ret=0

return ret
