#compdef samhain
# Documentation: https://man.archlinux.org/search?q=samhain
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-c+[mode]:mode:(check update init full)' \
  '-D[run as daemon]' \
  '-e+[set runlevel]:level:' \
  '-f[run in foreground]' \
  '-i[init database]' \
  '-l+[loglevel]:level:(info notice warn err crit alert emerg)' \
  '-L+[log file]:file:_files' \
  '-m+[mode]:mode:' \
  '-n[no daemon]' \
  '-p+[PID file]:file:_files' \
  '-r+[reload signal]:signal:' \
  '-s[silent mode]' \
  '-t+[verify type]:type:(check update init full)' \
  '-v[verbose]' \
  '-q+[quote-mode]:mode:' \
  '-w+[whitelist mode]:mode:' \
  '-y[print yule (server)]' \
  '-Y[print yulectl]' \
  '--ignore-missing[ignore missing files]' \
  '--no-extshell[no shell injection]' && ret=0

return ret
