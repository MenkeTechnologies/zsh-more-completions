#compdef license-checker

# Zsh completion for license-checker - check npm project licenses

local -a arguments

arguments=(
  '--help[show help information]'
  '--version[show license-checker version]'
  '--production[only list production dependencies]'
  '--development[only list development dependencies]'
  '--unknown[report packages with unknown licenses]'
  '--onlyunknown[only list packages with unknown licenses]'
  '--json[output as JSON]'
  '--csv[output as CSV]'
  '--csvHeaders[output CSV header row]'
  '--markdown[output as Markdown]'
  '--out[write output to file]:file:_files'
  '--files[copy license files to this directory]:directory:_files -/'
  '--start[path to start from]:directory:_files -/'
  '--onlyAllow[semicolon-separated allowed license list]:licenses:'
  '--failOn[semicolon-separated license list that fails]:licenses:'
  '--excludePackages[semicolon-separated excluded package list]:packages:'
  '--excludePackagesStartingWith[exclude packages starting with prefix]:prefix:'
  '--includePackages[semicolon-separated included package list]:packages:'
  '--relativeLicensePath[output relative license paths]'
  '--summary[summarize licenses found]'
  '--customPath[path to custom format JSON]:file:_files -g "*.json"'
  '--includeVersions[include version in package names]'
  '--direct[only list direct dependencies]'
  '--excludePrivatePackages[exclude packages marked private]'
  '--limitAttributes[limit attributes in output]:attributes:'
)

_arguments -s $arguments
