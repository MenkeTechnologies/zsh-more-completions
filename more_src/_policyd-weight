#compdef policyd-weight

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --defaults)'{-d,--defaults}'[show defaults]' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-r --re-read)'{-r,--re-read}'[re-read config]' \
  '(-s --stop)'{-s,--stop}'[stop daemon]' \
  '(-D --debug)'{-D,--debug}'[debug mode]' && ret=0

return ret
