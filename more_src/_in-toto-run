#compdef in-toto-run

_arguments -s \
  '(-n --step-name)'{-n,--step-name}'=[step name]:name:' \
  '*'{-m,--materials}'=[material path]:path:_files' \
  '*'{-p,--products}'=[product path]:path:_files' \
  '(-s --record-streams)'{-s,--record-streams}'[record stdout/stderr]' \
  '(-x --no-command)'{-x,--no-command}'[do not run command]' \
  '(-P --password)'{-P,--password}'[prompt for key password]' \
  '(-g --gpg)'{-g,--gpg}'=[GPG keyid]:keyid:' \
  '--gpg-home=[GPG home]:dir:_files -/' \
  '--signing-key=[signing key file]:file:_files' \
  '*--exclude=[exclude pattern]:pattern:' \
  '--base-path=[base path]:dir:_files -/' \
  '*--lstrip-paths=[lstrip path prefix]:prefix:' \
  '(-d --metadata-directory)'{-d,--metadata-directory}'=[metadata dir]:dir:_files -/' \
  '--use-dsse[use DSSE wrapper]' \
  '--run-timeout=[run timeout]:s:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(- *)--version[show version]' \
  '*::command: _command_names'
