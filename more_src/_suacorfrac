#compdef suacorfrac
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/convolution_correlation/suacorfrac.c
# SUACORFRAC - general FRACtional Auto-CORrelation/convolution

local ret=1

_arguments -s -S \
  'a=[exponent of complex amplitude]:a:' \
  'b=[multiplier of complex phase]:b:' \
  'dt=[time sample interval (seconds)]:d:' \
  'verbose=[=1 for advisory messages]:v:(0 1)' \
  'ntout=[number of time samples output]:n:' \
  'sym=[non-zero produces symmetric output]:s:(0 1)' \
  'power=[required power parameter]:p:' \
  '*:SU file:_files' && ret=0

return ret
