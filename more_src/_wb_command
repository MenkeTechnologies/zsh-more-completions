#compdef wb_command
# Documentation: https://www.humanconnectome.org/software/workbench-command
# HCP Connectome Workbench command-line processing program

local ret=1

_arguments -s -S \
  '-help[display help info]' \
  '-version[show the version of wb_command]' \
  '-list-commands[list all processing subcommands]' \
  '-list-deprecated-commands[list deprecated subcommands]' \
  '-all-commands-help[show all processing subcommands and their help info]' \
  '-arguments-help[explain the format of subcommand help info]' \
  '-global-options[display options that can be added to any command]' \
  '-parallel-help[details on how wb_command uses parallelization]' \
  '-cifti-help[explain the cifti file format]' \
  '-gifti-help[explain the gifti file format]' \
  '-volume-help[explain volume files]' \
  '*:subcommand:_default' && ret=0

return ret
