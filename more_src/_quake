#compdef quake
# Documentation: https://manpages.org/quake/6
# Reference accessed: 2026-05-16
# Verified: quake(6) Debian wrapper manpage. Engine accepts +/- prefix
# tokens as pass-through.
# Removed from prior file: bogus man.archlinux.org search URL.

# quake: id Software Quake (Debian wrapper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debugger=[prepend debugger to engine command]:debugger:_command_names' \
  '--print-backtrace[use gdb for crash backtrace]' \
  '*:engine arg:_files' && ret=0
return ret
