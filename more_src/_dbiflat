#compdef dbiflat
# Documentation: https://man.archlinux.org/search?q=dbiflat
# Reference accessed: 2026-05-16

# EMBOSS dbiflat: build an EMBOSS index for a flat-file (EMBL/GenBank/Swiss) database
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-dbname=[database name]:name:' \
  '-standardfilename=[standard filename layout]:bool:(Y N)' \
  '-directory=[data file directory]:dir:_files -/' \
  '-filenames=[wildcard for files]:pattern:' \
  '-idformat=[database flat-file format]:format:(EMBL SWISS GB REFSEQ)' \
  '-fields=[fields to index (id,acc,sv,des,key,org,tax)]:fields:' \
  '-release=[database release]:release:' \
  '-date=[database date]:date:' \
  '-exclude=[exclude patterns]:patterns:' \
  '-files=[explicit file list]:files:_files' \
  '-indexoutdir=[output dir for index]:dir:_files -/' \
  '-maxindex=[max index files]:n:' \
  '-systemsort[use OS sort utility]' \
  '-cleanup[delete temp files]' \
  '*:database name:' && ret=0
return ret
