#compdef extractclumps
# Documentation: https://starlink.eao.hawaii.edu/docs/sun255.htx/sun255ss3.html
# CUPID: extract previously identified clumps of emission from an NDF.

local ret=1

_arguments -s -S \
  'DATA=[input NDF with physical data values]:ndf:_files' \
  'MASK=[input NDF with clump pixel assignments]:ndf:_files' \
  'OUT=[output NDF]:ndf:_files' \
  'OUTCAT=[KAPPA-style output catalogue]:cat:_files' \
  'JSACAT=[JSA-style output catalogue]:cat:_files' \
  'BACKOFF=[remove background before sizing]:flag:(TRUE FALSE)' \
  'DECONV=[apply beam correction]:flag:(TRUE FALSE)' \
  'FWHMBEAM=[beam FWHM in pixels]:fwhm:' \
  'VELORES=[velocity resolution in channels]:res:' \
  'SHAPE=[catalogue shape]:shape:(Polygon Ellipse Ellipse2 Ellipse3 None)' \
  'WCSPAR=[store params in WCS units]:flag:(TRUE FALSE)' \
  'LOGFILE=[text log file]:file:_files' \
  '*:ndf:_files' && ret=0

return ret
