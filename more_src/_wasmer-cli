#compdef wasmer
# Documentation: https://man.archlinux.org/search?q=wasmer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add packages to deno-like project'
  'app:Wasmer Edge app commands'
  'auth:authentication'
  'cache:cache management'
  'compile:precompile a wasm to native code'
  'config:show wasmer config'
  'connect:connect to remote runtime'
  'container:container subcommands'
  'create-exe:create a native executable'
  'create-obj:create native object'
  'deploy:deploy app to Wasmer Edge'
  'domain:domain commands'
  'gen-c-header:generate C header'
  'init:initialize a wasmer.toml'
  'inspect:inspect a wasm/wat file'
  'login:log in to Wasmer'
  'logout:log out'
  'namespace:namespace commands'
  'package:package commands'
  'publish:publish a package to Wasmer'
  'run:run a wasm file'
  'self-update:update wasmer'
  'ssh:open SSH to Edge instance'
  'uninstall:uninstall wasmer'
  'volume:volume commands'
  'wast:run wast tests'
  'wat2wasm:wat to wasm'
  'wasm2wat:wasm to wat'
  'whoami:show logged in user'
  'help:show help'
  'completions:generate completions'
  'completion:generate completions'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-v[verbose]' \
  '*--log-format=[log format]:f:(text json)' \
  '*--registry=[registry URL]:url:' \
  '*--token=[token]:t:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wasmer command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--invoke=[function name]:fn:' \
          '--addr=[bind address]:addr:' \
          '*--env=[env var]:e:' \
          '*--mapdir=[map dir]:m:' \
          '*--dir=[dir]:dir:_files -/' \
          '*--coredump-on-trap=[coredump file]:file:_files' \
          '--enable-all[enable all features]' \
          '--enable-bulk-memory[bulk memory]' \
          '--enable-multi-memory[multi memory]' \
          '--enable-multi-value[multi value]' \
          '--enable-reference-types[reference types]' \
          '--enable-simd[SIMD]' \
          '--enable-threads[threads]' \
          '--enable-tail-call[tail call]' \
          '--enable-memory64[memory64]' \
          '--enable-relaxed-simd[relaxed SIMD]' \
          '--enable-extended-const[extended const]' \
          '--enable-component-model[component model]' \
          '--allow-multiple-wasi-versions[multi WASI]' \
          '--llvm[LLVM compiler]' \
          '--cranelift[Cranelift compiler]' \
          '--singlepass[Singlepass compiler]' \
          '--use=[bundle URL]:u:' \
          '--bundle=[bundle file]:file:_files' \
          '*: :_files -g "*.wasm *.wat *.webc"' && ret=0 ;;
      (compile|create-exe|create-obj|inspect|gen-c-header)
        _arguments \
          '-o+[output]:file:_files' \
          '--target=[target triple]:t:' \
          '--cpu-features=[cpu features csv]:list:' \
          '--llvm[LLVM]' \
          '--cranelift[Cranelift]' \
          '--singlepass[Singlepass]' \
          '*: :_files -g "*.wasm *.wat"' && ret=0 ;;
      (publish|deploy|init|login|whoami|cache)
        _arguments '*: :' && ret=0 ;;
      (completion|completions)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
