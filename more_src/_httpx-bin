#compdef httpx
# _httpx-bin — ProjectDiscovery httpx HTTP toolkit (ProjectDiscovery, Go); fast multi-purpose HTTP probe for authorized reconnaissance
# upstream: https://github.com/projectdiscovery/httpx

_httpx-bin() {
    _arguments \
        '-h[show help]' \
        '-version[show version]' \
        '-u+[target URL/host]:str:' \
        '-l+[list file]:file:_files' \
        '-rr+[record routes file]:file:_files' \
        '-p+[ports]:ports:' \
        '-path+[paths to probe]:paths:' \
        '-http2[probe HTTP/2]' \
        '-pipeline[probe HTTP/1.1 pipelining]' \
        '-x+[methods]:methods:' \
        '-vhost[check vhost]' \
        '-tls-grab[collect TLS data]' \
        '-tls-probe[probe with TLS]' \
        '-csp-probe[probe CSP header]' \
        '-favicon[probe favicon hash]' \
        '-jarm[print JARM fingerprint]' \
        '-screenshot[take screenshot]' \
        '-system-chrome[use system chrome]' \
        '-headless-options+[chromium opts]:str:' \
        '-asn[print ASN]' \
        '-irr[include resp body in JSON]' \
        '-include-chain[include redirect chain]' \
        '-include-response[include full body]' \
        '-include-response-base64[include base64 body]' \
        '-store-response[store response body]' \
        '-store-response-dir+[dir]:dir:_files -/' \
        '-store-chain[store chain]' \
        '-json[json output]' \
        '-csv[csv output]' \
        '-output+[output file]:file:_files' \
        '-status-code[show status]' \
        '-content-length[show content length]' \
        '-content-type[show content type]' \
        '-location[show redirect location]' \
        '-favicon-hash[show favicon hash]' \
        '-jarm-fingerprint[show JARM]' \
        '-tech-detect[wappalyzer-like detect]' \
        '-title[show title]' \
        '-server[show server header]' \
        '-method[show method]' \
        '-website[show website name]' \
        '-ip[show resolved IP]' \
        '-cname[show CNAME]' \
        '-cdn[show CDN type]' \
        '-asn[show ASN]' \
        '-line-count[show line count]' \
        '-words-count[show word count]' \
        '-store-vision-data[store vision data]' \
        '-no-fallback[disable HTTPS fallback]' \
        '-no-fallback-scheme[do not change scheme]' \
        '-rl+[rate limit]:n:' \
        '-rate-limit-minute+[rate per min]:n:' \
        '-threads+[threads]:n:' \
        '-retries+[retries]:n:' \
        '-timeout+[timeout sec]:n:' \
        '-mc+[match status code]:codes:' \
        '-mlc+[match line count]:n:' \
        '-mwc+[match word count]:n:' \
        '-ms+[match string]:str:' \
        '-mr+[match regex]:regex:' \
        '-fc+[filter status code]:codes:' \
        '-flc+[filter line count]:n:' \
        '-fwc+[filter word count]:n:' \
        '-fs+[filter string]:str:' \
        '-fr+[filter regex]:regex:' \
        '-no-color[no color]' \
        '-silent[silent]' \
        '-stats[show stats]' \
        '-v[verbose]' \
        '*:target:'
}

_httpx-bin "$@"
