#compdef opensmtpd smtpd
# Documentation: https://man.openbsd.org/smtpd.8
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# OpenSMTPD: OpenBSD SMTP daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[display version and usage]' \
  '-d[do not daemonize; log to stderr]' \
  '-D+[define macro on command line]:macro=value:' \
  '-F[do not daemonize; log to syslogd]' \
  '-f+[config file]:file:_files -g "*.conf"' \
  '-n[only validate config]' \
  '-P+[temporarily disable subsystem]:subsystem:(mda mta smtp)' \
  '-T+[enable real-time tracing]:trace:(imsg io smtp mfa mta mda lookup stat rules expand all)' \
  '-v[verbose output]' \
  '*::opensmtpd args:_files' && ret=0
return ret
