#compdef opensmtpd smtpd
# Documentation: https://man.archlinux.org/search?q=opensmtpd
# Reference accessed: 2026-05-16

# OpenSMTPD: OpenBSD SMTP daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[debug mode (foreground)]' \
  '-D[macro=value]:macro=value:' \
  '-f[config file]:file:_files -g "*.conf"' \
  '-F[reset queue file format on next reload]' \
  '-n[only validate config]' \
  '-P[program to be enabled]:list:(mta mda smtp)' \
  '-T[trace subsystem]:trace:(imsg io smtp mfa mta mda lookup stat rules expand all)' \
  '-v[verbose]' \
  '-x[exit after init]' \
  '*::opensmtpd args:_files' && ret=0
return ret
