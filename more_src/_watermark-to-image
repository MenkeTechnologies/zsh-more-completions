#compdef watermark-to-image
# ============================================================================
# watermark-to-image - batch-apply a PNG watermark to
#                       images in a directory (Go,
#                       Apache-2.0)
#
# Author : Daniel Christian Schroeter (danielchristianschroeter)
# Upstream: https://github.com/danielchristianschroeter/
#           watermark-to-image
#
# `watermark-to-image` walks a source directory of
# image files, applies a configurable PNG
# watermark to each one (positionable, scalable,
# opacity-tunable), optionally resizes the
# watermarked output to fit a target dimension, and
# writes the result to a target directory. EXIF
# orientation metadata is preserved on the output
# images.
#
# Use cases:
#   - Batch-watermark product photos for an
#     e-commerce catalog
#   - Apply copyright marks to a portfolio batch
#     before uploading
#   - Generate thumbnails with a publisher's logo
#     overlay
#
# Usage:
#   watermark-to-image \
#       -sourceDirectory <src-dir> \
#       -targetDirectory <out-dir> \
#       -watermarkImageFile <watermark.png> \
#       [other-options]
#
# Required flags (Go stdlib flag.* parsing):
#   -sourceDirectory <dir>           - source
#                                       directory
#                                       containing
#                                       original
#                                       images
#   -targetDirectory <dir>           - target
#                                       directory for
#                                       watermarked
#                                       output
#   -watermarkImageFile <file>       - PNG watermark
#                                       image path
#
# Watermark sizing:
#   -watermarkScaleFactor <%>        - watermark
#                                       scale
#                                       percentage
#                                       (default
#                                       100.0)
#   -watermarkOpacity <0..1>         - watermark
#                                       opacity
#                                       (default 0.5)
#
# Watermark positioning:
#   -watermarkMarginRight <px>       - margin from
#                                       right edge
#                                       (default 20)
#   -watermarkMarginBottom <px>      - margin from
#                                       bottom edge
#                                       (default 20)
#
# Output resizing (mutually exclusive groups):
#   -targetWatermarkedImageMaxDimension <px>
#                                    - max output
#                                       dimension
#                                       (preserves
#                                       aspect; 0 =
#                                       no resize;
#                                       conflicts
#                                       with width/
#                                       height)
#   -targetWatermarkedImageWidth <px>
#                                    - explicit width
#                                       (preserves
#                                       aspect if
#                                       height = 0)
#   -targetWatermarkedImageHeight <px>
#                                    - explicit
#                                       height
#                                       (preserves
#                                       aspect if
#                                       width = 0)
#
# Output naming:
#   -targetWatermarkedImageFilename <name>
#                                    - rename all
#                                       outputs to
#                                       this base
#                                       filename
#   -targetWatermarkedImageFilenameSuffix <type>
#                                    - dynamic
#                                       filename
#                                       suffix:
#                                       3DIGITSCOUNT
#                                       (default) or
#                                       RAND
#                                       (6-digit
#                                       random number)
#
# Global:
#   -h                               - print help
#   -version                         - print version
#
# The disintegration/imaging lane is built on
# `github.com/disintegration/imaging v1.6.2`
# (declared verbatim at upstream go.mod HEAD as a
# direct dep, imported as `"github.com/disintegration/
# imaging"` then `imaging.Open(path)` +
# `imaging.Resize(img, w, h, imaging.Lanczos)` +
# `imaging.Overlay(base, overlay, pt, opacity)`),
# the canonical Go image processing library by
# Grigory Dryapak (disintegration) - github.com/
# disintegration/imaging, 5600+ stars.
#
# disintegration/imaging is a thin transformation
# layer built on top of the Go stdlib's `image` +
# `image/jpeg` + `image/png` + `image/gif` +
# `image/draw` packages. The library adds:
#   - High-level format-agnostic load/save:
#     `Open(path)` + `Save(img, path)` work for any
#     stdlib-supported format
#   - Resize with selectable resampling kernel:
#     NearestNeighbor / Box / Linear /
#     MitchellNetravali / Lanczos / CatmullRom
#   - Crop / Fit / Fill / Thumbnail with anchor
#     points
#   - Rotate by arbitrary angle with edge fill
#   - Flip (horizontal + vertical)
#   - Blur (Gaussian)
#   - Sharpen / Contrast / Brightness / Saturation /
#     Hue / Gamma adjustments
#   - Sepia / Grayscale / Invert color filters
#   - Overlay / Paste / PasteCenter compositing
#   - EXIF orientation correction on load
#
# The library has been the de-facto Go image
# canonical since 2016 - depended on by:
#   - Hugo (image processing pipeline for static
#     sites)
#   - go-shiori/shiori (bookmark thumbnail
#     generation)
#   - go-shiori/obelisk (the Go single-HTML web
#     archiver from Axis 258)
#   - thumbra (S3 thumbnail generation)
#   - imageup (Google Cloud image microservice)
#   - watermark-to-image (THIS BINARY)
#   - many of the Go bots / Discord wrappers / image
#     processing utilities
#
# watermark-to-image uses disintegration/imaging in
# the per-image processing loop:
#   1. `imaging.Open(sourceFile)` to load the
#      original image (EXIF orientation auto-
#      corrected)
#   2. `imaging.Resize(watermark, scaledW, scaledH,
#      imaging.Lanczos)` to scale the watermark to
#      `--watermarkScaleFactor` percent of original
#   3. `imaging.Overlay(base, scaledWatermark,
#      bottomRightPoint, opacity)` to composite the
#      watermark onto the base image
#   4. If --target* resize flag is set:
#      `imaging.Fit(combined, targetW, targetH,
#      imaging.Lanczos)` to constrain to target
#      dimensions
#   5. `imaging.Save(combined, targetPath)` writes
#      the output JPEG/PNG
#
# ----------------------------------------------------------------------------
# AXIS 259 :: Image processing libraries (multi-format
#              decoders + encoders + transformation
#              primitives)
# Round 1476 :: Go slot 2 of 4 :: continues Axis 259
#
# Cross-language canonical library family for this axis:
#   Rust    : image-rs/image                [R1475 _wpc]
#             umbrella
#   Go      : disintegration/imaging        [R1476 THIS FILE]
#             (built on stdlib image package)
#   TS/Node : lovell/sharp                  [R1477 closing]
#             (libvips binding)
#
# disintegration/imaging is structurally interesting
# in this axis because of its *stdlib-extension*
# pattern. Unlike the Rust slot (image-rs, an
# entirely separate multi-format umbrella) and the
# Node slot (lovell/sharp, a libvips binding), the
# Go canonical is essentially a transformation-
# primitives layer ON TOP OF the Go stdlib.
#
# The Go stdlib provides:
#   - `image` (universal pixel type + format-
#     agnostic interfaces)
#   - `image/jpeg` (JPEG decoder + encoder)
#   - `image/png` (PNG decoder + encoder)
#   - `image/gif` (GIF decoder + encoder; basic
#     animation)
#   - `image/draw` (image composition primitives)
#   - `image/color` (color model)
#
# disintegration/imaging adds:
#   - Format-agnostic file I/O
#   - High-level transformations (resize, crop,
#     rotate, ...)
#   - EXIF orientation handling
#   - Filter chains (Gaussian blur, sepia, grayscale,
#     ...)
#
# This stdlib-extension pattern is unique to the
# Go slot in this axis cluster. The Rust + Node
# slots both maintain entirely separate ecosystems
# from the host language's stdlib (Rust stdlib has
# no image support; Node stdlib has no image
# support).
#
# Cross-language interop at the wire format level - a
# PNG / JPEG / GIF / TIFF / WebP file decoded by
# image-rs + disintegration/imaging + lovell/sharp
# produces structurally identical pixel data
# (modulo per-decoder color-management decisions
# for embedded ICC profiles).
# ============================================================================

_watermark-to-image() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '-sourceDirectory[source directory (original images)]:dir:_files -/' \
        '-targetDirectory[target directory (watermarked output)]:dir:_files -/' \
        '-watermarkImageFile[PNG watermark image path]:file:_files -g "*.png"' \
        '-watermarkScaleFactor[scale factor (% of original)]:percent:' \
        '-watermarkOpacity[opacity 0.0-1.0]:opacity:' \
        '-watermarkMarginRight[right margin (px)]:px:' \
        '-watermarkMarginBottom[bottom margin (px)]:px:' \
        '-targetWatermarkedImageMaxDimension[max output dimension (0 = no resize)]:px:' \
        '-targetWatermarkedImageWidth[explicit output width (px)]:px:' \
        '-targetWatermarkedImageHeight[explicit output height (px)]:px:' \
        '-targetWatermarkedImageFilename[rename outputs to this base]:name:' \
        '-targetWatermarkedImageFilenameSuffix[suffix type]:type:(3DIGITSCOUNT RAND)' \
        '(- *)-h[print help]' \
        '(- *)-version[print version]'
}

_watermark-to-image "$@"
