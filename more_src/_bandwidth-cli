#compdef bandwidth-cli bandwidth bw-cli
# _bandwidth-cli — Bandwidth bandwidth-cli CLI command-line frontend wrapping the Bandwidth voice messaging emergency 911 calling enterprise telecom REST API managing messages voice calls conferences recordings phone-numbers TN sub-accounts dashboards routes account-level locations Order CSR availability site-services orderType (Bandwidth team, Go); cobra
# upstream: https://www.bandwidth.com/

_bandwidth-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'message:message operations'
        'voice:voice call operations'
        'conference:conference operations'
        'recording:recording operations'
        'number:phone number operations'
        'subaccount:sub-account operations'
        'dashboard:dashboard operations'
        'route:route operations'
        'order:order operations'
        'location:location operations'
        'site:site operations'
        'csr:CSR operations'
        'availability:number availability'
        'application:application operations'
        'webhook:webhook operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--account-id=+[id]:str:' \
        '--api-token=+[token]:str:' \
        '--api-secret=+[secret]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--api-url=+[url]:str:' \
        '--application-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table xml)' \
        '--format=+[format]:f:(json yaml csv table xml)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bandwidth-cli subcommand' sub ;;
        args)
            case $words[1] in
                message|voice|conference|recording|number|subaccount|dashboard|route|order|location|site|csr|availability|application|webhook) _arguments '1:op:(list get create update delete send hangup transfer modify)' '*:id:' ;;
            esac
            ;;
    esac
}

_bandwidth-cli "$@"
