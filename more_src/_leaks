#compdef leaks
# Documentation: man leaks(1) (macOS)
# Source: macOS leaks — search a process's memory for unreferenced malloc buffers.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-list[print as list ("classic") rather than tree]' \
    '-groupByType[group children by type in leak tree]' \
    '-nostacks[do not print backtraces]' \
    '-nosources[do not print sourceFile\:lineNumber in backtraces]' \
    '-quiet[suppress process header and binary image list]' \
    '*-exclude+[exclude leaks whose backtraces contain SYMBOL]:symbol:' \
    '-outputGraph+[write memory graph file]:path:_files' \
    '(-fullContent -readonlyContent -noContent)-fullContent[include full memory content in graph]' \
    '(-fullContent -readonlyContent -noContent)-readonlyContent[only print descriptions from read-only memory]' \
    '(-fullContent -readonlyContent -noContent)-noContent[do not print memory-content descriptions]' \
    '-fullStackHistory[include full alloc history]' \
    '-diffFrom=[diff against another memgraph]:memgraph:_files' \
    '-traceTree+[trace tree from address]:address:' \
    '-referenceTree[print reference tree]' \
    '-autoreleasePools[show autorelease-pool info]' \
    '-debug=[debug mode]:mode:' \
    '-conservative[treat all memory as possibly containing pointers]' \
    '-atExit[run command and check for leaks at exit]' \
    '*:pid / partial-name / memgraph / command (with -atExit):_files' \
    && ret=0

return ret
