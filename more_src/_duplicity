#compdef duplicity
# Documentation: https://manpages.debian.org/duplicity.1
# Source: duplicity-team/duplicity — encrypted rdiff / GPG / multi-backend backups.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'backup:automatic full/incremental backup'
            'bu:backup (alias)'
            'full:force a new full backup chain'
            'fb:full (alias)'
            'incremental:incremental backup'
            'ib:incremental (alias)'
            'verify:check backup integrity against stored signatures'
            'vb:verify (alias)'
            'restore:recover files at a specified time'
            'rb:restore (alias)'
            'collection-status:show backup chain + set info'
            'st:collection-status (alias)'
            'list-current-files:show files in most recent backup'
            'ls:list-current-files (alias)'
            'remove-older-than:delete backups older than a date'
            'ro:remove-older-than (alias)'
            'remove-all-but-n-full:retain only N most recent full backups'
            'ra:remove-all-but-n-full (alias)'
            'cleanup:remove extraneous duplicity files from backend'
            'cl:cleanup (alias)'
            'replicate:replicate backup chain to another backend'
        )
        _describe -t subcmds 'duplicity command' subcmds && ret=0
        ;;
    args)
        _arguments \
            '*--encrypt-key=[GPG public key for encryption]:keyid:' \
            '*--sign-key=[GPG private key for signing]:keyid:' \
            '*--exclude=[exclude path/glob]:pattern:' \
            '*--include=[include path/glob]:pattern:' \
            '*--exclude-filelist=[exclude paths from file]:file:_files' \
            '*--include-filelist=[include paths from file]:file:_files' \
            '*--exclude-globbing-filelist=[exclude globs from file]:file:_files' \
            '--archive-dir=[local cache directory]:dir:_directories' \
            '--volsize=[volume size in MB (default 200)]:mb:' \
            '--full-if-older-than=[force full if last full older than]:time:' \
            '(-t --time)'{-t+,--time=}'[restore / list point-in-time]:time:' \
            '*--verbosity=[log level (0-9 or e/w/n/i/d)]:level:' \
            '--no-encryption[disable GPG encryption]' \
            '--no-compression[disable bzip2 compression]' \
            '--dry-run[preview operations without executing]' \
            '--force[force a destructive operation]' \
            '--progress[show progress on stderr]' \
            '--num-retries=[retry on backend errors]:n:' \
            '--rsync-options=[options forwarded to rsync]:opts:' \
            '*:source / target URL:_files' \
            && ret=0
        ;;
esac

return ret
