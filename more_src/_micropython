#compdef micropython

# Zsh completion for MicroPython

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-i[inspect interactively after running script]' \
  '-c+[program passed in as string]:code' \
  '-m+[run library module as script]:module' \
  '-O[remove assert statements]' \
  '-OO[remove assert statements and docstrings]' \
  '-v[verbose output (trace imports)]' \
  '-X+[set implementation-specific option]:option' \
  '-B[do not write .pyc files]' \
  '--heap-size=[set heap size]:size' \
  '*:script file:_files -g "*.py"' && ret=0

return ret
