#compdef creevey
# ============================================================================
#  _creevey — Creevey: cross-browser screenshot testing tool for Storybook
#             with fancy UI Runner (Yandex / open source)
#
#  Source-direct extraction from
#    https://github.com/creevey/creevey/blob/master/src/creevey.ts
#    https://github.com/cacjs/cac (the cac library by EGOIST)
#
#  Maintained by Yandex contributors and open-source community
#  (creevey/creevey).  428 GH stars.  Creevey is a CROSS-BROWSER
#  SCREENSHOT TESTING tool for Storybook stories — captures
#  screenshots in multiple browsers via Selenium Grid or Playwright,
#  compares them pixel-by-pixel using ODiff or PixelMatch, and
#  surfaces visual regressions in a fancy web-based UI Runner.  Used
#  by frontend teams to catch visual regressions in component
#  libraries.  Sister tools: BackstopJS (Chromatic Screenshot testing,
#  in corpus), Percy (commercial visual regression), Chromatic
#  (commercial Storybook integration), Loki (visual regression),
#  Playwright (in corpus via _playwright), Selenium (in corpus via
#  _selenium-side-runner).
#
#  CLI library taxonomy update: 7th TypeScript-Node CLI library —
#  EGOIST's **cac** (cacjs/cac).  TypeScript-Node ecosystem now has
#  7 documented CLI libraries (R340 oclif + R341 yargs + R343 tj/
#  commander.js + R393 meow + R395 node:util.parseArgs + R396 sade
#  + R400 cac) — TIED for FIRST-MOST-DOCUMENTED CLI language
#  alongside Rust (9) and Go (9), at the TOP TIER of the cross-
#  language CLI library taxonomy.
#
#  cac (cacjs/cac) is EGOIST's "Command And Conquer" — TINY (~7KB)
#  Node.js CLI framework with a focus on speed and simplicity.
#  EGOIST is the prolific creator of Vue CLI, postcss-loader, tsup
#  bundler, VitePress, Vue Press, and many other Vue/Vite-ecosystem
#  tools.  cac is designed as the "tiny commander alternative" for
#  the modern Vite-era JavaScript ecosystem.  Used by Creevey
#  (cross-browser screenshot testing, 428 stars), Koishi chatbot
#  framework (koishijs/koishi 5578 stars), Hydro online-judge
#  platform (hydro-dev/Hydro 6608 stars), Soybean Admin Vue3
#  template (soybeanjs/soybean-admin 14415 stars), moeru-ai/airi
#  (self-hosted AI companion, MASSIVE 40576 stars), Bytedance
#  UI-TARS-desktop, voidzero-dev/vite-plus, linbudu599/TypeScript-
#  Tiny-Book, rotki cryptocurrency portfolio manager, Balancer
#  tokenlists, hyperledger-iroha-javascript, Hocuspocus YJS CRDT
#  backend, and many modern Node.js tools that want a fast,
#  minimal CLI parser in the Vite ecosystem.
#
#  cac API:
#    import { cac } from 'cac';
#
#    const cli = cac('mytool');
#
#    // Define subcommands with options
#    cli
#      .command('build [output]', 'Build the project')
#      .option('-w, --watch', 'Watch for changes')
#      .option('-c, --config <file>', 'Config file path', { default: './config.json' })
#      .option('--mode <mode>', 'Build mode', { default: 'production' })
#      .alias('compile')
#      .example('mytool build dist/')
#      .action((output, options) => {
#        console.log(`Building to ${output}`, options);
#      });
#
#    cli
#      .command('serve <port>', 'Start dev server')
#      .option('-h, --host <host>', 'Hostname', { default: 'localhost' })
#      .action((port, options) => {
#        console.log(`Serving on ${options.host}:${port}`);
#      });
#
#    // Global options
#    cli.option('--debug', 'Enable debug mode');
#
#    cli.help();
#    cli.version('1.0.0');
#    cli.parse();
#
#  cac distinctive features:
#    - TINY ~7KB MINIFIED — zero npm dependencies (vs commander's
#      ~30KB, oclif/yargs much larger; smaller than sade's ~5KB but
#      with more features)
#    - COMMANDER.JS-LIKE API — fluent chained builder pattern with
#      `.command()`/`.option()`/`.action()` chains
#    - `cac('name')` — create CLI instance (multi-command mode)
#    - `.command(PATTERN, DESCRIPTION, CONFIG?)` — define subcommand;
#      PATTERN can include `<required>` and `[optional]` positional
#      args (e.g. `'build [output]'` accepts optional output);
#      CONFIG object can include `{ allowUnknownOptions: true,
#      ignoreOptionDefaultValue: true }`
#    - `.alias(NAME)` — define subcommand alias (single string)
#    - `.example(STR)` — add example to current subcommand
#    - `.option('-s, --long <value>', 'description', CONFIG?)` — define
#      option for current subcommand; CONFIG can include `{ default,
#      type: [Type], coerce: Function }`
#    - `.action(callback)` — define handler for current subcommand;
#      callback receives positional args followed by options object
#      (e.g. for `build [output]`: `(output, options) => { ... }`)
#    - `.usage(STR)` — set usage line (typically `<role>` or similar
#      pattern shown in help)
#    - `.help()` — enable --help/-h auto-injection
#    - `.version(STR)` — set --version output (auto-adds --version/-v)
#    - `.parse(argv?, OPTS?)` — PARSE ENTRY; OPTS can include `{
#      run: false }` to NOT execute action immediately (useful for
#      validation before action; airi uses this pattern)
#    - `cli.runMatchedCommand()` — explicitly execute the matched
#      command's action (when `{ run: false }` was passed to parse)
#    - `cli.matchedCommand` — the matched Command object
#    - `cli.matchedCommandName` — name of matched subcommand (or
#      undefined)
#    - `cli.args` — array of positional args
#    - `cli.options` — parsed options object
#    - `cli.outputHelp()` — print help to stdout
#    - `cli.outputVersion()` — print version to stdout
#    - POSITIONAL ARG PATTERNS — `<required>` for required positionals,
#      `[optional]` for optional, `[...rest]` for rest args (gathered
#      into array)
#    - GLOBAL OPTIONS — `.option(...)` called BEFORE any `.command(...)`
#      becomes global (applies to all subcommands)
#    - AUTO-GENERATED `--help`/`-h` — when `.help()` called
#    - AUTO-GENERATED `--version`/`-v` — when `.version()` called
#    - AUTOMATIC kebab-to-camel — `--my-flag` → `options.myFlag`
#      automatically (camelCase result keys)
#    - TYPE COERCION via option config `{ type: [Boolean] }` /
#      `{ coerce: (val) => Number(val) }`
#    - PROCESS EXIT model — cac calls process.exit on help/version
#      output; caller controls in actions
#    - DEFAULT EXPORT — `import { cac } from 'cac'` (ESM named
#      import); also `const { cac } = require('cac')` (CommonJS)
#    - TYPESCRIPT-FIRST — written in TypeScript with full type
#      definitions
#  Distinct from R340 TypeScript-Node oclif (Salesforce's CLI
#  framework with plugin system + `@Command` class + `flags = {}`
#  static prop — much heavier framework), R341 TypeScript-Node yargs
#  (Node.js fluent builder via `.option('name', {})` / `.command('cmd',
#  desc, builder, handler)` chains — different chaining style and
#  heavier than cac), R343 TypeScript-Node tj/commander.js (Node.js
#  fluent builder by TJ Holowaychuk — CLOSEST concept analog with
#  similar `.command(pattern)` / `.option('-s, --long', 'desc')` /
#  `.action(handler)` API; cac is a TINY commander.js alternative
#  for the Vite era), R393 TypeScript-Node meow (Sindre Sorhus's
#  CLI helper with usage-string-as-help-text + flags schema — much
#  different philosophy), R395 node:util.parseArgs (Node.js stdlib —
#  much lower-level, no subcommands, no fluent API), R396 TypeScript-
#  Node sade (Luke Edwards's TINY commander alternative — also small
#  and fluent but cac has slightly richer subcommand pattern with
#  `<required>`/`[optional]`/`[...rest]` positional args).  cac's
#  approach: TINY (~7KB) zero-dependency Node.js CLI framework +
#  COMMANDER.JS-LIKE fluent builder API + `cac('name')` instance +
#  `.command(pattern, description, config)` + `.alias`/`.example`/
#  `.usage`/`.option`/`.action`/`.help`/`.version` chained builder +
#  POSITIONAL ARG PATTERNS `<required>` / `[optional]` / `[...rest]`
#  + GLOBAL OPTIONS before any .command() + `.parse(argv, { run:
#  false })` deferred-execution mode + `cli.matchedCommand`/`cli.
#  matchedCommandName`/`cli.runMatchedCommand()` post-parse accessors
#  + AUTO-GENERATED `--help`/`--version` + AUTOMATIC kebab-to-camel
#  + TYPESCRIPT-FIRST + ZERO DEPENDENCIES — corpus's **first documented
#  tiny-commander-alternative-with-deferred-execution Node.js CLI
#  library**.  Brings cross-language CLI library taxonomy variant
#  count to 139; TypeScript-Node ecosystem now has 7 documented CLI
#  libraries — TIED for FIRST-MOST-DOCUMENTED CLI LANGUAGE alongside
#  Rust (9) and Go (9) at the TOP TIER.
#
#  Surface (verbatim from `src/creevey.ts` cac chained builder):
#
#  Subcommands:
#
#    worker                         Start worker (cluster mode)
#        --browser BROWSER          Browser to run tests
#        --grid-url URL             Selenium grid URL
#    -d, --debug                    Enable debug mode
#    -c, --config FILE              Path to config file
#    -p, --port PORT                Port for UI server (default 3000)
#        --trace                    Enable trace mode (more verbose
#                                   than debug)
#        --report-dir DIR           Directory for test reports
#        --screen-dir DIR           Directory for reference images
#        --storybook-url URL        Storybook server URL
#        --odiff                    Use ODiff for image comparison
#
#    report [reportDir]             Launch web UI to review and approve
#                                   test results
#    -c, --config FILE              Path to config file
#    -p, --port PORT                Port for UI server (default 3000)
#        --screen-dir DIR           Directory for reference images
#
#    test [options]                 Run tests
#        --ui                       Launch web UI for running tests
#                                   and reviewing test results
#    -s, --storybook-start [cmd]    Start Storybook automatically
#    -c, --config FILE              Path to config file
#    -d, --debug                    Enable debug mode
#    -p, --port PORT                Port for UI server (default 3000)
#        --fail-fast                Stop tests after first failure
#        --report-dir DIR           Directory for test reports
#        --screen-dir DIR           Directory for reference images
#        --storybook-url URL        Storybook server URL
#        --storybook-port PORT      Storybook server port
#        --reporter REPORTER        [DEPRECATED] Use config file instead
#        --odiff                    Use ODiff for image comparison
#        --trace                    Enable trace mode
#        --no-docker                Disable Docker usage
#
#  Auto-injected by cac:
#    -h, --help                     Show help
#    -v, --version                  Show version
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also cac users):
#    - koishi (koishijs/koishi 5578 stars — Cross-platform chatbot
#      framework; uses cac for CLI; FUTURE candidate)
#    - hydrooj (hydro-dev/Hydro 6608 stars — Next-gen online-judge
#      platform; uses cac heavily for addon command)
#    - soybean (soybeanjs/soybean-admin 14415 stars — Vue3+Vite
#      admin template; uses cac in build scripts)
#    - airi (moeru-ai/airi 40576 stars — MASSIVE self-hosted AI
#      companion; uses cac for server CLI but minimal surface)
#    - vite-plus (voidzero-dev/vite-plus — uses cac for CLI pack-bin
#      tool)
#    - bytedance UI-TARS-desktop (uses cac via infra/pdk)
#    - rotki (rotki/rotki — cryptocurrency portfolio manager, uses
#      cac in build scripts)
#    - hyperledger-iroha-javascript (Hyperledger Iroha SDK, uses cac
#      for codegen tasks)
#    - balancer/tokenlists (Balancer token allowlists, uses cac in
#      scripts)
# ============================================================================

_creevey() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs=(
        'worker:start worker (cluster mode)'
        'report:launch web UI to review test results'
        'test:run tests'
      )
      _describe -t commands 'creevey subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        worker)
          _arguments -s -S \
            '--browser=[browser to run tests]:browser:(chrome firefox safari edge)' \
            '--grid-url=[Selenium grid URL]:url' \
            '(-d --debug)'{-d,--debug}'[enable debug mode]' \
            '(-c --config)'{-c,--config}'=[config file path]:file:_files' \
            '(-p --port)'{-p,--port}'=[UI server port (default 3000)]:port' \
            '--trace[enable trace mode (more verbose than debug)]' \
            '--report-dir=[directory for test reports]:dir:_directories' \
            '--screen-dir=[directory for reference images]:dir:_directories' \
            '--storybook-url=[Storybook server URL]:url' \
            '--odiff[use ODiff for image comparison]' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        report)
          _arguments -s -S \
            '(-c --config)'{-c,--config}'=[config file path]:file:_files' \
            '(-p --port)'{-p,--port}'=[UI server port (default 3000)]:port' \
            '--screen-dir=[directory for reference images]:dir:_directories' \
            '(-h --help)'{-h,--help}'[show help]' \
            '1:report directory:_directories'
          ;;
        test)
          _arguments -s -S \
            '--ui[launch web UI for running tests and reviewing results]' \
            '(-s --storybook-start)'{-s,--storybook-start}'=-[start Storybook automatically]::cmd' \
            '(-c --config)'{-c,--config}'=[config file path]:file:_files' \
            '(-d --debug)'{-d,--debug}'[enable debug mode]' \
            '(-p --port)'{-p,--port}'=[UI server port (default 3000)]:port' \
            '--fail-fast[stop tests after first failure]' \
            '--report-dir=[directory for test reports]:dir:_directories' \
            '--screen-dir=[directory for reference images]:dir:_directories' \
            '--storybook-url=[Storybook server URL]:url' \
            '--storybook-port=[Storybook server port]:port' \
            '--reporter=[DEPRECATED reporter (use config file)]:reporter' \
            '--odiff[use ODiff for image comparison]' \
            '--trace[enable trace mode]' \
            '--no-docker[disable Docker usage]' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_creevey "$@"
