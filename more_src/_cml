#compdef cml

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'comment:create or update a PR/MR comment'
      'check:create a check run'
      'pr:create a pull/merge request'
      'runner:launch a CML runner'
      'tensorboard-dev:publish TensorBoard experiment'
      'asset:manage CML assets'
      'publish:publish a file as an asset'
      'send-comment:send a comment (alias for comment)'
      'send-github-check:create a check (alias for check)'
      'ci:CI-related utilities'
      'repo:repository operations'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (comment|send-comment)
        _arguments \
          '--commit-sha=[commit SHA]:sha:' \
          '--head-sha=[head SHA]:sha:' \
          '--pr[comment on associated PR]' \
          '--update[update existing comment]' \
          '--rm-watermark[remove CML watermark]' \
          '--watermark-title=[custom watermark title]:title:' \
          '--native[use native markdown rendering]' \
          '--target=[target]:target:(pr commit)' \
          '--token=[repo token]:token:' \
          '--repo=[repository]:repo:' \
          '--driver=[CI driver]:driver:(github gitlab bitbucket)' \
          '1:markdown file:_files -g "*.md"' && ret=0
        ;;
      (runner)
        _arguments \
          '--labels=[runner labels]:labels:' \
          '--idle-timeout=[idle timeout in seconds]:seconds:' \
          '--name=[runner name]:name:' \
          '--no-retry[do not retry on failure]' \
          '--single[run a single job then exit]' \
          '--reuse[reuse existing runner]' \
          '--driver=[CI driver]:driver:(github gitlab bitbucket)' \
          '--repo=[repository]:repo:' \
          '--token=[repo token]:token:' \
          '--cloud=[cloud provider]:cloud:(aws azure gcp kubernetes)' \
          '--cloud-region=[cloud region]:region:' \
          '--cloud-type=[instance type]:type:' \
          '--cloud-gpu=[GPU type]:gpu:' \
          '--cloud-hdd-size=[disk size in GB]:size:' \
          '--cloud-spot[use spot/preemptible instances]' \
          '--cloud-startup-script=[startup script]:file:_files' && ret=0
        ;;
      (pr)
        _arguments \
          '--md=[markdown file for PR body]:file:_files -g "*.md"' \
          '--title=[PR title]:title:' \
          '--body=[PR body]:body:' \
          '--merge[merge PR after creation]' \
          '--squash[squash merge]' \
          '--rebase[rebase merge]' \
          '--no-close[do not close source branch]' \
          '--branch=[target branch]:branch:' \
          '--token=[repo token]:token:' \
          '--repo=[repository]:repo:' \
          '--driver=[CI driver]:driver:(github gitlab bitbucket)' && ret=0
        ;;
      (publish)
        _arguments \
          '--md[output as markdown image]' \
          '--title=[asset title]:title:' \
          '--native[use native storage]' \
          '--mime-type=[MIME type]:type:' \
          '--token=[repo token]:token:' \
          '--repo=[repository]:repo:' \
          '--driver=[CI driver]:driver:(github gitlab bitbucket)' \
          '1:file:_files' && ret=0
        ;;
      (check|send-github-check)
        _arguments \
          '--commit-sha=[commit SHA]:sha:' \
          '--head-sha=[head SHA]:sha:' \
          '--title=[check title]:title:' \
          '--conclusion=[check conclusion]:conclusion:(success failure neutral cancelled skipped timed_out action_required)' \
          '--token=[repo token]:token:' \
          '--repo=[repository]:repo:' \
          '1:report file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
