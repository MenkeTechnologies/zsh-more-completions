#compdef polyml-cli poly
# _polyml-cli — David Matthews Cambridge Poly/ML polyml-cli CLI command-line frontend wrapping the Poly/ML Standard ML implementation that compiles to native code open-source written in Standard ML and C originally David Matthews at Cambridge Computer Laboratory now Poly/ML team full implementation of Standard ML SML97 used as Isabelle proof assistant runtime native compilation incremental compilation persistent state memory-mapped database large heap support multi-threading processes parent child --use --eval --error-exit --with-markup --raise --gc --gcpercent --reportstats --reportexec --maxheap --minheap --immediate --debug --suffixes --dlopen --hashcode --noprint --printexceptions --no-fpe (David Matthews Cambridge Poly/ML team, Standard ML/C); custom argparse
# upstream: https://www.polyml.org/

_polyml-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--use=+[file]:file:_files -g "*.sml *.ML"' \
        '*--use=+[file]:file:_files -g "*.sml *.ML"' \
        '--eval=+[expression]:str:' \
        '*--eval=+[expression]:str:' \
        '--error-exit[error exit]' \
        '--with-markup[markup output]' \
        '--raise[raise exceptions]' \
        '--gc[verbose GC]' \
        '--gcpercent=+[N]:n:' \
        '--reportstats[report stats]' \
        '--reportexec[report exec]' \
        '--maxheap=+[N]:n:' \
        '--minheap=+[N]:n:' \
        '--immediate[immediate mode]' \
        '--debug[debug]' \
        '--suffixes=+[list]:str:' \
        '--dlopen=+[lib]:str:' \
        '*--dlopen=+[lib]:str:' \
        '--hashcode[hashcode]' \
        '--noprint[no print]' \
        '--printexceptions[print exceptions]' \
        '--no-fpe[no FPE]' \
        '--stacksize=+[N]:n:' \
        '--stackmax=+[N]:n:' \
        '--gcthreads=+[N]:n:' \
        '--codeseg=+[N]:n:' \
        '--ml-mem-size=+[N]:n:' \
        '--load=+[file]:file:_files -g "*.poly"' \
        '--PolyControl=+[k=v]:str:' \
        '*--PolyControl=+[k=v]:str:' \
        '*:sml file:_files -g "*.sml *.ML *.fun *.sig *.poly"'
}

_polyml-cli "$@"
