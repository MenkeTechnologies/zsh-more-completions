#compdef howdy
# Documentation: https://github.com/boltgolt/howdy (howdy/src/cli.py argparse)
# Reference accessed: 2026-05-29
# Howdy — Windows-Hello-style facial recognition login for Linux.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'add:register a new face profile for authentication'
  'clear:clear all existing face data'
  'config:edit configuration settings'
  'disable:disable face authentication'
  'list:display registered face profiles'
  'remove:remove a specific face profile'
  'set:configure or modify settings'
  'snapshot:capture a face image (without registering)'
  'test:test the face authentication system'
  'version:show Howdy version'
  'help:show help for a subcommand'
)

local -a _global
_global=(
  '(-U --user)'{-U,--user=}'[user account to use (default detected non-root user)]:user:_users'
  '-y[skip all questions (yes to all)]'
  '--plain[print machine-friendly output]'
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -C \
  $_global \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'howdy subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments \
          $_global \
          ':optional label for the new face profile:' && ret=0
        ;;
      disable)
        _arguments \
          $_global \
          ':state:(0 1 true false)' && ret=0
        ;;
      remove)
        _arguments \
          $_global \
          ':profile id (use `howdy list`):' && ret=0
        ;;
      set)
        _arguments \
          $_global \
          ':setting key:' \
          ':value:' && ret=0
        ;;
    esac
    ;;
esac

return ret
