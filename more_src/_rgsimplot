#compdef rgsimplot
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/rgsimplot/node4.html
# XMM-Newton SAS: display RGS spectroscopy diagnostic plots

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--withspatialset=[provide a spatial-dispersion imageset]:flag:(yes no)' \
  '--spatialset=[input spatial dispersion image file]:file:_files' \
  '--withendispset=[provide an energy-dispersion imageset]:flag:(yes no)' \
  '--endispset=[input energy-dispersion image file]:file:_files' \
  '--srclistset=[input sourcelist with extraction regions]:file:_files' \
  '--orderlist=[orders to display]:orders:' \
  '--withspatialregionsets=[overlay spatial extraction regions]:flag:(yes no)' \
  '--withendispregionsets=[overlay order extraction regions]:flag:(yes no)' \
  '--srcidlist=[source IDs for extraction regions]:ids:' \
  '--plotfile=[output filename for hard copy plots]:file:_files' \
  '--device=[PGPLOT graphics device for output]:device:' \
  '--invert=[toggle color table inversion]:flag:(yes no)' \
  '--colourmap=[color mapping type]:map:(LIN SQRT LOG)' \
  '--colour=[palette type]:palette:' \
  '--paperxmin=[horizontal position of bottom left corner]:x:' \
  '--paperymin=[vertical position of top left corner]:y:' \
  '--paperxmax=[horizontal position of bottom right corner]:x:' \
  '--paperymax=[vertical position of top right corner]:y:' \
  '*:file:_files' && ret=0

return ret
