#compdef osdctl
# Documentation: https://github.com/openshift/osdctl
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org search URL.

# osdctl: OpenShift Dedicated utilities CLI
local curcontext="$curcontext" state line ret=1
local -a commands=(
  'account:manage AWS Account CRs'
  'cluster:cluster operations (break-glass, etcd, snapshots)'
  'cloudtrail:surface AWS API errors from CloudTrail logs'
  'env:manage cluster environments and login configs'
  'evidence:collect evidence during feature testing'
  'federatedrole:apply federated role configurations'
  'get:retrieve AWS account information'
  'hive:work with Hive ClusterDeployment and ClusterSync'
  'metrics:display AWS Account Operator metrics'
  'network:run network verification utilities'
  'org:organization queries and management'
  'servicelog:list and post service logs to clusters'
  'setup:configure the osdctl configuration file'
  'sts:cluster policy and policy comparisons'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'osdctl command' commands && ret=0 ;;
esac

return ret
