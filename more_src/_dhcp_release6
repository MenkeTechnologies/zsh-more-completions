#compdef dhcp_release6

# dhcp_release6: send a RELEASE/DECLINE to free a v6 lease
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--iface=[interface]:iface:' \
  '--server-id=[server DUID]:duid:' \
  '--client-id=[client DUID]:duid:' \
  '--iaid=[IAID hex]:hex:' \
  '--ip=[IPv6 address]:ip:' \
  '--dry-run[dry run]' \
  '*::dhcp_release6 args:_files' && ret=0
return ret
