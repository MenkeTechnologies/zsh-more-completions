#compdef makempx

# makempx: build MetaPost MPX file from .mp source
local curcontext="$curcontext" ret=1
_arguments -C \
  '-troff[use troff input syntax]' \
  '-tex[use TeX input syntax (default)]' \
  '-help[show help]' \
  '-version[show version]' \
  '*:MP source file:_files -g "*.(mp|MPX)"' && ret=0
return ret
