#compdef hf
# Documentation: source-direct extraction from upstream
# huggingface/huggingface_hub —
#   src/huggingface_hub/cli/hf.py lines 50-105 (Typer app +
#     app.add_typer() registrations for 16 command groups +
#     app.command() for 9 top-level commands)
#   src/huggingface_hub/cli/auth.py lines 52-163 (auth
#     subcommand decorators: login/logout/switch/list|ls/
#     token/whoami)
#   src/huggingface_hub/cli/models.py lines 69-192 (3 model
#     subcommands: list|ls/info/card)
#   src/huggingface_hub/cli/datasets.py lines 70-259 (6 dataset
#     subcommands: list|ls/leaderboard/info/parquet/sql/card)
#   src/huggingface_hub/cli/repos.py lines 132-576 (repos +
#     branch + tag nested command tree)
#   src/huggingface_hub/cli/cache.py + spaces.py (cache: 4
#     verbs; spaces: 12 verbs)
# Reference accessed: 2026-05-30 via gh api.
#
# hf is the **new Hugging Face Hub CLI** introduced in
# huggingface_hub v0.34.0 (Sept 2024), replacing the legacy
# `huggingface-cli` (still in the corpus as the deprecated
# binary).  Provides upload/download/auth/cache management +
# Models/Datasets/Spaces/Endpoints/Webhooks/Collections/Papers/
# Discussions/Jobs/Skills/Buckets/Repos REST API access.
# Used by ML researchers + production teams managing
# Hugging Face Hub content.
#
# Critical extraction note: hf uses **Typer** (FastAPI's
# author's CLI library built on Click) — the FIRST round in
# the corpus to document Typer-based CLIs.  Differences from
# argparse/click/clap-derive that affect completion:
#   1. Typer's `app.add_typer(name="repos | repo")` registers
#      a single sub-app under TWO names (repos AND repo are
#      both valid aliases).  Similarly `extensions | ext`.
#      Completion lists both.
#   2. Typer's `app.command("list | ls")` does the same for
#      single subcommands: both `list` and `ls` work.  Used
#      heavily in hf for auth, models, datasets, repos, cache,
#      spaces, repos-branch, repos-tag.
#   3. Typer's `hidden=True` flag marks commands as
#      undocumented in --help.  hf hides `repo-files` group
#      and `lfs-enable-largefiles` + `lfs-multipart-upload`
#      top-level commands.  Completion still lists them for
#      forward compatibility.
#   4. Typer's `examples=[...]` decorator argument is purely
#      cosmetic for --help; doesn't affect completion.
#
# Critical extraction note: hf has a **fallback dispatch for
# unknown top-level commands** at hf.py:54-57 — when the user
# types `hf <unknown>`, the `fallback_typer_group_factory`
# routes it to `dispatch_unknown_top_level_extension()` which
# tries to find an INSTALLED EXTENSION matching the name.
# This makes hf plugin-extensible — third parties can ship
# `hf-foo` packages that register top-level commands.
# Documented in the comment block; the completion does NOT
# enumerate installed extensions since they're install-
# dependent.

local curcontext="$curcontext" state line ret=1

# Top-level single commands + command groups decoded source-
# direct from hf.py:77-105.  Each entry uses the canonical
# name; aliases are documented in the description.
local -a top_subcommands=(
  'sync:sync buckets (Hugging Face Buckets workflow)'
  'download:download files from the Hub (`hf download REPO FILE...`)'
  'upload:upload files to the Hub (`hf upload REPO LOCAL_PATH...`)'
  'upload-large-folder:upload a large folder with chunked multi-part transfer'
  'env:print environment info for bug reports'
  'update:update the huggingface_hub package'
  'version:print huggingface_hub version'
  'auth:authentication (login/logout/switch/list|ls/token/whoami)'
  'buckets:Hugging Face Buckets management'
  'cache:manage local download cache (list|ls/scan/delete/prune)'
  'collections:Hugging Face Collections management'
  'datasets:datasets (list|ls/leaderboard/info/parquet/sql/card)'
  'discussions:repo discussions + PRs management'
  'jobs:Hugging Face Jobs (compute) management'
  'models:models (list|ls/info/card)'
  'papers:papers index management'
  'repos:repository management (alias: `repo`; sub: create/duplicate/delete/move/settings/delete-files/branch/tag)'
  'repo:alias for repos'
  'repo-files:(HIDDEN) per-file repo operations'
  'skills:HF skills'
  'spaces:Spaces (list|ls/info/card/search/dev-mode/ssh/pause/restart/hardware/settings/logs/hot-reload)'
  'webhooks:webhooks management'
  'endpoints:Inference Endpoints management'
  'extensions:installed extensions (alias: `ext`)'
  'ext:alias for extensions'
  'lfs-enable-largefiles:(HIDDEN) enable Git LFS for large files'
  'lfs-multipart-upload:(HIDDEN) helper for multi-part LFS upload'
)

local -a auth_subcommands=(
  'login:login using a token (--token --add-to-git-credential --force)'
  'logout:logout from a token (--token-name)'
  'switch:switch active token (interactive)'
  'list:list stored tokens (alias: ls)'
  'ls:alias for list'
  'token:print the active token'
  'whoami:print user info for the active token (--format json)'
)

local -a models_subcommands=(
  'list:list models (alias: ls)'
  'ls:alias for list'
  'info:show model info'
  'card:print or edit model card'
)

local -a datasets_subcommands=(
  'list:list datasets (alias: ls)'
  'ls:alias for list'
  'leaderboard:dataset leaderboard view'
  'info:show dataset info'
  'parquet:list parquet shards of a dataset'
  'sql:run SQL query against a dataset'
  'card:print or edit dataset card'
)

local -a repos_subcommands=(
  'list:list repos (alias: ls)'
  'ls:alias for list'
  'create:create a new repo'
  'duplicate:duplicate an existing repo'
  'delete:delete a repo'
  'move:rename/move a repo (old-ns/name -> new-ns/name)'
  'settings:update repo settings'
  'delete-files:delete files within a repo'
  'branch:branch sub-group (create/delete)'
  'tag:tag sub-group (create/list|ls/delete)'
)

local -a cache_subcommands=(
  'list:list cached repos+revisions (alias: ls)'
  'ls:alias for list'
  'scan:scan local cache for size/age/refs'
  'delete:delete cached items by target spec'
  'prune:remove unreferenced revisions (--dry-run)'
)

local -a spaces_subcommands=(
  'list:list spaces (alias: ls)'
  'ls:alias for list'
  'info:space info'
  'card:print or edit space card'
  'search:full-text search'
  'dev-mode:start dev mode'
  'ssh:open SSH session'
  'pause:pause a space'
  'restart:restart a space'
  'hardware:get/set hardware'
  'settings:update space settings'
  'logs:tail logs'
  'hot-reload:hot-reload sub-group'
)

_arguments -C \
  '(-v --version)'{-v,--version}'[show huggingface_hub version and exit (HIDDEN; eager callback)]' \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--install-completion[install shell completion (typer auto-injected)]' \
  '--show-completion[show shell completion script (typer auto-injected)]' \
  '1:command:->topcmd' \
  '*::args:->args' && ret=0

case $state in
  topcmd)
    _describe -t top-subcommands 'hf command' top_subcommands && ret=0
    _message 'OR an installed extension name (e.g. `hf <ext-name>`; dispatched by fallback_typer_group_factory)'
    ret=0
    ;;
  args)
    case $words[1] in
      auth)
        if (( CURRENT == 2 )); then
          _describe -t auth-subs 'auth verb' auth_subcommands && ret=0
        else
          case $words[2] in
            login)
              _arguments \
                '--token=[HF token (default: prompts interactively)]:token:' \
                '--add-to-git-credential[save to git credential helper]' \
                '--force[force re-login even if already logged in]' && ret=0 ;;
            logout)
              _arguments \
                '--token-name=[specific token name to logout]:name:' && ret=0 ;;
            whoami)
              _arguments \
                '--format=[output format]:format:(text json)' && ret=0 ;;
          esac
        fi
        ;;
      models)
        if (( CURRENT == 2 )); then
          _describe -t models-subs 'models verb' models_subcommands && ret=0
        else
          _arguments '1:REPO id (e.g. meta-llama/Llama-3-8B):' && ret=0
        fi
        ;;
      datasets)
        if (( CURRENT == 2 )); then
          _describe -t datasets-subs 'datasets verb' datasets_subcommands && ret=0
        else
          _arguments '1:dataset REPO id:' && ret=0
        fi
        ;;
      repos|repo)
        if (( CURRENT == 2 )); then
          _describe -t repos-subs 'repos verb' repos_subcommands && ret=0
        else
          case $words[2] in
            branch)
              _arguments '1:branch verb:(create delete)' && ret=0 ;;
            tag)
              _arguments '1:tag verb:(create list ls delete)' && ret=0 ;;
            *)
              _arguments '1:REPO id (NAMESPACE/NAME):' && ret=0 ;;
          esac
        fi
        ;;
      cache)
        if (( CURRENT == 2 )); then
          _describe -t cache-subs 'cache verb' cache_subcommands && ret=0
        else
          case $words[2] in
            prune)
              _arguments \
                '--dry-run[show what would be pruned without doing it]' && ret=0 ;;
          esac
        fi
        ;;
      spaces)
        if (( CURRENT == 2 )); then
          _describe -t spaces-subs 'spaces verb' spaces_subcommands && ret=0
        else
          _arguments '1:space REPO id:' && ret=0
        fi
        ;;
      download)
        _arguments \
          '--repo-type=[repo type]:type:(model dataset space)' \
          '--revision=[branch / tag / commit]:rev:' \
          '--cache-dir=[override cache dir]:dir:_files -/' \
          '--local-dir=[local destination dir]:dir:_files -/' \
          '--token=[HF token]:token:' \
          '--quiet[suppress progress]' \
          '--dry-run[show what would be downloaded]' \
          '1:repo id (NAMESPACE/NAME):' \
          '*:files (relative paths within the repo):' && ret=0
        ;;
      upload|upload-large-folder)
        _arguments \
          '--repo-type=[repo type]:type:(model dataset space)' \
          '--revision=[branch / tag / commit]:rev:' \
          '--commit-message=[commit message]:msg:' \
          '--token=[HF token]:token:' \
          '--every=[periodically push every N seconds (upload-large-folder)]:seconds:' \
          '--num-workers=[parallel upload workers (upload-large-folder)]:n:' \
          '1:repo id (NAMESPACE/NAME):' \
          '2:local path (file or dir):_files' \
          '3:path in repo (optional; default = filename):' && ret=0
        ;;
    esac
    ;;
esac

return ret
