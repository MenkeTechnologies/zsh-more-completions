#compdef dupl
# Documentation: https://man.archlinux.org/search?q=dupl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-version[show version]' \
  '-files[list files instead of dirs]' \
  '-html[output HTML]' \
  '-plumbing[machine output]' \
  '-t+[threshold tokens]:n:' \
  '-threshold+[threshold tokens]:n:' \
  '-vendor[include vendor dir]' \
  '*: :_files' && ret=0

return ret
