#compdef gmx-bar
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-bar.html
# gmx bar: calculate free energy difference estimates through Bennett's acceptance ratio

local ret=1

_arguments -s \
  '*-f[dhdl xvgr/xmgr file]:file:_files' \
  '*-g[energy file]:file:_files' \
  '-o[xvgr/xmgr output file]:file:_files' \
  '-oi[BAR integrand xvgr/xmgr output]:file:_files' \
  '-oh[histogram xvgr/xmgr output]:file:_files' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-b[begin time for BAR analysis]:real:' \
  '-e[end time for BAR analysis]:real:' \
  '-temp[temperature in Kelvin]:real:' \
  '-prec[number of decimal digits in output]:int:' \
  '-nbmin[minimum block count for error estimation]:int:' \
  '-nbmax[maximum block count for error estimation]:int:' \
  '-nbin[bin count for histogram generation]:int:' \
  '-extp[linearly extrapolate dH/dl values as energies]' && ret=0

return ret
