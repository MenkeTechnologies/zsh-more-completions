#compdef maskfeat
# Documentation: https://man.archlinux.org/search?q=maskfeat
# Reference accessed: 2026-05-16

# EMBOSS maskfeat: write sequence with selected features masked to N/X
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s) with features]:sequence USA:_files' \
  '-type=[feature type(s) to mask (comma-list)]:types:' \
  '-tolower[mask by lowercasing instead of replacement]' \
  '-maskchar=[character to use for hard masking]:char:' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output format]:format:(fasta embl genbank gff swiss gcg pir nbrf raw msf ace text)' \
  '*:sequence USA:_files' && ret=0
return ret
