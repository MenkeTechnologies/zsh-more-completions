#compdef termirs
# =============================================================================
# termirs — caelansar/termirs's "termirs" — a
#   MODERN ASYNC SSH + SFTP TERMINAL CLIENT
#   written in Rust.  Provides a ratatui-
#   powered full-screen TUI with multi-session
#   tabs, a connection-list pane on the left
#   and a live terminal-emulator pane on the
#   right.  Each session runs a real ssh
#   client connection to the remote host
#   (using `russh` for the protocol, `wezterm-
#   term` for VT100 emulation, `ssh2-config`
#   for ~/.ssh/config parsing).  Built-in
#   integrated SFTP browser pane lets you
#   upload/download/rename/delete files
#   without leaving the TUI.  Built on direct
#   `russh 0.57.0` — the canonical pure-Rust
#   SSH protocol library by Pierre-Étienne
#   Meunier (Pijul author).  Rust=107 leader
#   bump opening Axis 52.
#
# AXIS 52 — SSH CLIENT / SERVER LIBRARY — OPENS @ R797
# =====================================================
# Establishes the 52nd three-language axis in
# the corpus.  This axis covers CLI tools
# written in language X that ship a DIRECT
# library binding to a full SSH-protocol
# implementation (client + server transport,
# channel multiplexing, key exchange, ciphers,
# auth).  Canonical implementations per
# language:
#   * Rust       : russh (this entry)
#                  — Eugeny/russh (formerly
#                    pijul-org/thrussh).  ~1.7k
#                    stars.  Pure-Rust SSH-2
#                    client+server library
#                    with async I/O on tokio,
#                    ed25519/ECDSA/RSA host
#                    keys, ChaCha20-Poly1305
#                    + AES-GCM ciphers,
#                    multi-channel session
#                    multiplexing, SOCKS-style
#                    direct-tcpip forwarding.
#                    Forked from Pijul's
#                    `thrussh` (Pierre-Étienne
#                    Meunier) and maintained
#                    by Eugene Pankov (Warp
#                    Tech) since 2021
#                  — version 0.57.0 used here
#                  — direct dep at
#                    `caelansar/termirs`
#                    Cargo.toml line:
#                    `russh = "0.57.0"`
#   * Go         : golang.org/x/crypto/ssh —
#                  the canonical Go SSH
#                  client+server, part of the
#                  Go extended crypto module.
#                  R798 will close the Go side
#   * TS-Node    : ssh2 (npm `ssh2`) —
#                  Mathieu Caputo / Brian
#                  Whites's pure-JS SSH-2
#                  client+server.  R799 will
#                  close the TS-Node side
#
# Distinguishing russh from other Rust SSH
# libs:
#   - thrussh (pre-rename / Pijul-org):
#     same codebase; "russh" is the
#     post-2021 community fork.  All new
#     work happens at Eugeny/russh
#   - ssh2-rs (alexcrichton): a libssh2
#     C bindings wrapper.  Heavier system
#     dep, faster cold start
#   - libssh-rs (eclipse-iceoryx): a
#     libssh C bindings wrapper.  Also
#     heavier system dep
#   - russh is the PURE-RUST entry — no
#     libssh / libssh2 / openssh-portable
#     C dep.  Builds cleanly on
#     embedded / no-std-adjacent targets,
#     supports both client AND server
#     roles
#
# Distinguishing termirs from other corpus
# SSH tooling:
#   - OPENSSH `ssh` (`_ssh`): classic C
#     reference implementation.  Single-
#     session, no TUI, no built-in SFTP
#     pane
#   - MOSH (`_mosh`): SSH-derived but uses
#     a different wire protocol designed
#     for high-latency / mobile links.
#     No TUI session manager
#   - WEZTERM (`_wezterm`): general-purpose
#     terminal emulator that can also do
#     SSH connections.  Much heavier;
#     graphical (uses wgpu / OpenGL)
#   - DISTANT (`_distant`): chipsenkbeil's
#     remote-file-system tool.  Different
#     niche — provides remote file
#     operations with a custom protocol
#   - WARPGATE (`_warpgate`): Eugeny's
#     SSH/HTTPS/MySQL/Postgres bastion
#     server.  Different niche — sits IN
#     FRONT of multiple targets as a
#     PAM/audit layer
#   - SSHORE (aitechnerd, no completion
#     yet): SSH connection manager +
#     SFTP client + tunnel manager
#   - OXIDETERM (no completion yet):
#     Local-first SSH workspace
#   - TERMIRS is the focused FULL-SCREEN
#     RATATUI TUI for daily-driver SSH +
#     SFTP usage with a connection-list
#     sidebar
#
# KEY TERMIRS FEATURES:
#   - ASYNC SSH STACK — tokio + russh +
#     wezterm-term VT100 emulation.  No
#     blocking I/O on the terminal-render
#     path
#   - MULTI-SESSION TABS — operate
#     several remote hosts simultaneously
#     in the same TUI; each tab is a
#     fully independent russh channel
#   - INTEGRATED SFTP BROWSER — dedicated
#     pane shows the remote filesystem
#     tree via `russh-sftp` (fork by the
#     maintainer); supports upload,
#     download, rename, delete, mkdir,
#     edit-in-place file operations
#   - FILE EDIT INTEGRATION — `file_edit.
#     rs` opens a remote file in the
#     user's `$EDITOR` (vim, nano, etc.)
#     via tempfile download → edit →
#     upload-on-save flow
#   - SEARCH — `grep-searcher`-powered
#     content search inside the remote
#     filesystem from the SFTP pane
#   - CLIPBOARD INTEGRATION — `arboard`
#     for system-clipboard copy/paste
#     across the SSH boundary
#   - SSH-CONFIG-AWARE — `ssh2-config`
#     parses `~/.ssh/config` so
#     `Host`-aliased entries Just Work.
#     `User`, `IdentityFile`, `Port`,
#     `ProxyJump` (limited), `Hostname`
#     overrides all honoured
#   - TOML SESSION CONFIG — sessions are
#     persisted as TOML in the
#     `~/.config/termirs/` directory
#     (XDG-aware via `dirs` crate).  Each
#     session records host, port, user,
#     identity-file path, last-used
#     timestamp
#   - TUI-TEXTAREA INPUT — `tui-textarea`
#     for multi-line input editing
#     (password prompts, search queries)
#   - RING CRYPTO BACKEND — `ring 0.17`
#     for KDF / HMAC / hash operations
#     (russh uses ring under the hood
#     too)
#   - LOG-TO-FILE OPTION — `--log` flag
#     enables structured tracing output
#     to `termirs.log` in the current
#     working directory.  Useful for
#     debugging connection failures
#     without polluting the TUI
#   - PANIC HOOK — `init_panic_hook`
#     restores the terminal state on
#     unexpected panics so the user
#     isn't left with a corrupted
#     terminal
#
# CONFIG FILE LOCATION:
# ~/.config/termirs/ (Linux, XDG-aware via
# the `dirs` crate)
# ~/Library/Application Support/termirs/ (macOS)
# %APPDATA%\termirs\ (Windows)
#
# Sessions stored as individual TOML files;
# the global UI state + last-used session
# index is in `state.toml`
#
# CLI ARGUMENT SURFACE:
# termirs has a deliberately MINIMAL CLI —
# all session management is done from inside
# the TUI.  The two flags below only control
# startup-time logging.  Once running, the
# TUI handles host selection + connection +
# SFTP browsing entirely via keyboard
# shortcuts (Vim-style by default; check the
# in-app help with `?`).
#
# CRITICAL DIRECT DEPENDENCIES (from
# Cargo.toml):
#   - russh 0.57.0             — SSH client
#                                library
#                                [AXIS 52 LIBRARY]
#   - russh-sftp (git fork)    — SFTP client
#                                (maintainer's
#                                fork of
#                                AspectUnk/
#                                russh-sftp)
#   - ssh2-config (git fork)   — ~/.ssh/config
#                                parser
#                                (maintainer's
#                                fork of
#                                veeso/ssh2-
#                                config)
#   - ratatui 0.29 (no_std-    — TUI
#     crossterm features)        framework
#   - crossterm 0.28 (event-   — terminal
#     stream)                    control
#   - tokio 1.x (rt-multi-     — async runtime
#     thread + macros + sync +
#     time + net + fs)
#   - tokio-util 0.7           — sync helpers
#   - clap 4.5 (derive)        — CLI parser
#   - ring 0.17                — crypto
#                                primitives
#   - tui-textarea 0.7         — multi-line
#                                text widget
#   - ratatui-async-explorer 0.3
#                              — async tree
#                                view widget
#   - arboard 3                — system
#                                clipboard
#   - grep-searcher 0.1        — content
#                                search
#                                inside
#                                remote
#                                files
#   - tracing 0.1 + tracing-   — structured
#     subscriber 0.3 + tracing- logging
#     appender 0.2
#   - serde 1.0 (derive) +     — TOML
#     toml 0.8                   config
#                                parsing
#   - uuid 1.0 (v4 + serde)    — session id
#   - chrono 0.4 (serde)       — timestamps
#   - dirs 6.0                 — XDG /
#                                Known Folders
#   - bytes 1.10               — buffer pool
#   - thiserror 1.0            — error types
#   - futures 0.3              — async helpers
#   - base64 0.22              — auth
#                                encoding
#
# Rust 2024 edition.  Builds with stable
# Rust 1.85+.
#
# UPSTREAM:
#   * Source             : https://github.com/caelansar/termirs
#   * russh              : https://github.com/Eugeny/russh
#   * License            : MIT
#   * Maintainer         : Caelansar
#
# INSTALL:
#   # From crates.io
#   cargo install termirs
#
#   # From source
#   git clone https://github.com/caelansar/termirs
#   cd termirs
#   cargo install --path .
#
# USAGE EXAMPLES:
#
#   # Launch the TUI (uses ~/.config/termirs
#   # for session persistence)
#   termirs
#
#   # Launch with logging enabled (writes to
#   # ./termirs.log in CWD)
#   termirs --log
#   termirs -l
#
#   # Verbose debug logging
#   termirs --log --log-level debug
#
#   # Trace-level logging (very verbose;
#   # includes russh packet-level events)
#   termirs --log --log-level trace
#
#   # Error-only logging (less noise but
#   # still captures failures)
#   termirs --log --log-level error
#
#   # Disable logging entirely (--log not
#   # given; default behaviour)
#   termirs
#
#   # Help (clap default)
#   termirs --help
#   termirs -h
#
#   # Version
#   termirs --version
#   termirs -V
#
# TUI USAGE (inside the running app):
#   - `n`              new session
#   - `e`              edit selected session
#   - `d`              delete selected session
#   - `Enter`          connect to selected
#                      session
#   - `Ctrl-Tab`       cycle session tabs
#   - `F2`             toggle SFTP browser
#   - `Ctrl-Q`         quit
#   - `?`              in-app help (full
#                      keymap)
#
# OPTIONS (sourced directly from
# https://github.com/caelansar/termirs/blob/main/src/main.rs Args struct):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _termirs_log_levels
_termirs_log_levels=(
    'off:disable logging entirely (even with --log on)'
    'error:errors only'
    'warn:errors + warnings'
    'info:default informational messages'
    'debug:debug + info'
    'trace:most verbose (includes russh packet-level events)'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-l --log)'{-l,--log}'[enable logging to termirs.log file]' \
    '--log-level=[log level (requires --log; default info)]:level:->level' \
    && ret=0

case $state in
    level)
        _describe -t levels 'log level' _termirs_log_levels && ret=0 ;;
esac

return ret
