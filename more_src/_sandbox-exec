#compdef sandbox-exec

local curcontext="$curcontext" state line ret=1

_arguments \
  '-f+[read profile from file]:profile file:_files' \
  '-n+[use predefined profile]:profile name:' \
  '-p+[profile string]:profile:' \
  '*-D+[define profile parameter]:key=value:' \
  '*::command:_command_names -e' \
  '*::args:_normal' && ret=0

return ret
