#compdef samtools-cram-size
# Documentation: http://www.htslib.org/doc/samtools-cram-size.html
# samtools cram-size: List a break down of data types and sizes in a CRAM file

local ret=1

_arguments -s -S \
  '(-o)'-o'[Output size information to FILE .]:FILE:_files' \
  '(-v)'-v'[Verbose mode. This shows one line per combination of Content ID and co]' \
  '(-e --encodings)'{-e,--encodings}'[CRAM uses an Encoding, which describes how the data is serialised into]' \
  '*:file:_files' && ret=0

return ret
