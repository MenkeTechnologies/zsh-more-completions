#compdef rzopfli
# Documentation: https://man.archlinux.org/search?q=rzopfli
# Reference accessed: 2026-05-16
# Source: cargo binstall rzopfli@0.1.6
# Probed via: --generate-completion zsh
# Repository: https://github.com/sorairolake/rzopfli

autoload -U is-at-least

_rzopfli() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-S+[Use <SUFFIX> as the suffix for the target file instead of '\''.gz'\'', '\''.zlib'\'', or '\''.deflate'\'']:SUFFIX:_default' \
'--suffix=[Use <SUFFIX> as the suffix for the target file instead of '\''.gz'\'', '\''.zlib'\'', or '\''.deflate'\'']:SUFFIX:_default' \
'-i+[Perform compression for the specified number of iterations]:TIMES:_default' \
'--iteration=[Perform compression for the specified number of iterations]:TIMES:_default' \
'--format=[Output to the specified format]:FORMAT:((gzip\:"The gzip file format, as defined in RFC 1952"
zlib\:"The zlib file format, as defined in RFC 1950"
deflate\:"The raw DEFLATE stream format, as defined in RFC 1951"))' \
'--log-level=[The minimum log level to print]:LEVEL:((OFF\:"Lowest log level"
ERROR\:"Error log level"
WARN\:"Warn log level"
INFO\:"Info log level"
DEBUG\:"Debug log level"
TRACE\:"Trace log level"))' \
'--generate-completion=[Generate shell completion]:SHELL:((bash\:"Bash"
elvish\:"Elvish"
fish\:"fish"
nushell\:"Nushell"
powershell\:"PowerShell"
zsh\:"Zsh"))' \
'(--rm -S --suffix)-c[Write to standard output, keep original files]' \
'(--rm -S --suffix)--stdout[Write to standard output, keep original files]' \
'-f[Force compression even if the output file already exists]' \
'--force[Force compression even if the output file already exists]' \
'(--rm)-k[Keep input files]' \
'(--rm)--keep[Keep input files]' \
'--rm[Remove input files after successful compression]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'*::input -- Files to compress:_files' \
&& ret=0
}

(( $+functions[_rzopfli_commands] )) ||
_rzopfli_commands() {
    local commands; commands=()
    _describe -t commands 'rzopfli commands' commands "$@"
}

if [ "$funcstack[1]" = "_rzopfli" ]; then
    _rzopfli "$@"
else
    compdef _rzopfli rzopfli
fi
