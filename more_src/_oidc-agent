#compdef oidc-agent
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/oidc-agent.1.html
# oidc-agent - OIDC token agent for managing OpenID Connect tokens

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[display help message]' \
  '--usage[show brief usage information]' \
  '(-V --version)'{-V,--version}'[print program version]' \
  '--always-allow-idtoken[always allow id-token requests without manual approval]' \
  '(-a --socket-path --bind_address)'{-a,--socket-path=,--bind_address=}'[specify UNIX-domain socket location]:path:_files' \
  '(-c --confirm)'{-c,--confirm}'[require user confirmation when applications request tokens]' \
  '--json[output agent socket and PID as JSON instead of bash]' \
  '(-k --kill)'{-k,--kill}'[terminate the current agent process]' \
  '--no-autoload[disable automatic configuration loading on token requests]' \
  '(--no-autoreauthenticate --no-auto-reauthenticate)'{--no-autoreauthenticate,--no-auto-reauthenticate}'[disable automatic re-authentication]' \
  '--no-scheme[disable custom URI scheme redirect]' \
  '--no-webserver[disable webserver startup for authorization code flow]' \
  '--pw-store=[cache encryption passwords in memory for TIME seconds]:seconds' \
  '--quiet[suppress informational messages to stdout]' \
  '--seccomp[enable seccomp system call filtering]' \
  '(-t --lifetime)'{-t,--lifetime=}'[default maximum lifetime for account configurations (seconds)]:seconds' \
  '--with-group=[allow access from applications in specified group]:group' \
  '(-d --console)'{-d,--console}'[run agent in foreground without daemonizing]' \
  '(-g --debug)'{-g,--debug}'[set log level to DEBUG]' \
  '--log-stderr[print log messages to stderr]' \
  '--status[display status of currently running agent]' && ret=0

return ret
