#compdef znap
# Documentation: https://github.com/marlonrichert/zsh-snap
# znap - Znap zsh plugin manager and prompt loader

local ret=1

_arguments -C \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'clone:download repositories'
      'source:start plugins'
      'prompt:optimize and load a prompt'
      'eval:cache and compile command output'
      'function:lazy-load a feature on first use'
      'compile:manually compile scripts or functions'
      'pull:update Znap and all repos'
      'status:check git status of all repos'
      'fpath:install generated completion functions'
      'help:show help for a command'
    )
    _describe -t commands 'znap command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      help)
        local -a sub
        sub=( clone source prompt eval function compile pull status fpath help )
        _describe -t subcommands 'znap command' sub && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
