#compdef bateconvert
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/bateconvert.html
# Apply BAT energy calibration to convert pulse heights to PI and ENERGY

local ret=1

_arguments -s -S \
  'infile=[input event file]:infile:_files' \
  'calfile=[calibration file with gain and offset]:calfile:_files' \
  'residfile=[quadratic-vs-linear residuals file]:residfile:_files' \
  'pulserfile=[pulser DAC to energy coefficients, CALDB]:pulserfile:' \
  'outfile=[output file, new instead of in-place]:outfile:_files' \
  'calmode=[energy conversion method]:calmode:(LINEAR QUADRATIC CUBIC DIRECTCUBIC FIXEDDAC)' \
  'zeroit=[zero the PI and ENERGY columns]:zeroit:(yes no)' \
  'fltpulserfile=[as-flown pulser coefficients, CALDB]:fltpulserfile:' \
  'scaled_energy=[write ENERGY as scaled 16-bit ints]:scaled_energy:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
