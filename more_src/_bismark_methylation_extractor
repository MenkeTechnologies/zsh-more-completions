#compdef bismark_methylation_extractor
# Documentation: https://github.com/FelixKrueger/Bismark/blob/master/bismark_methylation_extractor
# bismark_methylation_extractor: extract methylation calls from Bismark alignment output

local ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-p --paired-end -s --single-end)'{-p,--paired-end}'[process paired-end SAM/BAM files]' \
  '(-s --single-end -p --paired-end)'{-s,--single-end}'[process single-end SAM/BAM files]' \
  '--fasta[input is genomic FASTA format]' \
  '--ignore=[ignore first N bp from 5 prime end of read 1]:n:' \
  '--ignore_r2=[ignore first N bp from 5 prime end of read 2]:n:' \
  '--ignore_3prime=[ignore last N bp from 3 prime end of read 1]:n:' \
  '--ignore_3prime_r2=[ignore last N bp from 3 prime end of read 2]:n:' \
  '--comprehensive[merge strand-specific contexts into one file per context]' \
  '--merge_non_CpG[merge CHG and CHH into a non-CpG context]' \
  '--report[print short methylation summary report]' \
  '--no_overlap[do not count overlapping mate region in paired-end reads]' \
  '--include_overlap[count overlapping mate region in paired-end reads]' \
  '(-o --output_dir)'{-o+,--output_dir=}'[write output to this directory]:dir:_files -/' \
  '--no_header[suppress Bismark version header line in output]' \
  '--bedGraph[generate sorted bedGraph coverage output]' \
  '--cutoff=[min coverage before a position is reported in bedGraph]:n:' \
  '--remove_spaces[replace whitespace in read IDs with underscores]' \
  '--counts[add methylated/unmethylated counts to bedGraph output]' \
  '--cytosine_report[generate genome-wide cytosine methylation report]' \
  '(-g --genome_folder)'{-g+,--genome_folder=}'[path to genome folder with FastA files]:dir:_files -/' \
  '--zero_based[use 0-based genomic coordinates]' \
  '(--CX --CX_context)'{--CX,--CX_context}'[report all cytosine contexts]' \
  '--split_by_chromosome[write one output file per chromosome]' \
  '--buffer_size=[memory to allocate for UNIX sort]:size:' \
  '--samtools_path=[path to Samtools executable]:path:_files -/' \
  '--gzip[compress output files with gzip]' \
  '--mbias_only[only generate M-bias report, do not extract methylation]' \
  '--mbias_off[suppress M-bias analysis]' \
  '(--gazillion --scaffolds)'{--gazillion,--scaffolds}'[merge files for genomes with very many scaffolds]' \
  '--ample_memory[sort with arrays instead of UNIX sort]' \
  '(--parallel --multicore)'{--parallel,--multicore}'+[number of parallel processing threads]:n:' \
  '--yacht[single output file merging CpG and non-CG contexts]' \
  '--ucsc[generate UCSC genome browser compatible output]' \
  '*:alignment file:_files' && ret=0

return ret
