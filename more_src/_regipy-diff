# Reference accessed: 2026-05-20
# Verified: upstream Click-based CLI at the URL above; uses Click's
# standard zsh_complete dispatcher (Click >= 7.1).
# Source: Homebrew bottle
# Formula: regipy
# Type: maintainer-shipped (Homebrew)
# Harvested: 2026-05-15

_regipy_diff_completion() {
    local -a completions
    local -a completions_with_descriptions
    local -a response
    (( ! $+commands[regipy-diff] )) && return 1

    response=("${(@f)$(env COMP_WORDS="${words[*]}" COMP_CWORD=$((CURRENT-1)) _REGIPY_DIFF_COMPLETE=zsh_complete regipy-diff)}")

    for type key descr in ${response}; do
        if [[ "$type" == "plain" ]]; then
            if [[ "$descr" == "_" ]]; then
                completions+=("$key")
            else
                completions_with_descriptions+=("$key":"$descr")
            fi
        elif [[ "$type" == "dir" ]]; then
            _path_files -/
        elif [[ "$type" == "file" ]]; then
            _path_files -f
        fi
    done

    if [ -n "$completions_with_descriptions" ]; then
        _describe -V unsorted completions_with_descriptions -U
    fi

    if [ -n "$completions" ]; then
        compadd -U -V unsorted -a completions
    fi
}

if [[ $zsh_eval_context[-1] == loadautofunc ]]; then
    # autoload from fpath, call function directly
    _regipy_diff_completion "$@"
else
    # eval/source/. command, register function for later
    compdef _regipy_diff_completion regipy-diff
fi

