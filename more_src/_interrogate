#compdef interrogate
# Documentation: https://github.com/econchick/interrogate
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '*'{-v,--verbose}'[verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[no output]' \
  '(-f --fail-under)'{-f,--fail-under}'=[min coverage percent]:pct:' \
  '*'{-e,--exclude}'+[path to skip]:path:_files' \
  '(-i --ignore-init-method)'{-i,--ignore-init-method}'[ignore __init__ methods]' \
  '(-I --ignore-init-module)'{-I,--ignore-init-module}'[ignore __init__.py modules]' \
  '(-m --ignore-magic)'{-m,--ignore-magic}'[ignore dunder methods except __init__]' \
  '(-M --ignore-module)'{-M,--ignore-module}'[ignore module docstrings]' \
  '(-C --ignore-nested-classes)'{-C,--ignore-nested-classes}'[ignore nested classes]' \
  '(-n --ignore-nested-functions)'{-n,--ignore-nested-functions}'[ignore nested defs]' \
  '(-O --ignore-overloaded-functions)'{-O,--ignore-overloaded-functions}'[ignore @overload]' \
  '(-p --ignore-private)'{-p,--ignore-private}'[ignore __names]' \
  '(-P --ignore-property-decorators)'{-P,--ignore-property-decorators}'[ignore property helpers]' \
  '(-S --ignore-setters)'{-S,--ignore-setters}'[ignore property setters]' \
  '(-s --ignore-semiprivate)'{-s,--ignore-semiprivate}'[ignore _names]' \
  '*'{-r,--ignore-regex}'+[ignore names matching regex]:regex:' \
  '*'--ext+'[extra extension]:ext:(pyi ipynb)' \
  '*'{-w,--whitelist-regex}'+[include only matching names]:regex:' \
  '--style=[docstring style]:style:(sphinx google)' \
  '(-o --output)'{-o,--output}'=[write report file]:file:_files' \
  '--color[force color]' \
  '--no-color[disable color]' \
  '--omit-covered-files[hide 100% files when verbose]' \
  '(-g --generate-badge)'{-g,--generate-badge}'=[write shields badge path]:path:_files' \
  '--version[show version]' \
  '-h[help]' \
  '*:paths:_files -/'
