#compdef cfn-flip
# Documentation: https://pypi.org/project/cfn-flip/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '--version[show version]' \
  '(-i --input)'{-i,--input}'=[input format]:format:(json yaml)' \
  '(-o --output)'{-o,--output}'=[output format]:format:(json yaml)' \
  '(-j --json)'{-j,--json}'[convert to JSON]' \
  '(-y --yaml)'{-y,--yaml}'[convert to YAML]' \
  '(-c --clean)'{-c,--clean}'[opinionated cleanup of template]' \
  '(-l --long)'{-l,--long}'[long-form function syntax when converting to YAML]' \
  '(-n --no-flip)'{-n,--no-flip}'[perform other operations but do not flip format]' \
  '*:file:_files'
