#compdef cfn-flip
# Documentation: https://man.archlinux.org/search?q=cfn-flip
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-j --json)'{-j,--json}'[JSON instead of YAML]' \
  '(-c --clean)'{-c,--clean}'[clean output]' \
  '(-n --no-flip)'{-n,--no-flip}'[do not flip, only parse]' \
  '(-s --split)'{-s,--split}'[split output]' \
  '*:file:_files'
