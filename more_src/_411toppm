#compdef 411toppm
# Documentation: man 411toppm (Netpbm)
# Source: convert raw Sony Mavica .411 image data to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-width+[image width]:width:' \
    '-height+[image height]:height:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:411 file:_files -g "*.(411|raw)"' \
    && ret=0

return ret
