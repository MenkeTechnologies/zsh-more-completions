#compdef sumix
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/operations/sumix.c
# SUMIX - compute weighted moving average (trace mix) on a panel

local ret=1

_arguments -s -S \
  'mix=[array of weights for weighted average]:m:' \
  '*:SU file:_files' && ret=0

return ret
