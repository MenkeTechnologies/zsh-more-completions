#compdef plop
# Documentation: https://plopjs.com/documentation/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for plop - micro-generator framework

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--plopfile=[path to the plopfile]:file:_files' \
  '--cwd=[directory from which relative paths are calculated]:directory:_directories' \
  '--init-ts[create a TypeScript plopfile template]' \
  '--force[overwrite existing files without prompting]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:generator:' \
  '*:: :_default' && ret=0

return ret
