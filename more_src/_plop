#compdef plop

# Zsh completion for plop - micro-generator framework

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--plopfile[path to the plopfile]:file:_files' \
  '--cwd[directory from which relative paths are calculated]:directory:_directories' \
  '--require[require a module before running plop]:module' \
  '--dest[destination directory for generated files]:directory:_directories' \
  '--show[show available generators]' \
  '--force[overwrite existing files without prompting]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:generator:->generators' \
  '*:: :->args' && ret=0

case $state in
  generators)
    local -a generators
    generators=(${(f)"$(plop --show 2>/dev/null | tail -n +2 | sed 's/^[[:space:]]*//' | grep -v '^$')"})
    if (( ${#generators} )); then
      _describe -t generators 'generator' generators && ret=0
    fi
    ;;
esac

return ret
