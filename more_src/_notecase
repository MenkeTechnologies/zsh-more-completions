#compdef notecase
# Documentation: (project abandoned; package removed from current Debian)
# Reference accessed: 2026-05-16
# Verified: notecase was last shipped in Debian buster; upstream was
# abandoned ~2009 in favor of NoteCase Pro (closed source). The
# bookworm manpage is gone. Historical sources document --help,
# --version, and a positional .ncd file argument.
# Removed from prior file: bogus man.archlinux.org search URL; the
# verified flag set is reduced to what older shipping versions
# documented.

# notecase: hierarchical notes editor (abandoned upstream)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '*:notes file:_files -g "*.ncd(-.)"' && ret=0
return ret
