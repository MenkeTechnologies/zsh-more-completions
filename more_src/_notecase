#compdef notecase
# Documentation: https://notecase.sourceforge.net/download.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: notecase was abandoned upstream around 2009 in favor of NoteCase Pro
# (closed source). Historical shipping versions documented --help, --version
# and a positional .ncd file argument.

# notecase: hierarchical notes editor (abandoned upstream)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '*:notes file:_files -g "*.ncd(-.)"' && ret=0
return ret
