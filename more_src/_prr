#compdef prr

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'get:download a pull request for review'
  'submit:submit a review'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d+[workdir for reviews]:directory:_directories' \
  '--workdir=[workdir for reviews]:directory:_directories' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'prr command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      get)
        _arguments -s -S \
          '-o[open in editor after download]' \
          '--open[open in editor after download]' \
          '1:pull request (owner/repo/number):' && ret=0
        ;;
      submit)
        _arguments -s -S \
          '1:pull request (owner/repo/number):' && ret=0
        ;;
    esac
    ;;
esac

return ret
