#compdef k0sctl

# Zsh completion for k0sctl - k0s cluster management tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'apply:apply cluster configuration'
  'backup:create cluster backup'
  'config:manage configuration'
  'init:create default configuration'
  'kubeconfig:output cluster kubeconfig'
  'reset:remove k0s cluster'
  'version:show version'
)

_arguments -s -S \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '--trace[enable trace logging]' \
  '--no-drain[do not drain nodes before upgrade]' \
  '--no-wait[do not wait for cluster readiness]' \
  '(-c --config)'{-c+,--config=}'[config file path]:config file:_files -g "*.{yaml,yml}"' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'k0sctl command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      apply)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file path]:config file:_files -g "*.{yaml,yml}"' \
          '--no-drain[do not drain nodes]' \
          '--no-wait[do not wait for readiness]' \
          '--restore-from=[restore from backup]:backup file:_files'
        ;;
      backup)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file path]:config file:_files -g "*.{yaml,yml}"'
        ;;
      init)
        _arguments \
          '--k0s[include default k0s config]' \
          '--cluster-name=[cluster name]:name:'
        ;;
      kubeconfig)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file path]:config file:_files -g "*.{yaml,yml}"' \
          '--address=[override controller address]:address:'
        ;;
      reset)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file path]:config file:_files -g "*.{yaml,yml}"' \
          '--force[force reset]'
        ;;
    esac
    ;;
esac

return ret
