#compdef iio_generic_buffer
# _iio_generic_buffer — example IIO buffer capture utility (torvalds/linux tools/iio/)
# upstream: https://github.com/torvalds/linux/blob/master/tools/iio/iio_generic_buffer.c
# Flags from tools/iio/iio_generic_buffer.c (getopt_long).

_iio_generic_buffer() {
    _arguments \
        '(- *)-?[show help]' \
        '-a[enable auto-channel mode]' \
        '-A[enable auto-channel mode (no force)]' \
        '-b+[buffer length]:n:' \
        '-c+[number of samples to capture (0 = infinite)]:n:' \
        '-e[disable event reading]' \
        '-g[disable trigger usage]' \
        '-l+[buffer length]:n:' \
        '(-n --device-name)'{-n+,--device-name=}'[IIO device name]:name:' \
        '(-N --device-num)'{-N+,--device-num=}'[IIO device number]:n:' \
        '(-t --trigger-name)'{-t+,--trigger-name=}'[trigger name]:name:' \
        '(-T --trigger-num)'{-T+,--trigger-num=}'[trigger number]:n:' \
        '-w+[wait time (us) between buffer reads]:us:'
}

_iio_generic_buffer "$@"
