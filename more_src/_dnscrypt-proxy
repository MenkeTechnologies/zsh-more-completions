#compdef dnscrypt-proxy

# Zsh completion for dnscrypt-proxy - DNS encryption proxy

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-version,--version}'[show version]' \
  '(-config)'-config'[path to config file]:file:_files -g "*.toml"' \
  '(-check)'-check'[check config and exit]' \
  '(-service)'-service'[manage system service]:action:(install uninstall start stop restart)' \
  '(-resolve)'-resolve'[resolve a name]:name' \
  '(-list)'-list'[print list of available resolvers]' \
  '(-list-all)'-list-all'[print list of all resolvers]' \
  '(-json)'-json'[output in JSON format]' \
  '(-show-certs)'-show-certs'[display certificates]' \
  '(-logfile)'-logfile'[log file path]:file:_files' \
  '(-loglevel)'-loglevel'[log level]:level:(0 1 2 3 4 5 6)' \
  '(-child)'-child'[run as child process]' \
  '(-pidfile)'-pidfile'[PID file path]:file:_files'
