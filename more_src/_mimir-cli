#compdef mimir-cli mimirtool
# _mimir-cli — Grafana Mimir mimirtool admin CLI (Grafana Labs, Go); alecthomas/kingpin
# upstream: https://github.com/grafana/mimir

_mimir-cli() {
    local -a sub=(
        'alertmanager:manage alertmanager configs'
        'alerts:check alerts'
        'rules:manage ruler rules'
        'remote-read:remote-read query'
        'analyse:analyse metric usage'
        'analyze:analyze metric usage'
        'config:edit/diff config'
        'bucket-validation:validate object storage'
        'acl:generate header for tenant ACL'
        'login:authenticate'
        'logout:logout'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--address=+[mimir API address]:url:_urls' \
        '--id=+[tenant id]:str:' \
        '--user=+[user]:str:_users' \
        '--key=+[api key]:str:' \
        '--tls-ca-path=+[tls ca path]:file:_files' \
        '--tls-cert-path=+[tls cert path]:file:_files' \
        '--tls-key-path=+[tls key path]:file:_files' \
        '--tls-insecure-skip-verify[skip tls verify]' \
        '--auth-token=+[auth token]:str:' \
        '--extra-headers=+[extra headers]:str:' \
        '--log.level=+[log level]:level:(debug info warn error)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mimirtool subcommand' sub ;;
        args)
            case $words[1] in
                alertmanager) _arguments \
                    '1:cmd:(get load delete render verify migrate-utf8 unmute)' \
                    '*:file:_files -g "*.(yml|yaml)"' ;;
                rules) _arguments \
                    '1:cmd:(load list print get sync diff lint prepare check delete delete-namespace)' \
                    '--namespaces=+[namespaces]:list:' \
                    '--ignored-namespaces=+[ignored namespaces]:list:' \
                    '--rule-files=+[rule files]:list:' \
                    '*:file:_files -g "*.(yml|yaml)"' ;;
                analyse|analyze) _arguments \
                    '1:cmd:(prometheus grafana ruler dashboard)' \
                    '--address=+[address]:url:_urls' \
                    '--output=+[output]:file:_files' ;;
                config) _arguments \
                    '1:cmd:(diff convert describe)' \
                    '*:file:_files -g "*.yaml"' ;;
                bucket-validation) _arguments \
                    '--object-storage-config=+[storage config]:file:_files' ;;
                acl) _arguments \
                    '1:cmd:(generate-header)' \
                    '--id=+[tenant id]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_mimir-cli "$@"
