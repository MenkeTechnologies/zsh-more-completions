#compdef octopus octo

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'account:manage Octopus accounts'
  'build-information:manage build information'
  'channel:manage channels'
  'config:get/set CLI configuration'
  'deployment-target:manage deployment targets'
  'environment:manage environments'
  'project:manage projects'
  'project-group:manage project groups'
  'release:manage releases (create/deploy/list/delete)'
  'runbook:manage and run runbooks'
  'runbook-run:trigger a runbook run'
  'package:upload and manage packages'
  'space:manage spaces'
  'tag-set:manage tenant tag sets'
  'tenant:manage tenants'
  'user:manage users'
  'team:manage teams'
  'worker:manage workers'
  'worker-pool:manage worker pools'
  'task:manage running tasks'
  'login:authenticate to Octopus'
  'logout:clear stored credentials'
  'completion:generate shell completion'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--server=[Octopus server URL]:url:' \
  '--api-key=[Octopus API key]:key:' \
  '--access-token=[OIDC access token]:token:' \
  '--space=[Octopus space]:space:' \
  '--no-prompt[non-interactive mode]' \
  '--output-format=[output format]:format:(table json basic)' \
  '--debug[debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

local -a crud_subs=(
  'create:create resource'
  'list:list resources'
  'view:view resource'
  'delete:delete resource'
  'update:update resource'
)

case $state in
  (cmd) _describe -t cmds 'octopus command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (account)
        _arguments '*::sub:(aws azure azure-oidc gcp generic-oidc ssh token username list view delete)' && ret=0 ;;
      (build-information)
        _arguments '*::sub:(upload list view delete bulk-delete)' && ret=0 ;;
      (deployment-target)
        _arguments '*::sub:(azure-web-app kubernetes listening-tentacle polling-tentacle cloud-region ssh create list view delete)' && ret=0 ;;
      (release)
        local -a rel_subs=(
          'create:create a new release'
          'deploy:deploy a release'
          'list:list releases'
          'view:view release details'
          'delete:delete a release'
        )
        _describe -t rsubs 'release subcommand' rel_subs && ret=0
        _arguments \
          '--project=[project name or id]:project:' \
          '--release-number=[release number]:n:' \
          '--package-version=[default package version]:version:' \
          '*--package=[StepName:Version override]:pkg:' \
          '*--deploy-to=[environment to deploy to]:env:' \
          '--release-notes=[release notes]:notes:' \
          '--release-notes-file=[release notes file]:file:_files' \
          '--ignore-existing[ignore if release exists]' \
          '--ignore-channel-rules[ignore channel rules]' \
          '--channel=[channel name]:channel:' \
          '--git-ref=[git ref]:ref:' \
          '--git-commit=[git commit]:sha:' && ret=0 ;;
      (runbook)
        _arguments '*::sub:(create list view delete run snapshot)' && ret=0 ;;
      (runbook-run)
        _arguments \
          '--project=[project]:project:' \
          '--name=[runbook name]:name:' \
          '*--environment=[target environment]:env:' \
          '--snapshot=[snapshot name/id]:snapshot:' && ret=0 ;;
      (project|project-group|environment|tenant|space|tag-set|user|team|worker|worker-pool|channel)
        _describe -t crud 'subcommand' crud_subs && ret=0 ;;
      (package)
        _arguments '*::sub:(upload list view delete versions nuget zip)' && ret=0 ;;
      (config)
        _arguments '*::sub:(get set list reset)' && ret=0 ;;
      (login)
        _arguments \
          '--server=[Octopus server URL]:url:' \
          '--api-key=[API key]:key:' \
          '--access-token=[OIDC access token]:token:' && ret=0 ;;
      (task)
        _arguments '*::sub:(wait list view cancel)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
