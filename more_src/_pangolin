#compdef pangolin
# Documentation: https://cov-lineages.org/resources/pangolin/usage.html
# SARS-CoV-2 lineage assignment

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --outdir)'{-o,--outdir}'[output directory]:dir:_files -/' \
  '--outfile[output file name]:file:_files' \
  '--tempdir[temporary file location]:dir:_files -/' \
  '--no-temp[output all intermediate files]' \
  '--alignment[generate multiple sequence alignment output]' \
  '--alignment-file[alignment output filename]:file:_files' \
  '--analysis-mode[inference engine]:mode:(accurate fast pangolearn usher)' \
  '--skip-designation-cache[do not use designation cache]' \
  '--max-ambig[max proportion of ambiguous bases]:n:' \
  '--min-length[minimum sequence length]:n:' \
  '--update[update pangolin and data, then exit]' \
  '--update-data[update data files]' \
  '(-d --datadir)'{-d,--datadir}'[data directory]:dir:_files -/' \
  '--usher-tree[custom UShER protobuf tree file]:file:_files' \
  '--aliases[print alias_key.json and exit]' \
  '(-pv --pangolin-data-version)'{-pv,--pangolin-data-version}'[show data file versions]' \
  '--all-versions[show all tool and dependency versions]' \
  '--verbose[verbose output]' \
  '(-t --threads)'{-t,--threads}'[number of threads]:n:' \
  '*:query fasta:_files -g "*.fa *.fasta"' && ret=0

return ret
