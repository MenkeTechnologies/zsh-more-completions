#compdef llvm-xray
# _llvm-xray — LLVM XRay trace analysis (LLVM project, C++); analyze function-call tracing logs from XRay-instrumented binaries
# upstream: https://github.com/llvm/llvm-project

_llvm-xray() {
    local -a sub=(
        'account:account function call frequencies'
        'convert:convert log formats'
        'extract:extract instrumentation map'
        'graph:render call graph'
        'graph-diff:diff two graphs'
        'stack:stack reconstruction'
        'fdr-dump:dump FDR mode log'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'llvm-xray subcommand' sub ;;
        args)
            case $words[1] in
                account) _arguments \
                    '--top=+[top n]:n:' \
                    '--sort=+[sort by]:by:(count min med 90p 99p max sum func)' \
                    '--sortorder=+[order]:order:(ascending descending)' \
                    '--format=+[format]:fmt:(text csv)' \
                    '--instr_map=+[instr map]:file:_files' \
                    '-o+[output]:file:_files' \
                    '*:file:_files' ;;
                convert) _arguments \
                    '--output-format=+[format]:fmt:(yaml trace_event chrome)' \
                    '-o+[output]:file:_files' \
                    '--instr_map=+[instr map]:file:_files' \
                    '--symbolize[symbolize]' \
                    '*:file:_files' ;;
                extract) _arguments \
                    '-o+[output]:file:_files' \
                    '--symbolize[symbolize]' \
                    '*:file:_files' ;;
                graph|graph-diff) _arguments \
                    '--instr_map=+[instr map]:file:_files' \
                    '-o+[output]:file:_files' \
                    '--edge-label=+[edge label]:label:(none count med 90p 99p max sum)' \
                    '--vertex-label=+[vertex label]:label:(none count med 90p 99p max sum)' \
                    '*:file:_files' ;;
                stack) _arguments \
                    '--instr_map=+[instr map]:file:_files' \
                    '--all-stacks[show all stacks]' \
                    '--stack-format=+[format]:fmt:(flame chrome)' \
                    '*:file:_files' ;;
                fdr-dump) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_llvm-xray "$@"
