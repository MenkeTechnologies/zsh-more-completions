#compdef systemd-fsck
# _systemd-fsck — systemd-fsck (per-filesystem-check helper dispatched from systemd-fsck@.service / systemd-fsck-root.service; reads /etc/fstab passno + journal status, runs the matching fsck.<type> binary; -h help, --version, --root only on systemd-fsck-root)
# upstream: https://github.com/systemd/systemd (src/fsck)
# Flags from systemd src/fsck/fsck.c on tip.

_systemd-fsck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--root[only the root file system]' \
        '*:device or mountpoint:_files'
}

_systemd-fsck "$@"
