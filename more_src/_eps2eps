#compdef eps2eps

local -a arguments

arguments=(
    '-dNOPAUSE[No pause between pages]'
    '-dBATCH[Exit after processing]'
    '-dSAFER[Safer mode]'
    '-r[Resolution]:resolution:'
    '-sDEVICE=[Output device]:device:'
    '-dDEVICEWIDTHPOINTS=[Page width]:width:'
    '-dDEVICEHEIGHTPOINTS=[Page height]:height:'
    '-dLanguageLevel=[PostScript language level]:level:(1 2 3)'
    '-q[Quiet mode]'
    '1:input EPS file:_files -g "*.eps"'
    '2:output EPS file:_files -g "*.eps"'
)

_arguments -s -S $arguments
