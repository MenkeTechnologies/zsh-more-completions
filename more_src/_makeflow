#compdef makeflow
# Documentation: https://cctools.readthedocs.io/en/latest/man_pages/makeflow/
# makeflow - CCTools workflow engine for executing distributed workflows

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --clean)'{-c,--clean}'=[remove logfile and target files]:option' \
  '(-f --summary-log)'{-f,--summary-log}'=[write workflow summary to file]:file:_files' \
  '(-X --chdir)'{-X,--chdir}'=[change to directory before executing]:dir:_files -/' \
  '--argv=[load command-line arguments from JSON file]:file:_files' \
  '(-a --advertise)'{-a,--advertise}'[advertise the workflow to the catalog server]' \
  '(-l --makeflow-log)'{-l,--makeflow-log}'=[use this file for the makeflow log]:file:_files' \
  '(-L --batch-log)'{-L,--batch-log}'=[use this file for the batch system log]:file:_files' \
  '(-m --email)'{-m,--email}'=[email the workflow summary to address]:email' \
  '(-j --max-local)'{-j,--max-local}'=[max number of local jobs to run at once]:num' \
  '(-J --max-remote)'{-J,--max-remote}'=[max number of remote jobs to run at once]:num' \
  '(-R --retry)'{-R,--retry}'[automatically retry failed jobs up to 100 times]' \
  '(-r --retry-count)'{-r,--retry-count}'=[automatically retry failed jobs up to n times]:n' \
  '--local-cores=[max cores for local execution]:num' \
  '--local-memory=[max memory in MB for local execution]:mb' \
  '--local-disk=[max disk in MB for local execution]:mb' \
  '(-B --batch-options)'{-B,--batch-options}'=[add these options to all batch submit files]:options' \
  '(-T --batch-type)'{-T,--batch-type}'=[batch system type]:type:(local condor sge pbs torque slurm moab cluster wq amazon mesos k8s dryrun)' \
  '(-S --submission-timeout)'{-S,--submission-timeout}'=[time to retry failed batch job submission]:timeout' \
  '(-d --debug)'{-d,--debug}'=[enable debugging for this subsystem]:subsystem' \
  '(-o --debug-file)'{-o,--debug-file}'=[write debugging output to this file]:file:_files' \
  '(-C --catalog-server)'{-C,--catalog-server}'=[set catalog server host:port]:catalog' \
  '(-F --wq-fast-abort)'{-F,--wq-fast-abort}'=[work queue fast abort multiplier]:num' \
  '(-M -N --project-name)'{-M,-N,--project-name}'=[set the project name for work queue]:project' \
  '(-p --port)'{-p,--port}'=[port for the work queue manager to listen on]:port' \
  '(-Z --port-file)'{-Z,--port-file}'=[select a random port and write it to this file]:file:_files' \
  '(-P --priority)'{-P,--priority}'=[priority of this workflow with the work queue]:integer' \
  '(-t --keepalive-timeout)'{-t,--keepalive-timeout}'=[work queue keepalive timeout]:seconds' \
  '(-u --keepalive-interval)'{-u,--keepalive-interval}'=[work queue keepalive interval]:seconds' \
  '(-W --schedule)'{-W,--schedule}'=[work queue scheduling algorithm]:mode:(files time fcfs)' \
  '*:makeflow file:_files' && ret=0

return ret
