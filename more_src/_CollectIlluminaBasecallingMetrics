#compdef CollectIlluminaBasecallingMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectIlluminaBasecallingMetrics
# Picard: collect Illumina basecalling metrics for a sequencing run

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-B=,--BASECALLS_DIR=}'[Illumina basecalls output directory to read from]:dir:_files -/' \
  {-BCD=,--BARCODES_DIR=}'[directory of barcode files (defaults to BASECALLS_DIR)]:dir:_files -/' \
  {-L=,--LANE=}'[lane whose data will be read]:int:' \
  {-I=,--INPUT=}'[file listing expected barcodes from the run]:file:_files' \
  {-RS=,--READ_STRUCTURE=}'[logical structure of clusters in the run]:structure:' \
  {-O=,--OUTPUT=}'[file path for the collected metrics]:file:_files' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:argument:_files' && ret=0

return ret
