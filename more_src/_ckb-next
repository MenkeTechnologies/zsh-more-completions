#compdef ckb-next ckb-next-daemon
# Documentation: https://github.com/ckb-next/ckb-next
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

case $service in
  (ckb-next-daemon)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '--gid=[restrict /dev/input/ckb* access to group]:gid:_groups' \
      '--hwload=[hardware profile load mode]:mode:(always try never)' \
      '--nonotify[disable key monitoring/notifications]' \
      '--nobind[disable key rebinding, macros, and notifications (implies --nonotify)]' \
      '--nomouseaccel[disable mouse acceleration (macOS legacy)]' \
      '--nonroot[allow running as non-root user]' \
      '--ignore=[add vendor:product ID to ignore list]:vid\:pid' \
      '--search=[search keymap for key]:vid\:pid[keyname]' \
      '--enable-experimental[enable support for experimental devices]' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '--background[start hidden]' \
      '--close[close any running instance]' \
      '--with-config=[config file]:file:_files' && ret=0 ;;
esac

return ret
