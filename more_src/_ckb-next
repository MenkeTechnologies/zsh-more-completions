#compdef ckb-next ckb-next-daemon

local curcontext="$curcontext" ret=1

case $service in
  (ckb-next-daemon)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(--gid)--gid=+[set group ID]:gid:_groups' \
      '(--nobind)--nobind[do not bind LED keys to media keys]' \
      '(--nonotify)--nonotify[disable notify socket]' \
      '(--nonroot)--nonroot[run unprivileged]' \
      '(--enable-experimental)--enable-experimental[enable experimental features]' \
      '(--hwload)--hwload=+[HW load mode]:mode:(once always tries)' \
      '(--brain)--brain[enable brain mode]' \
      '(--nomouseaccel)--nomouseaccel[disable mouse acceleration]' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '--background[start hidden]' \
      '--close[close any running instance]' \
      '--with-config=[config file]:file:_files' && ret=0 ;;
esac

return ret
