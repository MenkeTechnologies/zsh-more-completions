#compdef existence
# Source: cargo binstall existence@0.4.0
# Probed via: completions zsh
# Repository: https://github.com/existence-lang/existence

autoload -U is-at-least

_existence() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_existence_commands" \
"*::: :->existence" \
&& ret=0
    case $state in
    (existence)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:existence-command-$line[1]:"
        case $line[1] in
            (lookup)
_arguments "${_arguments_options[@]}" : \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'--json[Output parsed sections as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
':term -- Term name (e.g. "existence", "entity"):_default' \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
'--limit=[Maximum number of results (default 10)]:LIMIT:_default' \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'--json[Output results as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
':query -- Search query (matches term names, definitions, and content):_default' \
&& ret=0
;;
(scope)
_arguments "${_arguments_options[@]}" : \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'-h[Print help]' \
'--help[Print help]' \
'::ring -- Ring level (0, 1, ...). Omit to list all rings:_default' \
&& ret=0
;;
(lint)
_arguments "${_arguments_options[@]}" : \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Path to lint (directory or single file). Defaults to src/:_default' \
&& ret=0
;;
(graph)
_arguments "${_arguments_options[@]}" : \
'--format=[Output format\: "dot" (default) or "json"]:FORMAT:_default' \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'-h[Print help]' \
'--help[Print help]' \
'::ring -- Filter to a specific ring level:_default' \
&& ret=0
;;
(fetch)
_arguments "${_arguments_options[@]}" : \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'-h[Print help]' \
'--help[Print help]' \
'::source -- Source in format github\:org/repo. If omitted, reads existence.toml:_default' \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
'--ring=[Add to ring N in existence.toml (0, 1, 2)]:RING:_default' \
'--description=[Pre-fill the ontology section'\''s first line]:DESCRIPTION:_default' \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'--no-edit[Don'\''t open in \$EDITOR after creating]' \
'-h[Print help]' \
'--help[Print help]' \
':term -- Term name (lowercase, hyphens for multi-word, e.g. "domain-model"):_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for (bash, zsh, fish, elvish, powershell):(bash elvish fish powershell zsh)' \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(serve)
_arguments "${_arguments_options[@]}" : \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(build-site)
_arguments "${_arguments_options[@]}" : \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(context)
_arguments "${_arguments_options[@]}" : \
'--ontology=[Path to the ontology directory (overrides auto-detection)]:ONTOLOGY:_files' \
'-h[Print help]' \
'--help[Print help]' \
':domain -- Domain name:_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_existence__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:existence-help-command-$line[1]:"
        case $line[1] in
            (lookup)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(scope)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(lint)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(graph)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(fetch)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(serve)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(build-site)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(context)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_existence_commands] )) ||
_existence_commands() {
    local commands; commands=(
'lookup:Read a node'\''s full definition' \
'search:Search across term files by relevance' \
'scope:Navigate the scoping chain — list terms at a ring level' \
'lint:Validate ontology nodes against SPEC.md rules' \
'graph:Generate term relationship graph' \
'fetch:Clone or pull an ontology from a GitHub repo' \
'new:Create a new ontology node from template' \
'completions:Generate shell completion scripts' \
'install:Set up ~/.claude integration (not yet implemented)' \
'serve:Start local API server (not yet implemented)' \
'build-site:Generate static site + JSON API (not yet implemented)' \
'context:Suggest relevant terms for a domain (not yet implemented)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'existence commands' commands "$@"
}
