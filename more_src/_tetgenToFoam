#compdef tetgenToFoam
# Converts .ele and .node and .face files, written by tetgen

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-noFaceFile[skip reading .face file for boundary information]' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' \
  ':file prefix:_files' && ret=0

return ret
