#compdef findomain

_arguments \
  '-t[target domain]:domain' \
  '-f[file with list of domains]:file:_files' \
  '-o[output file]:file:_files' \
  '--output[output directory]:directory:_directories' \
  '-r[use resolvers to discover active subdomains]' \
  '--resolver[custom resolvers file]:file:_files' \
  '-u[unique output file]:file:_files' \
  '-q[quiet mode]' \
  '-v[verbose mode]' \
  '--ip[show/resolve IP address for each subdomain]' \
  '--http-status[check HTTP status for each subdomain]' \
  '--threads[number of threads]:count' \
  '--wordlist[wordlist for bruteforce]:file:_files' \
  '-m[monitoring mode]' \
  '--postgres-connection[PostgreSQL connection string]:string' \
  '--import-subdomains[import subdomains from file]:file:_files' \
  '--enable-dot[enable DNS over TLS]' \
  '-s[screenshot subdomains]' \
  '--screenshots-path[path to store screenshots]:directory:_directories' \
  '-h[display help]' \
  '-V[display version]'
