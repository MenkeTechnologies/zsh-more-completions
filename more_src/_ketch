#compdef ketch
# Documentation: https://man.archlinux.org/search?q=ketch
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'app:manage applications on Ketch'
      'cname:manage framework CNAMEs'
      'framework:manage App CRDs for a cluster'
      'pool:manage pool resources'
      'completion:print shell completion'
      'version:print version'
    )
    _describe -t commands 'ketch command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(--kubeconfig)'--kubeconfig'=[kubeconfig path]:file:_files' \
      '(--context)'--context'=[kube context name]:context' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
