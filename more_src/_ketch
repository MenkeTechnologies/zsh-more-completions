#compdef ketch
# Documentation: https://github.com/theketchio/ketch
# Reference accessed: 2026-05-19
# Verified: upstream source cmd/ketch/root.go at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'app:manage applications on Ketch'
      'builder:manage CNB builders'
      'cname:manage application CNAMEs'
      'env:manage application environment variables'
      'job:manage jobs on Ketch'
      'ingress:manage the cluster ingress'
      'completion:print shell completion'
      'version:print version'
    )
    _describe -t commands 'ketch command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      app)
        local -a app_subs=(
          'deploy:deploy an application'
          'list:list applications'
          'log:show application logs'
          'remove:remove an application'
          'info:show application info'
          'start:start an application'
          'stop:stop an application'
          'export:export an application as YAML'
        )
        _describe -t app_subs 'app subcommand' app_subs && ret=0
        ;;
      builder)
        _describe -t builder_subs 'builder subcommand' \
          'list:list supported builders' 'set:set the default builder' && ret=0
        ;;
      cname)
        _describe -t cname_subs 'cname subcommand' \
          'add:add a CNAME' 'remove:remove a CNAME' && ret=0
        ;;
      env)
        _describe -t env_subs 'env subcommand' \
          'get:show env vars' 'set:set env vars' 'unset:unset env vars' && ret=0
        ;;
      job)
        _describe -t job_subs 'job subcommand' \
          'deploy:deploy a job' 'list:list jobs' 'remove:remove a job' \
          'export:export a job as YAML' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
