#compdef tika-server tikaserver
# ============================================================================
#  _tika-server — Apache Tika Server: REST/HTTP server for content extraction
#
#  Source-direct extraction from
#    https://github.com/apache/tika/blob/main/tika-server/tika-server-core/src/main/java/org/apache/tika/server/core/TikaServerCli.java
#    https://github.com/apache/tika/blob/main/tika-server/tika-server-core/src/main/java/org/apache/tika/server/core/TikaServerProcess.java
#    https://github.com/apache/commons-cli (Apache Commons CLI library)
#
#  Maintained by Apache Software Foundation (apache/tika).  Tika
#  is a content detection + analysis framework that extracts text,
#  metadata, and structured content from over 1,400 file formats
#  (PDF, Office, RTF, HTML, audio/video, images via OCR, archives,
#  source code).  tika-server is the REST/HTTP server (JAX-RS) that
#  exposes Tika's extraction over HTTP — POST a document to /tika,
#  get back extracted text; POST to /meta, get back metadata, etc.
#  Sister tools: tika-app (Tika command-line, IN CORPUS), Apache
#  PDFBox (IN CORPUS via _pdfbox), Apache POI (Microsoft Office
#  reader, in corpus via _poi).
#
#  CLI library taxonomy update: 5th Java CLI library — **Apache
#  Commons CLI** (commons-cli).  Java ecosystem now has 5
#  documented CLI libraries (R277 picocli + R299 args4j + R322
#  JCommander + R353 rvesse/airline + R371 Apache Commons CLI)
#  joining OCaml (5) at the third-most-documented-CLI-language tier
#  behind Rust (9) and Go (9).
#
#  Apache Commons CLI (commons-cli) is THE CANONICAL Java CLI
#  library by the Apache Software Foundation — originally written
#  in 2002 by John Keyes (initial commit predates picocli by 15
#  years).  Used by Apache Hadoop, Apache Maven, Apache Pig,
#  Apache Hive, Apache Solr, Apache Spark, Apache Tika, Apache
#  HBase, Apache Storm, Apache Flink, Apache Druid, Apache Accumulo,
#  Apache Pulsar, Apache Calcite, Apache Lucene, and most of the
#  Apache Java ecosystem.  Mature, stable, conservative — has been
#  the de facto Java CLI standard for over two decades.
#
#  Apache Commons CLI API:
#    import org.apache.commons.cli.CommandLine;
#    import org.apache.commons.cli.CommandLineParser;
#    import org.apache.commons.cli.DefaultParser;
#    import org.apache.commons.cli.HelpFormatter;
#    import org.apache.commons.cli.Options;
#
#    Options options = new Options();
#    options.addOption("h", "host", true, "host name");
#    options.addOption("p", "port", true, "listen port (default 9998)");
#    options.addOption("?", "help", false, "this help message");
#    options.addOption("c", "config", true, "tika-config file");
#
#    CommandLineParser parser = new DefaultParser();
#    try {
#      CommandLine cmd = parser.parse(options, args);
#      if (cmd.hasOption("help")) {
#        new HelpFormatter().printHelp("tika-server", options, true);
#        return;
#      }
#      String host = cmd.getOptionValue("host", "localhost");
#      int port = Integer.parseInt(cmd.getOptionValue("port", "9998"));
#      String[] remaining = cmd.getArgs();
#    } catch (ParseException e) {
#      System.err.println("Parse error: " + e.getMessage());
#    }
#
#  Apache Commons CLI distinctive features:
#    - IMPERATIVE Options BUILDER — `Options options = new Options();
#      options.addOption(SHORT, LONG, HAS_ARG, DESC)` instead of
#      annotation-based declaration
#    - `addOption(opt, longOpt, hasArg, description)` four-arg form —
#      short name, long name, takes-value boolean, description
#    - `Option.builder("opt").longOpt("name").hasArg().argName("FILE")
#      .required().desc("...").build()` fluent builder for complex options
#    - PARSER variants: `DefaultParser` (current, POSIX+GNU), `PosixParser`
#      (deprecated, POSIX), `GnuParser` (deprecated, GNU long-opts),
#      `BasicParser` (deprecated, simple)
#    - `parser.parse(options, args)` — RETURNS `CommandLine` result; throws
#      `ParseException` on errors (NOT exit-on-error like clap)
#    - RESULT API: `cmd.hasOption(NAME)` — boolean check; `cmd.getOptionValue(NAME)`
#      — single value; `cmd.getOptionValues(NAME)` — multi-value array;
#      `cmd.getArgs()` — remaining positional args; `cmd.getOptions()` —
#      all parsed Option objects; `cmd.getOptionProperties(NAME)` —
#      Properties object for -DKEY=VALUE style options
#    - `OptionGroup` — mutually exclusive options group
#    - `HelpFormatter` — separate class for help generation: `new
#      HelpFormatter().printHelp(USAGE, OPTIONS)` or the new builder API
#      `HelpFormatter.builder().get().printHelp(...)`
#    - REQUIRED options enforced via `Option.builder().required()` or
#      `option.setRequired(true)` — ParseException thrown if missing
#    - VALUE SEPARATORS via `Option.builder().valueSeparator('=')` for
#      -DKEY=VALUE style options
#    - MULTIPLE VALUES via `Option.builder().numberOfArgs(N)` or `.hasArgs()`
#      for unlimited multi-value options
#    - TYPE CONVERSION via `Option.builder().type(Number.class)` and
#      `cmd.getParsedOptionValue(NAME)` (return type Object) — minimal
#      built-in type coercion compared to picocli
#    - SHORT OPTIONS use SINGLE DASH (POSIX) — `-h`, `-p 9998`
#    - LONG OPTIONS use DOUBLE DASH — `--host`, `--port=9998` or
#      `--port 9998`
#    - NO auto-generated subcommand support — applications hand-roll
#      subcommand dispatch (positional arg switching)
#    - NO auto-color/auto-pager — plain text output only
#    - PARSE EXCEPTION model — NO process exit; caller catches
#      ParseException and handles error reporting
#  Distinct from R277 Java picocli (annotation-driven with `@Command`,
#  `@Option`, `@Parameters`, auto-colored ANSI help, built-in
#  subcommand support, autocompletion script generation), R299 Java
#  args4j (annotation-driven with `@Option` field annotations, simpler
#  than picocli), R322 Java JCommander (annotation-driven `@Parameter`,
#  reflection-based binding to instance fields, JUnit-style design),
#  R353 Java rvesse/airline (annotation-driven Cliff-Beam-like
#  hierarchical commands), R275 Rust clap-derive (struct + Rust attributes),
#  R343 commander.js (JS fluent builder).  Apache Commons CLI's approach:
#  IMPERATIVE BUILDER + PARSE EXCEPTION MODEL + NO ANNOTATIONS + NO
#  AUTO-COLOR + NO BUILT-IN SUBCOMMANDS + STABLE-FOR-22-YEARS — corpus's
#  **first documented imperative-Options-builder-for-Java CLI pattern**.
#  Brings cross-language CLI library taxonomy variant count to 110;
#  Java ecosystem now has 5 documented CLI libraries.
#
#  Surface (verbatim from TikaServerCli.java + TikaServerProcess.java
#  Options.addOption calls):
#
#  Options:
#    -h, --host HOST              Host name (default = localhost,
#                                 use `*` for all interfaces)
#    -p, --port PORT              Listen port (default = 9998)
#    -?, --help                   Show help message and exit
#    -c, --config FILE            Tika config XML file (overrides default)
#    -a, --pluginsConfig FILE     Tika pipes plugins config (JSON)
#    -i, --id ID                  Server ID for status endpoint + logging
#
#  Process options (when forked):
#    --noFork                     Run without forking (single process mode)
#    --forkedStatusFile FILE      Status file for forked process
#                                 (Not allowed with -noFork)
#    --tmpFilePrefix PREFIX       Tmp file prefix for debugging
#                                 (Not allowed with -noFork)
#    --numRestarts N              Restart counter for forked server
#                                 (Not allowed with -noFork)
#
#  Endpoints exposed when running:
#    POST /tika                   Extract text from uploaded document
#    POST /meta                   Extract metadata
#    POST /rmeta                  Recursive metadata (containers)
#    POST /detect/stream          Detect MIME type from stream
#    POST /language/stream        Detect language
#    POST /translate/all/SRC/DST  Translate text
#    GET  /status                 Server status JSON
#    GET  /version                Tika version
#    GET  /                       HTML index page
#
#  Dup-skipped neighbors during hunt (in corpus, also commons-cli-based,
#  already documented):
#    - hadoop (Apache Hadoop — IN CORPUS via _hadoop)
#    - mvn / mvnw (Apache Maven — IN CORPUS via _mvn)
#    - pig (Apache Pig — IN CORPUS via _pig)
#    - hbase (Apache HBase — IN CORPUS via _hbase)
#    - storm (Apache Storm — IN CORPUS via _storm)
#    - flink (Apache Flink — IN CORPUS via _flink)
#    - druid (Apache Druid — IN CORPUS via _druid)
#    - oozie (Apache Oozie — IN CORPUS via _oozie)
#    - sqoop (Apache Sqoop — IN CORPUS via _sqoop)
#    - tika (tika-app, Tika CLI — IN CORPUS via _tika)
# ============================================================================

_tika-server() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --host)'{-h,--host}'=[host name (default localhost, * for all)]:host:_hosts' \
    '(-p --port)'{-p,--port}'=[listen port (default 9998)]:port' \
    '(-? --help)'{-\?,--help}'[show help message and exit]' \
    '(-c --config)'{-c,--config}'=[Tika config XML file]:file:_files -g "*.xml"' \
    '(-a --pluginsConfig)'{-a,--pluginsConfig}'=[Tika pipes plugins config JSON]:file:_files -g "*.json"' \
    '(-i --id)'{-i,--id}'=[server ID for status endpoint + logging]:id' \
    '--noFork[run without forking (single-process mode)]' \
    '--forkedStatusFile=[status file for forked process]:file:_files' \
    '--tmpFilePrefix=[tmp file prefix for debugging]:prefix' \
    '--numRestarts=[restart counter for forked server]:n'
}

_tika-server "$@"
