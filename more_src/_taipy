#compdef taipy

_taipy() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_taipy_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                create)
                    _arguments \
                        '--template[application template]:template:(default multi-page multi-page-with-navbar)' \
                        '--name[application name]:name:' \
                        '--path[destination path]:path:_directories' \
                        '(- *)'{-h,--help}'[show help]' && ret=0
                    ;;
                run)
                    _arguments \
                        '--host[host to bind to]:host:_hosts' \
                        '--port[port to listen on]:port:' \
                        '--debug[enable debug mode]' \
                        '--no-reloader[disable auto-reloader]' \
                        '(- *)'{-h,--help}'[show help]' && ret=0
                    ;;
                help)
                    _arguments '1: :_taipy_commands' && ret=0
                    ;;
                version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_taipy_commands] )) ||
_taipy_commands() {
    local -a commands
    commands=(
        'create:create a new Taipy application from a template'
        'run:run a Taipy application'
        'help:show help for a command'
        'version:show Taipy version'
    )
    _describe -t commands 'taipy command' commands
}

_taipy "$@"
