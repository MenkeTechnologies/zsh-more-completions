#compdef notmuch

# completions for notmuch email indexer and searcher

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config=[configuration file]:file:_files' \
  '--database=[database path]:path:_directories' \
  '--uuid=[expected database UUID]:uuid' \
  '*::args:->subcmds' && ret=0

case $state in
  subcmds)
    local -a commands
    commands=(
      'address:output addresses from matching messages'
      'compact:compact the notmuch database'
      'config:access notmuch configuration'
      'count:count matching messages or threads'
      'dump:dump tags to a file'
      'insert:add a message to the maildir and tag it'
      'new:incorporate new mail into the database'
      'reindex:re-index matching messages'
      'reply:construct a reply template'
      'restore:restore tags from a dump file'
      'search:search for matching messages'
      'setup:interactively set up notmuch'
      'show:show messages matching a search term'
      'tag:add/remove tags on matching messages'
    )
    _describe -t commands 'notmuch command' commands && ret=0
    ;;
esac

return ret
