#compdef mem0-cli
# Documentation: https://github.com/mem0ai/mem0/tree/main/cli/python
# Reference accessed: 2026-05-23
# Verified: mem0 CLI Typer app (see also _mem0).

# Zsh completion for mem0-cli - Mem0 memory layer CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--api-key[Mem0 API key]:key:' \
  '--base-url[API base URL]:url:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'mem0 command' \
      'add[add memory]' \
      'search[search memories]' \
      'get[get memory by id]' \
      'list[list memories]' \
      'update[update memory]' \
      'delete[delete memory]' \
      'init[initialize project]' \
      'identify[identify user]' \
      'whoami[show current user]' \
      'status[show status]' \
      'import[import data]' \
      'config[manage configuration]' \
      'entity[manage entities]' \
      'event[inspect background events]' \
      'agent-rush[agent rush commands]' \
      'help[show help]' && ret=0
    ;;
esac

return ret
