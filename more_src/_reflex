#compdef reflex

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help]'
  {-c,--config}'[config file]:file:_files'
  {-d,--decoration}'[decoration style]:style:(none plain fancy)'
  {-g,--glob}'[glob pattern to match]:pattern:'
  {-G,--inverse-glob}'[glob pattern to exclude]:pattern:'
  {-r,--regex}'[regex pattern to match]:pattern:'
  {-R,--inverse-regex}'[regex pattern to exclude]:pattern:'
  {-s,--start-service}'[start command as a long-running service]'
  {-t,--sequential}'[do not run multiple instances in parallel]'
  {-v,--verbose}'[verbose output]'
  '--only[only react to specific event types]:types:(modified created deleted renamed)'
  '*:command:'
)

_arguments -s -S $arguments
