#compdef reflex
# Documentation: https://github.com/cespare/reflex
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above.
# Removed from prior file: fabricated --only flag with bogus enum
# (modified/created/deleted/renamed). Fixed --sequential short form
# from -t to -e. Added missing --all, --only-dirs, --only-files,
# --shutdown-timeout (-t), --substitute.

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help]'
  '--all[include normally ignored files]'
  {-c,--config}'[config file]:file:_files'
  {-d,--decoration}'[decoration style]:style:(none plain fancy)'
  '*'{-g,--glob}'[glob pattern to match]:pattern:'
  '*'{-G,--inverse-glob}'[glob pattern to exclude]:pattern:'
  '*'{-r,--regex}'[regex pattern to match]:pattern:'
  '*'{-R,--inverse-regex}'[regex pattern to exclude]:pattern:'
  '--only-dirs[match only directories]'
  '--only-files[match only files]'
  {-s,--start-service}'[start command as a long-running service]'
  {-e,--sequential}'[do not run multiple instances in parallel]'
  {-t,--shutdown-timeout}'[service shutdown grace period]:duration:'
  '--substitute[replacement symbol in commands]:symbol:'
  {-v,--verbose}'[verbose output]'
  '*:command:'
)

_arguments -s -S $arguments
