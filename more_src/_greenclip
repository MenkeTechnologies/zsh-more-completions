#compdef greenclip
# _greenclip — erebe/greenclip (Haskell clipboard manager for X11; daemon runs in the background watching the X selection, print dumps history (newline-separated), clear empties it, version prints version; commonly piped into rofi -dmenu)
# upstream: https://github.com/erebe/greenclip
# Subcommands from greenclip src/Main.hs on tip.

_greenclip() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '1:command:(daemon print clear version)'
}

_greenclip "$@"
