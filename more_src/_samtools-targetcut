#compdef samtools-targetcut
# Documentation: http://www.htslib.org/doc/samtools-targetcut.html
# samtools targetcut: Identify target regions by examining the continuity of read depth

local ret=1

_arguments -s -S \
  '(-Q)'-Q'[Ignore bases with quality less than minBaseQ .]:minBaseQ: ' \
  '(-i)'-i'[Penalty for in state transition.]:inPenalty: ' \
  '(-0)'-0'[Emission score 0.]:em0: ' \
  '(-1)'-1'[Emission score 1.]:em1: ' \
  '(-2)'-2'[Emission score 2.]:em2: ' \
  '(-f)'-f'[Reference FASTA file.]:ref: ' \
  '*:file:_files' && ret=0

return ret
