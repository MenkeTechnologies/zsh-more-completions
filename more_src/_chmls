#compdef chmls
# Documentation: chmls --help (Free Pascal CHM utility 2010)
# Source: list / extract / unblock Windows HTML Help (CHM) archives.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'list:show archive directory contents'
    'extract:extract a named file from archive'
    'extractall:extract every file to a directory'
    'unblockchm:mass-unblock CHM (NTFS XPsp2+ zone)'
    'extractalias:extract context info to .h/.ali files'
)

_arguments -C -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-p --no-page)'{-p,--no-page}'[do not page list output]' \
    '--no-offset[hide offset column in list]' \
    '(-n --name-only)'{-n,--name-only}'[only show name column]' \
    '1:command:->verbs' \
    '*::args:_files' \
    && ret=0

case $state in
    verbs) _describe -t verbs command verbs && ret=0 ;;
esac

return ret
