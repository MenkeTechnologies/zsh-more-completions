#compdef pfsrotate
# Documentation: http://pfstools.sourceforge.net/man1/pfsrotate.1.html
# pfstools: rotate frames in a pfs stream by 90 degrees

local ret=1

_arguments -s -S \
  '-r[rotate counter-clockwise instead of clockwise]' \
  '--help[print list of command line options]' && ret=0

return ret
