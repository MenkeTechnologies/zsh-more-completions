#compdef rekall
# Documentation: https://man.archlinux.org/search?q=rekall
# Reference accessed: 2026-05-16

# Rekall: forensic memory analysis framework (DFIR)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a plugins=(
  'imageinfo:show memory image info'
  'pslist:list processes'
  'pstree:print process tree'
  'psscan:scan for hidden processes'
  'dlllist:list loaded DLLs'
  'handles:list handles'
  'cmdscan:scan command history'
  'consoles:console buffer'
  'memmap:map of process memory'
  'memdump:dump process memory'
  'malfind:find injected code'
  'shimcache:show shimcache'
  'svcscan:scan services'
  'netscan:scan network connections'
  'connections:active connections'
  'sockets:open sockets'
  'driverscan:scan kernel drivers'
  'mftparser:parse $MFT'
  'mbrparser:parse MBR'
  'shell:rekall shell'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-f[memory image file]:file:_files' \
  '--filename=[memory image file]:file:_files' \
  '--profile=[memory profile (e.g. Win10x64_19041)]:profile:' \
  '--dtb=[directory table base (hex)]:hex:' \
  '--cache_dir=[cache directory]:dir:_files -/' \
  '--logfile=[log file]:file:_files' \
  '--log_level=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--no-colors[disable colors]' \
  '--output=[output file]:file:_files' \
  '--format=[output format]:fmt:(text json yaml csv)' \
  '--paging=[paging in terminal]:bool:(true false)' \
  '--debug[debug mode]' \
  '1: :->plugin' \
  '*::arg:->args' && ret=0
case $state in
  plugin) _describe -t plugins 'rekall plugin' plugins && ret=0 ;;
esac
return ret
