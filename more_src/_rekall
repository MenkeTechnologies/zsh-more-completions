#compdef rekall rekal
# Documentation: https://manned.org/rekal/97c60251
# Reference accessed: 2026-05-20
# Verified: upstream rekal(1) manpage at the URL above.
# Removed from prior file: invented --profile/--logfile/--log_level/
# --no-colors/--paging top-level flags. Replaced with documented
# --logging_level/--colors/--paging_limit. The `profile` is selected
# per-plugin or via --autodetect, not as a top-level flag.

# Rekall: forensic memory analysis framework (DFIR)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a plugins=(
  'imageinfo:show memory image info'
  'pslist:list processes'
  'pstree:print process tree'
  'psscan:scan for hidden processes'
  'dlllist:list loaded DLLs'
  'handles:list handles'
  'cmdscan:scan command history'
  'consoles:console buffer'
  'memmap:map of process memory'
  'memdump:dump process memory'
  'malfind:find injected code'
  'shimcache:show shimcache'
  'svcscan:scan services'
  'netscan:scan network connections'
  'connections:active connections'
  'sockets:open sockets'
  'driverscan:scan kernel drivers'
  'mftparser:parse $MFT'
  'mbrparser:parse MBR'
  'shell:rekall shell'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[debug-level logging]' \
  '(-q --quiet)'{-q,--quiet}'[turn off logging to stderr]' \
  '--debug[break into debugger on error]' \
  '(-f --filename)'{-f+,--filename=}'[raw image file]:file:_files' \
  '--dtb=[DTB physical address]:hex:' \
  '--cache_dir=[profile cache directory]:dir:_directories' \
  '--cache=[cache type]:type:' \
  '*--repository_path=[profile search path]:dir:_directories' \
  '--logging_format=[logging format string]:format:' \
  '--logging_level=[logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--colors=[color output]:mode:(auto yes no)' \
  '--output=[output file]:file:_files' \
  '(-F --format)'{-F+,--format=}'[output format]:fmt:' \
  '--pager=[pager program]:pager:' \
  '--paging_limit=[lines before invoking pager]:lines:' \
  '--performance=[algorithm tuning]:mode:(normal fast thorough)' \
  '--output_style=[output verbosity]:style:(concise full)' \
  '--timezone=[output timezone]:tz:' \
  '(-o --file_offset)'{-o+,--file_offset=}'[image offset]:offset:' \
  '--buffer_size=[max read buffer size]:bytes:' \
  '--home=[alternative home directory]:dir:_directories' \
  '*--plugin=[load user plugin]:plugin:' \
  '*--pagefile=[pagefile to load]:file:_files' \
  '--live=[live memory analysis]:mode:' \
  '--autodetect=[autodetect method]:method:' \
  '--autodetect_threshold=[match threshold]:n:' \
  '--autodetect_build_local=[local profile building]:mode:(full basic none)' \
  '--autodetect_scan_length=[memory scan length]:bytes:' \
  '1: :->plugin' \
  '*::arg:->args' && ret=0
case $state in
  plugin) _describe -t plugins 'rekall plugin' plugins && ret=0 ;;
esac
return ret
