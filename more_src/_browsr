#compdef browsr
# browsr — file explorer TUI for local and cloud filesystems (Python/Textual)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-t --theme)'{-t,--theme}'[set application theme]:theme:(dark light)' \
  '--max-file-size=[maximum file size to render in bytes]:bytes:' \
  '--max-lines=[maximum lines to render]:lines:' \
  '*:path or URI:_files'
