#compdef arping-tool
# _arping-tool — Arping helper wrapper (custom wrapper around arping(8) seen in some distros that auto-detects the system's arping flavour (Linux iputils vs Thomas Habets) and forwards flags; -c count, -i interface, -D duplicate-detection, -U unsolicited (gratuitous), -b broadcast, -f finish on first reply, -q quiet, -A use ARP request type 2; positional target host)
# upstream: distro-shipped (Linux iputils + Thomas Habets arping)
# Flags from iputils arping.c + habets arping/arping.c on tip.

_arping-tool() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[count]:n:' \
        '-i+[interface]:interface:_net_interfaces' \
        '-I+[interface]:interface:_net_interfaces' \
        '-D[duplicate-detection]' \
        '-U[unsolicited gratuitous]' \
        '-A[reverse ARP request]' \
        '-b[broadcast]' \
        '-f[exit on first reply]' \
        '-q[quiet]' \
        '-w+[timeout seconds]:seconds:' \
        '-s+[source ip]:ip:' \
        '-S+[source mac]:mac:' \
        '1:target:_hosts'
}

_arping-tool "$@"
