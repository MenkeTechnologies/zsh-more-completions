#compdef passivedns
# Documentation: https://github.com/gamelinux/passivedns/blob/master/README
# Network sniffer that logs DNS server replies for a passive DNS setup

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-i+[network device to sniff on]:interface:_net_interfaces' \
  '-H+[hostname to print in record]:hostname:_hosts' \
  '-r+[read pcap file]:pcap file:_files' \
  '-q[quiet mode]' \
  '-c+[set PF_RING cluster_id]:cluster id:' \
  '-n[use PF_RING]' \
  '-y[log to syslog using local7 facility]' \
  '-Y[log NXDOMAIN to syslog]' \
  '-N[set interface to non-promiscuous mode]' \
  '-j[use JSON as output in log file]' \
  '-J[use JSON as output in NXDOMAIN log file]' \
  '-l+[logfile for normal queries]:logfile:_files' \
  '-s+[print stats on SIGUSR1 to file]:stats file:_files' \
  '-L+[logfile for SRC error queries]:logfile:_files' \
  '-d+[delimiter between fields in log file]:delimiter:' \
  '-b+[Berkeley packet filter]:filter:' \
  '-D[run as daemon]' \
  '-p+[name of pid file]:pidfile:_files' \
  '-C+[seconds to cache DNS objects in memory]:seconds:' \
  '-P+[seconds between printing duplicate DNS info]:seconds:' \
  '-S+[soft memory limit in MB]:megabytes:' \
  '-f+[choose which fields to print]:fields:' \
  '-X+[manually set DNS RR types to care about]:flags:' \
  '-u+[user ID to drop privileges to]:user:_users' \
  '-g+[group ID to drop privileges to]:group:_groups' \
  '-T+[directory to chroot into]:dir:_files -/' \
  '-V[show version and exit]' \
  '*:pcap file:_files' && ret=0

return ret
