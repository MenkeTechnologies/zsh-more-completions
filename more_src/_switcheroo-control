#compdef switcheroo-control
# _switcheroo-control — D-Bus daemon to select discrete vs integrated GPU (hadess/switcheroo-control)
# upstream: https://gitlab.freedesktop.org/hadess/switcheroo-control
# Flags from src/switcheroo-control.c (GOptionEntry options[]).

_switcheroo-control() {
    _arguments \
        '(-v --verbose)'{-v,--verbose}'[show extra debugging information]' \
        '(-f --fake)'{-f,--fake}'[add fake GPUs to the output]' \
        '(-r --replace)'{-r,--replace}'[replace the running instance of switcheroo-control]'
}

_switcheroo-control "$@"
