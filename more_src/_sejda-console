#compdef sejda-console
# Documentation: https://github.com/torakiki/sejda/wiki/Tasks
# sejda-console - command-line PDF manipulation (merge, split, rotate, encrypt)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --files)'{-f,--files}'=[input PDF files]:files:_files -g "*.pdf"' \
  '(-o --output)'{-o,--output}'=[output file or directory]:output:_files' \
  '--overwrite[overwrite existing output files]' \
  '*::task:->tasks' && ret=0

case $state in
  tasks)
    local -a tasks
    tasks=(
      'split:split a PDF at a set of page numbers'
      'simplesplit:split a PDF at predefined page sets'
      'splitbysize:split a PDF by output file size'
      'splitbyevery:split a PDF every N pages'
      'splitbybookmarks:split a PDF by bookmark level'
      'merge:merge multiple PDF documents'
      'alternatemix:interleave pages from two documents'
      'extractpages:extract a selection of pages'
      'rotate:rotate pages of a PDF'
      'setviewerpreferences:set viewer preferences'
      'setpagelabels:apply page labels'
      'setmetadata:set document metadata'
      'setpagetransitions:set page transitions'
      'unpackattachments:extract embedded attachments'
      'pdftosingletiff:convert PDF to a single TIFF'
      'pdftomultipletiff:convert PDF to multiple TIFFs'
      'pdftojpeg:convert PDF pages to JPEG'
      'extractbybookmarks:extract pages by bookmarks'
      'encrypt:encrypt PDF documents'
      'decrypt:decrypt PDF documents'
    )
    _describe -t tasks 'sejda task' tasks && ret=0
    ;;
esac

return ret
