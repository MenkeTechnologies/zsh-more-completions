#compdef xbps xbps-cli
# _xbps — Void Linux XBPS package management suite top-level alias (Juan RP / Void Linux, C); custom argparse
# upstream: https://github.com/void-linux/xbps

_xbps() {
    local -a sub=(
        'install:install packages'
        'remove:remove packages'
        'update:update package lists'
        'upgrade:upgrade installed packages'
        'query:query metadata for installed packages'
        'rindex:create/modify repository index'
        'pkgdb:check package database'
        'reconfigure:reconfigure pending packages'
        'fetch:download a file (low-level)'
        'create:create a binary package'
        'alternatives:list/set alternatives'
        'checkvers:check installed versions vs repo'
        'dgraph:generate dependency graph'
        'digest:show digests of files'
        'fbulk:bulk build'
        'src:source utilities'
        'uchroot:enter chroot helper'
        'uhelper:userland helper'
        'uunshare:unshare helper'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--rootdir=+[root dir]:dir:_files -/' \
        '-r+[root dir]:dir:_files -/' \
        '--repository=+[repository]:list:_urls' \
        '-R+[repository]:list:_urls' \
        '--cachedir=+[cache dir]:dir:_files -/' \
        '-c+[cache dir]:dir:_files -/' \
        '--syslog[syslog]' \
        '-S[syslog]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--force[force]' \
        '-f[force]' \
        '--ignore-conf-repos[ignore conf repos]' \
        '-i[ignore conf repos]' \
        '--no-checks[no checks]' \
        '-n[no checks]' \
        '--yes[assume yes]' \
        '-y[assume yes]' \
        '--memory-sync[memory sync]' \
        '-M[memory sync]' \
        '--repository-cache=+[repository cache]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '-C+[config file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xbps subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|query|update|upgrade|reconfigure|fetch|create) _arguments '*:package:' ;;
            esac
            ;;
    esac
}

_xbps "$@"
