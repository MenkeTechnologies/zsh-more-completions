autoload -U is-at-least

_releaser() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_releaser_commands" \
"*::: :->releaser" \
&& ret=0
    case $state in
    (releaser)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:releaser-command-$line[1]:"
        case $line[1] in
            (w)
_arguments "${_arguments_options[@]}" : \
'-d+[Delay in seconds between publish next workflow'\''s crate]:NUMBER:_default' \
'--delay=[Delay in seconds between publish next workflow'\''s crate]:NUMBER:_default' \
'-a[Whether to add option --all-features to cargo publish command]' \
'--all[Whether to add option --all-features to cargo publish command]' \
'-n[Whether to add option --no-verify to cargo publish command]' \
'--noverify[Whether to add option --no-verify to cargo publish command]' \
'--nopublish[Dont publish crate. Just change version, commit, add tag and push changes]' \
'-h[Print help]' \
'--help[Print help]' \
':INCR -- Version increment. One of the following\: major, minor or patch:(major minor patch)' \
':PATH -- Sets workspace root path:_default' \
&& ret=0
;;
(c)
_arguments "${_arguments_options[@]}" : \
'-a[Whether to add option --all-features to cargo publish command]' \
'--all[Whether to add option --all-features to cargo publish command]' \
'-n[Whether to add option --no-verify to cargo publish command]' \
'--noverify[Whether to add option --no-verify to cargo publish command]' \
'--nopublish[Dont publish crate. Just change version, commit, add tag and push changes]' \
'-h[Print help]' \
'--help[Print help]' \
':INCR -- Version increment. One of the following\: major, minor or patch:(major minor patch)' \
':PATH -- Sets crate'\''s root path:_default' \
&& ret=0
;;
(b)
_arguments "${_arguments_options[@]}" : \
'-c+[Sets crate'\''s path where Cargo.toml located]:PATH:_default' \
'--crate=[Sets crate'\''s path where Cargo.toml located]:PATH:_default' \
'-l+[Sets Linux package directory path]:PATH:_default' \
'--linux=[Sets Linux package directory path]:PATH:_default' \
'-m+[Sets Mac OS x64-86 package directory path]:PATH:_default' \
'--macos=[Sets Mac OS x64-86 package directory path]:PATH:_default' \
'-a+[Sets Mac OS ARM64 package directory path]:PATH:_default' \
'--macosarm=[Sets Mac OS ARM64 package directory path]:PATH:_default' \
'-b+[Base URI of downloaded artifacts]:URI:_default' \
'--base=[Base URI of downloaded artifacts]:URI:_default' \
'-u+[File path to save result to. If not set result will be written into stdout]::PATH:_default' \
'--output=[File path to save result to. If not set result will be written into stdout]::PATH:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(s)
_arguments "${_arguments_options[@]}" : \
'-c+[Sets crate'\''s path where Cargo.toml located]:PATH:_default' \
'--crate=[Sets crate'\''s path where Cargo.toml located]:PATH:_default' \
'-i+[Sets 64-bit binary package directory path]:PATH:_default' \
'--binary=[Sets 64-bit binary package directory path]:PATH:_default' \
'-e+[Sets Windows executable name]:FILE:_default' \
'--exe=[Sets Windows executable name]:FILE:_default' \
'-b+[Base URI of downloaded artifacts]:URI:_default' \
'--base=[Base URI of downloaded artifacts]:URI:_default' \
'-u+[File path to save result to. If not set result will be written into stdout]::PATH:_default' \
'--output=[File path to save result to. If not set result will be written into stdout]::PATH:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':generator:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(bugreport)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_releaser__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:releaser-help-command-$line[1]:"
        case $line[1] in
            (w)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(c)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(b)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(s)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(bugreport)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_releaser_commands] )) ||
_releaser_commands() {
    local commands; commands=(
'w:Release workspace specified by path' \
'c:Release single crate specified by path' \
'b:Create brew package manager Formula (package definition file) to publish it into a tap (MacOS and Linux only)' \
's:Create scoop package manager JSON (package definition file) to publish it into bucket (Windows only)' \
'completion:Generate the autocompletion script for the specified shell' \
'bugreport:Collect information about the system and the environment that users can send along with a bug report' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'releaser commands' commands "$@"
}
