#compdef mkdir-cli
# _mkdir-cli — GNU coreutils mkdir make directories CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_mkdir-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-m+[mode]:str:' \
        '--mode=+[mode]:str:' \
        '-p[create parents]' \
        '--parents[create parents]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-Z[set SELinux context]' \
        '--context=+[ctx]:str:' \
        '*:directories:_files -/'
}

_mkdir-cli "$@"
