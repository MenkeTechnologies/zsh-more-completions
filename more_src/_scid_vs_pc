#compdef scid_vs_pc
# Documentation: https://scidvspc.sourceforge.net/
# Reference accessed: 2026-05-21
# Verified: upstream site documents only -nodock (disable docking on
# startup); otherwise accepts positional database/PGN/EPD files.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-nodock[start without docked windows]' \
  '*:database / PGN / EPD / FEN:_files -g "*.(si4|si3|pgn|epd|fen|pdn)"' && ret=0

return ret
