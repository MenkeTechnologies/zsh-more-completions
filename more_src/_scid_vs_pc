#compdef scid_vs_pc
# Documentation: https://man.archlinux.org/search?q=scid_vs_pc
# Reference accessed: 2026-05-16

# Scid vs. PC: Tcl/Tk chess database browser
local curcontext="$curcontext" ret=1

_arguments -C \
  '*:database / PGN / EPD / FEN:_files -g "*.(si4|si3|pgn|epd|fen|pdn)"' && ret=0

return ret
