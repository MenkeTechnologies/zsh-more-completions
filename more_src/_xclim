#compdef xclim
# Documentation: https://xclim.readthedocs.io/en/stable/notebooks/cli.html
# xclim - climate indicator computation command line tool

local ret=1

_arguments -s -C \
  '(- *)'{-V,--version}'[print version number and exit]' \
  '(- *)--help[show help]' \
  '(-i --input)'{-i,--input}'=[input netCDF path or glob pattern]:input:_files' \
  '(-o --output)'{-o,--output}'=[output filepath]:output:_files' \
  '(-v --verbose)'{-v,--verbose}'[print details about context and progress]' \
  '--dask-nthreads=[threads for dask.distributed Client]:n:' \
  '--dask-maxmem=[memory limit for dask.distributed Client]:mem:' \
  '--chunks=[chunks to use when opening input dataset(s)]:chunks:' \
  '--engine=[engine to use when opening input dataset(s)]:engine:' \
  '1:command:(indices info dataflags release_notes show_version_info)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s \
      '(-r --raise-flags)'{-r,--raise-flags}'[raise exception on quality control issues]' \
      '(-a --append)'{-a,--append}'[append ecad_qc_flag array as a data_var]' \
      '(-d --dims)'{-d,--dims}'=[dimensions upon which aggregation is performed]:dims:' \
      '(-f --freq)'{-f,--freq}'=[resampling periods frequency for aggregation]:freq:' && ret=0
    ;;
esac

return ret
