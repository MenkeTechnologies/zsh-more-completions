#compdef gosmopolitan
# Documentation: https://github.com/xen0n/gosmopolitan
# report i18n/l10n anti-patterns in Go source (singlechecker)

local ret=1

_arguments -s -S \
  '-V[print version and exit]' \
  '-allowtimelocal[allow time.Local usages]' \
  '-c=[display offending line with this many lines of context]:n:' \
  '-cpuprofile=[write CPU profile to file]:file:_files' \
  '-debug=[debug flags, any subset of fpstv]:flags:' \
  '-escapehatches=[comma-separated fully qualified names acting as i18n escape hatches]:names:' \
  '-flags[print analyzer flags in JSON]' \
  '-json[emit JSON output]' \
  '-lookattests[also check test files]' \
  '-memprofile=[write memory profile to file]:file:_files' \
  '-trace=[write trace log to file]:file:_files' \
  '-watchforscripts=[comma-separated Unicode scripts to watch for in string literals]:scripts:' \
  '*:packages:_files' && ret=0

return ret
