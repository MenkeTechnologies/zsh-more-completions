#compdef sloccount

# Zsh completion for sloccount (Source Lines of Code counter)

_arguments -s \
  '--duplicates[count duplicate files]' \
  '--crossdups[count cross-project duplicate files]' \
  '--autogen[count automatically generated files]' \
  '--multiproject[treat as multiple projects]' \
  '--filecount[show file counts instead of SLOC]' \
  '--details[show details for each source file]' \
  '--wide[show wide output format]' \
  '--follow[follow symbolic links]' \
  '*--addlang[add language to count]:language' \
  '--addlangall[add all known languages]' \
  '--append[append to existing data]' \
  '--datadir[data directory for cached results]:directory:_files -/' \
  '--cached[use cached data only]' \
  '--uncached[ignore cached data]' \
  '--effort[override effort estimation in person-months]:months' \
  '--schedule[override schedule estimation in months]:months' \
  '--personcost[override person-cost in dollars]:dollars' \
  '--overhead[override overhead ratio]:ratio' \
  '*:directories:_files -/'
