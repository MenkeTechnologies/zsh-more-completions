#compdef cerbos
# Documentation: https://docs.cerbos.dev/cerbos/latest/cli/cerbos.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cerbos: policy decision point (PDP) CLI
local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config=[config file]:file:_files -g "*.(yaml|yml)"' \
  '*--set=[runtime config override]:key=value:' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      'compile:validate and test policy definitions'
      'server:start the Cerbos PDP server'
      'healthcheck:check a running PDP instance'
      'run:run a command with a Cerbos PDP attached'
      'repl:interactive REPL for evaluating CEL conditions'
    )
    _describe -t commands 'cerbos command' cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
