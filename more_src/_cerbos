#compdef cerbos

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --verbose)'{-v,--verbose}'[Verbose logs]' \
  '--log-level=[Log level]:level:(debug info warn error)' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      compile:'compile policies'
      server:'run Cerbos PDP server'
      healthcheck:'check server health'
      hub:'Cerbos Hub commands'
      run:'run policy tests'
      repl:'policy REPL'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
