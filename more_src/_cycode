#compdef cycode
# Documentation: https://github.com/cycodehq/cycode-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'auth:authenticate machine with Cycode account'
  'configure:initial CLI client authentication setup'
  'ignore:exclude values, paths, or rule IDs from scan'
  'mcp:start Model Context Protocol server'
  'scan:run security scans (secrets, IaC, SCA, SAST)'
  'report:generate reports such as SBOM'
  'status:show CLI status and exit'
  'platform:access Cycode platform read APIs (beta)'
  'import:import SBOM files into Cycode'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable detailed logging]' \
  '(-o --output)'{-o,--output}'=[output format]:format:(rich text json table)' \
  '--client-id=[Cycode client ID]:id:' \
  '--client-secret=[client secret]:secret:' \
  '--id-token=[OIDC ID token]:token:' \
  '--no-progress-meter[suppress progress display]' \
  '--no-update-notifier[skip update checks]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'cycode subcommand' subcommands && ret=0
    ;;
esac

return ret
