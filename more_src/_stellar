#compdef stellar
# Documentation: https://man.archlinux.org/search?q=stellar
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'completion:generate shell completion'
  'contract:smart contract operations'
  'env:print env variables'
  'events:fetch contract events'
  'keys:manage keypairs and identities'
  'network:network configuration'
  'snapshot:create stellar-core snapshot'
  'tx:transaction operations'
  'xdr:XDR utilities'
  'cache:CLI cache utilities'
  'version:print version'
  'plugin:manage plugins'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--global[use global config]' \
  '--config-dir=[config directory]:dir:_files -/' \
  '--quiet[quiet output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--very-verbose[very verbose output]' \
  '--list[list installed plugins]' \
  '--no-cache[disable cache]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'stellar command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (contract) _values 'subcommand' 'asset' 'bindings' 'build' 'extend' 'deploy' 'fetch' 'init' 'inspect' 'install' 'invoke' 'optimize' 'read' 'restore' 'upload' 'id' 'info' 'alias' && ret=0 ;;
      (keys) _values 'subcommand' 'add' 'address' 'fund' 'generate' 'ls' 'rm' 'show' 'use' 'public-key' 'secret' && ret=0 ;;
      (network) _values 'subcommand' 'add' 'container' 'ls' 'rm' 'use' 'start' 'stop' 'health' && ret=0 ;;
      (tx) _values 'subcommand' 'new' 'sign' 'send' 'simulate' 'op' 'edit' 'fetch' 'hash' 'help' 'decode' 'encode' && ret=0 ;;
      (xdr) _values 'subcommand' 'compare' 'decode' 'encode' 'guess' 'types' 'version' && ret=0 ;;
      (cache) _values 'subcommand' 'actionlog' 'clean' 'path' && ret=0 ;;
    esac ;;
esac

return ret
