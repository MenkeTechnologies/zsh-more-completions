#compdef stellar
# Documentation: https://github.com/stellar/stellar-cli/blob/main/FULL_HELP_DOCS.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'contract:tools for smart contract developers'
  'doctor:diagnose and troubleshoot CLI and network issues'
  'events:watch the network for contract events'
  'env:print environment variables'
  'keys:create and manage identities including keys and addresses'
  'network:configure connection to networks'
  'container:start local networks in containers'
  'config:manage CLI configuration'
  'snapshot:download a snapshot of a ledger from an archive'
  'tx:sign, simulate, and send transactions'
  'xdr:decode and encode XDR'
  'strkey:decode and encode strkey'
  'completion:print shell completion code for the specified shell'
  'cache:cache for transactions and contract specs'
  'version:print version information'
  'plugin:subcommand for CLI plugins'
  'ledger:fetch ledger information'
  'message:sign and verify arbitrary messages using SEP-53'
  'fees:fetch network feestats and configure CLI fee settings'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config-dir=[location of config directory]:dir:_files -/' \
  '(-f --filter-logs)'{-f,--filter-logs}'=[filter logs output]:filter:' \
  '(-q --quiet)'{-q,--quiet}'[do not write logs to stderr including INFO]' \
  '(-v --verbose)'{-v,--verbose}'[log DEBUG events]' \
  '--very-verbose[log DEBUG and TRACE events]' \
  '--no-cache[do not cache simulations and transactions]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'stellar command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (contract) _values 'subcommand' 'asset' 'alias' 'bindings' 'build' 'extend' 'deploy' 'fetch' 'id' 'info' 'init' 'inspect' 'upload' 'install' 'invoke' 'optimize' 'read' 'restore' && ret=0 ;;
      (keys) _values 'subcommand' 'add' 'address' 'fund' 'generate' 'ls' 'rm' 'show' 'use' 'public-key' 'secret' && ret=0 ;;
      (network) _values 'subcommand' 'add' 'ls' 'rm' 'use' 'settings' && ret=0 ;;
      (container) _values 'subcommand' 'start' 'stop' 'logs' 'ls' && ret=0 ;;
      (tx) _values 'subcommand' 'new' 'sign' 'send' 'simulate' 'op' 'edit' 'fetch' 'hash' 'decode' 'encode' 'help' && ret=0 ;;
      (xdr) _values 'subcommand' 'compare' 'decode' 'encode' 'guess' 'types' 'version' && ret=0 ;;
      (cache) _values 'subcommand' 'actionlog' 'clean' 'path' && ret=0 ;;
      (completion) _values 'shell' 'bash' 'zsh' 'fish' 'elvish' 'powershell' && ret=0 ;;
      (fees) _values 'subcommand' 'stats' 'set' 'show' && ret=0 ;;
    esac ;;
esac

return ret
