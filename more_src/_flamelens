#compdef flamelens
# Documentation: https://github.com/YS-L/flamelens
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# flamelens: terminal flamegraph browser (Rust). Accepts folded-stacks via file arg or stdin pipe.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--echo[echo SVG output alongside interactive view]' \
  '--pid=[live flamegraph for running process (requires --features python)]:pid:_pids' \
  '*:folded stacks file:_files' && ret=0

return ret
