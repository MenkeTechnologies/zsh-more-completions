#compdef flamelens
# Documentation: https://man.archlinux.org/search?q=flamelens
# Reference accessed: 2026-05-16

# flamelens — terminal flamegraph browser (Rust). Mirrors common `flamelens --help` options (-i input.folded, --search, theme).

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-i,--input}"=[folded stacks input]:file:_files" \
  '--search=[initial filter substring]:pattern' \
  '--theme=[UI palette]:theme:(dark light system)' \
  '*:folded file:_files' && ret=0

return ret
