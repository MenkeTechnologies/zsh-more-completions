#compdef gmx-density
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-density.html
# gmx density: calculate the density of the system

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-n[index file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-ei[generic data file for electron information]:file:_files' \
  '-o[xvgr/xmgr output file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[frame selection interval]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-d[normal direction]:dir:(X Y Z)' \
  '-sl[number of box slices for binning]:int:' \
  '-dens[density type]:type:(mass number charge electron)' \
  '-ng[number of groups for density calculation]:int:' \
  '-center[bin relative to changing box center]' \
  '-symm[symmetrize density along axis]' && ret=0

return ret
