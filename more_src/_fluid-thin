#compdef fluid-thin thinruntime-controller
# _fluid-thin — Fluid ThinRuntime controller (fluid-cloudnative/fluid)
# upstream: https://github.com/fluid-cloudnative/fluid
# Subcommands + flags from cmd/thin/app/thin.go on tip.

_fluid-thin() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start the ThinRuntime controller'
                version:'print version and exit'
            )
            _describe -t commands 'fluid-thin command' cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '--metrics-addr=[metrics bind address]:host\:port:' \
                        '--enable-leader-election=[enable leader election]:bool:(true false)' \
                        '--leader-election-namespace=[leader-election namespace]:ns:' \
                        '--pprof-addr=[pprof bind address]:host\:port:' \
                        '--development=[enable development mode logging]:bool:(true false)' \
                        '--event-driven=[event-driven reconcile (false = period-driven)]:bool:(true false)' \
                        '--runtime-workers=[max concurrent runtime reconciles]:n:' \
                        '--kube-api-qps=[Kubernetes client QPS]:f:' \
                        '--kube-api-burst=[Kubernetes client burst]:n:' \
                        '--workqueue-default-sync-backoff=[workqueue base backoff]:dur:' \
                        '--workqueue-max-sync-backoff=[workqueue max backoff]:dur:' \
                        '--workqueue-qps=[workqueue QPS]:n:' \
                        '--workqueue-burst=[workqueue burst]:n:'
                    ;;
            esac
            ;;
    esac
}

_fluid-thin "$@"
