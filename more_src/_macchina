#compdef macchina
# Zsh completion for macchina - System information fetcher
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-d --doctor)'{-d,--doctor}'[check for issues with the configuration]' \
  '(-e --export-config)'{-e,--export-config}'[export the default configuration]' \
  '(-l --list-themes)'{-l,--list-themes}'[list available themes]' \
  '(-t --theme)'{-t,--theme}'[specify theme]:theme name:' \
  '(-i --interface)'{-i,--interface}'[specify network interface]:interface name:' \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
  '(-o --show)'{-o,--show}'[show only specified keys]:keys:' \
  '(-s --smallbar)'{-s,--smallbar}'[use small progress bars]' \
  '(-p --padding)'{-p,--padding}'[set padding]:padding:' \
  '(-b --bar)'{-b,--bar}'[use progress bars for percentage values]' \
  '--no-bar-delimiter[remove bar delimiters]' \
  '--no-ascii[disable ASCII art]' \
  '--no-color[disable colors]' \
  '--no-separator[disable separator]' \
  '(-U --current-shell)'{-U,--current-shell}'[show current shell instead of default]' \
  '(-C --long-shell)'{-C,--long-shell}'[show long shell format]' \
  '(-K --long-kernel)'{-K,--long-kernel}'[show long kernel format]' \
  '(-S --long-uptime)'{-S,--long-uptime}'[show long uptime format]' \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' && ret=0
return ret
