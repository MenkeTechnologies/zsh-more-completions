#compdef macchina
# Documentation: https://github.com/Macchina-CLI/macchina/blob/main/doc/macchina.1.scd
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Zsh completion for macchina - system information fetcher

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-d --doctor)'{-d,--doctor}'[check the system for failures]' \
  '(-e --export-config)'{-e,--export-config}'[print a template configuration file]' \
  '(-c --config)'{-c,--config=}'[specify a custom path to configuration file]:config file:_files' \
  '(-l --list-themes)'{-l,--list-themes}'[list available themes]' \
  '(-t --theme)'{-t,--theme=}'[specify theme name]:theme:' \
  '(-i --interface)'{-i,--interface=}'[specify network interface]:interface:' \
  '(-s --current-shell)'{-s,--current-shell}'[toggle current vs default shell]' \
  '(-C --logical-cores)'{-C,--logical-cores}'[toggle logical vs physical cores]' \
  '(-K --long-kernel)'{-K,--long-kernel}'[lengthen kernel output]' \
  '(-S --long-shell)'{-S,--long-shell}'[lengthen shell output]' \
  '(-U --long-uptime)'{-U,--long-uptime}'[lengthen uptime output]' \
  '(-m --memory-percentage)'{-m,--memory-percentage}'[show memory usage in percentage]' \
  '(-D --disks)'{-D,--disks=}'[specify disks for usage display]:disks:' \
  '(-p --disk-space-percentage)'{-p,--disk-space-percentage}'[show disk space usage in percentage]' \
  '(-o --show)'{-o,--show=}'[display only specified readouts]:readouts:(Host Machine Kernel Distribution OperatingSystem DesktopEnvironment WindowManager Packages Shell Terminal LocalIP Backlight Resolution Uptime Processor ProcessorLoad Memory Battery GPU DiskSpace)' \
  '--ascii-artists[list original artists of the ASCII art]' \
  '(- *)'{-h,--help}'[show help information]' \
  '(- *)'{-v,--version}'[show version]' && ret=0
return ret
