#compdef create-zuplo-api
# Documentation: https://github.com/zuplo/core/tree/main/packages/create-zuplo-api
# Reference accessed: 2026-05-24
# Verified: npm view create-zuplo-api bin; dist/index.js options in zuplo/core at the URL above.

# Zsh completion for create-zuplo-api - Zuplo API gateway project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--eslint[initialize with ESLint config]' \
  '--prettier[initialize with Prettier config]' \
  '--empty[initialize an empty project]' \
  '--use-npm[bootstrap using npm]' \
  '--use-pnpm[bootstrap using pnpm]' \
  '--use-yarn[bootstrap using Yarn]' \
  '--use-bun[bootstrap using Bun]' \
  '--reset[reset saved create-zuplo-api preferences]' \
  '--reset-preferences[reset saved create-zuplo-api preferences]' \
  '--git[initialize the project as a git repo]' \
  '--version-check[check for an outdated CLI version]' \
  '--install[install packages]' \
  '--verbose[enable verbose logging]' \
  '--yes[use saved preferences or defaults for unprovided options]' \
  '--server-project[create matching project on portal.zuplo.com]' \
  '--account=[Zuplo account for server project]:account:' \
  '--agents=[AI coding agents to configure]:agents:(claude copilot cursor windsurf codex)' \
  '(-e --example)'{-e,--example=}'[example name or GitHub URL]:example:' \
  '--example-path=[path within example branch/subdir]:path:' \
  ':project directory:_directories' && ret=0

return ret
