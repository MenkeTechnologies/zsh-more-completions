#compdef parquet-cli parquet

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'meta:print Parquet file metadata'
  'pages:print page-level info'
  'schema:print Parquet schema'
  'footer:print file footer'
  'cat:print rows as JSON'
  'head:print first N records'
  'scan:scan all rows for benchmarking'
  'csv-schema:infer Avro schema from a CSV file'
  'convert-csv:convert CSV to Parquet'
  'convert:convert between formats'
  'to-avro:convert Parquet to Avro'
  'dictionary:print dictionary content'
  'check-stats:check column statistics'
  'column-index:print column index'
  'column-size:print column sizes'
  'size-stats:print size statistics'
  'bloom-filter:print bloom filter'
  'geospatial-stats:print geospatial statistics'
  'prune:prune columns (deprecated)'
  'trans-compression:transcode compression (deprecated)'
  'masking:mask columns (deprecated)'
  'rewrite:rewrite a Parquet file'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--conf=[Hadoop config file]:file:_files' \
  '*--property=[property key=value]:prop:' \
  '--config-file=[CLI config file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'parquet-cli subcommand' subcommands && ret=0
    ;;
  (args)
    _files
    ret=0
    ;;
esac

return ret
