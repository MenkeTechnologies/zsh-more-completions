#compdef parquet-cli parquet
# Documentation: https://github.com/apache/parquet-java/tree/master/parquet-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:show help'
  'version:show version'
  'meta:print Parquet file metadata'
  'pages:print page summaries'
  'dictionary:print dictionary content for a column'
  'check-stats:check page and column statistics'
  'schema:print the Avro schema for a file'
  'csv-schema:infer Avro schema from a CSV file'
  'convert-csv:convert CSV data to Parquet'
  'convert:convert data files to Parquet'
  'to-avro:convert Parquet to Avro'
  'cat:print first N records as JSON'
  'head:print first N records'
  'column-index:print column and offset indexes'
  'column-size:print column sizes'
  'prune:prune columns (deprecated)'
  'trans-compression:transcode compression (deprecated)'
  'masking:mask columns (deprecated)'
  'footer:print file footer as JSON'
  'bloom-filter:check bloom filter'
  'scan:scan all rows'
  'rewrite:rewrite Parquet files'
  'size-stats:print file size statistics'
  'geospatial-stats:print geospatial statistics'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'parquet-cli subcommand' subcommands && ret=0
    ;;
  (args)
    _files
    ret=0
    ;;
esac

return ret
