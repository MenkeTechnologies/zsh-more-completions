#compdef ROIgrow
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/ROIgrow.html
# Grow ROIs outward along a surface mesh

local ret=1

_arguments -s \
  '-i_TYPE[input surface with type]:surface:_files' \
  '-roi_labels[column with integer ROI labels]:labels' \
  '-roi_nodes[column with ROI node indices]:nodes' \
  '-lim[distance to cover from each node]:dist' \
  '-prefix[prefix of 1D output dataset]:prefix' \
  '-full_list[output row for each surface node]' \
  '-grow_from_edge[expand ROIs from edges]' \
  '-insphere[add nodes within sphere of diameter]:diameter' \
  '-inbox[add nodes within box e1 e2 e3]:edges' \
  '-onestate[make all surfaces appear at once]' \
  '-anatomical[label surfaces as anatomically correct]' \
  '-novolreg[ignore transforms in surface volume]' \
  '-noxform[same as -novolreg]' \
  '-trace[debug and memory tracing]' \
  '-TRACE[extreme tracing]' \
  '-nomall[disable memory tracing]' \
  '-yesmall[enable memory tracing]' \
  '-all_opts[identify all available options]' \
  '(-h -help -HELP)-h[mini help]' \
  '(-h -help -HELP)-help[full help]' \
  '(-h -help -HELP)-HELP[extreme help]' \
  '-h_view[open help in editor]' \
  '-h_web[open help in browser]' \
  '-h_find[search help for word]:word' \
  '*:surface:_files' && ret=0

return ret
