#compdef cargo-public-api
# Documentation: https://github.com/Enselic/cargo-public-api
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-p+[package to analyze]:package' \
  '--package=[package to analyze]:package' \
  '--manifest-path=[path to Cargo.toml]:manifest:_files -g "Cargo.toml"' \
  '--all-features[activate all features]' \
  '--no-default-features[do not activate default features]' \
  '-F+[features to activate]:features' \
  '--features=[features to activate]:features' \
  '(-s --simplified)'{-s,--simplified}'[simplified output: omit blanket/auto trait/auto-derived impls]' \
  '*--omit=[omit items]:items:(blanket-impls auto-trait-impls auto-derived-impls)' \
  '--color=[color mode]:mode:(auto always never)' \
  '--target=[target platform]:target' \
  '--cap-lints=[set lint level cap]:level:(allow warn deny forbid)' \
  '--verbose[verbose output]' \
  '1:subcommand:(diff)' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      diff)
        _arguments \
          '--deny=[fail on changes of given kind]:kind:(added changed removed all)' \
          '*:diff target (e.g. latest, X.Y.Z, ref1..ref2):'
        ;;
    esac
    ;;
esac
