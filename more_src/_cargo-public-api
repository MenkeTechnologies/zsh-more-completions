#compdef cargo-public-api

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--diff-git-checkouts=[diff between two git refs]:old-ref new-ref' \
  '--diff-published=[diff against published version]:version' \
  '-p+[package to analyze]:package' \
  '--package=[package to analyze]:package' \
  '--manifest-path=[path to Cargo.toml]:manifest:_files -g "Cargo.toml"' \
  '--all-features[activate all features]' \
  '--no-default-features[do not activate default features]' \
  '-F+[features to activate]:features' \
  '--features=[features to activate]:features' \
  '--simplified[simplified output]' \
  '-s[simplified output]' \
  '--omit=[omit items]:items:(blanket-impls auto-trait-impls)' \
  '-o=[omit items]:items:(blanket-impls auto-trait-impls)' \
  '--color=[color mode]:mode:(auto always never)' \
  '--target=[target platform]:target' \
  '--cap-lints=[set lint level cap]:level:(allow warn deny forbid)' && ret=0

return ret
