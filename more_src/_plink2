#compdef plink2
# Documentation: https://www.cog-genomics.org/plink/2.0/general_usage
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# PLINK 2.0: whole-genome association analysis toolset
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--bfile[input PLINK1 binary fileset prefix]:prefix:' \
  '--bpfile[input bp-file prefix]:prefix:' \
  '--pfile[input PLINK2 fileset prefix]:prefix:' \
  '--vcf[input VCF]:file:_files -g "*.vcf*"' \
  '--bcf[input BCF]:file:_files -g "*.bcf"' \
  '--data[input Oxford gen+sample]:prefix:' \
  '--gen[Oxford gen file]:file:_files' \
  '--haps[Oxford haps file]:file:_files' \
  '--sample[sample file]:file:_files' \
  '--out[output prefix]:prefix:' \
  '--make-bed[output binary PLINK1 format]' \
  '--make-pgen[output PLINK2 format]' \
  '--export[export format]:fmt:(vcf bcf vcf-fid vcf-iid ped tped haps hapslegend bgen-1.1 bgen-1.2 bgen-1.3 oxford A AD A-transpose)' \
  '--recode[recode output]:fmt:' \
  '--threads[number of CPU threads]:n:' \
  '--memory[memory cap in MB]:MB:' \
  '--keep[file of FID/IIDs to keep]:file:_files' \
  '--remove[file of FID/IIDs to remove]:file:_files' \
  '--extract[file of variant IDs to keep]:file:_files' \
  '--exclude[file of variant IDs to remove]:file:_files' \
  '--chr[chromosome(s) to keep]:chr:' \
  '--not-chr[chromosomes to exclude]:chr:' \
  '--from[first variant ID]:id:' \
  '--to[last variant ID]:id:' \
  '--from-bp[start bp position]:n:' \
  '--to-bp[end bp position]:n:' \
  '--maf[minor allele frequency threshold]:val:' \
  '--max-maf[max MAF]:val:' \
  '--mac[minor allele count]:n:' \
  '--max-mac[max MAC]:n:' \
  '--mind[max missingness per sample]:val:' \
  '--geno[max missingness per variant]:val:' \
  '--hwe[Hardy-Weinberg p-value]:val:' \
  '--snps-only[keep only SNPs]:opt:(just-acgt)' \
  '--keep-allele-order[do not flip alleles]' \
  '--allow-extra-chr[allow non-standard chrom names]' \
  '--missing[per-sample/-variant missingness reports]' \
  '--freq[allele frequencies]' \
  '--hardy[HWE statistics]' \
  '--het[heterozygosity]' \
  '--check-sex[infer sex from X chromosome]' \
  '--pca[principal components]:n:' \
  '--king-cutoff[relatedness cutoff using KING]:val:' \
  '--glm[generalized linear model association]' \
  '--linear[linear regression]' \
  '--logistic[logistic regression]' \
  '--pheno[phenotype file]:file:_files' \
  '--pheno-name[phenotype name(s) to use]:name:' \
  '--covar[covariate file]:file:_files' \
  '--covar-name[covariate names]:names:' \
  '--score[polygenic score file]:file:_files' \
  '--score-list[multi-PGS file list]:file:_files' \
  '*:additional args:_files' && ret=0
return ret
