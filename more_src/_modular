#compdef modular

# Zsh completion for Modular CLI (Mojo SDK manager)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'auth:manage authentication'
      'clean:clean up packages and cache'
      'install:install a package'
      'uninstall:uninstall a package'
      'update:update installed packages'
      'config:manage configuration'
    )
    _describe -t commands 'modular command' commands && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(login logout)' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:package:(mojo nightly max)' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:package:(mojo nightly max)' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--all[clean all]' && ret=0
        ;;
      config)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list set unset)' && ret=0
        ;;
    esac
    ;;
esac

return ret
