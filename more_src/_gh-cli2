#compdef gh-cli2

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'auth:authenticate gh and git'
  'browse:open repository in browser'
  'codespace:codespaces'
  'gist:gist commands'
  'issue:issue commands'
  'org:organization commands'
  'pr:pull request commands'
  'project:project commands'
  'release:release commands'
  'repo:repository commands'
  'cache:Actions cache commands'
  'workflow:workflow commands'
  'run:workflow run commands'
  'co:checkout pull request'
  'status:show github status'
  'alias:alias commands'
  'api:make GitHub API requests'
  'attestation:attestation commands'
  'completion:print shell completion'
  'config:configure gh'
  'extension:extension commands'
  'gpg-key:GPG key commands'
  'label:label commands'
  'preview:preview features'
  'ruleset:ruleset commands'
  'search:search commands'
  'secret:secret commands'
  'ssh-key:SSH key commands'
  'variable:Actions variable commands'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*-R+[repo OWNER/REPO]:repo:' \
  '*--repo=[repo OWNER/REPO]:repo:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gh command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (auth)
        _arguments \
          '1:subcommand:(login logout refresh setup-git status switch token)' \
          '*: :' && ret=0 ;;
      (pr)
        _arguments \
          '1:subcommand:(checkout checks close comment create develop diff edit list lock merge ready reopen review status unlock update-branch view)' \
          '*: :' && ret=0 ;;
      (issue)
        _arguments \
          '1:subcommand:(close comment create delete develop edit list lock pin reopen status transfer unlock unpin view)' \
          '*: :' && ret=0 ;;
      (repo)
        _arguments \
          '1:subcommand:(archive autolink clone create delete deploy-key edit fork gitignore license list rename set-default sync unarchive view)' \
          '*: :' && ret=0 ;;
      (workflow)
        _arguments \
          '1:subcommand:(disable enable list run view)' \
          '*: :' && ret=0 ;;
      (run)
        _arguments \
          '1:subcommand:(cancel delete download list rerun view watch)' \
          '*: :' && ret=0 ;;
      (release)
        _arguments \
          '1:subcommand:(create delete delete-asset download edit list upload view)' \
          '*: :' && ret=0 ;;
      (codespace)
        _arguments \
          '1:subcommand:(code cp create delete edit jupyter list logs ports rebuild ssh stop view)' \
          '*: :' && ret=0 ;;
      (project)
        _arguments \
          '1:subcommand:(close copy create delete edit field-create field-delete field-list item-add item-archive item-create item-delete item-edit item-list link list mark-template unlink view)' \
          '*: :' && ret=0 ;;
      (gist)
        _arguments \
          '1:subcommand:(clone create delete edit list rename view)' \
          '*: :' && ret=0 ;;
      (org)
        _arguments \
          '1:subcommand:(list)' \
          '*: :' && ret=0 ;;
      (label)
        _arguments \
          '1:subcommand:(clone create delete edit list)' \
          '*: :' && ret=0 ;;
      (secret)
        _arguments \
          '1:subcommand:(delete list set)' \
          '*: :' && ret=0 ;;
      (variable)
        _arguments \
          '1:subcommand:(delete get list set)' \
          '*: :' && ret=0 ;;
      (cache)
        _arguments \
          '1:subcommand:(delete list)' \
          '*: :' && ret=0 ;;
      (ruleset)
        _arguments \
          '1:subcommand:(check list view)' \
          '*: :' && ret=0 ;;
      (search)
        _arguments \
          '1:subcommand:(code commits issues prs repos)' \
          '*: :' && ret=0 ;;
      (extension)
        _arguments \
          '1:subcommand:(browse create exec install list remove search upgrade)' \
          '*: :' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(clear-cache get list set)' \
          '*: :' && ret=0 ;;
      (alias)
        _arguments \
          '1:subcommand:(delete import list set)' \
          '*: :' && ret=0 ;;
      (gpg-key)
        _arguments \
          '1:subcommand:(add delete list)' \
          '*: :' && ret=0 ;;
      (ssh-key)
        _arguments \
          '1:subcommand:(add delete list)' \
          '*: :' && ret=0 ;;
      (attestation)
        _arguments \
          '1:subcommand:(download trusted-root verify)' \
          '*: :' && ret=0 ;;
      (api)
        _arguments \
          '(-X --method)'{-X+,--method=}'[HTTP method]:m:(GET POST PUT DELETE PATCH HEAD)' \
          '(-F --field)*'{-F+,--field=}'[typed field]:f:' \
          '(-f --raw-field)*'{-f+,--raw-field=}'[raw field]:f:' \
          '(-H --header)*'{-H+,--header=}'[header]:h:' \
          '(--input)--input=[file]:file:_files' \
          '(--paginate)--paginate[paginate]' \
          '(--cache)--cache=[cache duration]:t:' \
          '(--hostname)--hostname=[GH host]:h:_hosts' \
          '(--include -i)'{-i,--include}'[include response headers]' \
          '(--jq -q)'{-q+,--jq=}'[jq query]:q:' \
          '(-t --template)'{-t+,--template=}'[template]:t:' \
          '(--silent)--silent[silent]' \
          '(--verbose)--verbose[verbose]' \
          '(--preview)*--preview=[preview header]:h:' \
          '(--slurp)--slurp[slurp arrays]' \
          '*: :' && ret=0 ;;
      (browse)
        _arguments \
          '(-b --branch)'{-b+,--branch=}'[branch]:b:' \
          '(-c --commit)'{-c+,--commit=}'[commit]:c:' \
          '(--no-browser -n)'{-n,--no-browser}'[print URL]' \
          '(-p --projects)'{-p,--projects}'[projects tab]' \
          '(-r --releases)'{-r,--releases}'[releases tab]' \
          '(-s --settings)'{-s,--settings}'[settings tab]' \
          '(-w --wiki)'{-w,--wiki}'[wiki tab]' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '(-s --shell)'{-s+,--shell=}'[shell]:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
