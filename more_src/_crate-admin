#compdef crate-admin

# crate-admin: CrateDB admin shell (crash) CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-U[username]:user:_users' \
  '--username=[username]:user:_users' \
  '-W[ask password]' \
  '--password[ask password]' \
  '--host=[host:port]:host:_hosts' \
  '-c[command]:cmd:' \
  '--command=[command]:cmd:' \
  '--format=[output format]:fmt:(tabular csv mixed json json_row json_raw raw dynamic)' \
  '-A[file with sql]:file:_files -g "*.sql"' \
  '--sysinfo[print system info]' \
  '--verify-ssl=[verify ssl certs]:bool:(true false)' \
  '--cert-file=[client cert]:file:_files' \
  '--key-file=[client key]:file:_files' \
  '--ca-cert-file=[CA cert]:file:_files' \
  '--history=[history file]:file:_files' \
  '*::crate-admin args:_files' && ret=0
return ret
