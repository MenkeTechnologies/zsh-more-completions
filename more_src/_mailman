#compdef mailman
# Documentation: https://man.archlinux.org/search?q=mailman
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:show help'
  'aliases:regenerate MTA aliases'
  'conf:display Mailman config'
  'create:create a mailing list'
  'digests:manage digests'
  'import21:import Mailman 2.1 list data'
  'info:Mailman instance info'
  'inject:inject message into queue'
  'lists:list all mailing lists'
  'members:manage list memberships'
  'qfile:inspect a queue file'
  'remove:remove a mailing list'
  'reopen:re-open log files'
  'restart:restart runner subprocesses'
  'shell:withlist alias'
  'start:start Mailman processes'
  'status:Mailman status'
  'stop:stop Mailman processes'
  'unshunt:unshunt messages'
  'version:show Mailman version'
  'withlist:operate on a mailing list'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-C --config)'{-C,--config=}'[config file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'mailman subcommand' subcommands && ret=0
    ;;
esac

return ret
