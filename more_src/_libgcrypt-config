#compdef libgcrypt-config
# Documentation: https://manpages.debian.org/bookworm/libgcrypt20-dev/libgcrypt-config.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix[print installation prefix]' \
  '--exec-prefix[print exec prefix]' \
  '--version[show version]' \
  '--api-version[show API version]' \
  '--libs[print linker flags]' \
  '--cflags[print compiler flags]' && ret=0

return ret
