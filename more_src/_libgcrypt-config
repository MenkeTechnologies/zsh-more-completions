#compdef libgcrypt-config
# Documentation: https://man.archlinux.org/search?q=libgcrypt-config
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix[print installation prefix]' \
  '--exec-prefix[print exec prefix]' \
  '--version[show version]' \
  '--api-version[show API version]' \
  '--libs[print linker flags]' \
  '--cflags[print compiler flags]' && ret=0

return ret
