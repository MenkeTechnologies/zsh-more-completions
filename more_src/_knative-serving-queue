#compdef knative-serving-queue
# _knative-serving-queue — Knative Serving queue-proxy sidecar (sharedmain + envconfig)
# upstream: https://github.com/knative/serving
# Flags from cmd/queue/main.go on tip; primary runtime configuration via env vars (SERVING_NAMESPACE, SERVING_SERVICE, SERVING_CONFIGURATION, SERVING_REVISION, QUEUE_SERVING_PORT, USER_PORT, REVISION_TIMEOUT_SECONDS, REVISION_RESPONSE_START_TIMEOUT_SECONDS, REVISION_IDLE_TIMEOUT_SECONDS, CONTAINER_CONCURRENCY, ENABLE_PROFILING, METRICS_DOMAIN).

_knative-serving-queue() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_knative-serving-queue "$@"
