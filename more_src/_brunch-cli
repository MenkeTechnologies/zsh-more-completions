#compdef brunch-cli
# _brunch-cli — Brunch ultra-fast HTML5 build tool CLI alias (brunch team, JavaScript); custom argparse
# upstream: https://github.com/brunch/brunch

_brunch-cli() {
    local -a sub=(
        'new:create new project from skeleton'
        'build:build project'
        'watch:watch project'
        'pluginInfo:print plugin info'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'brunch subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:dir:_files -/' \
                    '-s+[skeleton]:str:' \
                    '--skeleton=+[skeleton]:str:' ;;
                build|watch) _arguments \
                    '-c+[config file]:file:_files' \
                    '--config=+[config file]:file:_files' \
                    '-e+[environment]:str:' \
                    '--env=+[environment]:str:' \
                    '-p+[production]' \
                    '--production[production]' \
                    '-d+[debug categories]:str:' \
                    '--debug=+[debug categories]:str:' \
                    '-j+[jobs]:n:' \
                    '--jobs=+[jobs]:n:' \
                    '-s[server]' \
                    '--server[server]' \
                    '-n+[network]:str:' \
                    '--network=+[network]:str:' \
                    '-P+[port]:port:' \
                    '--port=+[port]:port:' \
                    '--public-path=+[path]:str:' ;;
            esac
            ;;
    esac
}

_brunch-cli "$@"
