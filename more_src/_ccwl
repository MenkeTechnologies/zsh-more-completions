#compdef ccwl
# Documentation: upstream scripts/ccwl at github.com/arunisaac/ccwl
# Reference accessed: 2026-05-30 via gh api inspection of the
# Guile (option ...) entries in scripts/ccwl (a guile script with a
# single `main` dispatch via match-case on argv).
# ccwl R96 — Concise Common Workflow Language compiler that emits
# CWL workflows (.cwl) or Graphviz (.dot) graphs from .scm
# descriptions.

local curcontext="$curcontext" state line ret=1

local -a _subcmds _targets
_subcmds=( 'compile:transform a ccwl .scm description into CWL or Graphviz' )
_targets=( cwl dot )

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd) _describe -t commands 'ccwl subcommand' _subcmds && ret=0 ;;
  subcmd_args)
    case $words[1] in
      compile)
        _arguments -s -S \
          '(-t --to)'{-t,--to}'=[output target format]:target:($_targets)' \
          '(-o --output)'{-o,--output}'=[output file (default stdout)]:file:_files' \
          '(- *)'{-h,--help}'[show help]' \
          '*:source file:_files -g "*.scm"' && ret=0
        ;;
    esac
    ;;
esac

return ret
