#compdef go-arch-lint
# Documentation: https://github.com/fe3dback/go-arch-lint
# go-arch-lint: linter that validates a Go project against an architecture spec

local ret=1
local -a commands

commands=(
  'check:validate the project architecture against the rules'
  'graph:generate a dependency graph visualization'
  'mapping:show the component-to-package mapping'
  'schema:show the archfile JSON schema'
  'version:print the version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--json[output results as JSON]' \
  '--output-type=[output format]:type:(default ascii json)' \
  '--output-color[use ANSI colors in terminal output]' \
  '--output-json-one-line[single-line JSON output]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'go-arch-lint command' commands && ret=0
    ;;
  args)
    case $line[1] in
      check)
        _arguments -s \
          '--arch-file=[path to the architecture file]:file:_files' \
          '--project-path=[absolute path to the project directory]:dir:_files -/' \
          '--max-warnings=[maximum number of warnings to output]:count' && ret=0
        ;;
    esac
    ;;
esac

return ret
