#compdef guake

# Zsh completion for guake - drop-down terminal for GNOME

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-t --toggle-visibility)'{-t,--toggle-visibility}'[toggle main window visibility]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[toggle fullscreen]' \
  '--show[show Guake main window]' \
  '--hide[hide Guake main window]' \
  '(-p --preferences)'{-p,--preferences}'[show preferences window]' \
  '(-a --about)'{-a,--about}'[show about dialog]' \
  '(-n --new-tab)'{-n,--new-tab}'[add a new tab]:directory:_files -/' \
  '(-s --select-tab)'{-s,--select-tab}'[select tab by index]:index' \
  '(-g --selected-tab)'{-g,--selected-tab}'[return selected tab index]' \
  '(-l --selected-tablabel)'{-l,--selected-tablabel}'[return selected tab label]' \
  '--split-vertical[split selected tab vertically]' \
  '--split-horizontal[split selected tab horizontally]' \
  '(-e --execute-command)'{-e,--execute-command}'[execute command on selected tab]:command' \
  '(-i --tab-index)'{-i,--tab-index}'[specify tab to operate on]:index' \
  '--bgcolor[set tab background color]:color' \
  '--fgcolor[set tab foreground color]:color' \
  '--change-palette[change color palette]:palette' \
  '--rename-tab[rename the specified tab]:name' \
  '--rename-current-tab[rename current tab]:name' \
  '(-q --quit)'{-q,--quit}'[quit Guake]'
