#compdef cups-lpd
# Documentation: man cups-lpd(8)
# Source: OpenPrinting/cups scheduler/cups-lpd.c (master) — LPD-to-CUPS bridge daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h+[CUPS server host[:port]]:host:_hosts' \
    '*-o+[CUPS option=value]:opt:_default' \
    '-n[do not perform hostname lookups]' \
    && ret=0

return ret
