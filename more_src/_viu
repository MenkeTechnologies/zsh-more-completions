#compdef viu

# Zsh completion for viu - terminal image viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-w --width)'{-w,--width}'[resize to width]:width (pixels):' \
  '(-h --height)'{-h,--height}'[resize to height]:height (pixels):' \
  '(-n --name)'{-n,--name}'[print file name above image]' \
  '(-t --transparent)'{-t,--transparent}'[display transparent pixels]' \
  '(-s --static)'{-s,--static}'[do not animate GIFs]' \
  '(-b --blocks)'{-b,--blocks}'[force block output]' \
  '(-f --frame-rate)'{-f,--frame-rate}'[GIF frame rate]:frames per second:' \
  '(-1 --once)'{-1,--once}'[play GIF only once]' \
  '(-r --recursive)'{-r,--recursive}'[recurse into directories]' \
  '--mirror[mirror the image]' \
  '--flip[flip the image]' \
  '*:image file:_files' && ret=0

return ret
