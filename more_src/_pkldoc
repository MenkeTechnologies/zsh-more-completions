#compdef pkldoc
# _pkldoc — generate HTML documentation from Pkl modules (apple/pkl)
# upstream: https://github.com/apple/pkl
# Flags from pkl-doc/src/main/kotlin/org/pkl/doc/Main.kt + pkl-commons-cli BaseOptions.kt (clikt).

_pkldoc() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '(-o --output-dir)'{-o+,--output-dir=}'[directory for generated documentation]:dir:_files -/'
        '--no-symlinks[copy directories/files instead of creating symlinks]'
        '--migrate[migrate pkl-doc site from version 0 to version 1]'
        '--allowed-modules=[allowed module URI patterns (regex, comma-separated)]:patterns:'
        '--allowed-resources=[allowed resource URI patterns (regex, comma-separated)]:patterns:'
        '--root-dir=[evaluation root directory]:dir:_files -/'
        '--cache-dir=[package cache directory]:dir:_files -/'
        '--no-cache[disable caching of packages]'
        '(-w --working-dir)'{-w+,--working-dir=}'[base path for relative module paths]:dir:_files -/'
        '*'{-p+,--property=}'[read property (name=value, repeatable)]:property:'
        '--color=[when to colorize output]:when:(auto always never)'
        '*'{-e+,--env-var=}'[set environment variable (name=value)]:envvar:'
        '--module-path=[colon-separated list of module-path directories/jars]:paths:'
        '--settings=[Pkl settings module URI]:uri:'
        '(-t --timeout)'{-t+,--timeout=}'[evaluation timeout (seconds)]:seconds:'
        '--ca-certificates=[CA certificate bundle (PEM)]:file:_files -g "*.pem"'
        '--http-proxy=[HTTP proxy URL]:url:'
        '--http-no-proxy=[comma-separated list of no-proxy patterns]:patterns:'
        '*--http-rewrite=[URL rewrite rule (from=to)]:rule:'
        '*--http-header=[HTTP header rule (<url-pattern>=<name>:<value>)]:rule:'
        '*--external-module-reader=[external module reader (<scheme>="<exe args>")]:spec:'
        '*--external-resource-reader=[external resource reader (<scheme>="<exe args>")]:spec:'
        '--trace-mode=[stack-trace style]:style:(legacy compact full)'
        '--project-dir=[project directory]:dir:_files -/'
        '--no-project[ignore PklProject files]'
        '--omit-project-settings[ignore project evaluator settings]'
        '*:module URI or path:_files'
    )
    _arguments -s $args
}

_pkldoc "$@"
