#compdef drill-tool
# _drill-tool — drill wrapper helper (small wrapper around drill(1) that adds default DNSSEC-friendly output and consistent IPv4/IPv6 fallback; -k DNSSEC anchor, -T trace, -S verify signature, -V verbose, -p port, -4/-6 family, -x reverse lookup, -t TCP, -u UDP, -d debug, --version; positional QNAME [QTYPE [@SERVER]])
# upstream: https://github.com/NLnetLabs/ldns (drill)
# Flags from NLnetLabs/ldns drill on tip.

_drill-tool() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-k+[DNSSEC anchor]:file:_files' \
        '-T[trace]' \
        '-S[verify signature]' \
        '-v+[verbose level]:level:(0 1 2 3 4 5)' \
        '-p+[port]:port:' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-x[reverse lookup]' \
        '-t[TCP]' \
        '-u[UDP]' \
        '-d+[debug level]:level:' \
        '1:qname:' \
        '2::qtype:(A AAAA NS MX TXT CNAME PTR SOA DS DNSKEY RRSIG NSEC NSEC3 CAA TLSA SVCB HTTPS SRV ANY)' \
        '3::server:_hosts'
}

_drill-tool "$@"
