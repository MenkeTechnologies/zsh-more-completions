#compdef clojure clj
# Documentation: https://clojure.org/reference/deps_and_cli
# Source: clojure/brew-install src/main/resources/clojure/install/clojure — Clojure CLI launcher (bash).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-version[show Clojure CLI version]' \
    '--version[show Clojure CLI version]' \
    '*-J+[JVM option]:jvm-opt:_default' \
    {-A+,-A}'[REPL alias]:alias:_default' \
    '-M+[main with alias]:alias:_default' \
    {-X+,-X}'[exec function with alias]:alias:_default' \
    {-T+,-T}'[tool exec]:tool/alias:_default' \
    '-P[prepare; download deps but do not run]' \
    '-Sdeps+[extra deps EDN]:deps:_default' \
    '-Scp+[provide concrete classpath]:cp:_default' \
    '-Spath[compute and print classpath]' \
    '-Sverbose[print path info]' \
    '-Sthreads+[concurrency threads]:n:_default' \
    '-Strace[write trace.edn for resolution]' \
    '-Sdescribe[print env+config description]' \
    '-Sforce[force re-computation of classpath]' \
    '-Srepro[ignore user/system deps.edn]' \
    '-Stree[print dependency tree]' \
    '-Spom[generate manifest pom.xml]' \
    '-Sresolve-tags[resolve git tags in deps.edn]' \
    '(-h --help -?)'{-h,--help,-\?}'[show help]' \
    '*::main args:_default' \
    && ret=0

return ret
