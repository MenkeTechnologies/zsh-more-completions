#compdef mimic3
# _mimic3 — Mycroft Mimic 3 neural text-to-speech (MycroftAI/mimic3)
# upstream: https://github.com/MycroftAI/mimic3
# Flags from mimic3_tts/__main__.py (argparse).

_mimic3() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[print version and exit]' \
        '--voice=[voice name (key:speaker)]:voice:' \
        '--speaker=[speaker name / index]:speaker:' \
        '--voices[list available voices]' \
        '--voices-dir=[voices directory]:dir:_files -/' \
        '--preload-voice=[preload voice]:voice:' \
        '--output-dir=[directory to write WAV file(s)]:dir:_files -/' \
        '--output-naming=[output file naming]:naming:(text time id)' \
        '--play-program=[external play program]:cmd:' \
        '--csv[input format is id|text]' \
        '--csv-delimiter=[CSV delimiter]:char:' \
        '--csv-voice[CSV input has voice column]' \
        '--id-delimiter=[id delimiter]:char:' \
        '--stdin-format=[input format on stdin]:fmt:(auto lines document)' \
        '--stdout[write WAV audio to stdout]' \
        '--interactive[interactive mode]' \
        '--mark-file=[file for SSML marks]:file:_files' \
        '--ssml[input text is SSML]' \
        '--noise-scale=[voice noise scale]:value:' \
        '--noise-w=[noise W]:value:' \
        '--length-scale=[length scale (speed)]:value:' \
        '--process-on-blank-line[trigger TTS on blank line]' \
        '--result-queue-size=[result queue size]:n:' \
        '--cuda[use CUDA / GPU]' \
        '--deterministic[deterministic output]' \
        '--seed=[random seed]:seed:' \
        '--remote=[remote Mimic 3 server URL]:url:' \
        '--debug[debug output]' \
        '*:text:'
}

_mimic3 "$@"
