#compdef lxqt-confupdate
# Documentation: https://github.com/Razor-qt/razor-qt/blob/master/razorqt-confupdate/razor-confupdate.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# lxqt-confupdate is the LXQt continuation of razor-confupdate; lxqt-session
# invokes it with --watch (see lxqt-session/src/lxqtmodman.cpp).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--watch[watch for new update files instead of exiting]' \
  '--debug[retain output of update scripts]' \
  '--check[check whether a config file needs updating]:file:_files' \
  '*:update file:_files' && ret=0

return ret
