#compdef kismet_drone
# _kismet-drone — Kismet kismet_drone (passive capture-only client that ships packets to a kismet_server / modern Kismet daemon; -f config file, -c capture source, -t log title, -s silent, -v verbose, -V version, --homedir, --confdir, --logdir; runs on small embedded probes to feed centralised Kismet servers)
# upstream: https://github.com/kismetwireless/kismet-old (legacy)
# Flags from legacy kismet kismet_drone/kismet_drone.cc on tip.

_kismet-drone() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-f+[config file]:file:_files' \
        '*-c+[capture source]:source:' \
        '-t+[log title]:title:' \
        '-s[silent]' \
        '-v[verbose]' \
        '--homedir+[home dir]:dir:_files -/' \
        '--confdir+[config dir]:dir:_files -/' \
        '--logdir+[log dir]:dir:_files -/'
}

_kismet-drone "$@"
