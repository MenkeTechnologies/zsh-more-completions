#compdef scalene

# Zsh completion for scalene - Python CPU/memory/GPU profiler

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cpu[profile CPU usage]' \
  '--gpu[profile GPU usage]' \
  '--memory[profile memory usage]' \
  '--profile-all[profile all code, not just target]' \
  '--profile-only=[profile only specified files]:file pattern' \
  '--profile-exclude=[exclude specified files from profiling]:file pattern' \
  '--reduced-profile[only profile lines with significant usage]' \
  '--html[generate HTML output]' \
  '--json[generate JSON output]' \
  '--cli[display results on the command line]' \
  '--column-width=[column width for output]:width' \
  '(-o --outfile)'{-o,--outfile}'[output file name]:file:_files' \
  '--use-virtual-time[use virtual time instead of wall clock]' \
  '--cpu-only[only profile CPU time]' \
  '--cpu-percent-threshold=[threshold for showing lines]:percent' \
  '--cpu-sampling-rate=[CPU sampling rate]:rate' \
  '--allocation-sampling-window=[memory allocation sampling window]:bytes' \
  '--malloc-threshold=[threshold for reporting malloc calls]:bytes' \
  '--program-path=[path to the program]:path:_files -/' \
  '--no-browser[do not open browser for HTML output]' \
  '--stacks[collect full stack traces]' \
  '--on[start profiling immediately]' \
  '--off[start with profiling disabled]' \
  '*:script:_files -g "*.py"'
