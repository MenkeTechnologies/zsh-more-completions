#compdef minidjvu
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/minidjvu.1.html
# bitonal DjVu encoder/decoder

local ret=1

_arguments -s -S \
  '(-A --Averaging)'{-A,--Averaging}'[compute average representatives for matching shapes]' \
  '(-a --aggression)'{-a,--aggression}'[set pattern matching aggression]:level' \
  '(-c --clean)'{-c,--clean}'[remove small black marks (probable noise)]' \
  '(-d --dpi)'{-d,--dpi}'[specify image resolution in dpi]:dpi' \
  '(-e --erosion)'{-e,--erosion}'[sacrifice quality for ~5-10% smaller size]' \
  '(-i --indirect)'{-i,--indirect}'[generate indirect multipage document]' \
  '(-l --lossy)'{-l,--lossy}'[turn on all lossy options]' \
  '(-m --match)'{-m,--match}'[run pattern matching to shrink file size]' \
  '(-n --no-prototypes)'{-n,--no-prototypes}'[disable prototype searching]' \
  '(-p --pages-per-dict)'{-p,--pages-per-dict}'[pages to compress per pass]:pages' \
  '(-r --report)'{-r,--report}'[print verbose per-page messages]' \
  '(-s --smooth)'{-s,--smooth}'[flip pixels that appear to be noise]' \
  '(-v --verbose)'{-v,--verbose}'[print stage messages]' \
  '(-X --Xtension)'{-X,--Xtension}'[shared dictionary file extension]:ext' \
  '(-w --warnings)'{-w,--warnings}'[do not disable libtiff warnings]' \
  '*:file:_files' && ret=0

return ret
