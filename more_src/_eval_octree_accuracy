#compdef eval_octree_accuracy
# Documentation: https://github.com/OctoMap/octomap/blob/devel/octomap/src/eval_octree_accuracy.cpp
# Evaluate the statistical accuracy of an octree from scan graph data

local ret=1

_arguments -s -S \
  '-i[input graph file]:graph:_files -g "*.graph"' \
  '-res[octree resolution in meters]:m' \
  '-m[maximum scan range]:m' \
  '-n[maximum number of scans]:n' \
  '*:graph:_files -g "*.graph"' && ret=0

return ret
