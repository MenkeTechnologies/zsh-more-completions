#compdef gocr
# Documentation: https://manpages.debian.org/bookworm/gocr/gocr.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm gocr(1) manpage OPTIONS. Single-dash short
# opts only; no GNU long form.
# Removed from prior file: fabricated --help/--version long flags and
# bogus man.archlinux.org search URL.

# gocr: command-line OCR tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show usage information]' \
  '-V[show version information]' \
  '-i[input file (- for stdin)]:file:_files' \
  '-o[output file]:file:_files' \
  '-e[errors file]:file:_files' \
  '-x[progress output file/fifo/fd]:dest:' \
  '-p[database path (default ./db/)]:dir:_files -/' \
  '-f[output format]:format:(ISO8859_1 TeX HTML XML UTF8 ASCII)' \
  '-l[grey level 0-255 (0=auto)]:level:' \
  '-d[dust size in pixels]:size:' \
  '-s[spacewidth in dots]:dots:' \
  '-v[verbose bitfield]:bitfield:' \
  '-c[only verbose for these chars]:chars:' \
  '-C[only recognise these chars]:chars:' \
  '-a[certainty 0-100 (default 95)]:n:' \
  '-u[unrecognized char (default _)]:char:' \
  '-m[operational mode bitfield]:mode:' \
  '-n[numbers-only mode]:bool:' \
  '*:image file:_files' && ret=0
return ret
