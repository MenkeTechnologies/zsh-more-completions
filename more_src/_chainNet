#compdef chainNet
# make alignment nets out of chains

local ret=1

_arguments -s -S \
  '-minSpace=[minimum gap size to fill (default 25)]:n' \
  '-minFill=[minimum fill to record (default half of minSpace)]:n' \
  '-minScore=[minimum chain score to consider (default 2000)]:n' \
  '-inclHap[include query sequences matching _hap or _alt]' \
  '1:in chain:_files -g "*.chain"' \
  '2:target sizes:_files' \
  '3:query sizes:_files' \
  '4:target net:_files' \
  '5:query net:_files' && ret=0

return ret
