#compdef fextract
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fextract.txt
# Extract (copy) an extension from a FITS file into a new FITS file

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "outfile=[output FITS file]:file:_files" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
