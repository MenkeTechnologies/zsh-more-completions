#compdef DiscFix
# Documentation: https://github.com/SGL-UT/GPSTk/blob/main/ext/apps/geomatics/cycleslips/DiscFix.cpp
# GPSTk GNSS cycle slip detection and correction

local ret=1

_arguments -s \
  '*--obs[input RINEX observation file]:file:_files' \
  '--obspath[path for input RINEX files]:dir:_files -/' \
  '--file[file containing additional options]:file:_files' \
  '--start[start processing at specified time]:time' \
  '--stop[stop processing at specified time]:time' \
  '--decimate[downsample data to time interval (sec)]:dt' \
  '--gap[minimum gap between passes (sec)]:t' \
  '--noCA1[require L1 P-code; reject C/A]' \
  '--noCA2[require L2 P-code; reject C/A]' \
  '--forceCA1[use L1 C/A range even if P-code present]' \
  '--forceCA2[use L2 C/A range even if P-code present]' \
  '--onlySat[process only specified satellite]:sat' \
  '*--exSat[exclude satellite]:sat' \
  '--doGLO[process GLONASS satellites]' \
  '--GLOfreq[GLONASS channel numbers (sat:n)]:freq' \
  '--smoothPR[smooth pseudorange values]' \
  '--smoothPH[debias phase values]' \
  '--smooth[enable both smoothing options]' \
  '--DC[configure cycle slip fixer parameter]:param=value' \
  '--DChelp[display DC parameters and defaults]' \
  '--log[log file name]:file:_files' \
  '--cmd[editing commands output file]:file:_files' \
  '--format[time format specification]:fmt' \
  '--round[round output times to n digits]:n' \
  '--RinexFile[output corrected RINEX file]:file:_files' \
  '--Prgm[RINEX PROGRAM string]:str' \
  '--RunBy[RINEX RUNBY string]:str' \
  '--Observer[RINEX OBSERVER string]:str' \
  '--Agency[RINEX AGENCY string]:str' \
  '--Marker[RINEX MARKER string]:str' \
  '--Number[RINEX NUMBER string]:str' \
  '--verbose[extended output information]' \
  '--help[display help and exit]' && ret=0

return ret
