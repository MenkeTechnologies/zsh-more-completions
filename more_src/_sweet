#compdef sweet sweet-cli
# Documentation: https://sweetcli.com/docs/commands/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Sweet CLI - terminal-first AI coding assistant

_sweet() {
    local line state
    local -a commands
    commands=(
        'login:authenticate with billing account'
        'start:run a task against the current directory'
        'resume:continue the most recent session'
    )

    _arguments -C \
        '(- *)--help[show help]' \
        '--model=[model name]:model:' \
        '--provider=[provider name]:provider:' \
        '--session=[session id]:id:' \
        '--work-for=[run autonomously for duration (e.g. 45m)]:duration:' \
        '--list-sessions[show previous sessions]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'sweet command' commands
            ;;
    esac
}

_sweet "$@"
