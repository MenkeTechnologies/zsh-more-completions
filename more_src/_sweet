#compdef sweet sweet-cli
# Documentation: https://man.archlinux.org/search?q=sweet
# Reference accessed: 2026-05-16

_sweet() {
    local line state
    local -a commands
    commands=(
        'login:Login to Sweet'
        'start:Start a new task'
        'resume:Resume a previous task'
        'help:Show help'
    )

    _arguments -C \
        '--list-sessions[Show previous sessions]' \
        '--work-for[Run autonomously for duration]:duration:' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'sweet command' commands
            ;;
    esac
}

_sweet "$@"
