#compdef shp2pgsql

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-?[show help]' \
  '(-c -a -d -p)-c[create new table and populate (default)]' \
  '(-c -a -d -p)-a[append data to existing table]' \
  '(-c -a -d -p)-d[drop table before creating new]' \
  '(-c -a -d -p)-p[only produce table creation SQL]' \
  '-D[use PostgreSQL dump format for faster loading]' \
  '-s+[SRID, optionally <FROM_SRID>:<SRID>]:srid:' \
  '-k[preserve identifier case]' \
  '-i[coerce integers to 32-bit]' \
  '-I[create GiST index on geometry column]' \
  '-m+[map long column names to DBF names]:file:_files' \
  '-S[generate simple geometries (no MULTI)]' \
  '-t+[force output dimensionality]:dim:(2D 3DZ 3DM 4D)' \
  '-w[output WKT instead of WKB]' \
  '-e[execute each statement independently]' \
  '-W+[input DBF encoding]:encoding:(UTF-8 LATIN1 ISO-8859-1 CP1252)' \
  '-N+[NULL geometry policy]:policy:(insert skip abort)' \
  '-n[import DBF file only]' \
  '-G[use geography type (WGS84)]' \
  '-g+[geometry column name]:column:' \
  '-T+[tablespace for new table]:tablespace:' \
  '-X+[tablespace for indexes]:tablespace:' \
  '-Z[prevent ANALYZE statements]' \
  '1:Shapefile:_files -g "*.shp"' \
  '2::table name (schema.table):' \
  '3::database:' && ret=0

return ret
