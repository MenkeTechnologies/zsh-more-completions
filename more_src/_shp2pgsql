#compdef shp2pgsql

# Zsh completion for shp2pgsql - shapefile to PostGIS loader

_arguments -s -S \
  '-s+[set SRID (from\[:to\])]:SRID' \
  '(-a -c -p)-d[drop table, then create and populate]' \
  '(-d -c -p)-a[append data to existing table]' \
  '(-d -a -p)-c[create table and populate (default)]' \
  '(-d -a -c)-p[prepare mode, create table only]' \
  '-g+[specify geometry column name]:column name' \
  '-D[use dump format for faster loading]' \
  '-G[use geography type instead of geometry]' \
  '-k[keep identifiers case (do not convert to lowercase)]' \
  '-i[use int4 type for all integer dbf fields]' \
  '-I[create a spatial index on the geometry column]' \
  '-S[generate simple geometries instead of MULTI]' \
  '-t+[specify coordinate dimensionality]:dimensionality:(2D 3DZ 3DM 4D)' \
  '-w[output WKT format instead of WKB]' \
  '-W+[specify encoding of dbf file]:encoding:(UTF-8 LATIN1 ISO-8859-1 CP1252)' \
  '-N+[policy for NULL geometries]:policy:(insert skip abort)' \
  '-n[only import dbf file]' \
  '-?[show help]' \
  '1:shapefile:_files -g "*.shp"' \
  '2:schema.table:' \
  '3:database:_files'
