#compdef ftdump ftstring ftdiff ftlint ftmulti
# Documentation: upstream FreeType ft2demos man pages at
# manpages.debian.org/bookworm/freetype2-demos/
# Reference accessed: 2026-05-30 via WebFetch of
# ft{dump,string,diff,lint,multi}.1.en.html.
# FreeType ft2demos R113 — 5-stem multi-binary harvest completing
# the R112 ft2demos extras deferral.

local -a _encodings _render_modes
_encodings=( unic symb ADOB ADBC )
_render_modes=( '0:normal' '1:light' '2:mono' '3:LCD horizontal' '4:LCD vertical' )

case $service in

  ftdump)
    # Simple font dumper — print font file information.
    _arguments -s -S \
      '(-c -C)'{-c,-C}'[print charmap coverage]' \
      '-n[print SFNT name tables]' \
      '-p[print TrueType programs]' \
      '-t[print SFNT table list]' \
      '-u[emit UTF-8]' \
      '(- *)-v[show version]' \
      '*:font file:_files -g "*.(ttf|otf|woff|woff2|pfa|pfb|bdf|pcf)"'
    ;;

  ftstring)
    # Interactive string renderer.
    _arguments -s -S \
      '-d+[window dimensions WxH\[xD\] (default 640x480x24)]:dim:' \
      '-r+[resolution in dpi (default 72)]:dpi:' \
      '-e+[encoding tag]:encoding:($_encodings)' \
      '-m+[custom text to render]:text:' \
      '-k+[emulate keystrokes (q = batch mode)]:keys:' \
      '(- *)-v[show version]' \
      '1:point size:' \
      '*:font file:_files -g "*.(ttf|otf|woff|woff2|pfa|pfb|bdf|pcf)"'
    ;;

  ftdiff)
    # Display text in 3 columns with different hinting modes per column.
    _arguments -s -S \
      '-w+[window width in pixels (default 640)]:px:' \
      '-h+[window height in pixels (default 480)]:px:' \
      '-r+[resolution in dpi (default 72)]:dpi:' \
      '-s+[character size in points (default 16)]:pt:' \
      '-f+[UTF-8 text file with content to display]:file:_files' \
      '(- *)-v[show version]' \
      '*:font file:_files -g "*.(ttf|otf|woff|woff2)"'
    ;;

  ftlint)
    # Lint a font (check for FreeType loading issues across glyphs).
    _arguments -s -S \
      '-f+[FT_LOAD_XXX load flags (hex, default 0)]:hex:' \
      '-r+[render mode]:mode:(($^_render_modes))' \
      '-i+[glyph index range I-J (default all)]:range:' \
      '-q[quiet mode (suppress rendering analysis output)]' \
      '(- *)-v[show version]' \
      '1:ppem (pixel size):' \
      '*:font file:_files -g "*.(ttf|otf|woff|woff2)"'
    ;;

  ftmulti)
    # Interactive viewer for variation fonts (Multiple Masters /
    # GX / OpenType variation).
    _arguments -s -S \
      '-w+[window width in pixels (default 640)]:px:' \
      '-h+[window height in pixels (default 480)]:px:' \
      '-e+[encoding tag]:encoding:($_encodings)' \
      '-r+[resolution in dpi (default 72)]:dpi:' \
      '-f+[first glyph index to display]:index:' \
      '-d+[variation-font axis coordinates ("axis1 axis2 ...")]:axes:' \
      '(- *)-v[show version]' \
      '*:font file:_files -g "*.(ttf|otf|woff|woff2)"'
    ;;

esac
