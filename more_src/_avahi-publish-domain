#compdef avahi-publish-domain
# _avahi-publish-domain — Avahi avahi-publish-domain CLI advertising browsing legacy-browse register-domain types over multicast DNS-SD on the local link via the system avahi-daemon dbus interface remaining registered until the process exits for Bonjour-compatible domain discovery (Avahi team, C); getopt
# upstream: https://www.avahi.org/

_avahi-publish-domain() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[domain]' \
        '--domain[advertise browsing domain]' \
        '-D[domain]' \
        '-R[do not fail on collision]' \
        '--no-fail[ignore failures]' \
        '-r[register]' \
        '-b[browse]' \
        '-l[legacy browse]' \
        '-n[register non-default]' \
        '--no-reverse[no reverse mapping]' \
        '*:domain name:'
}

_avahi-publish-domain "$@"
