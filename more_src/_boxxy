#compdef boxxy

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '*'{-r+,--rule=}'[rule specification (source\:target\:mode)]:rule:' \
    '(-c --config)'{-c+,--config=}'[config file path]:config:_files' \
    '--shell=[shell to use]:shell:_command_names -e' \
    '--immutable[make rules immutable]' \
    '--dry-run[show what would be done without executing]' \
    '(-):command:_command_names -e' \
    '*::arguments:_normal'
