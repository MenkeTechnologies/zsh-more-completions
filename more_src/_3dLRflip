#compdef 3dLRflip
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dLRflip.html
# AFNI flip the rows of a dataset along one of three axes

local ret=1

_arguments -s -S \
  '(-LR -AP -IS -X -Y -Z)-LR[flip along left-right axis (default)]' \
  '(-LR -AP -IS -X -Y -Z)-AP[flip along anterior-posterior axis]' \
  '(-LR -AP -IS -X -Y -Z)-IS[flip along inferior-superior axis]' \
  '(-LR -AP -IS -X -Y -Z)-X[flip along the first direction]' \
  '(-LR -AP -IS -X -Y -Z)-Y[flip along the second direction]' \
  '(-LR -AP -IS -X -Y -Z)-Z[flip along the third direction]' \
  '-prefix[output dataset prefix name]:prefix:' \
  '*:dataset:_files' && ret=0

return ret
