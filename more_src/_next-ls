#compdef next-ls nextls
# Documentation: https://man.archlinux.org/search?q=next-ls
# Reference accessed: 2026-05-16

# Zsh completion for Next LS (Elixir language server)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--stdio[use stdio transport]' \
  '--port=[port for TCP transport]:port:' && ret=0

return ret
