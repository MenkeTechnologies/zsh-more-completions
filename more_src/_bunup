#compdef bunup
# Documentation: https://bunup.dev/docs/guide/cli-options.html
# bunup - fast, zero-config bundler for TypeScript and JavaScript powered by Bun

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display the menu and exit]' \
  '--entry=[entry file or glob pattern]:entry:_files' \
  '(-c --config)'{-c,--config}'=[path to a custom configuration file]:config:_files' \
  '--no-config[explicitly disable config]' \
  '--filter=[filter workspace packages or config array items by name]:name' \
  '--name=[name of the build configuration]:name' \
  '(-o --out-dir)'{-o,--out-dir}'=[output directory for bundled files (default dist)]:dir:_files -/' \
  '--format=[single output format]:format:(esm cjs iife)' \
  '--minify[enable all minification options]' \
  '--no-minify[explicitly disable minify]' \
  '--minify-whitespace[minify whitespace in the output]' \
  '--minify-identifiers[minify identifiers by renaming variables]' \
  '--minify-syntax[minify syntax by optimizing code structure]' \
  '--watch[watch for file changes and rebuild automatically]' \
  '--clean[clean the output directory before building]' \
  '(-q --silent)'{-q,--silent}'[disable logging during the build process]' \
  '--splitting[enable code splitting]' \
  '--conditions=[package.json export conditions for import resolution]:conditions' \
  '(-t --target)'{-t,--target}'=[target environment for the bundle]:target:(bun node browser)' \
  '--external=[external packages that should not be bundled]:packages' \
  '--packages=[bundle all dependencies or externalize all]:mode:(bundle external)' \
  '--shims[enable shims for Node.js globals]' \
  '--dts[generate TypeScript declaration files (.d.ts)]' \
  '--dts-only[only emit TypeScript declaration files]' \
  '--preferred-tsconfig=[path to custom tsconfig.json file]:file:_files -g "*.json"' \
  '--sourcemap=[generate a sourcemap]:sourcemap' \
  '--banner=[banner text added to top of bundle files]:text' \
  '--footer=[footer text added to bottom of bundle files]:text' \
  '--drop=[remove function calls from bundle]:calls' \
  '--public-path=[public path prefix for assets]:path' \
  '--source-base=[base directory for entry points]:dir:_files -/' \
  '*:entry:_files' && ret=0

return ret
