#compdef iostat
# _iostat — OpenBSD iostat (kernel I/O stats on tty, disk and CPU; -I prints raw counts, -D disk-only, -d disk transfer rate (no MB/s), -T tty-only, -c repeats N times every -w seconds)
# upstream: https://github.com/openbsd/src (usr.sbin/iostat)
# Flags from usr.sbin/iostat/iostat.8 on tip.

_iostat() {
    _arguments \
        '-C[show CPU stats (default unless -D/-d/-T)]' \
        '-D[show disk transfers only]' \
        '-d[show disk transfer rate only]' \
        '-I[show raw counts (unaveraged)]' \
        '-T[show TTY stats]' \
        '-c+[repeat count]:count:' \
        '-M+[core file]:file:_files' \
        '-N+[kernel symbol file]:file:_files' \
        '-w+[wait seconds between reports]:seconds:' \
        '*:drive:'
}

_iostat "$@"
