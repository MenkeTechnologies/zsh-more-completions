#compdef onchange

# Zsh completion for onchange - run a command when files change

_arguments -s -S \
  '(-i --initial)'{-i,--initial}'[run the command on initial start]' \
  '--no-initial[do not run the command initially]' \
  '(-k --kill)'{-k,--kill}'[kill running process and start a new one]' \
  '(-d --delay)'{-d,--delay}'[delay before running the command]:ms:' \
  '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
  '--await-write-finish[await stable file size before triggering]' \
  '(-e --exclude)'{-e,--exclude}'[exclude paths matching pattern]:pattern:' \
  '(-f --filter)'{-f,--filter}'[only react to events matching filter]:filter:' \
  '(-p --poll)'{-p,--poll}'[use polling for file changes]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:pattern:_files'
