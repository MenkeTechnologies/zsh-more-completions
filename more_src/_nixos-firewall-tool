#compdef nixos-firewall-tool
# Documentation: https://wiki.nixos.org/wiki/Firewall
# thin wrapper around iptables/nftables for temporary NixOS firewall changes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    open\:"temporarily open a tcp or udp port"
    show\:"display the current firewall rules"
    reset\:"reset the firewall to its configured state"
    help\:"show usage information"
  ))' \
  '2:protocol:(tcp udp)' \
  '3:port:' && ret=0

return ret
