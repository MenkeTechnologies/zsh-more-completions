#compdef oshcc
# Documentation: https://man.archlinux.org/search?q=oshcc
# Reference accessed: 2026-05-16

# oshcc: OpenSHMEM C compiler driver
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--showme[show compile command, do not run]' \
  '--showme:compile[show compile flags]' \
  '--showme:link[show link flags]' \
  '--showme:command[show command name]' \
  '--showme:incdirs[show include dirs]' \
  '--showme:libdirs[show library dirs]' \
  '--showme:libs[show libraries]' \
  '--showme:version[show OpenSHMEM impl version]' \
  '-c[compile only]' \
  '-o[output file]:file:_files' \
  '-I[include dir]:dir:_files -/' \
  '-L[library dir]:dir:_files -/' \
  '-l[library]:lib:' \
  '*:source files:_files' && ret=0
return ret
