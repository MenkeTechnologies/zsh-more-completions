#compdef oshcc
# Documentation: https://docs.open-mpi.org/en/main/man-openshmem/man1/oshmem-wrapper-compiler.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org search URL.

# oshcc: OpenSHMEM C compiler wrapper (Open MPI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--showme[show command that would be executed, do not run]' \
  '--showme:compile[show compiler flags]' \
  '--showme:link[show linker flags]' \
  '--showme:command[show underlying compiler command]' \
  '--showme:incdirs[show include directories]' \
  '--showme:libdirs[show library directories]' \
  '--showme:libs[show libraries]' \
  '--showme:version[show Open MPI version]' \
  '--showme:help[show showme help]' \
  '-c[compile only]' \
  '-o+[output file]:file:_files' \
  '-I+[include dir]:dir:_files -/' \
  '-L+[library dir]:dir:_files -/' \
  '-l+[library]:lib:' \
  '*:source files:_files' && ret=0
return ret
