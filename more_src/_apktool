#compdef apktool
# Documentation: https://ibotpeaches.github.io/Apktool/
# Source: iBotPeaches/Apktool brut.apktool/apktool-cli/src/main/java/brut/apktool/Main.java — Android APK decoder/builder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(-v --verbose -q --quiet)'{-v,--verbose}'[increase output verbosity]' \
    '(-v --verbose -q --quiet)'{-q,--quiet}'[suppress normal output]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'd:decode an APK'
            'decode:decode an APK'
            'b:build an APK from decoded files'
            'build:build an APK from decoded files'
            'if:install framework files'
            'install-framework:install framework files'
            'cf:clean framework directory'
            'clean-frameworks:clean framework directory'
            'lf:list installed frameworks'
            'list-frameworks:list installed frameworks'
            'pr:publicize resources in an ARSC file'
            'publicize-resources:publicize resources in an ARSC file'
            'h:help'
            'help:help'
            'v:version'
            'version:version'
        )
        _describe -t subcmds 'apktool command' subcmds && ret=0
        ;;
    args)
        case $words[1] in
            d|decode)
                _arguments \
                    '(-a --all-src)'{-a,--all-src}'[decode all sources (includes unknown dex)]' \
                    '(-f --force)'{-f,--force}'[force delete destination directory]' \
                    '(-r --no-res)'{-r,--no-res}'[do not decode resources]' \
                    '(-s --no-src)'{-s,--no-src}'[do not decode sources]' \
                    '(-o --output)'{-o+,--output=}'[output directory (default: apk.out)]:dir:_directories' \
                    '(-p --frame-path)'{-p+,--frame-path=}'[framework files directory]:dir:_directories' \
                    '(-t --frame-tag)'{-t+,--frame-tag=}'[framework files tag]:tag:' \
                    '(-j --jobs)'{-j+,--jobs=}'[parallel job count]:n:' \
                    '*'{-l,--lib=}'[shared library package=path]:pkg=file:' \
                    '--no-debug-info[do not include debug info (.local/.param/.line)]' \
                    '--only-manifest[only decode AndroidManifest.xml without resources]' \
                    '--res-resolve-mode=[resource resolve mode]:mode:(default greedy lazy)' \
                    '--keep-broken-res[keep broken resources (decode even on error)]' \
                    '--ignore-raw-values[ignore raw attribute values in XML]' \
                    '--match-original[keep files closest to original (prevents rebuild)]' \
                    '--no-assets[do not decode assets]' \
                    '*:APK file:_files -g "*.apk"' \
                    && ret=0
                ;;
            b|build)
                _arguments \
                    '(-f --force)'{-f,--force}'[skip change-detection; rebuild all]' \
                    '(-o --output)'{-o+,--output=}'[output APK file (default dist/name.apk)]:file:_files' \
                    '(-p --frame-path)'{-p+,--frame-path=}'[framework files directory]:dir:_directories' \
                    '(-j --jobs)'{-j+,--jobs=}'[parallel job count]:n:' \
                    '*'{-l,--lib=}'[shared library package=path]:pkg=file:' \
                    '--no-apk[disable repacking files into a new APK]' \
                    '--no-crunch[disable resource-file crunching]' \
                    '--copy-original[copy original AndroidManifest.xml and META-INF]' \
                    '--debuggable[set android:debuggable=true in manifest]' \
                    '--net-sec-conf[add generic network security configuration]' \
                    '--aapt=[aapt2 binary path]:file:_files' \
                    '*:decoded dir:_directories' \
                    && ret=0
                ;;
            if|install-framework|cf|clean-frameworks|lf|list-frameworks)
                _arguments \
                    '(-p --frame-path)'{-p+,--frame-path=}'[framework files directory]:dir:_directories' \
                    '(-t --frame-tag)'{-t+,--frame-tag=}'[framework files tag]:tag:' \
                    '(-a --all)'{-a,--all}'[include all framework files regardless of tag]' \
                    '*:framework file:_files' \
                    && ret=0
                ;;
            *)
                _files
                ;;
        esac
        ;;
esac

return ret
