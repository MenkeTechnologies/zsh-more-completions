#compdef bluetoothctl-cli
# _bluetoothctl-cli — BlueZ bluetoothctl Linux bluetooth control CLI alias (bluez team, C); custom argparse
# upstream: https://github.com/bluez/bluez

_bluetoothctl-cli() {
    local -a sub=(
        'list:list controllers'
        'show:show controller info'
        'select:select default controller'
        'power:set controller power'
        'pairable:set pairable mode'
        'discoverable:set discoverable mode'
        'discoverable-timeout:set discoverable timeout'
        'agent:enable/disable agent'
        'default-agent:set default agent'
        'system-alias:set system alias'
        'reset-alias:reset alias'
        'advertise:set advertise'
        'advertise-uuids:set advertise uuids'
        'advertise-service:set advertise service'
        'advertise-manufacturer:set advertise manufacturer'
        'advertise-data:set advertise data'
        'advertise-discoverable:set advertise discoverable'
        'advertise-discoverable-timeout:set advertise disc timeout'
        'advertise-tx-power:set advertise tx power'
        'advertise-name:set advertise name'
        'advertise-appearance:set advertise appearance'
        'advertise-secondary:set secondary advertising'
        'advertise-interval:set advertising interval'
        'advertise-rsi:set RSI flag'
        'scan:start/stop scan'
        'scan-filter-uuids:set scan filter uuids'
        'scan-filter-rssi:set scan filter rssi'
        'scan-filter-pathloss:set scan filter pathloss'
        'scan-filter-transport:set scan filter transport'
        'scan-filter-duplicate-data:set scan filter dup data'
        'scan-filter-discoverable:set scan filter discoverable'
        'scan-filter-clear:clear scan filter'
        'devices:list devices'
        'paired-devices:list paired devices'
        'pair:pair device'
        'cancel-pairing:cancel pairing'
        'trust:trust device'
        'untrust:untrust device'
        'block:block device'
        'unblock:unblock device'
        'remove:remove device'
        'connect:connect to device'
        'disconnect:disconnect from device'
        'info:show device info'
        'menu:open menu'
        'back:exit menu'
        'help:show help'
        'quit:quit bluetoothctl'
        'exit:exit bluetoothctl'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--agent=+[capability]:c:(DisplayOnly DisplayYesNo KeyboardOnly NoInputNoOutput KeyboardDisplay)' \
        '-a+[capability]:c:(DisplayOnly DisplayYesNo KeyboardOnly NoInputNoOutput KeyboardDisplay)' \
        '--endpoints[set up audio endpoints]' \
        '-e[set up audio endpoints]' \
        '--timeout=+[seconds]:n:' \
        '-t+[seconds]:n:' \
        '--init-script=+[file]:file:_files' \
        '-i+[file]:file:_files' \
        '--monitor[monitor mode]' \
        '-m[monitor mode]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bluetoothctl subcommand' sub ;;
        args)
            case $words[1] in
                pair|trust|untrust|block|unblock|remove|connect|disconnect|info|cancel-pairing) _arguments '*:device MAC:' ;;
                power|pairable|discoverable|agent|advertise|scan) _arguments '1:state:(on off)' ;;
            esac
            ;;
    esac
}

_bluetoothctl-cli "$@"
