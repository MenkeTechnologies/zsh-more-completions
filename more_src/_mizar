#compdef mizar mizf
# Documentation: https://man.archlinux.org/search?q=mizar
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-l+[long lines limit]:n:' \
  '-s[silent mode]' \
  '-q[quiet]' \
  '*:mizar file:_files -g "*.miz"' && ret=0

return ret
