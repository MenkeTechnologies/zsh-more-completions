#compdef dcp
# Documentation: https://man.archlinux.org/search?q=dcp
# Reference accessed: 2026-05-16

# exdx/dcp — `src/config.rs` (clap 2)

local ret=1
_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[version]' \
  '-d+[download path on host]:dir:_files -/' \
  '-c+[path inside container image]:container-path:' \
  '-w[write archive stream to stdout instead of filesystem]' \
  '-u+[registry username]:user:' \
  '-p+[registry password]:password:' \
  '-l+[log level (info debug trace error warn)]:level:(info debug trace error warn)' \
  '-f[force pull even if image exists locally]' \
  '-s+[container runtime socket]:socket:_files' \
  '1:container image: ' && ret=0
return ret
