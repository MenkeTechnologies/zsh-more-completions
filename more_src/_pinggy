#compdef pinggy
# Documentation: https://man.archlinux.org/search?q=pinggy
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-R --R)'{-R+,--R=}'[remote port forwarding (SSH-style)]:spec (e.g. 0\:localhost\:3000):' \
  '(-L --L)'{-L+,--L=}'[local port forwarding (SSH-style)]:spec (e.g. 4300\:localhost\:4300):' \
  '(-p --server-port)'{-p+,--server-port=}'[Pinggy server port]:port:(443 80)' \
  '--type=[tunnel type]:type:(http tcp tls udp tlstcp)' \
  '(-l --localport)'{-l+,--localport=}'[local endpoint protocol\:host\:port]:endpoint:' \
  '(-d --debugger)'{-d+,--debugger=}'[web debugger port]:port:' \
  '--token=[authentication token]:token:' \
  '--force[force close existing tunnels]' \
  '--loglevel=[log level]:level:(ERROR INFO DEBUG)' \
  '--logfile=[log file path]:file:_files' \
  '(-v --v)'{-v,--v}'[print logs to stdout]' \
  '--vv[detailed logs (SDK + libpinggy)]' \
  '--vvv[full logs (CLI + SDK + libpinggy)]' \
  '--saveconf=[save configuration to file]:file:_files' \
  '--conf=[load configuration from file]:file:_files' \
  '--serve=[serve directory via simple web server]:dir:_files -/' \
  '(-a --autoreconnect)'{-a,--autoreconnect}'[auto-reconnect on failure]' \
  '--remote-management=[enable remote tunnel control]:token:' \
  '--manage=[remote management server]:address:' \
  '--NoTui[disable terminal UI]' \
  '*::extended_or_user_at_host:' && ret=0

return ret
