#compdef TestVHACD
# Documentation: https://github.com/kmammou/v-hacd
# TestVHACD - approximate convex decomposition (V-HACD) command-line tool

local ret=1

_arguments -s -S \
  '-h[maximum number of output convex hulls (default 32, 1-100000)]:count:' \
  '-r[total number of voxels to use (default 100000, 10000-10000000)]:voxels:' \
  '-e[volume error allowed as a percentage (default 1, 0.001-10)]:percent:' \
  '-d[maximum recursion depth (default 10, 2-64)]:depth:' \
  '-s[shrinkwrap output to source mesh (default true)]:bool:(true false t f 1 0)' \
  '-f[fill mode (default flood)]:mode:(flood surface raycast)' \
  '-v[max vertices in output convex hull (default 64, 8-2048)]:count:' \
  '-a[run asynchronously (default true)]:bool:(true false t f 1 0)' \
  '-l[minimum size of a voxel edge (default 2, 1-32)]:size:' \
  '-p[split plane optimization mode (default false)]:bool:(true false t f 1 0)' \
  '-o[export format for convex hulls]:format:(obj stl usda)' \
  '-g[enable/disable logging display (default true)]:bool:(true false t f 1 0)' \
  '*:wavefront obj:_files -g "*.obj"' && ret=0

return ret
