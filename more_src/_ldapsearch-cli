#compdef ldapsearch-cli
# _ldapsearch-cli — OpenLDAP ldapsearch LDAP search tool CLI alias (openldap team, C); custom argparse
# upstream: https://git.openldap.org/openldap/openldap

_ldapsearch-cli() {
    _arguments \
        '--help[show help]' \
        '-h+[ldap host]:host:_hosts' \
        '-H+[URI]:url:_urls' \
        '-p+[port]:port:' \
        '-D+[bind DN]:str:' \
        '-w+[bind password]:str:' \
        '-W[prompt for password]' \
        '-y+[password file]:file:_files' \
        '-x[simple authentication]' \
        '-O+[SASL security props]:str:' \
        '-N[no canonical resolution]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-n[show what would be done]' \
        '-d+[debug level]:n:' \
        '-A[retrieve attribute names only]' \
        '-L[print as LDIFv1]' \
        '-LL[print as LDIF without comments]' \
        '-LLL[print as LDIF without comments or version]' \
        '-M[manage DSA IT]' \
        '-MM[manage DSA IT (critical)]' \
        '-S+[sort attribute]:str:' \
        '-s+[scope]:s:(base one sub children)' \
        '-b+[base DN]:str:' \
        '-l+[time limit seconds]:n:' \
        '-z+[size limit]:n:' \
        '-a+[alias deref]:m:(never always search find)' \
        '-c[continuous mode]' \
        '-e+[ext]:str:' \
        '-E+[search extension]:str:' \
        '-f+[file with input]:file:_files' \
        '-F+[URL prefix]:str:' \
        '-i+[input file]:file:_files' \
        '-I[interactive SASL]' \
        '-Q[quiet SASL]' \
        '-R+[SASL realm]:str:' \
        '-T+[file path prefix]:dir:_files -/' \
        '-U+[SASL authcid]:str:' \
        '-X+[SASL authzid]:str:' \
        '-Y+[SASL mechanism]:str:' \
        '-Z[StartTLS]' \
        '-ZZ[StartTLS required]' \
        '-o+[option]:str:' \
        '-t[write values to files]' \
        '-tt[write all values to files]' \
        '-u[include user friendly DN]' \
        '*:filter and attrs:'
}

_ldapsearch-cli "$@"
