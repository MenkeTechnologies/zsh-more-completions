#compdef ejabberdctl
# Documentation: https://man.archlinux.org/search?q=ejabberdctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start ejabberd'
  'debug:attach interactive Erlang shell'
  'live:start in foreground with interactive shell'
  'help:show help'
  'status:show server status'
  'stop:stop ejabberd'
  'restart:restart ejabberd'
  'mnesia:Mnesia info'
  'register:register a user'
  'unregister:unregister a user'
  'change_password:change a user password'
  'kick_user:kick user sessions'
  'backup:backup ejabberd database'
  'restore:restore database from backup'
  'dump_table:dump Mnesia table'
  'install_fallback:install fallback'
  'mnesia_change_nodename:change Mnesia node name'
  'set_loglevel:set loglevel'
  'get_loglevel:get loglevel'
)

_arguments -C \
  '(-n --node)'{-n,--node}'=[Erlang node name]:node:' \
  '(-s --spool)'{-s,--spool}'=[spool dir]:dir:_files -/' \
  '(-l --logs)'{-l,--logs}'=[log dir]:dir:_files -/' \
  '(-f --config)'{-f,--config}'=[ejabberd config]:file:_files' \
  '(-c --ctl-config)'{-c,--ctl-config}'=[ejabberdctl config]:file:_files' \
  '(-d --config-dir)'{-d,--config-dir}'=[config dir]:dir:_files -/' \
  '(-t --no-timeout)'{-t,--no-timeout}'[no command timeout]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ejabberdctl subcommand' subcommands && ret=0
    ;;
esac

return ret
