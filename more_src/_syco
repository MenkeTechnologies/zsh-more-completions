#compdef syco
# Documentation: https://github.com/systemconsole/syco
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS syco: synonymous codon usage Gribskov statistic plot
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout filter mode]' '-options[prompt for std qualifiers]' \
  '-debug[debug log]' '-verbose[verbose]' '-warning[report warnings]' \
  '-error[report errors]' '-fatal[fatal errors]' '-die[dying messages]' \
  '-version[report version]' '-outfile=[output filename]:file:_files' \
  '-sequence=[DNA sequence(s)]:file:_files' \
  '-cfile=[codon usage file]:file:_files' \
  '-graph=[graph format]:fmt:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-window=[window length]:n:' \
  '-uncommon[plot uncommon codons]' \
  '-minimum=[minimum value to plot]:val:' \
  '*:DNA sequence:_files' && ret=0

return ret
