#compdef tstables
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tstables.cpp
# tstables - collect and dump PSI/SI tables from a transport stream

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--list-dvb-charset-order[list DVB character sets in preferred order]' \
  '--list-descriptors[list all supported PSI/SI descriptors]' \
  '--list-tables[list all supported PSI/SI tables]' \
  '--dump-psi-repository[dump internal state of the PSI repository (debug)]' \
  '*:ts file:_files -g "*.ts *.m2ts *.mpg"' && ret=0

return ret
