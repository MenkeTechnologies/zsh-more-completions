#compdef megacopy
# megacopy — sync local and remote directories

local curcontext="$curcontext" ret=1

_arguments -s -S \
  {-l,--local}'=[local directory path]:local path:_files -/' \
  {-r,--remote}'=[remote directory path]:remote path:' \
  {-d,--download}'[download files from MEGA]' \
  {-n,--dryrun}'[show what would be done without making changes]' \
  '--no-progress[disable progress indicator]' \
  '--limit-speed=[limit transfer speed]:speed:' \
  '--no-follow-symlinks[do not follow symbolic links]' \
  '--disable-resume[disable resuming of interrupted transfers]' \
  '--config=[load configuration from a file]:config file:_files' \
  '--ignore-config-file[do not load configuration file]' \
  '--debug=[enable debugging output]:debug flags:' \
  '(- *)--version[show version]' \
  '--reload[reload filesystem cache]' \
  '--no-ask-password[never ask interactively for a password]' \
  '--disable-previews[do not generate previews on upload]' && ret=0

return ret
