#compdef swaybar
# Documentation: https://github.com/swaywm/sway/blob/master/swaybar/main.c
# Reference accessed: 2026-05-21
# Verified: upstream source at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-s --socket)'{-s+,--socket=}'[connect to sway via socket]:socket:_files' \
  '(-b --bar_id)'{-b+,--bar_id=}'[bar ID for which to get the configuration]:id' \
  '(-d --debug)'{-d,--debug}'[enable debugging]' && ret=0

return ret
