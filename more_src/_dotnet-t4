#compdef dotnet-t4 t4
# Documentation: https://github.com/mono/t4/blob/main/dotnet-t4/readme.md
# dotnet-t4 - T4 text template transformation tool

local ret=1

_arguments -s -S \
  '(-h -\? --help)'{-h,-\?,--help}'[display help information]' \
  '(-v --verbose)'{-v,--verbose}'[output additional diagnostic information]' \
  '(-o --out)'{-o,--out}'=[output file name or path]:file:_files' \
  '*-r=[add an assembly reference by path or name]:assembly:_files' \
  '*'{-u,--using}'=[import a namespace via using statement]:namespace:' \
  '*-I=[add a directory for resolving included files]:dir:_files -/' \
  '*-P=[add a directory for resolving assemblies]:dir:_files -/' \
  '(-c --class)'{-c,--class}'=[preprocess template into a class for runtime use]:name:' \
  '(-l --useRelativeLinePragmas)'{-l,--useRelativeLinePragmas}'[use relative paths in line pragmas]' \
  '*'{-p,--parameter}'=[set a session parameter]:name=value:' \
  '--debug[generate debug symbols and retain temporary files]' \
  '*--dp=[configure a directive processor]:directive!class!assembly:' \
  '*-a=[set a host parameter with optional scope]:processor!directive!name!value:' \
  '*:template:_files -g "*.tt"' && ret=0

return ret
