#compdef rmclean
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/rmclean.html
# Run RM-CLEAN on a set of dirty rm-cubes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'inq=[inq keyword]:inq:' \
  'inu=[inu keyword]:inu:' \
  'freq=[freq keyword]:freq:' \
  'weight=[weight keyword]:weight:' \
  'nmax=[nmax keyword]:nmax:' \
  'gain=[gain keyword]:gain:' \
  'cutoff=[cutoff keyword]:cutoff:' \
  'fwhm=[fwhm keyword]:fwhm:' \
  'method=[method keyword]:method:' \
  'outq=[outq keyword]:outq:' \
  'outu=[outu keyword]:outu:' \
  'modq=[modq keyword]:modq:' \
  'modu=[modu keyword]:modu:' \
  'resq=[resq keyword]:resq:' \
  'resu=[resu keyword]:resu:' \
  'ni=[ni keyword]:ni:' \
  'derot=[derot keyword]:derot:' \
  'debug=[debug keyword]:debug:' \
  '*:visibility dataset:_files' && ret=0

return ret
