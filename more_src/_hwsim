#compdef hwsim
# Documentation: https://man.archlinux.org/man/extra/iwd/hwsim.1.en
# hwsim — iwd Internet wireless simulation utility for the mac80211_hwsim driver

local ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version number and exit]' \
  '(-h --help)'{-h,--help}'[show help message and exit]' && ret=0

return ret
