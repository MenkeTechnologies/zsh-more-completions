#compdef dpdk-proc-info
# Documentation: https://doc.dpdk.org/guides/tools/proc_info.html
# DPDK secondary process to retrieve and print statistics

local ret=1

_arguments -s -S \
  '-p+[hexadecimal bitmask of ports to configure]:portmask' \
  '-m[display DPDK memory information]' \
  '--stats[print generic port statistics]' \
  '--xstats=-[print extended port statistics]::hide_zero' \
  '--stats-reset[reset generic port statistics]' \
  '--xstats-reset[reset extended port statistics]' \
  '--show-port[display port configuration and RX queue info]' \
  '--show-tm[display per port traffic manager settings]' \
  '--show-crypto[show cryptodev configurations and stats]' \
  '--show-ring=-[display ring allocation info]::name' \
  '--show-mempool=-[display mempool allocation]::name' \
  '--iter-mempool=[iterate and display mempool elements]:name' \
  '--show-port-private[display port private information]' \
  '--version[show DPDK version]' \
  '--firmware-version[show ethdev firmware version]' \
  '--show-rss-reta[display port RSS redirection table]' \
  '--show-module-eeprom[display port module EEPROM information]' \
  '--show-rx-descriptor=[display Rx descriptor info]:queue_id\:offset\:num' \
  '--show-tx-descriptor=[display Tx descriptor info]:queue_id\:offset\:num' \
  '--show-edev-queue-xstats=[display eventdev queue stats]:queue_num\:evdev_id' \
  '--show-edev-port-xstats=[display eventdev port stats]:port_num\:evdev_id' \
  '--edev-dump-xstats=[dump all eventdev stats]:evdev_id' \
  '--edev-reset-xstats=[reset eventdev extended stats]:evdev_id' \
  '--show-edev-device-xstats=[display eventdev device extended stats]:evdev_id' && ret=0

return ret
