# Reference accessed: 2026-05-22
# Verified: src/cli.ts parseArgs and --help output.

# Zsh completion for void-agent - Void agent loop CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--cwd[workspace root]:directory:_directories' \
  '--model[model name]:model:' \
  '--base-url[OpenAI-compatible API base URL]:url:' \
  '--system[extra system prompt]:text:' \
  '--system-file[system prompt from file]:file:_files' \
  '*:message:' && ret=0

return ret
