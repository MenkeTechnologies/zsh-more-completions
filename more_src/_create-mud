#compdef create-mud
# Documentation: https://www.npmjs.com/package/create-mud
# Reference accessed: 2026-05-24
# Verified: npm view create-mud bin; npx create-mud --help output.

# Zsh completion for create-mud - MUD game client scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--interactive[run interactive prompts (default)]'   '--no-interactive[skip interactive prompts]'   '--name=[project name]:name:'   '--template=[template to scaffold]:template:(react react-ecs phaser threejs vanilla)'   '--mud-version=[MUD package version]:version:'   '(-h --help)'{-h,--help}'[show help]'   '(-v --version)'{-v,--version}'[show version number]'   '*:arguments:' && ret=0

return ret
