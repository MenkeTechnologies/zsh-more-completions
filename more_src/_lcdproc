#compdef lcdproc LCDd
# Documentation: https://manpages.org/lcdproc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (and LCDd(8) man page).

local curcontext="$curcontext" ret=1

case $service in
  (LCDd)
    _arguments \
      '(- *)-h[display help screen]' \
      '-c+[use configuration file]:file:_files' \
      '*-d+[driver to use]:driver:' \
      '-f[run in the foreground]' \
      '-i+[show LCDproc server screen in rotation]:bool:(0 1)' \
      '-w+[time to pause at each screen]:seconds:' \
      '-a+[bind to network address]:addr:' \
      '-p+[listen on port]:port:' \
      '-u+[run as user]:user:_users' \
      '-s+[output messages to syslog (1) or stdout (0)]:bool:(0 1)' \
      '-r+[set reporting level]:level:(0 1 2 3 4 5)' && ret=0 ;;
  (*)
    _arguments \
      '(- *)-h[display help]' \
      '(- *)-v[show version]' \
      '-c+[alternate configuration file]:file:_files' \
      '-s+[LCDd server host]:host:_hosts' \
      '-p+[LCDd server port]:port:' \
      '-f[run in foreground mode]' \
      '-e+[screen update delay in 1/100s]:delay:' \
      '*:screens:' && ret=0 ;;
esac

return ret
