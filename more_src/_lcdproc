#compdef lcdproc LCDd
# Documentation: https://man.archlinux.org/search?q=lcdproc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

case $service in
  (LCDd)
    _arguments \
      '(- *)-h[show help]' \
      '-c+[config file]:file:_files' \
      '-d+[driver]:driver:' \
      '-f[run in foreground]' \
      '-i+[reporting level 0-5]:level:(0 1 2 3 4 5)' \
      '-s+[report to stderr]:flag:(0 1)' \
      '-w+[wait time msec]:ms:' \
      '-b+[backlight mode]:mode:(on off open)' \
      '-a+[listen address]:addr:' \
      '-p+[listen port]:port:' \
      '-u+[user]:user:_users' && ret=0 ;;
  (*)
    _arguments \
      '(- *)-h[show help]' \
      '-c[use cycling screens]' \
      '-d+[server delay msec]:ms:' \
      '-f[run in foreground]' \
      '-r+[reporting level 0-5]:level:(0 1 2 3 4 5)' \
      '-s+[server host:port]:host:_hosts' \
      '-v[show version]' \
      '*:screens:' && ret=0 ;;
esac

return ret
