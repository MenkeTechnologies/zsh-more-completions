#compdef pagerduty-cli2 pd2
# _pagerduty-cli2 — PagerDuty pagerduty-cli2 CLI command-line frontend wrapping the PagerDuty incident management on-call paging platform REST API providing auth incident service team escalation-policy schedule user oncall change events extension business-service maintenance-window analytics rest-api-key audit log-entries response-play subscriber post-mortem (PagerDuty team, TypeScript); oclif
# upstream: https://github.com/PagerDuty/pagerduty-cli

_pagerduty-cli2() {
    local -a sub=(
        'auth:authenticate'
        'incident:incident operations'
        'service:service operations'
        'team:team operations'
        'escalation-policy:escalation policy operations'
        'schedule:schedule operations'
        'user:user operations'
        'oncall:oncall operations'
        'change:change event operations'
        'event:event operations'
        'extension:extension operations'
        'maintenance-window:maintenance window operations'
        'business-service:business service operations'
        'response-play:response play operations'
        'rest:raw REST call'
        'analytics:analytics'
        'audit:audit log'
        'log-entry:log entry operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--token=+[token]:str:' \
        '--subdomain=+[name]:str:' \
        '--alias=+[name]:str:' \
        '--profile=+[name]:str:' \
        '--email=+[email]:str:' \
        '-o+[format]:f:(json yaml table csv)' \
        '--output=+[format]:f:(json yaml table csv)' \
        '--columns=+[cols]:str:' \
        '--filter=+[expr]:str:' \
        '--sort=+[col]:str:' \
        '--no-header[no header]' \
        '--no-truncate[no truncate]' \
        '--csv[csv output]' \
        '--keys=+[k=v]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pd subcommand' sub ;;
        args)
            case $words[1] in
                incident|service|team|escalation-policy|schedule|user|extension|maintenance-window|business-service|response-play) _arguments '1:op:(list get create update delete acknowledge resolve reassign snooze open close)' '*:id:' ;;
                auth) _arguments '1:op:(set get clear web-login)' '*:arg:' ;;
                oncall) _arguments '1:op:(list current)' '*:arg:' ;;
                rest) _arguments '1:method:(GET POST PUT DELETE PATCH)' '2:path:' ;;
            esac
            ;;
    esac
}

_pagerduty-cli2 "$@"
