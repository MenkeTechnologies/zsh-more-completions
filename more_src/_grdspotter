#compdef grdspotter
# GMT supplements/spotter — create CVA grid from gravity/topography and rotations

local ret=1

_arguments -s \
  '-E+[rotation parameters file/IDs/lon-lat-angle]:rot:_default' \
  '-G+[output grid file]:file:_files' \
  '-I+[grid spacing dx/dy]:spacing:_default' \
  '-R+[region west/east/south/north]:region:_default' \
  '-A+[crustal age grid]:file:_files' \
  '-D+[output DI or PA grids]:opts:_default' \
  '-L+[seamount chain ID grid (needs -Q)]:file:_files' \
  '-M[compute flowlines on-the-fly to save memory]' \
  '-N+[upper age for unknown crustal age nodes]:age:_default' \
  '-Q+[IDs to use (needs -L)]:ids:_default' \
  '-S[normalize CVA grid to percentages]' \
  '-T+[truncate or fixed age handling]:opts:_default' \
  '-W+[bootstrap estimates of max CVA location]:n:_default' \
  '-Z+[filter z-values or multi-slice CVA]:opts:_default' \
  '*-V[verbose (stackable)]' \
  '-r[pixel registration]' \
  '*:input grid:_files' \
  && ret=0

return ret
