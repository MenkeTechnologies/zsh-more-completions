#compdef envbuilder
# Devcontainer image builder by Coder
# Reference: https://github.com/coder/envbuilder

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--devcontainer-dir=[path to devcontainer directory]:directory:_files -/' \
  '--devcontainer-json-path=[path to devcontainer.json]:file:_files -g "*.json"' \
  '--dockerfile-path=[path to Dockerfile]:file:_files' \
  '--build-context-path=[path to build context]:directory:_files -/' \
  '--cache-repo=[container registry for layer caching]:repo:' \
  '--cache-ttl-days=[cache TTL in days]:days:' \
  '--docker-config-base64=[base64-encoded Docker config]:config:' \
  '--fallback-image=[image to use if build fails]:image:' \
  '--force-safe[force safe mode]' \
  '--git-clone-depth=[git clone depth]:depth:' \
  '--git-clone-single-branch[clone only a single branch]' \
  '--git-http-proxy-url=[HTTP proxy URL for git]:url:' \
  '--git-ssh-private-key-path=[path to SSH private key for git]:file:_files' \
  '--git-url=[git repository URL]:url:' \
  '--git-username=[git username]:username:' \
  '--init-command=[command to run on init]:command:' \
  '--init-script=[script to run on init]:script:' \
  '--insecure[allow insecure connections]' \
  '--layer-cache-dir=[directory for layer cache]:directory:_files -/' \
  '--post-start-script-path=[path to post-start script]:file:_files' \
  '--push-image[push the built image to registry]' \
  '--remote-repo-build-mode[build from remote repository]' \
  '--setup-script=[setup script to run]:script:' \
  '--skip-rebuild[skip rebuild if image exists]' \
  '--verbose[enable verbose output]' \
  '--workspace-folder=[workspace folder path]:directory:_files -/' && ret=0

return ret
