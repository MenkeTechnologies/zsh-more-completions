#compdef esl-histplot
# Easel: collate data histogram, output xmgrace datafile

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-f+[read data from whitespace-delimited field n (default 1)]:n' \
  '-o+[direct output to file instead of stdout]:file:_files' \
  '*:data file:_files' && ret=0

return ret
