#compdef sfadd
# Documentation: https://raw.githubusercontent.com/ahay/src/master/system/main/add.c
# Madagascar: add, multiply, or divide RSF datasets

local ret=1

_arguments -s \
  'scale=[scalar values to multiply each dataset with]:scale' \
  'add=[scalar values to add to each dataset]:add' \
  'sqrt=[if y take square root]:sqrt:(y n)' \
  'abs=[if y take absolute value]:abs:(y n)' \
  'log=[if y take logarithm]:log:(y n)' \
  'exp=[if y compute exponential]:exp:(y n)' \
  'mode=[operation: a=add p/m=multiply d=divide]:mode:(a p m d)' \
  '*:RSF file:_files' && ret=0

return ret
