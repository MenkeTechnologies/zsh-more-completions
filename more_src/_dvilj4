#compdef dvilj dvilj2p dvilj4 dvilj4l dvilj6
# Documentation: dvilj --help (dviljk 2.6p5)
# Source: TeX dviljk family — DVI -> HP LaserJet PCL drivers.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c-[number of copies]:n:' \
    '-C-[compression mode for raster chars]:n:(0 2 3)' \
    '-d-[duplex (1=long-edge / 2=short-edge)]:mode:(1 2)' \
    '(-D)-D-[doublepage output (1=odd / 2=even)]::mode:(1 2)' \
    '-E[econo-mode printing]' \
    '-e-[output file]:file:_files' \
    '-f-[first page number]:n:' \
    '-g[do not reset printer at job begin]' \
    '-h-[header file]:file:_files' \
    '-l[landscape mode]' \
    '-M-[do not generate missing PK files]:flag:' \
    '-m-[magnification]:mag:(0 h 1 2 3 4 5)' \
    '-n[download fonts raw (default compressed)]' \
    '-p-[number of pages]:n:' \
    '-q[quiet]' \
    '-r[reverse page order]' \
    '-R-[resolution]:dpi:(300 600)' \
    '-s-[paper size]:size:' \
    '-t-[last page number]:n:' \
    '-w[no warnings]' \
    '-W-[min width of compressed chars]:n:' \
    '-v[show pixel files used]' \
    '-V-[vendor options]:vendor:(kyocera brother)' \
    '-x-[x-offset (mm)]:mm:' \
    '-y-[y-offset (mm)]:mm:' \
    '-X-[x page origin in dots (default 432)]:dots:' \
    '-Y-[y page origin in dots (default 600)]:dots:' \
    '-z[print test page with pagecounter]' \
    '*:DVI file (use - for stdin):_files -g "*.dvi"' \
    && ret=0

return ret
