#compdef btrfs-restore

_arguments -s \
  '(-s --snapshots)'{-s,--snapshots}'[recover snapshots]' \
  '(-x --xattr)'{-x,--xattr}'[restore extended attributes]' \
  '(-m --metadata)'{-m,--metadata}'[restore owner/mode/times]' \
  '(-S --symlinks)'{-S,--symlinks}'[restore symlinks]' \
  '(-i --ignore-errors)'{-i,--ignore-errors}'[continue past errors]' \
  '(-o --overwrite)'{-o,--overwrite}'[overwrite existing]' \
  '-t+[root tree byte offset]:bytenr:' \
  '-f+[subvolume root bytenr filter]:bytenr:' \
  '(-u --super)'{-u,--super=}'[superblock mirror]:mirror:(0 1 2)' \
  '(-r --root)'{-r,--root=}'[restore subvolume objectid]:rootid:' \
  '-d[find directory]' \
  '(-l --list-roots)'{-l,--list-roots}'[list subvolume tree roots]' \
  '(-D --dry-run)'{-D,--dry-run}'[list without restoring]' \
  '--path-regex=[restore matching regex]:regex:' \
  '-c[ignore case (with --path-regex)]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  ':device:_files' \
  ':path:_files -/'
