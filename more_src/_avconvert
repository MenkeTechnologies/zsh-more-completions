#compdef avconvert
# Documentation: avconvert --help (macOS 26)
# Source: Apple AVFoundation-based media converter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local presets=(
    Preset640x480 Preset960x540 Preset1280x720 Preset1920x1080 Preset3840x2160
    PresetAppleM4A PresetAppleM4V480pSD PresetAppleM4V720pHD PresetAppleM4V1080pHD
    PresetAppleM4VAppleTV PresetAppleM4VCellular PresetAppleM4ViPod PresetAppleM4VWiFi
    PresetAppleProRes422LPCM PresetAppleProRes4444LPCM
    PresetHEVC1920x1080 PresetHEVC1920x1080WithAlpha PresetHEVC3840x2160 PresetHEVC3840x2160WithAlpha
    PresetHEVC4320x2160 PresetHEVC7680x4320 PresetHEVCHighestQuality PresetHEVCHighestQualityWithAlpha
    PresetHighestQuality PresetLowQuality PresetMediumQuality
    PresetMVHEVC960x960 PresetMVHEVC1440x1440 PresetMVHEVC4320x4320 PresetMVHEVC7680x7680
    PresetPassthrough
)

_arguments -s \
    '(- *)'{-h,--help}'[print usage and list presets]' \
    '(-p --preset)'{-p+,--preset=}'[preset name]:preset:('"$presets"')' \
    '(-s --source)'{-s+,--source=}'[source media file]:source:_files' \
    '(-o --output)'{-o+,--output=}'[output movie file]:output:_files' \
    '--disableFastStart[disable fast-start movie creation]' \
    '--disableMetadataFilter[disable the metadata filter (use with caution)]' \
    '--disableSpatialConversion[disable automatic spatial/spherical/immersive conversion]' \
    '--duration=[trim output to N seconds]:seconds:' \
    '--multiPass[higher-quality multi-pass encode]' \
    '(-prog --progress)'{-prog,--progress}'[display progress information]' \
    '--replace[overwrite existing output file]' \
    '--sourceProjection=[projection of source]:projection:(Equirectangular HalfEquirectangular)' \
    '--sourceViewPacking=[view packing of source]:packing:(SideBySide OverUnder)' \
    '--start=[skip first N seconds of source]:seconds:' \
    '--useAlternateLensCalibration=[lens calibration media file]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[verbose conversion]' \
    && ret=0

return ret
