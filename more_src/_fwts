#compdef fwts
# Documentation: https://man.archlinux.org/search?q=fwts
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-a --all)'{-a,--all}'[run all tests]' \
  '(-b --batch)'{-b,--batch}'[run batch tests]' \
  '(-i --interactive)'{-i,--interactive}'[run interactive tests]' \
  '(-A --acpitests)'{-A,--acpitests}'[run ACPI tests]' \
  '(-U --uefitests)'{-U,--uefitests}'[run UEFI tests]' \
  '--utils[run utility tools]' \
  '--batch-experimental[run experimental batch tests]' \
  '--interactive-experimental[run experimental interactive tests]' \
  '(-d --dump)'{-d,--dump}'[dump firmware data to log]' \
  '--dumpfile=[load tables from dump]:file:_files' \
  '--acpica=[ACPICA debug mode]:mode:(serialized slack ignore-errors disassemble parse_only output_file dsdt_init disable_repair disable_predefined_repair)' \
  '--acpica-debug[enable ACPICA debug output]' \
  '--acpi-compliance[run ACPI compliance tests]' \
  '--arch=[target architecture]:arch:(x86 x86_32 x86_64 ia64 arm64 aarch64)' \
  '--clog=[capture kernel log file]:file:_files' \
  '--disassemble-aml[disassemble AML]' \
  '--ebbr[run ARM EBBR tests]' \
  '--filter-error-discard=[discard errors csv]:list:' \
  '--filter-error-keep=[keep errors csv]:list:' \
  '--firmware-vendor[firmware vendor specific]' \
  '--force-clean[force log file removal]' \
  '--ifv[ignore firmware vendor]' \
  '--json-data-path=[JSON data path]:dir:_files -/' \
  '--klog=[load kernel log from file]:file:_files' \
  '--lp-flags=[Launchpad flags]:flags:' \
  '--lp-tags=[Launchpad tags]:tags:' \
  '--lspci=[lspci command]:cmd:_command_names' \
  '--no-s3[do not run S3 test]' \
  '--no-s4[do not run S4 test]' \
  '--olog=[output log file]:file:_files' \
  '(-p --power-states)'{-p+,--power-states=}'[power state tests]:n:' \
  '(-P --pm-method)'{-P+,--pm-method=}'[PM method]:m:' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-r --results-output)'{-r+,--results-output=}'[results output file]:file:_files' \
  '--results-no-separators[no separators in results]' \
  '--rsdp=[RSDP address]:addr:' \
  '(-s --skip-test)'{-s+,--skip-test=}'[skip tests csv]:list:' \
  '--sbbr[run SBBR tests]' \
  '--show-progress[show test progress]' \
  '--show-progress-dialog[show progress dialog]' \
  '--show-tests[show available tests]' \
  '--show-tests-categories[show test categories]' \
  '--show-tests-full[show full test info]' \
  '--stdout-summary[summary on stdout]' \
  '(-t --table-path)'{-t+,--table-path=}'[ACPI table path]:dir:_files -/' \
  '--uefi-get-var-multiple=[uefi var get count]:n:' \
  '--uefi-set-var-multiple=[uefi var set count]:n:' \
  '--uefi-query-var-multiple=[uefi var query count]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-w --log-width)'{-w+,--log-width=}'[log width]:n:' \
  '*: :' && ret=0

return ret
