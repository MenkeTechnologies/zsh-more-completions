#compdef cumulvec
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss31.html
# KAPPA: counts a cumulative vector through a one-dimensional NDF

local ret=1

_arguments -s \
  'IN=[input NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'THRESH=[threshold value]:value' \
  'TITLE=[title for the output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
