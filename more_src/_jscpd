#compdef jscpd
# Documentation: https://man.archlinux.org/search?q=jscpd
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  {-l,--min-lines}'[min size of duplication in lines]:lines:' \
  {-k,--min-tokens}'[min size of duplication in tokens]:tokens:' \
  {-x,--max-lines}'[max source size in lines]:lines:' \
  {-z,--max-size}'[max source size]:size:' \
  {-t,--threshold}'[exit with error when duplications >= threshold]:threshold:' \
  {-c,--config}'[path to config file]:file:_files' \
  {-i,--ignore}'[glob pattern for excluded files]:pattern:' \
  '--ignore-pattern[ignore code blocks matching regexp]:pattern:' \
  {-r,--reporters}'[reporters comma-separated]:reporter:(ai console consoleFull xml json csv markdown html silent threshold xcode sarif)' \
  {-o,--output}'[report output directory]:directory:_files -/' \
  {-m,--mode}'[search quality mode]:mode:(strict mild weak)' \
  {-f,--format}'[formats comma-separated]:formats:' \
  {-p,--pattern}'[glob pattern for file search]:pattern:' \
  {-b,--blame}'[blame authors of duplications from git]' \
  {-s,--silent}'[do not print progress and result to console]' \
  '--store[custom duplication store (e.g. leveldb)]:store:' \
  {-a,--absolute}'[use absolute paths in reports]' \
  {-n,--noSymlinks}'[do not follow symlinks when scanning files]' \
  '--ignoreCase[ignore case of symbols in code (experimental)]' \
  {-g,--gitignore}'[ignore files matched by .gitignore]' \
  '--formats-exts[list formats with extensions like javascript:es,es6]:spec:' \
  {-d,--debug}'[show options and selected files; skip detection]' \
  {-v,--verbose}'[verbose output during detection]' \
  '--list[list supported formats]' \
  '--skipLocal[skip duplicates inside same folder; detect cross-folder only]' \
  '--exitCode[exit code when duplications are found]:code:' \
  '*:path:_files'
