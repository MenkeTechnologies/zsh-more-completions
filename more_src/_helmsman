#compdef helmsman

# Zsh completion for helmsman - Helm releases declarative manager

_arguments -s -S \
  '(-a --apply)'{-a,--apply}'[apply the plan (default is dry run)]' \
  '(-d --debug)'{-d,--debug}'[show execution logs]' \
  '--dry-run[apply the plan without actually making changes]' \
  '*-f+[path to a desired state file]:state file:_files' \
  '--group=[limit operations to a group of apps]:group' \
  '--keep-untracked-releases[do not delete untracked releases]' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--log-level=[log level]:level:(INFO DEBUG TRACE WARNING ERROR FATAL)' \
  '--no-banner[suppress the banner]' \
  '--no-cleanup[skip post-deployment cleanup]' \
  '--no-color[disable colored output]' \
  '--no-env-subst[disable environment variable substitution]' \
  '--no-ns[do not create namespaces]' \
  '--no-ssm-subst[disable AWS SSM parameter substitution]' \
  '--ns-override=[override the namespace for all apps]:namespace' \
  '-p+[target for operations]:target' \
  '--show-diff[show helm diff output]' \
  '--skip-validation[skip desired state validation]' \
  '--update-deps[update chart dependencies before installing]' \
  '-v[show verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]'
