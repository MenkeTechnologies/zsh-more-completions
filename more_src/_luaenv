#compdef luaenv

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'commands:list all available luaenv commands'
  'completions:list completions for a command'
  'global:set or show the global Lua version'
  'help:show help for a command'
  'init:configure the shell environment for luaenv'
  'install:install a Lua version'
  'local:set or show the local directory Lua version'
  'prefix:show the path to a Lua version'
  'rehash:rehash luaenv shims'
  'root:show the root directory of luaenv'
  'shell:set or show the shell-specific Lua version'
  'shims:list existing luaenv shims'
  'uninstall:uninstall a Lua version'
  'version:show the current Lua version and its origin'
  'version-file:detect the version file in the current directory'
  'version-file-read:read the version from a version file'
  'version-file-write:write a version to a version file'
  'version-name:show the current Lua version name'
  'version-origin:explain how the current Lua version was set'
  'versions:list all installed Lua versions'
  'whence:list versions that contain the given command'
  'which:show the full path for a command'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'luaenv command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        local -a available_versions
        if _cache_invalid luaenv_install_versions || ! _retrieve_cache luaenv_install_versions; then
          available_versions=(${(f)"$(luaenv install --list 2>/dev/null | sed 's/^[[:space:]]*//')"})
          _store_cache luaenv_install_versions available_versions
        fi
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--list[list all available versions]' \
          '1:version:compadd -a available_versions' && ret=0
        ;;
      uninstall)
        local -a installed_versions
        installed_versions=(${(f)"$(luaenv versions --bare 2>/dev/null)"})
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:version:compadd -a installed_versions' && ret=0
        ;;
      global|local|shell)
        local -a installed_versions
        installed_versions=(${(f)"$(luaenv versions --bare 2>/dev/null)"})
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:version:compadd system -a installed_versions' && ret=0
        ;;
      which)
        local -a shim_commands
        shim_commands=(${(f)"$(luaenv shims --short 2>/dev/null)"})
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:command:compadd -a shim_commands' && ret=0
        ;;
      whence)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:command name' && ret=0
        ;;
      help)
        _arguments -s -S \
          '1:command:compadd -a - commands' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '1:command:compadd -a - commands' && ret=0
        ;;
      prefix)
        local -a installed_versions
        installed_versions=(${(f)"$(luaenv versions --bare 2>/dev/null)"})
        _arguments -s -S \
          '1:version:compadd -a installed_versions' && ret=0
        ;;
    esac
    ;;
esac

return ret
