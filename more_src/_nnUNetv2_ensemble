#compdef nnUNetv2_ensemble
# Documentation: https://github.com/MIC-DKFZ/nnUNet/blob/master/documentation/how_to_use_nnunet.md
# nnU-Net v2 ensemble of multiple prediction folders

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-i[input prediction folders]:input folder:_files -/' \
  '-o[output folder]:output folder:_files -/' \
  '-np[number of processes]:num processes:' \
  '*:arg:_files' && ret=0

return ret
