#compdef identify
# _identify — ImageMagick identify (describe format/dimensions/depth/colorspace of image files; -verbose dump full metadata, -format Magick string controls output, -ping skips pixel decode, -regard-warnings exit on warnings, -list lists known kinds (Format/Coder/Colorspace/etc.))
# upstream: https://github.com/ImageMagick/ImageMagick
# Flags from ImageMagick MagickWand/identify.c on tip.

_identify() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-verbose[verbose]' \
        '-quiet[quiet]' \
        '-ping[skip pixel decode]' \
        '-regard-warnings[treat warnings as errors]' \
        '-strip[strip metadata]' \
        '-debug+[debug events]:events:(All Accelerate Annotate Blob Cache Coder Configure Deprecate Draw Exception Image Locale Module Pixel Policy Resource Trace Transform User Wand X11)' \
        '-define+[define option]:option=value:' \
        '-density+[DPI]:dpi:' \
        '-depth+[depth bits]:bits:' \
        '-format+[output format]:format:' \
        '-list+[list info]:type:(Align Alpha Boolean Channel Class CLI ColorMatrix Colorspace Command Complex Compose Compress ConfigurePath DataType Decoration Delegate Direction Dispose Distort Dither Endian Evaluate FillRule Filter Font Format Function Gravity Intent Interlace Interpolate Kernel Layers LineCap LineJoin List Locale LogEvent Log Magic Method Metric Mime Mode Module Morphology Noise Orientation PixelChannel PixelIntensity PixelMask PixelTrait Policy Preview Primitive QuantumFormat Resource Sparse Statistic Storage Stretch Style Threshold Type Units Validate VirtualPixel Weight)' \
        '-log+[log format]:format:' \
        '-monitor[monitor progress]' \
        '-precision+[significant digits]:n:' \
        '-quiet[quiet]' \
        '-respect-parentheses[respect parentheses]' \
        '-set+[attribute]:property:' \
        '-units+[units]:units:(Undefined PixelsPerInch PixelsPerCentimeter)' \
        '*:image:_files'
}

_identify "$@"
