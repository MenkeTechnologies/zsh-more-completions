#compdef pyp
# Documentation: https://github.com/hauntsaninja/pyp
# Easily run Python at the shell

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--explain --script)'{--explain,--script}'[print the Python that would get run, instead of running it]' \
  '(-b --before)'{-b,--before}'[Python to run before processing input]:code' \
  '(-a --after)'{-a,--after}'[Python to run after processing input]:code' \
  '--define-pypprint[define pypprint instead of importing it from pyp]' \
  '--version[show version information]' \
  '*:code:_default' && ret=0

return ret
