#compdef compseq

# EMBOSS compseq: count composition of words/oligomers in sequence(s)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-word=[word size to count]:size:' \
  '-frame=[reading frame (0/1/2/3 for codon analysis)]:frame:' \
  '-ignorebz[ignore B and Z residues]' \
  '-infile=[reference composition file (for expected counts)]:file:_files' \
  '-reverse[count reverse-complement words]' \
  '-calcfreq[calculate expected from sequence rather than uniform]' \
  '-zerocount[print words with zero count too]' \
  '-outfile=[output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
