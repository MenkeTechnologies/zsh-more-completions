#compdef shaka-packager packager

_arguments -s -S \
  '--mpd_output[output path for the MPD manifest]:output file:_files -g "*.mpd"' \
  '--hls_master_playlist_output[output path for the HLS master playlist]:output file:_files -g "*.m3u8"' \
  '--hls_base_url[base URL for HLS media playlists]:url:' \
  '--base_urls[comma-separated list of base URLs for manifests]:urls:' \
  '--segment_duration[target segment duration in seconds]:seconds:' \
  '--fragment_duration[target fragment duration in seconds]:seconds:' \
  '--segment_sap_aligned[align segments to stream access points]' \
  '--fragment_sap_aligned[align fragments to stream access points]' \
  '--utc_timings[UTC timing schemes for DASH]:scheme_id_uri=value:' \
  '--default_language[default language for media]:language:' \
  '--default_text_language[default language for text]:language:' \
  '--allow_approximate_segment_timeline[use approximate segment timeline in DASH]' \
  '--generate_static_live_mpd[generate static MPD for live content]' \
  '--nonce_constant_iv[use constant IV for encryption]' \
  '--temp_dir[temporary directory for intermediate files]:directory:_files -/' \
  '--io_block_size[block size for IO operations in bytes]:bytes:' \
  '--enable_raw_key_encryption[enable encryption with raw keys]' \
  '--enable_raw_key_decryption[enable decryption with raw keys]' \
  '--keys[encryption key info as label=key_id:key pairs]:key info:' \
  '--iv[IV for encryption in hex]:hex iv:' \
  '--pssh[PSSH data in hex]:hex pssh:' \
  '--protection_scheme[protection scheme]:scheme:(cenc cens cbc1 cbcs)' \
  '--vmodule[per-module verbose logging]:module=level:' \
  '--dump_stream_info[dump stream info and exit]' \
  '--quiet[suppress non-error output]' \
  '*:stream descriptor:'
