#compdef copilot

# Zsh completion for AWS Copilot CLI (container deployment on ECS)

local curcontext="$curcontext" state line ret=1

local -a copilot_commands
copilot_commands=(
  'init:create a new ECS or App Runner application'
  'docs:open the Copilot documentation'
  'app:manage applications'
  'env:manage environments'
  'svc:manage services'
  'job:manage jobs'
  'task:manage one-off tasks'
  'pipeline:manage CI/CD pipelines'
  'deploy:deploy a service, job, or environment'
  'secret:manage secrets'
  'storage:manage storage resources'
  'version:print the version number'
  'completion:output shell completion code'
  'run:run a one-off task'
)

local -a copilot_global_flags
copilot_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '-v[show version]'
  '--version[show version]'
)

_arguments -s -S \
  $copilot_global_flags \
  '1:command:_describe -t commands command copilot_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      init)
        _arguments -s -S \
          $copilot_global_flags \
          '-a=[name of the application]:app name:' \
          '--app=[name of the application]:app name:' \
          '-n=[name of the service or job]:name:' \
          '--name=[name of the service or job]:name:' \
          '-t=[type of workload]:type:(Request-Driven\ Web\ Service Load\ Balanced\ Web\ Service Backend\ Service Worker\ Service Scheduled\ Job Static\ Site)' \
          '--type=[type of workload]:type:' \
          '-d=[path to Dockerfile]:Dockerfile:_files' \
          '--dockerfile=[path to Dockerfile]:Dockerfile:_files' \
          '-i=[container image to use]:image:' \
          '--image=[container image to use]:image:' \
          '--port=[port exposed by the service]:port:' \
          '--tag=[container image tag]:tag:' \
          '--deploy[deploy the service after init]' \
          '--resource-tags=[tags for AWS resources]:tags:' && ret=0
        ;;
      app)
        local -a app_commands
        app_commands=(
          'init:create a new application'
          'ls:list all applications'
          'show:display information about an application'
          'delete:delete an application'
          'upgrade:upgrade the application'
        )
        _arguments -s -S \
          $copilot_global_flags \
          '1:app command:_describe -t commands command app_commands' \
          '*::app args:' && ret=0
        ;;
      env)
        local -a env_commands
        env_commands=(
          'init:create a new environment'
          'ls:list all environments'
          'show:display information about an environment'
          'delete:delete an environment'
          'deploy:deploy an environment'
          'package:print the CloudFormation template'
          'override:override the CloudFormation template'
        )
        _arguments -s -S \
          $copilot_global_flags \
          '1:env command:_describe -t commands command env_commands' \
          '*::env args:->env_args' && ret=0
        case "$state" in
          env_args)
            case "${line[1]}" in
              init)
                _arguments -s -S \
                  $copilot_global_flags \
                  '-n=[name of the environment]:name:' \
                  '--name=[name of the environment]:name:' \
                  '-a=[name of the application]:app name:' \
                  '--app=[name of the application]:app name:' \
                  '--profile=[named profile for the environment account]:profile:' \
                  '--default-config[use default environment configuration]' \
                  '--import-vpc-id=[use an existing VPC]:vpc id:' \
                  '--import-public-subnets=[use existing public subnets]:subnet ids:' \
                  '--import-private-subnets=[use existing private subnets]:subnet ids:' \
                  '--override-vpc-cidr=[override the VPC CIDR]:cidr:' \
                  '--override-az-names=[override availability zone names]:az names:' \
                  '--region=[AWS region]:region:' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  $copilot_global_flags \
                  '-n=[name of the environment]:name:' \
                  '--name=[name of the environment]:name:' \
                  '-a=[name of the application]:app name:' \
                  '--app=[name of the application]:app name:' \
                  '--yes[skip confirmation]' && ret=0
                ;;
              *)
                _arguments -s -S $copilot_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      svc)
        local -a svc_commands
        svc_commands=(
          'init:create a new service'
          'ls:list all services'
          'show:display information about a service'
          'status:display status of a deployed service'
          'logs:display logs of a deployed service'
          'deploy:deploy a service'
          'delete:delete a service'
          'exec:execute a command in a running container'
          'package:print the CloudFormation template'
          'override:override the CloudFormation template'
          'pause:pause a running service'
          'resume:resume a paused service'
        )
        _arguments -s -S \
          $copilot_global_flags \
          '1:svc command:_describe -t commands command svc_commands' \
          '*::svc args:->svc_args' && ret=0
        case "$state" in
          svc_args)
            case "${line[1]}" in
              init)
                _arguments -s -S \
                  $copilot_global_flags \
                  '-n=[service name]:name:' \
                  '--name=[service name]:name:' \
                  '-a=[application name]:app:' \
                  '--app=[application name]:app:' \
                  '-t=[service type]:type:(Request-Driven\ Web\ Service Load\ Balanced\ Web\ Service Backend\ Service Worker\ Service Static\ Site)' \
                  '--type=[service type]:type:' \
                  '-d=[path to Dockerfile]:Dockerfile:_files' \
                  '--dockerfile=[path to Dockerfile]:Dockerfile:_files' \
                  '-i=[container image]:image:' \
                  '--image=[container image]:image:' \
                  '--port=[port to expose]:port:' \
                  '--subscribe-topics=[SNS topics to subscribe to]:topics:' && ret=0
                ;;
              deploy)
                _arguments -s -S \
                  $copilot_global_flags \
                  '-n=[service name]:name:' \
                  '--name=[service name]:name:' \
                  '-a=[application name]:app:' \
                  '--app=[application name]:app:' \
                  '-e=[environment name]:env:' \
                  '--env=[environment name]:env:' \
                  '--tag=[container image tag]:tag:' \
                  '--force[force a new deployment]' \
                  '--resource-tags=[additional tags]:tags:' \
                  '--diff[show diff before deploying]' && ret=0
                ;;
              logs)
                _arguments -s -S \
                  $copilot_global_flags \
                  '-n=[service name]:name:' \
                  '--name=[service name]:name:' \
                  '-a=[application name]:app:' \
                  '--app=[application name]:app:' \
                  '-e=[environment name]:env:' \
                  '--env=[environment name]:env:' \
                  '--follow[follow logs]' \
                  '--limit=[number of events]:number:' \
                  '--log-group=[log group name]:group:' \
                  '--since=[start time]:duration:' \
                  '--end-time=[end time]:time:' \
                  '--start-time=[start time]:time:' \
                  '--json[output in JSON format]' \
                  '--previous[show logs for previous task]' && ret=0
                ;;
              exec)
                _arguments -s -S \
                  $copilot_global_flags \
                  '-n=[service name]:name:' \
                  '--name=[service name]:name:' \
                  '-a=[application name]:app:' \
                  '--app=[application name]:app:' \
                  '-e=[environment name]:env:' \
                  '--env=[environment name]:env:' \
                  '-c=[command to execute]:command:' \
                  '--command=[command to execute]:command:' \
                  '--container=[container name]:container:' \
                  '--task-id=[task ID]:task id:' && ret=0
                ;;
              *)
                _arguments -s -S $copilot_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      job)
        local -a job_commands
        job_commands=(
          'init:create a new job'
          'ls:list all jobs'
          'deploy:deploy a job'
          'delete:delete a job'
          'logs:display logs of a deployed job'
          'package:print the CloudFormation template'
          'run:run a deployed job'
          'override:override the CloudFormation template'
        )
        _arguments -s -S \
          $copilot_global_flags \
          '1:job command:_describe -t commands command job_commands' \
          '*::job args:' && ret=0
        ;;
      pipeline)
        local -a pipeline_commands
        pipeline_commands=(
          'init:create a new pipeline'
          'deploy:deploy a pipeline'
          'delete:delete a pipeline'
          'ls:list all pipelines'
          'show:display pipeline information'
          'status:display pipeline status'
          'override:override the pipeline CloudFormation template'
        )
        _arguments -s -S \
          $copilot_global_flags \
          '1:pipeline command:_describe -t commands command pipeline_commands' \
          '*::pipeline args:' && ret=0
        ;;
      storage)
        local -a storage_commands
        storage_commands=(
          'init:create a new storage resource'
          'ls:list all storage resources'
          'delete:delete a storage resource'
        )
        _arguments -s -S \
          $copilot_global_flags \
          '1:storage command:_describe -t commands command storage_commands' \
          '*::storage args:' && ret=0
        ;;
      secret)
        local -a secret_commands
        secret_commands=(
          'init:create or update a secret'
        )
        _arguments -s -S \
          $copilot_global_flags \
          '1:secret command:_describe -t commands command secret_commands' \
          '*::secret args:' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          $copilot_global_flags \
          '-n=[name of the service, job, or environment]:name:' \
          '--name=[name of the service, job, or environment]:name:' \
          '-a=[application name]:app:' \
          '--app=[application name]:app:' \
          '-e=[environment name]:env:' \
          '--env=[environment name]:env:' \
          '--tag=[container image tag]:tag:' \
          '--force[force a new deployment]' \
          '--diff[show diff before deploying]' \
          '--resource-tags=[additional tags]:tags:' && ret=0
        ;;
      task)
        local -a task_commands
        task_commands=(
          'run:run a one-off task'
          'exec:execute a command in a running task'
          'delete:delete one-off tasks'
          'logs:display logs for a running task'
        )
        _arguments -s -S \
          $copilot_global_flags \
          '1:task command:_describe -t commands command task_commands' \
          '*::task args:' && ret=0
        ;;
      completion)
        _arguments -s -S \
          $copilot_global_flags \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S $copilot_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
