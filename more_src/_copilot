#compdef copilot

# Zsh completion for GitHub Copilot CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '(-p --prompt)'{-p+,--prompt=}'[execute a prompt in non-interactive mode]:text:' \
  '(-i --interactive)'{-i+,--interactive=}'[start interactive mode and execute prompt]:prompt:' \
  '(-s --silent)'{-s,--silent}'[output only the agent response]' \
  '--effort=[set reasoning effort level]:level:(low medium high xhigh)' \
  '--reasoning-effort=[set reasoning effort level]:level:(low medium high xhigh)' \
  '--acp[start as Agent Client Protocol server]' \
  '*--add-dir=[add directory to allowed list]:directory:_directories' \
  '*--add-github-mcp-tool=[add GitHub MCP server tool]:tool:' \
  '*--add-github-mcp-toolset=[add GitHub MCP server toolset]:toolset:' \
  '*--additional-mcp-config=[additional MCP servers configuration]:json or @path:_files' \
  '--agent=[specify a custom agent]:agent:' \
  '--allow-all[enable all permissions]' \
  '--allow-all-paths[disable file path verification]' \
  '--allow-all-tools[allow all tools without confirmation]' \
  '--allow-all-urls[allow access to all URLs]' \
  '*--allow-tool=[tools the CLI has permission to use]:tool:' \
  '*--allow-url=[allow access to specific URLs or domains]:url:' \
  '--autopilot[start in autopilot mode]' \
  '*--available-tools=[only these tools will be available]:tool:' \
  '--banner[show the startup banner]' \
  '--bash-env=-[enable BASH_ENV support]::value:(on off)' \
  '--config-dir=[set the configuration directory]:directory:_directories' \
  '--continue[resume the most recent session]' \
  '*--deny-tool=[tools the CLI does not have permission to use]:tool:' \
  '*--deny-url=[deny access to specific URLs or domains]:url:' \
  '--disable-builtin-mcps[disable all built-in MCP servers]' \
  '*--disable-mcp-server=[disable a specific MCP server]:server name:' \
  '--disallow-temp-dir[prevent automatic access to temp directory]' \
  '--enable-all-github-mcp-tools[enable all GitHub MCP server tools]' \
  '--enable-reasoning-summaries[request reasoning summaries for OpenAI models]' \
  '*--excluded-tools=[tools not available to the model]:tool:' \
  '--log-dir=[set log file directory]:directory:_directories' \
  '--log-level=[set the log level]:level:(none error warning info debug all default)' \
  '--max-autopilot-continues=[max continuation messages in autopilot mode]:count:' \
  '--mode=[set the initial agent mode]:mode:(interactive plan autopilot)' \
  '--model=[set the AI model to use]:model:' \
  '--mouse=-[enable mouse support in alt screen mode]::value:(on off)' \
  '--no-ask-user[disable the ask_user tool]' \
  '--no-auto-update[disable downloading CLI update automatically]' \
  '--no-bash-env[disable BASH_ENV support]' \
  '--no-color[disable all color output]' \
  '--no-custom-instructions[disable loading of custom instructions]' \
  '--no-experimental[disable experimental features]' \
  '--no-mouse[disable mouse support in alt screen mode]' \
  '--output-format=[output format]:format:(text json)' \
  '--plain-diff[disable rich diff rendering]' \
  '--plan[start in plan mode]' \
  '*--plugin-dir=[load a plugin from a local directory]:directory:_directories' \
  '--resume=-[resume from a previous session]::session id:' \
  '--screen-reader[enable screen reader optimizations]' \
  '*--secret-env-vars=[environment variable names to redact]:vars:' \
  '--share=-[share session to markdown file]::path:_files' \
  '--share-gist[share session to a secret GitHub gist]' \
  '--stream=[enable or disable streaming mode]:mode:(on off)' \
  '--experimental[enable experimental features]' \
  '--yolo[enable all permissions]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'help:display help information'
      'init:initialize Copilot instructions'
      'login:authenticate with Copilot'
      'mcp:manage MCP servers'
      'plugin:manage plugins'
      'update:download the latest version'
      'version:display version information'
    )
    _describe 'command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      help)
        local -a help_topics
        help_topics=(
          'commands:interactive mode commands'
          'config:configuration settings'
          'environment:environment variables'
          'logging:logging'
          'monitoring:monitoring with OpenTelemetry'
          'permissions:permissions'
          'providers:custom model providers (BYOK)'
        )
        _describe 'topic' help_topics && ret=0
        ;;
      init)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      login)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' \
          '--config-dir=[set the configuration directory]:directory:_directories' \
          '--host=[GitHub host URL]:host:' && ret=0
        ;;
      mcp)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' \
          '1:mcp command:->mcp_command' \
          '*::mcp args:->mcp_args' && ret=0
        case "$state" in
          mcp_command)
            local -a mcp_commands
            mcp_commands=(
              'add:add an MCP server'
              'get:show server details'
              'help:display help'
              'list:list configured MCP servers'
              'remove:remove an MCP server'
            )
            _describe 'mcp command' mcp_commands && ret=0
            ;;
          mcp_args)
            case "${line[1]}" in
              add)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[display help]' \
                  '--config-dir=[path to configuration directory]:directory:_directories' \
                  '*--env=[environment variable (KEY=VALUE)]:env:' \
                  '*--header=[HTTP header for remote servers]:header:' \
                  '--json[output added config as JSON]' \
                  '--show-secrets[show full environment variable and header values]' \
                  '--timeout=[timeout in milliseconds]:ms:' \
                  '--tools=[tool filter]:tools:' \
                  '--transport=[server transport]:transport:(stdio http sse)' \
                  ':name:' \
                  '*:url or command and args:' && ret=0
                ;;
              get)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[display help]' \
                  '--config-dir=[path to configuration directory]:directory:_directories' \
                  '--json[output as JSON]' \
                  '--show-secrets[show full environment variable and header values]' \
                  ':name:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[display help]' \
                  '--config-dir=[path to configuration directory]:directory:_directories' \
                  '--json[output as JSON]' && ret=0
                ;;
              remove)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[display help]' \
                  '--config-dir=[path to configuration directory]:directory:_directories' \
                  ':name:' && ret=0
                ;;
              *)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[display help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      plugin)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' \
          '1:plugin command:->plugin_command' \
          '*::plugin args:->plugin_args' && ret=0
        case "$state" in
          plugin_command)
            local -a plugin_commands
            plugin_commands=(
              'install:install a plugin'
              'list:list installed plugins'
              'marketplace:manage plugin marketplaces'
              'uninstall:uninstall a plugin'
              'update:update a plugin'
            )
            _describe 'plugin command' plugin_commands && ret=0
            ;;
          plugin_args)
            case "${line[1]}" in
              install)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[display help]' \
                  '--config-dir=[path to configuration directory]:directory:_directories' \
                  ':source:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[display help]' \
                  '--config-dir=[path to configuration directory]:directory:_directories' && ret=0
                ;;
              uninstall)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[display help]' \
                  '--config-dir=[path to configuration directory]:directory:_directories' \
                  ':name:' && ret=0
                ;;
              update)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[display help]' \
                  '--config-dir=[path to configuration directory]:directory:_directories' \
                  ':name:' && ret=0
                ;;
              marketplace)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[display help]' \
                  '1:marketplace command:->marketplace_command' \
                  '*::marketplace args:->marketplace_args' && ret=0
                case "$state" in
                  marketplace_command)
                    local -a marketplace_commands
                    marketplace_commands=(
                      'add:add a marketplace'
                      'browse:browse plugins in a marketplace'
                      'list:list registered marketplaces'
                      'remove:remove a marketplace'
                    )
                    _describe 'marketplace command' marketplace_commands && ret=0
                    ;;
                  marketplace_args)
                    case "${line[1]}" in
                      add)
                        _arguments -s -S \
                          '(-h --help)'{-h,--help}'[display help]' \
                          '--config-dir=[path to configuration directory]:directory:_directories' \
                          ':source:' && ret=0
                        ;;
                      browse)
                        _arguments -s -S \
                          '(-h --help)'{-h,--help}'[display help]' \
                          '--config-dir=[path to configuration directory]:directory:_directories' \
                          ':name:' && ret=0
                        ;;
                      list)
                        _arguments -s -S \
                          '(-h --help)'{-h,--help}'[display help]' \
                          '--config-dir=[path to configuration directory]:directory:_directories' && ret=0
                        ;;
                      remove)
                        _arguments -s -S \
                          '(-h --help)'{-h,--help}'[display help]' \
                          '--config-dir=[path to configuration directory]:directory:_directories' \
                          '(-f --force)'{-f,--force}'[force removal even if plugins are installed]' \
                          ':name:' && ret=0
                        ;;
                      *)
                        _arguments -s -S \
                          '(-h --help)'{-h,--help}'[display help]' && ret=0
                        ;;
                    esac
                    ;;
                esac
                ;;
              *)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[display help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      update|version)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
