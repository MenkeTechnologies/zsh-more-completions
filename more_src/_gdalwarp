#compdef gdalwarp

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-s_srs+[source SRS]:SRS:(EPSG\:4326 EPSG\:3857)' \
  '-t_srs+[target SRS]:SRS:(EPSG\:4326 EPSG\:3857)' \
  '-ct+[coordinate transformation pipeline]:pipeline' \
  '-to+[transformer option]:NAME=VALUE' \
  '-order+[polynomial order]:order:(1 2 3)' \
  '-tps[use thin plate spline]' \
  '-rpc[use RPC transformer]' \
  '-geoloc[use geolocation arrays]' \
  '-et+[error threshold]:threshold' \
  '-refine_gcps+[refine GCPs]:tolerance minimum_gcps' \
  '-te+[target extent]:xmin ymin xmax ymax' \
  '-te_srs+[SRS for target extent]:SRS' \
  '-tr+[target resolution]:xres yres' \
  '-tap[target aligned pixels]' \
  '-ts+[target size]:width height' \
  '-ovr+[overview level]:level:(AUTO NONE)' \
  '-wo+[warp option]:NAME=VALUE' \
  '-ot+[output data type]:type:(Byte Int16 UInt16 Int32 UInt32 Float32 Float64 CFloat32 CFloat64)' \
  '-wt+[working data type]:type:(Byte Int16 UInt16 Int32 UInt32 Float32 Float64 CFloat32 CFloat64)' \
  '-r+[resampling method]:method:(near bilinear cubic cubicspline lanczos average rms mode max min med q1 q3 sum)' \
  '-srcnodata+[source nodata value]:value' \
  '-dstnodata+[destination nodata value]:value' \
  '-dstalpha[add alpha band to destination]' \
  '-nosrcalpha[do not use source alpha band]' \
  '-wm+[working memory in MB]:memory' \
  '-multi[use multithreaded I/O]' \
  '-q[quiet mode]' \
  '-of+[output format]:format:(GTiff COG VRT MBTiles GPKG)' \
  '-co+[creation option]:NAME=VALUE' \
  '-cutline+[cutline datasource]:datasource:_files' \
  '-cl+[cutline layer]:layer name' \
  '-cwhere+[cutline WHERE]:WHERE clause' \
  '-csql+[cutline SQL]:SQL' \
  '-cblend+[cutline blend distance]:distance' \
  '-crop_to_cutline[crop to cutline extent]' \
  '-overwrite[overwrite existing output]' \
  '-nomd[do not copy metadata]' \
  '-cvmd+[metadata for cutline]:domain' \
  '-setci[set color interpretation]' \
  '-oo+[open option]:NAME=VALUE' \
  '-doo+[destination open option]:NAME=VALUE' \
  '*:files:_files'
