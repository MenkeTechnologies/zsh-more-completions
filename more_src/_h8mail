#compdef h8mail
# Documentation: https://github.com/khast3x/h8mail
# OSINT: email breach hunting and password lookup.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-t,--targets}'[string inputs or files of email targets]:target:' \
  '*'{-u,--url}'[URLs or files to parse pages for emails]:url:' \
  '(-q --custom-query)'{-q+,--custom-query=}'[perform a custom query (username,password,ip,hash,domain)]:query:' \
  '--loose[allow loose search by disabling email pattern recognition]' \
  '(-c --config)'{-c+,--config=}'[configuration file for API keys]:file:_files' \
  '(-o --output)'{-o+,--output=}'[file to write CSV output]:file:_files' \
  '(-j --json)'{-j+,--json=}'[file to write JSON output]:file:_files' \
  '(-bc --breachcomp)'{-bc+,--breachcomp=}'[path to breachcompilation torrent folder]:dir:_files -/' \
  '(-sk --skip-defaults)'{-sk,--skip-defaults}'[skip Scylla and HunterIO check]' \
  '(-k --apikey)'{-k+,--apikey=}'[pass config options (K=V,K=V)]:keys:' \
  '*'{-lb,--local-breach}'[local cleartext breaches to scan]:path:_files' \
  '*'{-gz,--gzip}'[local tar.gz compressed breaches to scan]:path:_files' \
  '(-sf --single-file)'{-sf,--single-file}'[show progress bar for big files; disable concurrent search]' \
  '(-ch --chase)'{-ch+,--chase=}'[add related emails from hunter.io per target]:n:' \
  '--power-chase[add related emails from ALL API services; use with --chase]' \
  '--hide[show only first 4 chars of found passwords]' \
  '--debug[print request debug information]' \
  '(-g --gen-config)'{-g,--gen-config}'[generate a config file template and exit]' && ret=0

return ret
