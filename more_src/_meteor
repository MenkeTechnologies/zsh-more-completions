#compdef meteor
# Documentation: https://github.com/meteor/meteor (tools/cli/main.js + commands.js + commands-packages.js)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'run:start the development server with HMR'
  'debug:run dev server with Node.js debugger enabled'
  'shell:open an interactive shell to the running app'
  'create:generate a new Meteor application or package'
  'build:bundle the app for deployment'
  'bundle:deprecated alias for build'
  'lint:check code for errors and style issues'
  'mongo:connect to the MongoDB database of a Meteor app'
  'reset:clear local cache and optionally reset database'
  'deploy:deploy app to Galaxy or custom server'
  'authorized:manage user access permissions for deployed apps'
  'test:run the test suite for the current app'
  'test-packages:execute tests for Meteor packages'
  'rebuild:rebuild packages without running the app'
  'login:authenticate with Meteor account'
  'logout:remove stored authentication credentials'
  'whoami:display the currently logged-in user'
  'admin:admin commands (list-organizations, members, maintainers)'
  'self-test:internal Meteor testing framework'
  'publish:publish a package to the package server'
  'publish-for-arch:publish compiled builds for specific architectures'
  'publish-release:create and publish a Meteor release'
  'list:display packages used in the current app'
  'update:update Meteor release and/or packages'
  'add:add packages as dependencies'
  'remove:remove packages from dependencies'
  'refresh:refresh the package catalog'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show current release]' \
  '(- *)--arch[show Meteor architecture name of current host]' \
  '--release=[Meteor release version to use]:version:' \
  '--unsafe-perm[allow running with superuser privileges]' \
  '--allow-superuser[allow running as superuser]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'meteor subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments \
          '--package[create a Meteor package instead of an app]' \
          '--example=[clone an example project]:example:' \
          '--from=[clone a remote git URL or local path]:source:' \
          '--bare[create a minimal app]' \
          '--minimal[create a minimal app]' \
          '--full[create a full app with example boilerplate]' \
          '--typescript[use TypeScript]' \
          '--react[use React]' \
          '--vue[use Vue]' \
          '--blaze[use Blaze]' \
          '--svelte[use Svelte]' \
          '--solid[use Solid]' \
          '--apollo[use Apollo]' \
          '--tailwind[use Tailwind CSS]' \
          '--chakra-ui[use Chakra UI]' \
          '*:directory:_directories' && ret=0
        ;;
      run|debug)
        _arguments \
          '--port=[port to listen on]:port:' \
          '--inspect[Node inspector]' \
          '--inspect-brk[Node inspector with break]' \
          '--production[run in production mode]' \
          '--settings=[settings JSON file]:file:_files' \
          '--release=[release to use]:release:' \
          '--mobile-server=[mobile server URL]:url:' \
          '--cordova-server-port=[Cordova server port]:port:' \
          '--no-lint[skip linting]' \
          '--no-release-check[skip release check]' && ret=0
        ;;
      add|remove)
        _arguments '*:package:' && ret=0
        ;;
      build)
        _arguments \
          '--debug[build in debug mode]' \
          '--directory[output to a directory]' \
          '--architecture=[server architecture]:arch:(os.osx.x86_64 os.linux.x86_64 os.linux.x86_32 os.windows.x86_32 os.windows.x86_64)' \
          '--server=[server URL]:url:' \
          '--server-only[build only the server, skip mobile]' \
          '--mobile-settings=[mobile settings JSON]:file:_files' \
          '*:output:_directories' && ret=0
        ;;
      mongo)
        _arguments \
          '--url[print MongoDB URL and exit]' \
          ':site:' && ret=0
        ;;
      deploy)
        _arguments \
          '--free[deploy on the free Galaxy tier]' \
          '--mongo[provision MongoDB on Galaxy]' \
          '--plan=[Galaxy plan]:plan:' \
          '--settings=[settings JSON file]:file:_files' \
          '--container-size=[Galaxy container size]:size:' \
          ':site:' && ret=0
        ;;
      reset)
        _arguments \
          '--db[also reset MongoDB database]' && ret=0
        ;;
      admin)
        _arguments \
          '1:subcommand:(list-organizations members maintainers)' \
          '*:: :_files' && ret=0
        ;;
      test|test-packages)
        _arguments \
          '--driver-package=[testing driver package]:package:' \
          '--port=[port to listen on]:port:' \
          '--full-app[serve full app with test mode]' \
          '--once[exit after running tests once]' \
          '--release=[release to use]:release:' \
          '--settings=[settings JSON file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
