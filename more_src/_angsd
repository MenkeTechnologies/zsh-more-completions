#compdef angsd
# Documentation: https://www.popgen.dk/angsd/index.php/ANGSD
# ANGSD: analysis of next-generation sequencing data (genotype likelihoods, SFS, SNPs)

local ret=1

_arguments -s -S \
  '(-bam -b)'{-bam,-b}'+[file listing full path of each BAM, one per row]:file:_files' \
  '-ref+[reference genome file]:file:_files' \
  '-anc+[ancestral sequence file]:file:_files' \
  '-out+[output file prefix]:prefix' \
  '-fai+[reference genome index file]:file:_files -g "*.fai"' \
  '-nThreads+[number of processing threads]:int' \
  '-minMapQ+[discard reads with mapping quality below threshold]:int' \
  '-minQ+[discard bases with base quality below threshold]:int' \
  '-r+[single region (chr:start-stop)]:region' \
  '-rf+[file of multiple regions]:file:_files' \
  '-pileup+[input SAMtools mpileup file]:file:_files' \
  '-vcf-gl+[input VCF/BCF file]:file:_files -g "*.(vcf|bcf)*"' \
  '-glf+[input genotype likelihood binary file]:file:_files' \
  '-beagle+[input Beagle genotype probability file]:file:_files' \
  '-GL+[genotype likelihood model]:model:(1 2 3 4)' \
  '-doGlf+[output log genotype likelihoods format]:format:(0 1 2 3 4)' \
  '-doMajorMinor+[infer major and minor alleles]:int' \
  '-doMaf+[estimate allele frequencies]:int' \
  '-SNP_pval+[filter polymorphic sites by LRT threshold]:float' \
  '-doGeno+[estimate genotypes from likelihoods]:int' \
  '-doPost+[calculate posterior probabilities]:int' \
  '-doCounts+[generate allele counts]:int' \
  '-doSaf+[output site allele frequency likelihoods]:int' && ret=0

return ret
