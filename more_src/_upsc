#compdef upsc
# Documentation: https://man.archlinux.org/search?q=upsc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-c[list clients connected to UPS]' \
  '-l[list UPSes on host]' \
  '-L[list UPSes with descriptions]' \
  '*:ups@host:' && ret=0

return ret
