#compdef upsc
# Documentation: https://networkupstools.org/docs/man/upsc.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show NUT version banner]' \
  '-j[output results in JSON format]' \
  '-c[list clients connected to UPS]' \
  '-l[list UPS names configured at host]' \
  '-L[list UPS names with descriptions]' \
  '-D[raise debugging level]' \
  '-W+[network connection timeout in seconds]:seconds:' \
  '*:ups@host:' && ret=0

return ret
