#compdef pget
# Documentation: https://github.com/replicate/pget
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--concurrency=[maximum parallel chunks per file]:n:' \
  '(-m --chunk-size)'{-m+,--chunk-size=}'[download chunk size in bytes]:size:' \
  '--connect-timeout=[connection establishment timeout]:duration:' \
  '(-f --force)'{-f,--force}'[overwrite existing files]' \
  '(-x --extract)'{-x,--extract}'[extract archive after download]' \
  '--log-level=[logging verbosity level]:level:(debug info warn error)' \
  '--max-concurrent-files=[max files to download concurrently]:n:' \
  '--max-conn-per-host=[max concurrent connections per host]:n:' \
  '*--resolve=[map hostname to IP]:host\:ip:' \
  '(-r --retries)'{-r+,--retries=}'[retry attempts]:n:' \
  '(-v --verbose)'{-v,--verbose}'[debug logging mode]' \
  '1:URL:' \
  '2:destination:_files' && ret=0
return ret
