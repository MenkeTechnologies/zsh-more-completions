#compdef git-imerge

# Zsh completion for git-imerge - incremental merge and rebase for git

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start a new incremental merge/rebase'
  'merge:start a simple incremental merge'
  'rebase:start an incremental rebase'
  'drop:start to drop a commit via incremental rebase'
  'revert:start to revert a commit via incremental rebase'
  'continue:resume an incremental merge after resolving conflicts'
  'finish:finish an incremental merge'
  'diagram:display a diagram of merge state'
  'simplify:simplify a completed merge history'
  'remove:irrevocably remove an incremental merge'
  'reparent:change the parents of a commit'
  'record:record resolved merge of a particular pair of commits'
  'autofill:attempt to fill in merges automatically'
  'init:initialize tracking of an already-started merge'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'git-imerge command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      start|merge|rebase)
        _arguments \
          '--name[name for the imerge]:name' \
          '--branch[checkout to branch]:branch:->branches' \
          '--goal[goal for the imerge]:goal:(merge rebase rebase-with-history full)' \
          '--first-parent[handle only first-parent history]' \
          '*:commit:->commits' && ret=0
        ;;
      continue)
        _arguments \
          '--edit[open editor for commit message]' \
          '--no-edit[use default commit message]' && ret=0
        ;;
      finish)
        _arguments \
          '--goal[finish goal]:goal:(merge rebase rebase-with-history full)' \
          '--branch[branch to create]:branch' && ret=0
        ;;
      diagram)
        _arguments \
          '--name[name of imerge]:name' \
          '--commits[show abbreviated commit hashes]' \
          '--frontier[show merge frontier]' \
          '--html[generate HTML diagram]' \
          '--color[colorize output]' \
          '--no-color[disable color output]' && ret=0
        ;;
      simplify)
        _arguments \
          '--name[name of imerge]:name' \
          '--goal[simplify goal]:goal:(merge rebase rebase-with-history full)' \
          '--branch[branch to create]:branch' && ret=0
        ;;
      remove)
        _arguments '--name[name of imerge to remove]:name' && ret=0
        ;;
    esac

    case $state in
      branches)
        local -a branches
        branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
        _describe -t branches 'branch' branches && ret=0
        ;;
      commits)
        _alternative 'branches:branch:->branches' && ret=0
        ;;
    esac
    ;;
esac

return ret
