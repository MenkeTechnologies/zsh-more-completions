#compdef gwctl
# Documentation: https://github.com/kubernetes-sigs/gwctl
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# cobra + k8s genericclioptions (cmd/root.go)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[gwctl version]' \
  '(-v)-v=-[klog verbosity]:level:' \
  '--kubeconfig=-[kubeconfig path]:file:_files' \
  '--context=-[kubectl context]:context:_kube_contexts' \
  '(-n --namespace)'{-n,--namespace}'=-[default namespace]:namespace:_kube_namespaces' \
  '1:command:(apply get describe delete analyze version)' \
  '*::arguments:_default'
