#compdef arm-linux-readelf arm-linux-gnueabi-readelf arm-linux-gnueabihf-readelf
# _arm-linux-readelf — GNU binutils arm-linux-readelf CLI cross-arch ELF analyzer printing ELF header program headers section headers segment mapping dynamic symbol table relocations notes Build ID GNU_HASH version-info string-dump-section hex-dump-section for ARM Linux binaries shared libraries (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_arm-linux-readelf() {
    _arguments \
        '-h[file header]' \
        '--file-header[file header]' \
        '-l[program headers]' \
        '--program-headers[program headers]' \
        '--segments[program headers]' \
        '-S[section headers]' \
        '--section-headers[section headers]' \
        '--sections[section headers]' \
        '-g[section groups]' \
        '--section-groups[section groups]' \
        '-t[section details]' \
        '--section-details[section details]' \
        '-e[all headers]' \
        '--headers[all headers]' \
        '-s[symbol table]' \
        '--syms[symbol table]' \
        '--symbols[symbol table]' \
        '-r[relocations]' \
        '--relocs[relocations]' \
        '-u[unwind sections]' \
        '--unwind[unwind sections]' \
        '-d[dynamic section]' \
        '--dynamic[dynamic section]' \
        '-V[version sections]' \
        '--version-info[version sections]' \
        '-A[arch-specific info]' \
        '--arch-specific[arch-specific info]' \
        '-D[use dynamic section]' \
        '--use-dynamic[use dynamic section]' \
        '-n[notes]' \
        '--notes[notes]' \
        '-c[archive index]' \
        '--archive-index[archive index]' \
        '-I[histogram]' \
        '--histogram[histogram]' \
        '-W[wide output]' \
        '--wide[wide output]' \
        '-w[dwarf]' \
        '--debug-dump[dwarf]' \
        '--debug-dump=+[type]:t:(info abbrev decodedline rawline loc Ranges pubnames frames frames-interp str gdb_index addr cu_index links follow-links)' \
        '-x+[hex dump section]:str:' \
        '--hex-dump=+[section]:str:' \
        '-R+[relocate hex dump]:str:' \
        '--relocated-dump=+[section]:str:' \
        '-p+[string dump section]:str:' \
        '--string-dump=+[section]:str:' \
        '-z[decompress]' \
        '--decompress[decompress sections before display]' \
        '*:file:_files'
}

_arm-linux-readelf "$@"
