#compdef kcov-cli
# _kcov-cli — Simon Kågström kcov code coverage tester for shell, Python, Bash, Lua, native CLI alias (SimonKagstrom team, C++); custom argparse
# upstream: https://github.com/SimonKagstrom/kcov

_kcov-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--exit-first-process[exit when first process exits]' \
        '--clean[clean output directory before running]' \
        '--coveralls-id=+[coveralls token]:str:' \
        '--codecov-token=+[codecov token]:str:' \
        '--include-path=+[paths csv]:str:' \
        '--exclude-path=+[paths csv]:str:' \
        '--include-pattern=+[patterns csv]:str:' \
        '--exclude-pattern=+[patterns csv]:str:' \
        '--exclude-line=+[line patterns csv]:str:' \
        '--exclude-region=+[region patterns csv]:str:' \
        '--debug=+[debug mask]:n:' \
        '--verify[verify coverage]' \
        '--quiet[suppress output]' \
        '--limits=+[limits low,high]:str:' \
        '--threshold=+[coverage threshold pct]:n:' \
        '--replace-src-path=+[replace src path]:str:' \
        '--strip-path=+[strip path prefix]:str:' \
        '--path-strip-level=+[strip n components]:n:' \
        '--accumulate[accumulate coverage data]' \
        '--merge[merge data into a single report]' \
        '--report-as-stdout[print summary to stdout]' \
        '--bash-method=+[bash trace method]:m:(DEBUG-trap PS4 fallback)' \
        '--python-parser=+[python parser]:p:(auto compatibility builtin)' \
        '--python-command=+[python command]:str:' \
        '--system-record[system record mode]' \
        '--system-report[system report mode]' \
        '--output-interval=+[seconds]:n:' \
        '--print-uncommon[print uncommon]' \
        '--collect-only[collect only]' \
        '--report-only[report only]' \
        '*:output-dir program args:_files'
}

_kcov-cli "$@"
