#compdef razor-admin
# Documentation: https://www.mankier.com/1/razor-admin
# Razor registering agent: register identities and create razorhome

local ret=1

_arguments -s -S \
  '-register[register a new identity]' \
  '-create[create razor-agent.conf and razorhome]' \
  '-discover[force server discovery]' \
  '-h[print usage message]' \
  '-v[print version number]' \
  '(-d --verbose)'{-d,--verbose}'[print debugging information]' \
  '-debuglevel=[set debug level]:level' \
  '-dl=[set debug level]:level' \
  '-s[simulate a check without contacting the server]' \
  '-conf=[alternate configuration file]:file:_files' \
  '-home=[razorhome directory]:dir:_files -/' \
  '-logfile=[log file]:file:_files' \
  '-ident=[identity file]:file:_files' \
  '-rs=[use a specific Razor server]:server' \
  '-user=[registration user (user@domain.com)]:user' \
  '-pass=[registration password]:password' \
  '-l[list]' && ret=0

return ret
