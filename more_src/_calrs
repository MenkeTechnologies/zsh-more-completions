# WHAT IT IS
#   `calrs` is the canonical Rust rewrite of Cal.com's core
#   scheduling functionality — a small operator-facing CLI plus
#   public web booking server that lets a freelancer, consultant,
#   small business, or sales team:
#
#     • Connect one or more CalDAV calendar sources (iCloud,
#       Fastmail, Posteo, mailbox.org, NextCloud, Radicale,
#       SOGo, Open-Xchange, Zimbra, Synology, Yahoo Mail,
#       AOL Mail) — `calrs source add`
#
#     • Pull the latest events from those sources — `calrs
#       sync` (with `--full` for ignore-sync-token full
#       resync)
#
#     • Define typed bookable event types — `calrs event-type
#       add` (e.g. "30-min discovery call", "60-min strategy
#       session", "15-min coffee chat", typed duration +
#       buffer-before + buffer-after + min-notice + max-bookings-
#       per-day + price + location-type {video / in-person /
#       phone-call}).
#
#     • Receive bookings via the public web server — `calrs
#       serve --port 3000` exposes the public booking page at
#       `https://<your-domain>/<event-type-slug>` where
#       prospective clients pick a time slot from the typed
#       availability window
#
#     • Configure OIDC admin SSO — `calrs config oidc set
#       --issuer https://my-idp.example.com --client-id ... --
#       client-secret ...` (the calrs admin UI is then protected
#       by a typed OIDC flow against the configured Identity
#       Provider with PKCE + state + nonce + scope handling)
#
#     • Manage admin users — `calrs user add / list / remove /
#       set-role`
#
#     • Send automated email reminders to bookers + bookings
#       owners — via the configurable SMTP backend (`calrs
#       config smtp set --host ... --port 587 --user ... ---
#       password ...`)
#
#     • View the upcoming calendar inline in the terminal —
#       `calrs calendar show --from 2026-06-02 --to 2026-06-15`
#
#     • Manage bookings interactively — `calrs booking list /
#       cancel / reschedule`
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs clap-derive
#                       `Cli` / `Commands` enum + per-subcommand
#                       module enums in commands/*.rs;  extracted
#                       via raw.githubusercontent.com fetch of
#                       src/main.rs)
#
#   calrs [GLOBAL OPTIONS] <COMMAND> [SUBCOMMAND] [ARGS...]
#
#   Global options:
#     -h, --help                     Show help
#     -V, --version                  Print version
#     --data-dir <PATH>              Custom data directory
#                                    (overrides the OS-canonical
#                                    `ProjectDirs::from("", "",
#                                    "calrs").data_dir()`)
#                                    [env: CALRS_DATA_DIR]
#
#   Commands:
#     source <SUBCOMMAND>            Manage CalDAV sources
#         add                        Add a CalDAV source (URL,
#                                    username, password)
#         list                       List configured sources
#         remove                     Remove a CalDAV source
#         show                       Show CalDAV source details
#     sync [--full]                  Pull latest events from
#                                    all configured CalDAV
#                                    sources
#         --full                     Full re-sync (ignore sync
#                                    tokens; refetches every
#                                    calendar from the source)
#     calendar <SUBCOMMAND>          View the calendar
#         show [--from DATE] [--to DATE]
#                                    Show events in YYYY-MM-DD
#                                    window
#     event-type <SUBCOMMAND>        Manage bookable event types
#         add                        Add a bookable event type
#         list                       List event types
#         remove                     Remove an event type
#         show                       Show event type details
#         update                     Update an event type
#     booking <SUBCOMMAND>           Manage bookings
#         list                       List bookings
#         cancel                     Cancel a booking
#         reschedule                 Reschedule a booking
#         show                       Show booking details
#     user <SUBCOMMAND>              Manage admin users
#         add                        Add an admin user
#         list                       List admin users
#         remove                     Remove an admin user
#         set-role                   Set user role
#     config <SUBCOMMAND>            Configure calrs settings
#         oidc                       OIDC configuration (issuer,
#                                    client-id, client-secret,
#                                    scopes)
#         smtp                       SMTP configuration (host,
#                                    port, user, password, from)
#         general                    General settings (timezone,
#                                    language, public URL)
#     serve [--port PORT] [--host ADDR]
#                                    Start the web booking
#                                    server
#         --port <PORT>              Port to listen on
#                                    [default: 3000]
#         --host <ADDR>              Address to bind to
#                                    (0.0.0.0 for all interfaces)
#                                    [default: 127.0.0.1]
#
# AXIS / CORPUS POSITION
#   `olivierlambert/calrs` declares a **direct** dependency on
#   `openidconnect = { version = "4.0.1", default-features = false,
#   features = ["reqwest", "rustls-tls"] }` in its `Cargo.toml`
#   (verified via `gh api repos/olivierlambert/calrs/contents/
#   Cargo.toml`).  The `src/auth/` module imports the typed
#   primitives via `use openidconnect::core::{CoreClient,
#   CoreProviderMetadata, ...}` and `use openidconnect::{Authorization
#   Code, CsrfToken, Nonce, OAuth2TokenResponse, PkceCodeChallenge,
#   PkceCodeVerifier, RedirectUrl, Scope, ...}`.
#
#   `ramosbugs/openidconnect-rs` is **THE canonical Rust OpenID
#   Connect library** — David A. Ramos's reference pure-Rust
#   implementation of the OpenID Connect 1.0 protocol stack
#   built on top of the same author's `oauth2` crate (which is
#   THE canonical Rust OAuth 2.0 client implementation).  At
#   1,000+ ★ on GitHub and millions of all-time crates.io
#   downloads, it is the dominant Rust OIDC dependency by an
#   order of magnitude — the alternatives are either feature-
#   limited (the `oauth2` crate is plain OAuth 2.0 without the
#   OIDC identity-token decoding layer; `jsonwebtoken` is JWT-
#   only) or vendor-specific (e.g. `aws-sdk-cognitoidentity`).
#
#   `openidconnect-rs` exposes the full typed surface:
#
#     • Typed `CoreClient::from_provider_metadata(metadata,
#       client_id, client_secret)` typed client constructor
#       seeded from OIDC Provider Metadata (the
#       `/.well-known/openid-configuration` endpoint discovery
#       per OIDC Discovery 1.0)
#     • Typed `CoreProviderMetadata::discover_async(issuer_url,
#       http_client)` typed async discovery
#     • Typed `client.authorize_url(AuthenticationFlow, csrf_fn,
#       nonce_fn)` typed auth-URL builder for the AuthorizationCode
#       /  Implicit / Hybrid flows
#     • Typed `client.exchange_code(code)
#       .set_pkce_verifier(verifier)
#       .request_async(http_client)` typed code-exchange flow
#     • Typed `client.exchange_refresh_token(token)
#       .request_async(http_client)` typed refresh flow
#     • Typed `client.user_info(access_token, sub_optional)
#       .request_async(http_client)` typed UserInfo endpoint
#       call
#     • Typed `client.exchange_token_revocation()` typed RFC
#       7009 token revocation
#     • Typed `client.exchange_token_introspection(token)
#       .request_async(http_client)` typed RFC 7662 token
#       introspection
#     • Typed `IdTokenClaims<...>` typed claims envelope with
#       full standard-claims accessor methods (`claims.subject()`
#       /  `claims.audience()` /  `claims.issuer()` /  `claims.
#       expiration()` /  `claims.issue_time()` /  `claims.
#       auth_time()` /  `claims.nonce()` /  `claims.acr()` /
#       `claims.amr()` /  `claims.azp()` /  `claims.email()` /
#       `claims.preferred_username()` /  `claims.name()` /
#       `claims.given_name()` /  `claims.family_name()` /
#       `claims.middle_name()` /  `claims.nickname()` /  `claims.
#       profile()` /  `claims.picture()` /  `claims.website()` /
#       `claims.email_verified()` /  `claims.gender()` /  `claims.
#       birthday()` /  `claims.zoneinfo()` /  `claims.locale()` /
#       `claims.phone_number()` /  `claims.phone_number_verified()`
#       /  `claims.address()` /  `claims.updated_at()`)
#     • Typed `PkceCodeChallenge::new_random_sha256()` /
#       `PkceCodeVerifier` typed PKCE (Proof Key for Code
#       Exchange, RFC 7636) primitives — mandatory for any
#       modern OAuth 2.0 public-client flow
#     • Typed `CsrfToken::new_random()` typed CSRF protection
#     • Typed `Nonce::new_random()` typed ID-token replay
#       protection
#     • Typed `Scope::new(...)` /  `Scopes` typed scope-set
#       builder
#     • Typed `RedirectUrl::new(url)` /  `IssuerUrl::new(url)` /
#       `ClientId::new(s)` /  `ClientSecret::new(s)` /
#       `AccessToken` /  `IdToken<...>` /  `RefreshToken`
#       typed newtype wrappers for type-safe protocol
#       manipulation
#     • Full typed JWT validation chain — typed JWS signature
#       verification (RS256, RS384, RS512, PS256, PS384, PS512,
#       ES256, ES384, EdDSA, HS256, HS384, HS512), typed
#       claims validation (iss/aud/exp/nbf/iat/nonce), typed
#       JWKS rotation via the `JwkSetUrl` discovery
#     • Typed integrations with `reqwest` (default) and `surf`
#       HTTP backends; rustls + native-tls + openssl TLS
#       choices
#     • Apple Sign In typed Core extensions
#     • Google + Microsoft + Auth0 + Okta + Keycloak +
#       Authentik provider quirks handled out of the box
#
#   `openidconnect-rs` is the OIDC library behind every modern
#   Rust OIDC integration in production:
#
#     • **Hyperswitch** (juspay) — the open-source payments
#       gateway (42,823+ ★; OIDC for merchant auth)
#     • **Windmill Labs** windmill — Open-source developer
#       platform (16,634+ ★; OIDC for tenant SSO)
#     • **boxlite-ai/boxlite** — AI agent compute substrate
#       (2,107+ ★; OIDC for agent identity; covered as
#       `_boxlite`)
#     • **Trieve** (devflowinc/trieve) — open-source
#       all-in-one AI search engine + RAG
#     • **mdn/rumba** — Mozilla Developer Network's clean-up
#       project (Kuma re-engineered)
#     • **Golem Cloud** — durable computing platform
#     • **olivierlambert/calrs** (this very project; the Rust
#       Cal.com alternative)
#     • **Mastodon Tafarn** (TheEnbyperor/tafarn) —
#       ActivityPub home server
#     • **Frona** — fronalabs/frona
#     • **Espresso Lab oidc-forward-auth-middleware** —
#       NGINX/Traefik forward-auth OIDC sidecar
#     • **Keystone (OpenStack)** Rust port
#     • **Divedb** (cetra3/divedb) — federated diving log
#     • **Gyre** (amanjeev/gyre) — experimental API gateway
#       supporting multiple OIDC issuers
#     • Plus dozens of community SSO gateways, identity
#       brokers, and self-hosted SaaS replacements.
#
#   OAuth 2.0 + OpenID Connect (OIDC) together form **the
#   universal identity and authorization protocol of the modern
#   web** — collectively standardized by the IETF (OAuth 2.0:
#   RFC 6749 base + RFC 6750 Bearer Token + RFC 7009 Revocation
#   + RFC 7591 Dynamic Client Registration + RFC 7592 + RFC
#   7636 PKCE + RFC 7662 Token Introspection + RFC 8252 OAuth
#   2.0 for Native Apps + RFC 9068 JWT Bearer Tokens + RFC
#   9126 Pushed Authorization Requests + RFC 9207 Authorization
#   Server Issuer Identification + the OAuth 2.1 consolidation
#   draft) and the OpenID Foundation (OpenID Connect Core
#   1.0 + OIDC Discovery 1.0 + OIDC Dynamic Client Registration
#   1.0 + OIDC Session Management 1.0 + OIDC Front-Channel
#   Logout + OIDC Back-Channel Logout + OIDC RP-Initiated
#   Logout + OIDC CIBA Client-Initiated Backchannel
#   Authentication + OIDC Federation 1.0 + FAPI 1.0 / 2.0
#   Financial-grade API profiles).
#
#   Every major identity provider speaks OIDC:
#
#     • **Auth0** (Okta) — the dominant SaaS IdP
#     • **Okta Workforce + Customer Identity Cloud**
#     • **Microsoft Entra ID** (formerly Azure AD) — the
#       Microsoft-Office365 enterprise IdP
#     • **Google Identity Platform** + **Google Workspace**
#       + **Sign in with Google**
#     • **Apple ID** + **Sign in with Apple**
#     • **GitHub OAuth** + **GitHub Enterprise OIDC**
#     • **GitLab OIDC**
#     • **AWS Cognito**
#     • **Keycloak** — the canonical open-source IdP
#     • **Authentik** — the rising open-source IdP
#       alternative (covered in this corpus on the LDAP axis)
#     • **PingFederate** + **PingOne**
#     • **ForgeRock OpenAM + OpenIDM**
#     • **CyberArk Identity** + **CyberArk PAM**
#     • **OneLogin**
#     • **JumpCloud**
#     • **Cloudflare Access**
#     • **Tailscale SSO**
#     • **WorkOS**
#     • **Stytch**
#     • **Clerk.dev**
#     • **FusionAuth**
#     • **Logto**
#     • **Zitadel**
#     • **CASBin**
#     • **Ory Hydra + Kratos**
#     • **dex** (CoreOS / Red Hat)
#     • **Boruta**
#
#   Verified via:
#     gh api repos/olivierlambert/calrs/contents/Cargo.toml
#       → [package] name = "calrs"
#       → [package] license = "AGPL-3.0"
#       → [[bin]] name = "calrs"  path = "src/main.rs"
#       → [dependencies] openidconnect = { version = "4.0.1",
#                                            default-features = false,
#                                            features = ["reqwest",
#                                                         "rustls-tls"] }
#         (DIRECT)
#     raw.githubusercontent.com olivierlambert/calrs main src/
#         main.rs
#       → mod auth;  mod caldav;  mod commands;  mod crypto;
#         mod db;  mod email;  mod i18n;  mod models;
#         mod oauth2_caldav;  mod rrule;  mod utils;  mod web;
#       → use clap::{Parser, Subcommand};
#       → #[derive(Parser)]
#         #[command(name = "calrs",
#                   about = "Fast, self-hostable scheduling",
#                   version)]
#         struct Cli { data_dir: Option<PathBuf>,
#                       #[command(subcommand)] command: Commands }
#       → enum Commands { Source { command }, Sync { full },
#                          Calendar { command }, EventType
#                          { command }, Booking { command },
#                          User { command }, Config { command },
#                          Serve { port: 3000, host:
#                          127.0.0.1 } }
#       → enum CalendarCommands { Show { from, to } }
#
#   This entry is the Rust=179 leader bump that **OPENS Axis 124
#   (OAuth 2.0 / OpenID Connect 1.0 / IETF RFC 6749 + RFC 8252
#   + RFC 7636 PKCE + OIDC Discovery + OIDC Dynamic Client
#   Registration identity protocol)** at 1/0/0 following R1069
#   _openapi-to-graphql (TS-Node=178 CLOSED Axis 123 GraphQL at
#   1/1/1 triple-178 + 116th axis closed).  **R1070 ROUND-NUMBER
#   commit landmark.**  Go=179 continuation on deck for R1071
#   via the canonical Go OIDC library `zitadel/oidc` (the
#   ZITADEL team's reference Go OIDC implementation, the
#   dominant Go OIDC stack used by ZITADEL itself, dex, AWS
#   Pomerium, the Cloudflare Access internal tooling, and
#   dozens of production Go SSO gateways).  TS-Node=179 closing
#   pair at R1072 via the canonical Node.js OIDC library
#   `panva/node-openid-client` (Filip Skokan's reference
#   Node.js OIDC implementation, the dominant Node-side OIDC
#   dependency used by Next-Auth, Auth.js, Strapi, Keycloak's
#   Node.js admin tooling, and every production Node SSO
#   integration).
#
#   No completion for `calrs` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_calrs() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '--data-dir=[custom data directory (env CALRS_DATA_DIR)]:dir:_files -/' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _cl_cmds=(
                'source:manage CalDAV sources'
                'sync:pull latest events from CalDAV sources'
                'calendar:view your calendar'
                'event-type:manage bookable event types'
                'booking:manage bookings'
                'user:manage admin users'
                'config:configure calrs settings (OIDC, SMTP, general)'
                'serve:start the web booking server'
            )
            _describe -t commands 'calrs command' _cl_cmds && ret=0
            ;;
        args)
            case $words[1] in
                source)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'source action' '(add list remove show)' && ret=0
                    fi
                    ;;
                sync)
                    _arguments '--full[full re-sync (ignore sync tokens)]' && ret=0
                    ;;
                calendar)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'calendar action' '(show)' && ret=0
                    elif [[ $words[2] == show ]]; then
                        _arguments \
                            '--from=[start date YYYY-MM-DD]:date:' \
                            '--to=[end date YYYY-MM-DD]:date:' && ret=0
                    fi
                    ;;
                event-type)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'event-type action' '(add list remove show update)' && ret=0
                    fi
                    ;;
                booking)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'booking action' '(list cancel reschedule show)' && ret=0
                    fi
                    ;;
                user)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'user action' '(add list remove set-role)' && ret=0
                    fi
                    ;;
                config)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'config action' '(oidc smtp general)' && ret=0
                    fi
                    ;;
                serve)
                    _arguments \
                        '--port=[port to listen on (default 3000)]:port:' \
                        '--host=[address to bind to (default 127.0.0.1)]:addr:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_calrs "$@"
