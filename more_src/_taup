#compdef taup
# Documentation: https://taup.readthedocs.io/en/latest/
# TauP Toolkit dispatcher for seismic travel-time and raypath tools

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:tool:(time path curve pierce setsac wavefront table distaz find phase create web spikes setms3)' \
  '*::args:_files' && ret=0

return ret
