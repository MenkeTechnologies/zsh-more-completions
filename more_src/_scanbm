#compdef scanbm
# Documentation: https://manpages.org/scanbm/8
# SANE scanner button daemon manager mode

local ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config=}'[use configfile instead of the default scanbd.conf]:file:_files' \
  '(-d --debug)'{-d-,--debug=-}'[turn debug mode on with optional level 1-7]::level:(1 2 3 4 5 6 7)' \
  '(-s --signal)'{-s,--signal}'[use SIGUSR1/SIGUSR2 instead of dbus to stop/restart polling]' \
  '(-t --trigger)'{-t,--trigger=}'[trigger action for the numerical device]:device' \
  '(-a --action)'{-a,--action=}'[numerical action to be triggered]:action' \
  '-m[invoke as manager mode]' && ret=0

return ret
