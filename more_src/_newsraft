#compdef newsraft

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --feeds)'{-d+,--feeds=}'[feeds db file]:file:_files' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-D --data-dir)'{-D+,--data-dir=}'[data dir]:dir:_files -/' \
  '(-x --explore)'{-x,--explore}'[explore mode]' \
  '(-u --update)*'{-u+,--update=}'[update url/feed]:u:' \
  '(-U --update-all)'{-U,--update-all}'[update all]' \
  '*: :' && ret=0

return ret
