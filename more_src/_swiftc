#compdef swiftc

# Zsh completion for swiftc - Swift compiler

_arguments -s -S \
  '-c[compile without linking]' \
  '-o+[output file]:output file:_files' \
  '-O[optimize for speed]' \
  '-Osize[optimize for size]' \
  '-Onone[no optimization]' \
  '-g[generate debug information]' \
  '-module-name+[module name]:name' \
  '-emit-module[emit a module file]' \
  '-emit-library[emit a shared library]' \
  '-emit-object[emit object file(s)]' \
  '-emit-executable[emit an executable]' \
  '-emit-assembly[emit assembly file(s)]' \
  '-emit-ir[emit LLVM IR file(s)]' \
  '-emit-bc[emit LLVM bitcode file(s)]' \
  '-emit-sil[emit SIL file(s)]' \
  '-emit-silgen[emit raw SIL file(s)]' \
  '-parse[parse input file(s)]' \
  '-typecheck[type-check input file(s)]' \
  '-dump-ast[dump AST]' \
  '-dump-parse[dump parse tree]' \
  '-print-ast[print AST]' \
  '*-I+[add import search path]:search path:_directories' \
  '*-L+[add library search path]:search path:_directories' \
  '*-l+[link with library]:library name' \
  '*-F+[add framework search path]:search path:_directories' \
  '*-framework+[link with framework]:framework name' \
  '-sdk+[SDK path]:sdk path:_directories' \
  '-target+[target triple]:target triple' \
  '-target-variant+[target variant triple]:target variant' \
  '-swift-version+[Swift language version]:version:(4 4.2 5 6)' \
  '-whole-module-optimization[optimize across the entire module]' \
  '-num-threads+[number of threads]:threads' \
  '*-D+[define a conditional compilation flag]:flag' \
  '-suppress-warnings[suppress all warnings]' \
  '-warnings-as-errors[treat warnings as errors]' \
  '-j+[number of parallel jobs]:jobs' \
  '-v[verbose output]' \
  '-###[print commands without executing]' \
  '*-Xcc+[pass flag to C compiler]:flag' \
  '*-Xlinker+[pass flag to linker]:flag' \
  '*-Xfrontend+[pass flag to frontend]:flag' \
  '*-Xllvm+[pass flag to LLVM]:flag' \
  '-static[make a static library]' \
  '-static-stdlib[statically link the Swift standard library]' \
  '-static-executable[statically link the executable]' \
  '-enable-library-evolution[enable library evolution]' \
  '-enable-testing[enable testability]' \
  '-parse-as-library[parse input as a library]' \
  '-parse-stdlib[parse input as the standard library]' \
  '-index-store-path+[store index data to path]:path:_directories' \
  '-serialize-diagnostics[serialize diagnostics to file]' \
  '-module-cache-path+[module cache path]:path:_directories' \
  '*-enable-experimental-feature+[enable experimental feature]:feature' \
  '-package-name+[package name]:name' \
  '*:swift files:_files -g "*.swift"'
