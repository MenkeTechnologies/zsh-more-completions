#compdef nicegui

_nicegui() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_nicegui_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                run)
                    _arguments \
                        '--host[host to bind to]:host:_hosts' \
                        '--port[port to listen on]:port:' \
                        '--title[page title]:title:' \
                        '--dark[enable dark mode]' \
                        '--binding-refresh_interval[binding refresh interval in seconds]:interval:' \
                        '--reload[enable auto-reload on code changes]' \
                        '--show[open browser on start]' \
                        '(- *)'{-h,--help}'[show help]' \
                        '*:app module:_files -g "*.py"' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_nicegui_commands] )) ||
_nicegui_commands() {
    local -a commands
    commands=(
        'run:run a NiceGUI application'
    )
    _describe -t commands 'nicegui command' commands
}

_nicegui "$@"
