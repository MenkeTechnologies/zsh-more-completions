#compdef hhconsensus
# Documentation: https://github.com/soedinglab/hh-suite/wiki
# HHconsensus: calculate the consensus sequence for an A3M/FASTA input alignment

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i+[query alignment A2M/A3M/FASTA or query HMM]:input file:_files' \
  '-s+[append consensus sequence in FASTA]:seq file:_files' \
  '-o+[write alignment with consensus sequence in A3M]:a3m file:_files' \
  '-oa3m+[write alignment with consensus sequence in A3M]:a3m file:_files' \
  '-oa2m+[write alignment with consensus sequence in A2M]:a2m file:_files' \
  '-ofas+[write alignment with consensus sequence in FASTA]:fasta file:_files' \
  '-v+[verbose mode]:level:(0 1 2)' \
  '-id+[maximum pairwise sequence identity]:int' \
  '-diff+[filter most diverse set of sequences]:int' \
  '-cov+[minimum coverage with query]:int' \
  '-qid+[minimum sequence identity with query]:int' \
  '-qsc+[minimum score per column with query]:num' \
  '-M+[input alignment format: a2m/first/percentage]:mode' \
  '-maxseq+[max number of input rows]:int' \
  '-maxres+[max number of HMM columns]:int' && ret=0

return ret
