#compdef rtarea
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=rtarea&sektion=1
# BRL-CAD presented-area computation via raytracing

local ret=1

_arguments -s \
  '-n[number of steps to execute]:steps' \
  '-c[set configuration command (e.g. "set cc=1")]:command' \
  '-x[librt debug flags (hex)]:flags' \
  '-X[rtarea debug flags (hex)]:flags' \
  '1:database:_files -g "*.g"' \
  '*:object:_default' && ret=0

return ret
