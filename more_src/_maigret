#compdef maigret

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--info[show information about supported sites]' \
  '--site[limit search to specific site]:site name:' \
  '--use-disabled-sites[include disabled sites in search]' \
  {-a,--all-sites}'[search across all sites]' \
  '--top-sites[search only top N sites]:count:' \
  '--tags[filter sites by tags]:tags:' \
  '--timeout[request timeout in seconds]:seconds:' \
  '--retries[number of retries for failed requests]:count:' \
  '--max-connections[max concurrent connections]:count:' \
  '--proxy[proxy URL]:proxy url:' \
  '--tor[use Tor for requests]' \
  '--i2p[use I2P for requests]' \
  {-v,--verbose}'[increase verbosity]' \
  '--no-color[disable colored output]' \
  '--no-progressbar[disable progress bar]' \
  '--print-not-found[print sites where username was not found]' \
  '--print-errors[print errors during search]' \
  '--json[output results as JSON]:output file:_files -g "*.json"' \
  '--csv[output results as CSV]:output file:_files -g "*.csv"' \
  '--txt[output results as text]:output file:_files -g "*.txt"' \
  '--html[output results as HTML]:output file:_files -g "*.html"' \
  '--pdf[output results as PDF]:output file:_files -g "*.pdf"' \
  '--xmind[output results as XMind]:output file:_files -g "*.xmind"' \
  {-o,--output}'[output directory]:directory:_directories' \
  '--folderoutput[save results to folder]:directory:_directories' \
  '--reports-sorting[sort reports by]:sort key:(data default)' \
  '--permute[permute username variations]' \
  '--no-recursion[do not search for related usernames]' \
  '--self-check[perform a self-check of the database]' \
  '--stats[show search statistics]' \
  '--db[path to custom database file]:database:_files -g "*.json"' \
  '--cookies[cookies for requests]:cookies:' \
  '--no-update[do not check for updates]' \
  '*:username:' && ret=0

return ret
