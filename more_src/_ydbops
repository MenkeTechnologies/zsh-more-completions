#compdef ydbops
# _ydbops — YDB cluster maintenance CLI (ydb-platform/ydbops)
# upstream: https://github.com/ydb-platform/ydbops
# Subcommands from cmd/root.go (cobra).

_ydbops() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[debug-level logging]' \
        '--endpoint=[YDB grpc endpoint]:url:' \
        '--ca-file=[trusted CA cert]:file:_files -g "*.(pem|crt)"' \
        '--user=[YDB username]:user:' \
        '--password-file=[YDB password file]:file:_files' \
        '--token-file=[auth token file]:file:_files' \
        '--profile=[ydbops profile]:profile:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'maintenance:request/list/complete/refresh maintenance tasks'
                'restart:rolling restart of cluster nodes'
                'run:run ad-hoc operations on cluster nodes'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                maintenance) _arguments '1:sub:(create list complete drop refresh)' ;;
                restart) _arguments '1:sub:(storage tenant cluster)' ;;
            esac
            ;;
    esac
}

_ydbops "$@"
