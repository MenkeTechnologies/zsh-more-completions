#compdef unimatrix

# Zsh completion for unimatrix - Matrix terminal effect with Unicode

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-a[asynchronous scroll (varying speeds)]' \
  '-b[use bold characters]' \
  '-c[color]:color:(green red blue white yellow cyan magenta black)' \
  '-f[use a Flash/thunderbolt effect]' \
  '-g[character set]:chars:(a c d e g j k l m o p r s t u)' \
  '-l[character list]:characters:' \
  '-n[do not use bold characters]' \
  '-o[set speed]:speed:' \
  '-s[set speed]:speed:' \
  '-t[set time between frames]:time:' \
  '-w[use single-width characters only]'
