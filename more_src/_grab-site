#compdef grab-site
# Documentation: https://github.com/ArchiveTeam/grab-site
# grab-site - crawler for backing up websites to WARC

local ret=1

_arguments -s -S \
  '--help[display help text]' \
  '--1[grab only the URL and page requisites without recursing]' \
  '(-i --input-file)'{-i,--input-file}'[load URLs from a local file or URL]:file:_files' \
  '--igsets=[use specified ignore sets]:igsets' \
  '--no-global-igset[disable the default global ignore set]' \
  '--igon[print all ignored URLs to terminal and dashboard]' \
  '--import-ignores=[copy ignore file to DIR/ignores before crawl]:file:_files' \
  '--no-offsite-links[avoid following links to depth 1 on other domains]' \
  '--no-sitemaps[do not queue URLs from sitemap.xml]' \
  '--no-video[skip video downloads by MIME type and extension]' \
  '--max-content-length=[skip responses larger than N bytes]:bytes' \
  '--no-dupespotter[disable duplicate page detection]' \
  '--concurrency=[use N parallel connections]:n' \
  '--delay=[wait N milliseconds between requests]:ms' \
  '--warc-max-size=[limit WARC files to ~BYTES before rollover]:bytes' \
  '--finished-warc-dir=[move finished WARCs to specified directory]:dir:_files -/' \
  '--dir=[set control file directory]:dir:_files -/' \
  '--level=[recurse N levels instead of infinite]:n' \
  '--page-requisites-level=[recurse page requisites N levels]:n' \
  '--id=[use custom crawl ID]:id' \
  '--permanent-error-status-codes=[HTTP codes not to retry]:codes' \
  '--ua=[custom User-Agent header]:useragent' \
  '--wpull-args=[additional wpull arguments]:args' \
  '--which-wpull-args-partial[print wpull arguments and exit]' \
  '--which-wpull-command[print full wpull command without executing]' \
  '--debug[enable debug output]' \
  '*:url:_urls' && ret=0

return ret
