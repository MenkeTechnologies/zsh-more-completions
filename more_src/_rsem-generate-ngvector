#compdef rsem-generate-ngvector
# Documentation: https://github.com/deweylab/RSEM/blob/master/README.md
# RSEM: cluster transcripts by read-mapping ambiguity into an Ng vector

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-k[k-mer length (default 25)]:int' \
  '1:input fasta file:_files' \
  '2:output name:' && ret=0

return ret
