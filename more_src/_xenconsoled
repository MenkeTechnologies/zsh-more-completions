#compdef xenconsoled

# xenconsoled: Xen guest console daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-i[run in foreground]' \
  '--interactive[run in foreground]' \
  '--log=[log destination]:dest:(none guest hv)' \
  '--log-dir=[log directory]:dir:_files -/' \
  '--pid-file=[PID file]:file:_files' \
  '--timestamp=[timestamp]:val:(none guest hv all)' \
  '*::xenconsoled args:_files' && ret=0
return ret
