#compdef xenconsoled
# Documentation: https://github.com/xen-project/xen/blob/master/tools/console/daemon/main.c
# Reference accessed: 2026-05-21
# Verified: upstream tools/console/daemon/main.c getopt_long quoted from source.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-i --interactive)'{-i,--interactive}'[run interactively (do not daemonize)]' \
  '(-l --log)'{-l+,--log=}'[log destination]:dest:(none guest hv all)' \
  '(-r --log-dir)'{-r+,--log-dir=}'[console log directory]:dir:_files -/' \
  '(-p --pid-file)'{-p+,--pid-file=}'[PID file]:file:_files' \
  '(-t --timestamp)'{-t+,--timestamp=}'[timestamp logs]:when:(none guest hv all)' \
  '(-o --overflow-data)'{-o+,--overflow-data=}'[buffer overflow handling]:mode:(discard keep)' \
  '(-e --replace-escape)'{-e,--replace-escape}'[replace ESC characters with dots in console logs]' && ret=0
return ret
