#compdef dotstate
# Documentation: https://github.com/serkanyersen/dotstate
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: cargo binstall dotstate@0.3.2, probed via `dotstate completions zsh`
# Repository: https://github.com/serkanyersen/dotstate

autoload -U is-at-least

_dotstate() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_dotstate_commands" \
"*::: :->dotstate" \
&& ret=0
    case $state in
    (dotstate)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dotstate-command-$line[1]:"
        case $line[1] in
            (sync)
_arguments "${_arguments_options[@]}" : \
'-m+[Custom commit message]:MESSAGE:_default' \
'--message=[Custom commit message]:MESSAGE:_default' \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-v[Show detailed information]' \
'--verbose[Show detailed information]' \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
'--common[Add as a common file (shared across all profiles)]' \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
':path -- Path to the file to add:_files' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
'--common[Remove from common files (shared across all profiles)]' \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
':path -- Path to the file to remove (relative to home directory, e.g., ".zshrc"):_default' \
&& ret=0
;;
(activate)
_arguments "${_arguments_options[@]}" : \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(deactivate)
_arguments "${_arguments_options[@]}" : \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
'--fix[Attempt to auto-fix detected issues]' \
'-v[Show detailed diagnostic information]' \
'--verbose[Show detailed diagnostic information]' \
'--json[Output results as JSON for scripting]' \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(logs)
_arguments "${_arguments_options[@]}" : \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(repository)
_arguments "${_arguments_options[@]}" : \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
'::command -- Command to show help for:_default' \
&& ret=0
;;
(upgrade)
_arguments "${_arguments_options[@]}" : \
'--check[Check for updates without prompting to install]' \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(packages)
_arguments "${_arguments_options[@]}" : \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
":: :_dotstate__packages_commands" \
"*::: :->packages" \
&& ret=0

    case $state in
    (packages)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dotstate-packages-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
'-p+[Target profile (defaults to active profile)]:PROFILE:_default' \
'--profile=[Target profile (defaults to active profile)]:PROFILE:_default' \
'-v[Show detailed package information]' \
'--verbose[Show detailed package information]' \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
'-p+[Target profile (defaults to active profile)]:PROFILE:_default' \
'--profile=[Target profile (defaults to active profile)]:PROFILE:_default' \
'-n+[Package display name]:NAME:_default' \
'--name=[Package display name]:NAME:_default' \
'-m+[Package manager (brew, cargo, apt, npm, pip, custom, etc.)]:MANAGER:_default' \
'--manager=[Package manager (brew, cargo, apt, npm, pip, custom, etc.)]:MANAGER:_default' \
'-b+[Binary name to check for existence]:BINARY:_default' \
'--binary=[Binary name to check for existence]:BINARY:_default' \
'--description=[Optional description]:DESCRIPTION:_default' \
'--package-name=[Package name in the manager (defaults to binary name)]:PACKAGE_NAME:_default' \
'--install-command=[Install command (required for custom manager)]:INSTALL_COMMAND:_default' \
'--existence-check=[Command to check if package exists (optional, for custom)]:EXISTENCE_CHECK:_default' \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
'-p+[Target profile (defaults to active profile)]:PROFILE:_default' \
'--profile=[Target profile (defaults to active profile)]:PROFILE:_default' \
'-y[Skip confirmation prompt]' \
'--yes[Skip confirmation prompt]' \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Package name to remove:_default' \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
'-p+[Target profile (defaults to active profile)]:PROFILE:_default' \
'--profile=[Target profile (defaults to active profile)]:PROFILE:_default' \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
'-p+[Target profile (defaults to active profile)]:PROFILE:_default' \
'--profile=[Target profile (defaults to active profile)]:PROFILE:_default' \
'-v[Show package manager output]' \
'--verbose[Show package manager output]' \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
'::command -- Command to show help for:_default' \
&& ret=0
;;
        esac
    ;;
esac
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--no-colors[Disable colors in the TUI (also respects \`NO_COLOR\` env var)]' \
'-h[Print help]' \
'--help[Print help]' \
'::shell -- The shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_dotstate_commands] )) ||
_dotstate_commands() {
    local commands; commands=(
'sync:Sync with remote\: commit, pull (with rebase), and push' \
'list:List all synced files' \
'add:Add a file to sync' \
'remove:Remove a file from sync' \
'activate:Activate the symlinks, restores app state after deactivation' \
'deactivate:Deactivate symlinks. this might be useful if you are going to uninstall dotstate or you need the original files' \
'doctor:Run diagnostics and optionally fix issues' \
'logs:Shows logs location and how to view them' \
'config:Configuration file location' \
'repository:Repository location' \
'help:Show help for a specific command' \
'upgrade:Check for updates and optionally upgrade \`DotState\`' \
'packages:Manage packages for profiles' \
'completions:Generate command-line completions' \
    )
    _describe -t commands 'dotstate commands' commands "$@"
}
(( $+functions[_dotstate__activate_commands] )) ||
_dotstate__activate_commands() {
    local commands; commands=()
    _describe -t commands 'dotstate activate commands' commands "$@"
}
