#compdef kubeblocks-manager
# _kubeblocks-manager — KubeBlocks Apps/Workloads/Operations controller (apecloud/kubeblocks)
# upstream: https://github.com/apecloud/kubeblocks
# Flags from cmd/manager/main.go on tip.

_kubeblocks-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-id=[leader-election lock name]:name:' \
        '--leader-elect-lease-duration=[leader lease duration (s)]:n:' \
        '--leader-elect-renew-deadline=[leader renew deadline (s)]:n:' \
        '--leader-elect-retry-period=[leader retry period (s)]:n:' \
        '--apps=[enable Apps controllers]:bool:(true false)' \
        '--workloads=[enable Workloads controllers]:bool:(true false)' \
        '--operations=[enable Operations controllers]:bool:(true false)' \
        '--extensions=[enable Extensions controllers]:bool:(true false)' \
        '--experimental=[enable experimental controllers]:bool:(true false)' \
        '--trace=[enable trace logging]:bool:(true false)' \
        '--parameters=[enable Parameters controller]:bool:(true false)' \
        '--multi-cluster-kubeconfig=[multi-cluster kubeconfig paths]:list:' \
        '--multi-cluster-contexts=[kube contexts the manager talks to]:list:' \
        '--multi-cluster-contexts-disabled=[disabled kube contexts]:list:' \
        '--managed-namespaces=[restrict managed namespaces (list)]:list:' \
        '--user-agent=[operator User-Agent]:ua:' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_kubeblocks-manager "$@"
