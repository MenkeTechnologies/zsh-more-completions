#compdef vtctl

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--server[server to connect to]:server address' \
  '--alsologtostderr[log to stderr as well]' \
  '--v[log level for V logs]:level' \
  '--log_dir[directory for log files]:directory:_directories' \
  '--stderrthreshold[logs at or above this threshold go to stderr]:threshold:(INFO WARNING ERROR FATAL)' \
  '--logtostderr[log to stderr instead of files]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'InitTablet:initialize a tablet in the topology'
      'GetTablet:get tablet info'
      'ListAllTablets:list all tablets in a cell'
      'DeleteTablet:delete tablet from topology'
      'Ping:ping a tablet'
      'RefreshState:refresh tablet state from topo'
      'RunHealthCheck:run a health check on a tablet'
      'Sleep:sleep for a duration on a tablet'
      'CreateShard:create a shard'
      'GetShard:get shard info'
      'DeleteShard:delete a shard'
      'ListShards:list shards in a keyspace'
      'TabletExternallyReparented:update topology after external reparent'
      'InitShardPrimary:set the initial primary for a shard'
      'CreateKeyspace:create a keyspace'
      'GetKeyspace:get keyspace info'
      'DeleteKeyspace:delete a keyspace'
      'ListKeyspaces:list all keyspaces'
      'SetKeyspaceServedFrom:change a keyspace served-from map'
      'VtctldCommand:run a vtctld gRPC command'
      'Validate:validate topology'
      'GetSchema:get schema for tablets'
      'ApplySchema:apply schema changes'
      'ApplyVSchema:apply vschema changes'
    )
    _describe -t commands 'vtctl command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      InitTablet)
        _arguments \
          '--hostname[hostname for the tablet]:hostname' \
          '--port[port for the tablet]:port' \
          '--grpc_port[gRPC port for the tablet]:port' \
          '--keyspace[keyspace for the tablet]:keyspace' \
          '--shard[shard for the tablet]:shard' \
          '--tablet-type[tablet type]:type:(primary replica rdonly spare backup restore)' \
          '*:tablet alias' && ret=0
        ;;
      GetTablet|DeleteTablet|Ping|RefreshState|RunHealthCheck)
        _arguments '*:tablet alias' && ret=0
        ;;
      Sleep)
        _arguments ':tablet alias' ':duration' && ret=0
        ;;
      CreateShard|GetShard|DeleteShard)
        _arguments \
          '--force[force creation]' \
          '*:keyspace/shard' && ret=0
        ;;
      ListShards)
        _arguments '*:keyspace' && ret=0
        ;;
      ListAllTablets)
        _arguments '*:cell' && ret=0
        ;;
      InitShardPrimary)
        _arguments \
          '--force[force reparent even if primary already exists]' \
          '--wait_replicas_timeout[time to wait for replicas]:timeout' \
          ':keyspace/shard' ':tablet alias' && ret=0
        ;;
      CreateKeyspace|GetKeyspace|DeleteKeyspace)
        _arguments '*:keyspace' && ret=0
        ;;
      GetSchema)
        _arguments \
          '--tables[comma-separated list of tables]:tables' \
          '--exclude_tables[tables to exclude]:tables' \
          '--include-views[include views]' \
          '*:tablet alias' && ret=0
        ;;
      ApplySchema)
        _arguments \
          '--sql[SQL to apply]:sql' \
          '--sql-file[file containing SQL]:file:_files' \
          '*:keyspace' && ret=0
        ;;
      ApplyVSchema)
        _arguments \
          '--vschema[vschema JSON]:json' \
          '--vschema_file[file containing vschema]:file:_files' \
          '*:keyspace' && ret=0
        ;;
      TabletExternallyReparented)
        _arguments '*:tablet alias' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
