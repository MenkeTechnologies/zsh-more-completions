#compdef sfddiff

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--ignore-hints[ignore hint differences]' \
  '--ignore-bitmaps[ignore bitmap diffs]' \
  '--diff-hints[diff hints]' \
  '--merge=+[merge into base]:file:_files -g "*.sfd"' \
  '*:sfd file:_files -g "*.sfd"' && ret=0

return ret
