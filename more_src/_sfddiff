#compdef sfddiff
# Documentation: https://man.archlinux.org/man/sfddiff.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show option list]' \
  '(- *)--usage[show usage description]' \
  '(- *)--version[show version]' \
  '--ignorehints[suppress hint/instruction diffs]' \
  '--ignoregpos[suppress kerning/gpos diffs]' \
  '--ignoregsub[suppress ligature/gsub diffs]' \
  '--ignorenames[suppress name string diffs]' \
  '--ignorebitmaps[suppress bitmap diffs]' \
  '--exact[require exact outline match]' \
  '--warn[warn on slight outline/reference diffs]' \
  '--merge[create merged sfd; sfdfile2 outlines go to background]:outfile:_files' \
  '*:sfd file:_files -g "*.sfd"' && ret=0

return ret
