#compdef tjs
# Documentation: https://github.com/saghul/txiki.js
# Reference accessed: 2026-05-27
# Verified: upstream src/js/run-main/index.js getopts spec and help strings
# (subcommands run, eval, serve, test, bundle, compile, app on master branch).

local curcontext="$curcontext" state line ret=1
local -a _tjs_subcommands

_tjs_subcommands=(
  'run:run a JavaScript program'
  'eval:evaluate a JavaScript expression'
  'serve:serve an HTTP application'
  'test:run tests in the given directory'
  'bundle:bundle a JavaScript/TypeScript file using esbuild'
  'compile:compile a file into a standalone executable'
  'app:manage tpk app packages'
)

local -a _tjs_app_subcommands
_tjs_app_subcommands=(
  'init:create a template app in the current directory'
  'pack:package the app into a .tpk file'
  'compile:compile the app into a standalone executable'
)

_arguments -C \
  '(-v --version)'{-v,--version}'[print version information]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-e --eval)'{-e+,--eval=}'[evaluate a JavaScript expression]:expression:' \
  '--memory-limit=[set memory limit for JS runtime]:bytes:' \
  '--stack-size=[set maximum JS stack size]:bytes:' \
  '--wasm-stack-size=[set the WebAssembly stack size]:bytes:' \
  '--tls-ca=[path to a custom CA bundle PEM file]:file:_files' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'tjs subcommand' _tjs_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments \
          '--import-map=[path to an import map JSON file]:file:_files -g "*.json"' \
          '*:file:_files -g "*.(js|mjs|cjs|ts|wasm)"' && ret=0
        ;;
      eval)
        _arguments '*:expression:' && ret=0
        ;;
      serve)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port to listen on]:port:' \
          '--tls-cert=[path to TLS certificate PEM file]:file:_files' \
          '--tls-key=[path to TLS private key PEM file]:file:_files' \
          '*:file:_files -g "*.(js|mjs|ts)"' && ret=0
        ;;
      bundle)
        _arguments \
          '(-m --minify)'{-m,--minify}'[minify the output]' \
          '*:file:_files -g "*.(js|mjs|ts)"' && ret=0
        ;;
      compile)
        _arguments '*:file:_files -g "*.(js|mjs|ts)"' && ret=0
        ;;
      test)
        _arguments '*:directory:_files -/' && ret=0
        ;;
      app)
        if (( CURRENT == 2 )); then
          _describe -t commands 'tjs app subcommand' _tjs_app_subcommands && ret=0
        else
          _files && ret=0
        fi
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
