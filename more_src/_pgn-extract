#compdef pgn-extract
# _pgn-extract — PGN game extractor and filter (D.J. Barnes / pgn-extract)
# upstream: https://www.cs.kent.ac.uk/people/staff/djb/pgn-extract/
# Flags from help.html.

_pgn-extract() {
    _arguments \
        '(- *)-h[show brief help]' \
        '(- *)'{-\?,--help}'[show help]' \
        '(- *)--version[show version]' \
        '-C[suppress all comments]' \
        '-D[do not output duplicate games]' \
        '*-e+[ECO classification file]:file:_files' \
        '-emy[use my ECO classifications]' \
        '-t+[tag-match file]:file:_files' \
        '-T+[tag command]:cmd:' \
        '-Wcm[output in chess-master format]' \
        '-Wepd[output as EPD]' \
        '-Wfen[output as FEN]' \
        '-Wlalg[output in long algebraic]' \
        '-Wuci[output in UCI format]' \
        '-y+[bookmark file]:file:_files' \
        '--addfencastling[add castling rights to FEN]' \
        '--addhashcode[add hashcode comment]' \
        '--addlabeltag[add label tag]' \
        '--addmatchtag[add match tag]' \
        '--allownullmoves[allow null moves]' \
        '--append[append to output]' \
        '--btm[only black-to-move positions]' \
        '--checkfile=[check tags file]:file:_files' \
        '--checkmate[only games ending in checkmate]' \
        '--commented[only games with comments]' \
        '--commentlines[output comments on separate lines]' \
        '--deletesamesetup[delete duplicate setups]' \
        '--detag=[delete tag]:tag:' \
        '--dropbefore=[drop moves before token]:token:' \
        '--dropply=[drop moves before ply]:n:' \
        '--duplicates=[duplicates output file]:file:_files' \
        '--evaluation[require evaluation comments]' \
        '--fencomments[insert FEN comments]' \
        '--fenpattern=[match FEN regex]:regex:' \
        '--fenpatterni=[match FEN regex (case-insensitive)]:regex:' \
        '--fifty[only games with 50-move rule fall]' \
        '--firstgame=[start game number]:n:' \
        '--fixresulttags[fix mismatched result tags]' \
        '--fixtagstrings[fix tag string formatting]' \
        '--fuzzydepth=[fuzzy match depth]:depth:' \
        '--gamelimit=[max games to process]:n:' \
        '--hashcomments[include hash comments]' \
        '--higherratedwinner[only games won by higher-rated]' \
        '--higherratingwinner[only games won by higher-rated]' \
        '--insufficient[detect insufficient material draws]' \
        '--keepbroken[keep broken games]' \
        '--lichesscommentfix[fix Lichess comment quirks]' \
        '--linelength=[output line length]:n:' \
        '--linenumbers[include line numbers in output]' \
        '--lowerratedwinner[only games won by lower-rated]' \
        '--lowerratingwinner[only games won by lower-rated]' \
        '--markmatches[mark matching games]' \
        '--matchplylimit=[ply limit for matches]:n:' \
        '--maxmoves=[max move count]:n:' \
        '--maxply=[max ply count]:n:' \
        '--minmoves=[min move count]:n:' \
        '--minply=[min ply count]:n:' \
        '--nestedcomments[allow nested comments]' \
        '--nobadresults[skip games with bad result]' \
        '--nochecks[suppress check / mate marks]' \
        '--nocomments[suppress comments]' \
        '--noduplicates[skip duplicates]' \
        '--nofauxep[suppress faux en passant]' \
        '--nomovenumbers[suppress move numbers]' \
        '--nonags[suppress NAGs]' \
        '--noresults[suppress result tags]' \
        '--nosetuptags[suppress setup tags]' \
        '--notags[suppress all tags]' \
        '--nounique[skip unique games]' \
        '--novars[suppress variations]' \
        '--odds[show odds info]' \
        '--onlysetuptags[only output setup tags]' \
        '--output=[output file]:file:_files' \
        '--plycount[add PlyCount tag]' \
        '--plylimit=[max plies to output per game]:n:' \
        '--quiescent[detect quiescent moves]' \
        '--quiet[quiet mode]' \
        '--repetition[detect threefold repetition draws]' \
        '--selectonly[only select games (no extract)]' \
        '--seven[seven-tag-roster output]' \
        '--seventyfive[detect 75-move-rule draws]' \
        '--skipmatching[skip matching games]' \
        '--splitvariants[split variations into separate games]' \
        '--stalemate[only games ending in stalemate]' \
        '--startply=[start at ply]:n:' \
        '--stopafter=[stop after N games]:n:' \
        '--suppressmatched[suppress matched output]' \
        '--tagsubstr[match tag substring]' \
        '--totalplycount[show total ply count]' \
        '--underpromotion[only games with underpromotion]' \
        '--vanywhere[match variation anywhere]' \
        '--wtm[only white-to-move positions]' \
        '--xroster[exclude roster from output]' \
        '*:PGN file:_files -g "*.pgn"'
}

_pgn-extract "$@"
