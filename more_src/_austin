#compdef austin

local -a arguments

arguments=(
  '(-a --alt-format)'{-a,--alt-format}'[alternative collapsed stack format]'
  '(-b --binary)'{-b,--binary}'[use binary format output]'
  '(-C --children)'{-C,--children}'[include child processes]'
  '(-e --exposure)'{-e,--exposure}'=[exposure time in seconds]:seconds:'
  '(-f --full)'{-f,--full}'[produce full output]'
  '(-g --gc)'{-g,--gc}'[sample only during GC]'
  '(-i --interval)'{-i,--interval}'=[sampling interval in microseconds]:usec:'
  '(-m --memory)'{-m,--memory}'[profile memory]'
  '(-o --output)'{-o,--output}'=[output file]:file:_files'
  '(-p --pid)'{-p,--pid}'=[attach to PID]:pid:_pids'
  '(-P --pipe)'{-P,--pipe}'[pipe mode - use with austin-tui]'
  '(-s --sleepless)'{-s,--sleepless}'[suppress idle samples]'
  '(-t --timeout)'{-t,--timeout}'=[timeout in seconds]:seconds:'
  '(-w --where)'{-w,--where}'[dump stack of a running process]'
  '(-x --exclusive)'{-x,--exclusive}'[sample only target process]'
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
  '1:python script:_files -g "*.py"'
  '*:arguments:'
)

_arguments -s -S $arguments
