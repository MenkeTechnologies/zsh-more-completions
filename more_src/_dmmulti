#compdef dmmulti
# CCP4: multi-crystal density modification and NCS averaging

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'HKLIN1[input MTZ reflection file (crystal 1)]:mtz:_files -g "*.mtz"' \
  'HKLOUT1[output MTZ reflection file (crystal 1)]:mtz:_files' \
  '*:keyword:(MODE SOLC XTAL LABIN LABOUT NCYCLE RESOLUTION SCHEME AVERAGE GRID WANG SKEL SCALE END)' && ret=0

return ret
