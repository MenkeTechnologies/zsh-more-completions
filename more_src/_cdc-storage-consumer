#compdef cdc-storage-consumer
# _cdc-storage-consumer — TiCDC reference cloud-storage downstream consumer
# upstream: https://github.com/pingcap/tiflow
# Flags from cmd/storage-consumer/main.go on tip.

_cdc-storage-consumer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-upstream-uri=[upstream storage URI (s3/gcs/azblob)]:uri:' \
        '-downstream-uri=[downstream sink URI]:uri:' \
        '-config=[changefeed config file]:file:_files' \
        '-log-file=[log file path]:file:_files' \
        '-log-level=[log level]:level:(debug info warn error)' \
        '-flush-interval=[flush interval]:dur:' \
        '-file-index-width=[file index zero-padding width]:n:' \
        '-enable-profiling[enable pprof endpoint]' \
        '-tz=[storage consumer time zone]:tz:'
}

_cdc-storage-consumer "$@"
