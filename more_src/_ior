#compdef ior
# Documentation: https://ior.readthedocs.io/en/latest/userDoc/options.html
# Parallel I/O benchmark

local ret=1

_arguments -s \
  '-a[API for I/O]:api:(POSIX MPIIO HDF5 HDFS S3 S3_EMC NCMPI RADOS)' \
  '-A[user reference number for summary]:num:' \
  '-b[contiguous bytes to write per task]:size:' \
  '-c[collective I/O mode]' \
  '-C[reorder tasks by constant offset]' \
  '-d[delay between repetitions in seconds]:seconds:' \
  '-D[seconds before stopping write or read phase]:seconds:' \
  '-e[fsync upon POSIX write close]' \
  '-E[use existing test file, do not remove]' \
  '-f[test script filename]:file:_files' \
  '-F[file-per-process mode]' \
  '-g[intra-test barriers between open/write/close]' \
  '-G[time stamp signature value]:value:' \
  '-h[display help information]' \
  '-H[display hints]' \
  '-i[test repetition count]:count:' \
  '-I[non-shared datasets per process]' \
  '-j[outlier warning threshold in seconds]:seconds:' \
  '-J[HDF5 alignment in bytes]:bytes:' \
  '-k[keep test files on exit]' \
  '-K[keep error-containing files]' \
  '-l[data packet type]:type:(offset incompressible timestamp o i t)' \
  '-m[multiple file count mode]' \
  '-M[memory allocation per node]:mem:' \
  '-n[no HDF5 fill during creation]' \
  '-N[task count for test]:count:' \
  '-o[output test filename]:file:_files' \
  '-O[IOR directives string]:directives:' \
  '-p[preallocate file size]' \
  '-P[use shared file pointer]' \
  '-q[abort on error during checking]' \
  '-Q[task offset for read tests]:offset:' \
  '-r[read existing file]' \
  '-R[verify data after reading]' \
  '-s[file segment count]:count:' \
  '-S[strided access in datatype]' \
  '-t[transfer size in bytes]:size:' \
  '-T[maximum test duration in minutes]:minutes:' \
  '-u[unique directory per file-per-process]' \
  '-U[hints file path]:file:_files' \
  '*-v[output information (repeat to increase level)]' \
  '-V[use MPI_File_set_view]' \
  '-w[write file mode]' \
  '-W[verify data after writing]' \
  '-x[no retry on incomplete transfer]' \
  '-X[random seed for task reordering]:seed:' \
  '-Y[fsync after each POSIX write]' \
  '-z[random file access offsets]' \
  '-Z[random task reordering]' && ret=0

return ret
