#compdef @SSwarper
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@SSwarper.html
# Skull-strip and nonlinearly warp an anatomical to a template

local ret=1

_arguments -s \
  '-input[anatomical dataset, non-skull-stripped]:dataset:_files' \
  '-base[base template dataset]:dataset:_files' \
  '-subid[name code for output datasets]:id' \
  '-odir[output directory]:dir:_files -/' \
  '-minp[minimum patch size for final 3dQwarp]:size' \
  '-nolite[do not use -lite with 3dQwarp]' \
  '-skipwarp[stop after skull-stripping]' \
  '-unifize_off[skip 3dUnifize preprocessing]' \
  '-init_skullstr_off[skip initial 3dSkullstrip]' \
  '-extra_qc_off[do not generate extra QC images]' \
  '-jump_to_extra_qc[generate only QC images]' \
  '-cost_nl_init[cost for initial nonlinear align]:cost' \
  '-cost_nl_final[cost for final nonlinear align]:cost' \
  '-deoblique[obliquity correction via 3dWarp]' \
  '-deoblique_refitly[obliquity correction via 3drefit]' \
  '-warpscale[warp flexibility 0.1-1.0]:scale' \
  '-giant_move[expand parameters for large angles]' \
  '-aniso_off[skip 3danisosmooth preprocessing]' \
  '-ceil_off[skip ceiling-capping]' \
  '-SSopt[extra options for 3dSkullStrip]:opts' \
  '-mask_ss[mask instead of skullstripping]:dataset:_files' \
  '-tmp_name_nice[use nicer intermediate prefix]' \
  '-verb[verbose progress output]' \
  '-echo[run with set echo for debugging]' \
  '-noclean[retain intermediate files]' && ret=0

return ret
