#compdef fpcat
# Documentation: https://chemfp.readthedocs.io/en/latest/tools.html
# chemfp tool to convert between fingerprint file formats and manage ordering

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o+[output filename]:file:_files' \
  '--out=[output format]:format:(fps fps.gz fps.zst fpb)' \
  '(--preserve-order --reorder)--preserve-order[maintain input fingerprint ordering]' \
  '(--preserve-order --reorder)--reorder[reorder by population count for FPS output]' \
  '--max-spool-size=[limit memory usage during FPB generation]:size:' \
  '--tmpdir=[temporary directory for intermediate files]:dir:_files -/' \
  '*:fingerprint file:_files' && ret=0

return ret
