#compdef autopkgtest-virt-docker autopkgtest-virt-podman
# _autopkgtest-virt-docker — Docker/Podman virtualisation backend for autopkgtest
# upstream: https://salsa.debian.org/ci-team/autopkgtest
# Flags from autopkgtest-virt-docker(1) man page.

_autopkgtest-virt-docker() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(--docker --podman)--docker[use Docker container manager]' \
        '(--docker --podman)--podman[use Podman container manager]' \
        '(-d --debug)'{-d,--debug}'[enable debugging output]' \
        '(--init --no-init)--init[launch container by running /sbin/init]' \
        '(--init --no-init)--no-init[launch container with sleep infinity (default Docker)]' \
        '(-p --pull)'{-p,--pull}'[pull image before setup]' \
        '(-s --sudo)'{-s,--sudo}'[run docker/podman commands through sudo]' \
        '1:image:'
}

_autopkgtest-virt-docker "$@"
