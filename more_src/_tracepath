#compdef tracepath tracepath6
# Documentation: https://manpages.debian.org/testing/iputils-tracepath/tracepath.8.en.html
# Reference accessed: 2026-05-30
# tracepath / tracepath6 — trace path to a network host discovering MTU along the way.
# Unlike traceroute, no administrative privileges required. Multi-stem covers both binaries.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-V[show version]' \
  '(-4 -6)-4[IPv4 only]' \
  '(-4 -6)-6[IPv6 only]' \
  '(-n -b)-n[print primarily IP addresses numerically]' \
  '(-n -b)-b[print both: host names and IP addresses]' \
  '-l+[initial packet size (default 65535 IPv4 / 128000 IPv6)]:bytes:' \
  '-m+[max hops / TTL (default 30)]:hops:' \
  '-p+[starting destination port for probes]:port:' \
  '1:destination host:_hosts' \
  '2:port (optional override):' \
  && ret=0

return ret
