#compdef plenti
# Documentation: https://man.archlinux.org/search?q=plenti
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new:scaffold project'
  'build:produce static build'
  'serve:local dev server'
  'version:show version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(* -)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'plenti command' commands && ret=0
    ;;
  (args)
    _arguments '*:paths or flags: _default' && ret=0
    ;;
esac

return ret
