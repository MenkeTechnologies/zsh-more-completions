#compdef gpgparsemail
# Documentation: gpgparsemail --help (GnuPG)
# Source: GnuPG gpgparsemail — parse a mail message into an annotated format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--crypto[decrypt or verify messages]' \
    '--no-header[do not output the header lines]' \
    '--verbose[enable extra informational output]' \
    '--debug[enable additional debug output]' \
    '(- *)--help[display help and exit]' \
    '*:mail file:_files' \
    && ret=0

return ret
