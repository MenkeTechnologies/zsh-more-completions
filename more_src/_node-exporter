#compdef node-exporter node_exporter
# _node-exporter — Prometheus node_exporter (machine-level metrics: CPU, memory, filesystem, network, etc.)
# upstream: https://github.com/prometheus/node_exporter
# Flags from node_exporter.go on tip + kingpinflag/web (--web.listen-address, --web.systemd-socket, --web.config.file) + promslog (--log.level, --log.format).

_node-exporter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--web.telemetry-path=[path under which to expose metrics]:path:' \
        '--web.disable-exporter-metrics[exclude promhttp_*, process_*, go_* metrics]' \
        '--web.max-requests=[max parallel scrape requests (0=unlimited)]:n:' \
        '--collector.disable-defaults[disable all collectors by default]' \
        '--runtime.gomaxprocs=[GOMAXPROCS target]:n:' \
        '*--web.listen-address=[listen address (repeatable for systemd socket activation)]:addr:' \
        '--web.systemd-socket[use systemd socket activation listener instead of port]' \
        '--web.config.file=[path to TLS/auth config file]:file:_files' \
        '--log.level=[log level]:level:(debug info warn error)' \
        '--log.format=[log format]:fmt:(logfmt json)' \
        '*--collector.*[enable/disable specific collector (e.g. --collector.systemd or --no-collector.cpu)]'
}

_node-exporter "$@"
