#compdef shotcut

# Zsh completion for shotcut - Shotcut video editor

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--fullscreen[start in fullscreen mode]' \
  '--noupgrade[do not check for upgrades]' \
  '--gpu[use GPU processing]' \
  '--clear-recent[clear recent projects list]' \
  '--appdata=[set app data directory]:dir:_directories' \
  '--QT_SCALE_FACTOR=[set Qt scale factor]:factor' \
  '*:file:_files -g "*.{mlt,xml,mp4,mkv,avi,mov,webm,flv,mpg,mpeg,wmv,ogv,wav,mp3,ogg,flac,png,jpg,jpeg,gif,svg}"' && ret=0

return ret
