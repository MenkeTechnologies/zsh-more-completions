#compdef afl-persistent-config
# _afl-persistent-config — permanently reconfigure system for AFL++ fuzzing (AFLplusplus/AFLplusplus)
# upstream: https://github.com/AFLplusplus/AFLplusplus
# Flags from afl-persistent-config (bash).

_afl-persistent-config() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-hh[show extended help]' \
        '(- *)--help[show help]'
}

_afl-persistent-config "$@"
