#compdef nfreader
# _nfreader — Peter Haag nfdump nfreader CLI for reading and parsing NetFlow v5/v7/v9/IPFIX records from nfdump file archives outputting records in text or CSV with optional NSEL/NEL extension fields (phaag team, C); getopt
# upstream: https://github.com/phaag/nfdump

_nfreader() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r+[input file]:file:_files -g "*.nfcapd nfcapd.*"' \
        '--read=+[input file]:file:_files -g "*.nfcapd nfcapd.*"' \
        '-R+[input dir]:dir:_files -/' \
        '--read-dir=+[input dir]:dir:_files -/' \
        '-M+[file dir list]:str:' \
        '-o+[output format]:f:(line raw long extended fmt csv json pipe)' \
        '--output=+[output format]:f:(line raw long extended fmt csv json pipe)' \
        '-F+[fmt string]:str:' \
        '--format=+[fmt string]:str:' \
        '-n+[N records]:n:' \
        '--limit=+[N records]:n:' \
        '-c+[N records]:n:' \
        '-t+[time interval]:str:' \
        '--timewindow=+[time interval]:str:' \
        '-s+[stat field]:str:' \
        '--stat=+[stat field]:str:' \
        '-T+[print field]:str:' \
        '--print-fields=+[csv]:str:' \
        '-A+[agg field]:str:' \
        '--aggregate=+[agg field]:str:' \
        '-e+[exporter list]:str:' \
        '-a[aggregate]' \
        '--anonymise[anonymise]' \
        '*:filter expression:'
}

_nfreader "$@"
