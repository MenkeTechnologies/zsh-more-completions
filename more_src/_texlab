#compdef texlab
# Documentation: https://man.archlinux.org/search?q=texlab
# Reference accessed: 2026-05-16

# Zsh completion for texlab - LaTeX language server

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbosity)'{-v,--verbosity}'[set log verbosity]:level:(0 1 2 3 4)' \
  '--log-file=[log to file]:file:_files' \
  '--citation-style=[citation style]:style:' \
  '-q[suppress log output]' \
  '--quiet[suppress log output]'
