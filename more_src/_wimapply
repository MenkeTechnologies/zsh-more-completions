#compdef wimapply
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-apply.1.html
# wimapply — extract one image, or all images, from a WIM archive

local ret=1

_arguments -s -S \
  '--check[verify WIM integrity before applying]' \
  '--ref=[reference additional WIMs or split parts]:glob' \
  '--rpfix[fix targets of absolute symlinks relative to image root]' \
  '--norpfix[disable reparse point fixup]' \
  '--unix-data[restore UNIX-specific metadata and special files]' \
  '--no-acls[skip restoring security descriptors]' \
  '--strict-acls[fail if security descriptors cannot be set exactly]' \
  '--no-attributes[skip restoring Windows file attributes]' \
  '--include-invalid-names[extract files with invalid names by sanitizing them]' \
  '--wimboot[extract pointer files to WIM instead of actual files]' \
  '--compact=[compress extracted files using System Compression]:format:(xpress4k xpress8k xpress16k lzx)' \
  '--recover-data[extract corrupted files with warnings instead of aborting]' \
  '*:WIM file:_files' && ret=0

return ret
