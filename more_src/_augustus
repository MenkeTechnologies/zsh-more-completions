#compdef augustus AUGUSTUS gff2gbSmallDNA.pl filterGenes.pl etraining
# _augustus — Mario Stanke AUGUSTUS gene prediction in eukaryotic genomic sequences with comparative gene prediction (Gaius-Augustus team, C++); custom argparse
# upstream: https://github.com/Gaius-Augustus/Augustus

_augustus() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--species=+[species]:s:(human fly arabidopsis brugia aedes tribolium schistosoma tetrahymena galdieria maize toxoplasma caenorhabditis aspergillus_fumigatus aspergillus_nidulans aspergillus_oryzae aspergillus_terreus chaetomium_globosum coccidioides_immitis cryptococcus encephalitozoon_cuniculi histoplasma_capsulatum lodderomyces_elongisporus magnaporthe_grisea pichia_stipitis rhizopus_oryzae saccharomyces saccharomyces_cerevisiae_S288C saccharomyces_cerevisiae_rm11-1a schizosaccharomyces_pombe ustilago_maydis yarrowia_lipolytica)' \
        '--strand=+[strand]:s:(both forward backward)' \
        '--genemodel=+[mode]:m:(partial complete atleastone exactlyone bacterium intronless)' \
        '--singlestrand=+[bool]:b:(true false)' \
        '--hintsfile=+[hints file]:file:_files -g "*.gff *.gff3 *.gtf"' \
        '--AUGUSTUS_CONFIG_PATH=+[config path]:dir:_files -/' \
        '--alternatives-from-evidence=+[bool]:b:(true false)' \
        '--alternatives-from-sampling=+[bool]:b:(true false)' \
        '--sample=+[N]:n:' \
        '--minexonintronprob=+[F]:f:' \
        '--minmeanexonintronprob=+[F]:f:' \
        '--maxtracks=+[N]:n:' \
        '--temperature=+[N]:n:' \
        '--proteinprofile=+[file]:file:_files' \
        '--progress=+[bool]:b:(true false)' \
        '--predictionStart=+[N]:n:' \
        '--predictionEnd=+[N]:n:' \
        '--gff3=+[bool]:b:(on off)' \
        '--UTR=+[bool]:b:(on off)' \
        '--noInFrameStop=+[bool]:b:(true false)' \
        '--noprediction=+[bool]:b:(true false)' \
        '--uniqueGeneId=+[bool]:b:(true false)' \
        '--outfile=+[output file]:file:_files' \
        '--errfile=+[error file]:file:_files' \
        '--exonnames=+[bool]:b:(on off)' \
        '--codingseq=+[bool]:b:(on off)' \
        '--printHints=+[bool]:b:(true false)' \
        '--start=+[bool]:b:(on off)' \
        '--stop=+[bool]:b:(on off)' \
        '--introns=+[bool]:b:(on off)' \
        '--cds=+[bool]:b:(on off)' \
        '--mea=+[bool]:b:(0 1)' \
        '--meaPredictionPath=+[path]:str:' \
        '--printOEs=+[bool]:b:(0 1)' \
        '--paramlist[print parameter list]' \
        '--extrinsicCfgFile=+[file]:file:_files' \
        '*:fasta:_files -g "*.fa *.fasta *.fna *.fa.gz"'
}

_augustus "$@"
