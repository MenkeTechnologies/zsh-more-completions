#compdef megacmd

# Zsh completion for megacmd — MEGA.nz CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values -s 'megacmd' \
      ls cd pwd lcd get put cp mkdir rm mv sync backup webdav ftp \
      whoami login logout import export version help && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
