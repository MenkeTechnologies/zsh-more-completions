#compdef octez-client tezos-client
# _octez-client — Nomadic Labs Tezos octez-client CLI for the Tezos liquid-proof-of-stake blockchain (tezos team, OCaml); cmdliner
# upstream: https://gitlab.com/tezos/tezos

_octez-client() {
    local -a sub=(
        'list:list known operations'
        'man:show command manual'
        'gen:generate keys'
        'import:import keys'
        'show:show information'
        'transfer:transfer XTZ'
        'reveal:reveal a public key'
        'originate:originate a contract'
        'delegate:set delegate'
        'submit:submit a proposal'
        'register:register keys'
        'set:set parameters'
        'forget:forget a key'
        'remember:remember a key'
        'rpc:invoke an RPC'
        'sign:sign a message'
        'check:verify signature'
        'config:configuration subcommands'
        'bootstrapped:wait for bootstrap'
        'get:get value'
        'list-contracts:list contracts'
        'unrevealed:list unrevealed manager keys'
        'simulate:simulate operation'
        'run:run script or view'
        'create:create multisig contract'
        'prepare:prepare multisig action'
        'invoke:invoke entrypoint'
        'multisig:multisig subcommands'
        'sapling:sapling subcommands'
        'attest:attest block'
        'tx:tx rollup subcommands'
        'sc:smart rollup subcommands'
        'wait:wait until level'
        'stake:stake to baker'
        'unstake:unstake from baker'
        'finalize:finalize unstake'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-base-dir+[base dir]:dir:_files -/' \
        '--base-dir=+[base dir]:dir:_files -/' \
        '-d+[base dir]:dir:_files -/' \
        '-config-file+[config file]:file:_files -g "*.json"' \
        '--config-file=+[config file]:file:_files -g "*.json"' \
        '-c+[config file]:file:_files -g "*.json"' \
        '-protocol+[protocol hash]:str:' \
        '--protocol=+[protocol hash]:str:' \
        '-p+[protocol hash]:str:' \
        '-block+[block hash]:str:' \
        '--block=+[block hash]:str:' \
        '-b+[block hash]:str:' \
        '-endpoint+[node URL]:url:_urls' \
        '--endpoint=+[node URL]:url:_urls' \
        '-E+[node URL]:url:_urls' \
        '-media-type+[media type]:m:(any binary json text)' \
        '--media-type=+[media type]:m:(any binary json text)' \
        '-wait+[blocks]:n:' \
        '--wait=+[blocks]:n:' \
        '-w+[blocks]:n:' \
        '-mode+[mode]:m:(mockup proxy client light)' \
        '--mode=+[mode]:m:(mockup proxy client light)' \
        '-M+[mode]:m:(mockup proxy client light)' \
        '-better-errors[better errors]' \
        '-log-requests[log requests]' \
        '-l[log requests]' \
        '-password-filename+[file]:file:_files' \
        '-no-auth[no auth]' \
        '-protect-encrypted[protect encrypted]' \
        '-remote-signer+[uri]:str:' \
        '-R+[uri]:str:' \
        '-sources+[file]:file:_files' \
        '-S+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'octez-client subcommand' sub ;;
    esac
}

_octez-client "$@"
