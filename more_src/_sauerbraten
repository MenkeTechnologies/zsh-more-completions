#compdef sauerbraten
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man6/sauerbraten.6.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Sauerbraten: Cube 2 first-person shooter
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[run as dedicated server]' \
  '-w[window width in pixels]:width:' \
  '-h[window height in pixels]:height:' \
  '-z[z-buffer precision in bits]:depth:' \
  '-b[bits per pixel]:bpp:' \
  '-a[Full Scene Antialiasing samples]:samples:' \
  '-t[run in windowed mode]' \
  '-k[add directory to data search paths]:dir:_files -/' \
  '-f[shader precision (0-3; 0 disables)]:n:(0 1 2 3)' \
  '*::extra args:_files' && ret=0
return ret
