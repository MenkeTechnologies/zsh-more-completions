#compdef raxmlHPC-AVX2
# RAxML standard ML phylogenetic inference (raxmlHPC-AVX2 build)
# Same options as raxmlHPC; delegate to its completion.

local ret=1
if (( $+functions[_raxml] )); then
  _raxml "$@" && ret=0
else
  _arguments -s -S \
    '-h[show help]' \
    '-s[alignment file]:file:_files' \
    '-n[output run name]:name:' \
    '-m[substitution model]:model:' \
    '*:file:_files' && ret=0
fi
return ret
