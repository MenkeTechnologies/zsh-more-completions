#compdef pdb_delres
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Deletes a range of residues, e.g. -1:10 or -1:10:5

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[residue range to delete, e.g. -1:10:step]:range' \
  '*:PDB file:_files' && ret=0

return ret
