# Probed via: completion zsh
# Repository: https://github.com/happytoolin/hni

autoload -U is-at-least

_hni() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'*-C+[run as if in <dir>]:DIR:_files' \
'-?[print resolved command and exit (aliases\: --dry-run, --print-command)]' \
'--debug-resolved[print resolved command and exit (aliases\: --dry-run, --print-command)]' \
'--explain[print detection + resolution details and exit]' \
'-v[show versions]' \
'--version[show versions]' \
'-h[show help]' \
'--help[show help]' \
":: :_hni_commands" \
"*::: :->hni" \
&& ret=0
    case $state in
    (hni)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:hni-command-$line[1]:"
        case $line[1] in
            (ni)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nr)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nlx)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nu)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nun)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nci)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(na)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(np)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(ns)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(node)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_hni__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:hni-help-command-$line[1]:"
        case $line[1] in
            (ni)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nr)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nlx)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nu)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nun)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nci)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(na)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(np)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(ns)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(node)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_hni_commands] )) ||
_hni_commands() {
    local commands; commands=(
'ni:install or add dependencies' \
'nr:run package scripts' \
'nlx:execute package binaries' \
'nu:upgrade dependencies' \
'nun:remove dependencies' \
'nci:clean install' \
'na:package manager alias' \
'np:run shell commands in parallel' \
'ns:run shell commands sequentially' \
'node:package-manager-aware node shim' \
'init:print shell init code' \
'doctor:print environment and detection diagnostics' \
'completion:print shell completion script' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'hni commands' commands "$@"
}
