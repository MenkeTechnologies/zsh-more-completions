#compdef wimsplit
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-split.1.html
# wimsplit — split a WIM into multiple parts

local ret=1

_arguments -s -S \
  '--check[verify integrity and include integrity info in each part]' \
  '--include-integrity[add integrity info to parts without prior verification]' \
  '*:WIM file:_files' && ret=0

return ret
