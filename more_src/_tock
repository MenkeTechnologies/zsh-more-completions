#compdef tock

# https://github.com/kriuchkov/tock — cobra (internal/app/commands/root.go)
local -a _tock_cmds
_tock_cmds=(
  'start:start tracking'
  'stop:stop activity'
  'add:add past activity'
  'note:add note to activity'
  'tag:set tag'
  'list:list activities'
  'report:report time'
  'export:export data'
  'last:show last activity'
  'continue:resume tracking'
  'current:show active timer'
  'remove:remove activities'
  'watch:live view'
  'calendar:calendar view'
  'analyze:analytics'
  'ical:iCal output'
  'completion:generate shell completions'
  'version:print version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[version]' \
  '(-f --file)'{-f,--file}'=-[tock data file]:file:_files' \
  '(-b --backend)'{-b,--backend}'=-[storage backend]:backend:' \
  '--config=-[config file]:file:_files' \
  '--lang=-[locale]:lang:' \
  '1: :->cmd' \
  '*:: :->args'

case $state in
  cmd) _describe -t commands 'tock command' _tock_cmds ;;
  args) _default ;;
esac
