#compdef trippy

# Zsh completion for trippy - Network diagnostics tool (trip command)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-m,--mode}'[tracing mode]:mode:(icmp udp tcp dublin)' \
  {-u,--unprivileged}'[unprivileged mode]' \
  {-p,--protocol}'[protocol]:protocol:(icmp udp tcp)' \
  '--udp[use UDP for traceroute]' \
  '--tcp[use TCP for traceroute]' \
  {-4,--ipv4}'[use IPv4 only]' \
  {-6,--ipv6}'[use IPv6 only]' \
  {-F,--first-ttl}'[time to live for first hop]:ttl:' \
  {-t,--max-ttl}'[maximum time to live]:ttl:' \
  '--min-round-duration[minimum round duration]:duration:' \
  '--max-round-duration[maximum round duration]:duration:' \
  {-g,--grace-duration}'[grace period after last probe]:duration:' \
  '--initial-sequence[initial sequence number]:number:' \
  {-R,--multipath-strategy}'[multipath routing strategy]:strategy:(classic paris dublin)' \
  {-U,--max-inflight}'[maximum number of in-flight probes]:count:' \
  {-I,--interface}'[source interface]:interface:_net_interfaces' \
  {-A,--source-address}'[source address]:address:' \
  {-P,--target-port}'[target port]:port:' \
  {-S,--source-port}'[source port]:port:' \
  '--payload-pattern[payload pattern]:pattern:' \
  '--tos[type of service]:tos:' \
  '--read-timeout[socket read timeout]:timeout:' \
  {-i,--send-wait}'[minimum wait between probes]:wait:' \
  {-Q,--max-samples}'[maximum number of samples per hop]:samples:' \
  {-r,--dns-resolve-method}'[DNS resolve method]:method:(system resolv google cloudflare)' \
  '--dns-resolve-all[resolve all DNS entries]' \
  '--dns-timeout[DNS lookup timeout]:timeout:' \
  '--dns-lookup-as-info[lookup autonomous system info]' \
  '--tui-refresh-rate[TUI refresh rate]:rate:' \
  '--tui-privacy-max-ttl[mask target IP in TUI]:ttl:' \
  '--tui-address-mode[TUI address mode]:mode:(ip host both)' \
  '--tui-as-mode[TUI AS mode]:mode:(asn prefix country-code registry-name allocated)' \
  '--tui-max-addrs[max addresses per hop]:count:' \
  '--tui-theme-colors[TUI theme colors]:colors:' \
  {-C,--report-cycles}'[number of report cycles]:cycles:' \
  {-G,--geoip-mmdb-file}'[GeoIP MMDB file]:file:_files -g "*.mmdb"' \
  '--generate[generate shell completions]:shell:(bash fish zsh powershell elvish)' \
  '--print-tui-theme-items[print TUI theme items]' \
  '--log-format[log format]:format:(compact pretty json chrome)' \
  '--log-filter[log filter]:filter:' \
  '--log-span-events[log span events]:events:(new close none active full)' \
  {-v,--verbose}'[verbose output]' \
  '-c[config file]:file:_files' \
  '*:target:_hosts' \
  && return 0
