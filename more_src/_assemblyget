#compdef assemblyget
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/assemblyget.html
# EMBOSS: get assembly of sequence reads

local ret=1

_arguments -s -S \
  '-assembly=[input assembly of sequence reads]:assembly:_files' \
  '-outassembly=[output assembly of sequence reads]:outassembly:_files' \
  '-auto[turn off prompts]' \
  '-stdout[write first file to standard output]' \
  '-filter[read from stdin, write to stdout]' \
  '-options[prompt for standard and additional values]' \
  '-debug[write debug output]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-die[report dying program messages]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '-version[report version number and exit]' && ret=0

return ret
