#compdef makefile2graph

# Zsh completion for makefile2graph Makefile dependency front-end

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--label-columns[annotate nodes with makefile column]' \
  '-B[disable built-in and -include rules]' \
  '-d+[make debug level]:level' \
  '*:make target:{ _message "Makefile target name" }' && ret=0

return ret
