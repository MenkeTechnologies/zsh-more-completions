#compdef mdinspect
# Documentation: https://mdtraj.org/1.9.4/mdinspect.html
# Inspect MD trajectory files for problems (MDTraj)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --topology)'{-t,--topology}'[topology for the system (.prmtop/.pdb)]:topology:_files' \
  '--bond-low[min fraction of sum of covalent radii for bonded atoms (default 0.4)]:fraction' \
  '--bond-high[max fraction of sum of covalent radii for bonded atoms (default 1.2)]:fraction' \
  '--rmsd-tolerance[max tolerance for percent change in RMSD (default 100.0)]:tolerance' \
  '*:input trajectory:_files' && ret=0

return ret
