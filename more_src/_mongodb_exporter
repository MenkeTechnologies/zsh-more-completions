#compdef mongodb_exporter
# Documentation: https://github.com/percona/mongodb_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--mongodb.uri=[MongoDB connection URI]:uri:' \
  '--mongodb.global-conn-pool[use global connection pool instead of per-request]' \
  '--mongodb.direct-connect[use direct connection to MongoDB]' \
  '--mongodb.collstats-colls=[list of collections to get collstats]:collections:' \
  '--compatible-mode[enable old mongodb-exporter compatible metrics]' \
  '--collector.diagnosticdata[enable collecting metrics from getDiagnosticData]' \
  '--collector.replicasetstatus[enable collecting metrics from replSetGetStatus]' \
  '--collector.dbstats[enable collecting metrics from dbStats]' \
  '--collector.dbstatsfreestorage[enable collecting free storage metrics from dbStats]' \
  '--collector.topmetrics[enable collecting metrics from top admin command]' \
  '--collector.indexstats[enable collecting metrics from indexStats]' \
  '--collector.collstats[enable collecting metrics from collStats]' \
  '--discovering-mode[enable autodiscover collections]' \
  '--collect-all[enable all collectors]' \
  '--web.listen-address=[address to listen on for web interface and telemetry]:address:' \
  '--web.telemetry-path=[path under which to expose metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' && ret=0

return ret
