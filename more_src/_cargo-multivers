#compdef cargo-multivers
# Documentation: https://crates.io/crates/cargo-multivers
# build multiple CPU-feature versions of a binary merged into one portable binary

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--target[build for the target triple]:triple' \
  '--print[information to print on stdout]:information' \
  '--cpus[comma-separated list of CPUs to use as a target]:cpus' \
  '--exclude-cpu-features[comma-separated CPU features to exclude]:features' \
  '--runner-version[version of the runner to use]:version' \
  '--profile[build artifacts with the specified profile]:profile' \
  '--color[color preferences for program output]:when:(auto always never)' \
  '--out-dir[copy final artifacts to this directory]:dir:_files -/' \
  '--runner-features[features to activate for the runner]:features' \
  '--runner-manifest-path[path to a custom runner Cargo.toml]:file:_files -g "*.toml"' \
  '*::cargo build args:_default' && ret=0

return ret
