#compdef gitbutler

# Zsh completion for GitButler CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'open:open GitButler for a project'
  'project:manage projects'
  'snapshot:manage workspace snapshots'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'gitbutler command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      project)
        local -a project_cmds=(
          'add:add a project'
          'list:list all projects'
          'switch-to-workspace:switch to GitButler workspace'
        )
        _describe -t commands 'project command' project_cmds && ret=0
        ;;
      snapshot)
        local -a snapshot_cmds=(
          'list:list snapshots'
          'restore:restore a snapshot'
        )
        _describe -t commands 'snapshot command' snapshot_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
