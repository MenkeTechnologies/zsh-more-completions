#compdef sigh
# _sigh — fastlane sigh iOS provisioning profile manager (fastlane, Ruby); commander
# upstream: https://github.com/fastlane/fastlane

_sigh() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--adhoc[ad-hoc profile]' \
        '-a[ad-hoc profile]' \
        '--developer-id[developer ID profile]' \
        '--development[development profile]' \
        '-d[development profile]' \
        '--skip-install[skip install]' \
        '-i[skip install]' \
        '--force=+[force]:b:(true false)' \
        '-f+[force]:b:(true false)' \
        '--include-mac-in-profiles=+[include mac in profiles]:b:(true false)' \
        '-c+[include mac in profiles]:b:(true false)' \
        '--app-identifier=+[app identifier]:str:' \
        '-b+[app identifier]:str:' \
        '--username=+[apple ID username]:str:_users' \
        '-u+[apple ID username]:str:_users' \
        '--team-id=+[team id]:str:' \
        '-l+[team id]:str:' \
        '--team-name=+[team name]:str:' \
        '-q+[team name]:str:' \
        '--provisioning-name=+[provisioning name]:str:' \
        '-n+[provisioning name]:str:' \
        '--ignore-profiles-with-different-name=+[ignore profiles with different name]:b:(true false)' \
        '--output-path=+[output path]:dir:_files -/' \
        '-o+[output path]:dir:_files -/' \
        '--cert-id=+[cert id]:str:' \
        '-k+[cert id]:str:' \
        '--cert-owner-name=+[cert owner name]:str:' \
        '-w+[cert owner name]:str:' \
        '--filename=+[filename]:str:' \
        '-x+[filename]:str:' \
        '--skip-fetch-profiles=+[skip fetch profiles]:b:(true false)' \
        '--include-all-certificates=+[include all certificates]:b:(true false)' \
        '--skip-certificate-verification=+[skip cert verification]:b:(true false)' \
        '-z+[skip cert verification]:b:(true false)' \
        '--platform=+[platform]:p:(ios macos tvos catalyst)' \
        '--readonly=+[readonly]:b:(true false)' \
        '--template-name=+[template name]:str:' \
        '--fail-on-name-taken=+[fail on name taken]:b:(true false)' \
        '*:arg:'
}

_sigh "$@"
