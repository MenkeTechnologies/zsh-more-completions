#compdef pl-device-test
# Documentation: https://docs.pennylane.ai/en/stable/code/api/pennylane.devices.tests.cli.html
# PennyLane device test suite runner

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--device=[device to test]:device' \
  '--shots=[number of shots in stochastic mode]:shots' \
  '--skip-ops[skip tests using unsupported device operations]' \
  '--flaky-report[show the flaky report in the terminal]' \
  '*--device-kwargs=[additional device kwargs KEY=VAL]:kwarg' \
  '*::pytest args:_default' && ret=0

return ret
