#compdef rpcs3
# Documentation: https://man.archlinux.org/search?q=rpcs3
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--fullscreen[fullscreen mode]' \
  '--no-gui[no GUI]' \
  '--installfw+[install firmware PUP]:file:_files -g "*.PUP *.pup"' \
  '--installpkg[install PKG files]' \
  '--decrypt+[decrypt files]:file:_files' \
  '--no-fast-boot[disable fast boot]' \
  '--rsx-capture[start with RSX capture]' \
  '--user-id+[user ID]:id:' \
  '--config+[config file]:file:_files -g "*.yml"' \
  '--high-dpi+[high DPI]:b:(0 1)' \
  '--rounding+[rounding mode]:m:' \
  '--style+[style sheet]:file:_files' \
  '--styles[show available styles]' \
  '--gdb+[gdb server port]:port:' \
  '--vulkan+[vulkan device]:dev:' \
  '--input+[input device]:dev:' \
  '--audio+[audio backend]:b:(Null XAudio2 OpenAL FAudio Cubeb)' \
  '--codec+[video codec]:c:' \
  '--no-display[headless]' \
  '*: :_files -g "*.bin *.elf *.self *.sprx *.pkg *.rap *.iso"' && ret=0

return ret
