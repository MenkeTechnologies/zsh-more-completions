#compdef rpcs3
# Documentation: https://github.com/RPCS3/rpcs3/blob/master/rpcs3/rpcs3.cpp
# Reference accessed: 2026-05-21
# Verified: upstream rpcs3/rpcs3.cpp QCommandLineOption declarations.
# Removed from prior file: --rounding (real name is --dpi-rounding),
# --vulkan, --input, --audio, --codec (note: --codecs lists codecs),
# --no-display (real is --headless), --gdb, --no-fast-boot (none of
# these exist in upstream source).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--headless[run in headless mode]' \
  '--no-gui[run without GUI]' \
  '--fullscreen[fullscreen mode (with --no-gui)]' \
  '--game-screen=[forces the emulator to use specified screen]:index' \
  '--hidpi=[Qt high-DPI scaling]:enabled:(0 1)' \
  '--dpi-rounding=[Qt high-DPI rounding policy]:policy' \
  '--styles[list available styles]' \
  '--style=[load custom style]:style' \
  '--stylesheet=[load custom stylesheet]:path:_files' \
  '--config=[force CLI boot config file]:path:_files -g "*.yml"' \
  '--input-config=[force input config file (with --no-gui)]:name' \
  '--installfw=[install firmware PUP file]:file:_files -g "*.PUP *.pup"' \
  '--installpkg=[install pkg file(s)]:file:_files -g "*.pkg"' \
  '--decrypt=[decrypt PS3 binaries]:path:_files' \
  '--user-id=[start RPCS3 as this user]:id' \
  '--savestate=[load a savestate]:path:_files' \
  '--rsx-capture=[load an rsx capture]:path:_files' \
  '--qDebug[log qDebug to RPCS3.log]' \
  '--high-res-timer=[high-resolution timer (Windows)]:enabled:(0 1)' \
  '--verbose-curl[enable verbose curl logging]' \
  '--allow-any-location[allow rpcs3 to run from any location (dangerous)]' \
  '--codecs[list ffmpeg codecs]' \
  '--stdout[attach console and listen to stdout]' \
  '--stderr[attach console and listen to stderr]' \
  '*: :_files -g "*.bin *.elf *.self *.sprx *.pkg *.rap *.iso"' && ret=0

return ret
