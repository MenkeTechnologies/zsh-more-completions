#compdef create-drizzle-project
# Documentation: https://www.npmjs.com/package/create-drizzle-project
# Reference accessed: 2026-05-24
# Verified: npm view create-drizzle-project bin; npm readme Options section.

# Zsh completion for create-drizzle-project - Drizzle ORM project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-d --driver)'{-d,--driver=}'[database driver]:driver:(mysql postgres sqlite)' \
  '(-p --dbProvider)'{-p,--dbProvider=}'[database provider]:provider:' \
  '(-c --configType)'{-c,--configType=}'[drizzle config file type]:type:(typescript javascript)' \
  '(-m --migrateFile)'{-m,--migrateFile=}'[migration file path]:path:_files' \
  '(-o --outDir)'{-o,--outDir=}'[output directory]:directory:_directories' \
  '(-b --databaseDir)'{-b,--databaseDir=}'[database and schema directory]:directory:_directories' \
  '(-i --install)'{-i,--install}'[install dependencies]' \
  '--no-install[skip dependency installation]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[output version]' && ret=0

return ret
