#compdef create-remix

# Completion for create-remix - Create a new Remix project

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--template=[template name or URL]:template' \
  '--install[install dependencies]' \
  '--no-install[skip dependency installation]' \
  '--init-script[run template init script]' \
  '--no-init-script[skip template init script]' \
  '--git-init[initialize a git repository]' \
  '--no-git-init[skip git initialization]' \
  '--package-manager=[package manager to use]:package manager:(npm yarn pnpm bun)' \
  '--overwrite[overwrite existing directory]' \
  {-d,--debug}'[enable debug output]' \
  {-y,--yes}'[accept all defaults]' \
  '--token=[auth token for private templates]:token' \
  '1:project directory:_directories' && ret=0

return ret
