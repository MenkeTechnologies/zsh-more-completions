#compdef arachni
# Documentation: https://man.archlinux.org/search?q=arachni
# Reference accessed: 2026-05-16

# Arachni: open source web application scanner CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--checks=[checks to run]:checks:' \
  '--checks-exclude=[checks to exclude]:checks:' \
  '--plugins=[plugins to load]:plugins:' \
  '--scope-include-pattern=[include URL pattern]:pattern:' \
  '--scope-exclude-pattern=[exclude URL pattern]:pattern:' \
  '--scope-restrict-paths=[restrict to paths file]:file:_files' \
  '--scope-extend-paths=[extend with paths file]:file:_files' \
  '--scope-redundant-path-pattern=[redundant path pattern]:pattern:' \
  '--scope-auto-redundant=[max auto-redundant pages]:n:' \
  '--audit-cookies[audit cookies]' \
  '--audit-forms[audit forms]' \
  '--audit-headers[audit headers]' \
  '--audit-links[audit links]' \
  '--audit-jsons[audit JSONs]' \
  '--audit-xmls[audit XMLs]' \
  '--audit-cookies-extensively[audit cookies extensively]' \
  '--audit-with-both-methods[audit GET and POST]' \
  '--audit-with-raw-payloads[audit with raw payloads]' \
  '--http-user-agent=[user agent]:ua:' \
  '--http-cookie-jar=[cookie jar file]:file:_files' \
  '--http-request-concurrency=[concurrency]:n:' \
  '--report-save-path=[report save path]:file:_files' \
  '--report-create=[create report (afr file)]:file:_files' \
  '--reports=[reports]:reports:(html xml json yaml stdout)' \
  '*:target URL:' && ret=0
return ret
