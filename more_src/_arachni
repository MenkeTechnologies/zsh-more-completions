#compdef arachni

# Arachni: open-source web application security scanner CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-v[verbose]' \
  '--version[show version]' \
  '--http-request-concurrency=[concurrent HTTP requests]:n:' \
  '--http-request-timeout=[HTTP timeout (ms)]:ms:' \
  '--http-user-agent=[HTTP User-Agent]:ua:' \
  '--http-cookie-jar=[cookie jar file]:file:_files' \
  '--checks=[checks to run, comma list]:checks:' \
  '--checks-list[list available checks]' \
  '--reporters=[reporters, comma list]:reporters:' \
  '--reporters-list[list available reporters]' \
  '--plugin=[load plugin]:plugin:' \
  '--platforms=[target platforms (linux,windows,unix,php,java...)]:list:' \
  '--scope-include-pattern=[include URL pattern]:pattern:' \
  '--scope-exclude-pattern=[exclude URL pattern]:pattern:' \
  '--scope-page-limit=[max pages to audit]:n:' \
  '--scope-directory-depth-limit=[max directory depth]:n:' \
  '--scope-url-rewrites=[URL rewrites]:rewrites:' \
  '--audit-links[audit links]' \
  '--audit-forms[audit forms]' \
  '--audit-cookies[audit cookies]' \
  '--audit-headers[audit headers]' \
  '--audit-with-dom[execute JS during audit]' \
  '--audit-jsons[audit JSON inputs]' \
  '--audit-xmls[audit XML inputs]' \
  '--browser-cluster-pool-size=[browser pool size]:n:' \
  '--browser-cluster-job-timeout=[browser job timeout (ms)]:ms:' \
  '--report-save-path=[save report to path]:file:_files' \
  '--snapshot-save-path=[save snapshot]:file:_files' \
  '--session-cookie=[session cookie]:cookie:' \
  '--proxy=[proxy server]:proxy:' \
  '*:target URL:' && ret=0
return ret
