#compdef birdfont
# Documentation: https://man.archlinux.org/man/birdfont.1.en
# Birdfont font editor (TTF/OTF/SVG/BIRDFONT)

local ret=1

_arguments -s -S \
  '(-c --show-coordinates)'{-c,--show-coordinates}'[show coordinate in glyph view]' \
  '(-e --exit)'{-e,--exit}'[exit if a testcase fails]' \
  '(-f --fatal-warning)'{-f,--fatal-warning}'[treat warnings as fatal]' \
  '(-h --help)'{-h,--help}'[show command line options]' \
  '(-s --slow)'{-s,--slow}'[sleep between each command in test suite]' \
  '-t[run tests]:testcase:' \
  '*:file:_files' && ret=0

return ret
