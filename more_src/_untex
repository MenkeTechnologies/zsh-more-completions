#compdef untex
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/untex.1.html
# untex - strip LaTeX commands from input

local ret=1

_arguments -s \
  '-[read from standard input]' \
  '-o[remove options to LaTeX commands (everything in brackets [] behind a command)]' \
  '-i[process \include, \input{file} and \input file commands]' \
  '-m[(try to) remove all math code]' \
  '-u[replace all umlauts (\"a etc.) with ibm (CP850) characters]' \
  '-uiso[replace all umlauts (\"a etc.) with ISO characters]' \
  '-uascii[replace all umlauts (\"a etc.) with ascii characters]' \
  '-g[replace all "a etc. (german.sty) with ibm (CP850) characters]' \
  '-giso[replace all "a etc. (german.sty) with ISO characters]' \
  '-gascii[replace all "a etc. (german.sty) with ascii characters]' \
  '-e[remove environment names]' \
  '-a[remove arguments of commands (not recommended)]' \
  '*:TeX file:_files -g "*.(tex|ltx|latex)(-.)"' && ret=0

return ret
