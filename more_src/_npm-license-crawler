#compdef npm-license-crawler
# Documentation: https://github.com/mwittig/npm-license-crawler
# npm-license-crawler - analyze license information for multiple node.js modules

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--start=[path(s) to start crawling from]:path:_files -/' \
  '--exclude=[path(s) to exclude from crawling]:path:_files -/' \
  '--dependencies[show only third-party licenses from package.json]' \
  '--onlyDirectDependencies[show only direct dependency licenses]' \
  '--unknown[show only licenses that cannot be determined or have been guessed]' \
  '--json=[export data as JSON to the given file]:file:_files' \
  '--csv=[export data as comma-separated values to the given file]:file:_files' \
  '--relativeLicensePath[output the relative file path for license files]' \
  '--production[only list production dependencies]' \
  '--development[only list development dependencies]' \
  '--omitVersion[omit version numbers in output]' \
  '--noColor[disable colored console output]' \
  '*:path:_files -/' && ret=0

return ret
