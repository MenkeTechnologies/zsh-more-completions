#compdef powerline-go
# Documentation: https://man.archlinux.org/search?q=powerline-go
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-shell=[shell type]:shell:(autodetect bare bash zsh)' \
  '-mode=[powerline character mode]:mode:(patched compatible flat)' \
  '-theme=[color theme]:theme:(default low-contrast solarized-dark16 solarized-light16 gruvbox)' \
  '-modules=[modules csv]:list:' \
  '-modules-right=[right-side modules csv]:list:' \
  '-priority=[module priority csv]:list:' \
  '-newline[print prompt on next line]' \
  '-eval[output for shell eval]' \
  '-condensed[remove spacing between segments]' \
  '-ignore-warnings[hide powerline-go warnings]' \
  '-error=[exit code of last command]:n:' \
  '-numeric-exit-codes[show numeric exit codes]' \
  '-cwd-mode=[CWD display]:mode:(fancy plain dironly semifancy)' \
  '-cwd-max-depth=[max dirs to show]:n:' \
  '-cwd-max-dir-size=[chars per dir]:n:' \
  '-colorize-hostname[colorize host segment]' \
  '-fqdn-hostname[show full hostname]' \
  '-hostname-only-if-ssh[host segment only over SSH]' \
  '-alternate-ssh-icon[use alt SSH icon]' \
  '-east-asian-width[CJK double-width]' \
  '-static-prompt-indicator[fixed prompt arrow color]' \
  '-venv-name-size-limit=[venv name limit]:n:' \
  '-jobs=[number of background jobs]:n:' \
  '-git-assume-unchanged-size=[max repo size for git stats KB]:kb:' \
  '-git-disable-stats=[disable specific git stats csv]:list:' \
  '-git-mode=[git status detail]:mode:(fancy compact simple)' \
  '-max-width=[max prompt width pct]:pct:' \
  '-truncate-segment-width=[max segment width]:n:' \
  '-shorten-gke-names[shorten GKE cluster names]' \
  '-shorten-eks-names[shorten EKS cluster names]' \
  '-shorten-openshift-names[shorten OpenShift names]' \
  '-shell-var=[shell variable name]:name:' \
  '-shell-var-no-warn-empty[no warn if shell var empty]' \
  '-trim-ad-domain[trim AD domain from username]' \
  '-path-aliases=[path aliases csv]:list:' \
  '-duration=[command duration ns]:ns:' \
  '-duration-min=[min duration to show]:dur:' \
  '-duration-low-precision[low-precision duration]' \
  '-time=[time format]:fmt:' \
  '-vi-mode=[vi mode]:mode:(insert normal)' && ret=0

return ret
