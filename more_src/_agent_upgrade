#compdef agent_upgrade
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/tools/agent-upgrade.html
# Wazuh agent_upgrade - remotely upgrade agents via WPK

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --agents)'{-a,--agents}'[agent IDs to upgrade]:agent ids:' \
  '(-r --repository)'{-r,--repository}'[specify a repository URL]:url:' \
  '(-v --version)'{-v,--version}'[version to upgrade]:version:' \
  '(-F --force)'{-F,--force}'[force upgrade, ignoring version validations]' \
  '(-s --silent)'{-s,--silent}'[do not show output]' \
  '(-l --list_outdated)'{-l,--list_outdated}'[list all outdated agents]' \
  '(-f --file)'{-f,--file}'[custom WPK filename]:wpk file:_files' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-x --execute)'{-x,--execute}'[executable filename in the WPK custom file]:filename:' \
  '--http[use http protocol instead of https]' \
  '--package_type[use rpm or deb packages for linux]:type:(rpm deb)' && ret=0

return ret
