#compdef saltbr gmx-saltbr
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-saltbr.html
# gmx saltbr: compute salt bridges

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt = first time]:time:' \
  '-t[distance threshold; groups never closer excluded]:real:' \
  '-sep[use separate files for each interaction]' && ret=0

return ret
