#compdef pusher
# Documentation: https://man.archlinux.org/search?q=pusher
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:authenticate the Pusher CLI'
  'logout:log out of the Pusher CLI'
  'channels:Channels commands (apps, functions)'
  'beams:Beams (push notifications) commands'
  'help:show help'
  'version:show CLI version'
  'completion:generate shell completion'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug logging]' \
  '--token=[Pusher API token]:token:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pusher command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (channels)
        local -a chan_subs=(
          'apps:Channels app commands'
          'functions:Channels Functions commands'
          'integrations:integrations subcommands'
        )
        _describe -t chcmds 'channels subcommand' chan_subs && ret=0
        case $words[2] in
          (apps)
            _arguments \
              '*::sub:(list info subscribe trigger token webhooks)' \
              '--app-id=[app id]:id:' \
              '--channel=[channel name]:channel:' \
              '--event=[event name]:event:' \
              '--message=[event body]:message:' && ret=0 ;;
          (functions)
            _arguments \
              '*::sub:(deploy list delete logs invoke pause resume)' \
              '--app-id=[app id]:id:' \
              '--name=[function name]:name:' \
              '--code=[code file path]:file:_files' && ret=0 ;;
        esac ;;
      (beams)
        _arguments '*::sub:(instances notifications publish)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish)' && ret=0 ;;
    esac ;;
esac

return ret
