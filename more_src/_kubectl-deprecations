#compdef kubectl-deprecations
# kubectl-deprecations (kubepug, krew plugin): show deprecated API resources in a cluster
# https://github.com/rikatz/kubepug

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--k8s-version=[target Kubernetes version]:version' \
  '--swagger-dir=[directory with swagger.json for target version]:dir:_directories' \
  '--api-walk[walk through the API to find deprecated resources]' \
  '--error-on-deprecated[return error code when deprecated resources found]' \
  '--error-on-deleted[return error code when deleted resources found]' \
  '--format=[output format]:format:(plain json)' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--input-file=[read manifest from file]:file:_files -g "*.{yaml,yml,json}"'
