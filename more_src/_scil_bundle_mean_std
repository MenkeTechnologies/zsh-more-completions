#compdef scil_bundle_mean_std
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_bundle_mean_std.html
# Compute mean and std of metrics along a bundle

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--per_point=[compute metrics per point using a label map]:labels:_files -g "*.nii.gz"' \
  '--include_dps[include values from data_per_streamline]' \
  '--density_weighting[weight statistics by streamline count per voxel]' \
  '--distance_weighting=[weight by inverse distance from streamline to centroid]:nifti:_files' \
  '--correlation_weighting=[weight by longitudinal data correlation]:nifti:_files' \
  '--out_json=[output file path]:file:_files' \
  '--reference=[reference anatomy for tck/vtk/fib/dpy]:nifti:_files -g "*.nii *.nii.gz"' \
  '--indent=[JSON indentation for pretty printing]:indent' \
  '--sort_keys[sort keys in output JSON]' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '1:in_bundle:_files' \
  '*:in_metrics:_files -g "*.nii *.nii.gz"' && ret=0

return ret
