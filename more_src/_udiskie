#compdef udiskie

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-a[automount new devices]' \
  '-A[disable automount]' \
  '-n[enable notifications]' \
  '-N[disable notifications]' \
  '-t[show tray icon]' \
  '-T[disable tray icon]' \
  '-s[enable smart tray (show only when devices present)]' \
  '-S[disable smart tray]' \
  '-f[set file manager]:file manager:_command_names' \
  '-F[disable file manager]' \
  '-p[set password prompt]:program:(zenity kdialog systemd-ask-password)' \
  '-c[config file]:config file:_files' \
  '-C[do not use config file]' \
  '-v[verbose output]' \
  '-q[quiet mode]' \
  '--appindicator[use application indicator]' \
  '--no-appindicator[disable application indicator]' && ret=0

return ret
