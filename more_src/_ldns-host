#compdef ldns-host
# Documentation: https://github.com/NLnetLabs/ldns/blob/master/examples/ldns-host.1
# Reference accessed: 2026-05-19
# Verified: upstream ldns-host(1) manpage source.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-a[verbose ANY query]' \
  '-C[query SOA from all authoritative servers]' \
  '-d[verbose output (backward compat)]' \
  '-i[use IP6.INT for IPv6 reverse lookups]' \
  '-l[list zone via AXFR]' \
  '-r[non-recursive query]' \
  '-s[report SERVFAIL responses]' \
  '-T[query over TCP]' \
  '-v[verbose output]' \
  '-w[wait indefinitely for response]' \
  '-4[only IPv4]' \
  '-6[only IPv6]' \
  '-c+[query class]:class:(IN CH HS NONE ANY)' \
  '-N+[ndots threshold]:n:' \
  '-R+[retry count]:n:' \
  '-t+[query type]:type:(A AAAA NS MX CNAME PTR TXT SOA SRV ANY)' \
  '-W+[timeout seconds before retry]:sec:' \
  '*:host:_hosts' && ret=0

return ret
