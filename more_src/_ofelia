#compdef ofelia
# Documentation: https://github.com/mcuadros/ofelia
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'[configuration file]:config file:_files' \
  '--docker-host[Docker host URL]:url' \
  '--save-folder[folder to save job logs]:folder:_directories' \
  '--save-only-on-error[only save logs on error]' \
  '--log-level[log level]:level:(debug info warn error fatal panic)' \
  '--tls-verify[use TLS and verify remote]' \
  '--tls-cert[path to TLS certificate]:cert file:_files' \
  '--tls-key[path to TLS key]:key file:_files' \
  '--tls-cacert[path to TLS CA certificate]:ca cert file:_files' \
  '--version[show version]' && ret=0

return ret
