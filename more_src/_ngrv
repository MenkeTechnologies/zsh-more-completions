#compdef ngrv
# Documentation: https://man.archlinux.org/search?q=ngrv
# Reference accessed: 2026-05-16
# Source: cargo binstall ngrv@0.1.3
# Probed via: --generate-completion zsh
# Repository: https://github.com/sorairolake/ngrv

autoload -U is-at-least

_ngrv() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'(-q --quiet -k --si)-F+[Set output format to <FORMAT>]:FORMAT:_default' \
'(-q --quiet -k --si)--format=[Set output format to <FORMAT>]:FORMAT:_default' \
'-s+[Set estimated data size to <SIZE> bytes]:SIZE:_default' \
'--size=[Set estimated data size to <SIZE> bytes]:SIZE:_default' \
'-i+[Wait <SEC> seconds between updates]:SEC:_default' \
'--interval=[Wait <SEC> seconds between updates]:SEC:_default' \
'-N+[Prefix the output information with <NAME>]:NAME:_default' \
'--name=[Prefix the output information with <NAME>]:NAME:_default' \
'-u+[Set the progress characters to <STRING>]:STRING:_default' \
'--bar-style=[Set the progress characters to <STRING>]:STRING:_default' \
'*--spinner-style=[Set the tick character sequence or the tick string sequence for the spinner to <STRING>]:STRING:_default' \
'-B+[Use a transfer buffer size of <BYTES> bytes]:BYTES:_default' \
'--buffer-size=[Use a transfer buffer size of <BYTES> bytes]:BYTES:_default' \
'--generate-completion=[Generate shell completion]:SHELL:((bash\:"Bash"
elvish\:"Elvish"
fish\:"fish"
nushell\:"Nushell"
powershell\:"PowerShell"
zsh\:"Zsh"))' \
'(-F --format -q --quiet -u --bar-style)--no-progress[Hide the progress bar]' \
'(-F --format -q --quiet)--no-timer[Hide the elapsed time]' \
'(-F --format -q --quiet)--no-eta[Hide the remaining time]' \
'(-F --format -q --quiet)--no-rate[Hide the speed of data transfer]' \
'(-F --format -q --quiet)--no-bytes[Hide the total amount of data transferred]' \
'(-F --format -q --quiet --spinner-style)--no-spinner[Hide the spinner]' \
'(-k --si -s --size -i --interval -N --name -u --bar-style --spinner-style)-q[Don'\''t output any transfer information at all]' \
'(-k --si -s --size -i --interval -N --name -u --bar-style --spinner-style)--quiet[Don'\''t output any transfer information at all]' \
'-k[Use binary prefixes rather than SI prefixes for the amount of data displayed in the progress]' \
'--si[Use binary prefixes rather than SI prefixes for the amount of data displayed in the progress]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'*::inputs -- Files to concatenate:_files' \
&& ret=0
}

(( $+functions[_ngrv_commands] )) ||
_ngrv_commands() {
    local commands; commands=()
    _describe -t commands 'ngrv commands' commands "$@"
}

if [ "$funcstack[1]" = "_ngrv" ]; then
    _ngrv "$@"
else
    compdef _ngrv ngrv
fi
