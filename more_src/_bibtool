#compdef bibtool

_arguments -s \
  '-A[key disambiguation type]:type:(0 a A n N)' \
  '-c[include cross-referenced entries]' \
  '-d[find/mark identical sort keys]' \
  '-f[key format spec]:format:' \
  '-F[enable key generation]' \
  '(- *)-h[show help]' \
  '*-i[BibTeX input file]:file:_files -g "*.bib"' \
  '-k[short-format keys]' \
  '-K[long-format keys]' \
  '-m[write macro defs to file]:file:_files' \
  '-M[write used macro defs to file]:file:_files' \
  '-o[output file]:file:_files' \
  '-q[suppress warnings]' \
  '*-r[evaluate resource file]:file:_files' \
  '-R[evaluate default resource file]' \
  '-s[sort entries]' \
  '-S[reverse sort]' \
  '-v[verbose]' \
  '(- *)-V[show version]' \
  '-x[extract from aux file]:file:_files -g "*.aux"' \
  '-X[select entries matching regex]:regex:' \
  '-#[print stats for all known entry types]' \
  '-@[print stats for used entry types]' \
  '*:bib:_files -g "*.bib"'
