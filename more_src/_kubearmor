#compdef kubearmor
# _kubearmor — KubeArmor per-node runtime security enforcement daemon (kubearmor/KubeArmor)
# upstream: https://github.com/kubearmor/KubeArmor
# Flags from KubeArmor/config/config.go on tip.

_kubearmor() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--cluster=[Kubernetes cluster name]:name:' \
        '--host=[host name (default detected)]:host:_hosts' \
        '--gRPC=[gRPC bind port]:port:' \
        '--tlsEnabled=[enable TLS on gRPC]:bool:(true false)' \
        '--tlsCertPath=[TLS CA cert directory]:dir:_files -/' \
        '--tlsCertProvider=[TLS cert source]:src:(self external)' \
        '--logPath=[log destination]:path:_files' \
        '--seLinuxProfileDir=[SELinux profile directory]:dir:_files -/' \
        '--criSocket=[CRI socket URI]:uri:' \
        '--nriSocket=[NRI socket path]:path:_files' \
        '--nriIndex=[NRI plugin index]:n:' \
        '--nri=[enable NRI event source]:bool:(true false)' \
        '--visibility=[container visibility list]:list:' \
        '--hostVisibility=[host visibility list]:list:' \
        '--kubearmorPolicy=[enable KubeArmorPolicy CR support]:bool:(true false)' \
        '--kubearmorHostPolicy=[enable KubeArmorHostPolicy CR support]:bool:(true false)' \
        '--kubearmorVM=[enable KubeArmor VM agent]:bool:(true false)' \
        '--k8s=[running in Kubernetes]:bool:(true false)' \
        '--debug=[enable debug logs over gRPC]:bool:(true false)' \
        '--defaultFilePosture=[default file posture]:posture:(allow audit block)' \
        '--defaultNetworkPosture=[default network posture]:posture:(allow audit block)' \
        '--defaultCapabilitiesPosture=[default capabilities posture]:posture:(allow audit block)' \
        '--hostDefaultFilePosture=[host default file posture]:posture:(allow audit block)' \
        '--hostDefaultNetworkPosture=[host default network posture]:posture:(allow audit block)' \
        '--hostDefaultCapabilitiesPosture=[host default capabilities posture]:posture:(allow audit block)' \
        '--hostDefaultDevicePosture=[host default device posture]:posture:(allow audit block)' \
        '--untrackedNs=[comma-separated untracked namespaces]:list:' \
        '--lsm=[LSM preference order]:order:' \
        '--bpfFsPath=[bpf filesystem mount path]:dir:_files -/' \
        '--enforcerAlerts=[emit eBPF enforcer alerts]:bool:(true false)' \
        '--defaultPostureLogs=[emit default-posture alerts (AppArmor)]:bool:(true false)' \
        '--initTimeout=[main thread init timeout]:dur:' \
        '--stateAgent=[enable State Agent gRPC client]:bool:(true false)' \
        '--alertThrottling=[enable alert throttling]:bool:(true false)' \
        '--maxAlertPerSec=[max alerts per second]:n:' \
        '--throttleSec=[throttle window seconds]:n:' \
        '--annotateResources=[annotate without kubearmor-controller]:bool:(true false)' \
        '--procFsMount=[/proc mount path]:dir:_files -/' \
        '--machineIDPath=[machine-id file path]:file:_files'
}

_kubearmor "$@"
