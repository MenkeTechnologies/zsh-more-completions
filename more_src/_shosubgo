#compdef shosubgo
# Documentation: https://github.com/incogbyte/shosubgo
# grab subdomains using the Shodan API

local ret=1

_arguments -s -S \
  '-d[single target domain]:domain' \
  '-f[file containing multiple domains]:domains file:_files' \
  '-s[Shodan API key]:api key' \
  '-fail[instant failure on any error (exit 1)]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
