#compdef dufs

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-b --bind)'{-b,--bind}'[bind address]:address' \
  '(-p --port)'{-p,--port}'[listening port]:port' \
  '--path[root directory to serve]:path:_directories' \
  '(-A --allow-all)'{-A,--allow-all}'[allow all operations]' \
  '--allow-upload[allow file upload]' \
  '--allow-delete[allow file deletion]' \
  '--allow-search[allow search]' \
  '--allow-symlink[allow symlinks]' \
  '--allow-archive[allow archive download]' \
  '(-a --auth)'{-a,--auth}'[authentication credentials]:user\:pass@path' \
  '--hidden[serve hidden files]:pattern' \
  '--enable-cors[enable CORS]' \
  '--render-index[serve index.html when accessing a directory]' \
  '--render-spa[serve index.html for all paths]' \
  '--render-try-index[try serving index.html]' \
  '--assets[set assets directory]:path:_directories' \
  '--log-format[set log format]:format' \
  '--tls-cert[TLS certificate file]:file:_files' \
  '--tls-key[TLS private key file]:file:_files' \
  '--completions[generate shell completions]:shell:(bash zsh fish powershell elvish)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:path:_files' && ret=0
return ret
