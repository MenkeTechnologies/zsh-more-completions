#compdef 3dNwarpApply
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dNwarpApply.html
# AFNI: apply a nonlinear warp to a dataset

local ret=1

_arguments -s -S \
  '-nwarp[nonlinear warp dataset(s) to apply]:warp:_files' \
  '*-source[source dataset(s) to warp]:dataset:_files' \
  '-master[output grid dataset]:master:_files' \
  '*-prefix[output dataset name]:prefix:' \
  '-suffix[suffix for auto-generated output names]:suffix:' \
  '-newgrid[resample master to grid spacing in mm]:mm:' \
  '-dxyz[adjust grid spacing]:mm:' \
  '-interp[interpolation mode]:mode:(NN linear cubic quintic wsinc5)' \
  '-ainterp[interpolation mode for data]:mode:(NN linear cubic quintic wsinc5)' \
  '-iwarp[invert computed warp before applying]' \
  '-short[output 16-bit shorts instead of floats]' \
  '-wprefix[save intermediate warps]:prefix:' \
  '-quiet[suppress verbose output]' \
  '-verb[extra verbose output]' \
  '*:dataset:_files' && ret=0

return ret
