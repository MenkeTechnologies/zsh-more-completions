#compdef mri_threshold
# Documentation: https://github.com/freesurfer/freesurfer/blob/dev/mri_threshold/mri_threshold.cpp
# Threshold a volume at a given intensity

local ret=1

_arguments -s -S \
  '-help[display help]' \
  '-version[display version]' \
  '-B[binarize output volume to specified value]:value:' \
  '-V[set diagnostic output level]:level:' \
  '-F[apply thresholding to a specific frame]:frame:' \
  '-U[switch from lower to upper thresholding mode]' \
  '*:file:_files' && ret=0

return ret
