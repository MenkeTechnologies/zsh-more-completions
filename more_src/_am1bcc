#compdef am1bcc
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools am1bcc: assign AM1-BCC atomic charges

local ret=1

_arguments -s -S \
  '-i[input file name in ac format]:file:_files' \
  '-o[output file name]:file:_files' \
  '-f[output file format]:format:(pdb ac)' \
  '-t[am1bcc type]:type:(bcc abcg2)' \
  '-p[bcc parm file name]:file:_files' \
  '-j[atom and bond type judge option]:option:(0 1 2 3 4 5)' \
  '*:file:_files' && ret=0

return ret
