#compdef kirograph
# Documentation: https://www.npmjs.com/package/kirograph
# Reference accessed: 2026-05-23
# Verified: npm view kirograph bin; upstream docs at kirograph site.

# Zsh completion for kirograph - semantic codebase graph for AI agents

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install KiroGraph for a coding agent target'
  'index:index the codebase'
  'query:query the semantic graph'
  'hotspots:show highly connected graph hotspots'
  'diff:diff graph states'
  'snapshot:manage graph snapshots'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--target=[agent target]:target:(claude codex kiro)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'kirograph command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (snapshot)
        _arguments '1:sub:(save list diff)' && ret=0 ;;
      (*)
        _arguments '*::args:' && ret=0 ;;
    esac ;;
esac

return ret
