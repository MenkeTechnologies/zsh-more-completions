#compdef batcher
# Documentation: man batcher(8)
# Source: InterNetNews/inn backends/batcher.c — combine articles into batches for transmission (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[articles per batch]:N:_default' \
    '-A+[max total articles to batch]:N:_default' \
    '-b+[bytes per batch]:bytes:_default' \
    '-B+[max total bytes to batch]:bytes:_default' \
    '-i+[initial batch-file header string]:string:_default' \
    '-N+[max number of batches]:N:_default' \
    '-p+[post-processing command pipeline]:cmd:_default' \
    '-r[do not redirect stderr to errlog]' \
    '-s+[separator format string]:sep:_default' \
    '-v[verbose: log stats to stdout in addition to syslog]' \
    '1:host:_hosts' \
    '2::batch file:_files' \
    && ret=0

return ret
