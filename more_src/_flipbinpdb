#compdef flipbinpdb
# Documentation: https://www.ks.uiuc.edu/Research/namd/2.9/ug/node11.html
# FlipBinPDB - convert the byte ordering of NAMD binary restart (coor/vel/xsc) files

local ret=1

_arguments -s \
  '*:binary restart file:_files -g "*.(coor|vel|xsc|BinCoor|BinVel)"' && ret=0

return ret
