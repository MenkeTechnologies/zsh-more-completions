#compdef cargo-all-features cargo-build-all-features cargo-check-all-features cargo-test-all-features
# Documentation: https://github.com/frewsxcv/cargo-all-features
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# https://github.com/frewsxcv/cargo-all-features — build/test/check across feature combinations

_arguments -s -S \
  '--n-chunks=[split work into n chunks]:count:' \
  '--chunk=[1-based chunk index (with --n-chunks)]:index:' \
  '--chunk-granularity=[what to chunk]:granularity:(package feature)' \
  '1:cargo_subcommand:(check test build clippy bench run rustdoc doc metadata tree)' \
  '*::cargo_args:_normal' && return 0
