#compdef uno

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[component to load]:component:' \
  '-l+[library to load]:library:_files -g "*.dylib"' \
  '--singleaccept[accept only one connection]' \
  '*-s+[service]:service:' \
  '*--connect=[connection string]:string:' \
  '*--accept=[accept string]:string:' \
  '*:UNO command:' && ret=0

return ret
