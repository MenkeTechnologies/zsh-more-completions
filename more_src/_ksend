#compdef ksend
# Documentation: https://www.atnf.csiro.au/computing/software/karma/user-manual/node13.html
# Karma tool to send commands to various Karma GUI tools

local ret=1

_arguments -s \
  '-add_connection[connect to a running GUI tool]:host\:port' \
  '-load[tell the GUI tool to load a file]:file:_files' \
  '-print[tell the GUI tool to print]' \
  '-ppm[tell the GUI tool to dump a PPM]' \
  '-rclip[set the raw intensity clip range]:range' \
  '-hclip[set the histogram intensity clip range]:range' \
  '*:file:_files' && ret=0

return ret
