#compdef ykchalresp

_arguments -s \
  '-1[use slot 1]' \
  '-2[use slot 2]' \
  '-H[64-byte HMAC-SHA1 challenge]' \
  '-Y[6-byte Yubico OTP challenge]' \
  '-N[non-blocking; abort if button required]' \
  '-x[challenge is hex-encoded]' \
  '-v[verbose]' \
  '-6[OATH 6-digit format]' \
  '-8[OATH 8-digit format]' \
  '-t[use current time as challenge]' \
  '-i+[read challenge from file]:file:_files' \
  '(- *)-V[show version]' \
  '(- *)-h[show help]' \
  ':challenge:'
