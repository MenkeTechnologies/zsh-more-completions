#compdef ioke
# =============================================================================
# ioke — Ola Bini's "Ioke is a new language for the JVM, based on
#        Io and other languages" — a JVM-hosted prototype-based
#        dynamically-typed programming language combining ideas
#        from Io (cells + messages), Smalltalk (object-oriented
#        message passing), Lisp (S-expression-flavored
#        metaprogramming), Ruby (block syntax + nil-vs-false),
#        and Common Lisp (condition system).  Distinguishing from
#        every other documented language by:
#          - PROTOTYPE-BASED OBJECT MODEL via "mimics" — every
#            object can MIMIC any other object (akin to Self +
#            JavaScript prototypes), with multiple mimics enabling
#            multiple inheritance.  Distinct from Self R581 by
#            being multi-mimic + JVM-hosted + with Lisp-flavored
#            metaprogramming
#          - MESSAGE-AS-DATA: every operation is a "message" with
#            name + arguments + next-message chain; messages can
#            be intercepted via macros + modified at runtime
#          - LISP-FLAVORED HOMOICONICITY — Ioke programs ARE Ioke
#            data structures.  Macros operate on message chains
#            directly, like Lisp macros on S-expressions
#          - CONDITION SYSTEM inherited from Common Lisp:
#            recoverable conditions + restart handlers +
#            invoke-restart semantics; richer error handling than
#            Java's exceptions
#          - JVM-HOSTED — runs on the Java Virtual Machine, can
#            interop with Java libraries via reflection.  Comes
#            with a `ioke.jar` shipping a complete Ioke runtime
#          - COVERAGE INSTRUMENTATION via -c/--coverage flag +
#            IKover companion tool (Ioke-specific coverage
#            reporter)
#          - PROGRAM-FROM-STDIN via single `-` argument — Ioke
#            reads its program from stdin like Ruby/Perl
#          - LOAD-PATH MANAGEMENT via -Idir (repeatable) —
#            extends System loadPath like Ruby's -I flag
#          - CWD CONTROL via -Cdirectory — change to directory
#            before executing program
#        Used by: language-design researchers studying multi-
#        inheritance prototype models, JVM Lisp practitioners,
#        and as a reference implementation of message-passing
#        + condition systems + macros in a single homoiconic
#        language.
#
# Author:  Ola Bini (olabini on GitHub) — Swedish/Brazilian
#          programmer + prolific JVM language contributor.
#          Co-author of JRuby (Ruby on the JVM), co-author of
#          Maxine (Sun Labs Java VM), founder of Computer Lab
#          (Tor Project), and active speaker at JVM conferences.
#          Released Ioke 2008-2010; project is in maintenance
#          mode but the runtime + language remain operational.
#          License: ICU.
# Source:  https://github.com/olabini/ioke
#          https://github.com/olabini/ioke/blob/master/src/ikj/main/ioke/lang/Main.java
#          https://github.com/olabini/ioke/blob/master/bin/ioke
# CLI:     src/ikj/main/ioke/lang/Main.java — hand-rolled Java
#          argument parser walking argv with switch on each arg
#          (length-aware for `-eSCRIPT` vs `-e SCRIPT` and
#          `-IDIR` vs `-I DIR` patterns).  Launched via the
#          `bin/ioke` bash shim that sets up CLASSPATH +
#          JAVA_OPTS before invoking the Java runtime.
# Language: IOKE
#           ("Ioke" — Ola Bini — released 2008 as "a new language
#            for the JVM, based on Io and other languages".  The
#            name "Ioke" is pronounced "EE-OH-keh" and is the
#            Hawaiian word for "throat" (per Ola's blog).
#            Distinct from every previously-documented language by:
#              1. MULTI-MIMIC INHERITANCE — every object has a
#                 LIST of mimics (parent prototypes) rather than
#                 a single mimic; method/cell lookup walks the
#                 mimics in order.  This is multi-prototype-
#                 inheritance, distinct from Self's single mimic
#                 (R581) and JavaScript's single __proto__
#              2. CELL-NAME-AS-MESSAGE — instead of methods vs
#                 fields, Ioke has "cells".  A cell can be a
#                 value, a callable lambda, or a macro.  All
#                 access happens via message-sends
#              3. MESSAGE CHAINS — expressions in Ioke are CHAINS
#                 of messages connected by . or \n.  Each message
#                 has a name + arguments + a "next" pointer to
#                 the chain continuation
#              4. SYNTAX-MACROS via syntax declaration — Ioke
#                 macros operate on MESSAGE CHAINS (the AST is
#                 messages), making metaprogramming first-class
#                 + LISP-FLAVORED
#              5. CONDITION SYSTEM — Ioke ports Common Lisp's
#                 condition system to the JVM: signal + handle
#                 + restart semantics enable resumable errors
#                 distinct from Java's unwind-based exceptions
#              6. CELLS AS DATA — methods, lambdas, macros,
#                 syntax-macros are all CELLS distinguished by
#                 their kind; uniformly stored in the cell map
#              7. INDENT-AGNOSTIC GRAMMAR — Ioke uses end-of-line
#                 terminators (or `.`) to separate statements,
#                 with NO significant indentation (unlike Python/
#                 Haskell/Nim)
#              8. JVM INTEROP — full Java class access via
#                 Java::reflect; can use Java libraries directly
#                 with Ioke wrapping conventions
#              9. OLA BINI / JRUBY-ECOSYSTEM PROVENANCE — Ola
#                 is also co-author of JRuby (Ruby on JVM,
#                 4k stars) and Maxine (Sun Labs research JVM);
#                 Ioke is his original language-design project)
# License: ICU (Ioke)
# Status:  Ioke — 167+ stars on olabini/ioke; project is in
#          maintenance mode (last commit ~2010s) but the runtime
#          + language remain operational.  Used in academic
#          teaching of programming language design + JVM
#          metaprogramming.  Ola Bini continues blogging about
#          Ioke at olabini.com.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 91ST LANGUAGE DOCUMENTED
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# its **91ST PROGRAMMING LANGUAGE**: Ioke.  This expands the taxonomy
# from 90 to 91 languages, joining the prior 90 in the cross-language
# inventory.  Taxonomy now spans 375 cross-language CLI library variants
# across **91 documented languages**.
#
# Pattern: R632 90th language (TXR) → R633 Rust=66 (figment) → R634
# Go=66 (knadh/koanf) → R635 TS-Node=66 (conf — Axis 13 reaches 2/2/2)
# → R636 91ST LANGUAGE (Ioke THIS).  This completes the 3-leader-bump
# + new-language segment.  Expected R637 begins next segment (likely
# Rust=67 → Go=67 → TS-Node=67 → 92nd language).
#
# Leaderboard unchanged at R636: Rust=66, Go=66, TypeScript-Node=66
# (three-way tie at 66).
#
# WHY IOKE IS A DISTINCTIVE 91ST LANGUAGE:
#
# Ioke occupies a unique cell in the language design space that NO
# previously-documented language fully fills:
#
#   Feature              | Ioke      | Other documented langs
#   ---------------------|-----------|------------------------
#   Multi-mimic          | ✓ list of | Self (R581): single mimic;
#   inheritance            mimics      JavaScript: single __proto__;
#                                     Lua: __index chain; no other
#                                     documented language has
#                                     multi-mimic
#   Message-as-data      | ✓ message | Smalltalk has messages but
#   chains                 chains      not as-data; Io has messages
#                                     but Ioke extends with macros
#   Lisp macros on       | ✓ syntax  | Common Lisp/Scheme: macros
#   message-chains         decl       on S-exprs; Ioke: macros on
#                                     message chains
#   Condition system     | ✓ CL-     | Common Lisp: native; Ioke:
#   on JVM                 ported     PORTED to JVM (distinct from
#                                     Java exceptions)
#   Cells unification    | ✓ values  | Most OO langs: methods vs
#   (method/lambda/        + lambdas  fields are distinct; Ioke:
#   macro/value)           + macros   ALL CELLS uniformly
#                          uniform
#   Hawaiian-language    | ✓ "Ioke"  | Unique etymology
#   etymology              = throat
#
# Cross-language analogs (closest matches by feature):
#   - Multi-prototype inheritance → AmbientTalk (research)
#   - Message-as-data → Io (Steve Dekorte 2002 — Ioke's primary
#                         ancestor)
#   - Lisp macros on messages → ParenScript (CL-to-JS but different)
#   - Condition system on JVM → no other JVM language has this
#   - Cells uniformity → Newspeak (Bracha) approaches it
#
# Ioke is the FIRST documented language with MULTI-MIMIC INHERITANCE
# + LISP-FLAVORED MACROS-ON-MESSAGE-CHAINS + COMMON LISP CONDITION
# SYSTEM ON THE JVM + Ola Bini provenance.
#
# **IOKE'S PLACE IN THE PROTOTYPE-LANGUAGE LINEAGE**
#
# The taxonomy now documents the prototype-language lineage:
#   - Self (R581) — 1987, prototype-based, single-mimic
#   - Io (Steve Dekorte 2002) — message-passing prototype-based
#   - Ioke (R636 THIS) — 2008, multi-mimic + Lisp macros on Io's
#                         message-passing
#   - JavaScript — 1995, single __proto__ prototype-based
#   - Lua — 1993, __index-based prototype chains
#   - NewtonScript (Apple Newton) — 1993, single-parent prototype
#
# Ioke extends Io's prototype model with multi-mimic + Lisp-flavored
# metaprogramming — a unique combination not seen in any other
# documented language.
#
# -----------------------------------------------------------------------------
#
# THE ioke CLI — Java argv-walking + bash shim for JVM launch
#
# ioke's CLI is in src/ikj/main/ioke/lang/Main.java + bin/ioke
# (bash shim).  The bash shim sets up CLASSPATH + JAVA_OPTS, then
# invokes:
#
#     exec "$JAVA_CMD" $JAVA_OPTS [java args] \
#         -Xbootclasspath/a:"$IOKE_CP" \
#         -classpath "$CP$CP_DELIMETER$CLASSPATH" \
#         "-Dioke.home=$IOKE_HOME" \
#         "-Dfile.encoding=UTF-8" \
#         "-Dioke.lib=$IOKE_HOME/lib" \
#         "-Dioke.script=ioke" \
#         ioke.lang.Main "${ioke_args[@]}"
#
# Main.java walks argv with switch dispatch:
#
#     for(;!done && start<args.length;start++) {
#         String arg = args[start];
#         if(arg.charAt(0) == '-') {
#             if(arg.equals("--")) { done = true; }
#             else if(arg.equals("-d")) { debug = true; }
#             else if(arg.startsWith("-e")) { scripts.add(...); }
#             else if(arg.startsWith("-I")) { loadDirs.add(...); }
#             else if(arg.equals("-h") || arg.equals("--help")) { ... }
#             else if(arg.equals("-c") || arg.equals("--coverage")) { coverage = true; }
#             else if(arg.equals("--version")) { ... }
#             else if(arg.equals("--copyright")) { ... }
#             else if(arg.equals("-")) { readStdin = true; }
#             else if(arg.charAt(1) == 'C') { cwd = arg.substring(2); }
#         }
#     }
#
# CLI surface:
#   -Cdirectory       Change to directory (CWD) before executing
#   -d                Debug mode
#   -e SCRIPT         Execute script string (no program file needed)
#   -c, --coverage    Collect coverage info (consumed by IKover)
#   -h, --help        Show help
#   -Idir             Add directory to System loadPath (repeatable)
#   --copyright       Print copyright
#   --version         Print version
#   --                End of options marker
#   -                 Read program from stdin
#
# Positional after options:
#   programfile [arguments...]  — Ioke program file + program args
#
# Five-axis distinctness of Ioke from every other documented
# language:
#
#   1. MULTI-MIMIC INHERITANCE — Ioke's list-of-mimics design is
#      unique vs Self's single-mimic, JS's single __proto__, Lua's
#      __index chain.
#
#   2. LISP MACROS ON MESSAGE CHAINS — first-class metaprogramming
#      via syntax-declaration operating on the AST-as-messages.
#
#   3. COMMON LISP CONDITION SYSTEM PORTED TO JVM — unique
#      condition + restart semantics that no other JVM language
#      provides.
#
#   4. CELLS UNIFICATION — methods, lambdas, macros, syntax-
#      macros, values are all uniformly "cells" distinguished by
#      kind.
#
#   5. OLA BINI / JRUBY-ECOSYSTEM PROVENANCE — by co-author of
#      JRuby; designed at the intersection of Ruby/JVM/Lisp/Io
#      research lineages.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/olabini/ioke/blob/master/src/ikj/main/ioke/lang/Main.java
# HELP string + switch dispatch in Main.main().)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[print current version]' \
    '(- *)--copyright[print the copyright]' \
    '*-C-[execute with directory as CWD (-Cdir)]' \
    '-d[debug mode]' \
    '*-e+[execute script string]:script:_default' \
    '*-I-[add directory to System loadPath (-Idir, repeatable)]' \
    '(-c --coverage)'{-c,--coverage}'[collect coverage information for IKover]' \
    '1:Ioke program file or "-" for stdin:_files -g "*.ik"' \
    '*::program argument:_default' \
    && ret=0

return ret
