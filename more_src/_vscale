#compdef vscale
# Documentation: https://github.com/lestex/vscalecli
# vscale.io command line interface

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print the version]' \
  '*:command:((account\:"get account info" key\:"list SSH keys" scalet\:"manage scalets" help\:"show a list of commands or help for one command"))' && ret=0

return ret
