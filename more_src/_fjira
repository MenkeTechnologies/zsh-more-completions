#compdef fjira

# mk-5/fjira (cobra); Homebrew: Formula/f/fjira.rb

local ret=1
_arguments -s \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '--jira-url=[Jira base URL]:url:' \
  '--jira-user=[username or email]:user:' \
  '--jira-password=[password or token]:password:' \
  '*::ticket or command:_default' && ret=0
return ret
