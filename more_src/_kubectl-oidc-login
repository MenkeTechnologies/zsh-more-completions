#compdef kubectl-oidc-login

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:subcommand:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'get-token:exec plugin entrypoint'
      'setup:setup kubeconfig stanza'
      'completion:completion helpers'
      'version:print version'
    )
    _describe -t commands 'kubectl-oidc-login command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '--kubeconfig=[kubeconfig path]:file:_files' \
      '--context=[kube context]:context' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
