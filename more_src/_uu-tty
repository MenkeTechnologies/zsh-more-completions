#compdef uu-tty
# Source: Homebrew bottle
# Formula: uutils-coreutils
# Type: maintainer-shipped (Homebrew)
# Harvested: 2026-05-15

autoload -U is-at-least

_uu-tty() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-s[print nothing, only return an exit status]' \
'--silent[print nothing, only return an exit status]' \
'--quiet[print nothing, only return an exit status]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
}

(( $+functions[_uu-tty_commands] )) ||
_uu-tty_commands() {
    local commands; commands=()
    _describe -t commands 'uu-tty commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-tty" ]; then
    _uu-tty "$@"
else
    compdef _uu-tty uu-tty
fi
