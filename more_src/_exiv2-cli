#compdef exiv2-cli
# _exiv2-cli — Andreas Huggel Exiv2 image metadata library CLI alias (exiv2 team, C++); custom argparse
# upstream: https://github.com/Exiv2/exiv2

_exiv2-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[time adjustment]:str:' \
        '-b[binary output for previews]' \
        '-c+[JPEG comment]:str:' \
        '-C+[location]:str:' \
        '-d+[delete target]:t:(a c e i t x)' \
        '-D+[time adjustment]:str:' \
        '-e+[extract target]:t:(a c e i p t x X)' \
        '-f[force overwrite]' \
        '-F[force rename]' \
        '-g+[grep key]:str:' \
        '-i+[insert target]:t:(a c e i t x)' \
        '-k[preserve file timestamps]' \
        '-K+[grep key]:str:' \
        '-l+[location dir]:dir:_files -/' \
        '-m+[command file]:file:_files' \
        '-M+[command]:str:' \
        '-n+[charset]:str:' \
        '-p+[print mode]:m:(s a c e i t v x h)' \
        '-P+[print structure flags]:str:' \
        '-Q+[log level]:l:(d i w e m)' \
        '-q[quiet]' \
        '-r+[file rename format]:str:' \
        '-S+[suffix]:str:' \
        '-t[set modification time from EXIF]' \
        '-T[set EXIF time from file mod time]' \
        '-u[unknown tags also]' \
        '-v[verbose]' \
        '-Y+[year adjustment]:n:' \
        '-O+[month adjustment]:n:' \
        '-d+[day adjustment]:n:' \
        '1:command:(adjust ex extract fi fixcom fixiso fixmpc in insert mo modify mv rename pr print rm delete)' \
        '*:files:_files -g "*.{jpg,jpeg,tif,tiff,png,xmp,nef,cr2,arw,raf,rw2,raw,exv}"'
}

_exiv2-cli "$@"
