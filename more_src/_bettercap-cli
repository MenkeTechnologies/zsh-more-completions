#compdef bettercap-cli
# _bettercap-cli — Simone Margaritelli bettercap network attack and monitoring framework CLI alias (bettercap team, Go); custom argparse
# upstream: https://github.com/bettercap/bettercap

_bettercap-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-iface=+[interface]:_net_interfaces' \
        '-eval=+[commands]:str:' \
        '-caplet=+[caplet file]:file:_files -g "*.cap"' \
        '-script=+[script file]:file:_files -g "*.js"' \
        '-cpu-profile=+[file]:file:_files' \
        '-mem-profile=+[file]:file:_files' \
        '-no-colors[no colors]' \
        '-no-history[no history]' \
        '-env-file=+[file]:file:_files' \
        '-autostart=+[modules csv]:str:' \
        '-debug[debug]' \
        '-silent[silent]' \
        '-caplets-path=+[dir]:dir:_files -/' \
        '-print-version[print version]' \
        '-gateway-override=+[ip]:str:' \
        '-pcap-buf-size=+[bytes]:n:' \
        '-pcap-immediate-mode[immediate mode]' \
        '*:command:'
}

_bettercap-cli "$@"
