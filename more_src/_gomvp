#compdef gomvp
# Documentation: https://man.archlinux.org/search?q=gomvp
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-from+[old import path]:p:' \
  '-to+[new import path]:p:' \
  '-dry-run[dry run]' \
  '*: :_files' && ret=0

return ret
