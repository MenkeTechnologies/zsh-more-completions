#compdef gomvp
# Documentation: https://github.com/abenz1267/gomvp
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gomvp <src pkg> <dst pkg> — no documented flags.
local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:source package:' \
  '2:destination package:' && ret=0

return ret
