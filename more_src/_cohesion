#compdef cohesion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b[below threshold]:percent:' \
  '-a[above threshold]:percent:' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '--below[below threshold]:percent:' \
  '--above[above threshold]:percent:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:files:_files -g "*.py"' \
  && ret=0

return ret
