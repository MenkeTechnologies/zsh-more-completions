#compdef llverdev
# Documentation: https://man.archlinux.org/search?q=llverdev
# Reference accessed: 2026-05-16

# llverdev: Lustre offline block-device verifier
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-c[chunk size in KB]:n:' \
  '--chunksize=[chunk size in KB]:n:' \
  '-f[full scan (whole device)]' \
  '--full[full scan (whole device)]' \
  '-l[long writes (partial scan)]' \
  '--long[long writes (partial scan)]' \
  '-o[offset to start]:bytes:' \
  '--offset=[offset to start]:bytes:' \
  '-p[partial scan]' \
  '--partial[partial scan]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '-r[read mode]' \
  '--read[read mode]' \
  '-s[size in bytes]:bytes:' \
  '--size=[size in bytes]:bytes:' \
  '-t[start time]:time:' \
  '--timestamp=[start time]:time:' \
  '-w[write mode]' \
  '--write[write mode]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '*:device:_files' && ret=0
return ret
