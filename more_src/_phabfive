#compdef phabfive
# Documentation: https://man.archlinux.org/search?q=phabfive
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'configure:interactive setup wizard for Phabricator/Phorge connection'
  'config:print/show config'
  'paste:manage pastes'
  'passphrase:manage passphrase credentials'
  'project:manage projects'
  'maniphest:manage tasks'
  'differential:manage differential revisions'
  'diffusion:manage diffusion repositories'
  'user:manage users'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--phab-url=[Phabricator/Phorge URL]:url:' \
  '--phab-token=[API token]:token:' \
  '--profile=[profile name]:profile:' \
  '--config=[config file]:file:_files -g "*.{ini,yaml,yml,toml}"' \
  '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
  '--json[output JSON]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'phabfive command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (paste|passphrase|project|maniphest|differential|diffusion|user)
        _arguments '*::sub:(list get create edit search delete add comment subscribe)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
