#compdef connect-standalone connect-distributed kafka-connect
# _kafka-connect — Apache Kafka Connect launcher (connect-standalone runs source/sink connectors as a single process; connect-distributed runs the Connect cluster worker; first positional argument is the worker properties file followed by an optional list of connector properties files (standalone only); takes Java -X options too)
# upstream: https://github.com/apache/kafka (connect)
# Argument shape from Apache Kafka connect/runtime bin/connect-* on tip.

_kafka-connect() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '*-J+[JVM option]:option:' \
        '*--config+[connector properties file]:file:_files -g "*.properties"' \
        '*:worker or connector properties file:_files -g "*.properties"'
}

_kafka-connect "$@"
