#compdef ctr
# _ctr — containerd debug client (low-level gRPC client, ships with containerd)
# upstream: https://github.com/containerd/containerd
# Global flags + subcommand list from cmd/ctr/app/main.go on tip (urfave/cli/v2).

_ctr() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--debug[enable debug output in logs]' \
        '(-a --address)'{-a,--address}'=[containerd gRPC server address]:socket:_files' \
        '--timeout=[total ctr command timeout]:duration:' \
        '--connect-timeout=[connect-to-containerd timeout]:duration:' \
        '(-n --namespace)'{-n,--namespace}'=[namespace to use with commands]:ns:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                plugins:'list plugins loaded by containerd'
                version:'print client and server versions'
                containers:'manage containers (alias: c)'
                content:'manage content blobs'
                events:'stream container events'
                images:'manage images (alias: i)'
                leases:'manage leases'
                namespaces:'manage namespaces (alias: ns)'
                pprof:'pull performance profiles from containerd'
                run:'run a container'
                snapshots:'manage snapshots (alias: s)'
                tasks:'manage tasks (alias: t)'
                install:'install a runtime/CNI plugin from an image'
                oci:'OCI runtime utilities'
                sandboxes:'manage sandboxes'
                info:'show containerd server info'
                deprecations:'list deprecation warnings from containerd'
            )
            _describe -t commands 'ctr subcommand' subs
            ;;
    esac
}

_ctr "$@"
