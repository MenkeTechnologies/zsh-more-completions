#compdef hgLoadChain
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: load a generic chain file into the database

local ret=1

_arguments -s -S \
  '-tIndex[include tName in indexes (for non-split chain tables)]' \
  '-noBin[suppress bin field]' \
  '-noSort[do not sort by target (input must be pre-sorted)]' \
  '-oldTable[add to existing table]' \
  '-sqlTable=[create table from .sql file]:file:_files -g "*.sql"' \
  '-normScore[add normalized score column to table]' \
  '-qPrefix=[prepend this string to query name]:xxx' \
  '-test[suppress loading to database]' \
  '1:database:' \
  '2:track:' \
  '3:chain file:_files -g "*.chain"' && ret=0

return ret
