#compdef ddccontrol ddccontrol-gui

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-p[probe for displays]' \
  '-c+[capabilities]:dev:_files -g "/dev/i2c-*"' \
  '-d[dump current settings]' \
  '-r+[read control register]:reg:' \
  '-w+[write control register]:reg:' \
  '-W+[write value]:val:' \
  '-s+[save preset]:name:' \
  '-i+[restore preset]:name:' \
  '-b+[device address]:addr:' \
  '-f[force]' \
  '-D[debug level]' \
  '*:device:_files -g "/dev/i2c-*"' && ret=0

return ret
