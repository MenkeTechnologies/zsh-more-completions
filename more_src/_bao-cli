#compdef bao-cli openbao-cli
# _bao-cli — OpenBao Linux Foundation bao-cli openbao-cli CLI command-line frontend wrapping the OpenBao community fork of HashiCorp Vault providing secrets engines authentication methods kv kv-v2 transit pki database token approle aws azure gcp kubernetes ldap audit policies plugins sealing-unsealing snapshot raft-storage (Linux Foundation team, Go); cobra
# upstream: https://openbao.org/

_bao-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'read:read a secret path'
        'write:write to a path'
        'delete:delete a path'
        'list:list keys at a path'
        'kv:KV secrets engine'
        'transit:Transit secrets engine'
        'pki:PKI secrets engine'
        'database:Database secrets engine'
        'auth:authentication methods'
        'policy:policy management'
        'audit:audit device management'
        'secrets:secrets engine management'
        'token:token operations'
        'unseal:unseal the vault'
        'seal:seal the vault'
        'operator:operator commands'
        'plugin:plugin management'
        'agent:agent mode'
        'proxy:proxy mode'
        'monitor:stream logs'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--address=+[url]:str:' \
        '--namespace=+[name]:str:' \
        '--ca-cert=+[file]:file:_files' \
        '--ca-path=+[dir]:dir:_files -/' \
        '--client-cert=+[file]:file:_files' \
        '--client-key=+[file]:file:_files' \
        '--tls-skip-verify[skip TLS verify]' \
        '--token=+[token]:str:' \
        '-f+[format]:f:(json yaml table)' \
        '--format=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bao-cli subcommand' sub ;;
        args)
            case $words[1] in
                read|write|delete|list) _arguments '*:path:' ;;
                kv) _arguments '1:op:(get put patch delete destroy undelete list metadata enable-versioning)' '*:path:' ;;
                auth|secrets|policy|token|audit|plugin) _arguments '1:op:(list enable disable read write delete tune help)' '*:name:' ;;
            esac
            ;;
    esac
}

_bao-cli "$@"
