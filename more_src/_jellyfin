#compdef jellyfin
# Documentation: https://man.archlinux.org/search?q=jellyfin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --datadir)'{-d+,--datadir=}'[data folder (database, etc.)]:dir:_files -/' \
  '(-w --webdir)'{-w+,--webdir=}'[Jellyfin web UI resources]:dir:_files -/' \
  '(-C --cachedir)'{-C+,--cachedir=}'[cache directory]:dir:_files -/' \
  '(-c --configdir)'{-c+,--configdir=}'[configuration directory]:dir:_files -/' \
  '(-l --logdir)'{-l+,--logdir=}'[log directory]:dir:_files -/' \
  '--ffmpeg=[external ffmpeg path]:file:_files' \
  '--service[run as a headless service]' \
  '--nowebclient[do not host the web client]' \
  '--package-name=[packaging name (e.g. synology)]:name:' \
  '--published-server-url=[server URL for auto-discovery]:url:' \
  '--nonetchange[do not detect network status changes]' \
  '--restore-archive=[restore from backup archive]:file:_files' \
  '--mode=[server action mode]:mode:(default delete-keystore reset-database)' && ret=0

return ret
