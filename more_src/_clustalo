#compdef clustalo
# Documentation: https://man.archlinux.org/search?q=clustalo
# Reference accessed: 2026-05-16

# Clustal Omega: fast, accurate MSA with HMM seeding (UPGMA + HHalign)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(--version)--version[print version]' \
  '--long-version[print extended version info]' \
  '(-i --in)'{-i,--in=}'[input sequence file]:file:_files' \
  '--p1=[profile 1]:file:_files' \
  '--p2=[profile 2]:file:_files' \
  '--hmm-in=[input HMM file]:file:_files' \
  '--dealign[dealign input sequences first]' \
  '--profile1=[profile 1]:file:_files' \
  '--profile2=[profile 2]:file:_files' \
  '--is-profile[treat input as profile alignment]' \
  '-t[sequence type]:type:(Protein RNA DNA)' \
  '--seqtype=[sequence type]:type:(Protein RNA DNA)' \
  '--infmt=[input format]:fmt:(a2m fa fasta clu clustal msf phy phylip sto stockholm vie vienna)' \
  '(-o --out)'{-o,--out=}'[output alignment file]:file:_files' \
  '--outfmt=[output format]:fmt:(a2m fa fasta clu clustal msf phy phylip sto stockholm vie vienna)' \
  '--resno[print residue numbers in clustal format]' \
  '--wrap=[wrap output at N columns]:n:' \
  '--output-order=[output order]:order:(input-order tree-order)' \
  '--iterations=[number of iterations]:n:' \
  '(--iter)--iter=[number of iterations]:n:' \
  '--max-guidetree-iterations=[max guide tree iters]:n:' \
  '--max-hmm-iterations=[max HMM iters]:n:' \
  '--guidetree-in=[guide tree input file]:file:_files' \
  '--guidetree-out=[guide tree output file]:file:_files' \
  '--full[full distance matrix for guide tree]' \
  '--full-iter[full distance matrix during iterations]' \
  '--cluster-size=[cluster size for mBed guide tree]:n:' \
  '--clustering-out=[clustering output file]:file:_files' \
  '--use-kimura[use Kimura distance correction]' \
  '--percent-id[print percent identity]' \
  '--MAC-RAM=[max RAM for MAC algorithm in MB]:MB:' \
  '--threads=[number of CPU threads]:n:' \
  '--auto[auto-tune parameters]' \
  '--log=[log file]:file:_files' \
  '*:input/profile file:_files' && ret=0
return ret
