#compdef docker-bench-security
# _docker-bench-security — Docker Inc docker-bench-security CLI compliance auditing scanner running the CIS Docker Benchmark v1.6.0 v1.7.0 checks against host configuration daemon settings container runtime images audit reporting per-check pass-warn-info-note-warn-skip JSON markdown audit log (Docker team, shell); getopt
# upstream: https://github.com/docker/docker-bench-security

_docker-bench-security() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-b+[bench file]:file:_files' \
        '--benchmark=+[file]:file:_files' \
        '-c+[checks]:str:' \
        '--check=+[list]:str:' \
        '-e+[exclude checks]:str:' \
        '--exclude=+[list]:str:' \
        '-i+[include test]:str:' \
        '--include=+[test]:str:' \
        '-l+[log dir]:dir:_files -/' \
        '--log=+[dir]:dir:_files -/' \
        '-o+[output]:file:_files' \
        '--output-file=+[file]:file:_files' \
        '-r[only show problem checks]' \
        '--problem[only problem checks]' \
        '-n[no color]' \
        '--no-color[no color]' \
        '-j[JSON output]' \
        '--json[JSON output]' \
        '*::'
}

_docker-bench-security "$@"
