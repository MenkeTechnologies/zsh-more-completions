#compdef sumigfd
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/migration_inversion/sumigfd.c
# 45-90 degree finite-difference depth migration of SU data

local ret=1

_arguments -s -S \
  'nz=[number of depth samples]:nz' \
  'dz=[depth sampling interval]:dz' \
  'vfile=[name of file containing velocities]:file:_files' \
  'dt=[time sampling interval]:dt' \
  'dx=[midpoint sampling interval]:dx' \
  'dip=[maximum angle of dip reflector]:dip' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  'verbose=[flag for echoing info]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
