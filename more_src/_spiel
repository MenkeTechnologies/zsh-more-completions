#compdef spiel
# spiel — terminal presentations using Python and Rich/Textual

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a subcommands=(
  'present:present a deck'
  'demo:run the demo deck'
)

_arguments -s -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'spiel command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (present)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--slide=[start at slide number]:slide number:' \
          '1:deck file:_files -g "*.py"' \
          && ret=0
        ;;
      (demo)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
