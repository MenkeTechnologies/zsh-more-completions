#compdef doh
# Documentation: https://man.archlinux.org/search?q=doh
# Reference accessed: 2026-05-16

# curl/doh — DNS-over-HTTPS probe (`doh.c` main option loop)

local ret=1
_arguments -s -S \
  '-v[verbose libcurl trace]' \
  '-V[print version and exit]' \
  '-T[test mode: allow multiple DoH URLs]' \
  '-k[allow insecure TLS]' \
  '-4[force IPv4]' \
  '-6[force IPv6]' \
  '-h[help]' \
  '-tA[query A records only]' \
  '-tAAAA[query AAAA records only]' \
  '-tCNAME[query CNAME only]' \
  '-tTXT[query TXT only]' \
  '-r+[curl --resolve style entry]:resolve:' \
  '1:hostname:' \
  '*:DoH URL(s) (extra URLs require -T):urls:' && ret=0
return ret
