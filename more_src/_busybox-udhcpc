#compdef udhcpc
# _busybox-udhcpc — Erik Andersen Russ Dill BusyBox udhcpc tiny DHCP client suitable for embedded systems (busybox team, C); getopt
# upstream: https://git.busybox.net/busybox

_busybox-udhcpc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-b[background after init]' \
        '-f[run in foreground]' \
        '-i+[interface]:str:' \
        '--interface=+[interface]:str:' \
        '-n[exit if lease not obtained]' \
        '--now[exit if lease not obtained]' \
        '-p+[pid file]:file:_files' \
        '--pidfile=+[pid file]:file:_files' \
        '-q[exit after obtaining lease]' \
        '--quit[exit after obtaining lease]' \
        '-r+[requested ip]:host:_hosts' \
        '--request=+[requested ip]:host:_hosts' \
        '-s+[script]:file:_files' \
        '--script=+[script]:file:_files' \
        '-t+[send N discover packets]:n:' \
        '--retries=+[send N discover packets]:n:' \
        '-T+[seconds between retries]:n:' \
        '--timeout=+[seconds between retries]:n:' \
        '-A+[seconds to wait]:n:' \
        '--tryagain=+[seconds to wait]:n:' \
        '-S[log to syslog]' \
        '--syslog[log to syslog]' \
        '-O+[request option]:str:' \
        '--request-option=+[request option]:str:' \
        '-x+[option:value]:str:' \
        '--xtra=+[option:value]:str:' \
        '-F+[FQDN hostname]:host:_hosts' \
        '--fqdn=+[FQDN hostname]:host:_hosts' \
        '-H+[hostname]:host:_hosts' \
        '--hostname=+[hostname]:host:_hosts' \
        '-c+[client identifier]:str:' \
        '--clientid=+[client identifier]:str:' \
        '-C[do not send client id]' \
        '--clientid-none[do not send client id]' \
        '-V+[vendor identifier]:str:' \
        '--vendorclass=+[vendor identifier]:str:' \
        '-R[release on quit]' \
        '--release[release on quit]'
}

_busybox-udhcpc "$@"
