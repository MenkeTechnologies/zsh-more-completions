#compdef samtools-samples
# Documentation: http://www.htslib.org/doc/samtools-samples.html
# samtools samples: Print the samples from an alignment file

local ret=1

_arguments -s -S \
  '(-h)'-h'[print a header]' \
  '(-i)'-i'[test if the file is indexed. Add an extra column to the output with a]' \
  '(-T)'-T'[provide the sample tag name from the @RG line \[SM\].]:TAG: ' \
  '(-o)'-o'[output file \[stdout\].]:FILE:_files' \
  '(-f)'-f'[load an indexed fasta file in the collection of references. Can be use]:FILE:_files' \
  '(-F)'-F'[read a file containing the paths to indexed fasta files. One path per]:FILE:_files' \
  '(-X)'-X'[use a custom index file.]' \
  '*:file:_files' && ret=0

return ret
