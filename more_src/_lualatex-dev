#compdef lualatex-dev pdflatex-dev xelatex-dev latex-dev
# Documentation: development LaTeX format engines (TeX Live)
# Source: TeX Live -dev engines — preview LaTeX format ahead of next release.
# Reference accessed: 2026-06-10
# NOTE: these binaries share the LuaTeX / pdfTeX / XeTeX surface (depending
# on the prefix); cover the lowest common denominator here.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*--cnf-line=[parse STRING as configuration line]:string:' \
    '--credits[display credits and exit]' \
    '--debug-format[enable format debugging]' \
    '--draftmode[switch on draft mode]' \
    '(--file-line-error --no-file-line-error)--file-line-error[file\:line\:error style]' \
    '(--file-line-error --no-file-line-error)--no-file-line-error[disable file\:line\:error style]' \
    '--fmt=[format file]:name:' \
    '--halt-on-error[stop at first error]' \
    '(- *)--help[show help]' \
    '--ini[be ini engine (dumping formats)]' \
    '--interaction=[interaction mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)' \
    '--jobname=[job name]:string:' \
    '--kpathsea-debug=[kpathsea debug bitmask]:n:' \
    '--lua=[Lua initialization script (luatex-based engines)]:file:_files -g "*.lua"' \
    '--output-comment=[DVI file comment string]:string:' \
    '--output-directory=[output directory]:dir:_files -/' \
    '--output-format=[output format]:format:(dvi pdf)' \
    '--progname=[program name]:string:' \
    '--recorder[enable filename recorder]' \
    '(--shell-escape --no-shell-escape --shell-restricted)--shell-escape[enable system commands]' \
    '(--shell-escape --no-shell-escape --shell-restricted)--no-shell-escape[disable system commands]' \
    '(--shell-escape --no-shell-escape --shell-restricted)--shell-restricted[restrict system commands]' \
    '--synctex=[enable SyncTeX (bitmask)]:n:' \
    '(- *)--version[show version]' \
    '*:TeX source:_files -g "*.tex"' \
    && ret=0

return ret
