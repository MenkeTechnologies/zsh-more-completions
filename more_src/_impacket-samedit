#compdef impacket-samedit
# Documentation: https://github.com/fortra/impacket/blob/master/examples/samedit.py
# In-place edits a local user's password in a SAM hive file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-password=[new password to be set]:password' \
  '-hashes=[replace NTLM hash directly (LM hash is optional)]:hashes' \
  '-system=[SYSTEM hive file containing the bootkey for password encryption]:file:_files' \
  '-bootkey=[bootkey used to encrypt and decrypt SAM passwords]:bootkey' \
  '-debug[turn DEBUG output ON]' \
  '-ts[adds timestamp to every logging output]' \
  '1:user (account to replace the password):' \
  '2:sam (SAM hive file to edit):_files' && ret=0

return ret
