;;
(previous)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(song-link)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(discord)
_arguments "${_arguments_options[@]}" : \
":: :_am__subcmd__help__subcmd__discord_commands" \
"*::: :->discord" \
