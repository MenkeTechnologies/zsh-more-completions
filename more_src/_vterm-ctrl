#compdef vterm-ctrl

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'set-window-title:set the window title'
  'cursor-shape:set cursor shape'
  'find-file:open file in client'
  'message:show a message'
  'colorize:colorize output'
  'reset:reset terminal'
)

_arguments -C \
  '1: :->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'vterm-ctrl command' commands && ret=0
    ;;
esac

return ret
