#compdef img2stdcoord
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/registration/flirt/user_guide.html
# FSL: transform coordinates from image space to standard space

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-img[input image]:img:_files' \
  '-std[standard space image]:std:_files' \
  '-xfm[affine transformation matrix (image to standard)]:xfm:_files' \
  '-warp[non-linear warp field (image to standard)]:warp:_files' \
  '-premat[pre-warp affine transform]:premat:_files' \
  '-vox[input coordinates are in voxels (default)]' \
  '-mm[input coordinates are in mm]' \
  '*:coordfile:_files' && ret=0

return ret
