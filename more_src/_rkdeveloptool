#compdef rkdeveloptool
# Documentation: https://github.com/rockchip-linux/rkdeveloptool
# Rockchip flash tool to communicate with Rockusb devices

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'command' \
      'ld[list devices]' \
      'db[download boot loader]' \
      'ul[upgrade loader]' \
      'rl[read LBA to file]' \
      'wl[write file to LBA]' \
      'wlx[write file to named partition]' \
      'gpt[write GPT partition table]' \
      'prm[write parameter]' \
      'ppt[print partition table]' \
      'ef[erase flash]' \
      'td[test device]' \
      'rd[reset device]' \
      'cs[change storage]' \
      'rid[read flash ID]' \
      'rfi[read flash info]' \
      'rci[read chip info]' \
      'rcb[read capability]' \
      'pack[pack boot loader]' \
      'unpack[unpack boot loader]' \
      'tagspl[tag U-Boot SPL]' && ret=0
    ;;
  args)
    case $words[1] in
      db|ul|gpt|prm|unpack) _files && ret=0 ;;
      wl) _arguments ':begin sector:' ':file:_files' && ret=0 ;;
      wlx) _arguments ':partition name:' ':file:_files' && ret=0 ;;
      rl) _arguments ':begin sector:' ':sector length:' ':file:_files' && ret=0 ;;
      cs) _arguments ':storage:((1\:EMMC 2\:SD 9\:SPINOR))' && ret=0 ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
