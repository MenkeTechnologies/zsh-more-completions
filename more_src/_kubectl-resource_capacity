#compdef kubectl-resource_capacity kube-capacity
# Documentation: https://github.com/robscott/kube-capacity
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-p --pods)'{-p,--pods}'[show pods]' \
  '(-c --containers)'{-c,--containers}'[show containers]' \
  '(-u --util)'{-u,--util}'[show resource utilization]' \
  '(-a --available)'{-a,--available}'[show available instead of used]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace filter]:ns:' \
  '--namespace-labels=[namespace label selector]:sel:' \
  '--node-labels=[node label selector]:sel:' \
  '(-l --pod-labels)'{-l+,--pod-labels=}'[pod label selector]:sel:' \
  '(-t --node-taints)'{-t+,--node-taints=}'[node taint filter]:taint:' \
  '--pod-count[show pod counts per node]' \
  '--show-labels[show node labels]' \
  '--hide-limits[hide limits from output]' \
  '--hide-requests[hide requests from output]' \
  '--no-taint[exclude tainted nodes]' \
  '--no-headers[suppress headers]' \
  '--sort=[sort by field]:field:(cpu.util cpu.request cpu.limit cpu.util.percentage cpu.request.percentage cpu.limit.percentage mem.util mem.request mem.limit mem.util.percentage mem.request.percentage mem.limit.percentage name)' \
  '(-o --output)'{-o+,--output=}'[output format]:fmt:(table json yaml csv tsv)' \
  '--context=[kubectl context]:ctx:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--as=[impersonate user]:user:' \
  '--as-group=[impersonate group]:group:' \
  '*:node name:' && ret=0

return ret
