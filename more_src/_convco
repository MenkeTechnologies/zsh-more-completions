#compdef convco

# Zsh completion for convco - Conventional Commits CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:check commit messages for conventional commit compliance'
      'commit:create a conventional commit'
      'changelog:generate a changelog'
      'version:show or calculate the version'
    )
    _describe -t commands 'convco command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--from-stdin[read commits from stdin]' \
          '--rev=[revision range to check]:revision range' && ret=0
        ;;
      commit)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--type=[commit type]:type:(feat fix docs style refactor perf test build ci chore revert)' \
          '--scope=[commit scope]:scope' \
          '--description=[commit description]:description' \
          '--body=[commit body]:body' \
          '--breaking-change[mark as breaking change]' \
          '--edit[open editor for commit message]' \
          '--amend[amend the previous commit]' && ret=0
        ;;
      changelog)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--unreleased[only show unreleased changes]' \
          '--max-versions=[maximum number of versions to include]:int' \
          '--max-minors=[maximum number of minor versions to include]:int' \
          '--max-patches=[maximum number of patch versions to include]:int' && ret=0
        ;;
      version)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--bump[calculate next version bump]' \
          '--major[bump major version]' \
          '--minor[bump minor version]' \
          '--patch[bump patch version]' \
          '--label=[pre-release label]:label' \
          '--prefix=[version prefix]:prefix' && ret=0
        ;;
    esac
    ;;
esac

return ret
