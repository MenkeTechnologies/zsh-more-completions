#compdef ddd

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--debugger+[debugger to use]:dbg:(gdb dbx wdb xdb jdb pydb perl bashdb)' \
  '--gdb[use gdb]' \
  '--dbx[use dbx]' \
  '--wdb[use wdb]' \
  '--xdb[use xdb]' \
  '--jdb[use jdb]' \
  '--pydb[use pydb]' \
  '--perl[use perl debugger]' \
  '--bash[use bash debugger]' \
  '--make[use make debugger]' \
  '--driver+[driver]:d:' \
  '-r+[debug remote]:host:_hosts' \
  '-c+[core file]:file:_files' \
  '-x+[gdb command file]:file:_files' \
  '-tty+[tty]:t:' \
  '--no-exec-window[no exec window]' \
  '--exec-window[show exec window]' \
  '--separate-windows[separate windows]' \
  '--attached-windows[attached windows]' \
  '--config+[config dir]:dir:_files -/' \
  '--rcdir+[rc dir]:dir:_files -/' \
  '--rcfile+[rc file]:file:_files' \
  '--statesfile+[states file]:file:_files' \
  '--mode-text[text only]' \
  '--mode-graphic[graphic mode]' \
  '--font+[font]:font:' \
  '--display+[X display]:disp:' \
  '*: :_files' && ret=0

return ret
