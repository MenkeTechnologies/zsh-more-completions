#compdef helixturnhelix
# Documentation: https://man.archlinux.org/search?q=helixturnhelix
# Reference accessed: 2026-05-16

# EMBOSS helixturnhelix: identify HTH DNA-binding motifs in protein
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-mean=[mean score for population (-100..200)]:mean:' \
  '-sd=[standard deviation cut-off]:sd:' \
  '-minsd=[minimum SD per residue]:minsd:' \
  '-eightyseven[use 1987 weights instead of 1990]' \
  '-outfile=[report output file]:file:_files' \
  '-rformat=[report format]:format:(motif table excel feattable gff3 listfile pir simple swiss tagseq)' \
  '*:protein USA:_files' && ret=0
return ret
