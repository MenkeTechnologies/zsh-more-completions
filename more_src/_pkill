#compdef pkill pgrep
# Documentation: man pkill(1) / pgrep(1) (BSD)
# Source: pkill / pgrep — find or signal processes by name.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a sig_opts
sig_opts=(
    '-HUP' '-INT' '-QUIT' '-ILL' '-TRAP' '-ABRT' '-EMT' '-FPE' '-KILL' '-BUS'
    '-SEGV' '-SYS' '-PIPE' '-ALRM' '-TERM' '-URG' '-STOP' '-TSTP' '-CONT'
    '-CHLD' '-TTIN' '-TTOU' '-IO' '-XCPU' '-XFSZ' '-VTALRM' '-PROF' '-WINCH'
    '-INFO' '-USR1' '-USR2'
    '-1' '-2' '-3' '-6' '-9' '-14' '-15'
)

_arguments -s \
    ${sig_opts[@]/#-/-+}'[send named signal (pkill)]' \
    '-F+[restrict matches to PID in pidfile]:pidfile:_files' \
    '-G+[restrict matches to real gid (comma-list)]:gid:_groups' \
    '-I[confirm before signaling each process (pkill)]' \
    '-L[require pidfile created with flock(2)/pidfile(3)]' \
    '-P+[restrict matches to ppid (comma-list)]:ppid:_pids' \
    '-U+[restrict matches to real uid (comma-list)]:uid:_users' \
    '-d+[delimiter between PIDs (pgrep)]:delim:' \
    '-g+[restrict matches to pgrp (comma-list; 0 = self)]:pgrp:' \
    '-t+[restrict matches to controlling tty (comma-list)]:tty:' \
    '-u+[restrict matches to euid (comma-list)]:euid:_users' \
    '-a[include process ancestors]' \
    '-f[match against full argv]' \
    '-i[case-insensitive pattern + ps name]' \
    '-l[long output (cmd or kill cmd)]' \
    '-n[only newest matching process]' \
    '-o[only oldest matching process]' \
    '-q[no stdout for pgrep]' \
    '-v[invert match]' \
    '-x[exact match]' \
    '*:pattern:_command_names -e' \
    && ret=0

return ret
