#compdef wasm_of_ocaml
# Documentation: https://ocsigen.org/js_of_ocaml/latest/manual/wasm_overview
# Compiler from OCaml bytecode to WebAssembly (part of the js_of_ocaml project)

local ret=1
local -a subcmds

subcmds=(
  'compile:compile a bytecode program or cmo/cma to WebAssembly'
  'build-runtime:build a separately-compiled runtime'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-o+[set output file name]:output:_files' \
  '--pretty[pretty-print the generated code]' \
  '--debug-info[output debug information]' \
  '--debug=[enable debugging of a given section]:section' \
  '--source-map[generate a source map]' \
  '--no-source-map[do not generate a source map]' \
  '--source-map-inline[inline the source map in the output]' \
  '--source-map-root=[set the root directory of the source map]:dir:_files -/' \
  '--opt=[set the optimization profile level]:level:(1 2 3)' \
  '*--enable=[enable an optimization or feature]:option' \
  '*--disable=[disable an optimization or feature]:option' \
  '--no-inline[disable inlining]' \
  '--no-runtime[do not include the standard runtime]' \
  '--include-runtime[include the runtime for cmo/cma input]' \
  '--linkall[link all primitives and units]' \
  '--effects=[select the effect-handlers implementation]:kind:(cps jspi double-translation)' \
  '--target-env=[select the runtime target environment]:env:(isomorphic browser nodejs)' \
  '--Werror[treat warnings as errors]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-error messages]' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'wasm_of_ocaml command' subcmds && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
