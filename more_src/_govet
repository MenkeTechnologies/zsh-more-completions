#compdef govet
# _govet — standalone go vet wrapper for go-vet (Mike Andersen et al)
# upstream: https://pkg.go.dev/cmd/vet

_govet() {
    _arguments \
        '-n[print commands without running]' \
        '-x[print commands]' \
        '-vettool+[external vet tool]:file:_files' \
        '-tags+[build tags]:tags:' \
        '-v[verbose]' \
        '-c+[surrounding source context]:n:' \
        '-flags[print analyzer flags]' \
        '-json[json output]' \
        '*:packages:'
}

_govet "$@"
