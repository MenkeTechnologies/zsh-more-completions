#compdef dkimverify dkimverify.pl
# Documentation: https://www.unix.com/man-page/debian/1/dkimverify/
# verify DKIM/DomainKeys signatures on an email message

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--debug-canonicalization=[write canonicalized message to file]:file:_files' \
  '*:mail file:_files' && ret=0

return ret
