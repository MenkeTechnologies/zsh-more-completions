#compdef sbsign sbverify sbattach sbsiglist sbvarsign sbkeysync sbsigntool
# Documentation: https://man.archlinux.org/search?q=sbsign
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

case $service in
  (sbsign)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-o --output)'{-o,--output}'+[output file]:file:_files' \
      '(-c --cert)'{-c,--cert}'+[certificate]:file:_files' \
      '(-k --key)'{-k,--key}'+[private key]:file:_files' \
      '(-d --detached)'{-d,--detached}'[create detached signature]' \
      '(-e --engine)'{-e,--engine}'+[OpenSSL engine]:engine:' \
      '(--addcert)--addcert=+[add intermediate cert]:file:_files' \
      '*:file:_files -g "*.efi"' && ret=0 ;;
  (sbverify)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-c --cert)'{-c,--cert}'+[CA certificate]:file:_files' \
      '(-l --list)'{-l,--list}'[list signatures]' \
      '(-x --no-verify)'{-x,--no-verify}'[do not verify]' \
      '*:file:_files -g "*.efi"' && ret=0 ;;
  (sbattach)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-a --attach)'{-a,--attach}'+[attach signature file]:file:_files' \
      '(-d --detach)'{-d,--detach}'+[detach to file]:file:_files' \
      '(-r --remove)'{-r,--remove}'[remove signature]' \
      '*:file:_files -g "*.efi"' && ret=0 ;;
  (sbvarsign)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-a --attr)'{-a,--attr}'+[EFI variable attributes]:attrs:' \
      '(-c --cert)'{-c,--cert}'+[cert]:file:_files' \
      '(-k --key)'{-k,--key}'+[private key]:file:_files' \
      '(-g --guid)'{-g,--guid}'+[GUID]:guid:' \
      '(-i --include-attrs)'{-i,--include-attrs}'[include attributes in signature]' \
      '(-o --output)'{-o,--output}'+[output file]:file:_files' \
      '*:varname:' && ret=0 ;;
  (sbkeysync)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
      '(-p --pk)'{-p,--pk}'[sync PK]' \
      '(--keystore)--keystore=+[keystore]:dir:_files -/' \
      '(--no-default-keystores)--no-default-keystores[do not use default keystores]' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' && ret=0 ;;
esac

return ret
