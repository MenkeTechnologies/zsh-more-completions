#compdef fitcircle
# Documentation: https://docs.generic-mapping-tools.org/latest/fitcircle.html
# Source: GenericMappingTools/gmt classic-mode fitcircle — best-fit great/small circle through lon/lat points.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-L+[norm (1=L1, 2=L2, both if omitted)]:norm:(1 2)' \
    '-F+[output flags (f flat-earth, m mean, n north pole, s south pole, c small-circle pole)]:flags:_default' \
    '-S+[fit small circle (optional fixed latitude)]:lat:_default' \
    '*-V[verbose (stackable)]' \
    '-a+[aspatial column associations]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-:[swap first two columns]' \
    '*:input lon,lat table:_files' \
    && ret=0

return ret
