#compdef rush

# Zsh completion for rush - scalable monorepo manager (Microsoft)

local curcontext="$curcontext" state line ret=1

local -a global_opts=(
  '(-h --help)'{-h,--help}'[show help information]'
  '--version[show version]'
  '--debug[enable debug mode]'
  '(-p --parallelism)'{-p,--parallelism}'[set the maximum number of parallel operations]:n:'
)

local -a subcommands=(
  'add:add a dependency to a project'
  'build:build all projects that have been changed'
  'change:record a change for publishing'
  'check:check for inconsistent dependency versions'
  'deploy:prepare a deployment'
  'init:initialize a new repo'
  'install:install all dependencies'
  'link:create symlinks for all projects'
  'list:list all projects'
  'publish:publish packages that have been changed'
  'purge:delete temporary files'
  'rebuild:clean and rebuild all projects'
  'remove:remove a dependency from a project'
  'scan:scan the repository for problems'
  'setup:run first-time setup procedures'
  'unlink:remove symlinks created by link'
  'update:update package dependencies'
  'update-autoinstaller:update an autoinstaller'
  'update-cloud-credentials:update cloud credentials'
  'version:manage package versions'
  'write-autoinstallers:write autoinstaller state'
)

local -a build_opts=(
  '(-t --to)'{-t,--to}'[build up to and including this project]:project:'
  '(-T --to-except)'{-T,--to-except}'[build up to but excluding this project]:project:'
  '(-f --from)'{-f,--from}'[build from this project and its dependents]:project:'
  '(-p --parallelism)'{-p,--parallelism}'[set max parallel operations]:n:'
  '(-v --verbose)'{-v,--verbose}'[show verbose output]'
  '--production[perform a production build]'
  '--changed-projects-only[only build projects with changes]'
  '--timeline[display a timeline after build completes]'
)

_arguments -s -S \
  $global_opts \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'rush subcommand' subcommands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (build|rebuild)
        _arguments -s -S $build_opts '*:arguments:' && ret=0
        ;;
      (install)
        _arguments -s -S \
          '--purge[clean before installing]' \
          '--bypass-policy[bypass the rush policy]' \
          '--no-link[do not create symlinks]' \
          '--network-concurrency[set max concurrent network requests]:n:' \
          '--debug-package-manager[show debug output from the package manager]' \
          '--max-install-attempts[set max install attempts]:n:' \
          '--variant[use the specified installation variant]:variant name:' \
          '--check-only[only check if the install is up to date]' && ret=0
        ;;
      (add)
        _arguments -s -S \
          '(-p --package)'{-p,--package}'[the project to add the dependency to]:project:' \
          '--exact[use exact version]' \
          '--caret[use caret version range]' \
          '--dev[add as a devDependency]' \
          '--peer[add as a peerDependency]' \
          '--make-consistent[ensure all projects use the same version]' \
          '--all[add to all projects]' \
          '--skip-update[skip running rush update after adding]' \
          '*:package name:' && ret=0
        ;;
      (change)
        _arguments -s -S \
          '(-b --branch)'{-b,--branch}'[set the target branch for comparison]:branch:' \
          '--bulk[create change files in bulk mode]' \
          '--message[specify the change description]:message:' \
          '--email[specify the author email]:email:' \
          '--no-fetch[skip fetching the baseline branch]' \
          '--target-branch[set the target branch]:branch:' \
          '--overwrite[overwrite existing change files]' && ret=0
        ;;
      (publish)
        _arguments -s -S \
          '(-b --branch)'{-b,--branch}'[set the target branch]:branch:' \
          '--npm-auth-token[set the npm auth token]:token:' \
          '(-p --publish)'{-p,--publish}'[publish packages]' \
          '--include-all[include all packages]' \
          '--pack[run npm pack instead of npm publish]' \
          '--release-folder[set the release folder]:dir:_files -/' \
          '--tag[set the npm dist-tag]:tag:' \
          '--set-publish-tag[set the publish tag]:tag:' \
          '--add-commit-details[add commit details to change logs]' \
          '--registry[set the npm registry]:url:' \
          '--apply[apply the version updates]' \
          '--partial[allow partial publishing]' \
          '--prerelease-name[set the prerelease name]:name:' \
          '--suffix[set the version suffix]:suffix:' \
          '--target-branch[set the target branch]:branch:' \
          '--version-policy[use the specified version policy]:name:' && ret=0
        ;;
      (list)
        _arguments -s -S \
          '(-v --version)'{-v,--version}'[show versions]' \
          '--json[output as JSON]' \
          '(-t --to)'{-t,--to}'[list up to and including this project]:project:' \
          '(-f --from)'{-f,--from}'[list from this project]:project:' \
          '(-p --full-path)'{-p,--full-path}'[show full paths]' \
          '--detailed[show detailed information]' && ret=0
        ;;
      (update)
        _arguments -s -S \
          '(-s --skip-update)'{-s,--skip-update}'[skip running the update]' \
          '(-p --package-name)'{-p,--package-name}'[update only the specified package]:package name:' && ret=0
        ;;
      (*)
        _arguments -s -S $global_opts '*:arguments:' && ret=0
        ;;
    esac
    ;;
esac

return ret
