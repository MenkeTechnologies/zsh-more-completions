#compdef gitea
# _gitea-cli — Gitea self-hosted Git service CLI (Gitea team, Go); administer a running Gitea instance
# upstream: https://github.com/go-gitea/gitea

_gitea-cli() {
    local -a sub=(
        'actions:actions commands'
        'admin:admin commands'
        'cert:generate self-signed cert'
        'convert:convert MySQL CHARSET to utf8mb4'
        'docs:generate docs'
        'doctor:diagnose Gitea'
        'dump:create backup'
        'dump-repo:dump repo'
        'embedded:list embedded resources'
        'generate:generate secrets'
        'help:show help'
        'hook:internal hook command (git invokes)'
        'keys:internal SSH keys command'
        'manager:manager commands'
        'migrate:run migrations'
        'migrate-storage:migrate storage'
        'restore-repo:restore repo'
        'serv:internal git serv (ssh)'
        'serve:serve gitea'
        'web:run web server'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--config+[config file]:file:_files -g "*.ini"' \
        '-c+[config file]:file:_files -g "*.ini"' \
        '--custom-path+[custom path]:dir:_files -/' \
        '-C+[custom path]:dir:_files -/' \
        '--work-path+[work path]:dir:_files -/' \
        '-W+[work path]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gitea subcommand' sub ;;
        args)
            case $words[1] in
                admin) _arguments '1:admin cmd:(auth user)' '*:args:' ;;
                web) _arguments \
                    '--port+[port]:port:' \
                    '-p+[port]:port:' \
                    '--install-port+[install port]:port:' \
                    '--pid+[pid file]:file:_files' \
                    '-P+[pid file]:file:_files' ;;
                dump) _arguments \
                    '--file+[output file]:file:_files' \
                    '-f+[output file]:file:_files' \
                    '--verbose[verbose]' \
                    '--type+[archive type]:type:(zip tar tar.gz tar.bz2 tar.xz tar.sz tar.zst)' \
                    '-t+[archive type]:type:' \
                    '--tempdir+[temp dir]:dir:_files -/' \
                    '--skip-repository[skip repos]' \
                    '-R[skip repos]' \
                    '--skip-log[skip logs]' \
                    '-L[skip logs]' \
                    '--skip-attachment-data[skip attachments]' \
                    '--skip-package-data[skip packages]' \
                    '--skip-lfs-data[skip LFS]' \
                    '--skip-custom-dir[skip custom dir]' ;;
                actions) _arguments '1:actions cmd:(generate-runner-token list-runners)' '*:args:' ;;
                manager) _arguments '1:manager cmd:(flush-queues logging shutdown restart reload-templates)' '*:args:' ;;
            esac
            ;;
    esac
}

_gitea-cli "$@"
