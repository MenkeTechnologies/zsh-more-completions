#compdef sidxindex

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-out+[output MPD file]:file:_files -g "*.mpd"' \
  '-tpl+[template]:template:' \
  '-base-url+[base URL]:url:' \
  '-profile+[DASH profile]:profile:(onDemand main full live broadcast simple main_lo)' \
  '-single-segment[single segment mode]' \
  '-single-file[single file mode]' \
  '-bandwidth+[bandwidth]:n:' \
  '*:input file:_files -g "*.(mp4|m4s|mov)"' && ret=0

return ret
