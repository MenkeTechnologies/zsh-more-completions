#compdef egencache
# Gentoo ebuild metadata cache generator

local ret=1

_arguments -s -S \
  '--repo=[target repository]:repository name:' \
  '--repositories-configuration=[override repositories configuration]:config:_files' \
  '--cache-dir=[alternate cache directory]:directory:_files -/' \
  '--config-root=[alternate configuration root]:directory:_files -/' \
  '--gpg-dir=[GPG home directory]:directory:_files -/' \
  '--gpg-key=[GPG key for signing]:key id:' \
  '--jobs=[number of parallel jobs]:jobs:' \
  '--load-average=[load average limit]:load:' \
  '--portdir=[override PORTDIR]:directory:_files -/' \
  '--portdir-overlay=[override PORTDIR_OVERLAY]:directory:_files -/' \
  '--tolerant[exit successfully if only minor errors occurred]' \
  '--update[update metadata cache]' \
  '--update-changelogs[update ChangeLog files]' \
  '--update-manifests[update Manifest files]' \
  '--update-pkg-desc-index[update package description index]' \
  '--update-use-local-desc[update use.local.desc]' \
  '--sign-manifests[sign Manifests]' \
  '--strict-manifests[require correct Manifest files]' \
  '--thin-manifests[use thin Manifests]' \
  '--write-timestamp[write timestamp to metadata]' \
  '*:atom:' && ret=0

return ret
