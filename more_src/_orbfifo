#compdef orbfifo
# _orbfifo — orbuculum project orbfifo CLI client connecting to orbuculum daemon and demuxing ITM stimulus port channels into named POSIX FIFO files in a directory for downstream tail head cat tools to consume per-channel trace streams (Dave Marples team, C); custom argparse
# upstream: https://github.com/orbcode/orbuculum

_orbfifo() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose level]:l:(0 1 2 3 4)' \
        '-b+[basedir]:dir:_files -/' \
        '-c+[channel name format]:str:' \
        '-E[exception report]' \
        '-h+[timestamp format]:s:(none absolute relative delta cycle)' \
        '-n[no NL]' \
        '-P+[protocol]:p:(itm tpiu etm)' \
        '-s+[server:port]:host:port:' \
        '-t+[tag]:str:' \
        '-T[TPIU framing]' \
        '-w+[write to file]:file:_files' \
        '-x+[exclude channel mask]:n:' \
        '*:channel spec:'
}

_orbfifo "$@"
