#compdef nethermind
# Documentation: https://man.archlinux.org/search?q=nethermind
# Reference accessed: 2026-05-16

_arguments -s -S \
  '--config=[Network preset]:config:(mainnet sepolia holesky gnosis chiado energyweb aurora joc optimism base worldchain)' \
  '--datadir=[Database directory]:directory:_directories' \
  '--log=[Logging level]:level:' \
  '--JsonRpc.Enabled[Enable JSON-RPC server]' \
  '--JsonRpc.EngineHost=[Engine API listen host]:host:' \
  '--JsonRpc.EnginePort=[Engine API port]:port:' \
  '--JsonRpc.JwtSecretFile=[JWT secret path]:file:_files' \
  '--HealthChecks.Enabled[Expose health probes]' \
  '--Metrics.Enabled[Expose Prometheus metrics]' \
  '--Pruning.CacheMb=[In-memory pruning cache size MB]:size' \
  '*::arguments: _default'
