#compdef elasticsearch-certutil

# elasticsearch-certutil: generate/manage Elasticsearch certificates
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'ca:generate a CA certificate'
  'cert:generate certs from CA'
  'csr:generate CSR'
  'http:helper to generate HTTPS certs'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '--silent[silent]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-E[config setting key=value]:kv:' \
  '--ca[CA cert file]:file:_files' \
  '--ca-cert[CA cert file]:file:_files' \
  '--ca-key[CA key file]:file:_files' \
  '--ca-dn[CA DN]:dn:' \
  '--ca-pass[CA password]:pass:' \
  '--days[validity days]:n:' \
  '--dns[DNS names]:names:' \
  '--ip[IP addresses]:ips:' \
  '--keep-ca-key[keep CA key in PKCS#12]' \
  '--keysize[key size bits]:bits:(1024 2048 3072 4096)' \
  '--multiple[generate multiple certs in zip]' \
  '--name[certificate name]:name:' \
  '--out[output file]:file:_files' \
  '--pass[output password]:pass:' \
  '--pem[output PEM instead of PKCS#12]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'elasticsearch-certutil command' commands && ret=0 ;;
esac
return ret
