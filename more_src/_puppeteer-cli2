#compdef puppeteer-cli2 puppeteer2
# _puppeteer-cli2 — Google Chrome DevTools puppeteer-cli2 CLI command-line frontend wrapping the Puppeteer JavaScript API for Chrome and Chromium open-source written in TypeScript Node Headless Chrome Node.js API by Chrome DevTools Team JavaScript API which provides a high-level API to control Chrome or Chromium over the DevTools Protocol PDF screenshot HAR navigate evaluate render automate scrape headless Lighthouse install update list browsers-install browsers-clean browsers-list browsers-uninstall trace screencast pdf-export page-load network capabilities (Google Chrome DevTools team, TypeScript); commander
# upstream: https://pptr.dev/

_puppeteer-cli2() {
    local -a sub=(
        'install:install browsers'
        'uninstall:uninstall browsers'
        'list:list installed browsers'
        'clean:clean cache'
        'screenshot:take a screenshot of URL'
        'pdf:render URL as PDF'
        'trace:capture trace'
        'screencast:record screencast'
        'render:render URL as image'
        'eval:evaluate JS on a URL'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--browser=+[name]:n:(chrome firefox chromium chromedriver)' \
        '-b+[browser]:n:(chrome firefox chromium chromedriver)' \
        '--platform=+[p]:p:(linux mac mac_arm win32 win64)' \
        '--path=+[dir]:dir:_files -/' \
        '--cache=+[dir]:dir:_files -/' \
        '--base-url=+[url]:str:' \
        '--url=+[url]:str:' \
        '-u+[url]:str:' \
        '--output=+[file]:file:_files' \
        '-o+[output]:file:_files' \
        '--format=+[fmt]:f:(png jpeg webp pdf)' \
        '-f+[format]:f:(png jpeg webp pdf)' \
        '--full-page[full page]' \
        '--quality=+[N]:n:' \
        '--width=+[N]:n:' \
        '--height=+[N]:n:' \
        '--landscape[landscape mode]' \
        '--print-background[print background]' \
        '--scale=+[N]:str:' \
        '--margin-top=+[N]:str:' \
        '--margin-bottom=+[N]:str:' \
        '--margin-left=+[N]:str:' \
        '--margin-right=+[N]:str:' \
        '--header=+[html]:str:' \
        '--footer=+[html]:str:' \
        '--paper-format=+[p]:p:(Letter Legal Tabloid Ledger A0 A1 A2 A3 A4 A5 A6)' \
        '--paper-width=+[N]:str:' \
        '--paper-height=+[N]:str:' \
        '--device=+[name]:str:' \
        '-d+[device]:str:' \
        '--user-agent=+[ua]:str:' \
        '--proxy=+[url]:str:' \
        '--timeout=+[ms]:n:' \
        '--wait-until=+[e]:e:(load domcontentloaded networkidle0 networkidle2)' \
        '*--wait-until=+[e]:e:(load domcontentloaded networkidle0 networkidle2)' \
        '--cookie=+[k=v]:str:' \
        '*--cookie=+[k=v]:str:' \
        '--header-name=+[k=v]:str:' \
        '*--header-name=+[k=v]:str:' \
        '--inspect[inspect]' \
        '--headless=+[v]:v:(true false old new)' \
        '--no-headless[no headless]' \
        '--show-trace[show trace]' \
        '--lighthouse[run Lighthouse]' \
        '--har-path=+[file]:file:_files -g "*.har"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'puppeteer subcommand' sub ;;
        args)
            case $words[1] in
                install|uninstall|list) _arguments '*:browser:(chrome firefox chromium chromedriver)' ;;
                screenshot|pdf|render|eval|trace|screencast) _arguments '*:url:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_puppeteer-cli2 "$@"
