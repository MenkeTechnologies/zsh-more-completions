#compdef ionice-cli
# _ionice-cli — util-linux ionice set or get process I/O scheduling class and priority CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_ionice-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[class]:c:(0 1 2 3)' \
        '--class=+[class]:c:(0 1 2 3)' \
        '-n+[priority]:n:' \
        '--classdata=+[priority]:n:' \
        '-p+[pid]:pid:_pids' \
        '--pid=+[pid]:pid:_pids' \
        '-P+[pgid]:str:' \
        '--pgid=+[pgid]:str:' \
        '-t[ignore failures]' \
        '--ignore[ignore failures]' \
        '-u+[uid]:_users' \
        '--uid=+[uid]:_users' \
        '*:command:_command_names'
}

_ionice-cli "$@"
