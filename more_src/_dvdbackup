#compdef dvdbackup

# Zsh completion for dvdbackup (DVD backup tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-M[Backup the whole DVD to a directory]' \
  '-F[Backup feature film to a directory]' \
  '-T+[Backup a specific title set]:title number' \
  '-i+[Input device]:device:_files' \
  '-o+[Output directory]:directory:_files -/' \
  '-t+[Specify title number]:title number' \
  '-s+[Start chapter]:chapter' \
  '-e+[End chapter]:chapter' \
  '-a+[Specify audio stream]:audio stream' \
  '-n+[Specify name for output]:name' \
  '-p[Show progress]' \
  '-r+[Specify read error recovery mode]:mode:(a b c)' \
  '-v[Verbose output]' \
  '-I[Print information about the DVD]' \
  '-h[Print help]' \
  '-V[Print version]' && ret=0

return ret
