#compdef codeberg
# Documentation: https://man.archlinux.org/search?q=codeberg
# Reference accessed: 2026-05-16

# Zsh completion for codeberg-cli (codeberg.org/Aviac/codeberg-cli, cobra-like)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '*:: : _message "see codeberg --help"' && ret=0

return ret
