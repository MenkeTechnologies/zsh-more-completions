#compdef wl-clipboard-cli wl-copy wl-paste

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --trim-newline)'{-n,--trim-newline}'[trim trailing newline (wl-copy)]' \
  '(-o --paste-once)'{-o,--paste-once}'[paste once and exit]' \
  '(-f --foreground)'{-f,--foreground}'[stay in foreground]' \
  '(-c --clear)'{-c,--clear}'[clear clipboard]' \
  '(-p --primary)'{-p,--primary}'[use primary selection (X11 compat)]' \
  '(-r --regular)'{-r,--regular}'[use regular selection]' \
  '(-t --type)'{-t+,--type=}'[MIME type]:type:(text/plain text/html image/png image/jpeg application/json text/csv text/x-uri TARGETS)' \
  '(-s --seat)'{-s+,--seat=}'[Wayland seat]:seat:' \
  '(-l --list-types)'{-l,--list-types}'[list available types]' \
  '(-w --watch)'{-w+,--watch=}'[watch and pipe to command]:cmd:_command_names' \
  '*:input:_files' && ret=0

return ret
