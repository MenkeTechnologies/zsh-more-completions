#compdef charmm
# Documentation: https://academiccharmm.org/documentation/basicusage
# CHARMM - macromolecular mechanics and dynamics simulation program

local ret=1

_arguments -s \
  '(-i -input)'{-i,-input}'[input file instead of standard input]:input file:_files' \
  '(-o -output)'{-o,-output}'[output file instead of standard output]:output file:_files' \
  '-chsize[set arrays for a maximum of N atoms]:max atoms:' \
  '-prevclcg[run in mode compatible with previous CLCG]' \
  '-prevrandom[run in old random number generator mode]' \
  '(-h -help)'{-h,-help}'[print allowed command line arguments and quit]' \
  '*:variable assignment or file:_files' && ret=0

return ret
