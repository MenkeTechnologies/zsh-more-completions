#compdef ceph-dencoder
# Documentation: https://man.archlinux.org/search?q=ceph-dencoder
# Reference accessed: 2026-05-16

# ceph-dencoder: dencode/encode ceph objects for testing
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*:dencoder command:(version list_types type select_test import decode dump_json encode export count_tests)' && ret=0
return ret
