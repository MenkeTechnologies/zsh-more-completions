#compdef ceph-dencoder
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-dencoder/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ceph-dencoder: decode/encode Ceph objects for testing
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*:dencoder command:(version list_types type select_test import decode dump_json encode export count_tests skip get_features set_features)' && ret=0
return ret
