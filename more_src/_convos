#compdef convos
# Documentation: https://man.archlinux.org/search?q=convos
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'daemon:run as daemon'
  'cgi:run in CGI mode'
  'eval:evaluate code'
  'get:perform GET request'
  'cpanify:cpanify'
  'help:show help'
  'inflate:inflate'
  'prefork:run with prefork'
  'psgi:run via PSGI'
  'reset-password:reset password'
  'restart:restart'
  'routes:list routes'
  'test:run tests'
  'version:show version'
  'minion:run minion'
  'backup:backup data'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'convos command' commands && ret=0 ;;
esac

return ret
