#compdef convos
# Documentation: https://github.com/convos-chat/convos
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above; subcommands from cmd/ dirs in
# convos-chat/convos main branch (Go rewrite using urfave/cli/v3).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'daemon:run the Convos server'
  'get:perform an HTTP GET against the running server'
  'recover:recover an admin account'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'convos command' commands && ret=0 ;;
esac

return ret
