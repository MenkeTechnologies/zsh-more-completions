#compdef goimports-reviser

_arguments -s \
  '-rm-unused[remove unused imports]' \
  '-set-alias[set aliases for versioned packages]' \
  '-format[additional code formatting]' \
  '-company-prefixes=[comma-separated company prefixes]:prefixes:' \
  '-project-name=[project module path]:name:' \
  '-imports-order=[sort order]:order:' \
  '-recursive[apply rules recursively]' \
  '-list-diff[list files with formatting diffs]' \
  '-output=[output mode]:mode:(file write stdout)' \
  '-apply-to-generated-files[include generated files]' \
  '-excludes=[exclude files/dirs]:patterns:' \
  '-separate-named[separate named imports with blank lines]' \
  '-set-exit-status[exit 1 if changes needed]' \
  '-use-cache[enable cache]' \
  '(- *)-version[print version]' \
  '*:go file:_files -g "*.go"'
