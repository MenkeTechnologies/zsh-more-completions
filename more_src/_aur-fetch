#compdef aur-fetch
# Documentation: https://github.com/aurutils/aurutils/blob/master/man1/aur-fetch.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-r --results)'{-r,--results}'[write results to file]:file:_files' \
  '(-S --sync)'{-S,--sync}'[sync mode for existing repos]' \
  '(-R --recurse)'{-R,--recurse}'[fetch dependencies recursively]' \
  '--discard[discard local changes]' \
  '--rebase[rebase local changes on top of upstream]' \
  '--reset[reset to upstream state]' \
  '--confirm[confirm changes before merging]' \
  '--ff[allow fast-forward merges only when possible]' \
  '--ff-only[only fast-forward merges]' \
  '*:package' && ret=0

return ret
