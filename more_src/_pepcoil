#compdef pepcoil
# Documentation: https://man.archlinux.org/search?q=pepcoil
# Reference accessed: 2026-05-16

# EMBOSS pepcoil: predict coiled-coil regions in protein (Lupas method)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-window=[scanning window size (residues)]:size:(14 21 28)' \
  '-coil[predict coil regions]' \
  '-frame[show heptad frame assignment]' \
  '-other[predict non-coil regions]' \
  '-outfile=[report output file]:file:_files' \
  '*:protein USA:_files' && ret=0
return ret
