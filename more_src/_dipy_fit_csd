#compdef dipy_fit_csd
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_fit_csd.html
# DIPY: fit constrained spherical deconvolution (CSD) model

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--use_msmt[enable Multi-Shell Multi-Tissue method]' \
  '--t1_file=[path to T1 file (MSMT only)]:file:_files' \
  '--wm_file=[path to WM mask (MSMT only)]:file:_files' \
  '--gm_file=[path to GM mask (MSMT only)]:file:_files' \
  '--csf_file=[path to CSF mask (MSMT only)]:file:_files' \
  '--iso=[isotropic compartments count for MSMT-CSD]:n' \
  '--beta=[tissue segmentation smoothness factor]:beta' \
  '--bval_tol=[tolerance for b-value clustering]:tol' \
  '--b0_threshold=[threshold for b0 volume detection]:thr' \
  '--bvecs_tol=[bvector unit vector tolerance]:tol' \
  '--roi_center=[ROI center coordinates]:coords' \
  '--roi_radii=[ROI cuboid radii in voxels]:radii' \
  '--fa_thr=[FA threshold for response function]:thr' \
  '--frf=[fiber response function values]:frf' \
  '--sphere_name=[sphere for fODF reconstruction]:sphere' \
  '--relative_peak_threshold=[peak threshold multiplier]:thr' \
  '--min_separation_angle=[minimum distance between directions]:angle' \
  '--sh_order_max=[spherical harmonics order]:order' \
  '--parallel[enable parallelization]' \
  '--extract_pam_values[save PAM volumes separately]' \
  '--num_processes=[number of subprocesses]:n' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_pam=[peaks volume filename]:file:_files' \
  '--out_shm=[spherical harmonics volume filename]:file:_files' \
  '--out_peaks_dir=[peaks directions filename]:file:_files' \
  '--out_peaks_values=[peaks values filename]:file:_files' \
  '--out_peaks_indices=[peaks indices filename]:file:_files' \
  '--out_gfa=[generalized FA filename]:file:_files' \
  '--out_sphere=[sphere vertices filename]:file:_files' \
  '--out_b=[B matrix filename]:file:_files' \
  '--out_qa=[quantitative anisotropy filename]:file:_files' \
  '*:input (volumes bvals bvecs masks):_files' && ret=0

return ret
