#compdef fre

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-stat)'--stat'[Show frecency statistics]' \
  '(stat)--sort_method=[Sort method]:method:(frequent recent frecency)' \
  '(--sorted)'--sorted'[Output sorted directory list]' \
  '(--add)'--add+'[Record directory visit]:directory:_files -/' \
  '(--delete)'--delete+'[Remove path from store]:path:_files' \
  '(--decrease)'--decrease+'[Decrease weight by visits]:count: '::'path:_files -/' \
  '*::paths: _files -/'
