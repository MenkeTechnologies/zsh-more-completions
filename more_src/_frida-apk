#compdef frida-apk
# Documentation: https://github.com/frida/frida-tools/blob/main/frida_tools/apk.py
# Make an APK debuggable, optionally injecting the Frida gadget

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[output version information and exit]' \
  '(-o --output)'{-o,--output}'=[output path]:output:_files' \
  '(-g --gadget)'{-g,--gadget}'=[inject the specified gadget library]:gadget:_files' \
  '*'{-c,--gadget-config}'=[set the given key=value gadget interaction config]:config' \
  '1:apk file:_files -g "*.apk"' && ret=0

return ret
