#
# THE gptlint CLI — cleye + globby + LLM-API + 19+ flags
#
# gptlint's CLI is in bin/gptlint.ts + src/resolve-cli-config.ts.
# Uses cleye (privatenumber's CLI parser):
#
#     import { cli } from 'cleye'
#     import { globby, type Options as GlobbyOptions } from 'globby'
#
#     const args = cli({
#         name,
#         parameters: ['[file/dir/glob ...]'],
#         flags: {
#             config: { type: String, alias: 'c', ... },
#             rules: { type: [String], alias: 'r', ... },
#             ignoreFile: { type: String, default: '.gptlintignore', ... },
#             ignorePattern: { type: [String], ... },
#             noIgnore: { type: Boolean, ... },
#             noInlineConfig: { type: Boolean, ... },
#             noCache: { type: Boolean, alias: 'C', ... },
#             noGrit: { type: Boolean, alias: 'G', ... },
#             cacheDir: { type: String, ... },
#             concurrency: { type: Number, ... },
#             debug: { type: Boolean, alias: 'd', ... },
#             dryRun: { type: Boolean, ... },
#             printConfig: { type: Boolean, ... },
#             debugModel: { type: Boolean, alias: 'D', ... },
#             debugGrit: { type: Boolean, alias: 'g', ... },
#             noDebugStats: { type: Boolean, alias: 'S', ... },
#             earlyExit: { type: Boolean, alias: 'e', ... },
#             apiKey: { type: String, alias: 'k', ... },
#             apiOrganizationId: { type: String, ... },
#             apiBaseUrl: { type: String, ... },
#             model: { type: String, alias: 'm', ... },
#             weakModel: { type: String, alias: 'M', ... },
#             temperature: { type: Number, ... },
#         },
#     }, () => {}, cliArgs);
#
# globby is used in src/utils.ts (resolveGlobFilePatterns) +
# src/resolve-files.ts (source file discovery) + src/resolve-
# rules.ts (rule file discovery).  Every glob pattern in gptlint
# passes through globby's gitignore-aware matching.
#
# Positional: [file/dir/glob ...] — paths/patterns to lint
#
# Flags (19+):
#   -c, --config FILE          Configuration file
#   -r, --rules PATTERN        Rule definition markdown glob (repeatable)
#       --ignore-file FILE     Ignore-pattern file (default .gptlintignore)
#       --ignore-pattern P     Additional ignore pattern (repeatable)
#       --no-ignore             Disable all ignore files + patterns
#       --no-inline-config      Disable inline rule config in source
#   -C, --no-cache             Disable caching
#   -G, --no-grit              Disable Grit query engine pre-filter
#       --cache-dir DIR        Custom cache directory
#       --concurrency N         Max parallel LLM tasks
#   -d, --debug                Debug logging
#       --dry-run               Estimate cost without LLM calls
#       --print-config          Print resolved config + exit
#   -D, --debug-model           Verbose LLM logging
#   -g, --debug-grit            Verbose Grit logging
#   -S, --no-debug-stats        Suppress LLM stats logging
#   -e, --early-exit            Exit on first error
#   -k, --api-key KEY           OpenAI-compatible API key
#       --api-organization-id   API org billing ID
#       --api-base-url URL      OpenAI-compatible base URL
#   -m, --model MODEL           Strong LLM model (default gpt-4)
#   -M, --weak-model MODEL      Weak LLM model (default gpt-4o-mini)
#       --temperature N         LLM temperature
#
# Five-axis distinctness from fast-glob (R639):
#
#   1. HIGH-LEVEL WRAPPER OVER fast-glob — globby uses fast-glob
#      internally but adds gitignore + expand-directories +
#      ignore-files conveniences.
#
#   2. GITIGNORE-AWARE BY DEFAULT — { gitignore: true } reads
#      .gitignore + .ignore files automatically; fast-glob is
#      raw glob without gitignore.
#
#   3. EXPAND-DIRECTORIES — bare directory paths auto-expand to
#      all files; fast-glob requires explicit /**/*.
#
#   4. STANDALONE isGitIgnored + isIgnoredByIgnoreFiles helpers
#      — exportable for arbitrary ignore-check logic without
#      full glob runs.
#
#   5. SINDRE SORHUS FOUR-LIBRARY PROVENANCE — joins boxen +
#      wrap-ansi + conf as Sindre's 4th headline library in the
#      taxonomy.
#
# -----------------------------------------------------------------------------
