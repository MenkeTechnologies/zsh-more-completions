local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(-c --config)'{-c+,--config=}'[configuration file path]:config file:_files -g "*.{json,yaml,yml,js,cjs,mjs,ts}"' \
    '*'{-r+,--rules=}'[rule definition markdown glob pattern (repeatable)]:rules:_files -g "*.md"' \
    '--ignore-file=[ignore-pattern file path (default .gptlintignore)]:ignore file:_files' \
    '*--ignore-pattern=[additional ignore pattern (repeatable)]:pattern:_default' \
    '--no-ignore[disable all ignore files + patterns]' \
    '--no-inline-config[disable inline rule config in source]' \
    '(-C --no-cache)'{-C,--no-cache}'[disable caching]' \
    '(-G --no-grit)'{-G,--no-grit}'[disable Grit query engine pre-filter]' \
    '--cache-dir=[custom cache directory]:dir:_directories' \
    '--concurrency=[max parallel LLM tasks]:n:_default' \
    '(-d --debug)'{-d,--debug}'[enable debug logging]' \
    '--dry-run[estimate cost without LLM calls]' \
    '--print-config[print resolved config + parsed rules + exit]' \
    '(-D --debug-model)'{-D,--debug-model}'[verbose LLM logging]' \
    '(-g --debug-grit)'{-g,--debug-grit}'[verbose Grit logging]' \
    '(-S --no-debug-stats)'{-S,--no-debug-stats}'[suppress LLM stats logging]' \
    '(-e --early-exit)'{-e,--early-exit}'[exit after first error]' \
    '(-k --api-key)'{-k+,--api-key=}'[OpenAI-compatible API key (default OPENAI_API_KEY)]:key:_default' \
    '--api-organization-id=[API org billing ID]:org:_default' \
    '--api-base-url=[OpenAI-compatible base URL]:url:_urls' \
    '(-m --model)'{-m+,--model=}'[strong LLM model (default gpt-4)]:model:_default' \
    '(-M --weak-model)'{-M+,--weak-model=}'[weak LLM model (default gpt-4o-mini)]:model:_default' \
    '--temperature=[LLM temperature parameter]:n:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '*: :_files' \
    && ret=0

return ret
