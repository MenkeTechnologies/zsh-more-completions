#compdef condor_router_history
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_router_history.html
# display the history of routed jobs

local ret=1

_arguments -s -S \
  '-h[display usage information and exit]' \
  '-show_records[display individual records in addition to the summary]' \
  '-show_iwd[include working directory in displayed records]' \
  '-age[set the ending time of the summary to be days ago]:days' \
  '-days[set the number of days to summarize]:days' \
  '-start[set the start time of the summary]:start time' && ret=0

return ret
