#compdef duplicati-cli duplicati duplicati_client duplicati-client
# Documentation: https://man.archlinux.org/search?q=duplicati-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'backup:run backup'
  'restore:restore from backup'
  'compare:compare versions'
  'find:find file'
  'compact:compact backup'
  'delete:delete versions'
  'repair:repair backup'
  'test:test backup integrity'
  'verify:verify backup'
  'send-mail:send test email'
  'changepassword:change passphrase'
  'usage-report:show usage report'
  'list:list versions'
  'list-broken-files:list broken files'
  'list-changes:list changes'
  'list-folders:list folders'
  'list-files:list files'
  'list-jobs:list jobs'
  'list-sets:list backup sets'
  'list-tasks:list tasks'
  'find-broken-files:find broken files'
  'system-info:show system info'
  'license:show license'
  'export-config:export config'
  'import-config:import config'
  'options:show options'
  'gui:start GUI'
  'commit:commit changes'
  'commandline:run a command'
  'logout:logout'
  'login:login'
  'pause:pause server'
  'resume:resume server'
  'check:check connection'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--config-file=[config file]:file:_files' \
  '*--passphrase=[passphrase]:p:' \
  '*--no-encryption[no encryption]' \
  '*--exclude=[exclude pattern]:p:' \
  '*--include=[include pattern]:p:' \
  '*--blocksize=[block size]:s:' \
  '*--volsize=[volume size]:s:' \
  '*--compression-module=[compression]:c:(zip 7z gz bz2)' \
  '*--encryption-module=[encryption]:e:(aes gpg)' \
  '*--retention-policy=[retention]:r:' \
  '*--keep-time=[keep time]:t:' \
  '*--keep-versions=[keep versions]:n:' \
  '*--prefix=[prefix]:p:' \
  '*--dbpath=[db path]:dir:_files -/' \
  '*--time=[restore time]:t:' \
  '*--version=[version]:v:' \
  '*--no-progress[no progress]' \
  '*--verbose[verbose]' \
  '*--quiet-console[quiet]' \
  '*--log-file=[log file]:file:_files' \
  '*--log-level=[log level]:l:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'duplicati command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
