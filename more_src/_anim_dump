#compdef anim_dump
# _anim_dump — dump frames of an animated GIF/WebP to PNG/TIFF/PAM (webmproject/libwebp)
# upstream: https://github.com/webmproject/libwebp
# Flags from examples/anim_dump.c (custom strcmp dispatch).

_anim_dump() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-folder+[output folder]:dir:_files -/' \
        '-prefix+[output filename prefix]:prefix:' \
        '(-tiff -pam)-tiff[output frames as TIFF]' \
        '(-tiff -pam)-pam[output frames as PAM]' \
        '*:input animated image:_files -g "*.(gif|webp)"'
}

_anim_dump "$@"
