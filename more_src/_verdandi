#compdef verdandi
# Documentation: https://man.archlinux.org/search?q=verdandi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-o+[output file]:file:_files' \
  '-m+[mode]:mode:(average max min median)' \
  '-c+[output compression]:compression:(NONE LZW DEFLATE PACKBITS)' \
  '-v[verbose]' \
  '*:image_files:_files -g "*.{tif,tiff}"' && ret=0

return ret
