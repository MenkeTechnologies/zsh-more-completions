#compdef komorebi

# Zsh completion for komorebi - tiling window manager for Windows

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start komorebi'
  'stop:stop komorebi'
  'state:query current window manager state'
  'log:tail the komorebi log'
  'quick-save-resize:quicksave resize dimensions'
  'quick-load-resize:quickload resize dimensions'
  'save-resize:save resize dimensions to file'
  'load-resize:load resize dimensions from file'
  'focus:focus in a direction'
  'move:move in a direction'
  'stack:stack window in a direction'
  'resize-edge:resize in a direction'
  'resize-axis:resize along an axis'
  'unstack:unstack the focused window'
  'cycle-focus:cycle focus'
  'cycle-move:cycle move'
  'cycle-stack:cycle stack'
  'move-to-monitor:move window to monitor'
  'move-to-workspace:move window to workspace'
  'focus-monitor:focus a monitor by index'
  'focus-workspace:focus a workspace by index'
  'new-workspace:create a new workspace'
  'adjust-container-padding:adjust container padding'
  'adjust-workspace-padding:adjust workspace padding'
  'change-layout:change workspace layout'
  'flip-layout:flip layout'
  'promote:promote window'
  'retile:force retile'
  'toggle-float:toggle float for focused window'
  'toggle-monocle:toggle monocle mode'
  'toggle-maximize:toggle maximize for focused window'
  'toggle-pause:toggle pause for komorebi'
  'toggle-tiling:toggle tiling'
  'restore-windows:restore all windows'
  'manage:manage a window'
  'unmanage:unmanage a window'
  'reload-configuration:reload configuration'
  'watch-configuration:watch configuration for changes'
  'fetch-app-specific-configuration:fetch community application configs'
  'complete-configuration:generate static configuration'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'komorebi command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      focus|move|stack|resize-edge)
        _arguments '1:direction:(left right up down)' && ret=0
        ;;
      resize-axis)
        _arguments \
          '1:axis:(horizontal vertical)' \
          '2:sizing:(increase decrease)' && ret=0
        ;;
      cycle-focus|cycle-move|cycle-stack)
        _arguments '1:direction:(previous next)' && ret=0
        ;;
      move-to-monitor|focus-monitor)
        _arguments '1:monitor index:' && ret=0
        ;;
      move-to-workspace|focus-workspace)
        _arguments '1:workspace index:' && ret=0
        ;;
      change-layout)
        _arguments '1:layout:(bsp columns rows vertical-stack horizontal-stack ultrawide-vertical-stack)' && ret=0
        ;;
      flip-layout)
        _arguments '1:axis:(horizontal vertical)' && ret=0
        ;;
    esac
    ;;
esac

return ret
