#compdef komorebi
# Documentation: https://raw.githubusercontent.com/LGUG2Z/komorebi/master/komorebi/src/main.rs
# Reference accessed: 2026-05-19
# Verified: upstream clap Opts struct in komorebi/src/main.rs.
# Note: komorebi is the tiling WM daemon; the control CLI with
# start/stop/focus/etc. subcommands is the separate "komorebic" binary.

# Zsh completion for komorebi - tiling window manager daemon (Windows)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --ffm)'{-f,--ffm}'[enable custom focus-follows-mouse implementation]' \
  '(-a --await-configuration)'{-a,--await-configuration}'[wait for komorebic complete-configuration before processing events]' \
  '(-t --tcp-port)'{-t+,--tcp-port=}'[start a TCP server on the specified port]:port:' \
  '(-c --config)'{-c+,--config=}'[path to a static configuration JSON file]:file:_files' \
  '--clean-state[skip auto-applying dumped state from previous instances]' \
  '--log-level=[set logging verbosity]:level:(error warn info debug trace)' && ret=0

return ret
