#compdef pvanal
# Csound phase vocoder analysis: convert a soundfile into STFT frames

local ret=1

_arguments -s -S \
  '-s+[override input sampling rate]:srate' \
  '-c+[channel to analyze]:channel' \
  '-b+[begin time in seconds]:begin' \
  '-d+[duration in seconds]:duration' \
  '-n+[STFT frame size (power of two 16-16384)]:frmsiz' \
  '-w+[window overlap factor (incompatible with -h)]:windfact' \
  '-h+[hop size in samples (incompatible with -w)]:hopsize' \
  '-H[use Hamming window instead of von Hann]' \
  '-K[use Kaiser window instead of von Hann]' \
  '-B+[Kaiser window beta parameter]:beta' \
  '*:soundfile:_files' && ret=0

return ret
