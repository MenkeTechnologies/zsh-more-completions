#compdef uci

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'batch:execute multiple commands'
  'export:export configuration'
  'import:import configuration'
  'changes:list staged changes'
  'commit:commit changes'
  'add:add anonymous section'
  'add_list:add list element'
  'del_list:remove list element'
  'show:show configuration'
  'get:get option value'
  'set:set option value'
  'delete:delete section or option'
  'rename:rename section or option'
  'revert:revert changes'
  'reorder:reorder section'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[config directory]:dir:_files -/' \
  '-d+[list separator]:sep:' \
  '-f+[input file]:file:_files' \
  '-m[merge mode]' \
  '-n[no name in show]' \
  '-N[name in show]' \
  '-p+[search path]:path:_files -/' \
  '-P+[search path (prepend)]:path:_files -/' \
  '-q[quiet]' \
  '-s[force strict mode]' \
  '-S[disable strict mode]' \
  '-X[do not use extended syntax]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'uci command' commands && ret=0 ;;
esac

return ret
