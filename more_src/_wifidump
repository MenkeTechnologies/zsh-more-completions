#compdef wifidump
# Documentation: https://www.wireshark.org/docs/man-pages/wifidump.html
# Provide an interface to capture Wi-Fi frames from a remote host through SSH

local ret=1

_arguments -s -S \
  '--help[print program arguments]' \
  '--version[print program version]' \
  '--extcap-interfaces[list available interfaces]' \
  '--extcap-interface=[use specified interface]:interface:' \
  '--extcap-dlts[list DLTs of specified interface]' \
  '--extcap-config[list configuration options of specified interface]' \
  '--extcap-capture-filter=[set capture filter (tshark -f)]:filter:' \
  '--capture[start capturing from specified interface]' \
  '--fifo=[save captured packets to file or pipe]:path:_files' \
  '--remote-host=[address of remote host for capture]:host:_hosts' \
  '--remote-port=[SSH port of remote host]:port:' \
  '--remote-username=[username for SSH authentication]:username:_users' \
  '--remote-password=[password for SSH authentication]:password:' \
  '--sshkey=[path to private key for authentication]:key:_files' \
  '--remote-interface=[remote network interface to capture from]:interface:' \
  '--remote-channel-frequency=[remote channel frequency in MHz]:frequency:' \
  '--remote-channel-width=[remote channel width in MHz]:width:' && ret=0

return ret
