#compdef flux-top
# Documentation: https://flux-framework.readthedocs.io/projects/flux-core/en/latest/man1/flux-top.html
# display running Flux jobs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--color=[colorize output]:when:(always never auto)' \
  '(-q --queue)'{-q,--queue=}'[limit status and jobs to queue]:queue' \
  '*:target:_default' && ret=0

return ret
