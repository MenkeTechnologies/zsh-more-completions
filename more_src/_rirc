#compdef rirc
# Documentation: https://rcr.io/rirc/
# rirc - minimalistic terminal IRC client

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message and exit]' \
  '(-v --version)'{-v,--version}'[print rirc version and exit]' \
  '(-s --server)'{-s,--server=}'[set connection hostname]:server:_hosts' \
  '(-p --port)'{-p,--port=}'[set connection port]:port' \
  '(-w --pass)'{-w,--pass=}'[set IRC password]:pass' \
  '(-u --username)'{-u,--username=}'[set IRC username]:username' \
  '(-r --realname)'{-r,--realname=}'[set IRC realname]:realname' \
  '(-m --mode)'{-m,--mode=}'[set IRC user modes]:modes' \
  '(-n --nicks)'{-n,--nicks=}'[set comma separated list of nicks to use]:nicks' \
  '(-c --chans)'{-c,--chans=}'[set comma separated list of channels to join]:chans' \
  '--tls-cert=[set TLS client certificate file path]:path:_files' \
  '--tls-ca-file=[set TLS peer certificate file path]:path:_files' \
  '--tls-ca-path=[set TLS peer certificate directory path]:path:_files -/' \
  '--tls-verify=[set TLS peer certificate verification mode]:mode' \
  '--tls-disable[set TLS disabled]' \
  '--sasl=[authenticate with SASL mechanism]:mechanism' \
  '--sasl-user=[authenticate with SASL username]:user' \
  '--sasl-pass=[authenticate with SASL password]:pass' \
  '--ipv4[use IPv4 addresses only]' \
  '--ipv6[use IPv6 addresses only]' && ret=0

return ret
