#compdef hydorder gmx-hydorder
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-hydorder.html
# gmx hydorder: compute tetrahedrality parameters around a given atom

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-n[index file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-o[X PixMap matrix file]:file:_files' \
  '-or[generic output file]:file:_files' \
  '-Spect[generic output file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt = first time]:time:' \
  '-w[view output files]' \
  '-d[direction of the normal on the membrane]:enum:' \
  '-bw[binwidth of box mesh]:real:' \
  '-sgang1[tetrahedral angle parameter in Phase 1]:real:' \
  '-sgang2[tetrahedral angle parameter in Phase 2]:real:' \
  '-tblock[number of frames in one time-block average]:int:' \
  '-nlevel[number of height levels in 2D XPixMaps]:int:' && ret=0

return ret
