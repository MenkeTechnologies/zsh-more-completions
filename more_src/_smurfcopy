#compdef smurfcopy
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss61.html
# SMURF: copy a 2d image out of a time series file.

local ret=1

_arguments -s -S \
  'IN=[input time series file]:ndf:_files' \
  'OUT=[output file]:ndf:_files' \
  'SLICE=[time axis index]:n:' \
  'FTSPORT=[FTS-2 port for WCS]:port:(tracking image)' \
  'POINTING=[text file with pointing corrections]:file:_files' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:ndf:_files' && ret=0

return ret
