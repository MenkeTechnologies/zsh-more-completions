#compdef zeit
# Documentation: https://github.com/mrusme/zeit
# zeit - a command line tool for tracking time

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug[enable debug output]' \
  '1:command:((
    start:"begin tracking time"
    blocks:"list tracked time periods"
    projects:"manage projects"
    tasks:"manage tasks"
    export:"export the database"
    import:"import into the database"
    completion:"generate shell completion scripts"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '--note=[add a note to a block]:note:' \
      '--project=[specify the project]:project:' \
      '--task=[specify the task]:task:' \
      '--start=[set the start time]:time:' \
      '--end=[set the end time]:time:' \
      '(-f --format)'{-f,--format}'=[export or import format]:format:(json zeit)' \
      '(-h --help)'{-h,--help}'[show help]' && ret=0
    ;;
esac

return ret
