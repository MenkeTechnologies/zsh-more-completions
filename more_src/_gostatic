#compdef gostatic
# ============================================================================
#  _gostatic — gostatic: fast static site generator in Go
#
#  Source-direct extraction from
#    https://github.com/piranha/gostatic/blob/master/gostatic.go
#    https://github.com/jessevdk/go-flags (the go-flags library)
#
#  Authored by Alexander Solovyov (piranha/gostatic).  443 GH stars.
#  Single-binary static site generator — reads `config` file declaring
#  source/target paths + a chain of processors (markdown, HTML templates,
#  YAML/JSON frontmatter, image processing, etc.), rebuilds the static
#  site, and optionally serves it via HTTP with hot reload on file
#  changes.  Sister tools: hugo (Go static gen, in corpus), zola (Rust
#  static gen, in corpus), jekyll (Ruby static gen, in corpus), 11ty
#  (JavaScript static gen, in corpus).
#
#  CLI library taxonomy update: 8th Go CLI library — jessevdk/go-flags.
#  Go ecosystem now has 8 documented CLI libraries (cobra/urfave-cli/
#  kingpin/spf13-pflag/alecthomas-kong/alexflint-go-arg/integrii-flaggy/
#  jessevdk-go-flags) — extends Go's documented-CLI-library lead.
#  jessevdk/go-flags is one of the OLDEST Go CLI libraries (since 2012).
#  Used by Decred daemon (dcrd), Snap (Canonical's package manager —
#  snapcore/snapd), gostatic, Cloud Foundry cred-alert, and many others.
#  Modeled after GNU getopt with rich struct-tag-based declarative API.
#
#  go-flags struct-tag DSL uses MULTIPLE SEPARATE TAGS per directive:
#    type Opts struct {
#      Verbose    bool    `short:"v" long:"verbose" description:"..."`
#      Port       string  `short:"p" long:"port" default:"8000" description:"..."`
#      InitExample *string `short:"i" long:"init" description:"..."`
#      Force      bool    `short:"f" long:"force" description:"force ..."`
#    }
#  Each directive (`short`, `long`, `description`, `default`, `env`,
#  `required`, `value-name`, `choice`, `optional`, `optional-value`) is
#  a SEPARATE STRUCT TAG KEY.  Distinct from:
#    - R342 alexflint/go-arg `arg:"--seeds,separate,env:MGMT_SEEDS"` —
#      COMMA-SEPARATED DIRECTIVES inside SINGLE `arg:"..."` tag
#    - R334 alecthomas/kong `kong:"name='X',short='y',default='V'"` —
#      KEY='VALUE' DSL inside SINGLE `kong:"..."` tag
#    - R338 Odin core:flags `args:"name=X,pos=N"` — KEY=VALUE inside
#      SINGLE `args:"..."` tag
#  go-flags' approach: SEPARATE TAG PER DIRECTIVE — verbose but each
#  directive is independently identifiable via Go's `reflect.StructTag`
#  `Get("long")` etc.
#
#  Parser construction:
#    parser := flags.NewParser(&opts,
#      flags.PrintErrors|flags.PassDoubleDash|flags.HelpFlag)
#    parser.Usage = "[OPTIONS] path/to/config"
#    args, err := parser.Parse()
#  Construction takes FLAGS BITMASK (PrintErrors/PassDoubleDash/HelpFlag/
#  IgnoreUnknown/Default/...) that controls parser behavior.
#  `parser.Parse()` returns `(positional []string, err error)` — caller
#  inspects `args` for positional remainder.
#
#  Brings cross-language CLI library taxonomy variant count to 93; Go
#  ecosystem now has 8 documented CLI libraries.
#
#  Surface (verbatim from gostatic.go `Opts` struct):
#    --processors            Show page processors and exit
#    --show-config           Print config as JSON and exit
#    --summary               Print all pages on stdout
#    -i, --init [path]       Create example site at path (or cwd if no arg)
#    -d, --dump FILE         Print page metadata as JSON (path to source
#                            or target file)
#    -f, --force             Force building all pages
#    -w, --watch             Serve site on HTTP, rebuild on changes,
#                            hot-reload HTML in browser
#    --no-hotreload          Disable hot reload during --watch
#    -p, --port PORT         Port to serve on (default: 8000)
#    -v, --verbose           Enable verbose output
#    -V, --version           Show version and exit
#  Positional:
#    <config>                Path to site config file
#
#  Dup-skipped neighbors during hunt (smaller surface or in corpus):
#    - loxilb (loxilb-io/loxilb 1845 stars eBPF load balancer — uses
#      go-flags but main CLI surface is mostly init-time bootstrap)
#    - dcrd (decred/dcrd 773 stars Decred daemon — uses go-flags but
#      cryptocurrency-specific niche; HOLD for future round)
#    - cred-alert (pivotal-cf 113 stars — narrow credential scanner)
#    - snapd (canonical/snapd — IN CORPUS, Snap's `snap` binary uses
#      go-flags but already documented under different lib attribution)
# ============================================================================

_gostatic() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--processors[show page processors and exit]' \
    '--show-config[print config as JSON and exit]' \
    '--summary[print all pages on stdout]' \
    '(-i --init)'{-i,--init}'=[create example site at path]:target path:_directories' \
    '(-d --dump)'{-d,--dump}'=[print page metadata as JSON]:page (source/target):_files' \
    '(-f --force)'{-f,--force}'[force building all pages]' \
    '(-w --watch)'{-w,--watch}'[serve site on HTTP + rebuild + hot reload]' \
    '--no-hotreload[disable hot reload during --watch]' \
    '(-p --port)'{-p,--port}'=[port to serve on (default 8000)]:port' \
    '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
    '(-V --version)'{-V,--version}'[show version and exit]' \
    '1:config file:_files'
}

_gostatic "$@"
