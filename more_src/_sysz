#compdef sysz

# Zsh completion for sysz - fzf terminal UI for systemctl

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--user[show user units]' \
  '--sys[show system units]' \
  '(-s --state)'{-s,--state}'[filter by state]:state:(active inactive failed running)' \
  '(-v --verbose)'{-v,--verbose}'[show verbose info]' \
  '*:unit pattern'
