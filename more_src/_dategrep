#compdef dategrep

# Zsh completion for dategrep - grep for dates in log files

_arguments -s -S \
  '--start=[start date]:date expression:' \
  '--end=[end date]:date expression:' \
  '--last-minutes=[show entries from last N minutes]:minutes:' \
  '--format=[date format]:format:(rsyslog apache iso8601 tai64n)' \
  '--multiline[multiline mode]' \
  '--skip-unparsable[skip lines that cannot be parsed]' \
  '--sort-files[sort files by name before processing]' \
  '--configfile=[config file]:config file:_files' \
  '--help[show help]' \
  '--version[show version]' \
  '*:files:_files'
