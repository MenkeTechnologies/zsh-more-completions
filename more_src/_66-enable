#compdef 66-enable

_arguments -s -S \
  '-h[show help]' \
  '-z[use color output]' \
  '-v[set verbosity level]:verbosity:(0 1 2 3 4)' \
  '-l[set log directory]:log directory:_files -/' \
  '-t[set tree name]:tree name:' \
  '-F[force enable even if already enabled]' \
  '-S[also start the service after enabling]' \
  '*:service name:'
