#compdef dcb-apptrust
# Documentation: https://man.archlinux.org/man/dcb-apptrust.8.en
# dcb apptrust - manage trusted application selectors

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'dcb apptrust command' \
      'show[display all trusted selectors]' 'set[set new list of trusted selectors]' \
      'dev[network device]' 'order[trusted selector precedence list]' && ret=0
    ;;
esac

return ret
