#compdef ucarp
# Documentation: https://github.com/jedisct1/UCarp
# Userspace VRRP implementation

_arguments -s -S \
  '-i[network interface to bind to]:interface:_net_interfaces' \
  '-v[virtual IP identifier (1-255)]:vhid:' \
  '-p[VRRP password]:password:' \
  '-a[virtual shared IP address]:address:' \
  '-s[source IP address]:address:' \
  '-k[skew value]:skew:' \
  '-b[advertisement base interval]:seconds:' \
  '-B[run in background]' \
  '-f[path to PID file]:file:_files' \
  '-P[preemptive mode]' \
  '-n[neutral mode, do not run downscript on exit]' \
  '-M[use broadcast instead of multicast]' \
  '-S[ignore interface state]' \
  '-r[dead ratio]:ratio:' \
  '-z[run shutdown script on exit]' \
  '-u[upscript to run when becoming master]:script:_files' \
  '-d[downscript to run when becoming backup]:script:_files' \
  '-x[extra parameter passed to scripts]:parameter:' \
  '-V[show version]' \
  '-h[show help]' \
  && return 0
