#compdef redun
# Documentation: https://github.com/insitro/redun/blob/main/redun/cli.py
# redun: expressive Python workflow engine with automatic caching and data provenance

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a redun configuration directory'
  'run:run a workflow task'
  'launch:launch a workflow within an executor (e.g. docker, batch)'
  'log:show information on historical runs'
  'console:show information on historical runs in a TUI'
  'repl:get a repl for querying history'
  'tag:show and manipulate tags'
  'oneshot:execute one task'
  'db:manage redun repo database'
  'export:export records from redun repo'
  'import:import records into redun repo'
  'repo:define additional repositories'
  'push:sync records to another redun repo'
  'pull:sync records from another redun repo'
  'aws:execute a command for AWS executors'
  'fs:filesystem commands (local, s3, gs, http, etc)'
  'server:run the redun local web server UI'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[print version]' \
  '--setup=[override setup arguments for scheduler config]:setup' \
  '-c+[redun configuration directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'redun command' commands && ret=0 ;;
  (args) _files && ret=0 ;;
esac

return ret
