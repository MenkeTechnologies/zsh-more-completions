#compdef arpaname named-nzd2nzf nsec3hash
# Documentation: https://bind9.readthedocs.io/en/latest/manpages.html
#                https://gitlab.isc.org/isc-projects/bind9/-/raw/main/bin/tools/named-nzd2nzf.rst
#                https://gitlab.isc.org/isc-projects/bind9/-/raw/main/bin/tools/nsec3hash.rst
# Reference accessed: 2026-05-30
# BIND 9 small utilities. Companion to the existing BIND coverage
# (_dnssec-*, _named-checkzone, _named-rrchecker, _named-journalprint,
# _rndc, _rndc-confgen, _ddns-confgen, _tsig-keygen, _genrandom).
# Three tools too small for individual files but cohesive as a multi-stem.
# Deferred this round: isc-hmac-fixup (removed from BIND >= 9.16).

local curcontext="$curcontext" state line ret=1

case $service in

  arpaname)
    # arpaname IP [IP ...] — convert IPv4/IPv6 to IN-ADDR.ARPA / IP6.ARPA
    _arguments -s -S \
      '*:IPv4 or IPv6 address:' \
      && ret=0
    ;;

  named-nzd2nzf)
    # Single positional: the .nzd database file to dump as NZF text.
    _arguments -s -S \
      '1:NZD database file:_files -g "*.nzd"' \
      && ret=0
    ;;

  nsec3hash)
    # Two invocation forms (mutex):
    #   nsec3hash      SALT  ALGORITHM         ITERATIONS DOMAIN
    #   nsec3hash -r   ALGORITHM FLAGS         ITERATIONS SALT DOMAIN
    # Algorithm 1 = SHA-1 (currently the only NSEC3 algorithm).
    _arguments -s -S \
      '-r[record-format input order: ALGORITHM FLAGS ITERATIONS SALT DOMAIN]' \
      '*:argument:' \
      && ret=0
    ;;

esac

return ret
