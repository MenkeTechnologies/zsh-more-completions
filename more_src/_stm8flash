#compdef stm8flash
# Program STM8 devices over SWIM/ST-LINK(v1,v2)

local ret=1

_arguments -s -S \
  '-c+[programmer used]:programmer:(stlink stlinkv2 stlinkv21 stlinkv3 espstlink)' \
  '-p+[STM8 device part number]:part:' \
  '-s+[memory type or address]:memtype:(flash eeprom ram opt)' \
  '-b+[number of bytes to read/write]:bytes:' \
  '-r+[read data from device to file]:file:_files' \
  '-w+[write data from file to device]:file:_files' \
  '-v+[verify device against file]:file:_files' \
  '-u[unlock: reset option bytes to factory default]' \
  '-l[list supported STM8 devices]' \
  '-L[list attached ST-LINK programmers and serials]' \
  '-R[reset the device only]' && ret=0

return ret
