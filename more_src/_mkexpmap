#compdef mkexpmap
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/mkexpmap.html
# Generate a Chandra imaging exposure map (effective area vs. sky position)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'asphistfile=[the name of the input aspect histogram file]:file:_files' \
  'outfile=[the name of the output exposure map file]:file:_files' \
  'instmapfile=[the name of the input instrument map file]:file:_files' \
  'xygrid=[region in sky coordinates and resolution of output]:xygrid:' \
  'normalize=[physical units of the output exposure map]:normalize:(yes no)' \
  'useavgaspect=[only the average aspect pointing will be used]:useavgaspect:(yes no)' \
  'geompar=[the name of the Pixlib Geometry parameter file]:file:_files' \
  'verbose=[the verbosity level for messages]:verbose:(0 1 2 3 4 5)' \
  'clobber=[existing output files will be overwritten]:clobber:(yes no)' && ret=0

return ret
