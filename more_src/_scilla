#compdef scilla-checker scilla-runner scilla-server scilla-fmt
# _scilla — Zilliqa Scilla strongly-typed safe-by-construction smart-contract language toolchain checker runner formatter (Zilliqa team, OCaml); cmdliner
# upstream: https://github.com/Zilliqa/scilla

_scilla-checker() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-libdir+[stdlib path]:dir:_files -/' \
        '-init+[init json]:file:_files -g "*.json"' \
        '-jsonerrors[json errors]' \
        '-gaslimit+[gas limit]:n:' \
        '-cf[cashflow info]' \
        '-cf-token-fields+[csv]:str:' \
        '-contractinfo[contract info]' \
        '-typeinfo[type info]' \
        '-disable-pp-lit[disable pp lit]' \
        '-disable-sanity[disable sanity]' \
        '-disable-validate-json[disable validate json]' \
        '-imap-lookup[imap lookup]' \
        '-verbose[verbose]' \
        '-pp[pretty print]' \
        '-dump-callgraph[dump callgraph]' \
        '-dump-callgraph-stdout[dump callgraph to stdout]' \
        '-iopt-passes+[passes]:str:' \
        '-no-jsonerrors[plain errors]' \
        '*:file:_files -g "*.scilla *.scillib"'
}

_scilla-checker "$@"
