#compdef au

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'new:create new Aurelia project'
  'generate:run a generator'
  'g:run a generator (alias)'
  'config:get/set Aurelia configuration'
  'build:run gulp build task'
  'run:run gulp dev server'
  'test:run gulp test task'
  'help:show CLI help'
  'h:show help (alias)'
)

_arguments -C \
  '(- *)--version[show version]' \
  '(- *)-v[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'au subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (new)
        _arguments \
          '--here[create in current dir]' \
          '--plugin[create plugin project]' \
          '--select=[unattended feature list]:features:' \
          ':project name:' && ret=0
        ;;
      (config)
        _arguments \
          '--get[get config value]' \
          '--set[set config value]' \
          '--clear[clear config]' \
          '--add[add to config]' \
          '--remove[remove from config]' \
          '--no-save[do not save]' \
          '--no-backup[do not backup]' \
          ':key:' \
          ':value:' && ret=0
        ;;
    esac
    ;;
esac

return ret
