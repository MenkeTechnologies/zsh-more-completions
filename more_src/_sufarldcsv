#compdef sufarldcsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/statics/sufarldcsv.c
# SUFARLDCSV - floating approximate robust local datum from Q-files

local ret=1

_arguments -s -S \
  'rfile=[read a K-file with grid definition]:f:_files' \
  'sin=[input source Q-file]:f:_files' \
  'rin=[input receiver Q-file]:f:_files' \
  'cin=[input cdp Q-file]:f:_files' \
  'sloc=[source location names]:s:' \
  'rloc=[receiver location names]:r:' \
  'cloc=[cdp location names]:c:' \
  'sstat=[source static value name]:s:' \
  'rstat=[receiver static value name]:r:' \
  'cstat=[cdp static value name]:c:' \
  'smult=[source multiplier]:s:' \
  'rmult=[receiver multiplier]:r:' \
  'cmult=[cdp multiplier]:c:' \
  'cseq=[cdp sequence values]:c:' \
  'cedge=[cdp edge values]:c:' \
  'dout=[output datum value name]:d:' \
  'avrad=[averaging radius]:a:' \
  'kdist=[distance key]:k:' \
  'kmult=[distance key multiplier]:k:' \
  'navrg=[number of values to average]:n:' \
  'nback=[number of values backward]:n:' \
  'nedge=[number of edge values]:n:' \
  'nsmth=[number of smoothing passes]:n:' \
  'formxy=[format of x-y coordinate values]:f:' \
  '*:SU file:_files' && ret=0

return ret
