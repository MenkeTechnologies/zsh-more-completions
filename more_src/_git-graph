#compdef git-graph

# Zsh completion for git-graph - visualize commit history graph for Git

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-V --version)'{-V,--version}'[show git-graph version]'
  '(-p --path)'{-p,--path}'[path to the Git repository]:path:_files -/'
  '(-m --model)'{-m,--model}'[commit history model]:model:(simple git-flow)'
  '(-s --style)'{-s,--style}'[output style]:style:(normal thin round bold double ascii)'
  '--color[output with colors]:when:(always auto never)'
  '--no-color[disable color output]'
  '(-n --max-count)'{-n,--max-count}'[maximum number of commits to show]:count:'
  '(-w --wrap)'{-w,--wrap}'[wrap text to terminal width]:mode:(auto no 72 80)'
  '--svg[output SVG format]'
  '--local[include only local branches]'
  '--remotes[include only remote branches]'
  '--all[include all refs]'
  '--debug[show debug output]'
  '--sparse[print sparse graph (skip linear history)]'
  '--no-pager[disable pager]'
  '--format[commit format]:format:(oneline short medium full)'
  '1:branch or ref:'
)

_arguments -s -S $arguments
