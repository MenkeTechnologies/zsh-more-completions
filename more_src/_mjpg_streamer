#compdef mjpg_streamer
# Documentation: https://github.com/jacksonliam/mjpg-streamer
# mjpg_streamer: copy JPEG frames from input plugins to output plugins

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-b --background)'{-b,--background}'[fork to the background]' \
  '*-i+[input plugin and its arguments]:input plugin:_files -g "*.so"' \
  '*-o+[output plugin and its arguments]:output plugin:_files -g "*.so"' && ret=0

return ret
