#compdef ncu npm-check-updates
# Documentation: https://github.com/raineorshine/npm-check-updates
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for npm-check-updates - upgrade package.json dependencies

_arguments -s -S \
  '(-u --upgrade)'{-u,--upgrade}'[overwrite package file with upgraded versions]' \
  '(-i --interactive)'{-i,--interactive}'[choose which packages to update interactively]' \
  '(-f --filter)'{-f,--filter=}'[include only package names matching pattern]:pattern' \
  '(-x --reject)'{-x,--reject=}'[exclude packages matching pattern]:pattern' \
  '(-g --global)'{-g,--global}'[check global packages]' \
  '(-t --target)'{-t,--target=}'[determine version to upgrade to]:target:(latest greatest newest minor patch semver)' \
  '(-c --cooldown)'{-c,--cooldown=}'[minimum age in days for package versions]:days' \
  '(-d --doctor)'{-d,--doctor}'[iteratively install upgrades and run tests]' \
  '(-s --silent)'{-s,--silent}'[suppress all output]' \
  '(-r --registry)'{-r,--registry=}'[specify npm registry URI]:url' \
  '(-j --jsonAll)'{-j,--jsonAll}'[output new package file as JSON]' \
  '--jsonUpgraded[output upgraded dependencies in JSON]' \
  '--jsonDeps[list only dependencies in JSON format]' \
  '--deep[run recursively in directory]' \
  '--dep=[check specified dependency sections]:deps:(prod dev optional peer packageManager)' \
  '--pre=[include prerelease versions]:prerelease:(0 1)' \
  '--removeRange[remove version ranges from final package version]' \
  '(-e --errorLevel)'{-e,--errorLevel=}'[set error level]:level:(0 1 2)' \
  '--format=[modify output formatting]:format:(group ownerChanged repo time lines installedVersion cooldown)' \
  '(-l --loglevel)'{-l,--loglevel=}'[set logging level]:level:(silent error minimal warn info verbose silly)' \
  '--packageFile=[package file to check]:file:_files' \
  '(-p --packageManager)'{-p,--packageManager=}'[package manager to use]:pm:(npm yarn pnpm bun)' \
  '--timeout=[network timeout in milliseconds]:milliseconds' \
  '--color[force color output]' \
  '--no-color[disable color output]' \
  '--peer[check peer dependencies of installed packages]' \
  '--no-peer[do not check peer dependencies]' \
  '--root[include root project in addition to workspaces]' \
  '--no-root[exclude root in workspaces]' \
  '--workspace=[run on specified workspaces]:workspace' \
  '(-w --workspaces)'{-w,--workspaces}'[run on all workspaces]' \
  '--minimal[skip versions already satisfied by semver ranges]' \
  '--deprecated[include deprecated packages]' \
  '--no-deprecated[exclude deprecated packages]' \
  '--stdin[read package.json from stdin]' \
  '--concurrency=[max number of concurrent HTTP requests]:number' \
  '--configFilePath=[directory of config file]:path:_directories' \
  '--configFileName=[name of config file]:name' \
  '--mergeConfig[merge nested configs with root config]' \
  '--cache[cache versions locally]' \
  '--cacheClear[clear cache]' \
  '--cacheExpiration=[cache expiration in minutes]:minutes' \
  '--cacheFile=[custom cache filepath]:file:_files' \
  '--cwd=[working directory for npm execution]:dir:_directories' \
  '--enginesNode[only packages matching engines.node]' \
  '--filterVersion=[filter on package versions]:version' \
  '--rejectVersion=[exclude specific versions]:version' \
  '--registryType=[registry type]:type:(npm json)' \
  '--install=[auto-install behavior]:behavior:(always never prompt)' \
  '--doctorInstall=[custom install script for doctor mode]:script' \
  '--doctorTest=[custom test script for doctor mode]:script' \
  '--verbose[enable verbose logging]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && return 0
