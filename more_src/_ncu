#compdef ncu npm-check-updates

# Zsh completion for npm-check-updates - upgrade package.json dependencies

_arguments -s -S \
  '(-u --upgrade)'{-u,--upgrade}'[overwrite package file with upgraded versions]' \
  '(-i --interactive)'{-i,--interactive}'[choose which packages to update interactively]' \
  '(-f --filter)'{-f,--filter}'[include only package names matching pattern]:pattern' \
  '(-x --reject)'{-x,--reject}'[exclude packages matching pattern]:pattern' \
  '(-g --global)'{-g,--global}'[check global packages]' \
  '(-t --target)'{-t,--target}'[determine version to upgrade to]:target:(latest greatest newest minor patch semver)' \
  '--deep[recurse into subdirectories]' \
  '--dep[check only specified dependencies]:deps:(prod dev peer optional bundle)' \
  '--pre[include prerelease versions]:prerelease:(0 1)' \
  '--removeRange[remove version ranges from final package version]' \
  '(-e --errorLevel)'{-e,--errorLevel}'[set error level]:level:(0 1 2)' \
  '--format[modify output formatting]:format:(group ownerChanged repo)' \
  '(-j --jsonUpgraded)'{-j,--jsonUpgraded}'[output upgraded packages in JSON format]' \
  '--jsonAll[output all packages in JSON format]' \
  '(-l --loglevel)'{-l,--loglevel}'[set logging level]:level:(silent error minimal warn info verbose silly)' \
  '--packageFile[package file to check]:file:_files' \
  '(-p --packageManager)'{-p,--packageManager}'[package manager to use]:pm:(npm yarn pnpm staticRegistry)' \
  '--registry[third-party npm registry]:url' \
  '--timeout[network timeout in milliseconds]:milliseconds' \
  '--color[force color output]' \
  '--no-color[disable color output]' \
  '--peer[check peer dependencies of installed packages]' \
  '--root[runs updates on the root project in addition to workspaces]' \
  '(-w --workspace)'{-w,--workspace}'[filter workspaces]:workspace' \
  '--workspaces[run on all workspaces]' \
  '--concurrency[max number of concurrent HTTP requests]:number' \
  '--configFilePath[directory of config file]:path:_directories' \
  '--configFileName[name of config file]:name' \
  '--mergeConfig[merge nested configs with root config]' \
  '--doctor[iteratively install upgrades and run tests to identify breaking changes]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && return 0
