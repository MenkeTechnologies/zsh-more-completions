#compdef base91
# Documentation: https://man.archlinux.org/search?q=base91
# Reference accessed: 2026-05-16

# Zsh completion for Base91 encoder/decoder (typical -e/-d interface)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --decode)'{-d,--decode}'[decode instead of encode]' \
  '*:input file (default stdin):_files' && ret=0

return ret
