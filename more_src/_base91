#compdef base91
# Documentation: https://github.com/ajg/base91
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for Base91 encoder/decoder (typical -e/-d interface)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --decode)'{-d,--decode}'[decode instead of encode]' \
  '*:input file (default stdin):_files' && ret=0

return ret
