#compdef pkcrop
# pkcrop — crop and subset raster images (pktools)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-i,--input}'=[input raster file]:input file:_files' \
  {-o,--output}'=[output raster file]:output file:_files' \
  '-ulx+[upper left x coordinate]:x:' \
  '-uly+[upper left y coordinate]:y:' \
  '-lrx+[lower right x coordinate]:x:' \
  '-lry+[lower right y coordinate]:y:' \
  '-dx+[output pixel size in x]:resolution:' \
  '-dy+[output pixel size in y]:resolution:' \
  '*-b+[band to select]:band number:' \
  '-a_srs+[assign spatial reference system]:EPSG or WKT:' \
  '-of+[output format]:format:(GTiff HFA)' \
  '*-co+[creation option]:option:' \
  '-e+[extent from reference file]:reference file:_files' \
  '-ot+[output data type]:type:(Byte Int16 UInt16 Int32 UInt32 Float32 Float64)' \
  '-nodata+[nodata value]:value:' \
  '-s_srs+[source spatial reference]:EPSG or WKT:' \
  '-t_srs+[target spatial reference]:EPSG or WKT:' \
  '-r+[resampling method]:method:(near bilinear)' \
  '--scale+[scale factor]:scale:' \
  '--offset+[offset value]:offset:' && ret=0

return ret
