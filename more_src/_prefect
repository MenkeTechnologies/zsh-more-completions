#compdef prefect

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-prompt[disable interactive prompts]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'agent:manage agents'
      'block:manage blocks'
      'cloud:manage Prefect Cloud'
      'config:manage configuration'
      'deploy:deploy flows'
      'deployment:manage deployments'
      'flow:manage flows'
      'flow-run:manage flow runs'
      'init:initialize a Prefect project'
      'profile:manage profiles'
      'project:manage projects'
      'server:manage the Prefect server'
      'variable:manage variables'
      'version:show version'
      'work-pool:manage work pools'
      'work-queue:manage work queues'
      'worker:manage workers'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      server)
        _arguments -s -S \
          '1:action:(start)' \
          '--host=[host to bind to]:host' \
          '--port=[port to bind to]:port' \
          '--log-level=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '--name=[deployment name]:name' \
          '--pool=[work pool]:pool' \
          '--all[deploy all flows]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:flow entrypoints:_files -g "*.py"' && ret=0
        ;;
      profile)
        _arguments -s -S \
          '1:action:(create delete inspect ls rename set use)' && ret=0
        ;;
      flow)
        _arguments -s -S \
          '1:action:(serve)' && ret=0
        ;;
      cloud)
        _arguments -s -S \
          '1:action:(login logout open workspace)' && ret=0
        ;;
    esac
    ;;
esac

return ret
