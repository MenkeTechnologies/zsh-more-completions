#compdef approxmc
# Documentation: https://github.com/meelgroup/approxmc
# approximate model counter

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version info and exit]' \
  '(-s --seed)'{-s,--seed}'+[random seed]:seed' \
  '(-e --epsilon)'{-e,--epsilon}'+[tolerance]:epsilon' \
  '(-d --delta)'{-d,--delta}'+[confidence]:delta' \
  '(-v --verb)'{-v,--verb}'+[verbosity, 0 = quiet]:level' \
  '--sparse=[generate sparse XOR constraints]:flag:(0 1)' \
  '--arjun=[enable/disable Arjun preprocessing]:flag:(0 1)' \
  '*:dimacs file:_files' && ret=0

return ret
