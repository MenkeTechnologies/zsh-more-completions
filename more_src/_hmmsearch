#compdef hmmsearch
# Documentation: https://manpages.debian.org/testing/hmmer/hmmsearch.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian hmmer hmmsearch(1) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --pfamtblout option (not in manpage). Added missing
# --nonull2, -Z, --domZ, --stall, --mpi flags.

# HMMER hmmsearch: search an HMM against a sequence database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output file]:file:_files' \
  '-A[save multiple alignment of hits]:file:_files' \
  '--tblout[per-sequence hits table]:file:_files' \
  '--domtblout[per-domain hits table]:file:_files' \
  '--acc[show accessions, not names]' \
  '--noali[no alignments in output]' \
  '--notextw[no max output width]' \
  '--textw[max output text width]:cols:' \
  '-E[report sequences <= this E-value]:Eval:' \
  '-T[report sequences with bit score >= this]:bits:' \
  '--domE[per-domain reporting E-value]:Eval:' \
  '--domT[per-domain reporting score]:bits:' \
  '--incE[inclusion threshold E-value]:Eval:' \
  '--incT[inclusion threshold score]:bits:' \
  '--incdomE[per-domain inclusion E-value]:Eval:' \
  '--incdomT[per-domain inclusion score]:bits:' \
  '--cut_ga[use GA cutoffs]' \
  '--cut_nc[use NC cutoffs]' \
  '--cut_tc[use TC cutoffs]' \
  '--max[turn off heuristic filters]' \
  '--F1[MSV threshold]:val:' \
  '--F2[Vit threshold]:val:' \
  '--F3[Fwd threshold]:val:' \
  '--nobias[no bias filter]' \
  '--nonull2[turn off biased composition score corrections]' \
  '-Z[E-value calc: this many DB targets assumed]:n:' \
  '--domZ[per-domain E-value calc: this many domain targets assumed]:n:' \
  '--seed[random seed]:n:' \
  '--stall[stall on entry (for attaching debugger)]' \
  '--mpi[run MPI mode]' \
  '--tformat[target sequence format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip)' \
  '--cpu[CPU threads]:n:' \
  '*:HMM file and sequence database:_files' && ret=0
return ret
