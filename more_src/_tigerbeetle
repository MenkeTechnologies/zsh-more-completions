#compdef tigerbeetle

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'format:format a new TigerBeetle data file'
  'start:start a TigerBeetle replica'
  'version:show version'
  'repl:start an interactive REPL'
  'recover:recover a corrupted data file'
  'benchmark:run the built-in benchmark'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tigerbeetle subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (format)
        _arguments \
          '--cluster=[cluster id]:id:' \
          '--replica=[replica number]:n:' \
          '--replica-count=[total replicas]:n:' \
          '--development[development mode]' \
          '*:datafile:_files' && ret=0
        ;;
      (start)
        _arguments \
          '--addresses=[address list]:addresses:' \
          '--cache-grid=[grid cache size]:size:' \
          '--development[development mode]' \
          '*:datafile:_files' && ret=0
        ;;
      (recover|benchmark|repl)
        _files
        ret=0
        ;;
    esac
    ;;
esac

return ret
