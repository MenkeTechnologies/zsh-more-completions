#compdef gnt-network
# _gnt-network — Google Ganeti gnt-network CLI for managing Ganeti virtualisation cluster IP networks subnet allocation gateway nat-supporting external connectivity floating IP map node-groups connect-disconnect (ganeti team, Python); custom argparse
# upstream: https://github.com/ganeti/ganeti

_gnt-network() {
    local -a sub=(
        'add:add new network'
        'connect:connect network to node-group'
        'disconnect:disconnect network from node-group'
        'info:show network info'
        'list:list networks'
        'modify:modify network'
        'remove:remove network'
        'rename:rename network'
        'reserve:reserve IPs'
        'release:release IPs'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--cluster=+[name]:str:' \
        '--no-headers[no headers]' \
        '--separator=+[char]:str:' \
        '-o+[output fields]:str:' \
        '--output=+[output fields]:str:' \
        '--reason=+[text]:str:' \
        '--submit[submit only]' \
        '--print-job-id[print job id]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gnt-network subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '--network=+[cidr]:str:' \
                    '--gateway=+[ip]:str:' \
                    '--network6=+[cidr]:str:' \
                    '--gateway6=+[ip]:str:' \
                    '--mac-prefix=+[prefix]:str:' \
                    '--add-reserved-ips=+[ip csv]:str:' \
                    '--tags=+[csv]:str:' \
                    '*:network name:' ;;
                connect|disconnect) _arguments \
                    '--vlan=+[id]:n:' \
                    '--nicparams=+[K=V csv]:str:' \
                    '*:network groups:' ;;
                modify) _arguments \
                    '--mac-prefix=+[prefix]:str:' \
                    '--add-reserved-ips=+[ip csv]:str:' \
                    '--remove-reserved-ips=+[ip csv]:str:' \
                    '--gateway=+[ip]:str:' \
                    '*:network name:' ;;
            esac
            ;;
    esac
}

_gnt-network "$@"
