#compdef chopsticks
# _chopsticks — AcalaNetwork Chopsticks Substrate chain forking and fast-replay tool for parachain development (AcalaNetwork team, TypeScript); yargs
# upstream: https://github.com/AcalaNetwork/chopsticks

_chopsticks() {
    local -a sub=(
        'dev:start a forked dev chain'
        'xcm:run XCM scenarios'
        'follow-chain:follow a real chain'
        'try-runtime:run try-runtime'
        'decode-block:decode a block'
        'run-block:run a block'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.yml *.yaml *.json"' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.json"' \
        '--endpoint=+[upstream rpc url]:url:_urls' \
        '-e+[upstream rpc url]:url:_urls' \
        '--block=+[block hash or num]:str:' \
        '-b+[block hash or num]:str:' \
        '--wasm-override=+[runtime wasm]:file:_files -g "*.wasm"' \
        '--port=+[ws port]:port:_ports' \
        '-p+[ws port]:port:_ports' \
        '--db=+[sqlite db]:file:_files -g "*.sqlite *.db"' \
        '-d+[sqlite db]:file:_files -g "*.sqlite *.db"' \
        '--build-block-mode=+[mode]:m:(batch instant manual)' \
        '--allow-unresolved-imports[allow unresolved imports]' \
        '--runtime-log-level=+[level]:n:' \
        '--mock-signature-host[mock signature host]' \
        '--registered-types=+[file]:file:_files' \
        '--genesis=+[genesis json]:file:_files' \
        '--import-storage=+[storage file]:file:_files' \
        '--offchain-worker[run offchain worker]' \
        '--html[html output]' \
        '--timestamp=+[timestamp]:str:' \
        '--max-memory-block-count=+[n]:n:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'chopsticks subcommand' sub ;;
        args)
            case $words[1] in
                xcm) _arguments \
                    '--relaychain=+[relaychain config]:file:_files' \
                    '-r+[relaychain config]:file:_files' \
                    '--parachain=+[parachain config]:file:_files' \
                    '-p+[parachain config]:file:_files' \
                    '*:config:_files -g "*.yml *.yaml *.json"' ;;
                try-runtime) _arguments \
                    '--runtime=+[wasm runtime]:file:_files -g "*.wasm"' \
                    '--checks=+[checks]:c:(none all upgrade try-state)' \
                    '*:config:_files -g "*.yml *.yaml *.json"' ;;
                run-block|decode-block) _arguments \
                    '--block=+[block hash or num]:str:' \
                    '*:config:_files -g "*.yml *.yaml *.json"' ;;
            esac
            ;;
    esac
}

_chopsticks "$@"
