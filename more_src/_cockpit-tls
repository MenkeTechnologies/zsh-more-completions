#compdef cockpit-tls

# cockpit-tls: Cockpit'\''s TLS-terminating front-end (socket activated)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--idle-timeout=[idle timeout (seconds)]:n:' \
  '--port=[listen port]:port:' \
  '--for-tls-proxy[behind a TLS-terminating proxy]' \
  '--no-tls[disable TLS]' \
  '*::cockpit-tls args:_files' && ret=0
return ret
