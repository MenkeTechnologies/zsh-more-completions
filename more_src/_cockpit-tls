#compdef cockpit-tls

# cockpit-tls: TLS terminating reverse proxy in front of cockpit-ws
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--port=[listen port]:port:' \
  '--idle-timeout=[idle timeout in seconds]:seconds:' \
  '--no-tls[disable TLS (only for tests)]' \
  '*::extra args:_files' && ret=0
return ret
