#compdef cockpit-tls
# Documentation: https://cockpit-project.org/guide/latest/cockpit-tls.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cockpit-tls: TLS terminating reverse proxy in front of cockpit-ws

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help options]' \
  '--port=[serve HTTP requests on PORT instead of 9090]:port:' \
  '--no-tls[disable TLS; certs not read, https denied (testing only)]' \
  '--idle-timeout=[exit if no connections for given seconds (default 90)]:seconds:' \
  '*::extra args:_files' && ret=0
return ret
