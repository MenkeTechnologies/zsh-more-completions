#compdef pcp-uptime
# Documentation: https://man.archlinux.org/search?q=pcp-uptime
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-A+[archive]:file:_files' \
  '-H+[host]:host:_hosts' \
  '-O+[origin]:time:' \
  '-z[archive timezone]' \
  '-Z+[timezone]:tz:' \
  '-V[show version]' && ret=0

return ret
