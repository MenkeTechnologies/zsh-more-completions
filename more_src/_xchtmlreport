#compdef xchtmlreport
# _xchtmlreport — XCTestHTMLReport (Swift); generates rich HTML report from .xcresult bundle including screenshots, attachments, logs
# upstream: https://github.com/XCTestHTMLReport/XCTestHTMLReport

_xchtmlreport() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-r+[xcresult bundle]:bundle:_files -g "*.xcresult"' \
        '-o+[output dir]:dir:_files -/' \
        '-i[render inline]' \
        '-j+[junit report path]:file:_files' \
        '-s[shrink screenshots]' \
        '-n+[report name]:name:' \
        '-v[verbose]' \
        '-z[zip output]' \
        '--rename+[rename test summary]:str:' \
        '--include-screenshots[force include all screenshots]'
}

_xchtmlreport "$@"
