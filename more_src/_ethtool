#compdef ethtool

# Zsh completion for ethtool - network device settings

local curcontext="$curcontext" state line ret=1

_ethtool_interfaces() {
  local -a interfaces
  if [[ -d /sys/class/net ]]; then
    interfaces=( /sys/class/net/*(N:t) )
  fi
  _describe -t interfaces 'network interface' interfaces
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-a[show pause parameters]:interface:_ethtool_interfaces' \
  '-A[set pause parameters]:interface:_ethtool_interfaces' \
  '-c[show coalesce settings]:interface:_ethtool_interfaces' \
  '-C[set coalesce settings]:interface:_ethtool_interfaces' \
  '-g[show ring buffer settings]:interface:_ethtool_interfaces' \
  '-G[set ring buffer settings]:interface:_ethtool_interfaces' \
  '-i[show driver information]:interface:_ethtool_interfaces' \
  '-d[show register dump]:interface:_ethtool_interfaces' \
  '-e[show EEPROM dump]:interface:_ethtool_interfaces' \
  '-E[set EEPROM value]:interface:_ethtool_interfaces' \
  '-k[show offload features]:interface:_ethtool_interfaces' \
  '-K[set offload features]:interface:_ethtool_interfaces' \
  '-l[show channel parameters]:interface:_ethtool_interfaces' \
  '-L[set channel parameters]:interface:_ethtool_interfaces' \
  '-m[show module EEPROM info]:interface:_ethtool_interfaces' \
  '(-n -u)'{-n,-u}'[show Rx network flow classification rules]:interface:_ethtool_interfaces' \
  '(-N -U)'{-N,-U}'[set Rx network flow classification rules]:interface:_ethtool_interfaces' \
  '-p[flash device LED for identification]:interface:_ethtool_interfaces' \
  '-P[show permanent hardware address]:interface:_ethtool_interfaces' \
  '-r[restart auto-negotiation]:interface:_ethtool_interfaces' \
  '-S[show NIC and driver statistics]:interface:_ethtool_interfaces' \
  '-s[change generic options]:interface:_ethtool_interfaces' \
  '-t[execute adapter self test]:interface:_ethtool_interfaces' \
  '-T[show time stamping capabilities]:interface:_ethtool_interfaces' \
  '-x[show Rx flow hash indirection table and/or RSS hash key]:interface:_ethtool_interfaces' \
  '-X[set Rx flow hash indirection table and/or RSS hash key]:interface:_ethtool_interfaces' \
  '-W[set dump flag]:interface:_ethtool_interfaces' \
  '-w[get dump data]:interface:_ethtool_interfaces' \
  '--phy-statistics[show PHY statistics]:interface:_ethtool_interfaces' \
  '--show-priv-flags[show private flags]:interface:_ethtool_interfaces' \
  '--set-priv-flags[set private flags]:interface:_ethtool_interfaces' \
  '--show-eee[show EEE settings]:interface:_ethtool_interfaces' \
  '--set-eee[set EEE settings]:interface:_ethtool_interfaces' \
  '--set-phy-tunable[set PHY tunable]:interface:_ethtool_interfaces' \
  '--get-phy-tunable[get PHY tunable]:interface:_ethtool_interfaces' \
  '--show-fec[show FEC settings]:interface:_ethtool_interfaces' \
  '--set-fec[set FEC settings]:interface:_ethtool_interfaces' \
  '--cable-test[perform cable test]:interface:_ethtool_interfaces' \
  '--show-tunnels[show tunnel offload information]:interface:_ethtool_interfaces' \
  '--reset[reset device]:interface:_ethtool_interfaces' \
  '1:interface:_ethtool_interfaces' && ret=0

return ret
