#compdef eselect

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--brief[brief output]' \
  '--colour=+[enable/disable colour]:colour:(yes no)' \
  '--color=+[enable/disable colour]:color:(yes no)' \
  '1:module:->modules' \
  '*::arg:->args' && ret=0

case $state in
  (modules)
    local -a modules
    modules=(${(f)"$(eselect modules list 2>/dev/null | awk '{print $1}')"})
    if [[ ${#modules} -eq 0 ]]; then
      modules=(
        'binutils:manage binutils symlinks'
        'compiler:manage compiler symlinks'
        'editor:manage default editor'
        'env:manage environment variables'
        'fontconfig:manage fontconfig files'
        'java-nsplugin:manage Java browser plugin'
        'java-vm:manage Java Virtual Machine'
        'kernel:manage kernel symlinks'
        'locale:manage system locale'
        'mesa:manage Mesa OpenGL implementation'
        'modules:manage eselect modules'
        'news:manage Gentoo news'
        'opencl:manage OpenCL implementation'
        'opengl:manage OpenGL implementation'
        'pager:manage default pager'
        'php:manage PHP version'
        'plymouth:manage Plymouth theme'
        'profile:manage Gentoo profile'
        'python:manage Python version'
        'repository:manage ebuild repositories'
        'ruby:manage Ruby version'
        'rust:manage Rust toolchain'
        'visual:manage default visual editor'
        'wxwidgets:manage wxWidgets profile'
      )
    fi
    _describe -t modules 'module' modules && ret=0
    ;;
  (args)
    local -a actions=(
      'help:show help for this module'
      'list:list available options'
      'set:set the active option'
      'show:show the active option'
      'update:update the symlinks'
    )
    _describe -t actions 'action' actions && ret=0
    ;;
esac

return ret
