#compdef tsv-select
# Documentation: https://man.archlinux.org/search?q=tsv-select
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-f+[fields to select]:fields' \
  '--fields=[fields to select]:fields' \
  '-r[rest of fields]' \
  '--rest[rest of fields]' \
  '-d+[delimiter]:delimiter' \
  '--delimiter=[delimiter]:delimiter' \
  '--header[input has header]' \
  '*:file:_files' && return 0
