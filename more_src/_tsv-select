#compdef tsv-select
# Documentation: https://github.com/eBay/tsv-utils/blob/master/docs/tool_reference/tsv-select.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-f+[fields to select]:fields' \
  '--fields=[fields to select]:fields' \
  '-r[rest of fields]' \
  '--rest[rest of fields]' \
  '-d+[delimiter]:delimiter' \
  '--delimiter=[delimiter]:delimiter' \
  '--header[input has header]' \
  '*:file:_files' && return 0
