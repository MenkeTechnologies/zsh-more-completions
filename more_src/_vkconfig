#compdef vkconfig vkconfig-gui

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--reset[reset configurations]' \
  '--override[apply Vulkan override layer]' \
  '--surrender[remove Vulkan override layer]' \
  '--list[list configurations]' \
  '--info[print info]' \
  '--ls-loader[list loaders]' \
  '--ls-layers[list layers]' \
  '*:config:' && ret=0

return ret
