#compdef ddcutil

# Zsh completion for ddcutil - monitor control via DDC/CI

local curcontext="$curcontext" state line ret=1

local -a subcommands
subcommands=(
  'detect:Detect monitors'
  'capabilities:Query monitor capabilities'
  'getvcp:Get VCP feature value'
  'setvcp:Set VCP feature value'
  'scs:Save current settings'
  'loadvcp:Load VCP settings from file'
  'dumpvcp:Dump VCP settings to file'
  'environment:Explore execution environment'
  'interrogate:Collect system information for bug reports'
  'probe:Probe monitor capabilities'
  'watch:Watch for VCP value changes'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-d --display)'{-d,--display}'[display number]:display number' \
  '(-b --bus)'{-b,--bus}'[I2C bus number]:bus number' \
  '--mfg[filter by manufacturer code]:manufacturer code' \
  '--model[filter by model name]:model name' \
  '--sn[filter by serial number]:serial number' \
  '--edid[filter by EDID]:edid' \
  '--terse[terse output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--async[use asynchronous I2C access]' \
  '--force-slave-address[force I2C slave address]' \
  '--verify[verify setvcp values]' \
  '--noverify[do not verify setvcp values]' \
  '--mccs[MCCS version]:version:(1.0 2.0 2.1 3.0)' \
  '--sleep-multiplier[multiply default sleep times]:multiplier' \
  '--stats[show performance statistics]:stats type:(tries errors calls elapsed all)' \
  '--syslog[write to syslog]:level:(NEVER ERROR WARN INFO DEBUG)' \
  '--trace[trace groups]:group' \
  '--timestamp[prefix trace with timestamp]' \
  '1:subcommand:->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'ddcutil subcommand' subcommands
    ;;
  args)
    case $words[1] in
      getvcp|setvcp|watch)
        _arguments '*:VCP feature code'
        ;;
      loadvcp)
        _arguments '*:VCP settings file:_files'
        ;;
      dumpvcp)
        _arguments '*:output file:_files'
        ;;
      *)
        _arguments '*:arguments'
        ;;
    esac
    ;;
esac

return ret
