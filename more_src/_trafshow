#compdef trafshow

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-i+[interface]:if:_net_interfaces' \
  '-n[no resolve]' \
  '-p[no promisc]' \
  '-c+[colors file]:file:_files' \
  '-u+[update interval s]:s:' \
  '-s+[sort field]:f:' \
  '-R[scroll up]' \
  '-T+[idle timeout s]:s:' \
  '-N+[node names file]:file:_files' \
  '-S+[services file]:file:_files' \
  '*:filter:' && ret=0

return ret
