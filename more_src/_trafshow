#compdef trafshow
# Documentation: https://www.unix.com/man-page/debian/8/trafshow/
# Reference accessed: 2026-05-21
# Verified: upstream manpage at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-v[display version details and terminate]' \
  '-p[disable promiscuous mode on network interfaces]' \
  '-n[skip name resolution for addresses and ports]' \
  '-b[position reverse-flow entries alongside primary traffic streams]' \
  '-a+[enable flow aggregation with specified netmask prefix length]:length' \
  '-c+[specify alternate color configuration file]:file:_files' \
  '-i+[select specific network interface to monitor]:iface:_net_interfaces' \
  '-s+[activate search mode for matching list items]:string' \
  '-u+[UDP port for Cisco Netflow reception]:port' \
  '-R+[screen refresh interval in seconds]:seconds' \
  '-P+[expired data removal period in seconds]:seconds' \
  '-F+[load filter expression from file]:file:_files' \
  '*:filter expression:' && ret=0

return ret
