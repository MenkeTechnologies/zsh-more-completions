#compdef firefly-cli
# Documentation: https://man.archlinux.org/search?q=firefly-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help for available commands'
  'add:create a new transaction'
  'accounts:view account information'
  'budgets:view budget information'
  'edit:configure URL and API_TOKEN'
  'refresh:reconnect to the Firefly III API'
  'license:show license info'
  'version:show CLI version'
  'exit:quit the CLI'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'firefly-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '--amount=[transaction amount]:amount:' \
          '--description=[transaction description]:desc:' \
          '--source-name=[source account]:account:' \
          '--destination-name=[destination account]:account:' \
          '--category=[transaction category]:category:' \
          '--budget=[transaction budget]:budget:' \
          '--type=[transaction type]:type:(withdrawal deposit transfer)' \
          '--date=[date YYYY-MM-DD]:date:' \
          '--datetime=[datetime YYYY-MM-DDTHH:MM:SS]:datetime:' && ret=0 ;;
      (edit)
        _arguments \
          '--url=[Firefly III URL]:url:' \
          '--api-token=[API personal access token]:token:' && ret=0 ;;
    esac ;;
esac

return ret
