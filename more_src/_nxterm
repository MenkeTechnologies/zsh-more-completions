#compdef nxterm
# Documentation: https://invisible-island.net/xterm/xterm.man.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (xterm man page).
# Note: nxterm is a historical color xterm variant - typically a symlink
# or wrapper around xterm with color defaults. Accepts the xterm flag surface.

local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-display[X display]:display:' \
  '-geometry[window geometry]:geom:' \
  '-fn[font name]:font:' \
  '-fa[X font face]:font:' \
  '-fs[font size]:size:' \
  '-fg[foreground color]:color:' \
  '-bg[background color]:color:' \
  '-T[window title]:title:' \
  '-e[execute command]:command:_command_names' \
  '*:arg:_files' && ret=0
return ret
