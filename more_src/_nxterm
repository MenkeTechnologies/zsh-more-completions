#compdef nxterm
# Documentation: (historical X11 color xterm variant)
# Reference accessed: 2026-05-16
# Verified: no current upstream - typically a symlink/wrapper around
# xterm with color defaults. Accepts the same flag surface as xterm.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# nxterm: historical color xterm variant (effectively xterm)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-display[X display]:display:' \
  '-geometry[window geometry]:geom:' \
  '-fn[font name]:font:' \
  '-fa[X font face]:font:' \
  '-fs[font size]:size:' \
  '-fg[foreground color]:color:' \
  '-bg[background color]:color:' \
  '-T[window title]:title:' \
  '-e[execute command]:command:_command_names' \
  '*:arg:_files' && ret=0
return ret
