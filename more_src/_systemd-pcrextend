#compdef systemd-pcrextend
# _systemd-pcrextend — systemd TPM2 PCR extension CLI (systemd team, C); custom argparse
# upstream: https://github.com/systemd/systemd

_systemd-pcrextend() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--bank=+[hash bank]:bank:(sha1 sha256 sha384 sha512)' \
        '--pcr=+[pcr number]:n:' \
        '--tpm2-device=+[tpm2 device]:dev:' \
        '--file-system=+[filesystem]:path:_files -/' \
        '--machine-id[use machine-id]' \
        '--graceful[graceful]' \
        '--varlink[use varlink]' \
        '--json=+[json output]:fmt:(pretty short off)' \
        '*:word:'
}

_systemd-pcrextend "$@"
