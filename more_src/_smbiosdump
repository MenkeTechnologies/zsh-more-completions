#compdef smbiosdump
# Documentation: https://man.archlinux.org/search?q=smbiosdump
# Reference accessed: 2026-05-16

# smbiosdump: dump raw SMBIOS structures
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-V[show version]' \
  '-q[quiet]' \
  '-x[hex dump only]' \
  '-d[debug]' \
  '-f[input file]:file:_files' \
  '*::smbiosdump args:_files' && ret=0
return ret
