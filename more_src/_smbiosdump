#compdef smbiosdump

# smbiosdump: dump raw SMBIOS structures
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-V[show version]' \
  '-q[quiet]' \
  '-x[hex dump only]' \
  '-d[debug]' \
  '-f[input file]:file:_files' \
  '*::smbiosdump args:_files' && ret=0
return ret
