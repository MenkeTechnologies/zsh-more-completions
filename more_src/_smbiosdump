#compdef smbiosdump

# smbiosdump: extract and decode SMBIOS table contents
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-q[quiet mode]' \
  '-v[verbose output]' \
  '-d[dump raw bytes]' \
  '-t[only dump records of given type]:n:' \
  '*::smbiosdump args:_files' && ret=0
return ret
