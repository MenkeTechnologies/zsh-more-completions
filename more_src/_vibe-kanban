#compdef vibe-kanban vibe-kanban-cli
# Documentation: https://man.archlinux.org/search?q=vibe-kanban
# Reference accessed: 2026-05-16

# Zsh completion for Vibe Kanban
# https://vibekanban.com

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'compact:Summarize conversation and clear history'
  'review:Initiate code review of current changes'
  'init:Create CLAUDE.md with project instructions'
  'context:Visualize current token/context usage'
  'cost:Show monetary cost and duration'
  'pr-comments:Fetch and display GitHub PR comments'
)

_arguments -s -S \
  '1:command:->command' \
  '*: :_files' && ret=0

case $state in
  (command)
    _describe -t commands 'vibe-kanban command' commands && ret=0
    ;;
esac

# Environment Variables
local -a evars=(
  'VIBEKANBAN_PORT:Set server port'
  'HOST:Set backend server host'
  'MCP_PORT:MCP server port'
  'MCP_HOST:MCP server host'
  'VK_ALLOWED_ORIGINS:Allowed origins for reverse proxy'
  'DISABLE_WORKTREE_CLEANUP:Prevent auto-deletion of git worktrees'
  'VK_TUNNEL:Enable relay tunnel mode'
)

return ret
