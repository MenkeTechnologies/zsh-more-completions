#compdef typedoc

# Zsh completion for TypeDoc

_typedoc() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--options=[specify a json option file]:options file:_files -g "*.json"' \
    '--tsconfig=[specify a TypeScript config file]:tsconfig file:_files -g "tsconfig*.json"' \
    '--entryPoints=[entry point files]:entry points:_files -g "*.{ts,tsx}"' \
    '--entryPointStrategy=[strategy for resolving entry points]:strategy:(resolve expand packages merge)' \
    '--exclude=[exclude files by pattern]:glob pattern:' \
    '--externalPattern=[pattern for external files]:glob pattern:' \
    '--excludeExternals[prevent externally resolved symbols from being documented]' \
    '--excludeNotDocumented[prevent symbols without documentation from appearing in output]' \
    '--excludeInternal[prevent symbols marked @internal from being documented]' \
    '--excludePrivate[ignore private variables and methods]' \
    '--excludeProtected[ignore protected variables and methods]' \
    '--excludeReferences[prevent re-exports from being documented]' \
    '--out=[output directory]:output directory:_files -/' \
    '--json=[output file for JSON documentation]:json file:_files -g "*.json"' \
    '--pretty[pretty print JSON output]' \
    '--emit=[specify what TypeDoc should emit]:emit:(docs both none)' \
    '--theme=[specify theme]:theme:(default)' \
    '--name=[set the project name]:name:' \
    '--includeVersion[add package version to the project name]' \
    '--disableSources[disable setting source of a reflection]' \
    '--basePath=[base path for file paths]:base path:_files -/' \
    '--readme=[path to the README file]:readme file:_files -g "*.md"' \
    '--cname=[set the CNAME file text]:cname:' \
    '--sourceLinkTemplate=[source link template]:template:' \
    '--gitRevision=[use specified revision for source links]:revision:' \
    '--gitRemote=[use specified remote for source links]:remote:' \
    '--disableGit[disable git for source links]' \
    '--htmlLang=[set the lang attribute in generated HTML]:language:' \
    '--githubPages[generate .nojekyll file]' \
    '--cacheBust[include a timestamp in script/link tags]' \
    '--hideGenerator[hide TypeDoc link at end of page]' \
    '--searchInComments[search in comments]' \
    '--cleanOutputDir[clean output directory before rendering]' \
    '--titleLink=[set the link the title points to]:URL:' \
    '--navigationLinks=[define links in the header]:JSON:' \
    '--sidebarLinks=[define links in the sidebar]:JSON:' \
    '--navigation=[navigation options]:JSON:' \
    '--visibilityFilters=[set visibility filters]:JSON:' \
    '--searchCategoryBoosts=[boost search relevance for categories]:JSON:' \
    '--searchGroupBoosts=[boost search relevance for groups]:JSON:' \
    '--categorizeByGroup[categorize output by group]' \
    '--defaultCategory=[default category for reflections]:category name:' \
    '--categoryOrder=[order of categories]:JSON:' \
    '--groupOrder=[order of groups]:JSON:' \
    '--sort=[specify sort strategy]:strategy:(source-order alphabetical enum-value-ascending enum-value-descending static-first instance-first visibility kind required-first)' \
    '--kindSortOrder=[specify kind sort order]:JSON:' \
    '--watch[watch for file changes and rebuild]' \
    '--preserveWatchOutput[do not clear the screen between compilations]' \
    '--skipErrorChecking[do not type check before generating docs]' \
    '--help[display help]' \
    '--version[display version]' \
    '--showConfig[print resolved config and exit]' \
    '--plugin=[specify npm plugin packages]:plugin:' \
    '--logLevel=[set the log level]:level:(Verbose Debug Info Warn Error None)' \
    '--treatWarningsAsErrors[treat warnings as errors]' \
    '--treatValidationWarningsAsErrors[treat validation warnings as errors]' \
    '--intentionallyNotExported=[suppress warnings for not exported types]:types:' \
    '--requiredToBeDocumented=[require types to be documented]:types:' \
    '--validation=[enable validation checks]:JSON:' \
    '*:entry points:_files -g "*.{ts,tsx}"' \
    && ret=0

  return ret
}

_typedoc "$@"
