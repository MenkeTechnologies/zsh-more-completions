#compdef pkg-cli
# _pkg-cli — FreeBSD pkg package manager CLI alias (FreeBSD Foundation, C); custom argparse
# upstream: https://github.com/freebsd/pkg

_pkg-cli() {
    local -a sub=(
        'add:install package from file/URL'
        'alias:list/edit aliases'
        'annotate:add/modify/remove package annotations'
        'audit:audit installed packages for vulns'
        'autoremove:remove unneeded dependencies'
        'backup:backup/restore database'
        'bootstrap:install pkg itself'
        'check:check installed packages'
        'clean:clean cache'
        'config:show config'
        'create:create a package'
        'delete:remove packages'
        'fetch:fetch packages without install'
        'help:show help'
        'info:show information on packages'
        'install:install packages'
        'lock:lock a package against modifications'
        'plugins:plugins commands'
        'query:query database'
        'register:register a package'
        'remove:remove packages (alias)'
        'repo:create repository catalogue'
        'rquery:query repository'
        'search:search for packages'
        'set:set package attributes'
        'shell:open shell on database'
        'shlib:show what depends on shlib'
        'ssh:start client/server for pkg over ssh'
        'stats:show statistics'
        'unlock:unlock a package'
        'update:update repositories'
        'updating:show UPDATING entries'
        'upgrade:upgrade installed packages'
        'version:show version'
        'which:show package owning file'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-d[debug]' \
        '-c+[chroot dir]:dir:_files -/' \
        '-j+[jail]:str:' \
        '-l[skip locking]' \
        '-N[no interaction]' \
        '-o+[option name=value]:list:' \
        '-r+[reponame]:str:' \
        '-4[force IPv4]' \
        '-6[force IPv6]' \
        '--yes[assume yes]' \
        '-y[assume yes]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pkg subcommand' sub ;;
        args)
            case $words[1] in
                install|delete|remove|fetch|info|upgrade|update|audit|search|rquery|query) _arguments \
                    '*:package:' ;;
                clean) _arguments \
                    '--all[remove all cached]' \
                    '-a[remove all cached]' \
                    '--dry-run[dry run]' \
                    '-n[dry run]' \
                    '--quiet[quiet]' \
                    '-q[quiet]' \
                    '--yes[assume yes]' \
                    '-y[assume yes]' ;;
                lock|unlock) _arguments \
                    '--all[all packages]' \
                    '-a[all packages]' \
                    '--show-locked[show locked]' \
                    '-l[show locked]' \
                    '--regex[regex match]' \
                    '-r[regex match]' \
                    '*:package:' ;;
                stats) _arguments \
                    '--local[local]' \
                    '-l[local]' \
                    '--remote[remote]' \
                    '-r[remote]' \
                    '--bytes[bytes]' \
                    '-b[bytes]' ;;
            esac
            ;;
    esac
}

_pkg-cli "$@"
