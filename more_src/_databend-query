#compdef databend-query databend-meta bendsql
# Documentation: https://man.archlinux.org/search?q=databend-query
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (databend-query)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-c --config-file)'{-c+,--config-file=}'[config TOML]:file:_files -g "*.toml"' \
      '(--cmd)*--cmd=[init query]:q:' \
      '(--query)--query=[query string]:q:' \
      '(--internal-enable-sandbox-tenant)--internal-enable-sandbox-tenant[sandbox]' \
      '*-O+[option k=v]:opt:' \
      '*: :' && ret=0 ;;
  (databend-meta)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-c --config-file)'{-c+,--config-file=}'[config TOML]:file:_files' \
      '(--single)--single[single node]' \
      '(--admin-api-address)--admin-api-address=[admin addr]:a:' \
      '(--grpc-api-address)--grpc-api-address=[grpc addr]:a:' \
      '(--raft-listen-host)--raft-listen-host=[raft host]:h:' \
      '(--raft-advertise-host)--raft-advertise-host=[raft adv]:h:' \
      '(--raft-api-port)--raft-api-port=[raft port]:p:' \
      '(--id)--id=[node ID]:n:' \
      '(--join)*--join=[join nodes csv]:list:' \
      '(--leave-via)*--leave-via=[leave via csv]:list:' \
      '(--leave-id)--leave-id=[leave id]:id:' \
      '(--initial-cluster)*--initial-cluster=[initial cluster]:c:' \
      '(--log-dir)--log-dir=[log dir]:dir:_files -/' \
      '*: :' && ret=0 ;;
  (bendsql)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-c --command)'{-c+,--command=}'[execute SQL]:sql:' \
      '(-f --file)'{-f+,--file=}'[execute file]:file:_files -g "*.sql"' \
      '(-l --log-level)'{-l+,--log-level=}'[log level]:l:(trace debug info warn error)' \
      '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive]' \
      '(--query)--query=[query]:q:' \
      '(--time)--time=[show timing]:t:(local server)' \
      '(--format)--format=[output format]:f:(table csv tsv null)' \
      '(--user)--user=[user]:u:_users' \
      '(--password)--password=[pass]:p:' \
      '(--host)--host=[host]:host:_hosts' \
      '(--port)--port=[port]:port:' \
      '(--database)--database=[db]:d:' \
      '(--role)--role=[role]:r:' \
      '(--warehouse)--warehouse=[warehouse]:w:' \
      '(--ssl)--ssl[use SSL]' \
      '(--auth-type)--auth-type=[auth type]:a:' \
      '(--dsn)--dsn=[DSN]:dsn:' \
      '(--quote-style)--quote-style=[quote style]:q:(necessary always never)' \
      '(--max-display-rows)--max-display-rows=[max rows]:n:' \
      '(--show-progress)--show-progress[show progress]' \
      '(--show-stats)--show-stats[show stats]' \
      '*: :' && ret=0 ;;
esac

return ret
