#compdef sigopt
# Documentation: https://docs.sigopt.com/ai-module-api-references/api_reference/cli
# SigOpt experiment-tracking and optimization command-line client

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    run\:"track and execute a model run"
    optimize\:"run an AI Experiment optimization"
    start-worker\:"start a new AI Experiment worker"
    init\:"initialize SigOpt in the current directory"
    config\:"configure the SigOpt client"
    experiment\:"manage experiments"
    project\:"manage projects"
    training-run\:"manage training runs"
    version\:"show version information"
  ))' \
  '*::arg:->args' && ret=0

return ret
