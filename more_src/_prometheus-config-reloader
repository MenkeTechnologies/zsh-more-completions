#compdef prometheus-config-reloader

# prometheus-config-reloader: sidecar to reload Prometheus on config/rule changes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--web.listen-address=[listen address]:addr:' \
  '--config-file=[Prometheus config file]:file:_files' \
  '--config-envsubst-file=[envsubst output file]:file:_files' \
  '--reload-url=[reload URL]:url:' \
  '--watched-dir=[watched directory]:dir:_files -/' \
  '--rules-dir=[rules dir]:dir:_files -/' \
  '--watch-interval=[watch interval]:duration:' \
  '--retry-interval=[retry interval]:duration:' \
  '--listen-address=[listen address]:addr:' \
  '--log-format=[log format]:fmt:(logfmt json)' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '*::prometheus-config-reloader args:_files' && ret=0
return ret
