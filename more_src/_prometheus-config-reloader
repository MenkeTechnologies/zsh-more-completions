#compdef prometheus-config-reloader
# Documentation: https://github.com/prometheus-operator/prometheus-operator/tree/main/cmd/prometheus-config-reloader
# Reference accessed: 2026-05-20
# Verified: upstream cmd/prometheus-config-reloader/main.go kingpin flags.

# prometheus-config-reloader: sidecar to reload Prometheus on config/rule changes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config-file=[Prometheus config file watched by the reloader]:file:_files' \
  '--config-envsubst-file=[envsubst output file for substituted config]:file:_files' \
  '--watch-interval=[interval for re-reading config; 0 runs once and exits]:duration:' \
  '--delay-interval=[wait before reloading after detecting a change]:duration:' \
  '--retry-interval=[wait before retrying after endpoint error]:duration:' \
  '--reload-timeout=[timeout for response from reload URL]:duration:' \
  '--auto-gomemlimit-ratio=[ratio of GOMEMLIMIT to container/system memory]:ratio:' \
  '*--watched-dir=[directory to watch non-recursively]:dir:_files -/' \
  '--reload-method=[reload method]:method:(http signal)' \
  '--process-executable-name=[executable name for signal-based reload]:name:' \
  '--statefulset-ordinal-from-envvar=[env var to parse for StatefulSet ordinal]:envvar:' \
  '--listen-address=[address for metrics exposure]:addr:' \
  '--web-config-file=[TLS/authentication config file]:file:_files' \
  '--log-format=[log format]:fmt:(logfmt json)' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--reload-url=[URL to trigger configuration reload]:url:' \
  '--runtimeinfo-url=[URL to check runtime config status]:url:' && ret=0
return ret
