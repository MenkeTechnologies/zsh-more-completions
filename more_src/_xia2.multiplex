#compdef xia2.multiplex
# Documentation: https://xia2.github.io/multiplex/index.html
# Multi-crystal data reduction: scale, symmetry, filter and merge many datasets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'resolution.d_min=[manually override the automatically determined resolution]:d' \
  'symmetry.space_group=[manually override the automatically determined space group]:sg' \
  '*:arg:_files' && ret=0

return ret
