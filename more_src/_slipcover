#compdef slipcover
# Documentation: https://github.com/plasma-umass/slipcover
# slipcover - near-zero-overhead Python code coverage

local ret=1

_arguments -s -S \
  '--branch[measure both branch and line coverage]' \
  '--json[select JSON output]' \
  '--pretty-print[pretty-print JSON output]' \
  '--xml[select XML output]' \
  '--xml-package-depth=[directory depth identified as packages in report]:depth:' \
  '--out=[specify output file name]:file:_files' \
  '*--source=[specify directories to cover]:dir:_files -/' \
  '*--omit=[specify files to omit]:file:_files' \
  '--immediate[request immediate de-instrumentation]' \
  '--skip-covered[omit fully covered files from text output]' \
  '--fail-under=[fail with RC 2 if overall coverage below this]:pct:' \
  '--threshold=[threshold for de-instrumentation]:n:' \
  '--missing-width=[maximum width for missing column]:width:' \
  '-m[run given module as __main__]:module:' \
  '--merge[merge JSON coverage files saving to --out]' \
  '--version[show version and exit]' \
  '*:script:_files' && ret=0

return ret
