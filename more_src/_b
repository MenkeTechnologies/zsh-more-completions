#compdef b
# Documentation: https://build2.org/build2/doc/b.xhtml
# build2 build system driver

local ret=1

_arguments -s -S \
  '(-h --help)--help[print usage and exit]' \
  '--version[print version and exit]' \
  '(-v)-v[print actual commands being executed]' \
  '(-V)-V[print all underlying commands being executed]' \
  '(-q --quiet)'{-q,--quiet}'[run quietly, only printing errors]' \
  '--silent[run quietly, print errors in all contexts]' \
  '--verbose=[set diagnostics verbosity level (0-6)]:level:(0 1 2 3 4 5 6)' \
  '--stat[display build statistics]' \
  '--progress[show build progress]' \
  '--no-progress[suppress build progress display]' \
  '--diag-color[use color in diagnostics]' \
  '--no-diag-color[do not use color in diagnostics]' \
  '(-j --jobs)'{-j,--jobs}'=[number of parallel jobs]:jobs:' \
  '(-J --max-jobs)'{-J,--max-jobs}'=[maximum number of threads to create]:threads:' \
  '(-Q --queue-depth)'{-Q,--queue-depth}'=[queue depth multiplier over active jobs]:depth:' \
  '--jobserver=[GNU make jobserver type]:type:(fifo none)' \
  '--file-cache=[file cache implementation]:impl:(noop sync-lz4)' \
  '--max-stack=[max stack size in KBytes for new threads]:kb:' \
  '(-s --serial-stop)'{-s,--serial-stop}'[run serially and stop at first error]' \
  '(-n --dry-run)'{-n,--dry-run}'[print commands without executing them]' \
  '--match-only[match rules without executing the operation]' \
  '--load-only[load buildfiles without executing operations]' \
  '--no-external-modules[skip loading external modules during bootstrap]' \
  '--structured-result=[write results in structured format]:format:(lines json)' \
  '--mtime-check[enable file modification time sanity checks]' \
  '--no-mtime-check[disable file modification time sanity checks]' \
  '--dump=[dump build state after phase]:phase:(load match)' \
  '--dump-format=[dump format representation]:format:(buildfile json-v0.1)' \
  '--no-column[omit column numbers in diagnostics]' \
  '--no-line[omit line and column numbers in diagnostics]' \
  '--buildfile=[alternative file to read build information from]:file:_files' \
  '--config-guess=[path to config.guess script]:file:_files' \
  '--config-sub=[path to config.sub script]:file:_files' \
  '--pager=[pager program for displaying long text]:pager:_command_names -e' \
  '--pager-option=[additional option to pass to pager]:option:' \
  '--options-file=[read additional options from file]:file:_files' \
  '--default-options=[directory containing default options files]:dir:_files -/' \
  '--no-default-options[skip loading default options files]' \
  '*:target:_files' && ret=0

return ret
