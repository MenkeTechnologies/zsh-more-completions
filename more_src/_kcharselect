#compdef kcharselect
# Documentation: https://invent.kde.org/utilities/kcharselect
# Reference accessed: 2026-05-16
# Verified: upstream KDE kcharselect repo. KDE GUI app with no
# documented app-specific options.
# Removed from prior file: bogus man.archlinux.org search URL.

# kcharselect: KDE character chooser (GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' && ret=0
return ret
