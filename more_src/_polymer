#compdef polymer

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:production build'
  'init:initialize project from template'
  'install:install dependencies'
  'lint:analyze for issues'
  'serve:local web server'
  'test:run tests'
  'help:list of commands'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'polymer subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '--add-service-worker[add service worker]' \
          '--add-push-manifest[add push manifest]' \
          '--base-path=[base path]:path:' \
          '--browser-capabilities=[browser caps]:caps:' \
          '--bundle[bundle modules]' \
          '--css-minify[minify CSS]' \
          '--entrypoint=[entry point]:file:_files' \
          '--html-minify[minify HTML]' \
          '--js-compile[compile JS]' \
          '--js-minify[minify JS]' \
          '--js-transform-modules-to-amd[modules to AMD]' \
          '--js-transform-import-meta[transform import.meta]' \
          '--shell=[shell file]:file:_files' \
          '--preset=[build preset]:preset:' && ret=0
        ;;
      (lint)
        _arguments '--rules=[lint rules]:rules:' && ret=0
        ;;
      (serve)
        _arguments \
          '--npm[serve npm-style]' \
          '--module-resolution=[module resolution]:res:' \
          '--compile=[compile mode]:mode:' \
          '(-c --component-dir)'{-c,--component-dir=}'[components dir]:dir:_files -/' \
          '(-p --port)'{-p,--port=}'[port]:port:' \
          '--hostname=[hostname]:host:_hosts' \
          '--open[open browser]' \
          '--browser=[browser]:browser:' && ret=0
        ;;
    esac
    ;;
esac

return ret
