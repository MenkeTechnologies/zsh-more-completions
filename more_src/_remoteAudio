#compdef remoteAudio
# ============================================================================
# _remoteAudio — zsh completion for Tobias Wellnitz's NATS-based audio
#                streaming application for Amateur Radio
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/dh1tw/remoteAudio
#   Author     : Tobias Wellnitz (DH1TW)
#   License    : MIT
#   Language   : Go
#   Module     : github.com/dh1tw/remoteAudio  (Go 1.24.0)
#   Binary     : remoteAudio  (Makefile `go build` — preserves
#                module-name casing; emits `remoteAudio` on Unix,
#                `remoteAudio.exe` on Windows)
#   Last push  : 2026-05-19
#
# WHAT IT IS
#   remoteAudio is "an audio streaming application for Amateur Radio
#   purposes" — Tobias Wellnitz's PortAudio + Opus + NATS service that
#   sends and receives bi-directional voice between an operator's
#   workstation and a remote radio.  The server side runs near the
#   radio (sound-card connected to the radio's audio in/out), exposes
#   itself over NATS, and registers via go-micro service discovery so
#   multiple radios can be exposed under one broker.  The client side
#   discovers servers, selects one, streams audio out to a chosen
#   PortAudio output device, and captures microphone audio for
#   transmit (with optional vox / threshold).  A built-in web server
#   (Go templates + REST API) exposes volume, vox, server selection,
#   and TX/RX state for remote operation.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/{root,client,client_nats,
#                       server,server_nats,enumerate,version}.go
#                       spf13/cobra Command tree)
#   remoteAudio [PERSISTENT_FLAGS] <SUBCOMMAND>
#
#   Persistent flags (audio & opus, inherited by every subcommand):
#     --config <FILE>                Config file (default
#                                    `$HOME/.remoteAudio.yaml`)
#     --input-device-hostapi <API>   Host API for input device
#                                    [default: default]
#     -i, --input-device-name <NM>   Input audio device
#                                    [default: default]
#     --input-device-samplerate <HZ> Input sample rate    [default: 48000]
#     --input-device-latency <DUR>   Input latency        [default: 5ms]
#     --input-device-channels <N>    Input channels       [default: 1]
#     --output-device-hostapi <API>  Host API for output device
#     -o, --output-device-name <NM>  Output audio device  [default: default]
#     --output-device-samplerate <HZ> Output sample rate  [default: 48000]
#     --output-device-latency <DUR>  Output latency       [default: 5ms]
#     --output-device-channels <N>   Output channels      [default: 2]
#     --opus-application <PROFILE>   Opus encoder profile
#                                      voip / audio / restricted_lowdelay
#                                    [default: restricted_lowdelay]
#     --opus-bitrate <BPS>           Opus bitrate         [default: 32000]
#     --opus-complexity <0-10>       Opus encoder complexity [default: 9]
#     --opus-max-bandwidth <BW>      Opus max bandwidth
#                                      narrowband / mediumband /
#                                      wideband / superwideband / fullband
#                                    [default: wideband]
#     -f, --audio-frame-length <N>   Audio samples per frame [default: 480]
#     -R, --rx-buffer-length <N>     RX buffer length (frames) [default: 10]
#
#   Subcommands:
#     client                         Audio streaming client (transport
#                                    is selected as a sub-subcommand)
#       nats                         NATS-transport client
#         -u, --broker-url <HOST>      NATS broker host [default: localhost]
#         -p, --broker-port <PORT>     NATS broker port [default: 4222]
#         -U, --username <USER>        NATS username
#         -P, --password <PASS>        NATS password
#         -Y, --server-name <NAME>     Default audio server (e.g. ts480)
#         -w, --http-host <HOST>       Web-UI host  [default: 127.0.0.1]
#         -k, --http-port <PORT>       Web-UI port  [default: 9090]
#             --tx-volume <0-100>      TX volume on startup [default: 70]
#             --rx-volume <0-100>      RX volume on startup [default: 70]
#         -t, --stream-on-startup      Start streams immediately
#             --vox                    Enable VOX (voice activation)
#             --vox-threshold <0-1>    VOX threshold       [default: 0.1]
#             --vox-holdtime <DUR>     VOX hold time       [default: 500ms]
#
#     server                         Audio streaming server
#       nats                         NATS-transport server
#         -u, --broker-url <HOST>      NATS broker host
#         -p, --broker-port <PORT>     NATS broker port
#         -U, --username <USER>        NATS username
#         -P, --password <PASS>        NATS password
#         -Y, --server-name <NAME>     Server name (e.g. ts480)
#             --server-index <N>       Server index (GUI ordering) [default: 1]
#
#     enumerate                      List all PortAudio devices and
#                                    supported Host APIs (helper to
#                                    pick values for --input-device-*
#                                    and --output-device-*)
#     version                        Print remoteAudio version, git
#                                    commit hash, build time, Go
#                                    runtime, GOOS/GOARCH
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/nats-io/nats.go v1.41.2` declared
#   in go.mod — the canonical Go NATS.io client maintained by
#   Synadia / nats.io (nats-io/nats.go), the reference async-first
#   Go client supporting Core NATS pub/sub, JetStream persistence,
#   Object Store, Key-Value, and request/reply.  remoteAudio imports
#   `"github.com/nats-io/nats.go"` directly in both `cmd/client_nats.go`
#   and `cmd/server_nats.go` to publish Opus-encoded audio frames on
#   `audio.in.<server>` subjects and subscribe to `audio.out.<server>`
#   for the opposite direction;  go-micro plugins layer service
#   discovery on top of the same connection.  Verified via:
#     gh api repos/dh1tw/remoteAudio/contents/go.mod
#       → github.com/nats-io/nats.go v1.41.2
#     gh api repos/dh1tw/remoteAudio/contents/cmd/client_nats.go
#       → import "github.com/nats-io/nats.go"
#   This entry is the Go=125 leader bump that continues Axis 70
#   (NATS.io Client Library) opened at R869 with Rust=async-nats 0.49
#   (bytecodealliance/wrpc / wrpc-wasmtime).
#
#   No completion for `remoteAudio` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_remoteAudio() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--config=[config file (default $HOME/.remoteAudio.yaml)]:config file:_files -g "*.{yaml,yml,toml}"' \
        '--input-device-hostapi=[host API for input device]:host API:' \
        '(-i --input-device-name)'{-i+,--input-device-name=}'[input audio device]:device:' \
        '--input-device-samplerate=[input sample rate (default 48000)]:Hz:' \
        '--input-device-latency=[input latency (default 5ms)]:duration:' \
        '--input-device-channels=[input channels (default 1)]:channels:' \
        '--output-device-hostapi=[host API for output device]:host API:' \
        '(-o --output-device-name)'{-o+,--output-device-name=}'[output audio device]:device:' \
        '--output-device-samplerate=[output sample rate (default 48000)]:Hz:' \
        '--output-device-latency=[output latency (default 5ms)]:duration:' \
        '--output-device-channels=[output channels (default 2)]:channels:' \
        '--opus-application=[opus encoder profile]:profile:(voip audio restricted_lowdelay)' \
        '--opus-bitrate=[opus bitrate (default 32000)]:bps:' \
        '--opus-complexity=[opus encoder complexity 0-10 (default 9)]:complexity:' \
        '--opus-max-bandwidth=[opus max bandwidth]:bandwidth:(narrowband mediumband wideband superwideband fullband)' \
        '(-f --audio-frame-length)'{-f+,--audio-frame-length=}'[audio samples per frame (default 480)]:samples:' \
        '(-R --rx-buffer-length)'{-R+,--rx-buffer-length=}'[RX buffer length in frames (default 10)]:frames:' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_remoteAudio_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                client)  _remoteAudio_client  && ret=0 ;;
                server)  _remoteAudio_server  && ret=0 ;;
                enumerate|version)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_remoteAudio_commands] )) ||
_remoteAudio_commands() {
    local -a commands
    commands=(
        'client:audio streaming client'
        'server:audio streaming server'
        'enumerate:list all PortAudio devices and supported Host APIs'
        'version:print remoteAudio version, commit hash, and build info'
    )
    _describe -t commands 'remoteAudio command' commands
}

(( $+functions[_remoteAudio_client] )) ||
_remoteAudio_client() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '1:transport:(nats)' \
        '*::arg:->cargs' && ret=0

    case $state in
        cargs)
            case $words[1] in
                nats)  _remoteAudio_client_nats && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_remoteAudio_client_nats] )) ||
_remoteAudio_client_nats() {
    _arguments \
        '(-u --broker-url)'{-u+,--broker-url=}'[NATS broker host (default localhost)]:host:_hosts' \
        '(-p --broker-port)'{-p+,--broker-port=}'[NATS broker port (default 4222)]:port:' \
        '(-U --username)'{-U+,--username=}'[NATS username]:user:_users' \
        '(-P --password)'{-P+,--password=}'[NATS password]:password:' \
        '(-Y --server-name)'{-Y+,--server-name=}'[default audio server (e.g. ts480)]:server name:' \
        '(-w --http-host)'{-w+,--http-host=}'[web UI host (default 127.0.0.1)]:host:_hosts' \
        '(-k --http-port)'{-k+,--http-port=}'[web UI port (default 9090)]:port:' \
        '--tx-volume=[TX volume on startup 0-100 (default 70)]:volume:' \
        '--rx-volume=[RX volume on startup 0-100 (default 70)]:volume:' \
        '(-t --stream-on-startup)'{-t,--stream-on-startup}'[start streams immediately on startup]' \
        '--vox[enable VOX (voice activation)]' \
        '--vox-threshold=[VOX threshold 0-1 (default 0.1)]:threshold:' \
        '--vox-holdtime=[VOX hold time (default 500ms)]:duration:' \
        '(- *)'{-h,--help}'[help]'
}

(( $+functions[_remoteAudio_server] )) ||
_remoteAudio_server() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '1:transport:(nats)' \
        '*::arg:->sargs' && ret=0

    case $state in
        sargs)
            case $words[1] in
                nats)  _remoteAudio_server_nats && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_remoteAudio_server_nats] )) ||
_remoteAudio_server_nats() {
    _arguments \
        '(-u --broker-url)'{-u+,--broker-url=}'[NATS broker host (default localhost)]:host:_hosts' \
        '(-p --broker-port)'{-p+,--broker-port=}'[NATS broker port (default 4222)]:port:' \
        '(-U --username)'{-U+,--username=}'[NATS username]:user:_users' \
        '(-P --password)'{-P+,--password=}'[NATS password]:password:' \
        '(-Y --server-name)'{-Y+,--server-name=}'[server name (e.g. ts480)]:server name:' \
        '--server-index=[server index for GUI ordering (default 1)]:index:' \
        '(- *)'{-h,--help}'[help]'
}

_remoteAudio "$@"
