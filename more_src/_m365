#compdef m365

local curcontext="$curcontext" state line ret=1
local -a top_groups commands

commands=(
  'login:log in to Microsoft 365'
  'logout:log out of Microsoft 365'
  'status:show login status'
  'help:show help'
  'version:show CLI version'
  'request:execute a raw Microsoft Graph or SPO REST request'
  'context:manage CLI context'
  'cli:manage CLI configuration / completion / docs'
  'setup:initial CLI setup'
  'consent:consent to permissions'
  'docs:open the CLI docs'
)

top_groups=(
  'spo:SharePoint Online commands'
  'entra:Microsoft Entra ID (Azure AD) commands'
  'aad:legacy Azure AD commands (alias of entra)'
  'teams:Microsoft Teams commands'
  'planner:Microsoft Planner commands'
  'todo:Microsoft To Do commands'
  'outlook:Outlook commands'
  'onedrive:OneDrive commands'
  'graph:Microsoft Graph commands'
  'flow:Power Automate (Flow) commands'
  'pa:Power Apps commands'
  'pp:Power Platform commands'
  'tenant:tenant-level commands'
  'search:Search commands'
  'purview:Purview compliance commands'
  'viva:Viva commands'
  'app:Application registration commands'
  'file:Microsoft Graph file commands'
  'oneNote:OneNote commands'
  'yammer:Yammer commands (deprecated)'
  'booking:Microsoft Bookings commands'
  'skype:Skype commands'
  'spfx:SharePoint Framework project commands'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--query=[JMESPath query]:query:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(csv json md text)' \
  '--debug[debug output]' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _alternative \
      'cmds:command:_describe -t cmds "command" commands' \
      'grps:group:_describe -t grps "group" top_groups' && ret=0 ;;
  (args)
    case $line[1] in
      (login)
        _arguments \
          '(-t --authType)'{-t+,--authType=}'[auth type]:type:(certificate deviceCode password identity browser secret)' \
          '(-u --userName)'{-u+,--userName=}'[username]:user:' \
          '(-p --password)'{-p+,--password=}'[password]:pass:' \
          '(-c --certificateFile)'{-c+,--certificateFile=}'[certificate file]:file:_files' \
          '--certificateBase64Encoded=[base64 cert]:cert:' \
          '--thumbprint=[certificate thumbprint]:thumbprint:' \
          '--appId=[application id]:appId:' \
          '--tenant=[tenant id]:tenant:' \
          '--secret=[client secret]:secret:' && ret=0 ;;
      (cli)
        _arguments '*::sub:(config completion docs reconsent)' && ret=0 ;;
      (context)
        _arguments '*::sub:(init remove option)' && ret=0 ;;
    esac ;;
esac

return ret
