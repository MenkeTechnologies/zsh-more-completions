#compdef fedify
# Documentation: https://man.archlinux.org/search?q=fedify
# Reference accessed: 2026-05-16

# fedify-dev/fedify packages/cli (Deno compile); Homebrew: Formula/f/fedify.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'fedify command' compadd -- init create serve dev build preview deploy completions proxy cert
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
