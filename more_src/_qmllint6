#compdef qmllint6 qmllint-qt6
# _qmllint6 — Qt Project qmllint6 CLI Qt 6 QML JavaScript static analysis linter for .qml files detecting syntax errors property bindings type mismatches unused imports incompatible signal handlers Qt-Quick-Controls-version mismatches typescript-style level filtering (Qt Project team, C++); getopt
# upstream: https://doc.qt.io/qt-6/qtquick-tool-qmllint.html

_qmllint6() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-s+[silent]:str:' \
        '--silent[silent mode]' \
        '-j+[json output]:file:_files' \
        '--json=+[json output]:file:_files' \
        '-I+[import path]:dir:_files -/' \
        '--include-path=+[path]:dir:_files -/' \
        '-i+[ignore file]:file:_files' \
        '--ignore=+[file]:file:_files' \
        '-W+[warning enable]:str:' \
        '--warnings=+[level]:l:(disable info warning error)' \
        '-q[no warnings]' \
        '--qmllint-disable=+[ids]:str:' \
        '--qmllint-only=+[ids]:str:' \
        '--compiler=+[w]:w:(warning error)' \
        '--controls-sanity=+[w]:w:(warning error disable)' \
        '--multiline-strings=+[w]:w:(warning error info)' \
        '--unqualified=+[w]:w:(warning error info)' \
        '--unused-imports=+[w]:w:(warning error info)' \
        '--deprecated=+[w]:w:(warning error info)' \
        '--with-implicit-component=+[w]:w:(warning error info)' \
        '--resource=+[qrc file]:file:_files -g "*.qrc"' \
        '-r+[qrc file]:file:_files -g "*.qrc"' \
        '--bare[bare mode]' \
        '--module[module mode]' \
        '--fix[apply suggested fixes]' \
        '-f[apply suggested fixes]' \
        '*:qml file:_files -g "*.qml"'
}

_qmllint6 "$@"
