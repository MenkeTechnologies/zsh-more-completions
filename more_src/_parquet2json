#compdef parquet2json
# Documentation: https://man.archlinux.org/search?q=parquet2json
# Reference accessed: 2026-05-16

# Zsh completion for parquet2json (jupiter/parquet2json).

local -a subcmds
subcmds=(
  'cat:stream rows as JSON lines'
  'schema:print Thrift schema'
  'rowcount:print total row count'
)

local context state line
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:parquet input (path URL or s3:):' \
  '2:subcommand:->subcmd' \
  '*::options:->opts' && return 0

case $state in
  subcmd)
    _describe 'parquet2json command' subcmds
    ;;
  opts)
    case $words[2] in
      cat)
        _arguments -s -S \
          '(-o --offset)'{-o,--offset=}'[first row index or negative from end]:offset:' \
          '(-l --limit)'{-l,--limit=}'[max rows]:count:' \
          '(-c --columns)'{-c,--columns=}'[comma-separated column names]:columns:' \
          '(-n --nulls)'{-n,--nulls}'[emit JSON nulls]'
        ;;
      schema|rowcount)
        _nothing
        ;;
      *)
        _nothing
        ;;
    esac
    ;;
esac
