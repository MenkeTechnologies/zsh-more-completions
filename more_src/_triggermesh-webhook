#compdef triggermesh-webhook
# _triggermesh-webhook — TriggerMesh admission webhook (sharedmain; validates + defaults the Source/Target/Transformation/Flow CRDs)
# upstream: https://github.com/triggermesh/triggermesh
# Source: cmd/triggermesh-webhook/main.go on tip — sharedmain-based; runtime config lives in ConfigMaps watched by knative.dev/pkg/configmap.

_triggermesh-webhook() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_triggermesh-webhook "$@"
