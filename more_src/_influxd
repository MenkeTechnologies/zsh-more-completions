#compdef influxd

# Zsh completion for InfluxDB daemon (influxd)

local curcontext="$curcontext" state line ret=1

local -a influxd_commands
influxd_commands=(
  'downgrade:downgrade metadata schema'
  'help:help about any command'
  'inspect:commands for inspecting on-disk database data'
  'print-config:print the full InfluxDB configuration'
  'recovery:commands for recovering data'
  'run:start the influxd server (default)'
  'upgrade:upgrade from InfluxDB v1.x to v2.x'
  'version:print version information'
)

local -a influxd_global_flags
influxd_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -s -S \
  $influxd_global_flags \
  '--version[print version]' \
  '1:command:_describe -t commands command influxd_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      run)
        _arguments -s -S \
          $influxd_global_flags \
          '--assets-path=[override default assets path]:path:_directories' \
          '--bolt-path=[path to BoltDB file]:file:_files' \
          '--e2e-testing[enable end-to-end testing features]' \
          '--engine-path=[path to persistent engine files]:directory:_directories' \
          '--feature-flags=[feature flags]:flags:' \
          '--flux-log-enabled[enable Flux query logging]' \
          '--hardening-enabled[enable hardening options]' \
          '--http-bind-address=[HTTP bind address]:address:' \
          '--http-idle-timeout=[max idle time for HTTP connections]:duration:' \
          '--http-read-header-timeout=[max time to read HTTP headers]:duration:' \
          '--http-read-timeout=[max time to read HTTP request]:duration:' \
          '--http-write-timeout=[max time to write HTTP response]:duration:' \
          '--influxql-max-select-buckets=[max number of group-by time buckets]:count:' \
          '--influxql-max-select-point=[max number of points in SELECT]:count:' \
          '--influxql-max-select-series=[max number of series in SELECT]:count:' \
          '--instance-id=[instance ID]:id:' \
          '--log-level=[log level]:level:(debug info warn error)' \
          '--metrics-disabled[disable /metrics endpoint]' \
          '--nats-max-payload-bytes=[max NATS message payload]:bytes:' \
          '--nats-port=[NATS port]:port:' \
          '--no-tasks[disable task scheduler]' \
          '--pprof-disabled[disable /debug/pprof endpoint]' \
          '--query-concurrency=[max concurrent queries]:count:' \
          '--query-initial-memory-bytes=[initial memory bytes for a query]:bytes:' \
          '--query-max-memory-bytes=[max memory bytes for a query]:bytes:' \
          '--query-memory-bytes=[max memory bytes for all queries]:bytes:' \
          '--query-queue-size=[max queries allowed in queue]:count:' \
          '--reporting-disabled[disable usage reporting]' \
          '--secret-store=[secret store backend]:store:(bolt vault)' \
          '--session-length=[duration of user session]:minutes:' \
          '--session-renew-disabled[disable session renewal on activity]' \
          '--sqlite-path=[path to SQLite database]:file:_files' \
          '--storage-cache-max-memory-size=[max cache memory]:bytes:' \
          '--storage-cache-snapshot-memory-size=[cache snapshot trigger size]:bytes:' \
          '--storage-cache-snapshot-write-cold-duration=[cold duration for cache snapshot]:duration:' \
          '--storage-compact-full-write-cold-duration=[cold duration for full compaction]:duration:' \
          '--storage-compact-throughput-burst=[compaction throughput burst]:bytes:' \
          '--storage-max-concurrent-compactions=[max concurrent compactions]:count:' \
          '--storage-max-index-log-file-size=[max TSI index log file size]:bytes:' \
          '--storage-no-validate-field-size[skip field size validation]' \
          '--storage-retention-check-interval=[retention policy check interval]:duration:' \
          '--storage-series-file-max-concurrent-snapshot-compactions=[max concurrent series file compactions]:count:' \
          '--storage-series-id-set-cache-size=[series ID set cache size]:size:' \
          '--storage-shard-precreator-advance-period=[shard precreator advance period]:duration:' \
          '--storage-shard-precreator-check-interval=[shard precreator check interval]:duration:' \
          '--storage-tsm-use-madv-willneed[use madvise willneed for TSM files]' \
          '--storage-validate-keys[validate TSM keys]' \
          '--storage-wal-fsync-delay=[WAL fsync delay]:duration:' \
          '--storage-wal-max-concurrent-writes=[max concurrent WAL writes]:count:' \
          '--storage-wal-max-write-delay=[max WAL write delay]:duration:' \
          '--storage-write-timeout=[write timeout]:duration:' \
          '--store=[data store]:store:(disk memory)' \
          '--testing-always-allow-setup[always allow setup even if already set up]' \
          '--tls-cert=[TLS certificate file]:cert:_files' \
          '--tls-key=[TLS private key file]:key:_files' \
          '--tls-min-version=[minimum TLS version]:version:(1.0 1.1 1.2 1.3)' \
          '--tls-strict-ciphers[restrict to strong TLS ciphers]' \
          '--tracing-type=[tracing type]:type:(log jaeger)' \
          '--ui-disabled[disable the InfluxDB UI]' \
          '--vault-addr=[Vault server address]:address:' \
          '--vault-cacert=[CA cert for Vault server]:file:_files' \
          '--vault-capath=[CA cert directory for Vault]:directory:_directories' \
          '--vault-client-cert=[client cert for Vault]:file:_files' \
          '--vault-client-key=[client key for Vault]:file:_files' \
          '--vault-client-timeout=[Vault client timeout]:duration:' \
          '--vault-max-retries=[max retries for Vault]:count:' \
          '--vault-skip-verify[skip TLS verification for Vault]' \
          '--vault-tls-server-name=[Vault TLS server name]:name:' \
          '--vault-token=[Vault token]:token:' && ret=0
        ;;
      inspect)
        local -a inspect_commands
        inspect_commands=(
          'build-tsi:rebuild the TSI index'
          'compact-series-file:compact the series file'
          'delete-tsm:delete a measurement in a raw TSM file'
          'dump-tsi:dump low-level details about TSI files'
          'dump-tsm:dump low-level details about TSM files'
          'dump-wal:dump low-level details about WAL files'
          'export-index:export TSI index data'
          'export-lp:export data as line protocol'
          'merge-schema:merge schema files'
          'report-db:estimate on-disk database size'
          'report-tsi:report information about TSI files'
          'report-tsm:report information about TSM files'
          'verify-seriesfile:verify the integrity of series files'
          'verify-tombstone:verify the integrity of tombstones'
          'verify-tsm:verify the integrity of TSM files'
          'verify-wal:verify the integrity of WAL files'
        )
        _arguments -s -S \
          $influxd_global_flags \
          '1:inspect command:_describe -t commands command inspect_commands' \
          '*::inspect args:' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          $influxd_global_flags \
          '--bolt-path=[path for new BoltDB file]:file:_files' \
          '--config-file=[path to v1 config file]:file:_files' \
          '--continuous-query-export-path=[path for CQ export]:file:_files' \
          '--engine-path=[path for new engine files]:directory:_directories' \
          '--force[skip confirmation]' \
          '--influx-configs-path=[path to influx CLI configs]:file:_files' \
          '--log-level=[log level]:level:(debug info warn error)' \
          '--log-path=[path to upgrade log]:file:_files' \
          '--overwrite-existing-v2[overwrite existing v2 data]' \
          '--password=[password for initial user]:password:' \
          '--username=[username for initial user]:username:' \
          '--v1-dir=[path to v1 data directory]:directory:_directories' \
          '-v[verbose output]' \
          '--verbose[verbose output]' && ret=0
        ;;
      downgrade)
        _arguments -s -S \
          $influxd_global_flags \
          '--bolt-path=[path to BoltDB file]:file:_files' \
          '--config-file=[path to config file]:file:_files' \
          '--engine-path=[path to engine files]:directory:_directories' \
          '--force[skip confirmation]' \
          '--log-level=[log level]:level:(debug info warn error)' \
          '--sqlite-path=[path to SQLite file]:file:_files' \
          '1:target version:' && ret=0
        ;;
      recovery)
        local -a recovery_commands
        recovery_commands=(
          'auth:manage authorizations for recovery'
          'org:manage organizations for recovery'
          'user:manage users for recovery'
        )
        _arguments -s -S \
          $influxd_global_flags \
          '1:recovery command:_describe -t commands command recovery_commands' \
          '*::recovery args:' && ret=0
        ;;
      print-config)
        _arguments -s -S \
          $influxd_global_flags \
          '--key-name=[specific config key to print]:key:' && ret=0
        ;;
      *)
        _arguments -s -S $influxd_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
