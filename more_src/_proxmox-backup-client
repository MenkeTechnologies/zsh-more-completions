#compdef proxmox-backup-client

# Zsh completion for proxmox-backup-client - Proxmox Backup Server client

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'backup:create a new backup'
  'restore:restore a backup'
  'list:list backups'
  'prune:prune backup groups'
  'status:show repository status'
  'garbage-collect:run garbage collection'
  'login:log in to the backup server'
  'logout:log out from the backup server'
  'snapshot:manage backup snapshots'
  'catalog:dump catalog contents'
  'key:manage encryption keys'
  'mount:mount a backup snapshot via FUSE'
  'map:map a drive image from a backup snapshot'
  'unmap:unmap a drive image'
  'version:show version'
  'benchmark:run benchmarks'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'proxmox-backup-client command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (backup)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repository=[backup repository]:repository' \
          '--backup-type=[backup type]:type:(vm ct host)' \
          '--backup-id=[backup ID]:id' \
          '--include-dev=[include device mountpoints]:device' \
          '--exclude=[exclude paths]:pattern' \
          '--all-file-systems[include all mounted filesystems]' \
          '--entries-max=[max number of entries]:count' \
          '--verbose[verbose output]' \
          '--skip-lost-and-found[skip lost+found directories]' \
          '--keyfile=[path to encryption key]:file:_files' \
          '--encrypt[encrypt backup data]' \
          '--ns=[backup namespace]:namespace' \
          '--change-detection-mode=[change detection]:mode:(data metadata)' \
          '*:backup spec' && ret=0
        ;;
      (restore)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repository=[backup repository]:repository' \
          '--keyfile=[path to encryption key]:file:_files' \
          '--ns=[backup namespace]:namespace' \
          '1:snapshot' \
          '2:archive name' \
          '3:target:_files' && ret=0
        ;;
      (list)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repository=[backup repository]:repository' \
          '--ns=[backup namespace]:namespace' \
          '--output-format=[output format]:format:(text json)' && ret=0
        ;;
      (prune)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repository=[backup repository]:repository' \
          '--ns=[backup namespace]:namespace' \
          '--keep-last=[keep last N backups]:count' \
          '--keep-hourly=[keep hourly for N hours]:count' \
          '--keep-daily=[keep daily for N days]:count' \
          '--keep-weekly=[keep weekly for N weeks]:count' \
          '--keep-monthly=[keep monthly for N months]:count' \
          '--keep-yearly=[keep yearly for N years]:count' \
          '--dry-run[only show what would be pruned]' \
          '--backup-type=[backup type]:type:(vm ct host)' \
          '--backup-id=[backup ID]:id' && ret=0
        ;;
      (snapshot)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(list files forget protected)' && ret=0
        ;;
      (login|logout|status|garbage-collect|version|benchmark)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repository=[backup repository]:repository' && ret=0
        ;;
      (key)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(create change-passphrase show-key paper-key)' && ret=0
        ;;
      (mount)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repository=[backup repository]:repository' \
          '--keyfile=[path to encryption key]:file:_files' \
          '--ns=[backup namespace]:namespace' \
          '1:snapshot' \
          '2:archive name' \
          '3:mount point:_files -/' && ret=0
        ;;
      (map)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repository=[backup repository]:repository' \
          '--keyfile=[path to encryption key]:file:_files' \
          '1:snapshot' \
          '2:archive name' && ret=0
        ;;
      (unmap)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:device or name' && ret=0
        ;;
      (catalog)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repository=[backup repository]:repository' \
          '--keyfile=[path to encryption key]:file:_files' \
          '1:snapshot' && ret=0
        ;;
    esac
    ;;
esac

return ret
