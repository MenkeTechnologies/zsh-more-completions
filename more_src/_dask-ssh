#compdef dask-ssh
# Documentation: https://docs.dask.org/en/stable/deploying-cli.html
# dask-ssh - launch a Dask cluster over SSH on a set of hosts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--scheduler=[specify scheduler node, defaults to first address]:node' \
  '--scheduler-port=[specify scheduler port number]:port' \
  '--nthreads=[number of threads per worker process]:threads' \
  '--nworkers=[number of worker processes per host]:n' \
  '--hostfile=[textfile with hostnames/IP addresses]:file:_files' \
  '--ssh-username=[username to use when establishing SSH connections]:user:_users' \
  '--ssh-port=[port to use for SSH connections]:port' \
  '--ssh-private-key=[private key file to use for SSH connections]:file:_files' \
  '--nohost[do not pass the hostname to the worker]' \
  '--log-directory=[directory to use on all nodes for dask output]:dir:_files -/' \
  '--local-directory=[directory to use on all nodes for workers files]:dir:_files -/' \
  '--remote-python=[path to Python on remote nodes]:path:_files' \
  '--memory-limit=[bytes of memory that the worker can use]:limit' \
  '--worker-port=[serving computation port, defaults to random]:port' \
  '--nanny-port=[serving nanny port, defaults to random]:port' \
  '--remote-dask-worker=[worker to run]:worker' \
  '*:host:_hosts' && ret=0

return ret
