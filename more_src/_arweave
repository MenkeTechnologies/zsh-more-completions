#compdef arweave arweave-cli ar
# _arweave — Arweave Foundation arweave CLI for managing wallet keys uploading data to the permaweb querying transaction status GraphQL bundlers Irys SmartWeave contracts ArDrive Lite ArProfile (ArweaveTeam team, JavaScript); commander.js
# upstream: https://github.com/ArweaveTeam/arweave

_arweave() {
    local -a sub=(
        'balance:show wallet balance'
        'deploy:upload data to Arweave'
        'deploy-dir:upload directory'
        'deploy-file:upload single file'
        'transaction:show transaction'
        'tx:show transaction'
        'tx-status:show transaction status'
        'wallet:wallet operations'
        'wallet-export:export wallet'
        'wallet-import:import wallet'
        'wallet-save:save wallet'
        'price:estimate upload price'
        'reset:reset config'
        'tags:list tags'
        'list:list deployed files'
        'gateway:gateway operations'
        'helper:helper operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--gateway=+[url]:str:' \
        '-g+[url]:str:' \
        '--bundler=+[url]:str:' \
        '--key-file=+[file]:file:_files -g "*.json"' \
        '-k+[file]:file:_files -g "*.json"' \
        '--protocol=+[p]:p:(http https)' \
        '--host=+[host]:h:_hosts' \
        '--port=+[port]:n:' \
        '--no-color[no color]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'arweave subcommand' sub ;;
        args)
            case $words[1] in
                deploy|deploy-file|deploy-dir) _arguments \
                    '--tag=+[name=value]:str:' \
                    '--content-type=+[mime]:str:' \
                    '--package=+[b]:b:(true false)' \
                    '--dry-run[dry run]' \
                    '--force[force]' \
                    '*:file or dir:_files' ;;
                wallet) _arguments \
                    '1:action:(create get save export import balance address)' \
                    '*:wallet name:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_arweave "$@"
