#compdef marp

_marp() {
  _arguments \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '--allow-local-files[allow local file access]' \
    '--bespoke-progress[add progress bar to bespoke theme]' \
    '--bespoke-transition[add transition to bespoke theme]' \
    '(-c --config-file)'{-c,--config-file}'=[config file]:file:_files' \
    '--description=[set meta description]:description' \
    '--engine=[specify Marpit engine]:engine' \
    '--html[enable HTML tags]' \
    '--image=[convert to image]:format:(png jpeg)' \
    '--images=[convert slides to images]:format:(png jpeg)' \
    '--input-dir=[input directory]:directory:_directories' \
    '--jpg-quality=[JPEG quality (0-100)]:quality' \
    '(-o --output)'{-o,--output}'=[output file]:file:_files' \
    '--og-image=[set Open Graph image]:url' \
    '--pdf[convert to PDF]' \
    '--pdf-notes[add presenter notes to PDF]' \
    '--pdf-outlines[add outlines to PDF]' \
    '--pdf-outlines.headings[add heading outlines to PDF]' \
    '--pdf-outlines.pages[add page outlines to PDF]' \
    '--pptx[convert to PowerPoint]' \
    '(-p --preview)'{-p,--preview}'[open preview window]' \
    '(-s --server)'{-s,--server}'[start server mode]' \
    '--template=[template]:template:(bare bespoke)' \
    '--theme=[theme name or CSS file]:theme' \
    '--theme-set=[theme set path]:path:_files' \
    '--title=[set title of the document]:title' \
    '--url=[set canonical URL]:url' \
    '(-w --watch)'{-w,--watch}'[watch input file changes]' \
    '*:file:_files'
}

_marp "$@"
