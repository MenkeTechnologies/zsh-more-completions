#compdef dnadiff
# Documentation: https://manpages.debian.org/testing/mummer/dnadiff.1.en.html
# MUMmer wrapper for comparative analysis of two sequence sets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-d --delta)'{-d,--delta}'+[provide precomputed delta file]:file:_files -g "*.delta"' \
  '(-p --prefix)'{-p,--prefix}'+[output file prefix]:prefix' \
  ':reference:_files' \
  ':query:_files' && ret=0

return ret
