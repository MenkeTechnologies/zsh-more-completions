#compdef secret-tool libsecret-tool
# _libsecret-tool — GNOME libsecret secret-tool CLI manipulating the freedesktop org.freedesktop.secrets Secret Service API store storing looking up clearing searching arbitrary attribute key=value items in the GNOME Keyring KWallet Pass libsecret backend for shell scripting (GNOME team, C); custom argparse
# upstream: https://gitlab.gnome.org/GNOME/libsecret

_libsecret-tool() {
    local -a sub=(
        'store:store a secret'
        'lookup:print a stored secret value'
        'clear:clear matching secrets'
        'search:search for matching items'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--label=+[label]:str:' \
        '--unlock[unlock matching collection]' \
        '--all[match all items]' \
        '1:subcommand:->sub' \
        '*::attribute key=value:->args'

    case $state in
        sub) _describe -t commands 'secret-tool subcommand' sub ;;
    esac
}

_libsecret-tool "$@"
