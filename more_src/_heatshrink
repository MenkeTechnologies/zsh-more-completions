#compdef heatshrink
# _heatshrink — LZSS compressor for embedded systems (atomicobject/heatshrink)
# upstream: https://github.com/atomicobject/heatshrink
# Flags from heatshrink.c (getopt "hedi:w:l:v").

_heatshrink() {
    _arguments \
        '(- *)-h[show help]' \
        '(-e -d)-e[encode (compress, default)]' \
        '(-e -d)-d[decode (decompress)]' \
        '-v[verbose (print sizes and ratio)]' \
        '-i+[input buffer size (bytes)]:n:' \
        '-w+[log2 sliding window size]:n:' \
        '-l+[lookahead back-reference length bits]:n:' \
        '1:input file:_files' \
        '2:output file:_files'
}

_heatshrink "$@"
