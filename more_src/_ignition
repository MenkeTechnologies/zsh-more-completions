#compdef ignition
# Documentation: https://man.archlinux.org/search?q=ignition
# Reference accessed: 2026-05-16

# Zsh completion for ignition - Flatcar/CoreOS Ignition config validator

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--strict[fail on any warning]' \
  '*:Ignition config file:_files -g "*.ign *.json"'
