#compdef ionosctl
# _ionosctl — IONOS Cloud ionosctl official CLI for IONOS Cloud Compute DBaaS K8s and DNS APIs (ionos-cloud team, Go); cobra
# upstream: https://github.com/ionos-cloud/ionosctl

_ionosctl() {
    local -a sub=(
        'login:login to IONOS'
        'logout:remove credentials'
        'whoami:show current user'
        'config:configuration subcommands'
        'completion:generate completion'
        'token:token subcommands'
        'user:user subcommands'
        'group:group subcommands'
        'share:resource share subcommands'
        'role:role subcommands'
        'datacenter:data center subcommands'
        'server:server subcommands'
        'volume:volume subcommands'
        'nic:NIC subcommands'
        'lan:LAN subcommands'
        'image:image subcommands'
        'snapshot:snapshot subcommands'
        'natgateway:NAT gateway subcommands'
        'networkloadbalancer:NLB subcommands'
        'applicationloadbalancer:ALB subcommands'
        'targetgroup:target group subcommands'
        'k8s:Kubernetes subcommands'
        'container-registry:registry subcommands'
        'cr:container-registry alias'
        'dbaas:DBaaS subcommands'
        'dns:DNS subcommands'
        'logging-service:logging service subcommands'
        'autoscaling:autoscaling subcommands'
        'request:API request subcommands'
        'shell:open IONOS shell'
        'docs:generate docs'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-color[disable color]' \
        '--no-headers[no headers]' \
        '--output=+[format]:f:(text json json-pretty yaml)' \
        '-o+[format]:f:(text json json-pretty yaml)' \
        '--api-url=+[api url]:url:_urls' \
        '--config=+[config file]:file:_files' \
        '--cols=+[columns csv]:str:' \
        '--server-url=+[server url]:url:_urls' \
        '--force[force]' \
        '-f[force]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ionosctl subcommand' sub ;;
        args)
            case $words[1] in
                datacenter|server|volume|nic|lan|image|snapshot|natgateway|networkloadbalancer|applicationloadbalancer|targetgroup) _arguments '1:cmd:(create get list update delete)' ;;
                k8s) _arguments '1:k8s cmd:(cluster nodepool kubeconfig version stat)' ;;
                container-registry|cr) _arguments '1:registry cmd:(create get list update delete repo token names locations)' ;;
                dbaas) _arguments '1:dbaas cmd:(postgres mongo mariadb api-version)' ;;
                dns) _arguments '1:dns cmd:(zone record reverse-record snapshot quota)' ;;
                user|group|share|role) _arguments '1:cmd:(create get list update delete)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_ionosctl "$@"
