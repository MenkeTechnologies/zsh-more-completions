#compdef jack_rec
# Documentation: https://man.archlinux.org/search?q=jack_rec
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-f+[output filename]:file:_files' \
  '-d+[duration sec]:sec:' \
  '-b+[bitdepth]:bits:(16 24 32)' \
  '*:port:' && ret=0

return ret
