#compdef otbcli_VectorDataSetField
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_VectorDataSetField.html
# Orfeo ToolBox: set a field value on all geometries of a vector data

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input vector data file]:vector:_files' \
  '-out[output vector data file]:output:_files' \
  '-fn[field name to set]:name:' \
  '-fv[field value to assign]:value:' \
  '*::arg:_files' && ret=0

return ret
