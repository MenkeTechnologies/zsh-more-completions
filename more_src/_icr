#compdef icr
# Documentation: https://github.com/crystal-community/icr
# icr - interactive console for Crystal (REPL)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '*'{-r,--require}'[require a lib or local file at startup]:lib:' \
  '--disable-update-check[disable checking for new releases on startup]' \
  '*:file:_files' && ret=0

return ret
