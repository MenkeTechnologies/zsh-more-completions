#compdef git-annex

# Zsh completion for git-annex - manage files with git without checking content in

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'add:add files to annex'
  'get:get file content from a remote'
  'drop:drop file content'
  'copy:copy file content to/from a remote'
  'move:move file content to/from a remote'
  'sync:synchronize local repository with remotes'
  'init:initialize git-annex'
  'describe:change description of a repository'
  'initremote:create a new special remote'
  'enableremote:enable a special remote'
  'info:show information about the annex'
  'status:show the working tree status'
  'list:list annexed files'
  'whereis:show where file content is stored'
  'find:list available files'
  'unused:list unused data'
  'addunused:add back unused data'
  'dropunused:drop unused data'
  'log:show log of changes to files'
  'fsck:check consistency of annex'
  'fix:fix up symlinks'
  'lock:lock files to prevent modification'
  'unlock:unlock files for modification'
  'edit:alias for unlock'
  'merge:merge changes from remotes'
  'import:import files from a directory or special remote'
  'export:export content to a special remote'
  'assistant:daemon to keep repository in sync'
  'watch:daemon to watch for file changes'
  'webapp:launch the web app'
  'version:show version info'
  'help:show help'
  'config:get or set configuration'
  'wanted:get or set preferred content expression'
  'required:get or set required content expression'
  'group:get or set group membership'
  'groupwanted:get or set groupwanted expression'
  'dead:mark a repository as dead'
  'semitrust:return repository to default trust level'
  'trust:trust a repository'
  'untrust:do not trust a repository'
  'expire:expire repositories'
  'vicfg:edit configuration in vim'
  'migrate:change backend used for a file'
  'reinject:inject known file content'
  'unannex:undo accidental add'
  'uninit:de-initialize git-annex and clean up'
  'addurl:add a file from a url'
  'importfeed:import files from a podcast feed'
  'rmurl:remove url from a file'
  'registerurl:register url for a key'
  'setpresentkey:set present status of a key'
  'readpresentkey:read present status of a key'
  'checkpresentkey:check if key is present on a remote'
  'transferkey:transfer a key'
  'examinekey:examine a key'
  'calckey:calculate key for a file'
  'lookupkey:look up key used for a file'
  'fromkey:set up a file from a key'
  'tokey:alias for fromkey'
  'metadata:get or set metadata'
  'view:enter a metadata-based view'
  'vpop:pop out of a view'
  'vfilter:filter a view'
  'vcycle:cycle through view options'
  'vadd:add to a view'
  'pre-commit:run by git pre-commit hook'
)

local -a common_flags=(
  '(-f --force)'{-f,--force}'[allow actions that may lose data]'
  '--fast[avoid slow operations]'
  '(-a --auto)'{-a,--auto}'[automatic mode]'
  '--all[operate on all data]'
  '--branch[operate on files in a branch]:branch:'
  '--unused[operate on unused data]'
  '--failed[retry failed transfers]'
  '(-k --key)'{-k,--key}'[operate on a specific key]:key:'
  '--from[specify source remote]:remote:__git_annex_remotes'
  '--to[specify destination remote]:remote:__git_annex_remotes'
  '(-J --jobs)'{-J,--jobs}'[number of parallel jobs]:number:'
  '--json[enable JSON output]'
  '--json-progress[include progress in JSON output]'
  '--json-error-messages[include error messages in JSON output]'
  '(-q --quiet)'{-q,--quiet}'[quiet output]'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '(-d --debug)'{-d,--debug}'[show debug messages]'
  '--no-debug[disable debug messages]'
  '--numcopies[override numcopies setting]:number:'
  '--mincopies[override mincopies setting]:number:'
  '--time-limit[time limit for operations]:time:'
  '--backend[specify key-value backend]:backend:(SHA256E SHA256 SHA512E SHA512 SHA384E SHA384 SHA3_256E SHA3_256 SHA3_512E SHA3_512 SKEIN256E SKEIN256 SKEIN512E SKEIN512 SHA1E SHA1 MD5E MD5 WORM URL)'
  '(- *)'{-h,--help}'[show help]'
)

(( $+functions[__git_annex_remotes] )) ||
__git_annex_remotes() {
  local -a remotes
  remotes=(${(f)"$(git remote 2>/dev/null)"})
  _describe -t remotes 'remote' remotes
}

_arguments -s -S \
  $common_flags \
  '1:subcommand:->subcommand' \
  '*:file:_files' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'git-annex subcommand' subcommands && ret=0
    ;;
esac

return ret
