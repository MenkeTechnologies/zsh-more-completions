#compdef r.stream.snap
# Documentation: https://grass.osgeo.org/grass-stable/manuals/addons/r.stream.snap.html
# GRASS GIS addon: snaps point to modelled stream network

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--overwrite[allow output to overwrite existing maps]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  '*--input=[name of input vector points map]:map:' \
  '*--output=[name for output vector points map]:map:' \
  '*--stream_rast=[name of input raster map with stream network]:map:' \
  '*--accumulation=[name of input accumulation raster map]:map:' \
  '*--threshold=[minimum accumulation threshold to snap]:value:' \
  '*--radius=[maximum distance to snap in cells]:value:' \
  '*--memory=[maximum memory used in MB]:value:' && ret=0

return ret
