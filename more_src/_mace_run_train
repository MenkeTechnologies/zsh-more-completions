#compdef mace_run_train
# Documentation: https://mace-docs.readthedocs.io/en/latest/guide/training.html
# MACE: train a machine-learning interatomic potential

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--name=[name of the model and log file]:name' \
  '--train_file=[training data file]:file:_files' \
  '--valid_file=[validation dataset]:file:_files' \
  '--valid_fraction=[validation fraction of training set]:fraction' \
  '--test_file=[independent test dataset]:file:_files' \
  '--model=[model type]:model:(MACE ScaleShiftMACE AtomicDipolesMACE EnergyDipolesMACE)' \
  '--hidden_irreps=[control model size irreps]:irreps' \
  '--r_max=[cutoff radius in Angstroms]:radius' \
  '--batch_size=[training batch size]:size' \
  '--valid_batch_size=[validation batch size]:size' \
  '--max_num_epochs=[maximum training epochs]:epochs' \
  '--correlation=[body order expansion level]:order' \
  '--l_max=[angular resolution]:lmax' \
  '--num_interactions=[number of message passing layers]:num' \
  '--E0s=[isolated atom reference energies]:e0s' \
  '--config_type_weights=[weight distribution across config types]:weights' \
  '--energy_key=[keyword for reading energies]:key' \
  '--forces_key=[keyword for reading forces]:key' \
  '--stress_key=[keyword for stress tensor]:key' \
  '--dipole_key=[keyword for dipole moments]:key' \
  '--default_dtype=[precision]:dtype:(float64 float32)' \
  '--device=[computing device]:device:(cuda cpu mps)' \
  '--swa[enable stochastic weight averaging]' \
  '--start_swa=[epoch to begin SWA]:epoch' \
  '--ema[enable exponential moving average]' \
  '--amsgrad[use AMSGrad optimizer variant]' \
  '--restart_latest[continue from last checkpoint]' \
  '--eval_interval=[validation evaluation frequency]:interval' \
  '--patience=[early stopping patience]:patience' \
  '*:arg:_files' && ret=0

return ret
