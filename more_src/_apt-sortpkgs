#compdef apt-sortpkgs
# Documentation: man apt-sortpkgs(1)
# Source: Debian apt apt-sortpkgs (man) — sort APT package index files (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-s --source)'{-s,--source}'[use source index field ordering]' \
    '(-c --config-file)'{-c+,--config-file=}'[apt config file]:file:_files' \
    '(-o --option)*'{-o+,--option=}'[set option=value]:opt:_default' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '*:index file:_files' \
    && ret=0

return ret
