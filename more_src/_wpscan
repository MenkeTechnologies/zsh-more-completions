#compdef wpscan
# _wpscan — WPScan WordPress security scanner (WPScan team, Ruby); enumerate WP installations for authorized assessments
# upstream: https://github.com/wpscanteam/wpscan

_wpscan() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--hh[show extended help]' \
        '--version[show version]' \
        '--url+[target URL]:url:_urls' \
        '--server+[server type]:server:(apache iis nginx)' \
        '--force[do not check is wp]' \
        '--update[update db]' \
        '--no-update[skip db update]' \
        '--user-agent+[user agent]:str:' \
        '--random-user-agent[random ua]' \
        '--ua+[user agent]:str:' \
        '--http-auth+[basic auth]:str:' \
        '--proxy+[proxy URL]:url:_urls' \
        '--proxy-auth+[proxy auth]:str:' \
        '--cookie-string+[cookie string]:str:' \
        '--cookie-jar+[cookie jar]:file:_files' \
        '--request-timeout+[request timeout]:n:' \
        '--connect-timeout+[connect timeout]:n:' \
        '--disable-tls-checks[skip TLS verify]' \
        '--max-threads+[max threads]:n:' \
        '--throttle+[ms between requests]:n:' \
        '--output+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--format+[output format]:fmt:(cli json cli-no-color cli-no-colour)' \
        '-f+[output format]:fmt:' \
        '--detection-mode+[mode]:mode:(mixed passive aggressive)' \
        '--scope+[in-scope domains]:str:' \
        '--exclude-content-based+[exclude content regex]:regex:' \
        '--no-banner[no banner]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-color[no color]' \
        '--api-token+[WPScan API token]:str:' \
        '-t+[WPScan API token]:str:' \
        '--enumerate+[enumerate options]:options:' \
        '-e+[enumerate options]:options:' \
        '--exclude-usernames+[exclude usernames regex]:regex:' \
        '--usernames+[username list]:str:' \
        '--passwords+[passwords file]:file:_files' \
        '-P+[passwords file]:file:_files' \
        '--login-uri+[login URI]:str:' \
        '--multicall-max-passwords+[multicall passwords]:n:' \
        '--password-attack+[password attack]:attack:(wp-login xmlrpc xmlrpc-multicall)' \
        '*:url:_urls'
}

_wpscan "$@"
