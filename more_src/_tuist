#compdef tuist

_tuist_commands() {
  local -a commands=(
    'build:Build the project'
    'cache:Cache frameworks as xcframeworks'
    'clean:Clean project artifacts'
    'dump:Dump the project manifest'
    'edit:Edit the project manifest'
    'fetch:Fetch remote dependencies'
    'generate:Generate the Xcode project'
    'graph:Export dependency graph'
    'init:Initialize a new project'
    'install:Install project dependencies'
    'migration:Utilities for migrating to Tuist'
    'plugin:Manage Tuist plugins'
    'run:Run a scheme'
    'scaffold:Scaffold files from a template'
    'signing:Manage code signing'
    'test:Test the project'
    'version:Print the current version'
  )
  _describe 'command' commands
}

_tuist() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--help-env[Show environment help]' \
    '--verbose[Enable verbose output]' \
    '--no-color[Disable colored output]' \
    '1:command:_tuist_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        generate)
          _arguments \
            '--path[Path to the project]:path:_directories' \
            '--open[Open the project after generating]' \
            '--no-open[Do not open the project]' \
            '*:targets:'
          ;;
        build)
          _arguments \
            '--path[Path to the project]:path:_directories' \
            '--scheme[Scheme to build]:scheme:' \
            '--generate[Generate before building]' \
            '--clean[Clean before building]' \
            '--configuration[Build configuration]:config:(Debug Release)' \
            '--build-output-path[Build output path]:path:_directories' \
            '--device[Device to build for]:device:' \
            '--os[OS version]:version:' \
            '--rosetta[Build for Rosetta]' \
            '*:targets:'
          ;;
        test)
          _arguments \
            '--path[Path to the project]:path:_directories' \
            '--scheme[Scheme to test]:scheme:' \
            '--clean[Clean before testing]' \
            '--configuration[Build configuration]:config:(Debug Release)' \
            '--device[Device to test on]:device:' \
            '--os[OS version]:version:' \
            '--skip-ui-tests[Skip UI tests]' \
            '--result-bundle-path[Result bundle path]:path:_directories' \
            '--retry-count[Number of retries]:count:' \
            '*:targets:'
          ;;
        init)
          _arguments \
            '--path[Path for the project]:path:_directories' \
            '--name[Project name]:name:' \
            '--template[Template to use]:template:' \
            '--platform[Platform]:platform:(ios macos tvos watchos visionos)'
          ;;
        scaffold)
          _arguments \
            '--path[Path to the project]:path:_directories' \
            '--json[Output as JSON]' \
            '1:template:'
          ;;
        graph)
          _arguments \
            '--path[Path to the project]:path:_directories' \
            '--format[Output format]:format:(dot json png svg)' \
            '--output-path[Output path]:path:_directories' \
            '--skip-test-targets[Skip test targets]' \
            '--skip-external-dependencies[Skip external dependencies]' \
            '*:targets:'
          ;;
        clean)
          _arguments \
            '--path[Path to the project]:path:_directories' \
            '*:clean category:(dependencies builds tests plugins)'
          ;;
        fetch|install)
          _arguments \
            '--path[Path to the project]:path:_directories' \
            '--update[Update dependencies]'
          ;;
      esac
      ;;
  esac
}

_tuist "$@"
