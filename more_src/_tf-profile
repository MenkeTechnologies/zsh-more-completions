#compdef tf-profile
# Documentation: https://github.com/datarootsio/tf-profile
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tf-profile: profile and analyze Terraform run logs
local curcontext="$curcontext" state line ret=1
local -a _tfp_cmds
_tfp_cmds=(
  'stats:high-level statistics about Terraform runs'
  'table:per-resource metrics'
  'filter:filter logs to show only specific resources'
  'graph:generate Gantt-style Gnuplot visualization'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'tf-profile command' _tfp_cmds && ret=0 ;;
  args)
    case ${line[1]} in
      graph)
        _arguments \
          '--out=[output file path]:file:_files' \
          '--size=[plot dimensions WxH]:size:' \
          '*:log file:_files' && ret=0 ;;
      *) _arguments '*:log file:_files' && ret=0 ;;
    esac ;;
esac

return ret
