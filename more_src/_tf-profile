#compdef tf-profile
# Documentation: https://man.archlinux.org/search?q=tf-profile
# Reference accessed: 2026-05-16

# Zsh completion for tf-profile (Terraform helper CLI)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '*:path:_files -g "*.tf"' && ret=0

return ret
