#compdef barman

# Zsh completion for Barman - PostgreSQL backup manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[configuration file]:config:_files' \
  '--config=[configuration file]:config:_files' \
  '-q[be quiet]' \
  '--quiet[be quiet]' \
  '-d[enable debug mode]' \
  '--debug[enable debug mode]' \
  '--color=[control color output]:color:(never always auto)' \
  '--log-file=[log file]:log file:_files' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'archive-wal:archive WAL files for a server'
      'backup:perform a backup for a server'
      'check:check connection to a server'
      'check-backup:check backup validity'
      'cron:perform maintenance tasks'
      'delete:delete a backup'
      'diagnose:collect diagnostic information'
      'get-wal:get a WAL file'
      'list-backups:list backups for a server'
      'list-files:list files in a backup'
      'list-servers:list configured servers'
      'put-wal:put a WAL file'
      'rebuild-xlogdb:rebuild WAL file catalog'
      'receive-wal:start receiving WAL files'
      'recover:recover a backup to a target directory'
      'replication-status:show replication status'
      'show-backup:show backup details'
      'show-servers:show server details'
      'status:show server status'
      'switch-wal:switch WAL on the server'
      'sync-backup:synchronize backup from primary'
      'sync-info:show sync status'
      'sync-wals:synchronize WALs from primary'
      'verify:verify backup consistency'
    )
    _describe -t commands 'barman command' commands && ret=0
    ;;
  args)
    case $line[1] in
      backup)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--immediate-checkpoint[force immediate checkpoint]' \
          '--no-immediate-checkpoint[do not force immediate checkpoint]' \
          '--reuse-backup=[reuse previous backup]:mode:(link copy off)' \
          '--retry-times=[number of retries]:num' \
          '--retry-sleep=[seconds between retries]:seconds' \
          '--jobs=[parallel jobs]:jobs' \
          '-j+[parallel jobs]:jobs' \
          '--wait[wait for WAL archiving]' \
          '-w[wait for WAL archiving]' \
          '--wait-timeout=[wait timeout]:seconds' \
          '--name=[backup name]:name' \
          '1:server name' && ret=0
        ;;
      recover)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--target-time=[target recovery time]:time' \
          '--target-xid=[target transaction ID]:xid' \
          '--target-lsn=[target LSN]:lsn' \
          '--target-name=[target restore point]:name' \
          '--target-immediate[recover to end of backup]' \
          '--exclusive[set target as exclusive]' \
          '--tablespace=[remap tablespace]:mapping' \
          '--remote-ssh-command=[SSH command for remote recovery]:command' \
          '--jobs=[parallel jobs]:jobs' \
          '-j+[parallel jobs]:jobs' \
          '--bwlimit=[bandwidth limit in kbps]:kbps' \
          '--retry-times=[number of retries]:num' \
          '--no-retry[do not retry]' \
          '--network-compression[enable network compression]' \
          '--no-network-compression[disable network compression]' \
          '1:server name' \
          '2:backup ID' \
          '3:destination directory:_directories' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:server name' \
          '2:backup ID' && ret=0
        ;;
      list-backups)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--minimal[minimal output]' \
          '1:server name' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:server name' && ret=0
        ;;
    esac
    ;;
esac

return ret
