#compdef ccache
# _ccache — Joel Rosdahl ccache C/C++ compiler cache CLI (Joel Rosdahl, C/C++); custom argparse
# upstream: https://github.com/ccache/ccache

_ccache() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--cleanup[clean up cache]' \
        '-c[clean up cache]' \
        '--clear[wipe cache]' \
        '-C[wipe cache]' \
        '--config-path=+[config file path]:file:_files' \
        '--evict-namespace=+[evict namespace]:str:' \
        '--evict-older-than=+[evict older than dur]:str:' \
        '--get-config=+[get config]:str:' \
        '-k+[get config]:str:' \
        '--print-stats[print stats machine-readable]' \
        '--show-config[show config]' \
        '-p[show config]' \
        '--set-config=+[set config key=value]:str:' \
        '-o+[set config key=value]:str:' \
        '--inspect=+[inspect cache entry]:file:_files' \
        '--show-compression[show cache compression]' \
        '-x[show cache compression]' \
        '--show-log-stats[show recompression log stats]' \
        '--recompress=+[recompress cache type]:t:(none uncompressed zstd)' \
        '-X+[recompress cache type]:t:(none uncompressed zstd)' \
        '--recompress-threads=+[recompress threads]:n:' \
        '--checksum-file=+[checksum file]:file:_files' \
        '--extract-result=+[extract result file]:file:_files' \
        '--debug=+[debug]:b:(true false)' \
        '--logs=+[log file]:file:_files' \
        '-d+[log file]:file:_files' \
        '--print-version[print version]' \
        '--show-stats[show statistics]' \
        '-s[show statistics]' \
        '--zero-stats[zero statistics]' \
        '-z[zero statistics]' \
        '--print-log-stats[print log stats]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--verbose-debug[verbose debug]' \
        '--max-files=+[max files]:n:' \
        '-F+[max files]:n:' \
        '--max-size=+[max size]:str:' \
        '-M+[max size]:str:' \
        '--trim-dir=+[trim cache dir]:dir:_files -/' \
        '--trim-max-size=+[trim max size]:str:' \
        '--trim-method=+[trim method]:m:(atime mtime ctime)' \
        '--trim-recompress=+[trim recompress]:m:(none zstd)' \
        '--trim-recompress-threads=+[trim recompress threads]:n:' \
        '*:cmd:_command_names -e'
}

_ccache "$@"
