#compdef mri_extract_label
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_extract_label
# FreeSurfer: extract one or more labels from a segmentation volume

local ret=1

_arguments -s -S \
  '(--help -u)'{--help,-u}'[print out help information]' \
  '-s[apply a Gaussian smoothing kernel]:sigma' \
  '-t[apply transform to extracted volume]:xform file:_files' \
  '-exit_none_found[exit 1 if labels are not found]' \
  '-dilate[dilate output volume n times]:n' \
  '-erode[erode output volume n times]:n' \
  '*:argument:_files' && ret=0

return ret
