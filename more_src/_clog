#compdef clog

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '--since=[time limit]:time' \
  '--tail=[lines]' \
  '--selector=[label selector]:selector' \
  '--container=[container]:container' \
  '*:pod: _default'
