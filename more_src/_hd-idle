#compdef hd-idle
# Spin down idle hard disks

local ret=1

_arguments -s -S \
  '-a[specify device]:device:_files' \
  '-i[specify idle time in seconds]:seconds:' \
  '-c[specify command type]:type:(scsi ata)' \
  '-l[specify log file]:file:_files' \
  '-t[specify disk name]:disk name:' \
  '-d[debug mode]' \
  '-h[show help]' && ret=0

return ret
