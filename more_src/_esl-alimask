#compdef esl-alimask

# Easel esl-alimask: mask MSA columns based on annotation or files
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-o[output file]:file:_files' \
  '--rf-is-mask[treat #=GC RF annotation as the mask]' \
  '--pmask[posterior probability mask]' \
  '-p[mask columns w/post prob below threshold]:val:' \
  '--ppcons=[mask columns w/consensus prob below threshold]:val:' \
  '--alimask[apply mask from file]:file:_files' \
  '--gapthresh=[mask columns with gap fraction above threshold]:val:' \
  '--inthresh=[gap fraction threshold for inserts]:val:' \
  '--keepins[keep insert columns]' \
  '--rfmask[only keep RF-marked columns]' \
  '--informat[input format]:fmt:(stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--outformat[output format]:fmt:(stockholm pfam a2m afa clustal phylip phylips)' \
  '*:alignment file:_files' && ret=0
return ret
