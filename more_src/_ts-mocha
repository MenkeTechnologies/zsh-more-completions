#compdef ts-mocha
# _ts-mocha — TypeScript wrapper for Mocha (piotrwitek/ts-mocha)
# upstream: https://github.com/piotrwitek/ts-mocha
# Flags from bin/ts-mocha (custom argv switch).

_ts-mocha() {
    _arguments \
        '(-p --project)'{-p+,--project=}'[tsconfig.json path]:file:_files -g "*.json"' \
        '--paths[enable tsconfig-paths]' \
        '--type-check[enable TypeScript type checking]' \
        '*::mocha args:'
}

_ts-mocha "$@"
