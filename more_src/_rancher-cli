#compdef rancher
# _rancher-cli — Rancher k8s cluster CLI (SUSE Rancher, Go); manage Rancher 2.x clusters, projects, apps
# upstream: https://github.com/rancher/cli

_rancher-cli() {
    local -a sub=(
        'apps:apps'
        'app:apps alias'
        'catalog:catalogs'
        'clusters:clusters'
        'context:context (clusters/projects)'
        'globaldns:global DNS'
        'help:show help'
        'inspect:inspect resources'
        'kubectl:run kubectl'
        'login:login to Rancher server'
        'multiclusterapps:multi-cluster apps'
        'namespaces:namespaces'
        'nodes:nodes'
        'project:projects'
        'projects:projects'
        'ps:list workloads'
        'remove:remove resources'
        'rm:remove alias'
        'secrets:secrets'
        'server:manage rancher servers'
        'settings:settings'
        'ssh:ssh into node'
        'up:install rancher up'
        'volumes:volumes'
        'wait:wait for resource'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--debug[debug]' \
        '--config+[config file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rancher subcommand' sub ;;
        args)
            case $words[1] in
                login) _arguments \
                    '--token+[bearer token]:str:' \
                    '-t+[bearer token]:str:' \
                    '--cacert+[ca cert]:file:_files' \
                    '--name+[server name]:name:' \
                    '--skip-verify[skip TLS verify]' \
                    '*:url:_urls' ;;
                kubectl) _arguments '*::args:_files' ;;
                ssh) _arguments '*:node:' ;;
                clusters|nodes|projects|namespaces|workloads|secrets) _arguments '1:cmd:(create delete ls add-member-role)' '*:args:' ;;
            esac
            ;;
    esac
}

_rancher-cli "$@"
