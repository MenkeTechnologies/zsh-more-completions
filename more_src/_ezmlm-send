#compdef ezmlm-send
# Documentation: https://untroubled.org/ezmlm/man/man1/ezmlm-send.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-c[deprecated; ignored]' \
  '-C[deprecated; ignored]' \
  '-h+[required header for sublists]:header:' \
  '-r[preserve all Received: headers]' \
  '-R[remove Received: headers except list-added (default)]' \
  '-v[version]' \
  '-V[version]' \
  '1:dir:_files -/' && ret=0

return ret
