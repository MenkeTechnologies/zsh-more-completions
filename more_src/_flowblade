#compdef flowblade
# Documentation: https://man.archlinux.org/search?q=flowblade
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-xdg[use XDG dirs for config]' \
  '*:project file:_files -g "*.flb"' && ret=0

return ret
