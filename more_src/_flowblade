#compdef flowblade
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/flowblade.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-xdg[use XDG dirs for config]' \
  '*:project file:_files -g "*.flb"' && ret=0

return ret
