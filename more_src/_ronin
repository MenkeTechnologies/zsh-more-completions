#compdef ronin
# Documentation: https://man.archlinux.org/search?q=ronin
# Reference accessed: 2026-05-16

# ronin: ruby-based security/recon toolkit
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'help:show help for a command'
  'config:show or edit ronin config'
  'completion:install shell completions'
  'console:start an irb console with ronin loaded'
  'db:database management'
  'irb:run irb with ronin loaded'
  'install:install a ronin repository'
  'list:list installed ronin repositories'
  'new:scaffold a new project/file'
  'remove:remove an installed repository'
  'repos:list installed repos'
  'sync:sync a repo'
  'update:update installed repos'
  'exploit:launch exploit module'
  'payload:launch payload module'
  'scan:run scanners (cert, ip, url, nmap)'
  'fuzz:fuzz inputs'
  'encode:encoding helpers'
  'decode:decoding helpers'
  'banner-grab:banner-grab service'
  'cert-(grab,dump):TLS cert grab/dump'
  'dns:DNS helpers'
  'http:HTTP helpers'
  'host:host name helpers'
  'iprange:IP range helpers'
  'public-suffix-list:public suffix list helpers'
  'tld-list:TLD list helpers'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ronin command' commands && ret=0 ;;
esac
return ret
