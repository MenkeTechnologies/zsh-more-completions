#compdef ronin

# Ronin: Ruby framework for security research / pentesting (multi-subcommand)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'help:show help for subcommands'
  'completion:install shell tab completion'
  'config:open or list config files'
  'console:open Ronin Ruby REPL'
  'db:database management'
  'host:host info subcommands'
  'install:install a Ronin script library'
  'irb:short alias for console'
  'list:list installed repositories'
  'new:scaffold new Ronin project/script'
  'repos:repository management subcommands'
  'run:run a script'
  'sync:sync installed repositories'
  'uninstall:uninstall a Ronin script library'
  'unhexdump:reverse hexdump output to binary'
  'hexdump:hexdump binary file'
  'decode:decode encoded strings'
  'encode:encode strings'
  'scan:run scanning module against target'
  'fuzz:fuzz module against target'
  'recon:run reconnaissance modules'
  'exploit:run an exploit module'
  'payload:generate a payload'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ronin command' commands && ret=0 ;;
esac
return ret
