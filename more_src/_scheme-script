#compdef scheme-script
# Documentation: https://www.r6rs.org/final/html/r6rs-app/r6rs-app-Z-H-6.html
# Reference accessed: 2026-05-21
# Verified: R6RS Scheme script runner — accepts a Scheme script file
# argument; per-implementation flag handling is not part of the R6RS
# spec.

local curcontext="$curcontext" ret=1
_arguments \
  '*:Scheme script:_files -g "*.(scm|sld|sls|ss)"' && ret=0
return ret
