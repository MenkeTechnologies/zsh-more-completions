#compdef userdel
# _userdel — OpenBSD userdel (low-level binary behind user del; -r removes home, -p preserves home/mailbox but locks account, -D form edits defaults in /etc/usermgmt.conf)
# upstream: https://github.com/openbsd/src (usr.sbin/user)
# Flags from usr.sbin/user/userdel.8 on tip.

_userdel() {
    _arguments \
        '-D[set defaults in /etc/usermgmt.conf]' \
        '-p[preserve home and lock account]' \
        '-r[remove home directory]' \
        '-v[verbose]' \
        '1:user:_users'
}

_userdel "$@"
