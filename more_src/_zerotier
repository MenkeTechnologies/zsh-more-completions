#compdef zerotier

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'info:display status info'
  'listpeers:list all peers'
  'peers:list all peers'
  'listnetworks:list all networks'
  'join:join a network'
  'leave:leave a network'
  'set:set network configuration'
  'get:get network/peer properties'
  'listmoons:list moons'
  'orbit:orbit a moon'
  'deorbit:deorbit a moon'
  'dump:debug dump'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-j[JSON output]' \
  '-D+[path to ZeroTier home]:directory:_directories' \
  '-p+[port]:port number' \
  '-T+[auth token file]:file:_files' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'zerotier command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (join)
        _arguments \
          '--allowDNS[allow DNS configuration]' \
          '--allowDefault[allow default route override]' \
          '--allowGlobal[allow global IP assignment]' \
          '--allowManaged[allow managed routes]' \
          '1:network ID' && ret=0
        ;;
      (leave)
        _arguments '1:network ID' && ret=0
        ;;
      (set)
        _arguments \
          '1:network ID' \
          '2:property:(allowDNS allowDefault allowGlobal allowManaged)' \
          '3:value:(0 1 true false)' && ret=0
        ;;
      (get)
        _arguments \
          '1:network ID' \
          '2:property' && ret=0
        ;;
      (orbit)
        _arguments '1:world ID' '2:seed' && ret=0
        ;;
      (deorbit)
        _arguments '1:world ID' && ret=0
        ;;
    esac
    ;;
esac

return ret
