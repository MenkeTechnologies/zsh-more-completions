#compdef codiff
# Documentation: man codiff(1)
# Source: acmel/dwarves codiff.c (master) — DWARF-based struct/function diff (C, argp).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-s --structs)'{-s,--structs}'[show struct diffs]' \
    '(-f --functions)'{-f,--functions}'[show function diffs]' \
    '(-F --format_path)'{-F+,--format_path=}'[debugging format list]:formats:_default' \
    '(-t --terse_type_changes)'{-t,--terse_type_changes}'[show terse type changes]' \
    '(-V --verbose)'{-V,--verbose}'[show diff details]' \
    '(-q --quiet)'{-q,--quiet}'[show only differences]' \
    '1:old file:_files' \
    '2:new file:_files' \
    && ret=0

return ret
