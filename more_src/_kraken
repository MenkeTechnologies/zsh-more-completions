#compdef kraken kraken-build kraken-filter kraken-report kraken-mpa-report kraken-translate
# _kraken — Derrick Wood kraken original ultrafast metagenomics taxonomic sequence classifier predecessor of Kraken2 (DerrickWood team, C++/Perl); getopt
# upstream: https://github.com/DerrickWood/kraken

_kraken() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--db=+[database dir]:dir:_files -/' \
        '-d+[database dir]:dir:_files -/' \
        '--threads=+[N threads]:n:' \
        '-t+[N threads]:n:' \
        '--fasta-input[fasta input]' \
        '--fastq-input[fastq input]' \
        '--gzip-compressed[gzip compressed]' \
        '--bzip2-compressed[bzip2 compressed]' \
        '--quick[quick operation]' \
        '--min-hits=+[N hits]:n:' \
        '--unclassified-out=+[file]:file:_files' \
        '--classified-out=+[file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--preload[preload database]' \
        '--paired[paired reads]' \
        '--check-names[check names]' \
        '--only-classified-output[only classified output]' \
        '--mpa-format[Metaphlan format]' \
        '--show-zeros[show zero entries]' \
        '--report-zero-counts[report zero counts]' \
        '*:input reads:_files -g "*.fa *.fasta *.fq *.fastq *.fa.gz *.fastq.gz *.fa.bz2"'
}

_kraken "$@"
