#compdef nia
# Documentation: https://github.com/nozomio-labs/nia-cli
# Reference accessed: 2026-05-22
# Verified: src/cli.ts registered top-level commands.

# Zsh completion for nia - Nia indexing, search, and knowledge CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'nia command' \
      'auth[authentication]' \
      'search[query indexed sources or web]' \
      'repos[repository indexing and inspection]' \
      'sources[documentation and source management]' \
      'vault[knowledge base vaults]' \
      'oracle[autonomous research jobs]' \
      'tracer[tracer]' \
      'contexts[contexts]' \
      'packages[packages]' \
      'github[GitHub integration]' \
      'local[local folder indexing]' \
      'personal[macOS personal data connectors]' \
      'project[project nia.json scope]' \
      'papers[research papers]' \
      'datasets[Hugging Face datasets]' \
      'categories[categories]' \
      'extract[document extraction]' \
      'document[document Q&A]' \
      'deps[dependency manifest analysis]' \
      'connectors[connectors]' \
      'slack[Slack integration]' \
      'gdrive[Google Drive integration]' \
      'x[X/Twitter integration]' \
      'usage[account usage]' \
      'skill[install Nia agent skill]' && ret=0
    ;;
  args)
    case $line[1] in
      search)
        _values 'search mode' query web deep universal && ret=0
        ;;
      repos|sources|local|vault|project|personal|oracle|auth)
        _arguments '*:subcommand:' && ret=0
        ;;
    esac
    ;;
esac

return ret
