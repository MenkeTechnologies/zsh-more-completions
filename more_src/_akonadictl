#compdef akonadictl
# Documentation: https://api.kde.org/akonadi/index.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start Akonadi server'
  'stop:stop Akonadi server'
  'restart:restart Akonadi server'
  'status:show Akonadi status'
  'instances:list Akonadi instances'
  'vacuum:vacuum the database'
  'fsck:run integrity check'
  'self-test:run self test'
  'search-update:update search index'
  'list-resources:list configured resources'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'akonadictl command' commands && ret=0 ;;
esac

return ret
