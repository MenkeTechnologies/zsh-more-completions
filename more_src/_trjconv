#compdef trjconv gmx-trjconv
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-trjconv.html
# Convert trajectory files, select atoms, modify periodicity, center/fit, reduce frames

local ret=1

_arguments -s -S \
  '-f+[input trajectory]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-o+[output trajectory]:trajectory:_files -g "*.(xtc|trr|gro|g96|pdb|tng|h5md)"' \
  '-s+[structure file for mass data]:structure:_files -g "*.(tpr|gro|g96|pdb|brk|ent)"' \
  '-n+[index file]:index file:_files -g "*.ndx"' \
  '-fr+[frames index file]:index file:_files -g "*.ndx"' \
  '-sub+[cluster index file]:index file:_files -g "*.ndx"' \
  '-drop+[xvg file with frame values]:xvg file:_files -g "*.xvg"' \
  '-b+[first frame time ps]:time:' \
  '-e+[last frame time ps]:time:' \
  '-tu+[time unit]:unit:(fs ps ns us ms s)' \
  '-skip+[write every nth frame]:n:' \
  '-dt+[frame writing interval ps]:time:' \
  '-dump+[extract frame near time ps]:time:' \
  '-t0+[starting time adjustment ps]:time:' \
  '-timestep+[time between frames ps]:time:' \
  '-pbc+[periodicity treatment]:type:(none mol res atom nojump cluster whole)' \
  '-ur+[unit cell representation]:type:(rect tric compact)' \
  '-boxcenter+[box center location]:type:(tric rect zero)' \
  '-box+[new box dimensions]:vector:' \
  '-trans+[coordinate translation]:vector:' \
  '-shift+[frame-dependent coordinate shift]:vector:' \
  '-fit+[fitting method]:method:(none rot+trans rotxy+transxy translation transxy progressive)' \
  '-ndec+[decimal places for XTC output]:n:' \
  '-trunc+[truncate trajectory at time ps]:time:' \
  '-exec+[execute command per frame]:command:' \
  '-split+[start new file at interval ps]:time:' \
  '-nzero+[zero-padding digits for numbering]:n:' \
  '-dropunder+[exclude frames below threshold]:value:' \
  '-dropover+[exclude frames above threshold]:value:' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-w[view output files]' \
  '-round[round to nearest picosecond]' \
  '-center[center atoms in box]' \
  '-vel[include velocities]' \
  '-force[include forces]' \
  '-sep[write frames to separate files]' \
  '-conect[add CONECT records to PDB]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
