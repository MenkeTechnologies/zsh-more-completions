#compdef gfxrecon-compress
# Documentation: https://vulkan.lunarg.com/doc/view/latest/linux/capture_tools.html
# gfxrecon-compress - compress or decompress GFXReconstruct capture files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage information]' \
  '--version[print version information]' \
  '1:input file:_files' \
  '2:output file:_files' \
  '3:compression format:(LZ4 ZLIB ZSTD NONE)' && ret=0

return ret
