#compdef engram
# Documentation: https://man.archlinux.org/search?q=engram
# Reference accessed: 2026-05-16
# Source: https://github.com/grynn-in/engram/blob/8cec6cd98f3919edafe3fffb6e2329828d7296af/completions/engram.zsh
# Repository: grynn-in/engram (completions/engram.zsh)
# Zsh completion for engram
# Add to ~/.zshrc: fpath=(~/.engram/completions $fpath) && compinit

_engram() {
    local -a commands
    commands=(
        'init:Initialize memory in a project'
        'start:Load context at session start'
        'end:Write lossless checkpoint'
        'search:Search memory (semantic + keyword)'
        'sync:Sync knowledge between locations'
        'index:Build/update Qdrant vector index'
        'qdrant:Manage Qdrant binary'
        'hooks:Manage Claude Code hooks'
        'template:Manage knowledge templates'
        'status:Show memory layer stats'
        'version:Print version'
        'help:Show help'
    )

    local -a qdrant_commands
    qdrant_commands=(
        'download:Download Qdrant binary'
        'start:Start Qdrant in background'
        'stop:Stop Qdrant'
        'status:Check if running'
        'logs:Show recent logs'
    )

    local -a hooks_commands
    hooks_commands=(
        'install:Add hooks to settings.json'
        'remove:Remove engram hooks'
        'status:Show installed hooks'
    )

    local -a template_commands
    template_commands=(
        'create:Export project knowledge as template'
        'list:Show installed templates'
        'install:Install template from repo or path'
        'info:Show template details'
    )

    if (( CURRENT == 2 )); then
        _describe 'command' commands
    elif (( CURRENT == 3 )); then
        case $words[2] in
            qdrant)
                _describe 'qdrant command' qdrant_commands
                ;;
            hooks)
                _describe 'hooks command' hooks_commands
                ;;
            template)
                _describe 'template command' template_commands
                ;;
            search)
                _arguments \
                    '--chunks[Force chunk-level search]' \
                    '--json[Output as JSON]' \
                    '--global[Search all projects]' \
                    '--since[Filter by date]:date:' \
                    '--root[Memory root path]:path:_files -/'
                ;;
            sync)
                _arguments \
                    '--dry-run[Preview without changes]' \
                    '--all[Sync all layers]'
                ;;
            index)
                _arguments \
                    '--incremental[Only new/changed files]' \
                    '--status[Show index stats]' \
                    '--reset[Delete and rebuild]'
                ;;
            init)
                _arguments \
                    '--template[Use template]:template:_engram_templates'
                ;;
        esac
    fi
}

_engram_templates() {
    local templates_dir="${ENGRAM_HOME:-$HOME/.engram}/templates"
    if [[ -d "$templates_dir" ]]; then
        _values 'template' $(ls "$templates_dir" 2>/dev/null)
    fi
}

_engram "$@"
