#compdef ElmerSolver elmersolver
# Documentation: https://github.com/ElmerCSC/elmerfem
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ElmerSolver: parallel FEM solver
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-i[input case .sif file]:file:_files -g "*.sif"' \
  '*:case file:_files -g "*.sif"' && ret=0
return ret
