#compdef ct_run
# _ct_run — Erlang Common Test runner (Ericsson, Erlang); run Erlang Common Test suites
# upstream: https://github.com/erlang/otp

_ct_run() {
    _arguments \
        '-help[show help]' \
        '-dir+[test dir]:dir:_files -/' \
        '-suite+[suite]:str:' \
        '-group+[group]:str:' \
        '-case+[case]:str:' \
        '-spec+[spec file]:file:_files' \
        '-logdir+[log dir]:dir:_files -/' \
        '-cover+[cover spec]:file:_files' \
        '-cover_stop+[cover stop]:bool:(true false)' \
        '-config+[config file]:file:_files' \
        '-decrypt_key+[decrypt key]:str:' \
        '-decrypt_file+[decrypt file]:file:_files' \
        '-include+[include path]:dir:_files -/' \
        '-allow_user_terms[allow user terms]' \
        '-no_auto_compile[no auto compile]' \
        '-multiply_timetraps+[multiply timetraps]:n:' \
        '-scale_timetraps+[scale timetraps]:bool:(true false)' \
        '-create_priv_dir+[create priv dir]:type:(auto_per_run auto_per_tc manual_per_tc)' \
        '-event_handler+[event handler]:str:' \
        '-event_handler_init+[event handler init]:str:' \
        '-ct_hooks+[ct hooks]:str:' \
        '-stylesheet+[stylesheet]:file:_files' \
        '-repeat+[repeat]:n:' \
        '-duration+[duration]:str:' \
        '-until+[until]:str:' \
        '-force_stop[force stop]' \
        '-basic_html[basic html]' \
        '-no_html[no html]' \
        '-keep_logs+[keep logs]:n:' \
        '-pa+[code path prepend]:dir:_files -/' \
        '-pz+[code path append]:dir:_files -/' \
        '-noinput[no input]' \
        '-shell[run interactively]' \
        '-vts[run vts]' \
        '-browser+[browser]:browser:' \
        '*:args:'
}

_ct_run "$@"
