#compdef perlbal
# Documentation: https://man.archlinux.org/search?q=perlbal
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files -g "*.conf"' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '(-D --debug)'{-D,--debug}'+[debug level]:lvl:' \
  '(-l --listen)'{-l,--listen}'+[listen address]:addr:' \
  '(-s --stats)'{-s,--stats}'[stats server]' \
  '(-r --runas)'{-r,--runas}'+[runas user]:user:_users' && ret=0

return ret
