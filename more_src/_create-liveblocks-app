#compdef create-liveblocks-app
# Documentation: https://github.com/liveblocks/liveblocks/blob/main/tools/create-liveblocks-app/README.MD
# Reference accessed: 2026-05-24
# Verified: npm view create-liveblocks-app bin; README at the URL above.

# Zsh completion for create-liveblocks-app - Liveblocks starter kit and example installer

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--init[generate liveblocks.config.js or .ts in current directory]' \
  '--framework=[config framework with --init]:framework:(react javascript)' \
  '--next[use the Next.js Starter Kit]' \
  '--example=[Liveblocks example name]:example:' \
  '--name=[project or directory name]:name:' \
  '--package-manager=[package manager]:manager:(npm yarn pnpm)' \
  '--auth=[authentication for Next.js kit]:auth:(demo github auth0)' \
  '--install[install the project with selected package manager]' \
  '--no-install[do not install the project]' \
  '--git[initialize git]' \
  '--no-git[do not initialize git]' \
  '--vercel[deploy on Vercel and get Liveblocks API key]' \
  '--no-vercel[do not deploy on Vercel]' \
  '--api-key[get Liveblocks API key]' \
  '--no-api-key[do not get Liveblocks API key]' \
  '--open[open browser when deploying or getting API key]' \
  '--upgrade=[upgrade Liveblocks packages to version]:version:' \
  '--help[show help]' && ret=0

return ret
