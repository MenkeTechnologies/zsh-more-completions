#compdef pound
# Documentation: https://man.archlinux.org/search?q=pound
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-f+[config file]:file:_files -g "*.cfg"' \
  '-c[check config]' \
  '-v[verbose]' \
  '-W[disable warnings]' \
  '-p+[pid file]:file:_files' && ret=0

return ret
