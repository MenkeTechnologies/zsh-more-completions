#compdef pound
# Documentation: https://manpages.debian.org/trixie/pound/pound.8.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[print usage summary]' \
  '(- *)-V[print version and exit]' \
  '-c[check configuration only and exit]' \
  '-e[log to standard error]' \
  '-F[foreground mode]' \
  '-f+[location of the configuration file]:file:_files' \
  '-p+[location of the PID file]:file:_files' \
  '-v[verbose mode, send errors to stderr]' \
  '*-W+[enable or disable optional feature]:feature:' && ret=0

return ret
