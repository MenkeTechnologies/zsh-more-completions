#compdef sdsort
# Documentation: https://rdock.github.io/documentation/html_docs/reference-guide/programs.html
# sdsort - rDock sort SD records by data field.

local ret=1

_arguments -s -S \
  '-n[numeric sort (default text)]' \
  '-r[descending sort]' \
  '-f+[sort field]:field:' \
  '-s[sort each named compound independently]' \
  '-id+[compound name field]:field:' \
  '*:file:_files' && ret=0

return ret
