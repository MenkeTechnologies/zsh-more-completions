#compdef bean-check
# Documentation: https://manpages.debian.org/testing/beancount/bean-check.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# completions for beancount bean-check ledger validator

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  '-v[verbose output]'
  '--verbose[verbose output]'
  '--no-dedent[do not strip indentation from errors]'
  '-C[set currency conversion]'
  '*:beancount file:_files -g "*.beancount(-.)"'
)

_arguments -s -S $arguments
