#compdef excludebad
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss40.html
# KAPPA: excludes pixels containing bad values from a 2-d NDF

local ret=1

_arguments -s \
  'IN=[input NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'ROWS=[exclude bad rows rather than columns]:bool:(TRUE FALSE)' \
  'WLIM=[min fraction of good pixels in a row/column]:frac' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
