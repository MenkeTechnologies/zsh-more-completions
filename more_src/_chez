#compdef chez
# Documentation: chez --help (Chez Scheme)
# Source: high-performance Scheme implementation (R6RS/R7RS).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(-q --quiet)'{-q,--quiet}'[suppress greeting and prompt]' \
    '--script=[run as shell script]:path:_files' \
    '--program=[run rnrs program as shell script]:path:_files' \
    '--libdirs=[library directories (colon-separated)]:dirs:' \
    '--libexts=[library extensions (colon-separated)]:exts:' \
    '--compile-imported-libraries[compile libraries before loading]' \
    '--import-notify[enable import search messages]' \
    '--optimize-level=[optimisation level]:level:(0 1 2 3)' \
    '--debug-on-exception[call debug on uncaught exception]' \
    '--eedisable[disable expression editor]' \
    '--eehistory=[expression-editor history]:path:_files' \
    '--enable-object-counts[maintain object counts]' \
    '--retain-static-relocation[keep reloc info]' \
    '(-b --boot)'{-b+,--boot=}'[boot file]:path:_files' \
    '--verbose[trace boot/heap search]' \
    '*:scheme source:_files -g "*.(scm|ss|sps|sls)"' \
    && ret=0

return ret
