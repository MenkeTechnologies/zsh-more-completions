#compdef quotaon quotaoff
# Documentation: man quotaon(8) (BSD)
# Source: BSD quotaon / quotaoff — turn filesystem quotas on and off.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a)-a[apply to all mount-option-flagged filesystems]' \
    '-g[only group quotas]' \
    '-u[only user quotas]' \
    '-v[print per-filesystem message]' \
    '*:filesystem:_files -/' \
    && ret=0

return ret
