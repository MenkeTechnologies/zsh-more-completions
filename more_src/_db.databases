#compdef db.databases
# Documentation: https://grass.osgeo.org/grass-stable/manuals/db.databases.html
# GRASS GIS: list all databases for a given driver and location

local ret=1

_arguments -s -S \
  '--help[print usage summary]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  '--ui[force launching GUI dialog]' \
  'driver=[database driver]:driver:(dbf odbc ogr pg sqlite)' \
  'location=[location path or connection string]:location' && ret=0

return ret
