#compdef ionic-cli
# _ionic-cli — Ionic Framework Cordova/Capacitor CLI alias (Ionic Inc., TypeScript); inquirer
# upstream: https://github.com/ionic-team/ionic-cli

_ionic-cli() {
    local -a sub=(
        'start:scaffold project'
        'serve:start dev server'
        'build:build app'
        'generate:generate code'
        'g:generate code (alias)'
        'info:show env info'
        'login:authenticate to Ionic'
        'logout:logout from Ionic'
        'signup:create account'
        'state:current state'
        'cordova:run cordova commands'
        'capacitor:run capacitor commands'
        'cap:run capacitor commands (alias)'
        'ssh:manage ssh keys'
        'ssl:manage ssl certs'
        'config:manage config'
        'help:show help'
        'version:show version'
        'doctor:diagnose'
        'integrations:manage integrations'
        'init:init existing project'
        'monitoring:enable monitoring'
        'completion:generate shell completion'
        'lab:run ionic lab'
        'package:cloud package builds (deprecated)'
        'repair:repair ionic install'
        'deploy:appflow deploy'
        'live-reload:enable live reload'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '--no-interactive[no interactive]' \
        '--confirm[confirm prompts]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ionic subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '1:name:' \
                    '2:template:(blank tabs sidemenu list super conference my-first-app)' \
                    '--type=+[project type]:t:(angular angular-standalone vue vue-vite react react-vite ionic-angular ionic1)' \
                    '--display-name=+[display name]:str:' \
                    '--cordova[include cordova]' \
                    '--capacitor[include capacitor]' \
                    '--no-deps[no deps]' \
                    '--no-git[no git]' \
                    '--package-manager=+[package manager]:pm:(npm pnpm yarn bun)' \
                    '--no-link[no link]' \
                    '--bundle-id=+[bundle id]:str:' \
                    '--id=+[project id]:str:' \
                    '--tag=+[starter tag]:str:' ;;
                serve) _arguments \
                    '--lab[run with lab]' \
                    '-l[run with lab]' \
                    '--browser=+[browser]:str:' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--external[external]' \
                    '--public-host=+[public host]:host:_hosts' \
                    '--ssl[ssl]' \
                    '--lab-host=+[lab host]:host:_hosts' \
                    '--lab-port=+[lab port]:port:' \
                    '--platform=+[platform]:p:(android ios)' \
                    '--no-open[no open browser]' \
                    '--engine=+[engine]:e:(browser cordova capacitor)' \
                    '--target=+[target]:str:' \
                    '--livereload[livereload]' \
                    '--consolelogs[consolelogs]' \
                    '--prod[production]' \
                    '--dev[development]' \
                    '--proxy[enable proxy]' \
                    '--no-proxy[disable proxy]' ;;
                build) _arguments \
                    '--prod[production]' \
                    '--engine=+[engine]:e:(browser cordova capacitor)' \
                    '--platform=+[platform]:p:(android ios)' \
                    '--no-source-map[no source map]' \
                    '--watch[watch]' ;;
                generate|g) _arguments \
                    '1:thing:(component directive page service module pipe guard interface enum interceptor resolver class)' \
                    '*:name:' ;;
                cordova|capacitor|cap) _arguments '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(get set unset)' \
                    '*:arg:' ;;
                login) _arguments \
                    '--email=+[email]:str:' \
                    '--password=+[password]:str:' ;;
                deploy) _arguments \
                    '1:cmd:(add manifest build remove)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_ionic-cli "$@"
