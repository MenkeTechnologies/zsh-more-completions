#compdef apbs
# Documentation: https://apbs.readthedocs.io/en/latest/using/index.html
# APBS adaptive Poisson-Boltzmann electrostatics solver

local ret=1

_arguments -s -S \
  '(- *)--help[show help and exit]' \
  '(- *)--version[show version and exit]' \
  '--output-file=[redirect output to path]:file:_files' \
  '--output-format=[output format]:format:(flat xml)' \
  '*:APBS input file:_files -g "*.in"' && ret=0

return ret
