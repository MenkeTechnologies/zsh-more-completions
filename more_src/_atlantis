#compdef atlantis

# Zsh completion for atlantis - Terraform Pull Request Automation

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'server:Start the atlantis server'
  'testdrive:Start a guided tour of Atlantis'
  'version:Print the current Atlantis version'
)

_arguments -s -S \
  '--help[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'atlantis command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      server)
        _arguments \
          '--atlantis-url=[URL that Atlantis can be reached at]:url' \
          '--gh-user=[GitHub username]:username' \
          '--gh-token=[GitHub token]:token' \
          '--gh-webhook-secret=[GitHub webhook secret]:secret' \
          '--gitlab-user=[GitLab username]:username' \
          '--gitlab-token=[GitLab token]:token' \
          '--gitlab-webhook-secret=[GitLab webhook secret]:secret' \
          '--bitbucket-user=[Bitbucket username]:username' \
          '--bitbucket-token=[Bitbucket app password]:token' \
          '--repo-allowlist=[comma-separated list of allowed repositories]:repos' \
          '--port=[port to bind to]:port' \
          '--data-dir=[path to directory to store Atlantis data]:dir:_directories' \
          '--log-level=[log level]:level:(debug info warn error)' \
          '--config=[path to config file]:file:_files' \
          '--repo-config=[path to repo config file]:file:_files' \
          '--ssl-cert-file=[path to SSL certificate]:file:_files' \
          '--ssl-key-file=[path to SSL key]:file:_files' \
          '--tf-download[enable downloading of Terraform]' \
          '--default-tf-version=[default Terraform version]:version' \
          '--help[show help]' && ret=0
        ;;
      testdrive)
        _arguments \
          '--gh-user=[GitHub username]:username' \
          '--gh-token=[GitHub token]:token' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
