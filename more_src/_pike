#compdef pike

# Pike IAM policy generator completion

_pike_subcommands() {
  local -a subcmds=(
    'scan:Scan IaC files for required permissions'
    'readme:Generate a README with permissions'
  )
  _describe -t commands 'pike subcommand' subcmds
}

_pike() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:_pike_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        scan)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            {-d,--directory}'=[directory to scan]:directory:_directories' \
            {-o,--output-file}'=[output file]:file:_files' \
            {-f,--format}'=[output format]:format:(terraform json)'
          ;;
        readme)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            {-d,--directory}'=[directory to scan]:directory:_directories' \
            {-o,--output-file}'=[output file]:file:_files'
          ;;
      esac
      ;;
  esac
}

_pike "$@"
