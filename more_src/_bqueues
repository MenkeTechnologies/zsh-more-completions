#compdef bqueues
# Documentation: https://www.ibm.com/docs/en/SSWRJV_10.1.0/lsf_command_ref/bqueues.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bqueues: show LSF batch queues
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-l[long format]' \
  '-w[wide format]' \
  '-u[user]:user:_users' \
  '-m[host]:host:_hosts' \
  '-r[user share]' \
  '-o[output fields]:fields:' \
  '*:queue:' && ret=0
return ret
