#compdef bqueues

# bqueues: show LSF batch queues
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-l[long format]' \
  '-w[wide format]' \
  '-u[user]:user:_users' \
  '-m[host]:host:_hosts' \
  '-r[user share]' \
  '-o[output fields]:fields:' \
  '*:queue:' && ret=0
return ret
