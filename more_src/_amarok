#compdef amarok
# Documentation: https://man.archlinux.org/search?q=amarok
# Reference accessed: 2026-05-16

# Amarok: KDE music player
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-qt[show Qt options]' \
  '(- *)--help-kde[show KDE options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '-r[attempt to play]' \
  '--play[attempt to play]' \
  '-s[pause if playing]' \
  '--pause[pause if playing]' \
  '-t[play/pause toggle]' \
  '--play-pause[play/pause toggle]' \
  '-S[stop playback]' \
  '--stop[stop playback]' \
  '-n[next track]' \
  '--next[next track]' \
  '-p[previous track]' \
  '--previous[previous track]' \
  '+[increase volume]:percent:' \
  '-[decrease volume]:percent:' \
  '--volume=[set volume 0-100]:percent:' \
  '-a[add to playlist]:url:' \
  '--append[add to playlist]:url:' \
  '-A[append + play]:url:' \
  '--play-append[append + play]:url:' \
  '-l[load url]:url:' \
  '--load[load url]:url:' \
  '--queue[queue urls]:url:' \
  '--debug[enable debug logging]' \
  '*:URLs/files:_files' && ret=0
return ret
