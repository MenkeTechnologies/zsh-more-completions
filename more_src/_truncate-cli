#compdef truncate-cli
# _truncate-cli — GNU coreutils truncate shrink or extend size of file CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_truncate-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[do not create files]' \
        '--no-create[do not create files]' \
        '-o[treat SIZE as number of IO blocks]' \
        '--io-blocks[treat SIZE as number of IO blocks]' \
        '-r+[reference file]:file:_files' \
        '--reference=+[reference file]:file:_files' \
        '-s+[size]:str:' \
        '--size=+[size]:str:' \
        '*:files:_files'
}

_truncate-cli "$@"
