#compdef fmtdump
# Documentation: https://man.archlinux.org/search?q=fmtdump
# Reference accessed: 2026-05-16

# fmtdump: print fmt(1) compiled-format file for nmh
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-version[show version]' \
  '-form[mhl form file]:file:_files' \
  '*:format file:_files' && ret=0
return ret
