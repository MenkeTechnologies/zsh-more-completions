#compdef fmtdump
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man8/fmtdump.8mh.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fmtdump: decode nmh format files (mh-format compiled file dumper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-form[nmh format file]:file:_files' \
  '-format[format string]:string:' \
  '*:format file:_files' && ret=0
return ret
