#compdef mostro-cli
# ============================================================================
# _mostro-cli — zsh completion for MostroP2P/mostro-cli, "a simple CLI to
#                use Mostro P2P" — a Nostr-routed Bitcoin Lightning P2P
#                marketplace client (Rust=146 leader bump OPENING Axis 91
#                Bitcoin / rust-bitcoin)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/MostroP2P/mostro-cli
#   Maintainer : Mostro P2P team
#   License    : MIT
#   Stars      : 35
#   Language   : Rust
#   Crate      : mostro-cli  ([package] name = "mostro-cli";
#                              library name = "mostro_client")
#   Binary     : mostro-cli  (Cargo.toml [[bin]] name =
#                              "mostro-cli")
#   Last push  : 2026-05-28
#
# WHAT IT IS
#   mostro-cli is the client-side terminal interface to Mostro
#   — a Nostr-routed, non-custodial, peer-to-peer Bitcoin /
#   Lightning marketplace.  The CLI sends every order, message,
#   and dispute action as a NIP-59 gift-wrapped Nostr event
#   through the configured relay set, signed under the user's
#   identity-key + per-trade ephemeral key pair.  Lightning
#   invoices ride through the same protocol;  fiat settlement
#   is exchanged out-of-band.  Admin-side commands handle
#   dispute resolution (`adm-cancel`, `adm-settle`, `adm-add-
#   solver`, `adm-take-dispute`, `adm-send-dm`) and order-book
#   moderation.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/cli.rs — clap derive
#                       with `#[clap(rename_all = "lower")]` so
#                       every PascalCase variant lowercases to
#                       a single all-lowercase word)
#   mostro-cli [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global options:
#     -v, --verbose                  Verbose output
#     -m, --mostropubkey <PUBKEY>    Mostro service pubkey
#     -r, --relays <CSV>             Comma-separated relay list
#     -p, --pow <DIFFICULTY>         Proof-of-work difficulty
#     -s, --secret                   Use secret/private order
#                                    delivery
#
#   Order subcommands:
#     listorders                     Request open orders from
#                                    Mostro
#       -s, --status <STATUS>
#       -c, --currency <CURRENCY>
#       -k, --kind <KIND>
#
#     neworder                       Create a new buy/sell order
#       -k, --kind <KIND>              Order kind (required)
#       -a, --amount <SATS>            Sats amount
#                                      [default: 0 = market price]
#       -c, --fiat-code <CODE>         Currency
#       -f, --fiat-amount <RANGE>      Fiat amount (single value
#                                      or `min..max`)
#       -m, --payment-method <METHOD>  Payment method
#       -p, --premium <N>              Premium on price
#                                      [default: 0]
#       -i, --invoice <STR>            Lightning invoice
#       -e, --expiration-days <N>      Pending-order expiration
#                                      [default: 0]
#
#     takesell                       Take a sell order
#       -o, --order-id <UUID>
#       -i, --invoice <STR>
#       -a, --amount <FIAT>
#
#     takebuy                        Take a buy order
#       -o, --order-id <UUID>
#       -a, --amount <FIAT>
#
#     addinvoice                     Add a new invoice for
#                                    payment (buyer)
#       -o, --order-id <UUID>
#       -i, --invoice <STR>
#
#     addbondinvoice                 Reply to a bond payout
#                                    request
#       -o, --order-id <UUID>
#       -i, --invoice <STR>
#
#     fiatsent                       Mark fiat as sent
#     release                        Release escrow
#     cancel                         Cancel order
#     rate                           Rate counterparty
#     dispute                        Open a dispute
#     ordersinfo                     Show local orders info
#     restore                        Restore from backup
#
#   Direct-message subcommands:
#     getdm                          Get latest DMs
#       -s, --since <MIN>              Minutes lookback
#                                      [default: 30]
#       -f, --from-user                From counterparty
#                                      (otherwise from Mostro)
#     getdmuser                      Get DMs from any trade keys
#       -p, --pubkey <PUBKEY>
#       -o, --order-id <UUID>
#       -s, --since <MIN>
#     getadmindm                     Admin DMs
#     senddm                         Send a DM to a user
#     dmtouser                       Send a DM to a trade key
#
#   Admin subcommands:
#     admcancel                      Admin cancel an order
#     admsettle                      Admin settle a dispute
#     admaddsolver                   Add a dispute solver
#     admtakedispute                 Take a dispute as solver
#     admsenddm                      Admin send DM
#     listdisputes                   List disputes
#     sendadmindmattach              Send admin DM with
#                                    attachment
#
#   Key / index helpers:
#     conversationkey                Print the conversation key
#                                    for a counterparty
#     getlasttradeindex              Print last-trade index
#     getlasttradeprivkey            Print last-trade private
#                                    key
#
#   Standard clap auto-flags:
#     -h, --help                     Show help
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `bitcoin = "0.32.8"` and
#   `bitcoin_hashes = "0.20.0"` declared in Cargo.toml —
#   `bitcoin` (the npm-of-Rust crate name for rust-bitcoin) is
#   THE canonical Rust Bitcoin library maintained by the
#   rust-bitcoin org (rust-bitcoin/rust-bitcoin, 2.4K+ stars,
#   used by every major Rust Bitcoin / Lightning project — LDK,
#   BDK, electrs, BlockstreamResearch, etc.).  rust-bitcoin
#   exposes typed `bitcoin::Address`, `bitcoin::PublicKey`,
#   `bitcoin::Network` (Bitcoin / Testnet / Signet / Regtest /
#   Testnet4), `bitcoin::Script` / `bitcoin::ScriptBuf`, the
#   complete Bitcoin script-interpreter and tapscript
#   primitives, `bitcoin::Transaction` /
#   `bitcoin::Block` / `bitcoin::BlockHeader`, PSBT v2 with
#   `bitcoin::psbt::PartiallySignedTransaction`, witness /
#   SegWit / Taproot support, BIP-32 derivation via
#   `bitcoin::bip32::ExtendedPrivKey` /
#   `bitcoin::bip32::DerivationPath`, BIP-39 mnemonic helpers
#   via the companion `bip39` crate, the
#   `bitcoin::secp256k1` re-export of the libsecp256k1 bindings,
#   `bitcoin::Amount` / `bitcoin::SignedAmount` / `bitcoin::
#   FeeRate` with `Decimal`-correct arithmetic, base58check
#   encoding, and the `bitcoin_hashes::HashEngine` /
#   `bitcoin_hashes::Hash` trait set for double-SHA-256 / RIPEMD-
#   160 / Murmur3 / SipHash24 / TaggedHash compatibility with
#   the Bitcoin specification.  mostro-cli's `src/util.rs` uses
#   `bitcoin::Address::from_str` and `bitcoin::Network` to
#   validate destination addresses, and `bitcoin_hashes` to
#   anchor Mostro escrow contracts to Bitcoin chain state.
#   Verified via:
#     gh api repos/MostroP2P/mostro-cli/contents/Cargo.toml
#       → bitcoin = "0.32.8"
#       → bitcoin_hashes = { version = "0.20.0", default-
#                            features = false }
#       → [package] name = "mostro-cli"; license = "MIT"
#       → [[bin]] name = "mostro-cli"
#     gh api repos/MostroP2P/mostro-cli/contents/src/cli.rs
#       → #[derive(Parser)] struct Cli { command: Option<
#           Commands>, verbose, mostropubkey, relays, pow,
#           secret }
#       → #[derive(Subcommand, Clone)] #[clap(rename_all =
#           "lower")] enum Commands { ListOrders{...}, NewOrder
#           {...}, TakeSell{...}, ... } (29 variants)
#   This entry is the Rust=146 leader bump that OPENS Axis 91
#   (Bitcoin / rust-bitcoin) at 1/0/0.  Pairing Go and TS-Node
#   bumps will follow at R954 and R955 (Go=146 candidates
#   btcd/btcsuite users; TS-Node=146 candidates bitcoinjs-lib
#   users).
#
#   No completion for `mostro-cli` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_mostro-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-m --mostropubkey)'{-m,--mostropubkey}'=[Mostro service pubkey]:pubkey:' \
        '(-r --relays)'{-r,--relays}'=[comma-separated relay list]:relays:' \
        '(-p --pow)'{-p,--pow}'=[proof-of-work difficulty]:n:' \
        '(-s --secret)'{-s,--secret}'[use secret/private order delivery]' \
        '1: :_mostro_cli_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                listorders)
                    _arguments \
                        '(-s --status)'{-s,--status}'=[order status]:status:' \
                        '(-c --currency)'{-c,--currency}'=[currency]:currency:' \
                        '(-k --kind)'{-k,--kind}'=[order kind]:kind:(buy sell)' && ret=0 ;;
                neworder)
                    _arguments \
                        '(-k --kind)'{-k,--kind}'=[order kind]:kind:(buy sell)' \
                        '(-a --amount)'{-a,--amount}'=[sats amount (0 = market)]:sats:' \
                        '(-c --fiat-code)'{-c,--fiat-code}'=[fiat currency]:code:' \
                        '(-f --fiat-amount)'{-f,--fiat-amount}'=[fiat amount or min..max]:amount:' \
                        '(-m --payment-method)'{-m,--payment-method}'=[payment method]:method:' \
                        '(-p --premium)'{-p,--premium}'=[premium on price]:n:' \
                        '(-i --invoice)'{-i,--invoice}'=[Lightning invoice]:invoice:' \
                        '(-e --expiration-days)'{-e,--expiration-days}'=[expiration days]:days:' && ret=0 ;;
                takesell|takebuy)
                    _arguments \
                        '(-o --order-id)'{-o,--order-id}'=[order UUID]:uuid:' \
                        '(-i --invoice)'{-i,--invoice}'=[Lightning invoice]:invoice:' \
                        '(-a --amount)'{-a,--amount}'=[fiat amount]:amount:' && ret=0 ;;
                addinvoice|addbondinvoice)
                    _arguments \
                        '(-o --order-id)'{-o,--order-id}'=[order UUID]:uuid:' \
                        '(-i --invoice)'{-i,--invoice}'=[Lightning invoice]:invoice:' && ret=0 ;;
                getdm)
                    _arguments \
                        '(-s --since)'{-s,--since}'=[minutes lookback]:min:' \
                        '(-f --from-user)'{-f,--from-user}'[from counterparty (not Mostro)]' && ret=0 ;;
                getdmuser)
                    _arguments \
                        '(-p --pubkey)'{-p,--pubkey}'=[user pubkey]:pubkey:' \
                        '(-o --order-id)'{-o,--order-id}'=[order UUID]:uuid:' \
                        '(-s --since)'{-s,--since}'=[minutes lookback]:min:' && ret=0 ;;
                *)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_mostro_cli_commands] )) ||
_mostro_cli_commands() {
    local -a commands
    commands=(
        'listorders:request open orders from Mostro pubkey'
        'neworder:create a new buy/sell order'
        'takesell:take a sell order'
        'takebuy:take a buy order'
        'addinvoice:buyer adds a new invoice to receive payment'
        'addbondinvoice:reply to a bond payout request'
        'fiatsent:mark fiat as sent'
        'release:release escrow'
        'cancel:cancel an order'
        'rate:rate counterparty'
        'dispute:open a dispute'
        'ordersinfo:show local orders info'
        'restore:restore from backup'
        'getdm:get latest direct messages'
        'getdmuser:get DMs from any trade keys'
        'getadmindm:get admin DMs'
        'senddm:send a DM to a user'
        'dmtouser:send a DM to a trade key'
        'admcancel:admin cancel an order'
        'admsettle:admin settle a dispute'
        'admaddsolver:add a dispute solver'
        'admtakedispute:take a dispute as solver'
        'admsenddm:admin send DM'
        'listdisputes:list disputes'
        'sendadmindmattach:send admin DM with attachment'
        'conversationkey:print conversation key for a counterparty'
        'getlasttradeindex:print last-trade index'
        'getlasttradeprivkey:print last-trade private key'
    )
    _describe -t commands 'mostro-cli command' commands
}

_mostro-cli "$@"
