#compdef sendme

# n0-computer/sendme — iroh blob transfer (`src/main.rs` clap)

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'sendme command' compadd -- send receive recv
  ;;
rest)
  case $line[1] in
    send)
      _arguments -s -S \
        '(-h)'{-h,--help}'[help]' \
        '--ticket-type=[info embedded in ticket]:type:(id relay addresses relay-and-addresses)' \
        '--magic-ipv4-addr=[listen IPv4 with port]:addr:' \
        '--magic-ipv6-addr=[listen IPv6 with port]:addr:' \
        '--format=[ticket encoding]:format:(hex cid)' \
        '*-v[increase log verbosity]' \
        '--no-progress[suppress progress bars]' \
        '--relay=[relay mode or URL]:relay:(disabled default)' \
        '--show-secret[print magicsocket secret]' \
        '(-j)--jobs=[parallel import jobs]:count:' \
        '*:path to send:_files' && ret=0
      ;;
    receive|recv)
      _arguments -s -S \
        '(-h)'{-h,--help}'[help]' \
        '--magic-ipv4-addr=[listen IPv4 with port]:addr:' \
        '--magic-ipv6-addr=[listen IPv6 with port]:addr:' \
        '--format=[ticket encoding]:format:(hex cid)' \
        '*-v[increase log verbosity]' \
        '--no-progress[suppress progress bars]' \
        '--relay=[relay mode or URL]:relay:(disabled default)' \
        '--show-secret[print magicsocket secret]' \
        '(-j)--jobs=[parallel import jobs]:count:' \
        '1:blob ticket:' && ret=0
      ;;
  esac
  ;;
esac

return ret
