#compdef nyxmms2
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/xmms2.1.html
# nyxmms2 - the official XMMS2 command line interface

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[display command help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'play:start playback'
      'pause:pause playback'
      'stop:stop playback'
      'toggle:switch between play and pause'
      'next:jump to the next track'
      'prev:jump to the previous track'
      'seek:move to a specific time in the current track'
      'jump:navigate to a track matching criteria'
      'current:display current playback status'
      'add:insert media into a playlist'
      'remove:delete tracks from a playlist'
      'search:find and display matching media'
      'info:show properties of specified media'
      'list:display playlist contents'
      'move:rearrange tracks within a playlist'
      'playlist:playlist operations'
      'collection:collection operations'
      'server:server administration'
      'help:show help for a command'
    )
    _describe -t commands 'nyxmms2 command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      playlist)
        _values 'subcommand' clear create list remove rename shuffle sort switch config && ret=0
        ;;
      collection)
        _values 'subcommand' create list show remove rename config && ret=0
        ;;
      server)
        _values 'subcommand' browse config import plugins property rehash remove shutdown stats sync volume && ret=0
        ;;
      add)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
