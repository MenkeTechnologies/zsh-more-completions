#compdef convol
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/convol.html
# MIRIAD: convolve a cube with a beam function

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'map=[input image]:map:_files' \
  'beam=[input beam]:beam:_files' \
  'fwhm=[Gaussian width in arcsec]:fwhm:' \
  'pa=[Gaussian position angle in degrees]:pa:' \
  'region=[region of interest]:region:' \
  'out=[output image]:out:_files' \
  'options=[final,divide,asymmetric,correlate,cube]:options:(final divide asymmetric correlate cube)' \
  'scale=[output value multiplier]:scale:' \
  'sigma=[deconvolution noise parameter]:sigma:' \
  '*:image:_files' && ret=0

return ret
