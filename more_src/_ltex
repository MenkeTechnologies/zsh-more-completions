#compdef ltex-cli
# _ltex — LanguageTool-based grammar/spell checker (valentjn/ltex-ls)
# upstream: https://github.com/valentjn/ltex-ls

_arguments -s -S \
    '--input-encoding=[input file encoding]:encoding:(utf-8 latin1 ascii)' \
    '--code-language-ids=[mapping of file extensions to code language IDs]:mapping:' \
    '--enabled-rules=[comma-separated list of enabled rules]:rules:' \
    '--disabled-rules=[comma-separated list of disabled rules]:rules:' \
    '--language=[language code for checking]:lang:(en-US en-GB de-DE fr es pt-BR nl it pl ru zh-CN ja-JP)' \
    '--dictionary=[additional dictionary words]:words:' \
    '--hidden-false-positives=[JSON of false positives to hide]:json:' \
    '--latex-commands=[LaTeX command signatures]:commands:' \
    '--latex-environments=[LaTeX environments to handle]:environments:' \
    '--markdown-nodes=[Markdown node types to handle]:nodes:' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(- *)--version[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:file:_files'
