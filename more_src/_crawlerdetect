#compdef crawlerdetect crawler-detect
# _crawlerdetect — Mark Beech CrawlerDetect bot identification CLI detecting whether a User-Agent string belongs to a known web crawler bot scraper using a regex database of 1000+ bot patterns (jaybizzle team, PHP); Symfony Console
# upstream: https://github.com/JayBizzle/Crawler-Detect

_crawlerdetect() {
    local -a sub=(
        'detect:check if UA is a bot'
        'list:list known crawler patterns'
        'update:update crawler patterns'
        'check:check a UA file'
        'stats:show stats'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[non-interactive]' \
        '--no-interaction[non-interactive]' \
        '-f+[format]:f:(text json csv yaml)' \
        '--format=+[format]:f:(text json csv yaml)' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'crawlerdetect subcommand' sub ;;
        args)
            case $words[1] in
                detect) _arguments \
                    '--ua=+[user agent]:str:' \
                    '*:user agent:' ;;
                check) _arguments \
                    '--input=+[file]:file:_files' \
                    '*:user agent file:_files' ;;
                list) _arguments \
                    '--filter=+[pattern]:str:' ;;
            esac
            ;;
    esac
}

_crawlerdetect "$@"
