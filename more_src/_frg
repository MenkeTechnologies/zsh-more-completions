autoload -U is-at-least

_frg() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_frg_commands" \
"*::: :->frg" \
&& ret=0
    case $state in
    (frg)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:frg-command-$line[1]:"
        case $line[1] in
            (index)
_arguments "${_arguments_options[@]}" : \
'--max-filesize=[]:MAX_FILESIZE:_default' \
'--force[]' \
'--follow[Follow symbolic links]' \
'-h[Print help]' \
'--help[Print help]' \
'::path:_files' \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
'-m+[]:MAX_COUNT:_default' \
'--max-count=[]:MAX_COUNT:_default' \
'-C+[]:CONTEXT:_default' \
'--context=[]:CONTEXT:_default' \
'--glob=[]:GLOB:_default' \
'--type=[]:FILE_TYPE:_default' \
'*-e+[Additional patterns (combined with OR)]:EXTRA_PATTERNS:_default' \
'*--regexp=[Additional patterns (combined with OR)]:EXTRA_PATTERNS:_default' \
'-n[]' \
'--no-index[]' \
'-F[]' \
'--literal[]' \
'-i[]' \
'-S[Smart case\: case-insensitive if pattern is all lowercase]' \
'--smart-case[Smart case\: case-insensitive if pattern is all lowercase]' \
'-l[]' \
'-c[]' \
'--count[]' \
'-q[]' \
'--quiet[]' \
'--json[]' \
'--follow[Follow symbolic links]' \
'-h[Print help]' \
'--help[Print help]' \
':pattern:_default' \
'::path:_files' \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::path:_files' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::path:_files' \
&& ret=0
;;
(upgrade)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'--hook[Install git hook to auto-index on commit]' \
'-h[Print help]' \
'--help[Print help]' \
'::path:_files' \
&& ret=0
;;
(watch)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::path:_files' \
&& ret=0
;;
(man)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(replace)
_arguments "${_arguments_options[@]}" : \
'--glob=[Filter files by glob]:GLOB:_default' \
'--type=[Filter by file type]:FILE_TYPE:_default' \
'--write[Actually write changes (default is dry-run preview)]' \
'-i[Case-insensitive]' \
'-F[Treat pattern as fixed string]' \
'--literal[Treat pattern as fixed string]' \
'--follow[Follow symbolic links]' \
'-h[Print help]' \
'--help[Print help]' \
':pattern -- Regex pattern to search for:_default' \
':replacement -- Replacement string (supports $1, $2 for capture groups):_default' \
'::path:_files' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_frg__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:frg-help-command-$line[1]:"
        case $line[1] in
            (index)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(upgrade)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(watch)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(man)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(replace)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_frg_commands] )) ||
_frg_commands() {
    local commands; commands=(
'index:Build or rebuild the search index' \
'search:Search using the index' \
'update:Update the index incrementally' \
'status:Show index status' \
'upgrade:Upgrade frg to the latest release from GitHub' \
'init:Initialize frg for this project' \
'watch:Watch for file changes and auto-update the index' \
'man:Generate man page' \
'completions:Generate shell completions' \
'replace:Search and replace in files' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'frg commands' commands "$@"
}
