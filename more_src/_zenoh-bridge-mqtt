#compdef zenoh-bridge-mqtt
# Documentation: https://github.com/eclipse-zenoh/zenoh-plugin-mqtt/blob/master/README.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zenoh MQTT bridge: bridge MQTT to Zenoh
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files -g "*.json5"' \
  '(-m --mode)'{-m,--mode=}'[session mode]:mode:(peer client)' \
  '*'{-l,--listen=}'[listen endpoint locator]:endpoint:' \
  '*'{-e,--peer=}'[peer locator to connect to]:endpoint:' \
  '--no-multicast-scouting[disable automatic peer/router discovery]' \
  '(-i --id)'{-i,--id=}'[unique zenoh ID hex]:hex:' \
  '--rest-http-port=[REST API HTTP port]:port:' \
  '(-p --port)'{-p,--port=}'[MQTT server bind address PORT or IP\:PORT]:port:' \
  '(-s --scope)'{-s,--scope=}'[scope prefix mapping MQTT to zenoh]:scope:' \
  '*'{-a,--allow=}'[regex of allowed MQTT topics]:regex:' \
  '*--deny=[regex of denied MQTT topics]:regex:' \
  '*'{-w,--generalise-pub=}'[generalise zenoh publications]:keyexpr:' \
  '*'{-r,--generalise-sub=}'[generalise zenoh subscriptions]:keyexpr:' \
  '--tx-channel-size=[MQTT transmit channel buffer size]:size:' \
  '--dictionary-file=[username/password auth file]:file:_files' \
  '--server-private-key=[TLS private key for MQTT server]:file:_files' \
  '--server-certificate=[TLS public cert for MQTT server]:file:_files' \
  '--root-ca-certificate=[CA cert for client validation]:file:_files' && ret=0
return ret
