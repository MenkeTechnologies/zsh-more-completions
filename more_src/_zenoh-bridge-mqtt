#compdef zenoh-bridge-mqtt
# Documentation: https://github.com/eclipse-zenoh/zenoh-plugin-mqtt/blob/master/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zenoh MQTT bridge: bridge MQTT to Zenoh
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[config file]:file:_files -g "*.json5"' \
  '--cfg=[config file]:file:_files -g "*.json5"' \
  '--config=[config file]:file:_files -g "*.json5"' \
  '-e[connect endpoint]:endpoint:' \
  '--connect=[connect endpoint]:endpoint:' \
  '-l[listen endpoint]:endpoint:' \
  '--listen=[listen endpoint]:endpoint:' \
  '--no-multicast-scouting[disable multicast scouting]' \
  '-i[zenoh ID hex]:hex:' \
  '--id=[zenoh ID hex]:hex:' \
  '--mode=[mode]:mode:(peer client router)' \
  '--rest-http-port=[REST API port]:port:' \
  '--plugin-search-dir=[plugin search dir]:dir:_files -/' \
  '-P[load plugin]:plugin:' \
  '--plugin=[load plugin]:plugin:' \
  '--adminspace-permissions=[admin space permissions]:perms:(r w rw)' \
  '--no-timestamp[do not log timestamps]' \
  '*::zenoh-bridge-mqtt args:_files' && ret=0
return ret
