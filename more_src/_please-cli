#compdef please-cli
# Documentation: https://man.archlinux.org/search?q=please-cli
# Reference accessed: 2026-05-16

# Zsh completion for please-cli (rookasrudzianskas/please-cli).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-y --force)'{-y,--force}'[run generated program without confirmation]' \
  '*::Codex prompt words:'
