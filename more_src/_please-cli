#compdef please-cli
# Documentation: https://github.com/TNG/please-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for please-cli (TNG/please-cli) - AI helper for creating CLI commands

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-e --explanation)'{-e,--explanation}'[also show an explanation of the command]' \
  '(-l --legacy)'{-l,--legacy}'[use the legacy model]' \
  '--debug[enable debug output]' \
  '(-a --api-key)'{-a,--api-key}'[OpenAI API key]:key:' \
  '(-m --model)'{-m,--model}'[OpenAI model to use]:model:' \
  '*::prompt:'
