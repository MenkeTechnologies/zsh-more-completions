#compdef windbg windbgx
# _windbg — Microsoft WinDbg debugger CLI (Microsoft, C++); custom argparse
# upstream: https://learn.microsoft.com/en-us/windows-hardware/drivers/debugger/

_windbg() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-?[show help]' \
        '-aExtension+[extension dll]:file:_files' \
        '-b[break on driver loading]' \
        '-c+[command]:str:' \
        '-cf+[command file]:file:_files' \
        '-d[wait for debugger]' \
        '-e+[event handle]:str:' \
        '-g[ignore initial breakpoint]' \
        '-G[ignore final breakpoint]' \
        '-hd[help dialog]' \
        '-i+[image path]:str:' \
        '-k+[kernel debug params]:str:' \
        '-kd[kernel debug]' \
        '-kx+[kernel debug crashdump]:str:' \
        '-loga+[append log file]:file:_files' \
        '-logo+[overwrite log file]:file:_files' \
        '-lsrcpath+[server source path]:str:' \
        '-n[verbose]' \
        '-noinh[no inherit]' \
        '-noio[no io]' \
        '-noshell[no shell commands]' \
        '-o[debug all child processes]' \
        '-p+[process id]:pid:_pids' \
        '-pb[debug as part of process]' \
        '-pd[debug as detached]' \
        '-pe[debug existing process]' \
        '-pn+[process name]:str:' \
        '-pr[restart at startup]' \
        '-premote+[debug remote conn]:str:' \
        '-prr[restart and resume]' \
        '-pv[non-invasive debug]' \
        '-pvr[non-invasive resume]' \
        '-py+[python script]:file:_files' \
        '-Q[quiet]' \
        '-QR+[remote server]:str:' \
        '-QS[suppress symbol load]' \
        '-QY[auto save]' \
        '-r+[remote]:str:' \
        '-robp[redo on bp]' \
        '-server+[server]:str:' \
        '-secure[secure mode]' \
        '-sicv[load symbols on demand]' \
        '-T+[title]:str:' \
        '-tdf[output to debugger]' \
        '-v[verbose]' \
        '-W+[workspace]:str:' \
        '-WF+[workspace file]:file:_files' \
        '-WX[no workspace save]' \
        '-x[exception filter]' \
        '-xe+[break on event]:str:' \
        '-xd+[disable on event]:str:' \
        '-xi+[ignore event]:str:' \
        '-xn+[notify on event]:str:' \
        '-y+[symbol path]:str:' \
        '-z+[crash dump]:file:_files -g "*.dmp"' \
        '-zp+[page file]:file:_files' \
        '*:arg:'
}

_windbg "$@"
