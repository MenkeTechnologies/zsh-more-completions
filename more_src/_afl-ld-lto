#compdef afl-ld-lto
# Documentation: https://github.com/AFLplusplus/AFLplusplus/blob/stable/instrumentation/README.lto.md
# AFL++ LTO linker wrapper (set via LD=afl-ld-lto)

local ret=1

_arguments -s -S \
  '-o[output file]:output:_files' \
  '*:object file:_files -g "*.(o|a|so)"' && ret=0

return ret
