#compdef qpGraph
# Documentation: https://github.com/DReichLab/AdmixTools/blob/master/README.QPGRAPH
# AdmixTools qpGraph: fit an admixture graph to f-statistics

local ret=1

_arguments -s -S \
  '-h[show brief documentation]' \
  '-p+[parameter file specifying input data]:file:_files' \
  '-g+[graph file for analysis]:file:_files' \
  '-o+[output graph in editable format]:file:_files' \
  '-d+[graph output in dot format]:file:_files' && ret=0

return ret
