#compdef sugprfb
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/windowing_sorting_muting/sugprfb.c
# Remove first breaks from GPR data

local ret=1

_arguments -s -S \
  'nx=[number of traces to sum to create pilot trace (odd)]:nx' \
  'fbt=[length of first break in number of samples]:fbt' \
  '*:file:_files' && ret=0

return ret
