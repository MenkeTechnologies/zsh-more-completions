#compdef oxide
# Documentation: https://github.com/oxidecomputer/oxide.rs (cli/src/{main,cli_builder,cmd_auth}.rs)
# Reference accessed: 2026-05-29
# Oxide Computer Company cloud platform CLI.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'auth:authentication management (login/logout/status)'
  'docs:open Oxide CLI documentation'
  'completion:generate shell completion scripts'
  'version:show version'
  'api:direct API access'
  'disk:disk operations (import)'
  'instance:instance management (serial console, from-image)'
  'experimental:experimental features (timeseries dashboard)'
  'system:system administration (networking, hardware, update)'
  'bundle:support bundle operations (download, inspect)'
  'help:show help for a subcommand'
)

local -a _global
_global=(
  '(-h --help)'{-h,--help}'[show help]'
  '--debug[enable debug output]'
  '--profile=[configuration profile to use]:profile:'
  '--config-dir=[custom configuration directory]:dir:_directories'
  '*--resolve=[override DNS lookup (HOST\:PORT\:ADDR)]:resolve:'
  '--cacert=[path to trusted CA certificate file]:file:_files'
  '--insecure[disable cert validation and hostname verification]'
  '--timeout=[API call timeout (seconds)]:seconds:'
)

_arguments -C \
  $_global \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'oxide subcommand' _subcmds && ret=0
    ;;
  args)
    local -a _auth _instance _disk _system _bundle _experimental
    _auth=(
      'login:authenticate via OAuth 2.0 Device Authorization Grant'
      'logout:remove saved authentication information'
      'status:verify and display authentication state'
    )
    _instance=(
      'serial:attach to instance serial console'
      'from-image:create an instance from a source image'
    )
    _disk=(
      'import:import a local disk image to a project'
    )
    _system=(
      'networking:system networking operations'
      'hardware:system hardware operations'
      'update:system update management'
    )
    _bundle=(
      'download:download a support bundle'
      'inspect:inspect a support bundle'
    )
    _experimental=(
      'timeseries:experimental timeseries dashboard'
    )
    case $line[1] in
      auth)
        _arguments \
          $_global \
          '1: :->sub' \
          '*:: :->authargs' && ret=0
        if [[ $state == sub ]]; then
          _describe -t commands 'auth subcommand' _auth && ret=0
        elif [[ $state == authargs ]]; then
          case $line[1] in
            login)
              _arguments \
                '--host=[Silo instance address (required)]:host:_urls' \
                '--browser=[override default browser]:command:_command_names -e' \
                '--no-browser[print URL instead of opening browser]' \
                '--time-to-live=[token lifetime (e.g. 7d, 2w, 6M, 1y)]:duration:' && ret=0
              ;;
            logout)
              _arguments \
                '(-a --all)'{-a,--all}'[delete all profiles]' \
                '(-f --force)'{-f,--force}'[skip confirmation]' && ret=0
              ;;
          esac
        fi
        ;;
      instance) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'instance' _instance && ret=0 ;;
      disk) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'disk' _disk && ret=0 ;;
      system) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'system' _system && ret=0 ;;
      bundle) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'bundle' _bundle && ret=0 ;;
      experimental) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'experimental' _experimental && ret=0 ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
