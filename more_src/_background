#compdef background backtick dollarat elgetopt elgetpositionals elglob eltest emptyenv envfile execline-cd execline-umask export-array fdblock fdclose fdmove fdreserve fdswap forbacktickx foreground forstdin forx getcwd getpid heredoc homeof ifelse ifte ifthenelse importas loopwhilex multidefine multisubstitute pipeline piperw posix-cd posix-umask redirfd runblock tryexec unexport withstdinas
# Documentation: source-direct extraction from upstream
# skarnet/execline src/execline/*.c USAGE strings + subgetopt_r
# option-string specs + skalibs gol_main gol_bool tables +
# case-arm decoding via gh api.  Reference accessed: 2026-05-30.
# Skarnet execline R129 — 41-stem multi-binary harvest of the
# Skarnet execline shell-replacement language chain-loadable
# binaries. The 10 binaries from this repo that clash with stock
# zsh completions (`exec`/`trap`/`wait`), shell reserved words
# (`case`/`if`), shell builtins (`exit`/`export`/`shift`), or
# already-covered names in the corpus (`define`/`execlineb`) are
# deliberately omitted from this #compdef line per established
# anti-dup policy.  Sister to the wider Skarnet ecosystem
# (R117-R128).  Filename uses alphabetically-first stem
# `background`.

# Common -E/-e GOLB_AUTOIMPORT mutex used by several binaries.
local -a _exl_autoimport
_exl_autoimport=(
  '(-e)-E[automatically import VAR=value into env after binding (default)]'
  '(-E)-e[do NOT autoimport into env; only bind for the inner block]'
)

# Common -N/-n no-newline / strip-trailing-newline mutex used by
# the var-binding binaries.
local -a _exl_strip_nl
_exl_strip_nl=(
  '(-n)-N[do NOT strip a trailing newline from captured value]'
  '(-N)-n[strip a single trailing newline from captured value (default)]'
)

# Common -C/-c chomp-trailing-empty mutex.
local -a _exl_chomp
_exl_chomp=(
  '(-c)-C[do NOT strip trailing empty entries from the split list]'
  '(-C)-c[strip trailing empty entries (default)]'
)

# Common -0/-d NUL-delim xor custom-delim mutex.
local -a _exl_delim
_exl_delim=(
  '(-d)-0[input entries are NUL-separated (binary safe)]'
  '(-0)-d+[delimiter char/string (default newline)]:delim:'
)

# Common -p/-P parallelism mutex used by forx/forstdin/forbacktickx.
local -a _exl_parallel
_exl_parallel=(
  '(-P -p)-p[run all iterations in parallel (unbounded)]'
  '(-P -p)-P+[max concurrent iterations]:maxpar:'
)

# Common -o/-x okcode/breakcode mutex used by loopwhilex/forx/...
local -a _exl_okbreak
_exl_okbreak=(
  '(-x)-o+[exit codes considered OK (comma-separated)]:okcode,okcode,...:'
  '(-o)-x+[exit codes that BREAK the loop (comma-separated)]:breakcode,breakcode,...:'
)

case $service in

  background)
    _arguments -s -S \
      '-d[do NOT wait for the child to die before chain-loading remainder]' \
      '*:command (in {} braces):_command_names -e'
    ;;

  backtick)
    _arguments -s -S \
      '(-i -I -x -D)-i[ignore failure of inner command; bind var empty]' \
      '(-i -I -x -D)-I[INSIST: fail outright if inner command fails]' \
      '(-i -I -x -D)-x[on inner failure, exit with inner exit code]' \
      '(-i -I -x -D)-D+[default value if inner command output is empty]:default:' \
      "${_exl_strip_nl[@]}" \
      "${_exl_autoimport[@]}" \
      '1:variable name:_parameters' \
      '*:inner command (in {} braces) + remainder:_command_names -e'
    ;;

  dollarat)
    _arguments -s -S \
      '-n[no trailing newline]' \
      '(-d)-0[NUL-separate positional args (binary safe)]' \
      '(-0)-d+[delimiter char (default newline)]:delim:'
    ;;

  elgetopt)
    _arguments -s -S \
      '-D+[default if optstring not exhausted]:default:' \
      '1:getopt-style optstring (e.g. ab:c):' \
      '*:program and arguments:_command_names -e'
    ;;

  elgetpositionals)
    _arguments -s -S \
      '-P+[number of leading positionals to consume (default 1)]:num:' \
      '*:program and arguments:_command_names -e'
    ;;

  elglob)
    _arguments -s -S \
      '-v[do NOT die if pattern has no match (bind empty)]' \
      '-w[wildcard mode: each match becomes a separate positional]' \
      '-s[treat pattern as a literal string (no glob expansion)]' \
      '-m[allow matches on hidden (.dotfile) entries]' \
      '-e[on no-match, bind to the literal pattern string]' \
      '-0[NUL-separate matches]' \
      '-n[no trailing newline in joined output]' \
      '-d+[separator char (default space)]:delim:' \
      '1:variable name:_parameters' \
      '2:glob pattern:' \
      '*:program and arguments:_command_names -e'
    ;;

  eltest)
    _arguments -s -S \
      '*:test(1)-compatible expression:'
    ;;

  emptyenv)
    _arguments -s -S \
      '(-p --keep-path)'{-p,--keep-path}'[preserve $PATH (do not unset)]' \
      '(-l --keep-ld-library-path)'{-l,--keep-ld-library-path}'[preserve $LD_LIBRARY_PATH]' \
      '(-c --cleanup)'{-c,--cleanup}'[strip execline-internal sentinel vars (! ? # 0) before exec]' \
      '(-o --pop-elgetopt)'{-o,--pop-elgetopt}'[pop the current elgetopt-pushed env layer only]' \
      '(-P --pop-execline)'{-P,--pop-execline}'[pop the entire execline-pushed env layer]' \
      '*:program and arguments:_command_names -e'
    ;;

  envfile)
    _arguments -s -S \
      '(-I)-i[strict mode: parse errors are fatal (default)]' \
      '(-i)-I[lax mode: chain-load even if file is missing or unparseable]' \
      '1:envfile (key=value lines):_files' \
      '*:program and arguments:_command_names -e'
    ;;

  execline-cd)
    _arguments -s -S \
      '1:directory:_directories' \
      '*:program and arguments:_command_names -e'
    ;;

  execline-umask)
    _arguments -s -S \
      '1:octal umask:' \
      '*:program and arguments:_command_names -e'
    ;;

  export-array)
    _arguments -s -S \
      '-d+[delimiter char (default newline)]:delim:' \
      '1:variable name:_parameters' \
      '*:value-list (in {} braces) + program and arguments:'
    ;;

  fdblock)
    _arguments -s -S \
      '-n[block in NONBLOCK direction (negate: unblock the fd)]' \
      '1:file descriptor:' \
      '*:program and arguments:_command_names -e'
    ;;

  fdclose)
    _arguments -s -S \
      '1:file descriptor:' \
      '*:program and arguments:_command_names -e'
    ;;

  fdmove)
    _arguments -s -S \
      '-c[COPY rather than move; leave the source fd open]' \
      '1:destination fd:' \
      '2:source fd:' \
      '*:program and arguments:_command_names -e'
    ;;

  fdreserve)
    _arguments -s -S \
      '1:n (number of high-numbered fds to reserve):' \
      '*:program and arguments:_command_names -e'
    ;;

  fdswap)
    _arguments -s -S \
      '1:fd1:' \
      '2:fd2:' \
      '*:program and arguments:_command_names -e'
    ;;

  forbacktickx)
    _arguments -s -S \
      "${_exl_parallel[@]}" \
      "${_exl_okbreak[@]}" \
      "${_exl_autoimport[@]}" \
      "${_exl_strip_nl[@]}" \
      "${_exl_chomp[@]}" \
      "${_exl_delim[@]}" \
      '1:variable name:_parameters' \
      '*:backtick command (in {} braces) + body command:_command_names -e'
    ;;

  foreground)
    _arguments -s -S \
      '*:command (in {} braces) + remainder:_command_names -e'
    ;;

  forstdin)
    _arguments -s -S \
      "${_exl_autoimport[@]}" \
      "${_exl_parallel[@]}" \
      "${_exl_okbreak[@]}" \
      "${_exl_strip_nl[@]}" \
      "${_exl_chomp[@]}" \
      "${_exl_delim[@]}" \
      '1:variable name:_parameters' \
      '*:body command:_command_names -e'
    ;;

  forx)
    _arguments -s -S \
      "${_exl_autoimport[@]}" \
      "${_exl_parallel[@]}" \
      "${_exl_okbreak[@]}" \
      '1:variable name:_parameters' \
      '*:values (in {} braces) + body command:_command_names -e'
    ;;

  getcwd)
    _arguments -s -S \
      "${_exl_autoimport[@]}" \
      '1:variable name:_parameters' \
      '*:program and arguments:_command_names -e'
    ;;

  getpid)
    _arguments -s -S \
      "${_exl_autoimport[@]}" \
      '(-p)-P[bind PARENT pid (getppid)]' \
      '(-P)-p[bind OWN pid (getpid, default)]' \
      '1:variable name:_parameters' \
      '*:program and arguments:_command_names -e'
    ;;

  heredoc)
    _arguments -s -S \
      '-d[detach: do NOT block; run the writer in a child process]' \
      '1:file descriptor (heredoc text appears on this fd):' \
      '2:heredoc string:' \
      '*:program and arguments:_command_names -e'
    ;;

  homeof)
    _arguments -s -S \
      '1:username:_users'
    ;;

  ifelse)
    _arguments -s -S \
      '-n[negate: run THEN branch only if condition FAILS]' \
      '-X[XEC: chain-load remainder instead of forking]' \
      '*:command-if (in {} braces) + command-then (in {} braces) + command-else:_command_names -e'
    ;;

  ifte)
    _arguments -s -S \
      '-n[negate: run THEN branch only if condition FAILS]' \
      '-X[XEC: chain-load remainder instead of forking]' \
      '*:command-then (in {} braces) + command-else (in {} braces) + command-if:_command_names -e'
    ;;

  ifthenelse)
    _arguments -s -S \
      '-X[XEC: chain-load remainder instead of forking]' \
      '-s[stick: append remainder to the chosen branch]' \
      '*:cmd-if (in {} braces) + cmd-then (in {} braces) + cmd-else (in {} braces) + remainder:_command_names -e'
    ;;

  importas)
    _arguments -s -S \
      '(-D)-i[insist: fail if env var KEY is unset]' \
      '(-i)-D+[default value if env var KEY is unset]:default:' \
      '-u[unexport: remove KEY from the inherited env after binding]' \
      "${_exl_strip_nl[@]}" \
      '-s[strict: treat env var as one literal token (do not split)]' \
      "${_exl_chomp[@]}" \
      '-d+[delimiter char for splitting (default whitespace)]:delim:' \
      '1:env var KEY name:' \
      '2:local var NAME to bind to:_parameters' \
      '*:program and arguments:_command_names -e'
    ;;

  loopwhilex)
    _arguments -s -S \
      '-n[negate: loop WHILE prog FAILS instead of succeeds]' \
      "${_exl_okbreak[@]}" \
      '*:program and arguments to loop:_command_names -e'
    ;;

  multidefine)
    _arguments -s -S \
      "${_exl_delim[@]}" \
      '-r[raw: do not interpret \\-escapes in value]' \
      "${_exl_strip_nl[@]}" \
      "${_exl_chomp[@]}" \
      '1:value string:' \
      '*:vars (in {} braces) + program and arguments:_command_names -e'
    ;;

  multisubstitute)
    _arguments -s -S \
      '*:multisubstitute block (in {} braces) + program and arguments:_command_names -e'
    ;;

  pipeline)
    _arguments -s -S \
      '-d[detach pipeline producer from process group]' \
      '(-w)-r[read-side: connect inner cmd stdout to outer stdin (default)]' \
      '(-r)-w[write-side: connect inner cmd stdin to outer stdout]' \
      '*:inner command (in {} braces) + outer command:_command_names -e'
    ;;

  piperw)
    _arguments -s -S \
      '1:read fd:' \
      '2:write fd:' \
      '*:program and arguments:_command_names -e'
    ;;

  posix-cd)
    _arguments -s -S \
      '(-P)-L[follow symbolic links in path resolution (POSIX default)]' \
      '(-L)-P[do NOT follow symbolic links (canonical path)]' \
      '1:path (or - for $OLDPWD):_directories' \
      '*:program and arguments:_command_names -e'
    ;;

  posix-umask)
    _arguments -s -S \
      '-S[print umask in symbolic form (u=rwx,g=rwx,o=rx)]' \
      '1:octal mask:' \
      '*:program and arguments:_command_names -e'
    ;;

  redirfd)
    _arguments -s -S \
      '(-w -u -a -x)-r[OPEN for READ only (O_RDONLY)]' \
      '(-r -u -a -x)-w[OPEN for WRITE only with O_TRUNC + O_CREAT]' \
      '(-r -w -a -x)-u[OPEN for READ+WRITE (O_RDWR + O_CREAT)]' \
      '(-r -w -u -x)-a[OPEN for APPEND (O_APPEND + O_CREAT)]' \
      '(-r -w -u -a)-x[OPEN EXCLUSIVELY (O_EXCL + O_CREAT; fail if exists)]' \
      '(-n --block --nonblock)'{-N,--block}'[open in BLOCKING mode (default)]' \
      '(-N --block --nonblock)'{-n,--nonblock}'[add O_NONBLOCK to open flags]' \
      '(-b --switch-block)'{-b,--switch-block}'[after open, switch fd to blocking mode]' \
      '(-f --open)'{-f,--open}'[open even if file already has the fd assigned]' \
      "${_exl_autoimport[@]}" \
      '1:fd number or var name:' \
      '2:file path:_files' \
      '*:program and arguments:_command_names -e'
    ;;

  runblock)
    _arguments -s -S \
      '-P[pass the block through env to next stage instead of running now]' \
      '-r[recursive: also pass through nested blocks]' \
      '-n+[shift this many positional args before running the block]:argshift:' \
      '1:block number (1-indexed):' \
      '*:remaining command args:_command_names -e'
    ;;

  tryexec)
    _arguments -s -S \
      '-n[on inner exec failure, return 1 instead of dying]' \
      '-c[clear the inner exec failure marker before retrying]' \
      '-l[loop: keep retrying until exec succeeds]' \
      '-a+[argv[0] to substitute when exec'\''ing the inner command]:argv0:' \
      '*:command (in {} braces) + remainder:_command_names -e'
    ;;

  unexport)
    _arguments -s -S \
      '1:variable name to remove from env:_parameters' \
      '*:program and arguments:_command_names -e'
    ;;

  withstdinas)
    _arguments -s -S \
      '(-I -D)-i[insist: fail if stdin is empty]' \
      '(-i -D)-I[INSIST harder: fail if stdin read returns short]' \
      '(-i -I)-D+[default value if stdin is empty]:default:' \
      "${_exl_strip_nl[@]}" \
      "${_exl_autoimport[@]}" \
      '1:variable name:_parameters' \
      '*:remainder:_command_names -e'
    ;;

esac
