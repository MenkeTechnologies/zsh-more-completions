#compdef django-admin manage.py manage django

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'check:check the project for problems'
  'compilemessages:compile .po message files to .mo'
  'createcachetable:create the table for database caches'
  'dbshell:run the database client'
  'diffsettings:show settings differences'
  'dumpdata:output app data as JSON/XML/YAML'
  'flush:remove all data from the database'
  'inspectdb:introspect the database, output models'
  'loaddata:load data fixtures'
  'makemessages:scan code for translatable strings'
  'makemigrations:create new migrations from model changes'
  'migrate:apply or unapply migrations'
  'optimizemigration:optimize migration ops'
  'runserver:run the development web server'
  'sendtestemail:send a test email'
  'shell:start a Python shell'
  'showmigrations:list project migrations'
  'sqlflush:print the SQL statements for flush'
  'sqlmigrate:print the SQL for a migration'
  'sqlsequencereset:print SQL to reset sequences'
  'squashmigrations:squash existing migrations'
  'startapp:create a new app directory'
  'startproject:create a new project directory'
  'test:run the test suite'
  'testserver:run a server with test fixtures'
  'changepassword:change a users password'
  'createsuperuser:create a superuser'
  'remove_stale_contenttypes:remove stale content types'
  'clearsessions:clear expired sessions'
  'collectstatic:collect static files'
  'findstatic:find a static file'
  'version:show Django version'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show Django version]' \
  '--settings=[settings module]:settings:' \
  '--pythonpath=[directory to add to PYTHONPATH]:dir:_files -/' \
  '--traceback[show full Python traceback]' \
  '--no-color[disable colorized output]' \
  '--force-color[force colorized output]' \
  '--skip-checks[skip system checks]' \
  '(-v --verbosity)'{-v,--verbosity=}'[verbosity level]:level:(0 1 2 3)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'manage.py subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (migrate)
        _arguments \
          '--database=[database alias]:db:' \
          '--fake[mark migrations as run]' \
          '--fake-initial[detect initial migrations as applied]' \
          '--plan[show migrations plan]' \
          '--run-syncdb[create unmigrated app tables]' \
          '--check[exit with non-zero if changes pending]' \
          '--noinput[no input]' \
          '--prune[remove unapplied migrations]' && ret=0
        ;;
      (makemigrations)
        _arguments \
          '--dry-run[do not write files]' \
          '--merge[merge conflicting migrations]' \
          '--empty[create an empty migration]' \
          '--noinput[no input]' \
          '--name=[migration name]:name:' \
          '--no-header[no header in migration]' \
          '--check[exit non-zero if changes pending]' \
          '--scriptable[scriptable output]' \
          '--update[update latest migration]' && ret=0
        ;;
      (showmigrations)
        _arguments \
          '(-l --list)'{-l,--list}'[list format]' \
          '(-p --plan)'{-p,--plan}'[plan format]' \
          '--database=[database alias]:db:' && ret=0
        ;;
      (dumpdata)
        _arguments \
          '--all[dump all data]' \
          '--format=[format]:fmt:(json xml yaml jsonl)' \
          '--indent=[indent]:n:' \
          '*'{-e,--exclude=}'[apps/models to exclude]:exclude:' \
          '--database=[database alias]:db:' \
          '--natural-foreign[use natural foreign keys]' \
          '--natural-primary[use natural primary keys]' \
          '--pks=[primary keys to dump]:pks:' \
          '(-o --output)'{-o,--output=}'[output file]:file:_files' && ret=0
        ;;
      (loaddata)
        _arguments \
          '--database=[database alias]:db:' \
          '--app=[app label]:app:' \
          '--format=[fixture format]:fmt:(json xml yaml jsonl)' \
          '*'{-e,--exclude=}'[apps/models to exclude]:exclude:' \
          '--ignorenonexistent[ignore non-existent fields]' \
          '*:fixture:_files' && ret=0
        ;;
      (runserver)
        _arguments \
          '--noreload[do not auto-reload]' \
          '--nothreading[do not use threading]' \
          '(-6 --ipv6)'{-6,--ipv6}'[use IPv6]' \
          '--skip-checks[skip system checks]' \
          ':addrport:' && ret=0
        ;;
      (shell)
        _arguments \
          '(-i --interface)'{-i,--interface=}'[shell interface]:shell:(ipython bpython python)' \
          '--no-startup[do not run startup script]' \
          '--no-imports[no automatic imports]' \
          '(-c --command)'{-c,--command=}'[execute command]:cmd:' && ret=0
        ;;
      (test)
        _arguments \
          '--failfast[stop on first failure]' \
          '--testrunner=[test runner class]:class:' \
          '--noinput[no input]' \
          '--keepdb[preserve test DB]' \
          '--shuffle=[shuffle tests]:seed:' \
          '--reverse[reverse order]' \
          '--debug-mode[enable DEBUG]' \
          '--debug-sql[output SQL queries]' \
          '--parallel=[parallel test workers]:n:' \
          '*--tag=[run tests with tag]:tag:' \
          '*--exclude-tag=[exclude tests with tag]:tag:' \
          '--pdb[drop into pdb on failure]' \
          '--buffer[buffer stdout/stderr]' \
          '-k=[match test names]:pattern:' \
          '--timing[output test timing]' \
          '--durations=[show N slowest tests]:n:' \
          '*:tests:' && ret=0
        ;;
      (startproject|startapp)
        _arguments \
          '--template=[project template]:template:' \
          '*'{-e,--extension=}'[file extension]:ext:' \
          '*'{-n,--name=}'[file basename]:name:' \
          '*'{-x,--exclude=}'[exclude pattern]:pattern:' \
          '--directory=[project directory]:dir:_files -/' && ret=0
        ;;
      (collectstatic)
        _arguments \
          '--noinput[no input]' \
          '--no-post-process[do not post-process]' \
          '*'{-i,--ignore=}'[ignore pattern]:pattern:' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '(-c --clear)'{-c,--clear}'[clear destination first]' \
          '(-l --link)'{-l,--link}'[create symlinks]' \
          '--no-default-ignore[no default ignore patterns]' && ret=0
        ;;
      (createsuperuser)
        _arguments \
          '--username=[username]:user:_users' \
          '--email=[email]:email:' \
          '--database=[database alias]:db:' \
          '--noinput[no input]' && ret=0
        ;;
      (check)
        _arguments \
          '*'{-t,--tag=}'[run only checks with tag]:tag:' \
          '--list-tags[list available tags]' \
          '--deploy[run deployment checks]' \
          '--fail-level=[fail level]:level:(CRITICAL ERROR WARNING INFO DEBUG)' \
          '--database=[database alias]:db:' && ret=0
        ;;
    esac
    ;;
esac

return ret
