#compdef work-break
# Documentation: https://github.com/ShadoySV/work-break
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# work-break: Pomodoro-style work/rest notifier daemon.
# Subcommands per upstream README: autorun, notify, status, reload.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:(autorun notify status reload)' && return 0
