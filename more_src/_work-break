#compdef work-break
# Documentation: https://man.archlinux.org/search?q=work-break
# Reference accessed: 2026-05-16

# https://github.com/ShadoySV/work-break — Pomodoro-style work/rest notifier daemon

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '1:command:(autorun reload status notify work break terminate)' && return 0
