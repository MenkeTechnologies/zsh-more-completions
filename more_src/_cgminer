#compdef cgminer
# _cgminer — Con Kolivas cgminer ASIC and FPGA mining CLI for Bitcoin SHA-256 mining controlling Antminer Avalon BFL BlackArrow Cointerra HashFast Innosilicon Klondike Modminer Nanofury Onestring Spondoolies UPS USB Asic Stratum failover pool fan temp (ckolivas team, C); getopt
# upstream: https://github.com/ckolivas/cgminer

_cgminer() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-c+[config file]:file:_files -g "*.conf cgminer.conf"' \
        '--config=+[config file]:file:_files -g "*.conf cgminer.conf"' \
        '-o+[pool url]:str:' \
        '--url=+[pool url]:str:' \
        '-u+[user.worker]:str:' \
        '--user=+[user.worker]:str:' \
        '-p+[password]:str:' \
        '--pass=+[password]:str:' \
        '-O+[user:password]:str:' \
        '--userpass=+[user:password]:str:' \
        '-q+[N]:n:' \
        '--queue=+[N]:n:' \
        '-l+[N]:n:' \
        '--log=+[seconds]:n:' \
        '-d+[device list]:str:' \
        '--device=+[device list]:str:' \
        '-G[disable GPU]' \
        '--disable-gpu[disable GPU]' \
        '--enable-icarus[enable Icarus]' \
        '--ant-s1[Antminer S1]' \
        '--ant-s2[Antminer S2]' \
        '--ant-s3[Antminer S3]' \
        '-T[show text]' \
        '--text-only[show text]' \
        '-D[debug]' \
        '--debug[debug]' \
        '--protocol-dump[protocol dump]' \
        '--log-show-date[log show date]' \
        '--api-listen[enable API server]' \
        '--api-port=+[port]:n:' \
        '--api-network[allow API from network]' \
        '--api-groups=+[csv]:str:' \
        '--api-allow=+[csv]:str:' \
        '--api-description=+[text]:str:' \
        '--no-restart[no restart]' \
        '--syslog[use syslog]' \
        '--monitor=+[command]:str:' \
        '--failover-only[failover only]' \
        '--scan-time=+[seconds]:n:' \
        '--shares=+[N]:n:' \
        '--socks-proxy=+[host:port]:str:' \
        '--load-balance[load balance]' \
        '--round-robin[round robin]' \
        '--coinbase-addr=+[addr]:str:' \
        '--coinbase-sig=+[text]:str:' \
        '--cmd-idle=+[cmd]:str:' \
        '--cmd-sick=+[cmd]:str:' \
        '--cmd-dead=+[cmd]:str:' \
        '--lowmem[low memory]' \
        '--worktime[work time]'
}

_cgminer "$@"
