#compdef glooctl
# _glooctl — Solo.io Gloo Edge / Gateway management CLI (Solo.io, Go); spf13/cobra
# upstream: https://github.com/solo-io/gloo

_glooctl() {
    local -a sub=(
        'add:add a route/upstream/auth-config'
        'check:check Gloo system'
        'check-crds:check CRDs'
        'cluster:cluster management'
        'completion:generate shell completion'
        'create:create a resource'
        'dashboard:open Gloo UI'
        'debug:debug helpers'
        'delete:delete a resource'
        'demo:run demos'
        'edit:edit a resource'
        'federation:federated management'
        'get:show a resource'
        'init-plugin-manager:init plugin manager'
        'install:install Gloo'
        'istio:istio integration'
        'license:license commands'
        'plugin:manage plugins'
        'proxy:show proxy info'
        'remove:remove a route'
        'rl:rate-limit'
        'route:route management'
        'support:create support bundle'
        'tap:tap on a resource'
        'uninstall:uninstall Gloo'
        'upgrade:upgrade glooctl/Gloo'
        'virtualservice:virtual service management'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--namespace=+[gloo namespace]:str:' \
        '-n+[gloo namespace]:str:' \
        '--kubeconfig=+[kubeconfig]:file:_files' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '--config=+[config file]:file:_files' \
        '--dry-run[dry run]' \
        '--use-experimental-api[use experimental API]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'glooctl subcommand' sub ;;
        args)
            case $words[1] in
                get|delete|edit) _arguments \
                    '1:type:(upstream virtualservice gateway routetable authconfig settings proxy secrets ratelimit)' \
                    '--namespace=+[namespace]:str:' \
                    '-n+[namespace]:str:' \
                    '*:name:' ;;
                add|remove|route) _arguments \
                    '1:type:(route)' \
                    '*:arg:' ;;
                install|uninstall) _arguments \
                    '--namespace=+[namespace]:str:' \
                    '--version=+[version]:str:' \
                    '--release-name=+[release name]:str:' \
                    '--values=+[values yaml file]:file:_files' \
                    '--enterprise[enterprise]' \
                    '--license-key=+[license key]:str:' \
                    '--with-gloo-fed[with Gloo Fed]' ;;
                check) _arguments \
                    '--namespace=+[namespace]:str:' \
                    '--read-only-mode[read only mode]' \
                    '--exclude=+[resource type to exclude]:list:' \
                    '--include-cluster-services[include cluster services]' \
                    '-o+[output format]:fmt:(json yaml)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_glooctl "$@"
