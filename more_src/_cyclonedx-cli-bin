#compdef cyclonedx
# _cyclonedx-cli-bin — CycloneDX SBOM CLI (OWASP CycloneDX, C#); validate/analyze/convert/merge CycloneDX SBOM files
# upstream: https://github.com/CycloneDX/cyclonedx-cli

_cyclonedx-cli-bin() {
    local -a sub=(
        'add:add metadata/component'
        'analyze:analyze SBOM'
        'convert:convert SBOM between formats'
        'diff:diff two SBOMs'
        'keygen:generate key pair'
        'merge:merge SBOMs'
        'sign:sign SBOM'
        'validate:validate SBOM'
        'verify:verify SBOM signature'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(--version)--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cyclonedx subcommand' sub ;;
        args)
            case $words[1] in
                convert) _arguments \
                    '--input-file+[input file]:file:_files' \
                    '--output-file+[output file]:file:_files' \
                    '--input-format+[input format]:fmt:(autodetect json xml protobuf csv spdxjson)' \
                    '--output-format+[output format]:fmt:(autodetect json xml protobuf csv spdxjson)' \
                    '--input-version+[input version]:v:' \
                    '--output-version+[output version]:v:' ;;
                validate) _arguments \
                    '--input-file+[input file]:file:_files' \
                    '--input-format+[input format]:fmt:(autodetect json xml protobuf)' \
                    '--input-version+[input version]:v:' \
                    '--fail-on-errors[fail on errors]' ;;
                merge) _arguments \
                    '--input-files+[input files]:files:_files' \
                    '--output-file+[output file]:file:_files' \
                    '--input-format+[input format]:fmt:' \
                    '--output-format+[output format]:fmt:' \
                    '--hierarchical[hierarchical merge]' \
                    '--name+[name]:str:' \
                    '--version+[version]:str:' \
                    '--group+[group]:str:' ;;
                diff) _arguments \
                    '--from-file+[from file]:file:_files' \
                    '--to-file+[to file]:file:_files' \
                    '--from-format+[from format]:fmt:' \
                    '--to-format+[to format]:fmt:' \
                    '--component-versions[components only]' \
                    '--component-properties[components and props only]' ;;
                sign) _arguments \
                    '--input-file+[input file]:file:_files' \
                    '--key+[private key]:file:_files' \
                    '--output-file+[output file]:file:_files' ;;
                verify) _arguments \
                    '--input-file+[input file]:file:_files' \
                    '--public-key+[public key]:file:_files' ;;
            esac
            ;;
    esac
}

_cyclonedx-cli-bin "$@"
