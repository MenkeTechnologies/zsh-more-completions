#compdef sndfile-spectrogram
# _sndfile-spectrogram — render an audio file spectrogram to PNG (libsndfile/sndfile-tools)
# upstream: https://github.com/libsndfile/sndfile-tools
# Flags from src/spectrogram.c.

_sndfile-spectrogram() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '--dyn-range=[dynamic range (dB, default 180)]:db:'
        '--no-border[drop border / scales / heatmap / title]'
        '--log-freq[use logarithmic frequency axis]'
        '--min-freq=[minimum frequency (Hz)]:hz:'
        '--max-freq=[maximum frequency (Hz)]:hz:'
        '--fft-freq=[lowest resolvable frequency (Hz)]:hz:'
        '--gray-scale[grayscale palette]'
        '--kaiser[use Kaiser window (default)]'
        '--hann[use Hann window]'
        '--nuttall[use Nuttall window]'
        '--rectangular[use rectangular window]'
        '1:sound file:_files'
        '2:image width (px):'
        '3:image height (px):'
        '4:output PNG file:_files -g "*.png"'
    )
    _arguments -s $args
}

_sndfile-spectrogram "$@"
