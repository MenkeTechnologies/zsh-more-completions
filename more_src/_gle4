#compdef gle4
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/gle.1.html
# gle4 - Graphics Layout Engine (version 4 binary)

local ret=1

_arguments -s \
  '-help[show help about command line options]' \
  '-info[output software version, build date, GLE_TOP, GLE_BIN, etc.]' \
  '-verbosity[set the verbosity level of GLE console output]:level' \
  '-device[select output device(s)]:device:(eps teps ps pdf jpg png svg)' \
  '-cairo[use cairo output device]' \
  '-resolution[set the resolution for bitmap and PDF output]:dpi' \
  '-fullpage[select full page output]' \
  '-landscape[select full page landscape output]' \
  '-output[specify the name of the output file]:file:_files' \
  '-nosave[do not write output file to disk (dry-run)]' \
  '-preview[preview the output with QGLE]' \
  '-gs[preview the output with GhostScript]' \
  '-version[select a GLE version to run]:version' \
  '-compatibility[select a GLE compatibility mode]:mode' \
  '-calc[run GLE in calculator mode]' \
  '-catcsv[pretty print a CSV file to standard output]:file:_files' \
  '-tex[indicate that the script includes LaTeX expressions]' \
  '-inc[create an .inc file with LaTeX code]' \
  '-texincprefix[add the given subdirectory to the path in the .inc file]:prefix' \
  '-mkinittex[create inittex.ini from init.tex]' \
  '-nocolor[force grayscale output]' \
  '-transparent[create transparent output (with -d png)]' \
  '-noctrl-d[exclude CTRL-D from the PostScript output]' \
  '-nomaxpath[disable the upper-bound on drawing path complexity]' \
  '-noligatures[disable ligatures for fl and fi]' \
  '-gsoptions[specify additional options for GhostScript]:options' \
  '-safemode[disable reading/writing to the file system]' \
  '-allowread[allow reading from the given path]:path:_files' \
  '-allowwrite[allow writing to the given path]:path:_files' \
  '-keep[do not delete temporary files]' \
  '*:script:_files -g "*.gle"' && ret=0

return ret
