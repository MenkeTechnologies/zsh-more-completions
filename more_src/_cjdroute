#compdef cjdroute
# Documentation: https://www.mankier.com/1/cjdroute
# Reference accessed: 2026-05-17
# Verified: upstream docs (cjdroute(1) man page) at the URL above.

# cjdroute: cjdns packet switch
_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--genconf[generate config (writes to stdout)]' \
  '--genconf-seed[generate config from 64-byte seed on stdin]' \
  '--no-eth[disable ethernet beaconing in genconf]' \
  '--eth[include Ethernet interfaces in genconf-seed]' \
  '--cleanconf[reformat (print clean JSON) of config from stdin]' \
  '--nobg[do not fork to background]' \
  '--pidfile=[write PID to file]:file:_files'
