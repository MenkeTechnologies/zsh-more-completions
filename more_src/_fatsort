#compdef fatsort
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-a[sort hidden and system files too]' \
  '-c[case-sensitive sort]' \
  '-f[force sort even on mounted filesystem (DANGEROUS)]' \
  '-i[ignore matching entries]:pattern:' \
  '-I[use locale for sorting]:locale:' \
  '-l[list only, do not sort]' \
  '-n[natural order sort]' \
  '-o[sort order]:order:((a\:ascending d\:descending))' \
  '-q[quiet mode]' \
  '-r[reverse/recursive sort]' \
  '-t[sort by modification time]' \
  '-v[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:device:_files' && ret=0
return ret
