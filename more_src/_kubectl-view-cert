#compdef kubectl-view-cert
# Documentation: https://github.com/lmolas/kubectl-view-cert
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[query all objects in all namespaces]' \
  '(-E --expired)'{-E,--expired}'[show only expired certificates]' \
  '(-D --expired-days-from-now)'{-D+,--expired-days-from-now=}'[show expired certificates at date in future (now plus N days)]:days:' \
  '(-S --show-ca)'{-S,--show-ca}'[show CA certificates]' \
  '(-n --namespace)'{-n+,--namespace=}'[if present, the namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[the name of the kubeconfig context to use]:context:' \
  '--cluster=[the name of the kubeconfig cluster to use]:cluster:' \
  '--user=[the name of the kubeconfig user to use]:user:' \
  '--server=[the address and port of the Kubernetes API server]:server:' \
  '--token=[bearer token for authentication to the API server]:token:' \
  '--certificate-authority=[path to a cert file for the certificate authority]:file:_files' \
  '--client-certificate=[path to a client certificate file]:file:_files' \
  '--client-key=[path to a client key file]:file:_files' \
  '--insecure-skip-tls-verify[skip checking server certificate for validity]' \
  '--request-timeout=[length of time before giving up on a single server request]:timeout:' \
  '-v+[number for the log level verbosity]:level:' \
  '--version[version for kubectl-view-cert]' \
  '1:secret-name:' \
  '2:secret-key:'
