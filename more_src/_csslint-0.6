#compdef csslint-0.6 csslint
# Documentation: https://github.com/CSSLint/csslint/wiki/Command-line-interface
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (CSSLint deprecated since 2023).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version number]' \
  '--list-rules[output all available rules]' \
  '--quiet[suppress output except on errors]' \
  '--format=[output format]:format:(text compact lint-xml csslint-xml checkstyle-xml junit-xml)' \
  '--errors=[rules that trigger errors (csv)]:rules:' \
  '--warnings=[rules that trigger warnings (csv)]:rules:' \
  '--ignore=[rules to ignore (csv)]:rules:' \
  '--exclude-list=[paths to exclude (csv)]:paths:_files' \
  '*:CSS file:_files -g "*.css"' && ret=0

return ret
