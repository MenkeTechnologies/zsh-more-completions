#compdef csslint-0.6

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-v,--version}'[show version]' \
  '--dump-location[dump location]' \
  {-e,--evaluate}'[evaluate mode]' \
  '--author-sheet=[author stylesheet]:file:_files -g "*.css"' \
  '--user-sheet=[user stylesheet]:file:_files -g "*.css"' \
  '--ua-sheet=[user agent stylesheet]:file:_files -g "*.css"' \
  '--xml=[XML file]:file:_files -g "*.xml"' \
  '--xpath=[XPath expression]:expr:' \
  '*:CSS file:_files -g "*.css"' && ret=0

return ret
