#compdef nuXmv
# Documentation: https://nuxmv.fbk.eu/downloads/nuxmv-user-manual.pdf
# nuXmv symbolic model checker (batch-mode options)

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print the command line help]' \
  '-s[avoid loading commands from .nusmvrc/master.nusmvrc]' \
  '-int[start interactive shell]' \
  '-load+[interpret commands from file]:cmd file:_files' \
  '-source+[interpret commands from file]:cmd file:_files' \
  '-v+[enable printing of additional internal information]:verbose level:' \
  '-i+[read the variable ordering from file]:order file:_files' \
  '-o+[write the variable ordering to file]:order file:_files' \
  '-ctt[check whether the transition relation is total]' \
  '-lp[list all properties in SMV model]' \
  '-n+[specify which property of SMV model should be checked]:idx:' \
  '-cpp[run preprocessor on SMV files]' \
  '-is[do not check SPEC]' \
  '-ic[do not check COMPUTE]' \
  '-ils[do not check LTLSPEC]' \
  '-ii[do not check INVARSPEC]' \
  '-r[print the number of reachable states before exiting]' \
  '-f[compute reachable states before evaluating CTL expressions]' \
  '-AG[verify only AG formulas using an ad hoc algorithm]' \
  '-reorder[enable variable reordering after checking specifications]' \
  '-dynamic[enable dynamic reordering of variables]' \
  '-m+[method used when variable ordering is enabled]:method:' \
  '-mono[enable monolithic transition relation]' \
  '-thresh+[conjunctive partitioning with threshold (default 1000)]:cp_t:' \
  '-iwls95+[enable Iwls95 conjunctive partitioning]:cp_t:' \
  '-coi[enable cone of influence reduction]' \
  '-noaffinity[disable affinity clustering]' \
  '-dcx[disable display of counter-examples to false specifications]' \
  '-bmc[enable BMC instead of BDD model checking]' \
  '-bmc_length+[set bmc_length variable used by BMC]:length:' \
  '-ofm+[print flattened model to file]:fm file:_files' \
  '-obm+[print boolean model to file]:bm file:_files' \
  '*:smv file:_files -g "*.smv"' && ret=0

return ret
