#compdef doh-server
# _doh-server — DNS-over-HTTPS server (m13253/dns-over-https)
# upstream: https://github.com/m13253/dns-over-https
# Flags from doh-server/main.go (flag).

_doh-server() {
    _arguments \
        '(- *)-version[show version]' \
        '-conf+[config file]:file:_files -g "*.(conf|toml)"' \
        '-verbose[enable logging]' \
        '-pidfile+[PID file path]:file:_files'
}

_doh-server "$@"
