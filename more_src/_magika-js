_magika-js() {
    _arguments -s -S \
        '--json-output[format output in JSON]' \
        '--model-url=[override model URL]:url:' \
        '--model-path=[local path to model file (overrides URL)]:path:_files -g "*.bin *.json"' \
        '--model-config-url=[override model-config URL]:url:' \
        '--model-config-path=[local path to model config (overrides URL)]:path:_files -g "*.json"' \
        '--by-stream[identify file via stream (vs default by-bytes)]' \
        '--debug[output debug information (dl.label + output.label + score)]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '*:files to classify:_files'
}

_magika-js "$@"
