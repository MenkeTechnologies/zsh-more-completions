#compdef number-lines
# Documentation: https://github.com/eBay/tsv-utils/blob/master/docs/tool_reference/number-lines.md
# number-lines - prepend a line number to each line of input

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version information and exit]' \
  '(-H --header)'{-H,--header}'[treat first line of each file as a header]' \
  '(-s --header-string)'{-s,--header-string}'=[string to use as the header for the line number field]:string:' \
  '(-n --start-number)'{-n,--start-number}'=[number to use for the first line]:num:' \
  '(-d --delimiter)'{-d,--delimiter}'=[character appended to the line number, preceding the rest of the line]:delimiter char:' \
  '--line-buffered[immediately output every line]' \
  '*:file:_files' && ret=0

return ret
