#compdef mesheryctl

# Zsh completion for mesheryctl - Meshery cloud-native management CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_mesheryctl_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]'
  '(-c --config)'{-c+,--config=}'[path to config file]:config file:_files -g "*.{yaml,yml}"'
  '(-y --yes)'{-y,--yes}'[assume yes for prompts]'
)

_mesheryctl_system_commands() {
  local -a commands
  commands=(
    'start:Start Meshery'
    'stop:Stop Meshery'
    'restart:Restart Meshery'
    'status:Show Meshery status'
    'update:Update Meshery'
    'config:Manage Meshery config'
    'logs:Show Meshery logs'
    'reset:Reset Meshery'
    'check:Run preflight checks'
    'context:Manage Meshery contexts'
    'channel:Manage Meshery release channels'
    'provider:Manage Meshery providers'
    'dashboard:Open Meshery dashboard'
    'login:Log in to Meshery'
    'logout:Log out of Meshery'
    'token:Manage Meshery tokens'
  )
  _describe -t commands 'system commands' commands
}

_mesheryctl_mesh_commands() {
  local -a commands
  commands=(
    'validate:Validate service mesh conformance'
    'deploy:Deploy a service mesh'
    'remove:Remove a service mesh'
  )
  _describe -t commands 'mesh commands' commands
}

_mesheryctl_perf_commands() {
  local -a commands
  commands=(
    'apply:Run a performance test'
    'list:List performance test results'
    'view:View a performance test result'
    'delete:Delete a performance test result'
  )
  _describe -t commands 'perf commands' commands
}

