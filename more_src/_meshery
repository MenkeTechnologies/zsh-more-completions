_mesheryctl_registry_commands() {
  local -a commands
  commands=(
    'publish:Publish to registry'
    'update:Update registry'
  )
  _describe -t commands 'registry commands' commands
}

_arguments -s -S -C \
  "${_mesheryctl_global_flags[@]}" \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'system:Manage Meshery lifecycle'
      'mesh:Manage service meshes'
      'perf:Performance management'
      'pattern:Manage patterns'
      'filter:Manage WASM filters'
      'app:Manage applications'
      'model:Manage models'
      'design:Manage designs'
      'exp:Experimental features'
      'registry:Manage registry'
      'version:Show version'
    )
    _describe -t commands 'mesheryctl commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      system)
        _arguments -s -S -C \
          "${_mesheryctl_global_flags[@]}" \
          '1:subcommand:_mesheryctl_system_commands' \
          '*::arg:->system_args' && ret=0
        case "$state" in
          system_args)
            case "${line[1]}" in
              start)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--platform=[platform to deploy on]:platform:(docker kubernetes)' \
                  '--skip-update[skip update check]' \
                  '--skip-browser[skip opening browser]' && ret=0
                ;;
              stop)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--force[force stop]' \
                  '--keep-namespace[keep the Meshery namespace]' && ret=0
                ;;
              restart)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--skip-update[skip update check]' && ret=0
                ;;
              status)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" && ret=0
                ;;
              update)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--skip-reset[skip reset of local config]' && ret=0
                ;;
              config)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:operation:' && ret=0
                ;;
              logs)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--follow[follow log output]' && ret=0
                ;;
              reset)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" && ret=0
                ;;
              check)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--pre[run pre-flight checks]' \
                  '--preflight[run pre-flight checks]' \
                  '--adapter[check adapter status]' && ret=0
                ;;
              context)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:operation:(create delete list switch view)' \
                  '2:context name:' && ret=0
                ;;
              channel)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:operation:(set view)' \
                  '2:channel:(stable edge)' && ret=0
                ;;
              provider)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:operation:(set view list reset switch)' && ret=0
                ;;
              dashboard)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--port=[dashboard port]:port:' \
                  '--skip-browser[skip opening browser]' && ret=0
                ;;
              login)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" && ret=0
                ;;
              logout)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" && ret=0
                ;;
              token)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:operation:(create delete list)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      mesh)
        _arguments -s -S -C \
          "${_mesheryctl_global_flags[@]}" \
          '1:subcommand:_mesheryctl_mesh_commands' \
          '*::arg:->mesh_args' && ret=0
        case "$state" in
          mesh_args)
            case "${line[1]}" in
              validate)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--adapter=[adapter to use]:adapter:' \
                  '--spec=[specification to validate]:spec:(smi)' \
                  '--token-path=[path to token file]:file:_files' && ret=0
                ;;
              deploy)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--adapter=[adapter to use]:adapter:' \
                  '--namespace=[namespace to deploy to]:namespace:' \
                  '--token-path=[path to token file]:file:_files' && ret=0
                ;;
              remove)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--adapter=[adapter to use]:adapter:' \
                  '--namespace=[namespace]:namespace:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      perf)
        _arguments -s -S -C \
          "${_mesheryctl_global_flags[@]}" \
          '1:subcommand:_mesheryctl_perf_commands' \
          '*::arg:->perf_args' && ret=0
        case "$state" in
          perf_args)
            case "${line[1]}" in
              apply)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--url=[URL to test]:url:' \
                  '--name=[test name]:name:' \
                  '--mesh=[service mesh]:mesh:' \
                  '--qps=[queries per second]:qps:' \
                  '--concurrent-requests=[concurrent requests]:requests:' \
                  '--duration=[test duration]:duration:' \
                  '--load-generator=[load generator]:generator:(fortio wrk2 nighthawk)' \
                  '(-f --file)'{-f+,--file=}'[test configuration file]:file:_files -g "*.{yaml,yml}"' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" && ret=0
                ;;
              view)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:test name or id:' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:test name or id:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      pattern)
        _arguments -s -S -C \
          "${_mesheryctl_global_flags[@]}" \
          '1:subcommand:_mesheryctl_pattern_commands' \
          '*::arg:->pattern_args' && ret=0
        case "$state" in
          pattern_args)
            case "${line[1]}" in
              apply)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '(-f --file)'{-f+,--file=}'[pattern file]:file:_files -g "*.{yaml,yml}"' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '(-f --file)'{-f+,--file=}'[pattern file]:file:_files -g "*.{yaml,yml}"' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" && ret=0
                ;;
              view)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:pattern name or id:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      filter)
        _arguments -s -S -C \
          "${_mesheryctl_global_flags[@]}" \
          '1:subcommand:_mesheryctl_filter_commands' \
          '*::arg:->filter_args' && ret=0
        case "$state" in
          filter_args)
            case "${line[1]}" in
              apply)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '(-f --file)'{-f+,--file=}'[filter file]:file:_files -g "*.wasm"' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:filter name or id:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" && ret=0
                ;;
              view)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:filter name or id:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      app)
        _arguments -s -S -C \
          "${_mesheryctl_global_flags[@]}" \
          '1:subcommand:_mesheryctl_app_commands' \
          '*::arg:->app_args' && ret=0
        case "$state" in
          app_args)
            case "${line[1]}" in
              import)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '(-f --file)'{-f+,--file=}'[application file]:file:_files -g "*.{yaml,yml}"' \
                  '--source-type=[source type]:type:(helm manifest compose)' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" && ret=0
                ;;
              view)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:application name or id:' && ret=0
                ;;
              onboard)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '(-f --file)'{-f+,--file=}'[application file]:file:_files -g "*.{yaml,yml}"' \
                  '--source-type=[source type]:type:(helm manifest compose)' && ret=0
                ;;
              offboard)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '(-f --file)'{-f+,--file=}'[application file]:file:_files -g "*.{yaml,yml}"' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      model)
        _arguments -s -S -C \
          "${_mesheryctl_global_flags[@]}" \
          '1:subcommand:_mesheryctl_model_commands' \
          '*::arg:->model_args' && ret=0
        case "$state" in
          model_args)
            case "${line[1]}" in
              list)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '--page=[page number]:page:' \
                  '--pagesize=[page size]:size:' && ret=0
                ;;
              view)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:model name:' && ret=0
                ;;
              search)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:search term:' && ret=0
                ;;
              import)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '(-f --file)'{-f+,--file=}'[model file]:file:_files' && ret=0
                ;;
              export)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:model name:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      design)
        _arguments -s -S -C \
          "${_mesheryctl_global_flags[@]}" \
          '1:subcommand:_mesheryctl_design_commands' \
          '*::arg:->design_args' && ret=0
        case "$state" in
          design_args)
            case "${line[1]}" in
              apply)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '(-f --file)'{-f+,--file=}'[design file]:file:_files -g "*.{yaml,yml}"' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '(-f --file)'{-f+,--file=}'[design file]:file:_files -g "*.{yaml,yml}"' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" && ret=0
                ;;
              view)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:design name or id:' && ret=0
                ;;
              import)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '(-f --file)'{-f+,--file=}'[design file]:file:_files -g "*.{yaml,yml}"' \
                  '--source-type=[source type]:type:' && ret=0
                ;;
              export)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:design name or id:' \
                  '--output=[output format]:format:(yaml json)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      exp)
        _arguments -s -S -C \
          "${_mesheryctl_global_flags[@]}" \
          '1:subcommand:_mesheryctl_exp_commands' \
          '*::arg:->exp_args' && ret=0
        case "$state" in
          exp_args)
            case "${line[1]}" in
              components|relationship|connections|environment|workspace)
                _arguments -s -S \
                  "${_mesheryctl_global_flags[@]}" \
                  '1:operation:(list view)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      registry)
        _arguments -s -S -C \
          "${_mesheryctl_global_flags[@]}" \
          '1:subcommand:_mesheryctl_registry_commands' && ret=0
        ;;
      version)
        _arguments -s -S \
          "${_mesheryctl_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
