#compdef meshery
# Documentation: https://docs.meshery.io/reference/mesheryctl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: there is no separate canonical "meshery" CLI; Meshery is
# managed via "mesheryctl" (see _mesheryctl). Keep a minimal stub
# so completion still loads for users who alias "meshery" locally.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[show version]' \
  '*::meshery args:_default' && ret=0

return ret
