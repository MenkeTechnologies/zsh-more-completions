#compdef tau
# =============================================================================
# tau — Taubyte Network's "Fullstack Workspace for Humans &
#       Machines" — a Go-based decentralized cloud-platform
#       node binary that runs the Taubyte distributed P2P
#       network for serverless functions, websites, and
#       databases, replacing AWS/Vercel-style centralized
#       infrastructure with libp2p + IPFS + WebAssembly
#       sandboxes.
#       Distinguishing from k3s, microk8s, fly.io, vercel-cli,
#       and other PaaS deployment tools by:
#         - DECENTRALIZED P2P NETWORK — no central control
#           plane; tau nodes form a libp2p mesh that gossips
#           function/website state via PubSub and stores
#           assets in IPFS
#         - WEBASSEMBLY SANDBOXES — user code (functions,
#           pubsub handlers, HTTP services) compiles to WASM
#           and runs in tau's WAMR-based sandbox isolation;
#           NO container overhead
#         - SHAPE-BASED NODE TOPOLOGY — tau nodes have a
#           "shape" (auth / patrick / monkey / hoarder / odo /
#           seer / tns / gateway) defining their role; --shape
#           flag selects which services run on a given node
#         - URFAVE/CLI v2 FRAMEWORK — uses urfave/cli/v2 (not
#           cobra) with Commands + Subcommands + Aliases
#         - 3 ROOT COMMANDS:
#             * info build [--json] [--deps]  — show build info
#             * info commit                     — show commit hash
#             * start --shape S [--dev]         — start a shape
#             * config validate [-s SHAPE] [-p PATH]
#                                               — validate config
#             * config show [-s SHAPE] [-p PATH]
#                                               — display config
#             * config export [--unsafe]        — export config bundle
#         - SOURCE-CONFIG PARSING — tau reads config from
#           /tb/<shape>/config.yaml (default root /tb;
#           overridable via --root); validate / show / export
#           operate on these configs
#         - JSON BUILD-INFO via `tau info build --json` —
#           emits go-runtime BuildInfo (debug.BuildInfo)
#           including ldflag-injected Version + Commit +
#           BuildDate
#         - GORILLA/WEBSOCKET FOR P2P STREAMS — tau uses
#           gorilla/websocket as one of its transports for
#           peer-to-peer streams + dashboard real-time updates;
#           libp2p-websocket transport binds gorilla/websocket
#           to libp2p connections
#         - VERSION INJECTION VIA LDFLAGS — release binaries
#           have Version + Commit + BuildDate injected at link
#           time via -X linker flags; debug.ReadBuildInfo
#           fallback for `go run` invocations
#       Used by: Taubyte cloud customers running self-hosted
#       decentralized infrastructure, developers building
#       Web3/decentralized applications without AWS lock-in,
#       and as a reference implementation of gorilla/websocket
#       + urfave/cli + libp2p + IPFS + WAMR composition in Go.
#
# Author:  Taubyte Network (taubyte.com) — decentralized cloud
#          startup.  Active development through 2026.  License:
#          BSD-3-Clause.
# Source:  https://github.com/taubyte/tau
#          https://github.com/taubyte/tau/blob/main/cli/app/app.go
#          https://github.com/taubyte/tau/blob/main/cli/app/start_cmd.go
#          https://github.com/taubyte/tau/blob/main/cli/app/config_cmd.go
#          https://github.com/taubyte/tau/blob/main/cli/app/buildinfo_cmd.go
#          https://github.com/taubyte/tau/blob/main/go.mod
# CLI:     cli/app/*.go — uses urfave/cli/v2 (alternative to
#          cobra; documented elsewhere).  Headline library:
#          **gorilla/websocket** (urfave/cli is documented
#          across many Go completions; gorilla/websocket is the
#          new variant being documented here, expanding Axis 18
#          — WebSockets — to Go).
# Library: github.com/gorilla/websocket v1.5.3
#          ("gorilla/websocket" — "fast, well-tested and widely
#           used WebSocket implementation for Go" — originally
#           by Gary Burd as part of the gorilla web toolkit;
#           continued through 2024 as the canonical Go
#           WebSocket library.  Distinct from tokio-tungstenite
#           (R657, Rust Axis 18 opener) by being:
#              1. RFC 6455 WEBSOCKET PROTOCOL — same protocol
#                 as tungstenite but Go-idiomatic API:
#                   import "github.com/gorilla/websocket"
#                   var upgrader = websocket.Upgrader{
#                     CheckOrigin: func(r *http.Request) bool { return true },
#                   }
#                   func handler(w http.ResponseWriter, r *http.Request) {
#                     conn, err := upgrader.Upgrade(w, r, nil)
#                     if err != nil { log.Println(err); return }
#                     defer conn.Close()
#                     for {
#                       mt, msg, err := conn.ReadMessage()
#                       if err != nil { break }
#                       conn.WriteMessage(mt, msg)
#                     }
#                   }
#              2. UPGRADER PATTERN — server-side, an Upgrader
#                 struct configures handshake parameters
#                 (ReadBufferSize, WriteBufferSize, CheckOrigin,
#                 EnableCompression, Subprotocols) and upgrades
#                 an HTTP connection to WebSocket.  Distinct
#                 from tungstenite's accept_async function-based
#                 approach.
#              3. DIALER PATTERN — client-side, websocket.
#                 DefaultDialer.Dial(url, headers) opens a
#                 WebSocket connection.  Custom Dialer with
#                 NetDial / TLSClientConfig / Subprotocols /
#                 HandshakeTimeout for advanced cases:
#                   c, _, err := websocket.DefaultDialer.Dial(
#                     "wss://api.example.com/v1/stream",
#                     http.Header{"Authorization": []string{"Bearer xyz"}},
#                   )
#              4. READ/WRITE MESSAGE METHODS — conn.ReadMessage()
#                 returns (messageType, []byte, error);
#                 conn.WriteMessage(messageType, data) sends.
#                 Message types: websocket.TextMessage,
#                 websocket.BinaryMessage, websocket.CloseMessage,
#                 websocket.PingMessage, websocket.PongMessage.
#                 Distinct from tungstenite's Message enum
#                 variants.
#              5. JSON HELPERS — conn.ReadJSON(&v) and
#                 conn.WriteJSON(&v) provide direct JSON
#                 marshal/unmarshal over WebSocket messages.
#                 Distinct from tungstenite (no built-in JSON;
#                 user must serialize manually).
#              6. PERMESSAGE-DEFLATE — opt-in compression via
#                 EnableCompression: true in Upgrader/Dialer.
#                 Same as tungstenite's feature.
#              7. PING/PONG HANDLERS — conn.SetPingHandler() and
#                 conn.SetPongHandler() for keepalive control.
#                 conn.WriteControl(websocket.PingMessage, ...)
#                 sends ping.  Distinct from tungstenite's
#                 automatic ping/pong handling.
#              8. SUBPROTOCOL NEGOTIATION — both client (Dialer.
#                 Subprotocols) and server (Upgrader.Subprotocols)
#                 negotiate via Sec-WebSocket-Protocol header.
#              9. NO BUILT-IN TLS WRAPPER — TLS comes from
#                 http.Transport / TLSClientConfig; gorilla/
#                 websocket uses Go's stdlib crypto/tls.
#                 Distinct from tungstenite (offers
#                 native-tls/rustls choice).
#             10. GORILLA WEB TOOLKIT PROVENANCE — originally
#                 part of the Gorilla Web Toolkit (gorilla/mux,
#                 gorilla/handlers, gorilla/sessions, gorilla/
#                 csrf).  Gorilla project was archived in
#                 December 2022 but unarchived in October 2023
#                 by new maintainers; gorilla/websocket remains
#                 the de facto Go WebSocket library.)
# License: BSD-2-Clause (gorilla/websocket); BSD-3-Clause (tau)
# Status:  gorilla/websocket — 24,742+ stars on gorilla/websocket,
#          ~1.5B go.sum downloads (TOP-5 Go library by usage);
#          foundational WebSocket layer used by:
#            * Helm (Kubernetes package manager — port-forward
#              streams)
#            * Kubernetes kubectl (some streaming endpoints)
#            * Hashicorp Vault (UI streaming)
#            * Hashicorp Consul (web UI updates)
#            * Telegraf (websocket input plugin)
#            * InfluxDB (real-time queries)
#            * Caddy (websocket reverse proxy)
#            * Traefik (websocket support)
#            * Mattermost (chat backend)
#            * Centrifugo (realtime messaging)
#            * NATS (NATS WebSocket gateway)
#            * Tailscale (some control-plane endpoints)
#            * tau (THIS — P2P streams)
#            * 20,000+ Go applications
#          tau — 5,040+ stars on taubyte/tau, used by
#          decentralized-cloud + Web3 infrastructure teams.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 72 +
#                                                  AXIS 18 EXPANDS TO GO
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# the 72ND Go CLI library variant.  Go climbs from 71 to 72 documented
# libraries (gorilla/websocket via tau).  Go **catches Rust at 72**
# (Rust=Go=72, TS-Node=71 → twenty-third two-way tie at the
# leaderboard top in this round-sequence).  New leaderboard:
# Rust=72, Go=72, TypeScript-Node=71 (Rust+Go tied at the top).
# Taxonomy now spans 394 cross-language CLI library variants across
# 96 documented languages.
#
# Pattern: R657 Rust=72 (tokio-tungstenite — Axis 18 OPENS) →
# R658 Go=72 (gorilla/websocket THIS — Axis 18 expands to 2) →
# expected R659 TS-Node=72 → R660 97th language.  This is the
# 2nd of 3 leader bumps in the current segment.
#
# This completion EXPANDS Axis 18 (WEBSOCKETS) to TWO documented
# variants — symmetrically distributed across Rust (tokio-
# tungstenite R657) and Go (gorilla/websocket THIS R658).
# TS-Node Axis 18 variant expected in R659 (likely websockets/ws
# the canonical Node.js WebSocket library) to complete three-
# language symmetry.
#
#   Axis 18 (WEBSOCKETS) variants:
#     - tokio-tungstenite (snapview/tokio-tungstenite) — R657
#       (_aspeak) — Rust RFC 6455; Stream + Sink trait
#       integration; native-tls / rustls TLS; permessage-deflate;
#       Daniel Abramov / snapview ecosystem
#     - gorilla/websocket (gorilla/websocket) — R658 (THIS) —
#       Go RFC 6455; Upgrader + Dialer pattern; ReadJSON /
#       WriteJSON helpers; ping/pong handlers; stdlib TLS;
#       Gorilla Web Toolkit ecosystem
#
# Two Axis 18 variants address DIFFERENT API styles:
#   tokio-tungstenite  = STREAM + SINK trait integration with
#                         futures ecosystem (Rust async-await)
#   gorilla/websocket  = UPGRADER (server) + DIALER (client) +
#                         ReadJSON/WriteJSON conveniences (Go
#                         imperative)
#
# Both libraries wrap THE SAME RFC 6455 WebSocket protocol —
# handshake, framing, masking, ping/pong, close codes,
# permessage-deflate — differing primarily in language-
# idiomatic API shape:
#   - Rust tungstenite:  Stream<Message> + Sink<Message> +
#                         async/await; runtime-agnostic core
#                         (sync) + tokio wrapper (async)
#   - Go gorilla:        Conn.ReadMessage() / WriteMessage() +
#                         goroutine-friendly + JSON conveniences
#
# Axis 18 distribution: Rust=1, Go=1, TS-Node=0.  Expected R659
# TS-Node=1 (likely ws) restores three-language symmetry
# trajectory.
#
# (Leaderboard at R658: Rust=72, Go=72, TS-Node=71.  Rust+Go
# tied at 72.  Axis 9 / Logging 6/6/6 three-way symmetric.
# Axes 10 + 13 + 14 at 2/2/2.  Axes 7 + 11 + 12 + 15 + 16 + 17
# at 1/1/1.  Axis 18 at 1/1/0 (Rust + Go, TS-Node pending).
# Nine axes at three-language symmetry.)
#
# -----------------------------------------------------------------------------
#
# WHAT IS gorilla/websocket AND WHY IS IT THE 72ND Go CLI LIBRARY?
#
# gorilla/websocket is the canonical Go WebSocket library —
# originally part of the Gorilla Web Toolkit family alongside
# gorilla/mux (router), gorilla/handlers (HTTP middleware),
# gorilla/sessions (session storage), gorilla/csrf (CSRF
# protection), gorilla/schema (form decoding).  Distinct from
# Go's stdlib (which has NO WebSocket support) and from
# x/net/websocket (experimental, deprecated by Go team).
#
# Five distinguishing characteristics from tokio-tungstenite
# (R657):
#
#   1. UPGRADER (server) + DIALER (client) pattern — instead
#      of free-standing functions, gorilla/websocket provides
#      two struct types: websocket.Upgrader for HTTP servers
#      that upgrade incoming requests; websocket.Dialer for
#      clients that connect to remote WebSocket endpoints.
#      Each struct holds configuration (buffer sizes, TLS
#      config, subprotocols, compression, origin checks):
#         var upgrader = websocket.Upgrader{
#             CheckOrigin: func(r *http.Request) bool { return true },
#             EnableCompression: true,
#         }
#         conn, _ := upgrader.Upgrade(w, r, nil)
#         var dialer = websocket.DefaultDialer
#         c, _, _ := dialer.Dial("wss://...", headers)
#      Distinct from tungstenite's free-standing connect_async /
#      accept_async functions.
#
#   2. ReadJSON / WriteJSON HELPERS — direct JSON marshal/
#      unmarshal over WebSocket message:
#         var msg MyEvent
#         conn.ReadJSON(&msg)
#         conn.WriteJSON(&MyResponse{Status: "ok"})
#      tungstenite has no equivalent; users serialize manually
#      via serde_json + Message::Text.
#
#   3. CONTROL MESSAGES via SetPingHandler / SetPongHandler /
#      WriteControl — separate API for protocol-level control
#      frames (ping/pong/close) vs data frames.  Distinct from
#      tungstenite where all messages are Message variants.
#
#   4. STDLIB TLS — gorilla/websocket delegates TLS to Go's
#      crypto/tls + net/http transports.  No native-tls /
#      rustls choice (Go's stdlib is uniform).  Distinct from
#      tungstenite's Cargo-feature-driven TLS backend choice.
#
#   5. GORILLA WEB TOOLKIT PROVENANCE — gorilla/websocket is
#      part of an integrated set of Go web libraries (mux,
#      handlers, sessions, csrf, schema).  Distinct from
#      snapview which only maintains the tungstenite family.
#
# -----------------------------------------------------------------------------
#
# THE tau CLI — urfave/cli + gorilla/websocket + libp2p + IPFS
#
# tau's CLI is in cli/app/*.go.  Uses urfave/cli v2 (alternative
# to cobra) with Commands + Subcommands.
#
# Global flags:
#   --root PATH       Folder where tau is installed (default /tb)
#
# Commands:
#   info build [--json] [--deps]
#                     Show detailed build information
#   info commit       Show commit hash
#   start --shape SHAPE [--root PATH] [--dev]
#                     Start a tau node with the given shape
#                     (auth / patrick / monkey / hoarder / odo /
#                      seer / tns / gateway / etc.)
#                     --dev enables development mode
#   config validate [-s SHAPE] [-p PATH]
#                     Validate a shape's configuration
#                     (aliases: check, ok, "ok?", "valid?")
#   config show [-s SHAPE] [-p PATH]
#                     Display a shape's parsed configuration
#                     (aliases: render, display, print)
#   config export [--unsafe] [-s SHAPE]
#                     Export a configuration bundle
#                     (--unsafe exports private key)
#
# gorilla/websocket is used throughout tau's services package
# for libp2p-websocket transport binding + dashboard real-time
# updates.
#
# Five-axis distinctness from tokio-tungstenite (R657):
#
#   1. UPGRADER + DIALER pattern (struct config) vs tungstenite's
#      function-based connect_async/accept_async.
#
#   2. ReadJSON / WriteJSON helpers — first-class JSON
#      message exchange.
#
#   3. SetPingHandler / SetPongHandler / WriteControl separate
#      API for control frames.
#
#   4. STDLIB TLS — no Cargo-feature-driven backend choice.
#
#   5. GORILLA WEB TOOLKIT PROVENANCE — integrated family of
#      Go web libraries.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/taubyte/tau/blob/main/cli/app/app.go
# https://github.com/taubyte/tau/blob/main/cli/app/start_cmd.go
# https://github.com/taubyte/tau/blob/main/cli/app/config_cmd.go
# https://github.com/taubyte/tau/blob/main/cli/app/buildinfo_cmd.go
# urfave/cli v2 Commands + Flags definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _tau_cmds _tau_info_cmds _tau_config_cmds
_tau_cmds=(
    'info:build information'
    'start:start a tau node (shape)'
    'config:configuration utilities'
    'cnf:configuration utilities (alias)'
    'conf:configuration utilities (alias)'
    'help:show help for a subcommand'
)
_tau_info_cmds=(
    'build:show detailed build information'
    'commit:show commit hash'
)
_tau_config_cmds=(
    'validate:validate a shape configuration'
    'check:validate a shape configuration (alias)'
    'ok:validate a shape configuration (alias)'
    'show:display a shape configuration'
    'render:display a shape configuration (alias)'
    'display:display a shape configuration (alias)'
    'print:display a shape configuration (alias)'
    'export:export a configuration bundle'
)

_arguments -C \
    '--root=[folder where tau is installed]:path:_files -/' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'tau subcommand' _tau_cmds && ret=0
        ;;
    args)
        case $words[1] in
            info)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'info subcommand' _tau_info_cmds && ret=0
                elif [[ $words[2] == build ]]; then
                    _arguments \
                        '--json[output as JSON]' \
                        '--deps[include dependencies]' \
                        && ret=0
                fi
                ;;
            start)
                _arguments \
                    '(-s --shape)'{-s+,--shape=}'[shape (auth/patrick/monkey/hoarder/odo/seer/tns/gateway)]:shape:_default' \
                    '--root=[folder where tau is installed]:path:_files -/' \
                    '(--dev --dev-mode)'{--dev,--dev-mode}'[enable development mode]' \
                    && ret=0
                ;;
            config|cnf|conf)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'config subcommand' _tau_config_cmds && ret=0
                else
                    case $words[2] in
                        validate|check|ok|show|render|display|print)
                            _arguments \
                                '(-s --shape)'{-s+,--shape=}'[shape name]:shape:_default' \
                                '(-p --path)'{-p+,--path=}'[config path]:path:_files' \
                                && ret=0
                            ;;
                        export)
                            _arguments \
                                '--unsafe[export node private key (only to restore a node)]' \
                                '(-s --shape)'{-s+,--shape=}'[shape name]:shape:_default' \
                                && ret=0
                            ;;
                    esac
                fi
                ;;
            help)
                _describe -t commands 'subcommand' _tau_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
