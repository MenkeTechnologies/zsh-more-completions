#compdef cubman
# Documentation: https://gaussian.com/cubman/
# Manipulate Gaussian cube files (add, subtract, scale, properties, conversions)

local ret=1

_arguments -s -S \
  '-m[memory to allocate to the utility (must precede other arguments)]:amount' \
  '*:operation:(add copy diff prop subtract scale square sprod vprod magnitude normalize select toxyz)' && ret=0

return ret
