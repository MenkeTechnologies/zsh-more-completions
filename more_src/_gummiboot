#compdef gummiboot
# Documentation: https://man.archlinux.org/search?q=gummiboot
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'status:show status'
  'install:install gummiboot'
  'update:update installed gummiboot'
  'remove:remove gummiboot'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--path=[ESP path]:dir:_files -/' \
  '--no-variables[do not modify EFI variables]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gummiboot command' commands && ret=0 ;;
esac

return ret
