#compdef atfix
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/atfix.html
# Apply miscellaneous corrections to ATCA visibility data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'select=[select keyword]:select:' \
  'out=[out keyword]:out:' \
  'dantpos=[dantpos keyword]:dantpos:' \
  'tsyscal=[tsyscal keyword]:tsyscal:' \
  'options=[options keyword]:options:' \
  'array=[array keyword]:array:' \
  'gainel=[gainel keyword]:gainel:' \
  '*:visibility dataset:_files' && ret=0

return ret
