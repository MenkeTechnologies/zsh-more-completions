#compdef stubby
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/stubby.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[print usage message and exit]' \
  '-V[print stubby version and exit]' \
  '-C+[read settings from config file]:config:_files' \
  '-g[run stubby as a daemon]' \
  '-i[validate config, pretty-print, and exit]' \
  '-l[enable all logging (equivalent to -v 7)]' \
  '-v+[enable logging up to specified loglevel]:loglevel:(0 1 2 3 4 5 6 7)' && ret=0

return ret
