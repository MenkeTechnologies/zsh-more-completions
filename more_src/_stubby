#compdef stubby
# Documentation: https://man.archlinux.org/search?q=stubby
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-V[show version]' \
  '-C+[config file]:config:_files' \
  '-g[run in foreground]' \
  '-v[increase verbosity]' \
  '-l[enable logging]' \
  '-i[validate config and exit]' \
  '-p[list default listen addresses]' \
  '*:config file:_files' && ret=0

return ret
