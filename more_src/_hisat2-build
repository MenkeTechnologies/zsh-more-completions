#compdef hisat2-build hisat2-build-s hisat2-build-l
# _hisat2-build — Daehwan Kim hisat2-build CLI HISAT2 graph-based FM-index builder constructing hierarchical-FM index files .ht2 from reference FASTA with optional VCF SNP introducing population variant graph or GTF splice-site annotation HISAT2 alignment of spliced reads to genome (Daehwan Kim team, C++); custom argparse
# upstream: https://daehwankimlab.github.io/hisat2/

_hisat2-build() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-f[FASTA input]' \
        '-c[reference sequences on command line]' \
        '-a[no automatic A bit count]' \
        '--noauto[no automatic A]' \
        '--packed[packed memory layout]' \
        '--bmax=+[N]:n:' \
        '--bmaxdivn=+[N]:n:' \
        '--dcv=+[N]:n:' \
        '--nodc[no difference cover]' \
        '-r[do not build reverse index]' \
        '-3[3 indexes]' \
        '-o+[offrate]:n:' \
        '--offrate=+[N]:n:' \
        '-t+[ftabchars]:n:' \
        '--ftabchars=+[N]:n:' \
        '--ntoa[convert N to A]' \
        '--seed=+[seed]:n:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-p+[threads]:n:' \
        '--threads=+[N]:n:' \
        '--ss=+[splice site file]:file:_files' \
        '--exon=+[exon file]:file:_files' \
        '--snp=+[snp file]:file:_files -g "*.vcf *.snp"' \
        '--haplotype=+[haplotype file]:file:_files' \
        '--repeat-index[repeat index]' \
        '--large-index[force large-index]' \
        '--debug[debug]' \
        '*:fasta and basename:_files -g "*.fa *.fasta *.fna"'
}

_hisat2-build "$@"
