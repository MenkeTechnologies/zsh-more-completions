#compdef pgstats

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-H --human-readable)'{-H,--human-readable}'[human-readable output]' \
  '(-n --no-header)'{-n,--no-header}'[do not print header]' \
  '(-N --no-newline)'{-N,--no-newline}'[do not print newline]' \
  '(-s --stat)'{-s,--stat}'+[stat type]:stat:(archiver bgwriter checkpointer cluster connection database database_conflicts database_io functions index_io io memory pgstatactivity pgstatreplication pgstatslru pgstatwal pgstatwalreceiver progress_analyze progress_basebackup progress_cluster progress_create_index progress_copy progress_vacuum recovery_prefetch relation_io replication_slots size sortops statio_user_indexes statio_user_sequences statio_user_tables table table_io tempfile user_functions wait_event wal xlog xlog_remove xlog_receiver xlog_writer)' \
  '(-S --section)'{-S,--section}'+[section]:section:' \
  '(-i --interval)'{-i,--interval}'+[interval seconds]:sec:' \
  '(-c --count)'{-c,--count}'+[number of samples]:n:' \
  '(-d --dbname)'{-d,--dbname}'+[database name]:db:' \
  '(-f --filter)'{-f,--filter}'+[filter regex]:regex:' \
  '(-r --human-rate)'{-r,--human-rate}'[show as rate]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-h --host)'{-h,--host}'+[host]:host:_hosts' \
  '(-p --port)'{-p,--port}'+[port]:port:' \
  '(-U --user)'{-U,--user}'+[user]:user:' \
  '(-W --password)'{-W,--password}'[prompt for password]' && ret=0

return ret
