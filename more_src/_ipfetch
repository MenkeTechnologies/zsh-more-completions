#compdef ipfetch
# Source: https://github.com/MenkeTechnologies/zsh-more-completions/blob/d278e5f1659fc62ca4671ab34a319c3ceb558a41/src/_ipfetch
# Repository: MenkeTechnologies/zsh-more-completions (src/_ipfetch)

# Zsh completion for ipfetch (visual IP information tool)

_arguments -s -S \
  '(- *)'{-h,-help}'[Show help menu]' \
  '-ip[Specify a target IP address]:IP address:' \
  '-t[Specify the fetch method]:method:(curl wget)' \
  '--version[Show version]'
