_flk_commands() {
    local commands; commands=(
'init:Initialize a new flake.nix in the current directory' \
'search:Search for packages in nixpkgs' \
'deep-search:Get detailed information about a specific package' \
'list:List the packages of the flake.nix' \
'show:Show flake.nix content in pretty print format' \
'add:Add a package to the flake.nix' \
'remove:Remove a package from the flake.nix' \
'update:Update packages to latest version TODO\: manage version pinning after implementing #7' \
'command:Manage custom commands in the dev shell' \
'env:Manage environment variables in the dev shell' \
'lock:Manage flake.lock file' \
'completions:Generate and install shell completions' \
'activate:Reload the current shell environment' \
'export:Export flake configurations (Docker, JSON, etc.)' \
'direnv:Direnv integration' \
'hook:Hook for nix-shell compatibility' \
'profile:Manage profiles' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'flk commands' commands "$@"
}
