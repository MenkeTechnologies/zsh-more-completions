#compdef diann diann-cli DiaNN
# Documentation: https://github.com/vdemichev/DiaNN
# DIA-NN: neural-network DIA mass spectrometry analysis.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*--f=[input raw data file]:file:_files' \
  '--lib=[spectral library for searching]:file:_files' \
  '--fasta=[sequence database (UniProt format)]:file:_files' \
  '--out=[main output report filename]:file:_files' \
  '--out-lib=[output spectral library filename]:file:_files' \
  '--temp=[temporary directory]:dir:_files -/' \
  '--dir=[working directory with raw files]:dir:_files -/' \
  '--cfg=[configuration file of DIA-NN commands]:file:_files' \
  '--pipeline=[run from a saved pipeline file]:file:_files' \
  '--threads=[number of processing threads]:n' \
  '--verbose=[logging detail level]:level' \
  '--mass-acc=[MS/MS mass tolerance (ppm)]:ppm' \
  '--mass-acc-ms1=[MS1 mass tolerance (ppm)]:ppm' \
  '--window=[scan window for DIA cycles]:n' \
  '--qvalue=[precursor-level FDR threshold]:fdr' \
  '--matrices[generate quantitative matrices]' \
  '--matrix-qvalue=[protein-level FDR for matrices]:fdr' \
  '--matrix-spec-q=[protein FDR filter for matrices]:fdr' \
  '--gen-spec-lib[generate an empirical spectral library]' \
  '--fasta-search[enable library-free (in silico) search]' \
  '--predictor[use the deep-learning predictor]' \
  '--reannotate[update protein annotations from FASTA]' \
  '--cut=[protease cleavage specificity]:spec' \
  '--missed-cleavages=[maximum missed cleavages]:n' \
  '--min-pep-len=[minimum peptide length]:n' \
  '--max-pep-len=[maximum peptide length]:n' \
  '--min-pr-mz=[minimum precursor m/z]:mz' \
  '--max-pr-mz=[maximum precursor m/z]:mz' \
  '--min-fr-mz=[minimum fragment m/z]:mz' \
  '--max-fr-mz=[maximum fragment m/z]:mz' \
  '*--var-mod=[declare a variable modification]:mod' \
  '*--fixed-mod=[declare a fixed modification]:mod' \
  '*--mod=[declare a modification]:mod' \
  '--unimod4[enable carbamidomethylation]' \
  '--full-unimod[load the complete UniMod database]' \
  '--met-excision[allow N-terminal methionine excision]' \
  '--reanalyse[reuse previously generated .quant files]' \
  '--smart-profiling[adaptive profiling]' \
  '--peak-center[centroid spectral peaks]' \
  '--no-ifs-removal[preserve isotope features]' \
  '--int-removal=[interference removal control]:n' \
  '--no-prot-inf[disable protein inference]' \
  '--pg-level=[protein grouping stringency]:level' \
  '--relaxed-prot-inf[lenient protein inference]' \
  '--report-decoys[export decoy identifications]' \
  '--xic=[extract chromatograms within RT window (s)]:window' \
  '--export-quant[export raw fragment quantities]' \
  '--regex=[regex for file path matching]:pattern' \
  '--ignore-case[case-insensitive regex matching]' \
  '*:input:_files' && ret=0

return ret
