#compdef nx-cloud
# Documentation: https://www.npmjs.com/package/nx
# Reference accessed: 2026-05-23
# Verified: npx nx-cloud --help (nx package nx-cloud bin).

# Zsh completion for nx-cloud - Nx Cloud distributed task runner CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'clean-up-agents:clean up agents'
  'record:record run'
  'start-agent:start agent'
  'start-ci-run:start CI run'
  'stop-all-agents:stop all agents'
  'complete-ci-run:complete CI run'
  'upload-and-show-run-details:upload and show run details'
  'login:login to Nx Cloud'
  'configure:configure Nx Cloud'
  'convert-to-nx-cloud-id:convert to Nx Cloud ID'
  'logout:logout from Nx Cloud'
  'cleanup:cleanup'
  'validate:validate'
  'publish-conformance-rule:publish conformance rule'
  'publish-conformance-rules:publish conformance rules'
  'conformance:conformance commands'
  'conformance:check:check conformance'
  'upload-graph:upload graph'
  'fix-ci:fix CI configuration'
  'apply-locally:apply locally'
  'onboard:onboard workspace'
  'decrypt-artifact:decrypt artifact'
  'get:get resource'
  'upload-agent-metrics:upload agent metrics'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'nx-cloud command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
