#compdef sumedian
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/sumedian.c
# MEDIAN filter about a user-defined polygonal curve

local ret=1

_arguments -s -S \
  'xshift=[xshift]:xshift:' \
  'tshift=[tshift]:tshift:' \
  'nshift=[nshift]:nshift:' \
  'xfile=[xfile]:xfile:' \
  'tfile=[tfile]:tfile:' \
  'key=[key]:key:' \
  'mix=[mix]:mix:' \
  'median=[median]:median:' \
  'nmed=[nmed]:nmed:' \
  'sign=[sign]:sign:' \
  'subtract=[subtract]:subtract:' \
  'verbose=[verbose]:verbose:' \
  'tmpdir=[tmpdir]:tmpdir:' \
  '*:file:_files' && ret=0

return ret
