#compdef rmailmm
# Documentation: https://github.com/emacs-mirror/emacs/blob/master/lisp/mail/rmailmm.el
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: rmailmm is an Emacs Lisp library (lisp/mail/rmailmm.el), not a
# standalone CLI. It is invoked from within Emacs/Rmail (M-x rmail-mime
# etc.), so there is no canonical command-line interface to complete.
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:rmail file:_files' && ret=0
return ret
