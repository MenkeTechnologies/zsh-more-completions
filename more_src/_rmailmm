#compdef rmailmm
# Documentation: https://man.archlinux.org/search?q=rmailmm
# Reference accessed: 2026-05-16

# rmailmm: Emacs Rmail MIME handler (rmailmm) - rarely run directly
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:rmail file:_files' && ret=0
return ret
