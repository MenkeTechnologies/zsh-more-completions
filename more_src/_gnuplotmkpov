#compdef gnuplotmkpov
# Documentation: https://man.archlinux.org/search?q=gnuplotmkpov
# Reference accessed: 2026-05-16

# gnuplot-mkpov: convert gnuplot data to POV-Ray scene
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-o[output .pov file]:file:_files -g "*.pov"' \
  '-i[input data file]:file:_files' \
  '*::gnuplotmkpov args:_files' && ret=0
return ret
