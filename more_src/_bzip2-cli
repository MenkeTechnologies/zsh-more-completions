#compdef bzip2-cli bunzip2-cli bzcat-cli
# _bzip2-cli — Julian Seward bzip2 block-sorting compressor CLI alias (bzip2 team, C); custom argparse
# upstream: https://sourceware.org/bzip2/

_bzip2-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[output to stdout]' \
        '--stdout[output to stdout]' \
        '-d[decompress]' \
        '--decompress[decompress]' \
        '-z[force compression]' \
        '--compress[force compression]' \
        '-f[force overwrite]' \
        '--force[force overwrite]' \
        '-k[keep input files]' \
        '--keep[keep input files]' \
        '-q[suppress non-essential warnings]' \
        '--quiet[suppress non-essential warnings]' \
        '-s[reduced memory usage]' \
        '--small[reduced memory usage]' \
        '-t[test integrity]' \
        '--test[test integrity]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-L[show license]' \
        '--license[show license]' \
        '-1[level 1]' \
        '--fast[level 1]' \
        '-2[level 2]' \
        '-3[level 3]' \
        '-4[level 4]' \
        '-5[level 5]' \
        '-6[level 6]' \
        '-7[level 7]' \
        '-8[level 8]' \
        '-9[level 9]' \
        '--best[level 9]' \
        '*:files:_files -g "*.{bz,bz2,bzip,bzip2,tbz,tbz2}"'
}

_bzip2-cli "$@"
