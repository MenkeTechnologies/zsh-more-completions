#compdef cyrus-imapd
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/imapd.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org imapd(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags (imapd
# uses only the standard service-process flag block) and bogus
# man.archlinux.org search URL.

# cyrus-imapd: IMAP server process (run via Cyrus master)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-U[max process reuses before shutdown (default 250)]:n:' \
  '-T[idle timeout seconds before shutdown (default 60)]:seconds:' \
  '-D[run external debugger (debug_command in imapd.conf)]' \
  '-H[expect HAProxy protocol header from sender]' \
  '-s[serve IMAP over SSL (imaps)]' \
  '-N[bypass password checking (not recommended)]' \
  '-p[external SSF security strength factor]:ssf:' && ret=0
return ret
