#compdef spr
# Documentation: https://github.com/spacedentist/spr
# Reference accessed: 2026-05-21
# Verified: src/main.rs (Cli struct, Commands enum)
# Removed: status, rebase, format-only, -c/--count/--no-rebase, -v top-level
# (not present in current upstream main.rs).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:interactive assistant for configuring spr'
  'diff:create or update a Pull Request from current HEAD commit'
  'format:reformat commit message'
  'land:land a reviewed Pull Request'
  'amend:update local commit message with content from GitHub'
  'list:list open Pull Requests and their review decision'
  'patch:create a new branch from an existing Pull Request'
  'close:close a Pull Request'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cd=[change to DIR before performing operations]:directory:_directories' \
  '--github-auth-token=[GitHub personal access token]:token:' \
  '--github-repository=[GitHub repository (org/name)]:org/name:' \
  '--github-master-branch=[centrally shared branch name]:branch:' \
  '--branch-prefix=[prefix for branches created for pull requests]:prefix:' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'spr command' commands && ret=0
    ;;
esac

return ret
