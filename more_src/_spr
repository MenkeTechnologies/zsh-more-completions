#compdef spr

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'diff:create or update pull requests'
  'land:land pull requests'
  'status:show the status of pull requests'
  'amend:amend the current commit and update the pull request'
  'rebase:rebase the current branch'
  'format:format the commit message'
  'init:initialize spr configuration'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '--no-rebase[skip rebase]' \
  '--count=[number of commits]:count' \
  '-c+[number of commits]:count' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'spr command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      diff)
        _arguments -s -S \
          '--count=[number of commits]:count' \
          '-c+[number of commits]:count' \
          '--all[update all pull requests]' && ret=0
        ;;
      land)
        _arguments -s -S \
          '--count=[number of commits]:count' \
          '-c+[number of commits]:count' \
          '--all[land all pull requests]' && ret=0
        ;;
    esac
    ;;
esac

return ret
