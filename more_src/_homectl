#compdef homectl
# _homectl — systemd homectl (manage portable encrypted home directories backed by systemd-homed(8); subcommands: list, inspect, activate, deactivate, create, remove, update, password, resize, lock, unlock, with, list-images, authenticate, rebalance; -E export to JSON, --identity to inline JSON, --storage backend (luks|fscrypt|cifs|directory|subvolume))
# upstream: https://github.com/systemd/systemd (src/home/homectl.c)
# Subcommands from systemd src/home/homectl.c on tip.

_homectl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-H+[host:port]:host:_hosts' \
        '-M+[container]:container:' \
        '--no-pager[no pager]' \
        '--no-legend[no legend]' \
        '-E[export to JSON]' \
        '-j[JSON output]' \
        '-N[no notify]' \
        '--storage=*[backend]:backend:(luks fscrypt cifs directory subvolume)' \
        '--identity+[identity JSON]:file:_files' \
        '*--password-hint+[hint]:hint:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'homectl command' '(list inspect activate deactivate create remove update password resize lock unlock with list-images authenticate rebalance firstboot help)' ;;
        args) _arguments '*:user or image:' ;;
    esac
}

_homectl "$@"
