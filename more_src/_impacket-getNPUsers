#compdef impacket-getNPUsers
# Documentation: https://man.archlinux.org/search?q=impacket-getNPUsers
# Reference accessed: 2026-05-16

# impacket-getNPUsers: AS-REP roasting (no preauth)
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "-debug[verbose debug output]" \
  "-ts[print timestamps in log]" \
  "-ts-utc[print timestamps in UTC]" \
  "-target-ip[target IP]:ip:" \
  "-dc-ip[domain controller IP]:ip:" \
  "-codec[codec for non-utf-8 strings]:codec:" \
  "-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:" \
  "-no-pass[do not ask for password]" \
  "-k[use Kerberos]" \
  "-aesKey[AES key in hex]:hex:" \
  "-cert-pem[pem certificate file]:file:_files" \
  "-cert-pfx[pkcs12 cert file]:file:_files" \
  "-pfx-pass[pkcs12 cert password]:pass:" \
  -no-preauth[supply user without preauth]:user: -outputfile[output file]:file:_files -request[request actual AS-REP] -usersfile[user list file]:file:_files -format[hash format]:fmt:(john hashcat) -dc-host[domain controller hostname]:host:_hosts \
  '*::impacket-getNPUsers args:_files' && ret=0
return ret
