#compdef impacket-getNPUsers

# Impacket GetNPUsers.py: AS-REP Roasting attack on accounts w/o preauth
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-request[request AS-REP for all users found]' \
  '-no-preauth[only print preauth-not-required users]' \
  '-format[hash format]:fmt:(john hashcat)' \
  '-outputfile[output file]:file:_files' \
  '-usersfile[user list file]:file:_files' \
  '-target-domain[target domain]:domain:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-dc-host[DC hostname]:host:' \
  '*:domain/[:password]:' && ret=0
return ret
