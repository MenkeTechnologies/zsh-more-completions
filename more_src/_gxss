#compdef gxss
# _gxss — KathanP19 Gxss CLI for fast cross-site-scripting reflected-parameter detection by sending crafted payloads through URL query strings and analysing HTTP responses for reflected payload markers (KathanP19 team, Go); flag
# upstream: https://github.com/KathanP19/Gxss

_gxss() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-p+[payload]:str:' \
        '--payload=+[payload]:str:' \
        '-c+[N concurrent threads]:n:' \
        '--concurrent=+[N concurrent threads]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-r[follow redirects]' \
        '--follow-redirects[follow redirects]' \
        '-X+[HTTP method]:m:(GET POST PUT DELETE HEAD OPTIONS)' \
        '--method=+[HTTP method]:m:(GET POST PUT DELETE HEAD OPTIONS)' \
        '-H+[header]:str:' \
        '--header=+[header]:str:' \
        '-d+[body data]:str:' \
        '--data=+[body data]:str:' \
        '-x+[proxy]:str:' \
        '--proxy=+[proxy]:str:' \
        '--silent[silent]' \
        '*:URL or file:_files'
}

_gxss "$@"
