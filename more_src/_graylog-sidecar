#compdef graylog-sidecar graylog-sidecar.exe

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-c+[config file]:file:_files -g "*.{yml,yaml}"' \
  '-debug[enable debug logging]' \
  '-service+[service action]:action:(install uninstall start stop restart status)' \
  '-username+[user to run service as (Windows)]:user:_users' \
  '-password+[password (Windows)]:password:' \
  '-collect-logs[collect logs and exit]' \
  '*::passthrough:' && ret=0

return ret
