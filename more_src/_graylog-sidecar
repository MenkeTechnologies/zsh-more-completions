#compdef graylog-sidecar graylog-sidecar.exe
# Documentation: https://github.com/Graylog2/collector-sidecar
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-version[show version]' \
  '-c+[config file]:file:_files -g "*.{yml,yaml}"' \
  '-debug[enable debug logging]' \
  '-service+[service action]:action:(install uninstall start stop restart status)' \
  '*::passthrough:' && ret=0

return ret
