#compdef pdb_b
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Modifies the temperature factor column of a PDB file (default 10.0)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[B-factor value to set, e.g. -10.0]:b-factor' \
  '*:PDB file:_files' && ret=0

return ret
