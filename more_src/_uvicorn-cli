#compdef uvicorn-cli
# _uvicorn-cli — Uvicorn ASGI server CLI alias (Encode, Python); click
# upstream: https://github.com/encode/uvicorn

_uvicorn-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--host=+[bind host]:host:_hosts' \
        '--port=+[bind port]:port:' \
        '--uds=+[unix domain socket]:file:_files' \
        '--fd=+[file descriptor]:n:' \
        '--reload[auto reload]' \
        '--reload-dir=+[reload watch dir]:dir:_files -/' \
        '--reload-include=+[reload include glob]:list:' \
        '--reload-exclude=+[reload exclude glob]:list:' \
        '--reload-delay=+[reload delay sec]:f:' \
        '--workers=+[workers]:n:' \
        '--loop=+[event loop]:loop:(auto asyncio uvloop)' \
        '--http=+[http protocol]:proto:(auto h11 httptools)' \
        '--ws=+[websockets protocol]:proto:(auto none websockets wsproto)' \
        '--ws-max-size=+[ws max size]:n:' \
        '--ws-max-queue=+[ws max queue]:n:' \
        '--ws-ping-interval=+[ws ping interval]:f:' \
        '--ws-ping-timeout=+[ws ping timeout]:f:' \
        '--ws-per-message-deflate=+[ws per-message deflate]:b:(true false)' \
        '--lifespan=+[lifespan]:l:(auto on off)' \
        '--interface=+[interface]:i:(auto asgi3 asgi2 wsgi)' \
        '--env-file=+[env file]:file:_files' \
        '--log-config=+[log config]:file:_files' \
        '--log-level=+[log level]:level:(trace debug info warning error critical)' \
        '--access-log[access log]' \
        '--no-access-log[no access log]' \
        '--use-colors[use colors]' \
        '--no-use-colors[no use colors]' \
        '--proxy-headers[trust proxy headers]' \
        '--no-proxy-headers[no proxy headers]' \
        '--server-header[server header]' \
        '--no-server-header[no server header]' \
        '--date-header[date header]' \
        '--no-date-header[no date header]' \
        '--forwarded-allow-ips=+[forwarded allow IPs]:list:' \
        '--root-path=+[root path]:str:' \
        '--limit-concurrency=+[limit concurrency]:n:' \
        '--backlog=+[backlog]:n:' \
        '--limit-max-requests=+[limit max requests]:n:' \
        '--timeout-keep-alive=+[timeout keep alive sec]:n:' \
        '--timeout-graceful-shutdown=+[timeout graceful shutdown sec]:n:' \
        '--ssl-keyfile=+[ssl key]:file:_files' \
        '--ssl-certfile=+[ssl cert]:file:_files' \
        '--ssl-keyfile-password=+[ssl key password]:str:' \
        '--ssl-version=+[ssl version]:n:' \
        '--ssl-cert-reqs=+[ssl cert reqs]:n:' \
        '--ssl-ca-certs=+[ssl ca certs]:file:_files' \
        '--ssl-ciphers=+[ssl ciphers]:str:' \
        '--header=+[custom response header]:str:' \
        '--app-dir=+[app dir]:dir:_files -/' \
        '--h11-max-incomplete-event-size=+[h11 max event size]:n:' \
        '--factory[treat app as factory function]' \
        '*:asgi-app:'
}

_uvicorn-cli "$@"
