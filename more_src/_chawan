#compdef chawan
# Documentation: https://chawan.net/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# chawan — terminal markdown viewer (https://git.sr.ht/~gpanders/chawan or similar; `chawan --help` lists -v -T, URI/file).

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-v+}'[increase log verbosity]' \
  {-T+}'[set terminal type / title]' \
  '*:document URI or file:_files' && ret=0

return ret
