#compdef tophat
# Documentation: https://man.archlinux.org/search?q=tophat
# Reference accessed: 2026-05-16

# TopHat: spliced-read alignment to genome (RNA-Seq)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output directory]:dir:_files -/' \
  '(-p --num-threads)'{-p,--num-threads=}'[number of threads]:n:' \
  '(-N --read-mismatches)'{-N,--read-mismatches=}'[max read mismatches]:n:' \
  '--read-gap-length=[max read gap length]:n:' \
  '--read-edit-dist=[max read edit distance]:n:' \
  '(-a --min-anchor-length)'{-a,--min-anchor-length=}'[min anchor length]:n:' \
  '(-i --min-intron-length)'{-i,--min-intron-length=}'[min intron length]:n:' \
  '(-I --max-intron-length)'{-I,--max-intron-length=}'[max intron length]:n:' \
  '(-G --GTF)'{-G,--GTF=}'[GTF annotation file]:file:_files -g "*.gtf"' \
  '--transcriptome-index=[transcriptome index prefix]:prefix:' \
  '(-T --transcriptome-only)'{-T,--transcriptome-only}'[only map to transcriptome]' \
  '--library-type=[library strand type]:type:(fr-unstranded fr-firststrand fr-secondstrand)' \
  '(-r --mate-inner-dist)'{-r,--mate-inner-dist=}'[expected inner distance]:n:' \
  '--mate-std-dev=[mate distance std dev]:n:' \
  '--no-novel-juncs[do not find novel junctions]' \
  '--no-novel-indels[do not find novel indels]' \
  '--no-gtf-juncs[do not include GTF junctions]' \
  '--coverage-search[use coverage-based junction search]' \
  '--no-coverage-search[disable coverage search]' \
  '--microexon-search[search for microexons]' \
  '--bowtie1[use Bowtie1 instead of Bowtie2]' \
  '--bowtie-version=[Bowtie version]:n:(1 2)' \
  '*:bowtie2 index and read files:_files' && ret=0
return ret
