#compdef supadmissing
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/windowing_sorting_muting/supadmissing.c
# SUPADMISSING - add dead traces for missing key values

local ret=1

_arguments -s -S \
  'keyloc=[key whose missing values are padded (default cdp)]:k:' \
  'incval=[increment between expected key values]:i:' \
  'minval=[minimum keyloc value to output]:m:' \
  'maxval=[maximum keyloc value to output]:m:' \
  '*:SU file:_files' && ret=0

return ret
