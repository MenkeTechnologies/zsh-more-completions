#compdef cargo-px
# Documentation: https://crates.io/crates/cargo-px
# cargo proxy that runs code generators before forwarding to cargo

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:(build check test run verify-freshness)' \
  '*::cargo args:_default' && ret=0

return ret
