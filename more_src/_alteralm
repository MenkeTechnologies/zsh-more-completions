#compdef alteralm
# Documentation: https://healpix.sourceforge.io/html/fac_alteralm.htm
# HEALPix: alter a_lm (beam, pixel window, rotation)

local ret=1

_arguments -s -S \
  '(-d --double -s --single)'{-d,--double}'[use double precision]' \
  '(-d --double -s --single)'{-s,--single}'[use single precision (default)]' \
  '*:parameter file:_files' && ret=0

return ret
