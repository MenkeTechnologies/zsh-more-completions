#compdef velero-plugin-for-vsphere
# _velero-plugin-for-vsphere — Velero vSphere provider plugin (registers velero.io/vsphere VolumeSnapshotter + PVC BackupItemAction/RestoreItemAction/DeleteItemAction)
# upstream: https://github.com/vmware-tanzu/velero-plugin-for-vsphere
# Plugin runs as go-plugin gRPC server; framework Config exposes --log-level and --features.

_velero-plugin-for-vsphere() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[plugin log level]:level:(trace debug info warning error fatal panic)' \
        '--features=[csv of velero feature flags]:csv:'
}

_velero-plugin-for-vsphere "$@"
