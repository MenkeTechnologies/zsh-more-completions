#compdef @snapshot_volreg
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@snapshot_volreg.html
# Make a JPEG showing EPI edges overlaid on an anatomical to assess registration

local ret=1

_arguments -s -S \
  '1:ANATdataset:_files' \
  '2:EPIdataset:_files' \
  '3::jname:_files' \
  '4::xdisplay:_message xdisplay' && ret=0

return ret
