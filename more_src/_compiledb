#compdef compiledb

# Zsh completion for compiledb - generate compile_commands.json

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'make:generate from make command'
  'parse:parse build log file'
)

_arguments -s -S \
  '(-n --no-build)'{-n,--no-build}'[do not run the build command]' \
  '(-o --output)'{-o+,--output=}'[output file]:output file:_files -g "*.json"' \
  '(-p --parse)'{-p,--parse}'[parse build log from stdin]' \
  '--command-style=[command style in compile_commands.json]:style:(command arguments)' \
  '--no-strict[do not use strict mode]' \
  '--full-path[generate absolute paths]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'compiledb command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      make)
        _arguments \
          '(-f --makefile)'{-f+,--makefile=}'[makefile]:makefile:_files' \
          '*::make args:'
        ;;
      parse)
        _arguments \
          '(-i --input)'{-i+,--input=}'[input build log]:log file:_files' \
          '*::'
        ;;
    esac
    ;;
esac

return ret
