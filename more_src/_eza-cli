#compdef eza
# Documentation: https://man.archlinux.org/search?q=eza
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-1 --oneline)'{-1,--oneline}'[one per line]' \
  '(-l --long)'{-l,--long}'[long view]' \
  '(-G --grid)'{-G,--grid}'[grid view]' \
  '(-x --across)'{-x,--across}'[fill across]' \
  '(-R --recurse)'{-R,--recurse}'[recursive]' \
  '(-T --tree)'{-T,--tree}'[tree view]' \
  '(-F --classify)'{-F+,--classify=}'[classify]:c:(always auto never)' \
  '--color=[color]:c:(always auto never)' \
  '--colour=[color]:c:(always auto never)' \
  '--color-scale=[color scale]:c:(all age size)' \
  '--color-scale-mode=[scale mode]:m:(fixed gradient)' \
  '--icons=[icons]:i:(always auto never)' \
  '--no-quotes[no quotes]' \
  '--hyperlink[hyperlink]' \
  '(-a --all)'{-a,--all}'[show hidden]' \
  '(-A --almost-all)'{-A,--almost-all}'[show hidden, no . ..]' \
  '(-d --list-dirs)'{-d,--list-dirs}'[list dirs themselves]' \
  '(-D --only-dirs)'{-D,--only-dirs}'[only dirs]' \
  '(-f --only-files)'{-f,--only-files}'[only files]' \
  '(-L --level)'{-L+,--level=}'[max depth]:n:' \
  '(-r --reverse)'{-r,--reverse}'[reverse]' \
  '(-s --sort)'{-s+,--sort=}'[sort field]:s:(name size extension modified accessed created Name Size Extension Modified Accessed Created none -name -size -extension -modified -accessed -created)' \
  '--group-directories-first[dirs first]' \
  '(-I --ignore-glob)*'{-I+,--ignore-glob=}'[glob to ignore]:g:' \
  '--git-ignore[respect gitignore]' \
  '(-b --binary)'{-b,--binary}'[binary sizes]' \
  '(-B --bytes)'{-B,--bytes}'[bytes sizes]' \
  '(-g --group)'{-g,--group}'[show group]' \
  '(-h --header)'{-h,--header}'[show header]' \
  '(-H --links)'{-H,--links}'[show links count]' \
  '(-i --inode)'{-i,--inode}'[show inode]' \
  '(-m --modified)'{-m,--modified}'[modified time]' \
  '(-n --numeric)'{-n,--numeric}'[numeric uid/gid]' \
  '(-S --blocksize)'{-S,--blocksize}'[blocksize]' \
  '(-t --time)'{-t+,--time=}'[time field]:t:(modified accessed created)' \
  '(-u --accessed)'{-u,--accessed}'[accessed time]' \
  '(-U --created)'{-U,--created}'[created time]' \
  '(--changed)--changed[ctime time]' \
  '--time-style=[time style]:s:(default iso long-iso full-iso relative +FORMAT)' \
  '--total-size[show total size for dirs]' \
  '--no-permissions[hide permissions]' \
  '-o[show octal perms]' \
  '--octal-permissions[show octal perms]' \
  '--no-filesize[hide filesize]' \
  '--no-user[hide user]' \
  '--no-time[hide time]' \
  '--no-symlinks[hide symlinks]' \
  '--show-symlinks[show symlinks]' \
  '--git[show git status]' \
  '--no-git[hide git]' \
  '--git-repos[show git repo info]' \
  '--git-repos-no-status[git repo no status]' \
  '@@[mounts info]' \
  '*: :_files' && ret=0

return ret
