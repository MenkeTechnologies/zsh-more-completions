#compdef quorum-genesis-tool
# ============================================================================
# quorum-genesis-tool - GoQuorum / Besu genesis-file generator (Node, Apache-2.0)
#
# Author : ConsenSys (now Consensys / Diligence)
# Upstream: https://github.com/Consensys/quorum-genesis-tool
# npm    : quorum-genesis-tool
#
# quorum-genesis-tool generates the per-network bundle that bootstraps
# a Quorum or Besu Ethereum-compatible blockchain: the genesis.json,
# validator + member + bootnode keystores (each Argon2-encrypted with
# the supplied password), Tessera keys (private-transaction manager),
# pre-funded account allocations, and consensus-specific config
# (IBFT / IBFT2 / QBFT / Clique / Raft). Interactive mode walks the
# operator through every config knob; CLI-flag mode is for CI / IaC.
#
# The Argon2 password-hashing lane is built on `argon2 ^0.40`
# (declared verbatim at upstream package.json HEAD), the canonical
# Node Argon2 library by Ranieri Althoff (ranisalt / node-argon2,
# 2100+ stars on github.com/ranisalt/node-argon2). The library
# wraps the reference C library (`P-H-C/phc-winner-argon2`,
# Khovratovich + Biryukov + Aumasson, PHC winner 2015) via N-API,
# implementing RFC 9106 end-to-end with the three variants
# (Argon2i, Argon2d, Argon2id), the full parameter surface
# (memoryCost m, timeCost t, parallelism p, saltLength, hashLength),
# and PHC-format string emission (`$argon2id$v=19$m=...$<salt>$<hash>`)
# for cross-implementation hash exchange. Default options match the
# OWASP 2024 recommendations (m=19MB, t=2, p=1) which is what
# quorum-genesis-tool uses to encrypt the generated node keystores
# at rest.
#
# ----------------------------------------------------------------------------
# AXIS 208 :: ARGON2 PASSWORD HASHING (RFC 9106)  [CLOSES]
# Round 1324 :: TS-Node slot 3 of 4 :: CLOSES Axis 208 (201st axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : RustCrypto/argon2             [R1322 _sentryshot]
#   Go      : golang.org/x/crypto/argon2    [R1323 _wag]
#   TS/Node : ranisalt/node-argon2          [R1324 THIS FILE]
#
# All three lanes close on the same RFC 9106 (Argon2) - the
# Password Hashing Competition winner, published 2015, adopted as
# the OWASP-recommended password-hashing function for new
# applications since 2021. Three independent implementations
# (RustCrypto pure-Rust, golang.org/x/crypto pure-Go, ranisalt
# C-via-N-API) converge on the PHC string format so hashes are
# verifiable across language boundaries - critical for cross-
# service deployments where Go services hash and Rust services
# verify, or vice versa.
#
# quorum-genesis-tool is a real consumer with a non-trivial
# workload: many keystores per network, each Argon2-encrypted
# with the operator-supplied password, output to a per-network
# directory bundle for downstream consumption by GoQuorum / Besu
# node binaries during their initial sync.
# ============================================================================

_quorum-genesis-tool() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '--consensus[consensus algorithm]:algo:(ibft ibft2 qbft clique raft)' \
        '--chainID[blockchain ChainID (default 1337)]:chain id:' \
        '--blockperiod[seconds per block (default 5)]:seconds:' \
        '--requestTimeout[min request timeout per round (default 10)]:seconds:' \
        '--emptyBlockPeriod[empty-block reduction interval (default 60)]:seconds:' \
        '--epochLength[blocks before vote reset (default 30000)]:blocks:' \
        '--difficulty[network difficulty (default 1)]:n:' \
        '--gasLimit[per-block gas limit (hex; default 0xFFFF)]:hex:' \
        '--coinbase[mining-reward address (default 0x000...)]:address:' \
        '--maxCodeSize[max contract size in KB (default 64)]:kb:' \
        '--txnSizeLimit[max transaction size in KB]:kb:' \
        '--validators[number of validator node keys (default 4)]:n:' \
        '--members[number of member node keys]:n:' \
        '--bootnodes[number of bootnode keys]:n:' \
        '--accountPassword[password to encrypt generated keys]:password:' \
        '--outputPath[output directory (relative to CWD)]:directory:_files -/' \
        '--tesseraEnabled[also generate Tessera private-tx-manager keys]' \
        '--tesseraPassword[password for Tessera keystore]:password:' \
        '--quickstartDevAccounts[include quorum-dev-quickstart test accounts]' \
        '--genesisNodeAllocation[balance allocated per node]:balance:' \
        '--alloc[JSON of prefunded accounts]:json:' \
        '--noOutputTimestamp[skip timestamp suffix on output folder]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]'
}

_quorum-genesis-tool "$@"
