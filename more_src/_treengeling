#compdef treengeling
# Documentation: https://github.com/arminbiere/lingeling
# treengeling cube-and-conquer SAT solver

local ret=1

_arguments -s -S \
  '-h[print option summary]' \
  '--version[print version and exit]' \
  '-v[increase verbose level]' \
  '-S[print statistics for each solver instance]' \
  '-n[do not print satisfying assignments]' \
  '-t+[maximum number of actual worker threads]:workers' \
  '-a+[maximum number of active nodes]:nodes' \
  '-m+[assumed memory in MB]:mb' \
  '-g+[assumed memory in GB]:gb' \
  '-r+[randomize splits by swapping nodes]:posnum' \
  '-s+[seed for randomizing splits]:seed' \
  '-b+[percentage of nodes split]:branches' \
  '-f+[full round interval]:fullint' \
  '--balance[split larger nodes first]' \
  '--symmetric[symmetric splitting]' \
  '--asymmetric[asymmetric splitting]' \
  '--eager[eager splitting]' \
  '--lazy[disable eager splitting]' \
  '--portfolio[use portfolio style option fuzzing]' \
  '--locslkhd[use local search for look-ahead]' \
  '--no-relevancelkhd[do not use relevance look-ahead]' \
  '--treelook=[maximum depth for tree-based look-ahead]:depth' \
  '--min=[minimum conflict limit per search]:lim' \
  '--init=[initial conflict limit per search]:lim' \
  '--max=[maximum conflict limit per search]:lim' \
  '--reduce[reduce learned clause cache for right branches]' \
  '--force-simp[force simplification after light simplification]' \
  '--no-simp[do not explicitly simplify in each round]' \
  '--no-search[do not search in each round]' \
  '--no-parallel[disable additional parallel solver instance]' \
  '--no-full[disable full rounds]' \
  '*:dimacs file:_files' && ret=0

return ret
