#compdef cgrulesengd

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --logfile)'{-f,--logfile}'+[log file]:file:_files' \
  '(-s --syslog)'{-s,--syslog}'[log to syslog]' \
  '(-n --no-daemon)'{-n,--no-daemon}'[do not daemonize]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-Q --no-syslog)'{-Q,--no-syslog}'[no syslog]' \
  '(-N --nv)'{-N,--nv}'+[netlink event verbosity]:lvl:' \
  '(-p --pid-file)'{-p,--pid-file}'+[pid file]:file:_files' \
  '(-u --socket-user)'{-u,--socket-user}'+[user]:user:_users' \
  '(-g --socket-group)'{-g,--socket-group}'+[group]:group:_groups' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0

return ret
