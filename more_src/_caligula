#compdef caligula

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'burn:burn a disk image to a target device'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'caligula command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (burn)
        _arguments \
          '(-o --out)'{-o+,--out=}'[output device]:device:_files' \
          '(-z --compression)'{-z+,--compression=}'[input compression format]:fmt:(ask auto none gz bz2 xz lz4 zst)' \
          '(-s --hash)'{-s+,--hash=}'[hash to validate input]:hash:' \
          '--hash-file=[file containing hashes]:file:_files' \
          '--show-all-disks[show all disks (including non-removable)]' \
          '--interactive=[interactive mode]:mode:(auto always never)' \
          '(-f --force)'{-f,--force}'[skip safety confirmation]' \
          '--root=[whether to become root]:mode:(ask always never)' \
          '--no-confirm[do not prompt for confirmation]' \
          '*:image_file:_files -g "*.{iso,img,bin,gz,bz2,xz,lz4,zst}"' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell elvish)' && ret=0 ;;
    esac ;;
esac

return ret
