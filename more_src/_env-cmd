#compdef env-cmd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-e+[env file path]:env file:_files' \
  '--environments=[environment name(s)]:environments' \
  '-f+[custom env file path]:env file:_files' \
  '--file=[custom env file path]:env file:_files' \
  '-r+[use .env-cmdrc file]:rc file:_files' \
  '--rc-file=[use .env-cmdrc file]:rc file:_files' \
  '--fallback[enable env file fallback]' \
  '--no-override[do not override existing env vars]' \
  '--silent[suppress env-cmd errors]' \
  '--use-shell[execute command using shell]' \
  '--verbose[verbose output]' \
  '-x[expand variables in env values]' \
  '--expand-envs[expand variables in env values]' \
  '*::command:_command_names -e' && ret=0

return ret
