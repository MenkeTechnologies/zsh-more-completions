#compdef cargo-mutants
# Documentation: https://github.com/sourcefrog/cargo-mutants
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_cargo-mutants() {
  _arguments \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-V,--version}'[Show version]' \
    {-d,--dir}'[Root directory of the source tree]:dir:_directories' \
    '--manifest-path=[Path to Cargo.toml]:file:_files -g "Cargo.toml"' \
    {-p,--package}'[Mutate only this package]:package:' \
    {-f,--file}'[Only mutate functions in these files]:file:_files' \
    {-e,--exclude}'[Exclude files matching pattern]:pattern:' \
    '--re=[Only test mutants matching regex]:regex:' \
    '--exclude-re=[Exclude mutants matching regex]:regex:' \
    {-j,--jobs}'[Number of parallel jobs]:jobs:' \
    '--timeout=[Maximum time per test]:seconds:' \
    '--timeout-multiplier=[Timeout multiplier]:multiplier:' \
    '--minimum-test-timeout=[Minimum test timeout]:seconds:' \
    '--build-timeout=[Maximum time per build]:seconds:' \
    '--build-timeout-multiplier=[Build timeout multiplier]:multiplier:' \
    {-l,--list}'[List mutations without running them]' \
    '--list-files[List mutated files]' \
    '--json[Output in JSON format]' \
    '--no-shuffle[Do not shuffle mutations]' \
    '--no-times[Do not print times]' \
    '--in-place[Mutate in place without copying the tree]' \
    '--in-diff=[Only mutate lines in a diff]:file:_files' \
    '--baseline=[Baseline test handling]:mode:(run skip)' \
    '--test-tool=[Test tool to use]:tool:(cargo nextest)' \
    '--output=[Output directory]:dir:_directories' \
    {-C,--check}'[Only check that each mutant builds]' \
    '--features=[Features to activate]:features:' \
    '--all-features[Activate all features]' \
    '--no-default-features[Disable default features]' \
    '--profile=[Build profile]:profile:' \
    '--release[Build in release mode]' \
    '--test-workspace[Test the whole workspace]' \
    {-v,--verbose}'[Increase verbosity]' \
    '--colors=[Colorize output]:colors:(auto always never)' \
    '--shard=[Run only this shard k/n]:shard:' \
    '--error=[Error type to inject]:error:' \
    '--cap-lints=[Cap lint level]:level:(allow warn)' \
    '--gitignore[Respect gitignore]' \
    '--leak-dirs[Do not clean up temporary directories]' \
    '--iterate[Skip previously caught or unviable mutants]' \
    '--copy-vcs[Copy version control directories]' \
    '--cargo-test-arg=[Extra arg passed to cargo test]:arg:' \
    '*:args:'
}

_cargo-mutants "$@"
