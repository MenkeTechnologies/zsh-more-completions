#compdef srconv
# Documentation: https://csound.com/docs/manual/
# Csound utility to convert the sample rate of a soundfile

local ret=1

_arguments -s -S \
  '-P+[pitch transposition ratio (do not use with -r)]:ratio' \
  '-Q+[quality factor]:quality:(1 2 3 4)' \
  '-i+[auxiliary breakpoints file]:file:_files' \
  '-r+[output sample rate]:rate' \
  '-A[AIFF output format]' \
  '-W[WAV output format]' \
  '-h[no header on output]' \
  '-c[8-bit signed char samples]' \
  '-s[short integer samples]' \
  '-l[long (32-bit) integer samples]' \
  '-f[floating point samples]' \
  '-o+[output filename]:output:_files' \
  '*:soundfile:_files' && ret=0

return ret
