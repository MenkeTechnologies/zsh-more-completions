#compdef cyrus-fud
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/fud.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org fud(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-fud: provides find-user-data UDP query service
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-U[max process reuses before shutdown (default 250)]:n:' \
  '-T[idle timeout seconds before shutdown (default 60, 0 disables)]:seconds:' \
  '-D[run external debugger]' && ret=0
return ret
