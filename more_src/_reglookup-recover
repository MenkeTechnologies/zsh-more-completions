#compdef reglookup-recover
# Documentation: https://www.unix.com/man-page/debian/1/reglookup-recover/
# Windows NT+ registry deleted record recovery tool

local ret=1

_arguments -s -S \
  '-v[verbose output]' \
  '-h[enable column header row]' \
  '-H[disable column header row]' \
  '-l[display cells not interpreted as valid registry structures]' \
  '-L[do not display uninterpreted cells (default)]' \
  '-r[display raw cell contents for intact data structures]' \
  '-R[do not display raw cell contents (default)]' \
  '*:registry file:_files' && ret=0

return ret
