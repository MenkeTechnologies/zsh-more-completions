#compdef zeabur

_zeabur() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '(-i --interactive)'{-i,--interactive}'[Enable or disable interactive mode (default: true)]'
        '(-h --help)'{-h,--help}'[Display help for the command]'
        '--json[Output results in JSON format]'
    )

    subcmds=(
        'auth:Manage your authentication session'
        'project:Manage Zeabur projects'
        'service:Manage services within a project'
        'deployment:Manage and view deployments'
        'context:Set the working directory for the CLI'
        'deploy:Deploy local code'
        'variable:Manage environment variables'
        'completion:Generate the autocompletion script for the specified shell'
        'help:Help about any command'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'zeabur commands' subcmds
            ;;
        args)
            case $line[1] in
                auth)
                    local -a auth_subcmds
                    auth_subcmds=(
                        'login:Log in via browser (default) or token'
                        'logout:Log out of the current session'
                    )
                    _describe -t commands 'auth subcommands' auth_subcmds
                    ;;
                project)
                    local -a project_subcmds
                    project_subcmds=(
                        'ls:List all projects'
                        'create:Create a new project'
                        'delete:Delete a project'
                    )
                    _describe -t commands 'project subcommands' project_subcmds
                    ;;
                service)
                    local -a service_subcmds
                    service_subcmds=(
                        'ls:List all services in the current project context'
                        'create:Create a new service'
                        'restart:Restart the current service'
                        'suspend:Suspend a service'
                        'resume:Resume a suspended service'
                    )
                    _describe -t commands 'service subcommands' service_subcmds
                    ;;
                deployment)
                    local -a deployment_subcmds
                    deployment_subcmds=(
                        'get:View the status of the latest deployment'
                        'log:View service logs'
                    )
                    _describe -t commands 'deployment subcommands' deployment_subcmds
                    ;;
                context)
                    local -a context_subcmds
                    context_subcmds=(
                        'set:Set the active context'
                    )
                    _describe -t commands 'context subcommands' context_subcmds
                    ;;
                variable)
                    local -a variable_subcmds
                    variable_subcmds=(
                        'ls:List environment variables'
                        'create:Add a new variable'
                    )
                    _describe -t commands 'variable subcommands' variable_subcmds
                    ;;
            esac
            ;;
    esac
}

_zeabur "$@"
