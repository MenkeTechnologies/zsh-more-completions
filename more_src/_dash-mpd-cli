#compdef dash-mpd-cli
# Documentation: https://github.com/emarsden/dash-mpd-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# DASH manifest downloader

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-o --output)'{-o+,--output=}'[output filename]:file:_files' \
  '--proxy=[proxy URL (HTTP or SOCKS)]:url:' \
  '--no-proxy[disable system proxy]' \
  '--limit-rate=[throttle network bandwidth]:rate:' \
  '--auth-username=[HTTP basic auth username]:user:' \
  '--auth-password=[HTTP basic auth password]:pass:' \
  '--auth-bearer=[bearer token]:token:' \
  '--xslt-stylesheet=[XSLT stylesheet to rewrite MPD]:file:_files' \
  '*--drop-elements=[XPath of elements to drop]:xpath:' \
  '--enable-live-streams[allow downloading pseudo-live streams]' \
  '--sleep-requests=[seconds to sleep between requests]:secs:' \
  '--no-period-concatenation[keep multi-period content separate]' \
  '--cookies-from-browser=[extract cookies from browser]:browser:(firefox chrome safari edge)' \
  '*--key=[decryption key kid:key]:key:' \
  '--decryption-application=[decryption tool]:tool:(mp4decrypt shaka)' \
  '--mp4decrypt-location=[path to mp4decrypt]:file:_files' \
  '--shaka-packager-location=[path to shaka-packager]:file:_files' \
  '--muxer-preference=[muxer preference list]:list:' \
  '--mkvmerge-location=[path to mkvmerge]:file:_files' \
  '--ffmpeg-location=[path to ffmpeg]:file:_files' \
  '--vlc-location=[path to VLC]:file:_files' \
  '--mp4box-location=[path to mp4box]:file:_files' \
  '*:MPD URL or file:_files'
