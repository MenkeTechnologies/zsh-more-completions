#compdef karaf

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'clean:start fresh, removing data folder'
  'debug:start with debug enabled'
  'server:start without console (foreground)'
  'console:start with console (foreground, default)'
  'help:show help'
  'shutdown:gracefully shut down running instance'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'karaf subcommand' subcommands && ret=0
    ;;
esac

return ret
