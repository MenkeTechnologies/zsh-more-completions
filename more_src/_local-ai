#compdef local-ai
# Documentation: https://github.com/mudler/LocalAI/blob/master/core/cli/cli.go
# Reference accessed: 2026-05-19
# Verified: upstream Kong CLI struct in core/cli/cli.go.

# mudler/LocalAI — Kong CLI (core/cli/cli.go, context/context.go, run.go, models.go).
# Subcommand-based completion; use `local-ai completion zsh` for exhaustive generated flags.

local curcontext="$curcontext" state line ret=1
local -a lai_top msub

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[deprecated: prefer --log-level=debug]' \
  '--log-level=[log level]:level:(error warn info debug trace)' \
  '--log-format=[log format]:format:(default text json)' \
  '--log-dedup-logs[deduplicate consecutive identical log lines]' \
  '--no-log-dedup-logs[force log deduplication off]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    lai_top=(
      'run:run API server (default kong command)'
      'federated:federated mode'
      'models:model gallery operations'
      'backends:backend definitions'
      'tts:text-to-speech'
      'sound-generation:generate audio from text or audio'
      'transcript:speech-to-text'
      'p2p-worker:distributed llama.cpp worker'
      'worker:generic backend worker'
      'agent-worker:agent worker (NATS)'
      'util:utility commands'
      'agent:run agents standalone'
      'mcp-server:stdio MCP admin surface'
      'explorer:p2p explorer'
      'completion:emit shell completion script'
    )
    _describe -t commands 'local-ai command' lai_top && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments -s -S \
          '(--version)--version[print version and exit]' \
          '--address=[bind address for API server]:addr:' \
          '--models-path=[model storage path]:path:_files -/' \
          '--backends-path=[backend storage path]:path:_files -/' \
          '--backends-system-path=[system backends path]:path:_files -/' \
          '--data-path=[mutable application data path]:path:_files -/' \
          '--upload-path=[upload storage path]:path:_files -/' \
          '--generated-content-path=[generated media path]:path:_files -/' \
          '--localai-config-dir=[dynamic config directory (api keys etc.)]:path:_files -/' \
          '--models-config-file=[YAML model backend list]:file:_files -g "*.yml *.yaml"' \
          '--config-file=[alias of --models-config-file]:file:_files -g "*.yml *.yaml"' \
          '--galleries=[JSON gallery list]:json:' \
          '--backend-galleries=[JSON backend gallery list]:json:' \
          '--preload-models=[JSON list applied at start]:json:' \
          '--preload-models-config=[YAML preload file]:file:_files -g "*.yml *.yaml"' \
          '(-t --threads)'{-t,--threads}'=[parallel worker threads]:n:' \
          '--context-size=[default context size]:n:' \
          '--f16[prefer half-precision / GPU path where supported]' \
          '--cors[enable CORS middleware]' \
          '--cors-allow-origins=[allowed CORS origins]:origins:' \
          '--upload-limit=[max upload size in MB]:n:' \
          '--api-keys+[API keys that must be presented by clients]:key:' \
          '--disable-webui[API only; no web UI assets]' \
          '--p2p[enable P2P session setup]' \
          '--p2p-token=[shared P2P token]:token:' \
          '--p2ptoken=[deprecated alias for --p2p-token]:token:' \
          '--p2p-network-id=[logical P2P network name]:id:' \
          '--distributed[enable horizontal scaling mode]' \
          '--instance-id=[node id for distributed mode]:uuid:' \
          '--nats-url=[NATS broker URL]:url:' \
          '*:model configuration URL:' && ret=0
        ;;
      (models)
        if (( CURRENT == 3 )); then
          msub=(
            'list:models available from configured galleries'
            'install:download or install a named gallery model'
          )
          _describe -t commands 'local-ai models' msub && ret=0
        else
          case ${words[3]} in
            (list)
              _arguments -s -S \
                '--galleries=[JSON gallery list]:json:' \
                '--backend-galleries=[JSON backend gallery list]:json:' \
                '--models-path=[model directory]:path:_files -/' \
                '--backends-path=[backend directory]:path:_files -/' && ret=0
              ;;
            (install)
              _arguments -s -S \
                '--galleries=[JSON gallery list]:json:' \
                '--backend-galleries=[JSON backend gallery list]:json:' \
                '--models-path=[model directory]:path:_files -/' \
                '--backends-path=[backend directory]:path:_files -/' \
                '--disable-predownload-scan[skip best-effort download scanner]' \
                '*:model name or OCI URI:' && ret=0
              ;;
          esac
        fi
        ;;
      (completion)
        _values 'shell' bash zsh fish && ret=0
        ;;
    esac
    ;;
esac

return ret
