#compdef autopkgtest

# Zsh completion for autopkgtest (run Debian package tests)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-B --no-built-binaries)'{-B,--no-built-binaries}'[do not use built binaries]' \
  '--build-parallel[parallel build jobs]:number' \
  '--env[set environment variable in testbed]:VAR=value' \
  '--timeout-short[short test timeout]:seconds' \
  '--timeout-copy[copy timeout]:seconds' \
  '--timeout-test[test timeout]:seconds' \
  '--timeout-build[build timeout]:seconds' \
  '--timeout-factor[multiply all timeouts by factor]:factor' \
  '--setup-commands[run commands on testbed setup]:commands or file:_files' \
  '--setup-commands-boot[run commands after testbed boot]:commands or file:_files' \
  '--apt-upgrade[upgrade testbed before test]' \
  '--apt-pocket[enable additional pocket]:pocket:(proposed backports updates security)' \
  '--apt-source[add apt source]:source line' \
  '--copy[copy file to testbed]:host_path:testbed_path' \
  '--pin-packages[pin packages from pocket]:pocket=src,src,...' \
  '--add-apt-source[add apt source]:source line' \
  '--add-apt-release[add apt release file]:release' \
  '(-o --output-dir)'{-o,--output-dir}'[output directory for results]:directory:_files -/' \
  '(-l --log-file)'{-l,--log-file}'[write log to file]:file:_files' \
  '--summary[write test summary to file]:file:_files' \
  '-d[enable debugging output]' \
  '-q[be quiet]' \
  '*:test source:_files' \
  '-- :virtualisation server:->virt' && ret=0

case $state in
  virt)
    local -a virt_servers=(
      'autopkgtest-virt-chroot:run tests in a chroot'
      'autopkgtest-virt-docker:run tests in a Docker container'
      'autopkgtest-virt-podman:run tests in a Podman container'
      'autopkgtest-virt-lxc:run tests in an LXC container'
      'autopkgtest-virt-lxd:run tests in an LXD container'
      'autopkgtest-virt-null:run tests on the local machine'
      'autopkgtest-virt-qemu:run tests in a QEMU virtual machine'
      'autopkgtest-virt-schroot:run tests in a schroot'
      'autopkgtest-virt-ssh:run tests on a remote machine via SSH'
      'autopkgtest-virt-unshare:run tests via user namespace'
    )
    _describe -t commands 'virtualisation server' virt_servers && ret=0
    ;;
esac

return ret
