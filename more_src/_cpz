#compdef cpz
# Documentation: https://github.com/SUPERCILEX/fuc
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# supercilex/fuc/cpz Rust cp alternative

local ret=1
_arguments -s -S \
  '(*)--help[long help]' \
  '(- *)'{-h,-\?}'[short help]' \
  '(- *)'{-V,--version}'[version]' \
  '(-f)'{-f,--force}'[overwrite existing]' \
  '(-t)'{-t,--reverse-args}'[reverse TO/FROM order]' \
  '(-L)'{-L,--follow-symlinks,--dereference}'[follow symlinks when copying]' \
  '(-l)'{-l,--hard-link,--link}'[hard link instead of copy]' \
  '*::sources then destination:_files' && ret=0
return ret
