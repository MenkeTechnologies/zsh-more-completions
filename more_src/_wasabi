#compdef wasabi wasabi-wallet
# _wasabi — zkSNACKs Wasabi Wallet CLI for the privacy-focused Bitcoin wallet implementing WabiSabi CoinJoin protocol BIP-158 client-side filters Tor SOCKS5 hardware-wallet support Lurking Wife mode hwi (zkSNACKs team, C#); System.CommandLine
# upstream: https://github.com/zkSNACKs/WalletWasabi

_wasabi() {
    local -a sub=(
        'startbitcoind:start a regtest bitcoind'
        'stopbitcoind:stop the regtest bitcoind'
        'createwallet:create new wallet'
        'recoverwallet:recover wallet from mnemonic'
        'listwallets:list wallets'
        'selectwallet:select wallet'
        'syncwallet:sync wallet'
        'showwallet:show wallet info'
        'showbalance:show wallet balance'
        'listcoins:list coins'
        'listtransactions:list transactions'
        'send:send BTC'
        'getnewaddress:get new address'
        'startcoinjoin:start CoinJoin'
        'stopcoinjoin:stop CoinJoin'
        'getstatus:show status'
        'getfeerates:show fee rates'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--datadir=+[dir]:dir:_files -/' \
        '--no-tor[no Tor]' \
        '--network=+[net]:n:(Main TestNet RegTest)' \
        '--proxy=+[host:port]:str:' \
        '--rpcuser=+[user]:str:' \
        '--rpcpassword=+[password]:str:' \
        '--rpcport=+[port]:n:' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wasabi subcommand' sub ;;
        args)
            case $words[1] in
                createwallet|recoverwallet|selectwallet|syncwallet|showwallet|showbalance|listcoins|listtransactions|startcoinjoin|stopcoinjoin) _arguments \
                    '--wallet-name=+[name]:str:' \
                    '--password=+[password]:str:' ;;
                send) _arguments \
                    '--wallet-name=+[name]:str:' \
                    '--to=+[addr]:str:' \
                    '--amount=+[BTC]:f:' \
                    '--feerate=+[sat/vB]:f:' \
                    '--label=+[label]:str:' \
                    '--coins=+[csv outpoints]:str:' \
                    '--password=+[password]:str:' ;;
            esac
            ;;
    esac
}

_wasabi "$@"
