#compdef gitu
# Documentation: https://man.archlinux.org/search?q=gitu
# Reference accessed: 2026-05-16

# Zsh completion for gitu (TUI git client)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --dir)'{-d,--dir}'[set git directory]:directory:_directories' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
