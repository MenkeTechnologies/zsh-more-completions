#compdef gitu
# Documentation: https://github.com/altsem/gitu
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for gitu (TUI git client)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --dir)'{-d,--dir}'[set git directory]:directory:_directories' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
