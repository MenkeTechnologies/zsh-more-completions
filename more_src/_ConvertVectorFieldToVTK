#compdef ConvertVectorFieldToVTK
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ConvertVectorFieldToVTK.cxx — convert displacement field to VTK structured-points (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:inputDisplacementField:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:outputVTKFile:_files -g "*.vtk"' \
    '3::maskImage:_files -g "*.{nii,nii.gz}"' \
    '4::slice:_default' \
    '5::whichAxis:(0 1 2)' \
    && ret=0

return ret
