# Zsh completion for asciiquarium - ASCII aquarium

_arguments -s -S \
  '-h[show help]' \
  '--help[show help]' \
  '-q[no input processing]' \
  '--classic[use classic starting fish]' \
  '-c[use classic starting fish]' \
  '-v[show version]'
