#compdef fpart
# Documentation: https://github.com/martymac/fpart
# File partitioning tool for parallel operations

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-n+[number of partitions]:partitions:' \
  '-s+[maximum partition size]:size:' \
  '-f+[maximum files per partition]:count:' \
  '-i+[input file list]:input file:_files' \
  '-a[do not cross filesystem boundaries]' \
  '-o+[output file template]:output template:_files' \
  '-0[input filenames are NUL-terminated]' \
  '-e[add empty directories to partitions]' \
  '-l[follow symbolic links]' \
  '-b[print only partition number]' \
  '-y+[include files matching pattern]:pattern:' \
  '-Y+[include directories matching pattern]:pattern:' \
  '-x+[exclude files matching pattern]:pattern:' \
  '-X+[exclude directories matching pattern]:pattern:' \
  '-z+[minimum file size]:size:' \
  '-Z+[maximum file size]:size:' \
  '-d+[maximum directory depth]:depth:' \
  '-D[pack empty directories as empty]' \
  '-E[add leaf directories to partitions]' \
  '-L[follow symbolic links in file arguments]' \
  '-v[verbose mode]' \
  '-vv[extra verbose mode]' \
  '-V[print version]' \
  '-h[print help]' \
  '-w+[pre-partition hook]:command:_command_names' \
  '-W+[post-partition hook]:command:_command_names' \
  '-p+[number of simultaneous hook instances]:instances:' \
  '-q+[end-of-partition hook]:command:_command_names' \
  '-r+[live mode input directory]:directory:_files -/' \
  '-R[enable live mode]' \
  '*:file or directory:_files' && ret=0

return ret
