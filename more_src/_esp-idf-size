#compdef esp-idf-size
# Documentation: https://docs.espressif.com/projects/esptool/
# Analyze static memory usage of ESP-IDF firmware images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--format[output format]:format:(table text tree csv json2 raw dot)' \
  '(-o --output-file)'{-o,--output-file}'[write output to file instead of stdout]:file:_files' \
  '--diff[compare against another map file]:map file:_files -g "*.map"' \
  '--archives[show per-archive breakdown]' \
  '--files[show per-file breakdown]' \
  '--archive-details[show details for a specific archive]:archive:' \
  '--unify[unify symbols across sections]' \
  '--sort[sort by column]:column:' \
  '*:map file:_files -g "*.map"' && ret=0

return ret
