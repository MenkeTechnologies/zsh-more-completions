#compdef createsdf
# Documentation: https://github.com/mapbox/fontnik
# fontnik: generate signed distance field glyphsets from OpenType fonts

local ret=1

_arguments -s -S \
  '--min=[minimum char code to generate]:char code:' \
  '--max=[maximum char code to generate]:char code:' \
  '--workers=[number of concurrent workers]:count:' \
  '*:font file:_files' && ret=0

return ret
