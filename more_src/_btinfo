#compdef btinfo
# Documentation: https://github.com/bluez/bluez/blob/master/tools/btinfo.c
# Source: BlueZ tools/btinfo.c — dump controller info via HCI raw socket.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-i --index)'{-i+,--index=}'[controller index]:idx:' \
    '(-r --reset)'{-r,--reset}'[reset controller]' \
    '(-R --raw)'{-R,--raw}'[raw device mode]' \
    '(- *)'{-v,--version}'[version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
