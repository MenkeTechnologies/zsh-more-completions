  '--help[show this help text]' \
  '-b+[bitstream input file name]:file:_files' \
  '-o+[reconstructed YUV output file name]:file:_files' \
  '-s+[number of frames to skip before random access]:n:' \
  '-d+[bit depth of YUV output luma component]:depth:' \
  '-t+[maximum temporal layer to decode (-1 = all)]:layer:' \
  '--SEIDecodedPictureHash=[control decoded picture hash SEI handling]:mode:(0 1)' \
  '-l+[targetDecLayerIdSet file name]:file:_files' \
  '-w[only output content inside default display window]' && ret=0

