#compdef mosint
# Documentation: https://github.com/alpkeskin/mosint
# OSINT: automated email OSINT tool.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c+,--config=}'[config file (default is $HOME/.mosint.yaml)]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output file (.json)]:file:_files' \
  '(-s --silent)'{-s,--silent}'[silent mode (only output file)]' \
  '--coffee[print coffee]' \
  '1:email:_email_addresses' && ret=0

return ret
