#compdef qmail-queue
# _qmail-queue — qmail's queue submitter (reads message on FD 0 + envelope info on FD 1, deposits one entry into the outgoing queue for qmail-send; programs may override via $QMAILQUEUE)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-queue.8 on tip; no flags.

_qmail-queue() {
    _arguments '(- *)-h[show help]'
}

_qmail-queue "$@"
