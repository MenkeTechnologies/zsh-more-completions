#compdef seinfo
# _seinfo — SELinux setools seinfo (introspect components of a loaded or saved policy: --type/--attribute/--role/--user/--bool/--class/--common/--initialsid/--polcap/--portcon/--genfscon/--netifcon/--mlsrange/--cat/--sens; -x show stats, --stats overall stats, --version, --help, -t target object type; positional argument is the policy file (.policy) or empty for live policy)
# upstream: https://github.com/SELinuxProject/setools
# Flags from SELinuxProject/setools libqpol/seinfo.py on tip.

_seinfo() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--stats[overall stats]' \
        '-x[show stats]' \
        '*--type+[type]:type:' \
        '*--attribute+[attribute]:attr:' \
        '*--role+[role]:role:' \
        '*--user+[user]:user:_users' \
        '*--bool+[boolean]:bool:' \
        '*--class+[class]:class:' \
        '*--common+[common]:common:' \
        '*--initialsid+[sid]:sid:' \
        '*--polcap+[capability]:cap:' \
        '*--portcon+[portcon]:port:' \
        '*--genfscon+[genfscon]:fs:' \
        '*--netifcon+[netifcon]:iface:' \
        '*--mlsrange+[mls range]:range:' \
        '*--cat+[category]:cat:' \
        '*--sens+[sensitivity]:sens:' \
        '1::policy file:_files'
}

_seinfo "$@"
