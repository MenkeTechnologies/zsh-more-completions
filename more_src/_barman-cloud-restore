#compdef barman-cloud-restore
# Documentation: https://man.archlinux.org/search?q=barman-cloud-restore
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--cloud-provider)--cloud-provider=+[cloud provider]:provider:(aws-s3 azure-blob-storage google-cloud-storage)' \
  '(--endpoint-url)--endpoint-url=+[endpoint URL]:url:' \
  '(-P --profile)'{-P,--profile}'+[AWS profile]:profile:' \
  '(--azure-credential)--azure-credential=+[Azure credential]:cred:(azure-cli managed-identity)' \
  '(-t --test)'{-t,--test}'[test connectivity]' \
  '(--tablespace)--tablespace=+[tablespace remap NAME:DIR]:remap:' \
  '(--target-time)--target-time=+[target time]:time:' \
  '(--target-name)--target-name=+[target name]:name:' \
  '(--target-tli)--target-tli=+[target timeline]:n:' \
  '(--target-immediate)--target-immediate[recover to immediate consistency]' \
  '(--target-xid)--target-xid=+[target transaction id]:xid:' \
  '(--snappy)--snappy[snappy decompress]' \
  '*:server_name destination_url backup_id recovery_dir:' && ret=0

return ret
