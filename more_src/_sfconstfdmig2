#compdef sfconstfdmig2
# Documentation: https://ahay.org/RSF/sfconstfdmig2.html
# Madagascar: 2-D implicit finite-difference migration in constant velocity

local ret=1

_arguments -s \
  'vel=[constant velocity]:float:' \
  'nz=[vertical time samples]:int:' \
  'dz=[vertical time sampling]:float:' \
  'hi=[if y, use 45-degree; n, 15-degree (y/n)]:bool:(y n)' \
  'sixth=[one-sixth trick]:float:' \
  'movie=[auxiliary output file name]:file:_files' \
  '*:rsf file:_files' && ret=0

return ret
