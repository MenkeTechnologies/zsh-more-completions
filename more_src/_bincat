#compdef bincat
# Documentation: http://tdc-www.harvard.edu/software/wcstools/
# bincat: bin a catalog of sources into a FITS image with WCS (WCSTools)

local ret=1

_arguments -s -S \
  '-a[initial rotation angle in degrees]:angle' \
  '-b[initial center in B1950 (FK4) RA and Dec]:RA:_message RA' \
  '-c[name of source catalog to bin]:catalog:_files' \
  '-d[set CDELTn, CROTAn instead of CD matrix]' \
  '-f[set flux scaling factor]:num' \
  '-g[initial center in Galactic longitude and latitude]:long:_message long' \
  '-j[initial center in J2000 (FK5) RA and Dec]:RA:_message RA' \
  '-o[output pixel size in bits (FITS BITPIX)]:num' \
  '-p[initial plate scale in arcsec per pixel]:num' \
  '-s[size of image in x and y pixels]:nx:_message nx' \
  '-t[set FITS CTYPE projection]:proj' \
  '-v[verbose]' \
  '-w[read WCS information from this FITS file]:file:_files -g "*.(fits|fit|fts|FITS|FIT|FTS|imh)"' \
  '-x[X and Y coordinates of reference pixel]:x:_message x' \
  '-z[use AIPS classic projections instead of WCSLIB]' \
  '*:catalog file:_files' && ret=0

return ret
