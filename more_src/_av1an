#compdef av1an
# Documentation: https://github.com/master-of-zen/Av1an
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Av1an (master-of-zen/Av1an, av1an/src/main.rs CliOpts — clap 4). Flat command; no nested subcommands.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-i}"+[input video or VapourSynth script]:file:_files" \
  '--proxy+[proxy input for scenecut/target-quality]:file:_files' \
  {-o}"+[output file]:file:_files" \
  '--temp+[temp directory]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[quiet; conflicts with --verbose]' \
  '--verbose[extra progress]' \
  '(-l --log-file)'{-l,--log-file}"=[log file path]:file:_files" \
  '--log-level=[log file level]:level:(error warn info debug trace)' \
  '--completions=[emit shell completions]:shell:(bash elvish fish powershell zsh)' \
  '(-r --resume)'{-r,--resume}'[resume session]' \
  '(-k --keep)'{-k,--keep}'[keep temp folder]' \
  '--force[skip encoder-arg validation]' \
  '--no-defaults[omit Av1an default encoder params]' \
  {-y}'[overwrite output without confirm]' \
  {-n}"[never overwrite; conflicts with -y]" \
  '--max-tries=[chunk restart limit]:int' \
  '(-w --workers)'{-w,--workers}"=[worker count 0=auto]:int" \
  '--set-thread-affinity=[Linux/Win thread groups]:int' \
  '--scaler=[ffmpeg scaler name]:scaler' \
  '--vspipe-args+[args for VapourSynth script]' \
  '(-s --scenes)'{-s,--scenes}"=[scene file]:file:_files" \
  '--sc-only[scene detection only; needs --scenes]' \
  '--split-method=[chunk method]:method:(av-scenechange none)' \
  '--sc-method=[scenecut algorithm]:method:(standard fast)' \
  '--sc-downscale-height=[max height for scenecut]:int' \
  '--sc-pix-format=[pixel fmt for scenecut]' \
  '(-x --extra-split)'{-x,--extra-split}"=[max scene length frames]:int" \
  '--extra-split-sec=[max scene length seconds]:float' \
  '--min-scene-len=[min frames per scene]:int' \
  {-e}"+[encoder kind]:encoder:(svt_av1 aom rav1e vpx x264 x265)" \
  {-v}"+[encoder CLI args; allow hyphen values]" \
  {-f}"+[ffmpeg filter opts]" \
  {-a}"+[ffmpeg audio args]" \
  '--target-quality=[target VMAF etc]:float' \
  '*: :_normal' && ret=0

return ret
