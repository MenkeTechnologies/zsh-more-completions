#compdef mpartition
# mtools - partition MSDOS hard disk

local ret=1

_arguments -s -S \
  '-V[print version]' \
  '-a[activate partition]' \
  '-d[deactivate partition]' \
  '-c[create partition]' \
  '-p[print partition table]' \
  '-I[initialize partition table]' \
  '-B[install boot sector]:boot sector:_files' \
  '-s[specify number of sectors]:sectors:' \
  '-t[specify number of tracks]:tracks:' \
  '-h[specify number of heads]:heads:' \
  '-f[force operation]' \
  '-v[verbose mode]' \
  '-b[specify begin]:begin:' \
  '-l[specify length]:length:' \
  '-T[specify filesystem type]:type:' \
  '1:drive:' && ret=0

return ret
