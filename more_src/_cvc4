#compdef cvc4

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-V)--show-config[show build config]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
  '--lang+[input language]:lang:(auto cvc4 smt smt1 smt2 smtlib smtlib2 smtlib2.6 sygus tptp)' \
  '--output-lang+[output language]:lang:(auto cvc4 smt smt2 smtlib2 smtlib2.6 ast tptp)' \
  '--input-language+[input language]:lang:(auto cvc4 smt smt2 smtlib2 smtlib2.6 sygus tptp)' \
  '--produce-models[produce models]' \
  '-m[produce models]' \
  '--produce-assignments[produce assignments]' \
  '--produce-proofs[produce proofs]' \
  '--produce-unsat-cores[produce unsat cores]' \
  '--produce-unsat-assumptions[produce unsat assumptions]' \
  '--incremental[incremental mode]' \
  '-i[incremental mode]' \
  '--interactive[interactive mode]' \
  '--no-interactive[disable interactive]' \
  '--tlimit+[time limit ms]:ms:' \
  '--tlimit-per+[per-call time limit ms]:ms:' \
  '--rlimit+[resource limit]:n:' \
  '--rlimit-per+[per-call resource limit]:n:' \
  '--seed+[random seed]:n:' \
  '--random-freq+[random frequency]:f:' \
  '--threads+[parallel threads]:n:' \
  '--print-success[print success]' \
  '--no-print-success[no print success]' \
  '--statistics[print statistics]' \
  '--no-statistics[no statistics]' \
  '--stats-every-query[stats per query]' \
  '--stats-hide-zeros[hide zero stats]' \
  '--simplification+[simplification mode]:m:(none batch incremental)' \
  '--decision+[decision mode]:m:(internal justification stoponly)' \
  '--decision-mode+[decision mode]:m:(internal justification stoponly)' \
  '--bv-sat-solver+[BV SAT solver]:s:(minisat cryptominisat cadical)' \
  '--no-checking[no proof checking]' \
  '--check-proofs[check proofs]' \
  '--check-models[check models]' \
  '--check-unsat-cores[check unsat cores]' \
  '--dump+[dump]:m:(declarations assertions skolems clauses learned full benchmark state)' \
  '--dump-to+[dump output file]:file:_files' \
  '--lazy-definitional-expansion[lazy def expansion]' \
  '--default-dag-thresh+[dag thresh]:n:' \
  '*: :_files -g "*.smt *.smt2 *.cvc *.sy *.p *.tptp"' && ret=0

return ret
