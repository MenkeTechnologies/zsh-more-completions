#compdef prank
# PRANK: probabilistic multiple sequence alignment with phylogeny awareness

local ret=1

_arguments -s -S \
  '-help[show extended help]' \
  '-version[show version information]' \
  '-d=-[input sequence file in FASTA format]:file:_files' \
  '-t=-[guide tree file (NJ tree generated if unset)]:file:_files' \
  '-o=-[output filename prefix]:prefix:' \
  '-f=-[output format]:format:(fasta phylipi phylips paml nexus)' \
  '-m=-[model file]:file:_files' \
  '-d1=-[first input alignment file]:file:_files' \
  '-d2=-[second input alignment file]:file:_files' \
  '-t1=-[tree file for first alignment]:file:_files' \
  '-t2=-[tree file for second alignment]:file:_files' \
  '-dna=-[DNA file for protein alignment back-translation]:file:_files' \
  '-support[compute posterior support]' \
  '-showxml[output alignment XML file]' \
  '-showtree[output alignment guide tree]' \
  '-showanc[output ancestral sequences]' \
  '-showall[output all supplementary files]' \
  '-noanchors[disable Exonerate anchoring]' \
  '-nomafft[disable MAFFT for guide tree]' \
  '-njtree[estimate tree from input alignment]' \
  '-shortnames[truncate names at first space]' \
  '-quiet[reduce output verbosity]' \
  '-F[force insertions to always be skipped]' \
  '+F[force insertions to always be skipped]' \
  '-gaprate=-[gap opening rate]:rate:' \
  '-gapext=-[gap extension probability]:prob:' \
  '-codon[use empirical codon model for DNA]' \
  '-DNA[use DNA model]' \
  '-protein[use protein model]' \
  '-termgap[penalize terminal gaps normally]' \
  '-nomissing[no missing data handling]' \
  '-keep[retain gaps in pre-aligned sequences]' \
  '-iterate=-[iteration rounds (default 5)]:rounds:' \
  '-once[run a single iteration only]' \
  '-prunetree[remove guide tree branches lacking sequence data]' \
  '-prunedata[remove sequences without guide tree leaves]' \
  '-uselogs[slower method for larger sequence counts]' \
  '-translate[convert input to protein sequences]' \
  '-mttranslate[translate using mitochondrial table]' \
  '-convert[format conversion without alignment]' && ret=0

return ret
