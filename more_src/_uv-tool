#compdef uv-tool
# _uv-tool — uv tool management (astral-sh/uv)
# upstream: https://github.com/astral-sh/uv

_uv_tool() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_uv_tool_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                install)
                    _arguments \
                        '--with=[additional package]:package:' \
                        '--python=[Python version]:version:' \
                        '--force[force reinstall]' \
                        '--help[show help]' \
                        '1:package:' && ret=0 ;;
                upgrade)
                    _arguments \
                        '--all[upgrade all tools]' \
                        '--help[show help]' \
                        '1:tool:' && ret=0 ;;
                uninstall)
                    _arguments \
                        '--all[uninstall all tools]' \
                        '--help[show help]' \
                        '1:tool:' && ret=0 ;;
                run)
                    _arguments \
                        '--with=[additional package]:package:' \
                        '--python=[Python version]:version:' \
                        '--from=[package to run from]:package:' \
                        '--help[show help]' \
                        '*:command:_command_names -e' && ret=0 ;;
                list|dir|update-shell) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_uv_tool_commands] )) ||
_uv_tool_commands() {
    local -a commands
    commands=(
        'install:install a tool'
        'list:list installed tools'
        'run:run a tool in an ephemeral environment'
        'uninstall:uninstall a tool'
        'upgrade:upgrade a tool'
        'dir:show tool installation directory'
        'update-shell:update shell for tool PATH'
    )
    _describe -t commands 'uv tool command' commands
}

_uv_tool "$@"
