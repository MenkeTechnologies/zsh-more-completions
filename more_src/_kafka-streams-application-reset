#compdef kafka-streams-application-reset
# Documentation: https://kafka.apache.org/documentation/ (kafka-streams-application-reset.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--application-id[REQUIRED: The Kafka Streams application ID (application.id)]:id:'
    '--bootstrap-server[The server(s) to connect to]:host\:port:'
    '--by-duration[Reset offsets to offset by duration from current timestamp (PnDTnHnMnS)]:duration:'
    '--command-config[Config properties file passed to admin clients and embedded consumer]:file:_files'
    '--config-file[(DEPRECATED) Property file passed to admin clients and embedded consumer]:file:_files'
    '--dry-run[Display the actions without executing the reset commands]'
    '--force[Force the removal of members of the consumer group]'
    '--from-file[Reset offsets to values defined in CSV file]:file:_files'
    '--help[Print usage information]'
    '--input-topics[Comma-separated list of user input topics]:topics:'
    '--intermediate-topics[Comma-separated list of intermediate user topics]:topics:'
    '--internal-topics[Comma-separated list of internal topics to delete]:topics:'
    '--shift-by[Reset offsets shifting current offset by n]:n:'
    '--to-datetime[Reset offsets to offset from datetime (YYYY-MM-DDThh:mm:ss.sss)]:datetime:'
    '--to-earliest[Reset offsets to earliest offset]'
    '--to-latest[Reset offsets to latest offset]'
    '--to-offset[Reset offsets to a specific offset]:offset:'
    '--version[Display Kafka version]'
)

_arguments -s -S $arguments
