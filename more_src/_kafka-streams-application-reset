#compdef kafka-streams-application-reset

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--application-id[The Kafka Streams application ID]:id:'
    '--input-topics[Comma-separated list of user input topics]:topics:'
    '--intermediate-topics[Comma-separated list of intermediate user topics]:topics:'
    '--internal-topics[Comma-separated list of internal topics to delete]:topics:'
    '--to-datetime[Reset offsets to a specific datetime]:datetime:'
    '--by-duration[Reset offsets by duration]:duration:'
    '--to-earliest[Reset offsets to earliest offset]'
    '--to-latest[Reset offsets to latest offset]'
    '--to-offset[Reset offsets to a specific offset]:offset:'
    '--shift-by[Reset offsets shifting current offset by n]:n:'
    '--from-file[Reset offsets from a CSV file]:file:_files'
    '--execute[Execute the command]'
    '--dry-run[Display the actions without executing]'
    '--config-file[Property file with admin client configs]:file:_files'
    '--force[Force removal of internal topics even if not empty]'
)

_arguments -s -S $arguments
