#compdef create-better-fullstack
# Documentation: https://www.npmjs.com/package/create-better-fullstack
# Reference accessed: 2026-05-23
# Verified: npm view create-better-fullstack bin; npm readme CLI Flags section.

# Zsh completion for create-better-fullstack - combinatorial fullstack stack scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--yes[accept all defaults]' \
  '--yolo[scaffold a random stack]' \
  '--template=[preset template]:template:(t3 mern pern uniwind)' \
  '--ecosystem=[language ecosystem mode]:ecosystem:(typescript rust python go java)' \
  '--version-channel=[dependency channel]:channel:(stable latest beta)' \
  '--no-git[skip git initialization]' \
  '--no-install[skip dependency installation]' \
  '--package-manager=[package manager]:manager:(bun pnpm npm yarn)' \
  '--verbose[show detailed output]' \
  ':project name:' && ret=0

return ret
