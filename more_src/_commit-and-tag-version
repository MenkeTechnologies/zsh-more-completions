#compdef commit-and-tag-version

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*'{-i+,--infile=}'[changelog file]:file:_files -g "*.md"' \
  '*-p+[prerelease tag]:tag:' \
  '*--prerelease=-[prerelease tag]:tag:' \
  '*-m+[commit message]:message:' \
  '*--message=[commit message]:message:' \
  '*-t+[tag prefix]:prefix:' \
  '*--tag-prefix=[tag prefix]:prefix:' \
  '*--release-as=[release as specific version]:version:(major minor patch)' \
  '--prerelease[release as prerelease]' \
  '*--scripts.prebump=[prebump script]:command:' \
  '*--scripts.postbump=[postbump script]:command:' \
  '*--scripts.precommit=[precommit script]:command:' \
  '*--scripts.postcommit=[postcommit script]:command:' \
  '*--scripts.prerelease=[prerelease script]:command:' \
  '*--scripts.postrelease=[postrelease script]:command:' \
  '*--scripts.prechangelog=[prechangelog script]:command:' \
  '*--scripts.postchangelog=[postchangelog script]:command:' \
  '*--skip.bump[skip bumping version]' \
  '*--skip.changelog[skip changelog]' \
  '*--skip.commit[skip commit]' \
  '*--skip.tag[skip tag]' \
  '*--bumpFiles=[files to bump version in]:files:_files' \
  '*--packageFiles=[package files for version source]:files:_files' \
  {-n,--no-verify}'[bypass pre-commit/commit-msg hooks]' \
  {-s,--sign}'[sign the tag/commit]' \
  '--silent[no commit/changelog output]' \
  {-a,--commit-all}'[commit all staged changes]' \
  '--dry-run[print steps without committing]' \
  '--first-release[is the first release (no version bump)]' \
  '--header=[changelog header]:header:' \
  '--lerna-package=[name of lerna package]:name:' \
  '--no-verify[bypass git hooks]' \
  '--path=[only consider commits/files for path]:path:_files -/' \
  '--preset=[changelog preset]:preset:(angular atom codemirror conventionalcommits ember eslint express jquery jshint)' \
  '--release-count=[releases to include in changelog]:n:' \
  '--release-commit-message-format=[release commit message format]:format:' \
  '--tag-force[force replacement of tag]' \
  '--types=[commit types to include]:types:' \
  '--tag-suffix=[tag suffix]:suffix:' \
  '--git-tag-fallback[use git tag as fallback when version unavailable]' \
  '--no-git-tag-fallback[disable git tag fallback]' \
  '--changelog-header=[custom changelog header]:header:' && ret=0

return ret
