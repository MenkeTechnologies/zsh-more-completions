#compdef didc
# _didc — Candid CLI for Internet Computer (dfinity/candid)
# upstream: https://github.com/dfinity/candid
# Subcommands from tools/didc/src/main.rs (clap derive).

_didc() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_didc_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                check)
                    _arguments \
                        '(-s --strict)'{-s,--strict}'[require structural equality instead of subtyping]' \
                        '1:current did file:_files -g "*.did"' \
                        '2:previous did file (optional):_files -g "*.did"' && ret=0 ;;
                bind)
                    _arguments \
                        '(-t --target)'{-t+,--target=}'[target language]:lang:(js ts did mo rs rs-agent rs-stub)' \
                        '(-c --config)'{-c+,--config=}'[binding generation config (TOML)]:config:' \
                        '*'{-m+,--methods=}'[method names to bind (-m foo,bar or -m foo -m bar)]:methods:' \
                        '1:did file:_files -g "*.did"' && ret=0 ;;
                hash)
                    _arguments \
                        '1:field name:' && ret=0 ;;
                encode)
                    _arguments \
                        '(-f --format)'{-f+,--format=}'[hex format]:format:(hex pretty blob)' \
                        '(-t --types)'{-t+,--types=}'[Candid type annotations]:types:' \
                        '(-m --method)'{-m+,--method=}'[service method (requires --defs)]:method:' \
                        '(-d --defs)'{-d+,--defs=}'[did file for type definitions]:file:_files -g "*.did"' \
                        '1:Candid textual args (optional, else stdin):' && ret=0 ;;
                decode)
                    _arguments \
                        '(-f --format)'{-f+,--format=}'[hex format]:format:(hex blob)' \
                        '(-t --types)'{-t+,--types=}'[Candid type annotations]:types:' \
                        '(-m --method)'{-m+,--method=}'[service method (requires --defs)]:method:' \
                        '(-d --defs)'{-d+,--defs=}'[did file for type definitions]:file:_files -g "*.did"' \
                        '1:hex blob (optional, else stdin):' && ret=0 ;;
                assist)
                    _arguments \
                        '(-t --types)'{-t+,--types=}'[Candid type annotations]:types:' \
                        '(-m --method)'{-m+,--method=}'[service method]:method:' \
                        '(-d --defs)'{-d+,--defs=}'[did file]:file:_files -g "*.did"' && ret=0 ;;
                random)
                    _arguments \
                        '(-c --config)'{-c+,--config=}'[random-value config (TOML)]:config:' \
                        '(-l --lang)'{-l+,--lang=}'[target language]:lang:(did js)' \
                        '(-a --args)'{-a+,--args=}'[input args for a method, mocking the return]:args:' \
                        '(-t --types)'{-t+,--types=}'[Candid type annotations]:types:' \
                        '(-m --method)'{-m+,--method=}'[service method]:method:' \
                        '(-d --defs)'{-d+,--defs=}'[did file]:file:_files -g "*.did"' && ret=0 ;;
                subtype)
                    _arguments \
                        '(-d --defs)'{-d+,--defs=}'[did file]:file:_files -g "*.did"' \
                        '1:type 1:' \
                        '2:type 2:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_didc_commands] )) ||
_didc_commands() {
    local -a commands
    commands=(
        'check:type-check a Candid file (optional subtyping check vs previous version)'
        'bind:generate language bindings from a .did file'
        'hash:compute the hash of a field name'
        'encode:encode Candid textual value to binary'
        'decode:decode Candid binary data to textual value'
        'assist:generate Candid textual values interactively'
        'random:generate random Candid values'
        'subtype:check subtyping between two Candid types'
    )
    _describe -t commands 'didc command' commands
}

_didc "$@"
