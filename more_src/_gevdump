#compdef gevdump
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/Apps/gEvDump.cxx
# gevdump - GENIE utility to print-out GHEP event records

local ret=1

_arguments -s -S \
  '-f[GENIE GHEP/ROOT event file]:file:_files' \
  '-n[event number or range n1,n2 to print (default all)]:nrange:' \
  '--event-record-print-level[level of information shown when printing the event record]:level:' \
  '--message-thresholds[XML file customizing message stream thresholds]:xml:_files' \
  '*: :_files' && ret=0

return ret
