#compdef fileproviderctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'dump:dump state of fileprovider daemon'
  'diagnose:dump state in several files'
  'evaluate:evaluate finder actions/decorations on item'
  'check:run FPCK'
  'repair:run FPCK with repair'
  'obfuscate:return obfuscated form of filename'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'fileproviderctl command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (dump|diagnose)
        _arguments \
          {-l,--limit-dump-size}'[limit number of items dumped]' \
          {-o+,--output=}'[output path]:path:_files -/' \
          '*:domain or provider:' && ret=0
        ;;
      (check|repair)
        _arguments \
          '-f[full dump (all items)]' \
          '-a+[perform check under path]:path:_files -/' \
          '-b+[operate on existing DB backup]:path:_files -/' \
          '-o+[write output into file]:file:_files' \
          '-P[no-pager output]' \
          '-d[dismiss low-importance invariants]' \
          '-v[print files with broken invariants]' \
          '-m+[check d2d migration backup]:provider domain id:' \
          '-x+[launch as XPC Service or daemon]:mode:(xpc daemon)' && ret=0
        ;;
      (evaluate)
        _files && ret=0
        ;;
      (obfuscate)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
