#compdef kubectl-stash
# Documentation: upstream pkg/ tree at github.com/stashed/cli
# Reference accessed: 2026-05-30 via gh api inspection of every
# pkg/*.go Use:/AddCommand list.
# Stash kubectl-stash R64 — Kubernetes-native backup/restore for
# stateful workloads (AppsCode Stash CLI). 19 top-level commands;
# 8 have nested sub-actions.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'version:print version information'
  'completion:generate shell completion (bash/zsh/fish/powershell)'
  'cp:copy a stash resource (sub: backupconfig/repository/secret/volumesnapshot)'
  'delete:delete a stash resource (sub: snapshot)'
  'download:download snapshots from a repository'
  'trigger:trigger a backup immediately'
  'unlock:unlock a repository'
  'create:create a stash resource (sub: backupconfig/repository/restoresession)'
  'clone:clone a Kubernetes resource (sub: pvc)'
  'pause:pause backups (sub: backup)'
  'resume:resume backups (sub: backup)'
  'debug:debug a stash workload (sub: backup/operator/restore)'
  'gen:generate templates (sub: rules)'
  'key:manage restic keys (sub: add/list/update/remove)'
  'check:check repository integrity'
  'rebuild-index:rebuild the index of a repository'
  'migrate:migrate a v1 repository to v2'
  'prune:prune unused data from a repository'
  'purge-repos:purge orphaned repositories'
)

local -a _cp_subs _create_subs _debug_subs _key_subs _shells
_cp_subs=(
  'backupconfig:copy a BackupConfiguration'
  'repository:copy a Repository'
  'secret:copy a Secret'
  'volumesnapshot:copy a VolumeSnapshot'
)
_create_subs=(
  'backupconfig:create a BackupConfiguration'
  'repository:create a Repository'
  'restoresession:create a RestoreSession'
)
_debug_subs=(
  'backup:debug a backup'
  'operator:debug the stash operator'
  'restore:debug a restore'
)
_key_subs=(
  'add:add a new restic key to a repository'
  'list:list keys in a repository'
  'update:update a key in a repository'
  'remove:remove a key from a repository'
)
_shells=( bash zsh fish powershell )

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '(-n --namespace)'{-n,--namespace}'=[namespace]:namespace:' \
  '--context=[kubeconfig context]:context:' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'kubectl-stash subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      completion)
        _arguments '1:shell:($_shells)' && ret=0
        ;;
      cp)
        _arguments -C \
          '(-): :->cp_sub' \
          '(-)*:: :->cp_sub_args' && ret=0
        case $state in
          cp_sub) _describe -t commands 'kubectl-stash cp subcommand' _cp_subs && ret=0 ;;
          cp_sub_args)
            _arguments \
              '1:resource name:' \
              '--to-namespace=[destination namespace]:namespace:' && ret=0
            ;;
        esac
        ;;
      create)
        _arguments -C \
          '(-): :->create_sub' \
          '(-)*:: :->create_sub_args' && ret=0
        case $state in
          create_sub) _describe -t commands 'kubectl-stash create subcommand' _create_subs && ret=0 ;;
          create_sub_args)
            _arguments \
              '1:resource name:' \
              '--target-name=[backup target workload name]:name:' \
              '--target-kind=[backup target workload kind]:kind:(Deployment StatefulSet DaemonSet Job CronJob)' \
              '--schedule=[cron schedule expression]:cron:' \
              '--repository=[repository name]:name:' \
              '--paths=[paths to backup]:paths:' \
              '--volume-mounts=[volume mount points]:mounts:' \
              '--retention-policy-name=[retention policy name]:name:' \
              '--retention-policy-keep-last=[keep last N snapshots]:N:' \
              && ret=0
            ;;
        esac
        ;;
      debug)
        _arguments -C \
          '(-): :->debug_sub' \
          '(-)*:: :->debug_sub_args' && ret=0
        case $state in
          debug_sub) _describe -t commands 'kubectl-stash debug subcommand' _debug_subs && ret=0 ;;
        esac
        ;;
      key)
        _arguments -C \
          '(-): :->key_sub' \
          '(-)*:: :->key_sub_args' && ret=0
        case $state in
          key_sub) _describe -t commands 'kubectl-stash key subcommand' _key_subs && ret=0 ;;
          key_sub_args)
            _arguments \
              '--repo-name=[repository name]:name:' \
              '--host=[restic host]:host:' \
              '--user=[restic user]:user:' && ret=0
            ;;
        esac
        ;;
      delete)
        _arguments \
          '1:delete target:(snapshot)' \
          '*:snapshot id:' && ret=0
        ;;
      pause|resume)
        _arguments \
          '1:action target:(backup)' \
          '*:backupconfiguration name:' && ret=0
        ;;
      clone)
        _arguments \
          '1:clone target:(pvc)' \
          '*:PVC name:' && ret=0
        ;;
      gen)
        _arguments \
          '1:gen subcommand:(rules)' \
          '--repository=[repository name]:name:' && ret=0
        ;;
      download)
        _arguments \
          '1:repository name:' \
          '--snapshots=[snapshot IDs (comma-separated)]:ids:' \
          '--destination-dir=[destination directory]:dir:_directories' \
          && ret=0
        ;;
      trigger)
        _arguments \
          '1:backupconfiguration name:' \
          '--backupconfig=[BackupConfiguration to trigger]:name:' && ret=0
        ;;
      unlock|check|rebuild-index|migrate|prune)
        _arguments \
          '1:repository name:' \
          '--repo-name=[repository name]:name:' \
          '--namespace=[repository namespace]:namespace:' && ret=0
        ;;
      purge-repos)
        _arguments \
          '*:namespace:' \
          '--dry-run[print actions without executing]' && ret=0
        ;;
      version)
        _arguments \
          '--short[print only the version number]' \
          '(-o --output)'{-o,--output}'=[output format]:format:(yaml json)' && ret=0
        ;;
    esac
    ;;
esac

return ret
