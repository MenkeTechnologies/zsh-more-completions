_substudy() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_substudy_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                clean)
                    _arguments \
                        ':subtitle file:_files -g "*.srt"' && ret=0 ;;
                combine)
                    _arguments \
                        ':foreign-language subs:_files -g "*.srt"' \
                        ':native-language subs:_files -g "*.srt"' && ret=0 ;;
                export)
                    _arguments \
                        '1:format:(anki)' \
                        '*::arg:' && ret=0 ;;
                import)
                    _arguments \
                        '1:format:(whisper-json)' \
                        '*::arg:_files' && ret=0 ;;
                list)
                    _arguments \
                        '*: :' && ret=0 ;;
                transcribe)
                    _arguments \
                        '--related-text=[priming text similar to the video]:file:_files' \
                        '--expected-text=[full expected text (e.g. lyrics)]:file:_files' \
                        '--lang=[primary language code]:lang:(en es fr de it pt ja zh ko ar ru)' \
                        '--format=[output format]:format:(srt whisper-srt whisper-json)' \
                        ':video file:_files -g "*.{mp3,mp4,mkv,avi,mov,wav,m4a,flac,ogg,webm}"' && ret=0 ;;
                translate)
                    _arguments \
                        '--foreign-lang=[source language code]:lang:(en es fr de it pt ja zh ko ar ru)' \
                        '--native-lang=[target language code (REQUIRED)]:lang:(en es fr de it pt ja zh ko ar ru)' \
                        ':foreign subs:_files -g "*.srt"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_substudy_commands] )) ||
_substudy_commands() {
    local -a commands
    commands=(
        'clean:clean a subtitle file (remove non-dialog text)'
        'combine:combine two subtitle files into a bilingual SRT'
        'export:export subtitles (anki, music tracks, etc.)'
        'import:import subtitles (whisper-json, etc.)'
        'list:list information about a file'
        'transcribe:transcribe subtitles from audio via OpenAI Whisper'
        'translate:translate subtitles via OpenAI'
    )
    _describe -t commands 'substudy command' commands
}

_substudy "$@"
