#compdef kube-hunter

# Zsh completion for kube-hunter - Kubernetes penetration testing tool

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)--version[display version]' \
  '--cidr=[CIDR range to scan]:CIDR:' \
  '--interface[scan all connected network interfaces]' \
  '--internal[scan internal cluster network]' \
  '--pod[scan from within a pod]' \
  '--remote=[comma-separated remote hosts to scan]:hosts:' \
  '--active[enable active hunting mode]' \
  '--quick[perform a quick scan]' \
  '--include-patched-versions[include patched version checks]' \
  '--enable-cve-hunting[enable CVE hunting]' \
  '--list[list all available tests]' \
  '--mapping[perform network mapping only]' \
  '--statistics[show hunting statistics]' \
  '--log=[log level]:level:(WARNING INFO DEBUG NONE)' \
  '--report=[report output format]:format:(plain yaml json)' \
  '--dispatch=[dispatch method for results]:type:(stdout http)' \
  '--dispatch-url=[URL for HTTP dispatch]:url:'
