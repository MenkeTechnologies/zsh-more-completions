#compdef mfboot
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/mfboot.html
# Set the flux scale of a visibility dataset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'line=[line keyword]:line:' \
  'select=[select keyword]:select:' \
  'flux=[flux keyword]:flux:' \
  'mode=[mode keyword]:mode:' \
  'clip=[clip keyword]:clip:' \
  'device=[device keyword]:device:' \
  'options=[options keyword]:options:' \
  '*:visibility dataset:_files' && ret=0

return ret
