#compdef qperf
local curcontext="$curcontext" state line ret=1
local -a tests=(
  'tcp_bw:TCP streaming one way bandwidth'
  'tcp_lat:TCP streaming one way latency'
  'udp_bw:UDP streaming one way bandwidth'
  'udp_lat:UDP streaming one way latency'
  'sdp_bw:SDP streaming one way bandwidth'
  'sdp_lat:SDP streaming one way latency'
  'rds_bw:RDS streaming one way bandwidth'
  'rds_lat:RDS streaming one way latency'
  'sctp_bw:SCTP streaming one way bandwidth'
  'sctp_lat:SCTP streaming one way latency'
  'conf:show configuration'
)
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-t --time)'{-t,--time}'[test duration in seconds]:seconds:' \
  '(-m --msg_size)'{-m,--msg_size}'[message size]:size:' \
  '(-p --port)'{-p,--port}'[base port number]:port:' \
  '(-lp --listen_port)'{-lp,--listen_port}'[listen port number]:port:' \
  '--precision[number of significant digits]:digits:' \
  '--verbose[verbose output]' \
  '--use_bits_per_sec[show results in bits/sec]' \
  '--wait[wait for server to become available]' \
  '--timeout[timeout for waiting]:seconds:' \
  '--loc_cpus_used[local CPUs to pin to]:cpus:' \
  '--rem_cpus_used[remote CPUs to pin to]:cpus:' \
  '1:server node:_hosts' \
  '*:test:->tests' && ret=0
case $state in
  tests)
    _describe -t tests 'qperf test' tests && ret=0
    ;;
esac
return ret
