#compdef oct-photoelectron_spectrum
# Documentation: https://www.octopus-code.org/documentation/main/manual/utilities/oct-photoelectron_spectrum/
# Octopus: post-process the photoelectron momentum distribution into a spectrum

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help and exit]' \
  '(-v --version)'{-v,--version}'[print octopus version]' \
  '(-V --vec)'{-V,--vec}'=[polar zenith direction in comma-separated format]:vec' \
  '(-u --pvec)'{-u,--pvec}'=[plane cut vector in comma-separated format]:pvec' \
  '(-C --center)'{-C,--center}'=[center of the coordinates in p-space in comma-separated format]:center' \
  '(-E --espan)'{-E,--espan}'=[maximum and minimum energy in colon-separated values]:espan' \
  '(-e --de)'{-e,--de}'=[the resolution in energy]:de' \
  '(-T --thspan)'{-T,--thspan}'=[maximum and minimum theta in colon-separated format]:thspan' \
  '(-t --dth)'{-t,--dth}'=[the resolution in theta]:dth' \
  '(-P --phspan)'{-P,--phspan}'=[maximum and minimum phi in colon-separated format]:phspan' \
  '(-p --dph)'{-p,--dph}'=[the resolution in phi]:dph' \
  '(-I --integr)'{-I,--integr}'=[integrate the spectrum over the specified variable]:var' && ret=0

return ret
