#compdef ANTSUseDeformationFieldToGetAffineTransform
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ANTSUseDeformationFieldToGetAffineTransform.cxx — estimate rigid/affine from a deformation field (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:zzzWarp.nii.gz:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:load_ratio (e.g. 0.01):_default' \
    '3:type:(rigid affine)' \
    '4:OutAffine.txt:_files -g "*.{txt,mat}"' \
    '5::mask.nii.gz:_files -g "*.{nii,nii.gz}"' \
    && ret=0

return ret
