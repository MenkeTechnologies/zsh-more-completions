#compdef ligolo
# Tunneling/pivoting tool for penetration testing

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--selfcert[use self-signed certificate]' \
  '--certfile[TLS certificate file]:file:_files' \
  '--keyfile[TLS key file]:file:_files' \
  '--laddr[listening address]:addr:' \
  '--allow[allowed subnets]:subnets:' \
  '--dns[DNS server address]:addr:' \
  '--enable-autocert[enable automatic TLS certificates]' \
  '-v[verbose output]' \
  && return 0
