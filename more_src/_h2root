#compdef h2root
# Documentation: https://root.cern/manual/io/#converting-hbook-files-to-root
# Source: root-project/root main/src/h2root.cxx — convert CERN HBOOK (.hbook) files to ROOT trees.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:hbook input file:_files -g "*.(hbook|HBOOK)(-.)"' \
    '2:root output file:_files -g "*.root(-.)"' \
    '3:compress (1=on default, 0=off):(0 1)' \
    '4:tolower (1=mixed-case default, 2=lowercase):(1 2)' \
    '5:lrecl (record length, 0=default):_default' \
    '6:bufsize (branch buffer size, default 8000):_default' \
    '7:optcwn (1=optimize int sizes default, 0=keep 4-byte):(0 1)' \
    && ret=0

return ret
