#compdef barb
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/windbarbs — plot wind barbs at data point locations

local ret=1

_arguments -s \
  '-J+[map projection]:proj:_default' \
  '-R+[region west/east/south/north]:region:_default' \
  '-B+[map frame and axes]:frame:_default' \
  '-C+[color palette table]:cpt:_files' \
  '-D+[offset symbols by dx/dy[/dz]]:offset:_default' \
  '-G+[fill color or pattern]:fill:_default' \
  '-I+[modulate fill with illumination]:intens:_default' \
  '-N[do not clip symbols at border]' \
  '-Q+[barb parameters length/angle/fill/pen]:opts:_default' \
  '-U+[GMT timestamp logo]:stamp:_default' \
  '*-V[verbose (stackable)]' \
  '-W+[pen attributes]:pen:_default' \
  '-X+[shift origin horizontally]:x:_default' \
  '-Y+[shift origin vertically]:y:_default' \
  '-a+[aspatial column associations]:cols:_default' \
  '-bi+[binary input format]:format:_default' \
  '-di+[replace nodata with NaN]:nodata:_default' \
  '-e+[record pattern filter]:pattern:_default' \
  '-f+[column data types]:types:_default' \
  '-h+[header records]:n:_default' \
  '-i+[input column selection]:cols:_default' \
  '-p+[perspective view]:view:_default' \
  '-t+[transparency level]:pct:_default' \
  '*:input table:_files' \
  && ret=0

return ret
