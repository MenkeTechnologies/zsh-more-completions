#compdef sn0int

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose output]' \
  '--workspace=[select workspace]:workspace' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:run a module'
      'db:manage database'
      'install:install a module'
      'search:search modules'
      'login:login to registry'
      'new:create new module'
      'publish:publish a module'
      'select:select from scope'
      'add:add to scope'
      'delete:delete from scope'
      'keyring:manage keyring'
      'noscope:manage noscope'
      'notify:manage notifications'
      'pkg:manage packages'
      'repl:start REPL'
      'sandbox:test sandbox'
      'completions:generate shell completions'
    )
    _describe -t commands 'sn0int command' commands && ret=0
    ;;
esac

return ret
