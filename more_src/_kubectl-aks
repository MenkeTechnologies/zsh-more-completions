#compdef kubectl-aks
# Documentation: https://github.com/Azure/kubectl-aks/blob/main/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-aks (Azure/kubectl-aks). Interact with an AKS cluster's nodes.

local curcontext="$curcontext" state line ret=1

local -a node_flags=(
  '--node=[node name]:node:'
  '--subscription=[Azure subscription ID]:id:'
  '--resource-group=[Azure resource group]:group:'
  '--cluster-name=[AKS cluster name]:name:'
  '--node-resource-group=[node resource group]:group:'
  '--vmss=[VMSS name]:vmss:'
  '--instance-id=[VMSS instance ID]:id:'
  '--id=[Azure resource ID]:id:'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--runtime=[runtime to use]:runtime:(azure-api kube-api)' \
  '--debug-image=[container image used for debugging]:image:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:manage kubectl-aks configuration'
      'run-command:run a command on a node'
      'check-apiserver-connectivity:check connectivity to the API server'
      'version:print version'
    )
    _describe -t commands 'kubectl-aks command' commands && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _arguments -s -S \
          '1:subcommand:(show use-node use-cluster unset-current-node unset-node unset-cluster unset-all set-node list-clusters)' && ret=0
        ;;
      run-command)
        _arguments -s -S $node_flags \
          '--timeout=[timeout in seconds for the command to complete]:seconds:' && ret=0
        ;;
      check-apiserver-connectivity)
        _arguments -s -S $node_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
