#compdef gjar
# Documentation: https://www.gnu.org/software/classpath/docs/cp-tools.html
# Reference accessed: 2026-05-16
# Verified: GNU Classpath cp-tools docs. Mirrors Sun's jar(1).
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# gjar: GNU Classpath jar archiver
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-c -t -x -u -i)-c[create new archive]' \
  '(-c -t -x -u -i)-t[list table of contents]' \
  '(-c -t -x -u -i)-x[extract files from archive]' \
  '(-c -t -x -u -i)-u[update existing archive]' \
  '(-c -t -x -u -i)-i[compute archive index]' \
  '-f[archive file name]:file:_files' \
  '-0[store only (no compression)]' \
  '-v[verbose output]' \
  '-M[no manifest file]' \
  '-m[include manifest from file]:file:_files' \
  '-C[change to directory]:dir:_files -/' \
  '*:file:_files' && ret=0
return ret
