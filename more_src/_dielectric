#compdef dielectric gmx-dielectric
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-dielectric.html
# gmx dielectric: calculate frequency dependent dielectric constants

local ret=1

_arguments -s \
  '-f[xvgr/xmgr file containing autocorrelation function]:file:_files' \
  '-d[derivative data output file]:file:_files' \
  '-o[frequency-dependent dielectric constant output]:file:_files' \
  '-c[Cole-Cole plot output file]:file:_files' \
  '-b[first frame time to read]:time:' \
  '-e[last frame time to read]:time:' \
  '-dt[frame sampling interval]:time:' \
  '-w[view output graphics files]' \
  '-xvg[plot format selection]:format:(xmgrace xmgr none)' \
  '-x1[use first column as x-axis]' \
  '-eint[integration end time]:real:' \
  '-bfit[fit start time]:real:' \
  '-efit[fit end time]:real:' \
  '-tail[total function length]:real:' \
  '-A[parameter A starting value]:real:' \
  '-tau1[parameter tau1 starting value]:real:' \
  '-tau2[parameter tau2 starting value]:real:' \
  '-eps0[liquid dielectric constant]:real:' \
  '-epsRF[reaction field epsilon]:real:' \
  '-fix[fix parameters during fitting]:int:' \
  '-ffn[fit function type]:fn:(none exp aexp exp_exp exp5 exp7 exp9)' \
  '-nsmooth[smoothing point count]:int:' && ret=0

return ret
