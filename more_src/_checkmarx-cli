#compdef checkmarx-cli cx cxone-cli cxcli
# _checkmarx-cli — Checkmarx checkmarx-cli CLI command-line frontend wrapping the Checkmarx One CxOne SAST IAST DAST SCA application security testing platform supporting project scan management policy results triage report API-key OIDC OAuth2 SCA-vulnerability-management dependency-graph license-risk-supply-chain-attack (Checkmarx team, Go); cobra
# upstream: https://checkmarx.com/

_checkmarx-cli() {
    local -a sub=(
        'auth:authenticate'
        'configure:configure'
        'project:project operations'
        'scan:scan operations'
        'result:result operations'
        'triage:triage operations'
        'policy:policy operations'
        'analytics:analytics operations'
        'logs:fetch logs'
        'codebashing:CodeBashing references'
        'tenant:tenant operations'
        'risk-management:risk management'
        'application:application management'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--base-uri=+[url]:str:' \
        '--base-auth-uri=+[url]:str:' \
        '--client-id=+[id]:str:' \
        '--client-secret=+[secret]:str:' \
        '--apikey=+[key]:str:' \
        '--tenant=+[name]:str:' \
        '--proxy=+[url]:str:' \
        '--insecure[skip TLS verify]' \
        '--profile=+[name]:str:' \
        '-f+[format]:f:(json yaml table csv sarif html pdf)' \
        '--format=+[format]:f:(json yaml table csv sarif html pdf)' \
        '-o+[output file]:file:_files' \
        '--output-name=+[file]:file:_files' \
        '--output-path=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'checkmarx-cli subcommand' sub ;;
        args)
            case $words[1] in
                project|scan|result|triage|policy|tenant|application|risk-management) _arguments '1:op:(list show create update delete cancel kpi tags)' '*:id:' ;;
            esac
            ;;
    esac
}

_checkmarx-cli "$@"
