#compdef eigenstrat
# Documentation: https://github.com/DReichLab/EIG/blob/master/EIGENSTRAT/README
# EIGENSOFT eigenstrat: PCA-based stratification correction for association

local ret=1

_arguments -s -S \
  '-i[input genotype file]:file:_files' \
  '-j[input phenotype file]:file:_files' \
  '-p[input PCA file]:file:_files' \
  '-l[number of principal components to correct]:num' \
  '-o[output chisq statistics file]:file:_files' && ret=0

return ret
