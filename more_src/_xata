#compdef xata

# Zsh completion for Xata CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'auth:Manage authentication'
      'init:Initialize a Xata project'
      'schema:Manage database schema'
      'dbs:Manage databases'
      'branches:Manage branches'
      'codegen:Generate code from schema'
      'pull:Pull schema from remote'
      'push:Push schema to remote'
      'browse:Open the Xata web UI'
      'random-data:Generate random data'
      'shell:Open an interactive shell'
    )
    _describe -t commands 'xata command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      auth)
        local -a subcmds=(
          'login:Log in to Xata'
          'logout:Log out of Xata'
          'status:Show auth status'
        )
        if (( CURRENT == 2 )); then
          _describe -t subcmds 'auth subcommand' subcmds && ret=0
        fi
        ;;
      init)
        _arguments -s -S \
          '--db=[database URL]:database url' \
          '--schema=[schema file]:schema file:_files' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      schema)
        local -a subcmds=(
          'edit:Edit the schema interactively'
          'upload:Upload a schema file'
          'dump:Dump the current schema'
        )
        if (( CURRENT == 2 )); then
          _describe -t subcmds 'schema subcommand' subcmds && ret=0
        fi
        ;;
      dbs)
        local -a subcmds=(
          'list:List databases'
          'create:Create a database'
          'delete:Delete a database'
        )
        if (( CURRENT == 2 )); then
          _describe -t subcmds 'dbs subcommand' subcmds && ret=0
        fi
        ;;
      branches)
        local -a subcmds=(
          'list:List branches'
          'create:Create a branch'
          'delete:Delete a branch'
        )
        if (( CURRENT == 2 )); then
          _describe -t subcmds 'branches subcommand' subcmds && ret=0
        fi
        ;;
      codegen)
        _arguments -s -S \
          '--output=[output file]:output file:_files' \
          '--language=[output language]:language:(typescript javascript)' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
