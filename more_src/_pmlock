#compdef pmlock
# _pmlock — acquire an exclusive lock file (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pmlock/pmlock.c (pmgetopt opts).

_pmlock() {
    _arguments \
        '(- *)-?[show help]' \
        '(-i --ident)'{-i+,--ident=}'[identifier to write into lock file]:ident:' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '1:lock file:_files'
}

_pmlock "$@"
