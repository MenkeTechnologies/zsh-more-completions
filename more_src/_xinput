#compdef xinput
# _xinput — XInput utility (configure/test XInput devices: list, query state, enable/disable, list-props, set/get/delete prop, map to monitor, float/reattach to master, watch-props event stream)
# upstream: https://gitlab.freedesktop.org/xorg/app/xinput
# Subcommands from xinput list-devices output + xinput.man on tip.

_xinput() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'xinput command' \
                '(list:list devices list-props:list properties get-feedbacks:show feedbacks set-pointer:set core pointer test:test events query-state:query device state enable:enable device disable:disable device set-button-map:remap buttons set-prop:set property get-prop:get property delete-prop:delete property watch-props:watch property changes map-to-output:map device to a monitor list-barriers:list pointer barriers float:detach to floating reattach:reattach slave to master create-master:create new master device remove-master:remove a master)'
            ;;
        args)
            _arguments '*:device:'
            ;;
    esac
}

_xinput "$@"
