#compdef mkdist
# Documentation: https://github.com/unjs/mkdist
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--src=[source directory]:source directory:_directories' \
  '--dist=[output directory]:output directory:_directories' \
  '--format=[output format]:format:(cjs esm)' \
  '--ext=[output file extension]:extension:(js mjs ts)' \
  '*--pattern=[file glob pattern]:pattern' \
  '(-d --declaration)'{-d,--declaration}'[generate TypeScript declarations]' \
  '--no-clean[do not clean output directory before build]' \
  '1::root directory:_directories' && ret=0

return ret
