#compdef mkdist

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--src=[source directory]:source directory:_directories' \
  '--dist=[output directory]:output directory:_directories' \
  '--format=[output format]:format:(cjs esm)' \
  '--ext=[output file extension]:extension:(js mjs cjs)' \
  '--pattern=[file glob pattern]:pattern' \
  '--declaration[generate TypeScript declarations]' \
  '--clean[clean output directory before build]' \
  '--loaders=[custom loaders configuration]:loaders' && ret=0

return ret
