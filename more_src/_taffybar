#compdef taffybar
# Documentation: https://github.com/taffybar/taffybar/blob/master/app/Main.hs
# Reference accessed: 2026-05-27
# Verified: upstream Main.hs optionParser/startupModeP (taffybar/taffybar).

# Zsh completion for taffybar - a gtk+3 system info bar for xmonad/Wayland.

local curcontext="$curcontext" state line ret=1

local -a _taffybar_subcommands
_taffybar_subcommands=(
  'auto:use config autodetection (default)'
  'dyre:run dyre with ~/.config/taffybar/taffybar.hs'
  'example:run built-in example configuration'
  'dhall:run ~/.config/taffybar/taffybar.dhall'
)

local -a _taffybar_log_levels
_taffybar_log_levels=(
  'DEBUG:debug messages'
  'INFO:informational messages'
  'NOTICE:notice level'
  'WARNING:warning level (default)'
  'ERROR:error level'
  'CRITICAL:critical level'
  'ALERT:alert level'
  'EMERGENCY:emergency level'
)

_arguments -C \
  '(-l --log-level)'{-l+,--log-level=}'[set the log level]:level:(($_taffybar_log_levels))' \
  '(- *)--version[show the version number of taffybar]' \
  '(- *)'{-h,--help}'[show help and exit]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'taffybar startup mode' _taffybar_subcommands && ret=0
    ;;
  args)
    _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
    ;;
esac

return ret
