#compdef smokeping
# Documentation: https://oss.oetiker.ch/smokeping/doc/smokeping.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '--man=[show manpage]:probe:' \
  '--help[show help]' \
  '--email[email DYNAMIC targets]' \
  '--config=[config file]:file:_files' \
  '--check[verify config]' \
  '--makepod=[generate POD docs]:probe:' \
  '--version[show version]' \
  '--debug[run once, no fork]' \
  '--debug-daemon[debug daemon]' \
  '--restart[restart]' \
  '--reload[reload config]' \
  '--nodaemon[no fork]' \
  '*--filter=[regex filter]:regex:' \
  '--logfile=[log file]:file:_files' \
  '--static=[static site dir]:dir:_files -/' \
  '--nosleep[debug no sleep]' \
  '--gen-examples[generate examples]' \
  '--master-url=[master URL]:url:' \
  '--shared-secret=[secret file]:file:_files' \
  '--cache-dir=[cache dir]:dir:_files -/'
