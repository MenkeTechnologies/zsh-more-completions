#compdef cargo-cross cross

# Zsh completion for cross - cross-compilation tool for Rust

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:compile the current package'
  'check:analyze the current package and report errors'
  'test:run the tests'
  'bench:run the benchmarks'
  'run:run a binary or example'
  'clean:remove artifacts that cross has generated'
  'clippy:run clippy'
  'doc:build documentation'
  'rustc:compile a package and all of its dependencies'
  'rustdoc:build documentation with rustdoc flags'
  'fmt:run cargo fmt'
  'metadata:output the resolved dependencies of a package'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cross command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (build|check|test|bench|run|clippy|doc|rustc|rustdoc)
        _arguments -s -S \
          '--target=[target triple]:target' \
          '(-p --package)'{-p,--package}'[package to build]:package' \
          '--lib[build only this package library]' \
          '--bin=[build only the specified binary]:binary' \
          '--bins[build all binaries]' \
          '--example=[build only the specified example]:example' \
          '--examples[build all examples]' \
          '--test=[build only the specified test target]:test' \
          '--tests[build all tests]' \
          '--bench=[build only the specified bench target]:bench' \
          '--benches[build all benches]' \
          '--all-targets[build all targets]' \
          '--features=[space or comma separated list of features]:features' \
          '--all-features[activate all available features]' \
          '--no-default-features[do not activate the default feature]' \
          '(-r --release)'{-r,--release}'[build in release mode]' \
          '--profile=[build with specified profile]:profile' \
          '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs' \
          '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
          '--target-dir=[directory for build artifacts]:directory:_files -/' \
          '(-v --verbose)'{-v,--verbose}'[use verbose output]' \
          '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
          '--color=[when to use color]:when:(auto always never)' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:extra arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
