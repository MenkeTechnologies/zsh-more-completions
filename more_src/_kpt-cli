#compdef kpt
# Documentation: https://kpt.dev/reference/cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Removed invented
# subcommands (pkg get-kptfile, fn export, live preview /
# fetch-k8s-schema, alpha repo/rpkg) and unverifiable global
# flags (--http-cache, --no-prompt, --truncate-output). Only
# --allow-exec and --stack-trace are documented global flags.
# Subcommand sets per kpt.dev/reference/cli/{pkg,fn,live,alpha}.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'pkg:get, update, and describe packages with resources'
  'fn:generate, transform, validate packages using functions'
  'live:deploy local configuration packages to a cluster'
  'alpha:commands currently in alpha'
  'completion:generate shell completion script'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '--allow-exec[allow executable binaries to run as functions]' \
  '--stack-trace[print a stack-trace on failure]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kpt command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (pkg)
        _arguments \
          '1:subcommand:(cat diff get init tree update)' \
          '*: :_files' && ret=0 ;;
      (fn)
        _arguments \
          '1:subcommand:(doc eval render sink source)' \
          '*: :_files' && ret=0 ;;
      (live)
        _arguments \
          '1:subcommand:(apply destroy init install-resource-group migrate status)' \
          '*: :_files -/' && ret=0 ;;
      (alpha)
        _arguments '1:subcommand:(license live sync wasm)' '*: :_files' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
