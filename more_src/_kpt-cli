#compdef kpt
# Documentation: https://man.archlinux.org/search?q=kpt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'pkg:package management'
  'fn:function commands'
  'live:live cluster operations'
  'alpha:alpha commands'
  'completion:generate shell completions'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*--allow-exec[allow exec runtime]' \
  '*--http-cache=[http cache dir]:dir:_files -/' \
  '*--no-prompt[no prompt]' \
  '*--stack-trace[stack trace]' \
  '*--truncate-output=[truncate]:b:(true false)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kpt command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (pkg)
        _arguments \
          '1:subcommand:(get update init cat tree diff get-kptfile help)' \
          '*: :_files' && ret=0 ;;
      (fn)
        _arguments \
          '1:subcommand:(eval render export source sink doc help)' \
          '*: :_files' && ret=0 ;;
      (live)
        _arguments \
          '1:subcommand:(init apply destroy preview status migrate fetch-k8s-schema install-resource-group help)' \
          '*: :_files -/' && ret=0 ;;
      (alpha)
        _arguments '1:subcommand:(license repo rpkg sync wasm)' '*: :_files' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
