#compdef courierimap courier-imap courierimapd
# Documentation: https://man.archlinux.org/search?q=courierimap
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start daemon'
  'stop:stop daemon'
  'restart:restart daemon'
  'reload:reload configuration'
  'status:show status'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'courierimap command' commands && ret=0 ;;
esac

return ret
