#compdef surelan
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/velocity_analysis/surelan.c
# Residual-moveout semblance (velocity) analysis of SU data

local ret=1

_arguments -s -S \
  'nr=[number of r-parameter samples]:nr' \
  'dr=[r-parameter sampling interval]:dr' \
  'fr=[first value of r-parameter]:fr' \
  'smute=[samples with RMO stretch exceeding smute are zeroed]:smute' \
  'dzratio=[ratio of output to input depth sampling intervals]:dzratio' \
  'nsmooth=[length of semblance num and den smoothing window]:nsmooth' \
  'verbose=[1 for diagnostic print on stderr]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
