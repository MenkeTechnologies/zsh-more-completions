#compdef gnulib-tool
# Documentation: https://www.gnu.org/software/gnulib/manual/html_node/Invoking-gnulib_002dtool.html
# Import Gnulib modules into a package (authors/maintainers)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--list[print the available module names]' \
  '--find[find the modules which contain the specified file]' \
  '--import[import the given modules into the current package]' \
  '--add-import[augment the list of imports]' \
  '--remove-import[reduce the list of imports]' \
  '--update[update the current package from the imported modules]' \
  '--create-testdir[create a scratch package with the given modules]' \
  '--create-megatestdir[create a mega scratch package with all modules]' \
  '--test[test the given modules]' \
  '--megatest[test all modules]' \
  '--extract-description[extract the description of a module]' \
  '--extract-filelist[extract the list of files of a module]' \
  '--extract-dependencies[extract the dependencies of a module]' \
  '--extract-autoconf-snippet[extract the autoconf snippet of a module]' \
  '--extract-automake-snippet[extract the automake snippet of a module]' \
  '--extract-include-directive[extract the include directives of a module]' \
  '--extract-license[extract the license of a module]' \
  '--extract-maintainer[extract the maintainer of a module]' \
  '--extract-tests-module[extract the tests module of a module]' \
  '--dir=[specify the target directory]:directory:_files -/' \
  '--lib=[use the given library name (default libgnu)]:library:' \
  '--source-base=[directory relative to dir for source code]:directory:_files -/' \
  '--m4-base=[directory relative to dir for autoconf macros]:directory:_files -/' \
  '--tests-base=[directory relative to dir for unit tests]:directory:_files -/' \
  '--aux-dir=[directory relative to dir for auxiliary build tools]:directory:_files -/' \
  '--with-tests[include unit tests for the included modules]' \
  '*--avoid=[avoid including the given module]:module:' \
  '--lgpl[abort if modules are not available under the LGPL]' \
  '--libtool[use libtool rules]' \
  '--macro-prefix=[specify the prefix of the macros gl_EARLY and gl_INIT]:prefix:' \
  '--no-changelog[do not update or create ChangeLog files]' \
  '--dry-run[only print actions, do not perform them]' \
  '(-s --symbolic --symlink)'{-s,--symbolic,--symlink}'[make symbolic links instead of copying files]' \
  '*:module:' && ret=0

return ret
