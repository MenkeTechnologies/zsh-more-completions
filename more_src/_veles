autoload -U is-at-least

_veles() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_veles_commands" \
"*::: :->veles" \
&& ret=0
    case $state in
    (veles)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:veles-command-$line[1]:"
        case $line[1] in
            (search)
_arguments "${_arguments_options[@]}" : \
'-t+[Number of results]:TOP_K:_default' \
'--top-k=[Number of results]:TOP_K:_default' \
'-m+[Search mode]:MODE:_default' \
'--mode=[Search mode]:MODE:_default' \
'-f+[Output format\: pretty (default), compact, ripgrep, paths, json, jsonl]:FORMAT:_default' \
'--format=[Output format\: pretty (default), compact, ripgrep, paths, json, jsonl]:FORMAT:_default' \
'*-l+[Restrict to specific languages (comma-separated, e.g. \`rust,python\`)]:LANG:_default' \
'*--lang=[Restrict to specific languages (comma-separated, e.g. \`rust,python\`)]:LANG:_default' \
'*-g+[Glob pattern of paths to include (repeatable, e.g. \`--path '\''src/**/*.rs'\''\`)]:GLOB:_default' \
'*--path=[Glob pattern of paths to include (repeatable, e.g. \`--path '\''src/**/*.rs'\''\`)]:GLOB:_default' \
'*-x+[Glob pattern of paths to exclude (repeatable, e.g. \`--exclude '\''tests/**'\''\`)]:GLOB:_default' \
'*--exclude=[Glob pattern of paths to exclude (repeatable, e.g. \`--exclude '\''tests/**'\''\`)]:GLOB:_default' \
'--min-score=[Drop results scoring below this threshold]:MIN_SCORE:_default' \
'--include-text-files[Also index non-code text files]' \
'--multilingual[Use the multilingual embedding model (potion-multilingual-128M) instead of the default English/code-focused model. Recommended for codebases or queries containing Cyrillic, CJK, Greek, Arabic, etc]' \
'--no-cache[Force a fresh in-memory build, ignoring any \`.veles/\` cache]' \
'-h[Print help]' \
'--help[Print help]' \
':query -- Natural language or code query:_default' \
'::path -- Local path or git URL (default\: current directory):_default' \
&& ret=0
;;
(find-related)
_arguments "${_arguments_options[@]}" : \
'-t+[Number of similar chunks to return]:TOP_K:_default' \
'--top-k=[Number of similar chunks to return]:TOP_K:_default' \
'-f+[Output format\: pretty (default), compact, ripgrep, paths, json, jsonl]:FORMAT:_default' \
'--format=[Output format\: pretty (default), compact, ripgrep, paths, json, jsonl]:FORMAT:_default' \
'*-l+[Restrict results to these languages (repeatable, e.g. \`-l rust -l python\`). Overrides the default of "same language as the source chunk"]:LANG:_default' \
'*--lang=[Restrict results to these languages (repeatable, e.g. \`-l rust -l python\`). Overrides the default of "same language as the source chunk"]:LANG:_default' \
'*-g+[Glob pattern of paths to include (repeatable, e.g. \`--path '\''src/**/*.rs'\''\`)]:GLOB:_default' \
'*--path=[Glob pattern of paths to include (repeatable, e.g. \`--path '\''src/**/*.rs'\''\`)]:GLOB:_default' \
'*-x+[Glob pattern of paths to exclude (repeatable, e.g. \`--exclude '\''tests/**'\''\`)]:GLOB:_default' \
'*--exclude=[Glob pattern of paths to exclude (repeatable, e.g. \`--exclude '\''tests/**'\''\`)]:GLOB:_default' \
'--min-score=[Drop results scoring below this threshold]:MIN_SCORE:_default' \
'--include-text-files[Also index non-code text files]' \
'--multilingual[Use the multilingual embedding model]' \
'--no-cache[Force a fresh in-memory build, ignoring any \`.veles/\` cache]' \
'-h[Print help]' \
'--help[Print help]' \
':file_path -- File path as shown in search results:_default' \
':line -- Line number (1-indexed):_default' \
'::path -- Local path or git URL (default\: current directory):_default' \
&& ret=0
;;
(index)
_arguments "${_arguments_options[@]}" : \
'--include-text-files[Also index non-code text files]' \
'--multilingual[Use the multilingual embedding model]' \
'--force[Rebuild from scratch even if a \`.veles/\` cache already exists]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Local path to index (default\: current directory):_default' \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
'--multilingual[Use the multilingual embedding model (must match how it was built)]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Local path of the indexed repo (default\: current directory):_default' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Local path of the indexed repo (default\: current directory):_default' \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Local path of the indexed repo (default\: current directory):_default' \
&& ret=0
;;
(serve-grpc)
_arguments "${_arguments_options[@]}" : \
'-a+[Address to bind to]:ADDR:_default' \
'--addr=[Address to bind to]:ADDR:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(serve-mcp)
_arguments "${_arguments_options[@]}" : \
'--include-text-files[Also index non-code text files]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Optional local path to pre-index at startup:_default' \
&& ret=0
;;
(symbols)
_arguments "${_arguments_options[@]}" : \
'-f+[Output format\: pretty (default), compact, paths, json, jsonl]:FORMAT:_default' \
'--format=[Output format\: pretty (default), compact, paths, json, jsonl]:FORMAT:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':file -- File to outline:_default' \
&& ret=0
;;
(defs)
_arguments "${_arguments_options[@]}" : \
'*-l+[Restrict to specific languages (comma-separated)]:LANG:_default' \
'*--lang=[Restrict to specific languages (comma-separated)]:LANG:_default' \
'-k+[Restrict to a kind (function, struct, class, enum, trait, interface, type, const, static, var, module, method, macro)]:KIND:_default' \
'--kind=[Restrict to a kind (function, struct, class, enum, trait, interface, type, const, static, var, module, method, macro)]:KIND:_default' \
'-f+[Output format\: pretty (default), compact, paths, json, jsonl]:FORMAT:_default' \
'--format=[Output format\: pretty (default), compact, paths, json, jsonl]:FORMAT:_default' \
'--multilingual[Use the multilingual embedding model (must match how the index was built)]' \
'-h[Print help]' \
'--help[Print help]' \
':name -- Symbol name to look up (exact match):_default' \
'::path -- Local path of the indexed repo (default\: current directory):_default' \
&& ret=0
;;
(refs)
_arguments "${_arguments_options[@]}" : \
'-t+[Number of BM25 hits to include alongside definitions]:TOP_K:_default' \
'--top-k=[Number of BM25 hits to include alongside definitions]:TOP_K:_default' \
'-f+[Output format\: pretty (default), compact, ripgrep, paths, json, jsonl]:FORMAT:_default' \
'--format=[Output format\: pretty (default), compact, ripgrep, paths, json, jsonl]:FORMAT:_default' \
'--multilingual[Use the multilingual embedding model]' \
'-h[Print help]' \
'--help[Print help]' \
':name -- Symbol name to search for:_default' \
'::path -- Local path of the indexed repo (default\: current directory):_default' \
&& ret=0
;;
(tui)
_arguments "${_arguments_options[@]}" : \
'--multilingual[Use the multilingual embedding model (must match how the index was built)]' \
'--include-text-files[Also index non-code text files when building the index from scratch]' \
'--no-cache[Force a fresh in-memory build, ignoring any \`.veles/\` cache]' \
'--debug-keys[Echo every keypress to the status bar so you can verify which modifier/key codes your terminal actually forwards. Useful on macOS where Alt-* and F-keys often need explicit configuration]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::path -- Local path of the indexed repo (default\: current directory):_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- Target shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(man)
_arguments "${_arguments_options[@]}" : \
'--out-dir=[Write a \`veles.1\` plus one \`veles-<sub>.1\` per subcommand into this directory. The directory is created if needed]:DIR:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_veles__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:veles-help-command-$line[1]:"
        case $line[1] in
            (search)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(find-related)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(index)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(serve-grpc)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(serve-mcp)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(symbols)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(defs)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(refs)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(tui)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(man)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_veles_commands] )) ||
_veles_commands() {
    local commands; commands=(
'search:Search a codebase with a natural-language or code query' \
'find-related:Find code similar to a specific location' \
'index:Build the index and persist it to \`<path>/.veles/\`' \
'update:Incrementally update an existing index for files that changed on disk' \
'status:Show stats about the persisted index at \`<path>/.veles/\`' \
'clean:Remove the persisted index at \`<path>/.veles/\`' \
'serve-grpc:Start a gRPC server' \
'serve-mcp:Start an MCP server over stdio' \
'symbols:List definitions in a single file (functions, structs, classes, ...)' \
'defs:Find every definition with the given name across the indexed repo' \
'refs:Find references to a symbol — its definitions plus BM25 hits in chunks' \
'tui:Launch the interactive terminal UI for live hybrid search' \
'completions:Print a shell completion script to stdout' \
'man:Generate roff(7) man pages' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'veles commands' commands "$@"
}
