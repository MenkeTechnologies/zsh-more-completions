#compdef kubesess

# Zsh completion for kubesess (per-shell kubeconfig sessions)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'default:set default kubeconfig for this shell session'
      'switch:list or change kubeconfig directory'
      'clear:clear session default kubeconfig'
    )
    _describe -t commands 'kubesess command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
