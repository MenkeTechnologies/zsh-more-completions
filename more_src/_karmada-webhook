#compdef karmada-webhook
# Documentation: https://karmada.io/docs/reference/components/karmada-webhook/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Removed invented
# --karmada-kubeconfig/--leader-elect*/--master/--tls-cert-file/
# --tls-private-key-file/--logtostderr; real flags use --cert-dir +
# --tls-cert-file-name/--tls-private-key-file-name.

# karmada-webhook: Karmada admission webhook server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--kubeconfig=[path to karmada control plane kubeconfig file]:file:_files' \
  '--bind-address=[IP address to listen for the --secure-port]:addr:' \
  '--secure-port=[secure port on which to serve HTTPS]:port:' \
  '--cert-dir=[directory that contains the server key and certificate]:dir:_files -/' \
  '--tls-cert-file-name=[name of server certificate]:name:' \
  '--tls-private-key-file-name=[name of server key]:name:' \
  '--metrics-bind-address=[metrics bind address]:addr:' \
  '--health-probe-bind-address=[health probe bind address]:addr:' \
  '--feature-gates=[feature gates]:gates:' \
  '--v=[log level]:n:' \
  '*::karmada-webhook args:_files' && ret=0
return ret
