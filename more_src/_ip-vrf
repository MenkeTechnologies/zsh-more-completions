#compdef ip-vrf
# Documentation: https://man.archlinux.org/man/ip-vrf.8.en
# ip vrf - run command against VRF or report association

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip vrf command' \
      'exec[run command against named VRF]' \
      'identify[report VRF association for process]' \
      'pids[report processes associated with VRF]' \
      'show[show all configured VRF]' && ret=0
    ;;
esac

return ret
