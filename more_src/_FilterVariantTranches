#compdef FilterVariantTranches
# Documentation: https://gatk.broadinstitute.org/hc/en-us/articles/360037226672-FilterVariantTranches
# Apply tranche filtering based on a truth VCF and a score from a VCF INFO field

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --variant)'{-V,--variant}'=[input VCF to filter]:vcf:_files' \
  '(-o --output)'{-o,--output}'=[output VCF file]:output:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '*--snp-tranche=[sensitivity level(s) to SNPs at which to filter (percent)]:level:' \
  '*--indel-tranche=[sensitivity level(s) to indels at which to filter (percent)]:level:' \
  '*--resource=[validated VCF with known sites of common variation]:vcf:_files' \
  '--info-key=[INFO field key holding the score]:key:' \
  '--invalidate-previous-filters[remove all filters already present in the VCF]' \
  '*'{-L,--intervals}'=[genomic intervals to operate over]:intervals:' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:vcf:_files' && ret=0

return ret
