#compdef exeinfo
# _libexe — libyal Windows MZ/PE executable parser; prints DOS+PE headers, section table, import/export directories, resource directory
# upstream: https://github.com/libyal/libexe

_libexe() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-X[exclusive]' \
        '*:PE file:_files -g "*.(exe|dll|sys|ocx|scr|cpl|drv)"'
}

_libexe "$@"
