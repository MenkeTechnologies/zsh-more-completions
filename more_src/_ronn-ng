#compdef ronn-ng
# Documentation: https://github.com/apjanke/ronn-ng/blob/master/man/ronn.1.ronn
# ronn-ng - build manuals from Markdown (the ronn command)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --man)'{-m,--man}'[display files using man(1)]' \
  '(-S --server)'{-S,--server}'[serve dynamically generated HTML over HTTP]' \
  '--port=[server port (default 1207)]:port:' \
  '--pipe[write output to stdout]' \
  '(-o --output-dir)'{-o+,--output-dir=}'[direct generated files to directory]:dir:_files -/' \
  '(-E --encoding)'{-E+,--encoding=}'[input file encoding (default UTF-8)]:encoding:' \
  '(-r --roff)'{-r,--roff}'[generate roff output]' \
  '(-5 --html)'{-5,--html}'[generate HTML output]' \
  '(-f --fragment)'{-f,--fragment}'[generate HTML fragment without header/footer]' \
  '--manual=[manual name shown in header]:manual:' \
  '--organization=[organization name shown in footer]:org:' \
  '--date=[publication date (YYYY-MM-DD)]:date:' \
  '--style=[apply CSS style modules]:modules:' \
  '(-w --warnings)'{-w,--warnings}'[show troff conversion warnings]' \
  '-W[disable troff warnings]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '*:file:_files' && ret=0

return ret
