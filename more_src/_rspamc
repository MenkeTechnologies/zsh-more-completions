#compdef rspamc

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'symbols:scan and show symbols'
  'learn_spam:train Bayes as spam'
  'learn_ham:train Bayes as ham'
  'fuzzy_add:add fuzzy hash'
  'fuzzy_del:remove fuzzy hash'
  'stat:show stats'
  'stat_reset:reset stats'
  'counters:symbol statistics'
  'uptime:show uptime'
  'add_symbol:add symbol dynamically'
  'add_action:add action dynamically'
)

_arguments -C \
  '(-h --connect)'{-h,--connect=}'[server host:port]:host:_hosts' \
  '(-P --password)'{-P,--password=}'[password or path]:pw:' \
  '(-c --classifier)'{-c,--classifier=}'[classifier]:name:' \
  '(-w --weight)'{-w,--weight=}'[fuzzy weight]:n:' \
  '(-f --flag)'{-f,--flag=}'[fuzzy flag]:n:' \
  '(-p --pass)'{-p,--pass}'[pass all filters]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-i --ip)'{-i,--ip=}'[emulate source IP]:ip:' \
  '(-u --user)'{-u,--user=}'[emulate authed user]:user:' \
  '(-d --deliver)'{-d,--deliver=}'[deliver address]:addr:' \
  '(-F --from)'{-F,--from=}'[envelope from]:addr:' \
  '(-r --rcpt)'{-r,--rcpt=}'[envelope rcpt]:addr:' \
  '--helo=[HELO string]:str:' \
  '--hostname=[hostname]:name:' \
  '(-t --timeout)'{-t,--timeout=}'[timeout secs]:secs:' \
  '(-b --bind)'{-b,--bind=}'[bind host:port]:bind:' \
  '(-R --human)'{-R,--human}'[human-readable report]' \
  '(-j --json)'{-j,--json}'[JSON output]' \
  '--ucl[UCL output]' \
  '--raw[raw output]' \
  '--headers[show headers]' \
  '--extended-urls[extended URL info]' \
  '(-n --max-requests)'{-n,--max-requests=}'[max parallel requests]:n:' \
  '(-e --execute)'{-e,--execute=}'[execute command]:cmd:' \
  '--mime[MIME wrap output]' \
  '*--header=[header name=value]:hdr:' \
  '--sort=[sort criterion]:criterion:(name weight frequency hits name:asc weight:asc frequency:asc hits:asc)' \
  '--commands[list commands]' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rspamc command' subcommands && ret=0
    ;;
  (args)
    _arguments '*:input:_files' && ret=0
    ;;
esac

return ret
