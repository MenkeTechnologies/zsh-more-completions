#compdef ch-mount
# Documentation: https://manpages.debian.org/testing/charliecloud-runtime/ch-mount.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ch-mount: mount a Charliecloud SquashFS image
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '--version[show version]' \
  '1:squashfs image:_files -g "*.(sqfs|squashfs|sif)"' \
  '2:mount point:_files -/' && ret=0
return ret
