#compdef ebook-meta

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-t+[set title]:title' \
  '--title=[set title]:title' \
  '-a+[set authors]:authors' \
  '--authors=[set authors]:authors' \
  '--author-sort=[set author sort]:string' \
  '--title-sort=[set title sort]:string' \
  '-c+[set comments]:comments' \
  '--comments=[set comments]:comments' \
  '-p+[set publisher]:publisher' \
  '--publisher=[set publisher]:publisher' \
  '-k+[set category]:category' \
  '--category=[set category]:category' \
  '-d+[set description]:description' \
  '--description=[set description]:description' \
  '-r+[set rating]:rating' \
  '--rating=[set rating]:rating' \
  '-s+[set series]:series' \
  '--series=[set series]:series' \
  '-i+[set series index]:index' \
  '--index=[set series index]:index' \
  '--isbn=[set ISBN]:isbn' \
  '--tags=[set tags]:tags' \
  '-l+[set language]:language' \
  '--language=[set language]:language' \
  '--date=[set publication date]:date' \
  '--cover=[set cover image]:file:_files' \
  '--get-cover=[extract cover to file]:file:_files' \
  '--to-opf=[output metadata as OPF]:file:_files' \
  '--from-opf=[read metadata from OPF]:file:_files' \
  '--lrf-bookid=[set LRF book ID]:id' \
  '1:ebook file:_files'
