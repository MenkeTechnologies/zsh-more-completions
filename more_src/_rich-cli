#compdef rich

# Zsh completion for Rich CLI - pretty print in terminal

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-p[use pager for output]' \
  '--pager[use pager for output]' \
  '-n[show line numbers]' \
  '--line-numbers[show line numbers]' \
  '-g+[highlight lines]:lines' \
  '--guides[show indent guides]' \
  '-l+[lexer to use for syntax highlighting]:lexer' \
  '--lexer=[lexer to use for syntax highlighting]:lexer' \
  '-y[render syntax highlighting for the file]' \
  '--syntax[render syntax highlighting for the file]' \
  '-m[render Markdown]' \
  '--markdown[render Markdown]' \
  '-j[render JSON]' \
  '--json[render JSON]' \
  '--csv[render CSV as a table]' \
  '--rst[render reStructuredText]' \
  '-r[render Rich markup]' \
  '--rule[draw a horizontal rule]' \
  '-t+[set a title]:title' \
  '--text=[render text with style]:text' \
  '--text-left=[left-aligned text]:text' \
  '--text-center=[center-aligned text]:text' \
  '--text-right=[right-aligned text]:text' \
  '--text-full=[full-width text]:text' \
  '-s+[style for text]:style' \
  '--style=[style for text]:style' \
  '-e+[emoji code]:emoji' \
  '--emoji=[emoji code]:emoji' \
  '-w+[width of output]:width' \
  '--width=[width of output]:width' \
  '--force-terminal[force terminal output]' \
  '--no-wrap[disable wrapping]' \
  '--soft-wrap[enable soft wrapping]' \
  '--panel=[render in panel]:style:(none rounded heavy double ascii)' \
  '--theme=[syntax theme]:theme' \
  '--hyperlinks[render hyperlinks]' \
  '--no-hyperlinks[disable hyperlinks]' \
  '*:file:_files' && ret=0

return ret
