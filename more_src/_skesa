#compdef skesa
# Documentation: https://github.com/ncbi/SKESA
# strategic k-mer extension for scrupulous assemblies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[produce help message]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '--cores=[number of cores to use]:cores' \
  '--memory=[memory available in GB for sorted counter]:gb' \
  '--hash_count[use hash counter]' \
  '--estimated_kmers=[estimated distinct k-mers for bloom filter (millions)]:millions' \
  '--skip_bloom_filter[do not use bloom filter]' \
  '--reads=[input fasta/fastq file(s)]:file:_files' \
  '--use_paired_ends[single files contain interleaved paired reads]' \
  '--sra_run=[input SRA run accession]:accession' \
  '--contigs_out=[output file for contigs]:file:_files' \
  '--kmer=[minimal k-mer length for assembly]:len' \
  '--min_count=[minimal count for k-mers retained]:count' \
  '--max_kmer_count=[minimum average count for maximal k-mer estimation]:count' \
  '--vector_percent=[percentage threshold for vector detection]:percent' \
  '--insert_size=[expected insert size for paired reads]:size' \
  '--steps=[number of assembly iterations]:steps' \
  '--fraction=[maximum noise-to-signal ratio]:fraction' \
  '--max_snp_len=[maximal SNP length]:len' \
  '--min_contig=[minimal contig length for output]:len' \
  '--allow_snps[allow additional step for SNP discovery]' && ret=0

return ret
