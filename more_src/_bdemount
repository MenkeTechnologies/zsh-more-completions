#compdef bdemount
# Documentation: https://github.com/libyal/libbde
# Source: libyal/libbde manuals/bdemount.1 — FUSE-mount a BitLocker (BDE) volume as a raw block device.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-k[full volume encryption key + tweak key as base16 FVEK:TWEAK]:keys:' \
    '-o[volume offset in bytes]:offset:' \
    '-p[password]:password:' \
    '-r[recovery password]:recovery password:' \
    '-s[startup key file (.BEK)]:startup key:_files' \
    '-u[unattended (disable user interaction)]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '-X[extended options to pass to FUSE]:fuse opts:' \
    '*:image or volume then mountpoint:_files' \
    && ret=0

return ret
