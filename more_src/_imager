#compdef imager
# Documentation: https://man.archlinux.org/search?q=imager
# Reference accessed: 2026-05-16

# https://github.com/imager-io/imager — mozjpeg / webp / png optimizer

_arguments -s -S \
  '(-i --inputs)'{-i,--inputs}'*[input globs or files]:pattern:_files' \
  '(-o --output-file)'{-o,--output-file}'=[single output file]:file:_files' \
  '(-O --output-dir)'{-O,--output-dir}'=[directory for many outputs]:dir:_directories' \
  '--replace[overwrite inputs in place]' \
  '(-f --formats)'{-f,--formats}'*[output codecs]:format:(jpeg png webp)' \
  '--max-size=[max width/height WxH]:resolution:' \
  '--log-file=[internal debug log]:file:_files' \
  '--extreme[internal experimental mode]' && return 0
