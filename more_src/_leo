#compdef leo
# Documentation: https://github.com/ProvableHQ/leo/blob/master/crates/leo/src/cli/cli.rs
# Documentation: https://docs.leo-lang.org
# Reference accessed: 2026-05-27
# Verified: upstream crates/leo/src/cli/cli.rs Commands enum (clap derive).

# leo - statically-typed programming language for Aleo zero-knowledge applications

local curcontext="$curcontext" state line ret=1

local -a _leo_subcommands
_leo_subcommands=(
  'account:create a new Aleo account, sign and verify messages'
  'new:create a new Leo package in a new directory'
  'run:run a program with input variables'
  'r:run a program with input variables'
  'test:test a Leo program'
  't:test a Leo program'
  'execute:execute a program with input variables'
  'deploy:deploy a program'
  'devnet:run a local devnet'
  'devnode:run a local devnode'
  'query:query live data from the Aleo network'
  'build:compile the current package as a program'
  'b:compile the current package as a program'
  'abi:generate ABI from an Aleo bytecode file'
  'add:add a new on-chain or local dependency to the current package'
  'remove:remove a dependency from the current package'
  'clean:clean the output directory'
  'synthesize:synthesize individual keys'
  'update:update the Leo CLI'
  'upgrade:upgrade the program on a network'
)

local -a _leo_account_subs
_leo_account_subs=(
  'new:create a new Aleo account'
  'import:import an Aleo account from a private key'
  'sign:sign a message with an Aleo account'
  'verify:verify a signed message'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[show debug output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-essential output]' \
  '--non-interactive[disable interactive prompts]' \
  '--no-color[disable colored output]' \
  '--json[print JSON-formatted output where supported]' \
  '--home=[set Leo home directory]:dir:_directories' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'leo subcommand' _leo_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      account)
        _arguments \
          '1: :->accountsub' \
          '*:: :->rest' && ret=0
        case $state in
          accountsub) _describe -t commands 'account subcommand' _leo_account_subs && ret=0 ;;
          rest) _normal && ret=0 ;;
        esac
        ;;
      new)
        _arguments \
          '--network=[target network]:network:(mainnet testnet canary)' \
          '*:name:' && ret=0
        ;;
      run|r|execute)
        _arguments \
          '--endpoint=[network endpoint URL]:url:' \
          '--network=[target network]:network:(mainnet testnet canary)' \
          '--file=[input file]:file:_files' \
          '*:program-and-inputs:' && ret=0
        ;;
      deploy)
        _arguments \
          '--endpoint=[network endpoint URL]:url:' \
          '--network=[target network]:network:(mainnet testnet canary)' \
          '--private-key=[private key for signing]:key:' \
          '--priority-fee=[priority fee in microcredits]:fee:' \
          '--base-fee=[base fee in microcredits]:fee:' \
          '--broadcast[broadcast the transaction]' \
          '--dry-run[validate without broadcasting]' \
          '--yes[skip confirmation prompts]' \
          '*:program:' && ret=0
        ;;
      build|b)
        _arguments \
          '--offline[build without fetching dependencies]' \
          '--non-recursive[skip dependency builds]' \
          '--network=[target network]:network:(mainnet testnet canary)' && ret=0
        ;;
      add)
        _arguments \
          '--local=[local dependency path]:path:_directories' \
          '--network=[on-chain dependency network]:network:(mainnet testnet canary)' \
          '*:dependency:' && ret=0
        ;;
      remove)
        _arguments \
          '*:dependency:' && ret=0
        ;;
      query)
        _arguments \
          '--endpoint=[network endpoint URL]:url:' \
          '--network=[target network]:network:(mainnet testnet canary)' \
          '*:: :_normal' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
