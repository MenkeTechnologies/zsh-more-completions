#compdef weave-cli
# Documentation: https://www.npmjs.com/package/weave-cli
# Reference accessed: 2026-05-23
# Verified: npx weave-cli --help.

# Zsh completion for weave-cli - Fluxweave platform CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'weave command' \
      'login[login to platform]' \
      'verify-credentials[verify login status]' \
      'clear-credentials[clear stored credentials]' \
      'orgs[list attached orgs]' \
      'org-children[list child orgs]' \
      'tracker-list[list trackers]' \
      'tracker-detail[tracker details]' \
      'tracker-spec[process tracker spec file]' \
      'schema-list[list schemas]' \
      'schema-add[add or update schema]' \
      'layout-list[list layouts]' \
      'layout-spec[process layout spec file]' \
      'group-list[list groups]' \
      'group-spec[process group spec file]' \
      'label-list[list labels]' \
      'label-spec[process label spec file]' \
      'swimlane-list[list swimlanes]' \
      'swimlane-spec[process swimlane spec file]' \
      'channel-list[list channels]' \
      'channel-spec[process channel spec file]' \
      'invite-list[list invites]' \
      'invite-spec[process invite spec file]' \
      'script-list[list scripts]' \
      'script-spec[process script spec file]' && ret=0
    ;;
  args)
    case $line[1] in
      org-children|tracker-list|schema-list|layout-list|group-list|label-list|swimlane-list|channel-list|invite-list|script-list)
        _arguments ':org:' && ret=0
        ;;
      tracker-detail)
        _arguments ':org:' ':tracker id:' && ret=0
        ;;
      tracker-spec|schema-add|layout-spec|group-spec|label-spec|swimlane-spec|channel-spec|invite-spec|script-spec)
        _arguments ':org:' ':spec file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
