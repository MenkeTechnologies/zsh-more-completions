#compdef cargo-add

# Zsh completion for cargo-add (cargo add subcommand from cargo-edit)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '--dry-run[Do not actually write the manifest]' \
  '--no-default-features[Disable default features]' \
  '--default-features[Re-enable default features]' \
  '-F+[Space or comma separated list of features to activate]:features' \
  '--features=[Space or comma separated list of features to activate]:features' \
  '--optional[Mark the dependency as optional]' \
  '--no-optional[Mark the dependency as required]' \
  '--rename=[Rename the dependency]:name' \
  '--manifest-path=[Path to Cargo.toml]:file:_files' \
  '-p+[Package to modify]:package' \
  '--package=[Package to modify]:package' \
  '-q[Do not print cargo log messages]' \
  '--quiet[Do not print cargo log messages]' \
  '-v[Use verbose output]' \
  '--verbose[Use verbose output]' \
  '--color=[Coloring]:when:(auto always never)' \
  '--frozen[Require Cargo.lock and cache are up to date]' \
  '--locked[Require Cargo.lock is up to date]' \
  '--offline[Run without accessing the network]' \
  '--path=[Filesystem path to local crate to add]:path:_directories' \
  '--git=[Git repository location]:url' \
  '--branch=[Git branch to download the crate from]:branch' \
  '--tag=[Git tag to download the crate from]:tag' \
  '--rev=[Git reference to download the crate from]:rev' \
  '--registry=[Registry to use]:registry' \
  '--dev[Add as development dependency]' \
  '-D[Add as development dependency]' \
  '--build[Add as build dependency]' \
  '-B[Add as build dependency]' \
  '--target=[Add as dependency to the given target platform]:target' \
  '*:crate' && ret=0

return ret
