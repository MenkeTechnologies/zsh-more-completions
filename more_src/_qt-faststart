#compdef qt-faststart
# Documentation: https://man.archlinux.org/search?q=qt-faststart
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input file:_files -g "*.(mov|mp4|m4v|m4a)"' \
  '2:output file:_files -g "*.(mov|mp4|m4v|m4a)"' && ret=0

return ret
