#compdef bean-extract

_arguments -s \
  '(-e -f --existing --previous)'{-e,-f,--existing,--previous}'=[existing entries]:file:_files' \
  '(-r --reverse --descending)'{-r,--reverse,--descending}'[descending order]' \
  '*'{-d,--downloads}'=[downloads]:path:_files' \
  '1:config:_files -g "*.py"' \
  '*:downloads:_files'
