#compdef mpifxcorr
# Documentation: https://difx.readthedocs.io/en/latest/sources/difx_programs.html
# DiFX: the core MPI software correlator

local ret=1

_arguments -s -S \
  '-M[hostname of monitor data server (monHostname:[monSkip])]:monitor host' \
  '-r[start startSec seconds into job]:start sec' \
  '--vgoscomplex[flip sideband of all Complex VDIF stations]' \
  '*:input file:_files -g "*.input"' && ret=0

return ret
