#compdef jabref
# _jabref — JabRef Project jabref CLI Java cross-platform reference manager for BibTeX BibLaTeX with PDF metadata extraction Mendeley Endnote Zotero CSL Web of Science PubMed DOI ISBN ArXiv lookup HTTP fetch GROBID full-text annotated import groups citation key generation export-LaTeX (JabRef team, Java); cli11
# upstream: https://www.jabref.org/

_jabref() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[debug]:str:' \
        '--debug=+[debug]:str:' \
        '-i+[input file]:file:_files -g "*.bib *.ris *.enw *.copac *.xml *.csv *.json"' \
        '--import=+[file]:file:_files -g "*.bib *.ris *.enw *.copac *.xml *.csv *.json"' \
        '-ix+[input format]:str:' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '-x+[export format]:f:(bibtex bibtexml endnote html mods odf ris tablerefsabsbib tablerefs ovid yaml docbook5 csv json)' \
        '--exporters[list exporters]' \
        '-importers[list importers]' \
        '--importers[list importers]' \
        '--fetch=+[query]:str:' \
        '-p+[preference file]:file:_files' \
        '--preferences=+[file]:file:_files' \
        '--write-XMP-to-PDF=+[file]:file:_files -g "*.pdf"' \
        '--embed-bibtex-in-PDF=+[file]:file:_files -g "*.pdf"' \
        '--write-metadata-to-pdf=+[file]:file:_files -g "*.pdf"' \
        '--write-bibtexsentence-to-pdf=+[file]:file:_files -g "*.pdf"' \
        '-g+[file]:file:_files -g "*.bib"' \
        '--generate-bibtex-keys[generate bibtex keys]' \
        '--check-consistency=+[file]:file:_files -g "*.bib"' \
        '--check-integrity=+[file]:file:_files -g "*.bib"' \
        '--jumpToKey=+[citation key]:str:' \
        '-b[blank window]' \
        '--blank[blank window]' \
        '-n[no GUI]' \
        '--nogui[no GUI]' \
        '*:bib file:_files -g "*.bib"'
}

_jabref "$@"
