#compdef autom4te
# Documentation: autom4te --help (GNU Autoconf)
# Source: run GNU M4 on Autoconf inputs, manage freeze/cache.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-v,--verbose}'[verbosely report processing]' \
    {-d,--debug}'[do not remove temporary files]' \
    {-o+,--output=}'[output file (- for stdout)]:file:_files' \
    {-f,--force}'[do not rely on cached values]' \
    '*'{-W+,--warnings=}'[report warnings in CATEGORY]:category:(cross gnu obsolete override portability portability-recursive extra-portability syntax unsupported all none error)' \
    {-l+,--language=}'[set of M4 macros to use]:lang:(Autoconf Autotest M4sh M4sugar)' \
    {-C+,--cache=}'[preserve results in DIRECTORY]:dir:_files -/' \
    '--no-cache[disable the cache]' \
    {-m+,--mode=}'[output file mode (octal)]:mode:' \
    {-M,--melt}'[do not use M4 frozen files]' \
    {-F,--freeze}'[produce a frozen state file]' \
    '*-t+[trace MACRO calls]:macro:' \
    '*-p+[preselect MACRO for tracing]:macro:' \
    '*'{-B+,--prepend-include=}'[prepend directory to search path]:dir:_files -/' \
    '*'{-I+,--include=}'[append directory to search path]:dir:_files -/' \
    '*:file:_files -g "*.(m4|m4f|m4?)"' \
    && ret=0

return ret
