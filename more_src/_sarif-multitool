#compdef sarif-multitool
# Documentation: upstream docs/multitool-usage.md at github.com/microsoft/sarif-sdk
# Reference accessed: 2026-05-30
# microsoft/sarif-sdk Sarif.Multitool — .NET Global Tool for analyzing
# and manipulating SARIF (Static Analysis Results Interchange Format)
# files. Installed via `dotnet tool install --global Sarif.Multitool`,
# invoked as `sarif-multitool`. 19 documented verbs split across:
# primary log operations, event-log append flow, and utilities.
# Per-verb flag enumeration is sparse upstream; primary verb-list is
# transcribed, plus `convert --tool` enum (13 source-tool values).
# Common `--log` parameter options across many verbs: ForceOverwrite,
# Inline, PrettyPrint, Minify, Optimize.

local curcontext="$curcontext" state line ret=1
local -a _verbs
_verbs=(
  'absoluteuri:turn all relative URIs into absolute URIs'
  'apply-policy:apply policies from a SARIF log'
  'convert:convert a tool output log to SARIF format'
  'export-validation-config:export validation rule options to editable XML/JSON'
  'export-validation-rules:export validation rules metadata to SARIF/SonarQube XML'
  'file-work-items:send SARIF results to work-item tracking systems'
  'match-results-forward:identify New/Absent/Unchanged results across runs'
  'merge:merge multiple SARIF files into one'
  'page:extract a subset of results from SARIF'
  'query:find a matching subset of a SARIF file'
  'rebaseuri:rebase the URIs in one or more SARIF files'
  'rewrite:transform a SARIF file to a reformatted version'
  'suppress:suppress results from a SARIF file'
  'validate:validate a SARIF file against the schema + correctness rules'
  'emit-init-run:open an append-only event log seeded with a SARIF run JSON document'
  'add-result:append a fully-formed SARIF result object to an in-progress event log'
  'add-notification:append a fully-formed SARIF notification object to an in-progress event log'
  'add-invocation:append a fully-formed SARIF invocation object to an in-progress event log'
  'emit-finalize:replay a staged event log into a final SARIF file'
  'help:show usage information'
  'version:display version information'
)

local -a _log_opts
_log_opts=(ForceOverwrite Inline PrettyPrint Minify Optimize)

local -a _convert_tools
_convert_tools=(
  AndroidStudio ClangAnalyzer ClangTidy CppCheck ContrastSecurity
  Fortify FortifyFpr FxCop PREfast Pylint SemmleQL
  StaticDriverVerifier TSLint
)

_arguments -C -s -S \
  '(-): :->verb' \
  '(-)*:: :->verb_args' \
  && ret=0

case $state in
  verb)
    _describe -t commands 'sarif-multitool verb' _verbs && ret=0
    ;;
  verb_args)
    case $words[1] in
      convert)
        _arguments \
          '--tool=[source tool format]:tool:($_convert_tools)' \
          '(-o --output)-o+[output file]:file:_files' \
          '(-o --output)--output=[output file]:file:_files' \
          '--log=[log options (comma-separated)]:options:($_log_opts)' \
          '1:input file:_files' && ret=0
        ;;
      validate|absoluteuri|rebaseuri|rewrite|page|query|merge|suppress|apply-policy)
        _arguments \
          '(-o --output)-o+[output file]:file:_files' \
          '(-o --output)--output=[output file]:file:_files' \
          '--log=[log options (comma-separated)]:options:($_log_opts)' \
          '*:SARIF file:_files -g "*.sarif"' && ret=0
        ;;
      match-results-forward)
        _arguments \
          '*:SARIF file:_files -g "*.sarif"' && ret=0
        ;;
      file-work-items)
        _arguments \
          '*:SARIF file:_files -g "*.sarif"' && ret=0
        ;;
      export-validation-config|export-validation-rules)
        _arguments \
          '(-o --output)-o+[output file]:file:_files' \
          '(-o --output)--output=[output file]:file:_files' && ret=0
        ;;
      emit-init-run|add-result|add-notification|add-invocation|emit-finalize)
        _arguments \
          '1:event log file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
