#compdef graph2tree
# Documentation: https://github.com/OctoMap/octomap/blob/devel/octomap/src/graph2tree.cpp
# Convert an OctoMap scan graph into an octree (.bt/.ot)

local ret=1

_arguments -s -S \
  '-i[input scan graph file]:graph:_files -g "*.graph"' \
  '-o[output binary octree file]:bt:_files -g "*.bt"' \
  '-res[octree resolution in meters]:m' \
  '-m[maximum scan range]:m' \
  '-n[maximum number of scans to process]:n' \
  '-log[enable detailed log file with statistics]' \
  '-g[skip transformation, nodes already in global coordinates]' \
  '-compressML[apply maximum-likelihood compression after each scan]' \
  '-simple[use ray-by-ray insertion instead of optimized method]' \
  '-discretize[approximate raycasting on discretized coordinates]' \
  '-clamping[override sensor model clamping probabilities]:p_min p_max' \
  '-sensor[override sensor model hit/miss probabilities]:p_miss p_hit' && ret=0

return ret
