#compdef foundryup

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[install specific version]:version' \
  '-b+[install specific branch]:branch' \
  '--branch=[install specific branch]:branch' \
  '-r+[install from specific repo]:repo' \
  '--repo=[install from specific repo]:repo' \
  '-p+[install specific path]:path' \
  '--path=[install local path]:path:_directories' \
  '-C+[install specific commit]:commit' \
  '--commit=[install specific commit]:commit' \
  '-P+[install to specific directory]:directory:_directories' \
  '--install-dir=[install to specific directory]:directory:_directories' \
  '-j+[number of jobs]:jobs' \
  '--jobs=[number of jobs]:jobs' && ret=0

return ret
