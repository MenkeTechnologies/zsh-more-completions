#compdef bcrypt
# _bcrypt-bin — bcrypt blowfish file encryption (C); password-based block encryption tool (NOT the password-hashing scheme)
# upstream: https://bcrypt.sourceforge.net

_bcrypt-bin() {
    _arguments \
        '-h[show help]' \
        '-c[do not compress before encrypt]' \
        '-o[stdout for output]' \
        '-orig[do not overwrite even if exists]' \
        '-r[do not remove input file]' \
        '-s+[overwrite passes (default 7)]:n:' \
        '*:file:_files -g "*.(bfe|*)"'
}

_bcrypt-bin "$@"
