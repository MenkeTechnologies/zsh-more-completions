#compdef xdelta xdelta3
# Binary delta encoding tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'config:show configuration'
  'decode:decompress input'
  'encode:compress input'
  'test:run built-in tests'
  'printdelta:print delta information'
)

_arguments -s -S \
  '1:command:->command' \
  '-0[compression level 0 (none)]' \
  '-1[compression level 1 (fastest)]' \
  '-9[compression level 9 (best)]' \
  '-B[specify block size]:size:' \
  '-C[disable checksum]' \
  '-D[disable external decompression]' \
  '-e[compress]' \
  '-d[decompress]' \
  '-f[force overwrite]' \
  '-F[disable secondary compression]' \
  '-n[disable small string-matching compression]' \
  '-N[disable instruction compression]' \
  '-R[disable external recompression]' \
  '-s[specify source file]:source:_files' \
  '-S[specify secondary compression]:codec:(none lzma djw fgk)' \
  '-v[verbose output]' \
  '-q[quiet mode]' \
  '-V[show version]' \
  '-W[specify window size]:size:' \
  '-h[show help]' \
  '--help[show help]' \
  '*:file:_files' && ret=0

case $state in
  (command)
    _describe -t commands 'xdelta command' commands && ret=0
    ;;
esac

return ret
