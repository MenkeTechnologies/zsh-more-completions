#compdef fkeyprint
# Print the specified keyword(s) in the headers of input FITS files

local ret=1

_arguments -s \
  "infile=[input FITS file]:file:_files" \
  "keynam=[keyword name to print]:" \
  "outfile=[output report file]:file:_files" \
  "exact=[exact keyword match]:bool:(yes no)" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
