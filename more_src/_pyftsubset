#compdef pyftsubset

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--output-file=[output font file]:file:_files -g "*.(otf|ttf|woff|woff2)"' \
  '--text=[text characters to subset]:text:' \
  '--text-file=[file containing text to subset]:file:_files' \
  '--glyphs=[glyphs to include]:glyphs:' \
  '--glyphs-file=[file with glyphs to include]:file:_files' \
  '--unicodes=[unicode codepoints (comma/range)]:codepoints:' \
  '--unicodes-file=[file with unicode codepoints]:file:_files' \
  '--gids=[glyph IDs to include]:gids:' \
  '--gids-file=[file with glyph IDs]:file:_files' \
  '--ignore-missing-glyphs[do not error on missing glyphs]' \
  '--ignore-missing-unicodes[do not error on missing unicodes]' \
  '--no-ignore-missing-glyphs[error on missing glyphs (default)]' \
  '--no-ignore-missing-unicodes[error on missing unicodes (default)]' \
  '--layout-features=[OpenType layout features]:features:' \
  '--no-layout-closure[do not perform layout closure]' \
  '--layout-scripts=[OpenType layout scripts]:scripts:' \
  '--name-IDs=[name IDs to keep]:ids:' \
  '--name-legacy[keep legacy non-Unicode names]' \
  '--name-languages=[name table languages to keep]:langs:' \
  '--obfuscate-names[obfuscate name table strings]' \
  '--notdef-glyph[keep .notdef glyph]' \
  '--no-notdef-glyph[remove .notdef glyph]' \
  '--notdef-outline[keep .notdef outline]' \
  '--no-notdef-outline[remove .notdef outline]' \
  '--recommended-glyphs[keep recommended glyphs]' \
  '--no-recommended-glyphs[do not keep recommended glyphs]' \
  '--hinting[keep hinting (default)]' \
  '--no-hinting[remove hinting]' \
  '--desubroutinize[desubroutinize CFF table]' \
  '--no-desubroutinize[do not desubroutinize]' \
  '--legacy-kern[keep legacy kern table]' \
  '--no-legacy-kern[remove legacy kern table]' \
  '--drop-tables=[tables to drop]:tables:' \
  '--no-drop-tables=[tables to keep that would normally be dropped]:tables:' \
  '--passthrough-tables[pass through tables not understood]' \
  '--no-passthrough-tables[drop tables not understood]' \
  '--prune-unicode-ranges[prune OS/2 unicode ranges]' \
  '--no-prune-unicode-ranges[do not prune OS/2 unicode ranges]' \
  '--prune-codepage-ranges[prune OS/2 codepage ranges]' \
  '--retain-gids[retain original glyph IDs]' \
  '--retain-original-glyph-names[retain original glyph names]' \
  '--glyph-names[keep glyph names]' \
  '--no-glyph-names[remove glyph names]' \
  '--symbol-cmap[force symbol cmap]' \
  '--legacy-cmap[keep legacy cmap subtables]' \
  '--font-number=[TTC font number]:n:' \
  '--flavor=[output font flavor]:flavor:(woff woff2)' \
  '--with-zopfli[use zopfli for woff compression]' \
  '--no-with-zopfli[do not use zopfli]' \
  '--harfbuzz-repacker[use HarfBuzz repacker]' \
  '--no-harfbuzz-repacker[do not use HarfBuzz repacker]' \
  '--verbose[verbose output]' \
  '--debug[print exception traceback]' \
  '--timing[print timing information]' \
  '--lazy[lazy loading (default)]' \
  '--no-lazy[no lazy loading]' \
  '--recalc-bounds[recalculate font bounds]' \
  '--no-recalc-bounds[do not recalculate font bounds]' \
  '--recalc-timestamp[recalculate font modified timestamp]' \
  '--no-recalc-timestamp[do not recalculate timestamp]' \
  '*:font file:_files -g "*.(otf|ttf|woff|woff2|ttc)"' && ret=0

return ret
