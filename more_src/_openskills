#compdef openskills

# Zsh completion for openskills Anthropic skills CLI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:subcommand:(install list read sync uninstall update upgrade version)' \
  '*::args:{ _files }' && ret=0

return ret
