#compdef mp3unicode
# Documentation: http://mp3unicode.sourceforge.net/manpage.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mp3unicode

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '(-s --source-encoding)'{-s+,--source-encoding=}'[source encoding for reading tags]:encoding:' \
  '(-1 --id3v1-encoding)'{-1+,--id3v1-encoding=}'[encoding for writing ID3v1 tags]:encoding:' \
  '(-2 --id3v2-encoding)'{-2+,--id3v2-encoding=}'[encoding for writing ID3v2 tags]:encoding:' \
  '(-p --preserve-unicode)'{-p,--preserve-unicode}'[assume Unicode if detected]' \
  '(-w --preview)'{-w,--preview}'[show tags without writing]' \
  '(-q --quiet)'{-q,--quiet}'[suppress per-file reporting]' \
  '*:: :_files' && ret=0

return ret
