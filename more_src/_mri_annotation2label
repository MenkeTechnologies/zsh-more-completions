#compdef mri_annotation2label
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_annotation2label
# mri_annotation2label - convert an annotation into individual label files

local ret=1

_arguments -s -S \
  '--subject[source subject ID]:subject:' \
  '--hemi[hemisphere (lh or rh)]:hemi:(lh rh)' \
  '--label[extract only a single label by index]:index:' \
  '--labelbase[use base-XXX.label naming pattern]:base:' \
  '--outdir[output directory for label files]:dir:_files -/' \
  '--seg[generate segmentation volume output]:file:_files' \
  '--segbase[add offset to annotation numbers for seg]:offset:' \
  '--ctab[custom color lookup table file]:file:_files' \
  '--border[binary overlay of parcellation boundaries]:file:_files' \
  '--border-annot[border annotation output location]:file:_files' \
  '--annotation[input annotation (default aparc)]:annot:' \
  '--sd[SUBJECTS_DIR path]:dir:_files -/' \
  '(--surface --surf)'{--surface,--surf}'[surface file for RAS coordinates]:surf:' \
  '--stat[include surface overlay statistics in label files]:file:_files' \
  '--lobes[generate cortical lobe-based annotation]:file:_files' \
  '--lobesStrict[stricter lobe definition variant]:file:_files' \
  '--lobesStrictPHCG[strictest definition with parahippocampal lobe]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display version information]' && ret=0

return ret
