#compdef polimage
# Documentation: https://starlink.eao.hawaii.edu/docs/sun223.htx/sun223ss8.html
# POLPACK: converts a catalogue into an NDF.

local ret=1

_arguments -s -S \
  'IN=[input catalogue]:cat:_files' \
  'OUT=[output NDF]:ndf:_files' \
  'COLDAT=[column for DATA component]:col:' \
  'COLVAR=[column for VARIANCE component]:col:' \
  'COLX=[column for first-axis coordinates]:col:' \
  'COLY=[column for second-axis coordinates]:col:' \
  'COLZ=[column for third-axis coordinates]:col:' \
  'BOX=[x, y and z bin sizes]:box:' \
  'METHOD=[binning method]:method:(MEAN MEDIAN SIGMA)' \
  'MINVAL=[min good values per cell]:n:' \
  'SHAPE=[2/3-D spatial output vs 1-D list]:flag:(TRUE FALSE)' \
  'SIGMAS=[std devs for sigma-clipped rejection]:n:' \
  '*:cat:_files' && ret=0

return ret
