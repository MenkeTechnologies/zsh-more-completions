#compdef bbrf

_bbrf() {
    local curcontext="$curcontext" state line ret=1

    _arguments -C \
        '(- *)--help[show help message and exit]' \
        '--program=[select program to use]:program:' \
        '--show-key[show the CouchDB key in output]' \
        '--show-empty[show empty values in output]' \
        '(-n --no-banner)'{-n,--no-banner}'[suppress the banner]' \
        '1:subcommand:->subcmd' \
        '*::args:->args' && ret=0

    case $state in
        subcmd)
            local -a subcmds=(
                'new:create a new program'
                'use:select a program to use'
                'programs:list all programs'
                'scope:manage program scope'
                'domain:manage domains'
                'ip:manage IP addresses'
                'url:manage URLs'
                'service:manage services'
                'alert:manage alerts'
                'run:run a module'
                'show:show program details'
                'dashboard:display the dashboard'
            )
            _describe -t commands 'bbrf subcommand' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                new)
                    _arguments \
                        '--program=[program name]:program:' \
                        '*:program name:' && ret=0
                    ;;
                use)
                    _arguments \
                        '*:program name:' && ret=0
                    ;;
                scope)
                    local -a scope_subcmds=(
                        'add:add scope entries'
                        'remove:remove scope entries'
                        'in:check if target is in scope'
                        'out:check if target is out of scope'
                    )
                    _arguments \
                        '--program=[program name]:program:' \
                        '1:action:compadd -a scope_subcmds' \
                        '*:target:' && ret=0
                    ;;
                domain|ip|url|service|alert)
                    local -a entity_subcmds=(
                        'add:add entries'
                        'remove:remove entries'
                        'show:show entries'
                    )
                    _arguments \
                        '--program=[program name]:program:' \
                        '1:action:compadd -a entity_subcmds' \
                        '*:value:' && ret=0
                    ;;
                run)
                    _arguments \
                        '--program=[program name]:program:' \
                        '*:module name:' && ret=0
                    ;;
                show)
                    _arguments \
                        '--program=[program name]:program:' && ret=0
                    ;;
                dashboard)
                    _arguments \
                        '--program=[program name]:program:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_bbrf "$@"
