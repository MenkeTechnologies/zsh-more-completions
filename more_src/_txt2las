#compdef txt2las
# Documentation: https://github.com/LAStools/LAStools
# LAStools: convert ASCII text point clouds to LAS/LAZ

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print help]' \
  '-version[report tool version]' \
  '-gui[start with GUI]' \
  '-parse+[define field interpretation (e.g. xyzi)]:parse string' \
  '-skip+[skip first n lines of input]:n' \
  '-iskip+[skip n lines at input beginning]:n' \
  '-stdin[pipe input from stdin]' \
  '-itxt[expect input as text file]' \
  '-ipts[input as PTS, store header in VLR]' \
  '-iptx[input as PTX, store header in VLR]' \
  '-iptx_transform[use PTX header transformation matrix]' \
  '-set_scale+[quantize points with resolution x y z]:x' \
  '-set_offset+[use custom offset x y z]:x' \
  '-rescale+[apply new scale and rescale points]:x' \
  '-reoffset+[apply new offset and translate points]:x' \
  '-utm+[use UTM zone (e.g. 14T)]:zone' \
  '-sp83+[state plane NAD83 (e.g. OH_N)]:plane' \
  '-epsg+[set datum to EPSG code]:code' \
  '-longlat[geometric coordinates in longitude/latitude]' \
  '-latlong[geometric coordinates in latitude/longitude]' \
  '-set_ogc_wkt[translate GeoTIFF keys to OGC WKT CRS VLR]' \
  '-scale_intensity+[multiply intensity by factor]:factor' \
  '-scale_scan_angle+[scale scan angle by factor]:factor' \
  '-translate_intensity+[translate intensity by value]:value' \
  '-add_attribute+[add extra bytes attribute type name desc]:type' \
  '-set_point_type+[use LAS 1.4 point type (1-10)]:type' \
  '-set_creation_date+[set creation date (day year)]:day' \
  '-set_generating_software+[set software identifier]:string' \
  '-set_system_identifier+[set system identifier]:string' \
  '-set_version+[force LAS version]:version' \
  '-set_global_encoding+[set global encoding (0/1)]:value' \
  '-week_to_adjusted[convert GPS week to adjusted standard GPS]' \
  '-force[continue despite serious warnings]' \
  '-errors_ignore[continue on errors if possible]' \
  '-silent[output only errors/warnings]' \
  '-quiet[no output]' \
  '-progress+[report progress every n points]:n' \
  '-cores+[process on n parallel cores]:n' \
  '*-i+[input text file or wildcard]:input:_files' \
  '-o+[output file]:output:_files' \
  '-odir+[output directory]:dir:_files -/' \
  '-odix+[output filename suffix]:suffix' \
  '-ocut+[cut last n characters from filename]:n' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-obin[output as terrasolid BIN]' \
  '-otxt[output as text]' \
  '-opts[output as PTS]' \
  '-optx[output as PTX]' \
  '*:file:_files' && ret=0

return ret
