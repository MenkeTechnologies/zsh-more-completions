#compdef ElmerSolver_mpi
# Documentation: https://github.com/ElmerCSC/elmerfem/blob/devel/fem/src/ElmerSolver.F90
# Elmer multiphysics finite element solver (MPI parallel build)

local ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-s --silent)'{-s,--silent}'[suppress banner and informational output]' \
  '-rpar[set real MATC parameters: count followed by values]:count:' \
  '-ipar[set integer MATC parameters: count followed by values]:count:' \
  '*:sif file:_files -g "*.sif"' && ret=0

return ret
