#compdef dataform
# Documentation: https://docs.cloud.google.com/dataform/docs/reference/dataform-cli-reference
# Dataform CLI - compile/test/run BigQuery SQL workflows (init, run, compile, test)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version number]' \
  '--default-database=[default database / GCP project ID]:project' \
  '--default-location=[default BigQuery data location]:location' \
  '--json[output compilation result as JSON]' \
  '--vars=[custom compilation variables (key=value,...)]:vars' \
  '--full-refresh[force full refresh of incremental tables]' \
  '--dry-run[compile without executing]' \
  '1:command:(help init init-creds install compile test run format)' \
  '*::arg:->args' && ret=0

return ret
