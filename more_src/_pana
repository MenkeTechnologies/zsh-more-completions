#compdef pana
# Documentation: https://pub.dev/packages/pana
# pana - analyze a Dart/Flutter package and score it like pub.dev

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--hosted[download and analyze a hosted package]' \
  '--hosted-url=[server hosting the package]:url:' \
  '--dart-sdk=[Dart SDK directory]:dir:_files -/' \
  '--flutter-sdk=[Flutter SDK directory]:dir:_files -/' \
  '(-j --json)'{-j,--json}'[output report as JSON]' \
  '--exit-code-threshold=[exit code based on point differential]:n:' \
  '(--dartdoc --no-dartdoc)--dartdoc[enable dartdoc execution and scoring]' \
  '(--dartdoc --no-dartdoc)--no-dartdoc[disable dartdoc execution and scoring]' \
  '--dartdoc-version=[dartdoc version]:version:(sdk latest)' \
  '--license-data=[path to SPDX license data directory]:dir:_files -/' \
  '*:package:_files' && ret=0

return ret
