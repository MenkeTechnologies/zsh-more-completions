#compdef pymolcas
# Documentation: https://gitlab.com/Molcas/OpenMolcas/-/raw/master/Tools/pymolcas/pymolcas.py
# OpenMolcas driver: run a Molcas input through the EMIL flow control language

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --setup)'{-s,--setup}'[set up a custom molcasrc file with useful environment variables]' \
  '(-env --environment)'{-env,--environment}'[display information about environment]' \
  '(-clean --clean_scratch)'{-clean,--clean_scratch}'[clean scratch area after calculation]' \
  '(-new --new_scratch)'{-new,--new_scratch}'[clean scratch area before calculation]' \
  '(-old --old_scratch)'{-old,--old_scratch}'[reuse scratch area (default)]' \
  '(-ign --ignore_environment)'{-ign,--ignore_environment}'[run ignoring resource files]' \
  '(-val --validate)'{-val,--validate}'[validate input only (dry run)]' \
  '(-np --nprocs)'{-np,--nprocs}'+[number of parallel (MPI) processes]:nprocs:' \
  '(-nt --nthreads)'{-nt,--nthreads}'+[number of OpenMP threads per process]:nthreads:' \
  '(-v --version)'{-v,--version}'[print version of the driver]' \
  '(-o --output)'{-o,--output}'+[redirect output stream to FILE]:file:_files' \
  '(-e --error)'{-e,--error}'+[redirect error stream to FILE]:file:_files' \
  '(-oe -eo --outputerror)'{-oe,-eo,--outputerror}'+[redirect output and error streams to FILE]:file:_files' \
  '(-f --files)'{-f,--files}'[redirect output/error streams to standard files (*.log and *.err)]' \
  '(-b --buffer)'{-b,--buffer}'+[buffer size for input/error files]:buffer:' \
  '--banner[print banner (version and compilation info)]' \
  '--not-here[do not try to find MOLCAS in the current directory]' \
  '(-l --license)'{-l,--license}'[check if there is a valid license]' \
  '*:input file:_files -g "*.(input|inp)"' && ret=0

return ret
