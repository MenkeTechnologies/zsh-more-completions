#compdef snipkit
# Documentation: https://lemoony.github.io/snipkit/
# SnipKit - a snippet command-line manager designed to boost productivity

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '(-l --log-level)'{-l,--log-level}'=[log level used for debugging problems]:level:(panic fatal error warn info debug trace)' \
  '1:command:(assistant browse config copy exec export info manager print sync)' \
  '*::arg:->args' && ret=0

return ret
