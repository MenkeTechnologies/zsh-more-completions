#compdef pg_activity

# Zsh completion for pg_activity - PostgreSQL top-like monitor

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-U+[database user]:user' \
  '--username=[database user]:user' \
  '-p+[database port]:port' \
  '--port=[database port]:port' \
  '-h+[database host]:host' \
  '--host=[database host]:host' \
  '-d+[database name]:database' \
  '--dbname=[database name]:database' \
  '--blocksize=[filesystem block size]:size' \
  '--rds[enable AWS RDS compatibility]' \
  '--output=[output file for non-interactive mode]:file:_files' \
  '--no-pid[hide PID column]' \
  '--no-database[hide database column]' \
  '--no-user[hide user column]' \
  '--no-client[hide client column]' \
  '--no-cpu[hide CPU column]' \
  '--no-mem[hide memory column]' \
  '--no-read[hide read column]' \
  '--no-write[hide write column]' \
  '--no-time[hide time column]' \
  '--no-wait[hide wait column]' \
  '--no-app-name[hide application name column]' \
  '--duration-mode=[duration mode]:mode:(1 2 3)' \
  '--min-duration=[minimum query duration]:seconds' \
  '--filter=[filter by database name]:database' \
  '--debug-file=[debug file]:file:_files' \
  '--refresh=[refresh interval]:seconds' && ret=0

return ret
