#compdef lean4

# Zsh completion for lean4 - Lean 4 theorem prover and programming language

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)--githash[show git hash of the build]' \
  '--run[execute the file and run main]:file:_files -g "*.lean"' \
  '--stdin[read input from stdin]' \
  '--threads=[number of threads to use]:count' \
  '--memory=[soft memory limit in megabytes]:megabytes' \
  '--timeout=[deterministic timeout in seconds]:seconds' \
  '--plugin=[load a shared library plugin]:shared library:_files -g "*.so *.dylib *.dll"' \
  '--server[start the language server]' \
  '--worker[start a language server worker]' \
  '--lake=[path to lake binary]:lake binary:_files' \
  '--old-frontend[use the old frontend]' \
  '--new-frontend[use the new frontend]' \
  '--trust-level=[set trust level]:level:(0 1 2)' \
  '--profile[enable profiling]' \
  '--stats[display statistics]' \
  '--quiet[suppress informational messages]' \
  '*-D[set a Lean option]:option=value' \
  '*-R[set a Lean runtime option]:option=value' \
  '--root=[set package root directory]:directory:_directories' \
  '--ilean=[output ilean data to file]:file:_files' \
  '--oleandir=[output olean directory]:directory:_directories' \
  {-o,--output}'[output file]:output file:_files' \
  '--c=[output C file]:C file:_files -g "*.c"' \
  '--load-dynlib=[load a dynamic library]:library:_files -g "*.so *.dylib *.dll"' \
  '*:Lean source file:_files -g "*.lean"' && ret=0

return ret
