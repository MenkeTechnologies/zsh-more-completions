#compdef dpkg-depcheck
# Documentation: https://manpages.debian.org/dpkg-depcheck
# Source: debian/devscripts scripts/dpkg-depcheck.pl — determine actual packages used by a command (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-a --all -b --build-depends -d --ignore-dev-deps -m --min-deps)'{-a,--all}'[report all packages used]' \
    '(-a --all -b --build-depends -d --ignore-dev-deps -m --min-deps)'{-b,--build-depends}'[report build-depend packages]' \
    '(-a --all -b --build-depends -d --ignore-dev-deps -m --min-deps)'{-d,--ignore-dev-deps}'[ignore dev deps]' \
    '(-a --all -b --build-depends -d --ignore-dev-deps -m --min-deps)'{-m,--min-deps}'[minimal deps only]' \
    '(--no-C-locale --noC-locale)'{-C,--C-locale}'[run command under C locale]' \
    '(-C --C-locale)'{--no-C-locale,--noC-locale}'[do not force C locale]' \
    '(--no-list-files --nolist-files)'{-l,--list-files}'[list files needed for each package]' \
    '(-l --list-files)'{--no-list-files,--nolist-files}'[do not list files]' \
    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
    '(-O --strace-output)'{-O+,--strace-output=}'[strace output file]:file:_files' \
    '(-I --strace-input)'{-I+,--strace-input=}'[strace input file]:file:_files' \
    '(-f --features)'{-f+,--features=}'[features]:features:_default' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '*:command:_command_names -e' \
    && ret=0

return ret
