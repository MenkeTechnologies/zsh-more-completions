#compdef wmweather
# Documentation: https://man.archlinux.org/search?q=wmweather
# Reference accessed: 2026-05-16

# wmweather: Window Maker dockapp showing METAR / NWS weather data
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-display[X display]:display:' \
  '-station[ICAO station code (e.g. KSFO)]:station:' \
  '-update[update interval (sec)]:seconds:' \
  '-metric[show metric units]' \
  '-english[show english units]' \
  '-position[window geometry]:WxH+X+Y:' \
  '-bg[bg color]:color:' \
  '-fg[fg color]:color:' \
  '-w[network timeout]:seconds:' \
  '*::wmweather args:_files' && ret=0
return ret
