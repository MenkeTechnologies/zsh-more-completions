#compdef adonis ace

# Zsh completion for AdonisJS CLI (adonis / node ace)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_adonis_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
)

_arguments -s -S -C \
  "${_adonis_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'make\:controller:Create a new HTTP controller'
      'make\:model:Create a new Lucid model'
      'make\:migration:Create a new migration file'
      'make\:middleware:Create a new middleware'
      'make\:validator:Create a new validator'
      'make\:view:Create a new view template'
      'make\:command:Create a new Ace command'
      'make\:mailer:Create a new mailer'
      'make\:listener:Create a new event listener'
      'make\:exception:Create a new exception'
      'make\:provider:Create a new service provider'
      'make\:test:Create a new test file'
      'serve:Start the HTTP server'
      'build:Build the application for production'
      'test:Run tests'
      'migration\:run:Run pending migrations'
      'migration\:rollback:Rollback last migration batch'
      'migration\:status:Show migration status'
      'migration\:fresh:Drop all tables and re-run migrations'
      'migration\:reset:Rollback all migrations'
      'db\:seed:Run database seeders'
      'db\:wipe:Drop all tables'
      'list\:routes:List application routes'
      'generate\:key:Generate the application key'
      'env\:add:Add a new environment variable'
      'configure:Configure a package'
      'repl:Start the REPL session'
    )
    _describe -t commands 'adonis commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      serve)
        _arguments -s -S \
          "${_adonis_global_flags[@]}" \
          '--watch[watch for file changes and restart]' \
          '--hmr[enable hot module replacement]' \
          '--encore[start Encore dev server alongside]' \
          '--no-assets[do not start assets bundler]' && ret=0
        ;;
      build)
        _arguments -s -S \
          "${_adonis_global_flags[@]}" \
          '--no-assets[do not build frontend assets]' && ret=0
        ;;
      test)
        _arguments -s -S \
          "${_adonis_global_flags[@]}" \
          '--force[force run tests]' \
          '*:test files:_files' && ret=0
        ;;
      make:*)
        _arguments -s -S \
          "${_adonis_global_flags[@]}" \
          '--force[overwrite existing file]' \
          '1:name:' && ret=0
        ;;
      migration:run|migration:rollback|migration:fresh|migration:reset)
        _arguments -s -S \
          "${_adonis_global_flags[@]}" \
          '--force[force run in production]' && ret=0
        ;;
      migration:status)
        _arguments -s -S \
          "${_adonis_global_flags[@]}" && ret=0
        ;;
      db:seed)
        _arguments -s -S \
          "${_adonis_global_flags[@]}" \
          '--force[force run in production]' \
          '*:seeder files:_files' && ret=0
        ;;
      db:wipe)
        _arguments -s -S \
          "${_adonis_global_flags[@]}" \
          '--force[force run in production]' && ret=0
        ;;
      configure)
        _arguments -s -S \
          "${_adonis_global_flags[@]}" \
          '1:package name:' && ret=0
        ;;
      *)
        _arguments -s -S \
          "${_adonis_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
