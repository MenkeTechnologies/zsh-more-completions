#compdef codon
# High-performance Python compiler using LLVM

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:compile and run a program'
      'build:compile a program to executable'
      'doc:generate documentation'
      'jit:run in JIT mode'
    )
    _describe -t commands 'codon command' commands && ret=0
    ;;
  args)
    _arguments \
      '-o[output file]:file:_files' \
      '-release[enable optimizations]' \
      '-debug[enable debug info]' \
      '-D[define variable]:var:' \
      '-module[module name]:module:' \
      '-plugin[load plugin]:plugin:_files' \
      '-numerics[numerical library]:lib:(numpy)' \
      '*:source file:_files -g "*.py"' && ret=0
    ;;
esac

return ret
