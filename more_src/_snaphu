#compdef snaphu
# Documentation: https://web.stanford.edu/group/radar/softwareandlinks/sw/snaphu/snaphu_man1.html
# Statistical-cost network-flow phase unwrapping (SNAPHU)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message]' \
  '-a[read brightness data from amplitude file]:ampfile:_files' \
  '-A[read brightness data from power file]:pwrfile:_files' \
  '-b[set perpendicular baseline component in meters]:bperp:' \
  '-c[read correlation/coherence data from file]:corrfile:_files' \
  '-C[parse configuration string from command line]:configstr:' \
  '-d[run in deformation mode]' \
  '-e[flatten using unwrapped phase estimate]:estimatefile:_files' \
  '-f[read configuration parameters from file]:configfile:_files' \
  '-g[generate connected component mask for solution]:maskfile:_files' \
  '-G[generate connected component mask for input data]:maskfile:_files' \
  '-i[initialize-only mode (no iterative solver)]' \
  '-k[keep temporary tile outputs]' \
  '-l[log runtime parameters to file]:logfile:_files' \
  '-m[read interferogram magnitude data]:magfile:_files' \
  '-M[read byte mask file]:bytemaskfile:_files' \
  '-n[run without statistical cost functions]' \
  '-o[write unwrapped output to file]:outfile:_files' \
  '-p[run in Lp-norm mode with specified p value]:value:' \
  '-q[quantify-only mode (cost of unwrapped input)]' \
  '-s[run in smooth-solution mode]' \
  '-S[single-tile re-optimization after tile initialization]' \
  '-t[run in topography mode (default)]' \
  '-u[assume input file is already unwrapped]' \
  '-v[verbose mode]' \
  '-w[read external scalar weights from file]:weightfile:_files' \
  '--aa[read amplitude data from two separate files]:ampfile1:_files' \
  '--AA[read power data from two separate files]:pwrfile1:_files' \
  '--assemble[reassemble tile outputs with different parameters]' \
  '(--copyright --info)'{--copyright,--info}'[print copyright notice and exit]' \
  '--costinfile[read statistical cost arrays from file]:costfile:_files' \
  '--costoutfile[write statistical cost arrays to file]:costfile:_files' \
  '(--debug --dumpall)'{--debug,--dumpall}'[dump intermediate arrays to files]' \
  '--mst[use minimum spanning tree initialization]' \
  '--mcf[use minimum cost flow initialization]' \
  '--nproc[use n parallel processes in tile mode]:n:' \
  '--piece[read and unwrap subset of interferogram]:firstrow:' \
  '--tile[unwrap in tile mode with overlap]:ntilerow:' \
  '--tiledir[specify temporary tile directory]:dirname:_files -/' \
  '*:infile:_files' && ret=0

return ret
