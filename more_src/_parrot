#compdef parrot
# parrot — statistical density modification: solvent flattening, NCS averaging, histogram matching (CCP4)

local ret=1

_arguments -s -S \
  '-mtzin-ref[reference MTZ]:file:_files -g "*.mtz"' \
  '-pdbin-ref[reference PDB]:file:_files -g "*.(pdb|ent)"' \
  '-mtzin-wrk[work MTZ]:file:_files -g "*.mtz"' \
  '-seqin-wrk[sequence file]:file:_files' \
  '-pdbin-wrk-ha[heavy atom model]:file:_files -g "*.(pdb|ent)"' \
  '-pdbin-wrk-mr[MR model]:file:_files -g "*.(pdb|ent)"' \
  '-mtzout[output MTZ]:file:_files -g "*.mtz"' \
  '-colin-ref-fo[reference observed F and sigma]:path:' \
  '-colin-ref-hl[reference HL coefficients]:path:' \
  '-colin-wrk-fo[work observed F and sigma]:path:' \
  '-colin-wrk-hl[work HL coefficients]:path:' \
  '-colin-wrk-phifom[phase and FOM]:path:' \
  '-colin-wrk-fc[calculated structure factors]:path:' \
  '-colin-wrk-free[free R set flag]:path:' \
  '-colout[output column path]:path:' \
  '-colout-hl[output HL coefficients]:path:' \
  '-colout-fc[output calculated structure factors]:path:' \
  '-solvent-flatten[enable solvent flattening]' \
  '-histogram-match[enable histogram matching]' \
  '-ncs-average[enable NCS averaging]' \
  '-rice-probability[enable Rice probability weighting]' \
  '-cycles[number of modification cycles]:n:' \
  '-resolution[resolution limit]:res:' \
  '-solvent-content[solvent fraction]:frac:' \
  '-solvent-mask-filter-radius[solvent mask filter radius]:r:' \
  '-ncs-mask-filter-radius[NCS mask filter radius]:r:' \
  '-ncs-asu-fraction[NCS ASU fraction]:frac:' \
  '-ncs-operator[NCS operator parameters]:op:' \
  '-verbose[verbosity level]:n:' \
  '-stdin[read keywords from standard input]' \
  '*:argument:_files' && ret=0

return ret
