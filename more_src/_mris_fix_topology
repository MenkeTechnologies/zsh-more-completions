#compdef mris_fix_topology
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_fix_topology
# FreeSurfer: correct topological defects in a cortical surface

local ret=1

_arguments -s -S \
  '(- *)-help[print help and exit]' \
  '(- *)-version[print version and exit]' \
  '-orig[original surface name]:origname' \
  '-sphere[sphere surface name]:spherename' \
  '-inflated[inflated surface name]:inflatedname' \
  '-wi[write fixed inflated surface]' \
  '-verbose[enable verbose output]' \
  '-verbose_low[enable low-level verbose output]' \
  '-warnings[display warnings]' \
  '-errors[display errors]' \
  '-movies[generate movie files]' \
  '-intersect[check if final surface self-intersects]' \
  '-mappings[generate several different mappings]' \
  '-correct_defect[correct defect N only]:N' \
  '-niters[stop genetic algorithm after N iterations]:N' \
  '-genetic[use genetic search]' \
  '-ga[optimize genetic search]' \
  '-optimize[optimize genetic search]' \
  '-random[use random search with N iterations]:N' \
  '-seed[set random number generator seed]:N' \
  '-diag[set DIAG_SAVE_DIAGS]' \
  '-mgz[assume volumes are in mgz format]' \
  '-s[smooth corrected surface by N iterations]:N' \
  '-v[set diagnostic level]:D' \
  '*:argument:_files' && ret=0

return ret
