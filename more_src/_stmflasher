#compdef stmflasher
# Documentation: https://man.archlinux.org/search?q=stmflasher
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-d+[serial port]:port:_files -g "/dev/tty*"' \
  '-b+[baud rate]:rate:(1200 2400 4800 9600 19200 38400 57600 115200 230400)' \
  '-r+[read from file]:file:_files' \
  '-w+[write to file]:file:_files' \
  '-e+[number of pages to erase]:n:' \
  '-u[disable read protect]' \
  '-j[enable read protect]' \
  '-k[enable write protect]' \
  '-l[disable write protect]' \
  '-v[verify after write]' \
  '-n+[number of retries]:n:' \
  '-g+[goto address]:addr:' \
  '-V[show version]' \
  '-c+[command line settings]:opts:' \
  '-s+[start page]:n:' \
  '-f[force binary]' \
  '-y+[stm baud rate]:rate:' && ret=0

return ret
