#compdef elephant
# _elephant — data provider + executor service for menus / launchers (abenz1267/elephant)
# upstream: https://github.com/abenz1267/elephant
# Subcommands from cmd/elephant/elephant.go (urfave/cli v3).

_elephant() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_elephant_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                service)
                    _arguments '1:service subcommand:(enable disable)'
                    ;;
                generate|g)
                    _arguments '1:generate subcommand:(doc config)'
                    ;;
                community)
                    _arguments '1:community subcommand:(install readme remove list)'
                    ;;
                query)
                    _arguments \
                        '--async[run the query asynchronously]' \
                        '--json[JSON output]' \
                        '*:query parts:'
                    ;;
                state)
                    _arguments \
                        '--json[JSON output]' \
                        '1:content:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_elephant_commands] )) ||
_elephant_commands() {
    local -a commands
    commands=(
        'service:enable / disable the user systemd service'
        'version:print elephant version (alias: v)'
        'listproviders:list available data providers (alias: l)'
        'menu:show / drive a launcher menu (alias: m)'
        'generate:generate doc / config (alias: g)'
        'query:run a provider query'
        'state:fetch the runtime state'
        'community:install / list / remove community providers'
        'activate:activate (run) a previously queried entry'
        'config:show / edit elephant config (alias: c)'
        'debug:print debug info (alias: d)'
    )
    _describe -t commands 'elephant command' commands
}

_elephant "$@"
