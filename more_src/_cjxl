#compdef cjxl
# Documentation: cjxl --help (libjxl 0.11.2)
# Source: JPEG XL encoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help (add -v for more options)]' \
    '(- *)'{-V,--version}'[print version]' \
    '(-q --quality)'{-d+,--distance=}'[target visual distance in JND]:distance:' \
    '(-d --distance)'{-q+,--quality=}'[quality 0..100 (100=lossless)]:quality:' \
    '(-e --effort)'{-e+,--effort=}'[encoder effort 1..10 (default 7)]:effort:' \
    '--quiet[silence output]' \
    '*'{-v,--verbose}'[verbose (repeatable)]' \
    '1:input image:_files -g "*.(jxl|ppm|pnm|pfm|pam|pgx|png|apng|gif|jpg|jpeg|exr)"' \
    '2:output jxl:_files -g "*.jxl"' \
    && ret=0

return ret
