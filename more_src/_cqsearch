#compdef cqsearch
# Documentation: https://github.com/ruben2020/codequery/blob/master/cli/main_cli.cpp
# CodeQuery CLI search over a cqmakedb sqlite3 database

local ret=1

_arguments -s -S \
  '(-h)-h[display help]' \
  '(-v)-v[display version]' \
  '-s+[CodeQuery sqlite3 database file]:database:_files' \
  '-t+[search term (no spaces; * ? wildcards in fuzzy mode)]:term:' \
  '-p+[search type number]:type:(1\:symbol 2\:function-definition 3\:class 4\:files-including 5\:full-file-path 6\:functions-calling 7\:functions-called-by 8\:calls-of 9\:class-members 10\:class-of-member 11\:class-children 12\:class-parent 13\:functions-in-file)' \
  '(-f)-e[exact match (case-sensitive)]' \
  '(-e)-f[fuzzy match (case-insensitive, default)]' \
  '-g[generate GraphViz DOT output (with -p 2 or 3)]' \
  '-l+[limit source preview line length (0-800)]:length:' \
  '-u[display full file path instead of filename]' \
  '-b+[filter results by source file path term]:term:' \
  '-d[debug mode]' \
  '*:database:_files' && ret=0

return ret
