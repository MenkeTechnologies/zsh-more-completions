#compdef comic-dl comic_dl

_arguments -s -S \
  '(-i --input)'{-i,--input}'[URL of the comic to download]:url:' \
  '(-s --sorting)'{-s,--sorting}'[sorting order for chapters]:order:(ascending descending)' \
  '(-dd --download-directory)'{-dd,--download-directory}'[directory to save downloads]:directory:_files -/' \
  '(-rn --range)'{-rn,--range}'[range of chapters to download]:range:' \
  '--convert[convert downloaded images to specified format]:format:(pdf cbz)' \
  '--keep[keep original files after conversion]' \
  '--quality[image quality for JPEG]:quality:(low medium high best)' \
  '(-p --password)'{-p,--password}'[password for login]:password:' \
  '(-u --username)'{-u,--username}'[username for login]:username:' \
  '--comic-name[set custom comic name for output]:name:' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--print-index[print chapter index and exit]' \
  '--skip-existing[skip already downloaded chapters]'
