#
#  mow.cli distinctive features:
#    - DOCOPT-INSPIRED — Jawher Moussa explicitly modeled mow.cli on
#      Python's docopt (R352): the CLI grammar is declared as a
#      USAGE SPEC STRING that mow.cli parses
#    - `cli.App(name, description)` — creates the top-level Cli App
#    - `app.Command(name, description, func(cmd *cli.Cmd) { ... })`
#      — declares a subcommand with INNER CALLBACK that configures
#      the subcommand's options/spec/action
#    - NESTED `cmd.Command(name, desc, ...)` — sub-subcommands via
#      nested callbacks (multi-level command trees)
#    - OPTION ACCESSORS (all return POINTERS to typed values):
#      * `cmd.StringOpt("name letter", default, desc)` — returns
#        `*string`; "name letter" syntax allows BOTH `-l` AND
#        `--name` (multi-name string separated by space)
#      * `cmd.IntOpt(...)` — returns `*int`
#      * `cmd.BoolOpt(...)` — returns `*bool`
#      * `cmd.StringsOpt(...)` — returns `*[]string` (repeatable)
#      * `cmd.IntsOpt(...)` — returns `*[]int` (repeatable)
#    - POSITIONAL ARG ACCESSORS:
#      * `cmd.StringArg("UPPERCASE_NAME", default, desc)` — returns
#        `*string` (positional convention: UPPERCASE_NAME)
#      * `cmd.IntArg(...)`, `cmd.BoolArg(...)`, `cmd.StringsArg(...)`
#    - USAGE SPEC STRING via `cmd.Spec = "..."` — the DISTINCTIVE
#      mow.cli feature; uses docopt-like grammar:
#      * `[--opt]` — optional flag
#      * `(--opt | --alt)` — alternation (mutually exclusive)
#      * `<ARG>` or `ARG` — required positional
#      * `[ARG]` — optional positional
#      * `[ARG...]` — repeated positional
#      * `OPTIONS` — special token meaning "all globally-registered
#        options"
#      * `--` — separator (treats remaining as positionals)
#    - `cmd.Action = func() { ... }` — command body (called when
#      this command matches)
#    - `cmd.Before = func() { ... }` — pre-action hook
#    - `cmd.After = func() { ... }` — post-action hook
#    - `cmd.LongDesc = "..."` — longer description for --help
#    - `app.Run(os.Args)` — main entry point; parses argv, dispatches
#      to matching subcommand, calls its action
#    - AUTO-INJECTED `-h, --help` on every command and subcommand
#    - AUTO-INJECTED `--version` (via `app.Version("version", "1.0")`)
#    - `app.ErrorHandling(cli.ExitOnError|ContinueOnError|PanicOnError)`
#      — error handling mode
#    - DEFAULT VALUES — second arg to *Opt functions (e.g.
#      `cmd.StringOpt("name", "default-value", "desc")`)
#    - ENV VAR FALLBACK via `cli.StringOptWithEnv(name, default, desc,
#      envVars)` — fallback to env vars
#    - VALIDATION via custom `cli.Action` body checking pointer values
#    - PROCESS EXIT model — auto-exits on parse error (configurable
#      via ErrorHandling)
#  Distinct from R311 spf13/cobra (Go's most-popular CLI library —
#  Kubernetes/Helm/etcd-style PROC/COMMAND struct + `RunE` field),
#  R342 urfave/cli (flag-array approach — `cli.App{ Flags: []cli.Flag{
#  cli.StringFlag{Name: "X", Value: "Y"} } }`), R354 alecthomas/
#  kingpin (chainable builder), R354 jessevdk/go-flags (struct-tag
#  declarative), R334 alecthomas/kong (struct-tag declarative,
#  kong-style), R357 mitchellh/cli (Cmd interface), R350 alexflint/
#  go-arg (struct-tag derivation), R350 integrii/flaggy (chainable
#  imperative), R357 mitchellh/cli (Cmd interface).  mow.cli's
#  approach: DOCOPT-INSPIRED USAGE SPEC STRING via `cmd.Spec = "..."`
#  with `[--opt]`/`(--A|--B)`/`<ARG>`/`[ARG...]`/`OPTIONS`/`--`
#  grammar + `cli.App(name, desc)` factory + `app.Command(name, desc,
#  func(cmd))` callback registration + POINTER-RETURNING OPTION
#  ACCESSORS (StringOpt/IntOpt/BoolOpt/StringsOpt return `*T`) +
#  POSITIONAL ACCESSORS with UPPERCASE_NAME convention + NESTED
#  cmd.Command for sub-subcommands + `cmd.Action`/`Before`/`After`
#  hooks + AUTO-INJECTED `--help`/`--version` + ENV VAR FALLBACK via
#  `*OptWithEnv` variants + auto-exit on parse error — corpus's
#  **first documented docopt-inspired-usage-spec-string Go CLI
#  library**.  Brings cross-language CLI library taxonomy variant
#  count to 144; Go ecosystem now has 10 documented CLI libraries —
#  TYING Rust (10) at the TOP TIER of the cross-language CLI library
#  taxonomy.
#
#  Surface (verbatim from `cmd/colly/colly.go`):
#
#  Subcommands:
#
#    new [--callbacks=X] [--hosts=Y] [PATH]
#                                   Create a new scraper from template
#        --callbacks LIST           Comma-separated callbacks to add:
#                                   html | request | response | error
#                                   (e.g. --callbacks=html,response)
#        --hosts LIST               Comma-separated allowed hosts
#                                   (e.g. --hosts=xy.com,abcd.com)
#        PATH                       Output file path (if omitted,
#                                   writes to stdout)
#
#  Auto-injected by mow.cli:
#    -h, --help                     Show help on every command
#
#  Examples:
#    colly new                                      # Print template to stdout
#    colly new out.go                               # Write to out.go
#    colly new --callbacks=html out.go              # With HTML callback
#    colly new --callbacks=html,response,error --hosts=example.com scraper.go
#                                                   # Multi-callback + hosts
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also mow.cli users):
#    - emitter (emitter-io/emitter 4004 stars — High-perf pub-sub
#      message broker; uses mow.cli for emitter binary; FUTURE
#      candidate for messaging scope)
#    - clair-scanner (arminc/clair-scanner 862 stars — Docker
#      vulnerability scanner; uses mow.cli)
#    - yeetgif (sgreben/yeetgif 561 stars — GIF effects CLI; uses
#      mow.cli)
#    - pocV / sshx / pxe-pilot / overseer / calaos_dns / Holmes
#      / peggo tx / ndau commands (smaller community Go tools using
#      mow.cli)
#    - jawher/mow.cli (the library itself — flagship example is in
#      the library repo, not a user-facing binary)
# ============================================================================

_colly() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs=(
        'new:create a new scraper from template'
      )
      _describe -t commands 'colly subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        new)
          _arguments -s -S \
            '--callbacks=[comma-separated callbacks]:callbacks:(html request response error)' \
            '--hosts=[comma-separated allowed hosts]:hosts' \
            '(-h --help)'{-h,--help}'[show help]' \
            '1:output file path:_files -g "*.go"'
          ;;
      esac
      ;;
  esac
}

_colly "$@"
