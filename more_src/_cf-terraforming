#compdef cf-terraforming
# Documentation: https://github.com/cloudflare/cf-terraforming
# Reference accessed: 2026-05-17
# Verified: upstream README and internal/app/cf-terraforming/cmd/root.go (cobra).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-c)'{-c+,--config=}'[config file]:config:_files' \
  '(-v)'{-v,--verbose}'[verbose/debug log]' \
  '--resource-type=[comma-separated resource types]:types:' \
  '--modern-import-block[HCL import blocks instead of terraform import]' \
  '(-z)'{-z+,--zone=}'[zone ID]:zone:' \
  '(-a)'{-a+,--account=}'[account ID]:account:' \
  '(-e)'{-e+,--email=}'[API email]:email:' \
  '(-k)'{-k+,--key=}'[API key]:key:' \
  '(-t)'{-t+,--token=}'[API token]:token:' \
  '--hostname=[API hostname]:host:' \
  '--terraform-install-path=[TF working dir]:path:_files -/' \
  '--terraform-binary-path=[terraform binary]:path:_files' \
  '--provider-registry-hostname=[deprecated registry host]:host:' \
  '--resource-id=[resource-type=id mapping]:mapping:' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'cf-terraforming command' compadd -- generate import version
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
