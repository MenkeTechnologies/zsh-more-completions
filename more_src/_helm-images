#compdef helm-images
# Documentation: https://github.com/nikhilsbhat/helm-images
# Helm plugin to list container images referenced by a chart or release

local ret=1
local -a subcmds

subcmds=(
  'get:fetch all images that are part of specified chart/release'
  'completion:generate the autocompletion script for the specified shell'
  'version:fetch the version of helm-images installed'
  'help:help about any command'
)

_arguments -s -C \
  '*--set=[set values on command line]:value' \
  '*--set-file=[set values from files]:file:_files' \
  '*--set-string=[set STRING values on command line]:value' \
  '*'{-s,--show-only}'=[only show manifests from given templates]:template' \
  '--skip-crds[set --skip-crds for helm template]' \
  '--skip-tests[set --skip-tests for helm template]' \
  '--validate[set --validate for helm template]' \
  '*'{-f,--values}'=[specify values in YAML file(s)]:file:_files' \
  '--version=[specify version constraint for chart]:version' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'helm images command' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      get)
        _arguments -s \
          '--from-release[fetch images from release instead]' \
          '*'{-k,--kind}'=[Kubernetes app kind to fetch images from]:kind' \
          '(-l --log-level)'{-l,--log-level}'=[log level]:level:(debug info warn error fatal)' \
          '--no-color[disable color encoding]' \
          '(-o --output)'{-o,--output}'=[output format]:format:(yaml json table csv)' \
          '*'{-r,--registry}'=[registry name filter]:registry' \
          '*--skip=[resources to skip]:resource' \
          '--platform=[target image platform]:platform' \
          '(-u --unique)'{-u,--unique}'[remove duplicates]' \
          '--image-regex=[regex for splitting templates]:regex' \
          '(-h --help)'{-h,--help}'[help for get command]' \
          '*:arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
