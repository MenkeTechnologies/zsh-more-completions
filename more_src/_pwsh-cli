#compdef pwsh powershell
# _pwsh-cli — PowerShell 7+ cross-platform shell (Microsoft); .NET Core-based shell with object pipelines
# upstream: https://github.com/PowerShell/PowerShell

_pwsh-cli() {
    _arguments \
        '(-Help -h -\?)'{-Help,-h,'-?'}'[show help]' \
        '(-Version -v)'{-Version,-v}'[show version]' \
        '-File+[script file]:file:_files -g "*.ps1"' \
        '-Command+[command string]:cmd:' \
        '-Login[as login shell]' \
        '-Interactive[interactive]' \
        '-NonInteractive[non-interactive]' \
        '-NoExit[no exit after command]' \
        '-NoLogo[no logo]' \
        '-NoProfile[no profile]' \
        '-NoProfileLoadTime[no profile load time]' \
        '-ConfigurationName+[remoting config name]:name:' \
        '-ConfigurationFile+[config file]:file:_files' \
        '-CustomPipeName+[custom pipe name]:name:' \
        '-EncodedCommand+[base64 command]:str:' \
        '-ExecutionPolicy+[execution policy]:policy:(Restricted AllSigned RemoteSigned Unrestricted Bypass Default)' \
        '-InputFormat+[input format]:fmt:(Text XML)' \
        '-OutputFormat+[output format]:fmt:(Text XML)' \
        '-SettingsFile+[settings file]:file:_files' \
        '-SSHServerMode[ssh server mode]' \
        '-WindowStyle+[window style]:style:(Normal Minimized Maximized Hidden)' \
        '-WorkingDirectory+[cwd]:dir:_files -/' \
        '*::args:'
}

_pwsh-cli "$@"
