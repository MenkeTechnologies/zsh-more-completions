#compdef bet
# bet — brain extraction tool (FSL)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-o[generate brain surface overlay]' \
  '-m[generate binary brain mask]' \
  '-s[generate approximate skull image]' \
  '-n[do not generate segmented brain output]' \
  '-f[fractional intensity threshold (0-1, default 0.5)]:threshold (0-1):' \
  '-g[vertical gradient in fractional intensity (-1 to 1)]:gradient:' \
  '-r[head radius (mm)]:radius (mm):' \
  '-c[centre-of-gravity (x y z voxels)]:x: :y: :z:' \
  '-t[apply thresholding to segmented brain and target mask]' \
  '-e[generates eye and optic nerve cleanup]' \
  '-B[bias field and neck cleanup]' \
  '-S[eye and optic nerve cleanup for small FOV]' \
  '-R[robust brain centre estimation (iterates bet)]' \
  '-Z[improve BET if FOV is very small in Z]' \
  '-F[apply to 2nd stage results]' \
  '-A[run bet2 and betsurf for optic nerve segmentation]' \
  '-A2[run with additional T2 image for optic nerve]:T2 image:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '1:input image:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '2:output image:_files -g "*.{nii,nii.gz,img,hdr}"'
