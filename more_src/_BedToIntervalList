#compdef BedToIntervalList
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/util/BedToIntervalList.java
# Picard: convert a BED file to a Picard interval list

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input BED file]:file:_files -g "*.bed"' \
  '(-SD --SEQUENCE_DICTIONARY)'{-SD,--SEQUENCE_DICTIONARY}'=[sequence dictionary or BAM/VCF/IntervalList source]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output Picard interval list]:file:_files' \
  '--SORT=[sort output interval list before writing]:b:(true false)' \
  '--UNIQUE=[merge overlapping regions before writing]:b:(true false)' \
  '--DROP_MISSING_CONTIGS=[drop entries on contigs missing from dictionary]:b:(true false)' \
  '--KEEP_LENGTH_ZERO_INTERVALS=[write length-zero intervals]:b:(true false)' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
