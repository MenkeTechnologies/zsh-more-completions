#compdef dmenu-run dmenu_run

# Zsh completion for dmenu-run / dmenu_run (dmenu application launcher)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b[Appear at the bottom of the screen]' \
  '-f[Grab keyboard before reading stdin]' \
  '-i[Match menu items case-insensitively]' \
  '-l+[List items vertically with given number of lines]:lines' \
  '-m+[Monitor number to display on]:monitor' \
  '-p+[Define the prompt to be displayed]:prompt' \
  '-fn+[Set the font or font set]:font' \
  '-nb+[Set the normal background color]:color' \
  '-nf+[Set the normal foreground color]:color' \
  '-sb+[Set the selected background color]:color' \
  '-sf+[Set the selected foreground color]:color' \
  '-w+[Set the window ID to embed into]:window id' \
  '-h+[Set minimum height of a menu line]:pixels' \
  '-v[Print version information]' && ret=0

return ret
