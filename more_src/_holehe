#compdef holehe
# Documentation: https://github.com/megadose/holehe
# OSINT: check if an email is used on different sites.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--only-used[display only the sites used by the target email]' \
  '--no-color[do not color terminal output]' \
  '--no-clear[do not clear the terminal to display results]' \
  '(-NP --no-password-recovery)'{-NP,--no-password-recovery}'[do not try password recovery on the websites]' \
  '(-C --csv)'{-C,--csv}'[create a CSV with the results]' \
  '(-T --timeout)'{-T+,--timeout=}'[set max timeout value (default 10)]:seconds:' \
  '*:email:_email_addresses' && ret=0

return ret
