#compdef cool-retro-term
# Documentation: https://github.com/Swordfish90/cool-retro-term/blob/master/app/main.cpp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--default-settings[run with default settings]' \
  '--workdir=[working directory]:dir:_files -/' \
  '--program=[program to run]:cmd:_command_names' \
  '(-p --profile)'{-p+,--profile=}'[profile name]:profile:(Default Amber Apple\ ][ Default Green Green\ Scanlines IBM\ DOS IBM\ 3278 Monochrome\ Green Vintage Default\ Pixelated Future Transparent\ Green)' \
  '--fullscreen[run fullscreen]' \
  '--verbose[print profiles and settings]' \
  '-e[command to execute (last option)]:cmd:_command_names' \
  '*:: :' && ret=0

return ret
