#compdef mri_segment
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_segment
# FreeSurfer: segment white matter from a normalized volume

local ret=1

_arguments -s -S \
  '-u[display usage information]' \
  '-nold_remove[disable removal of 1D strands]' \
  '-slope[adjust curvature slope]:s' \
  '-pslope[curvature pslope (default 1.0)]:p' \
  '-nslope[curvature nslope (default 1.0)]:n' \
  '-debug_voxel[debug voxel coordinates]:x y z' \
  '-auto[auto-detect class statistics]' \
  '-noauto[disable auto class statistics]' \
  '-log[log output to ./segment.dat]' \
  '-keep[preserve white matter edits]' \
  '-gray_hi[gray matter high limit]:h' \
  '-ghi[gray matter high limit]:h' \
  '-wm_low[white matter low limit]:l' \
  '-wlo[white matter low limit]:l' \
  '-wm_hi[white matter high limit]:h' \
  '-whi[white matter high limit]:h' \
  '-nseg[thicken n largest thin strands]:n' \
  '-thicken[toggle thickening step]' \
  '-fillbg[toggle filling of basal ganglia]' \
  '-fillv[toggle filling of ventricles]' \
  '-b[blur sigma (default 0.25)]:s' \
  '-n[border classification iterations]:i' \
  '-t[thin strand limit in mm]:t' \
  '-v[verbose output]' \
  '-p[percentage threshold (default 0.80)]:p' \
  '-x[extract options from file]:filename:_files' \
  '-w[window size (default 11)]:w' \
  '*:volume:_files' && ret=0

return ret
