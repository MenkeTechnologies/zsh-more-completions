#compdef rsem-bam2wig
# Documentation: https://github.com/deweylab/RSEM/blob/master/README.md
# RSEM: generate a wiggle file of expected read coverage from a sorted BAM

local ret=1

_arguments -s -S \
  '--no-fractional-weight[do not use fractional weights for multi-reads]' \
  '1:sorted bam input:_files -g "*.bam"' \
  '2:wig output:_files' \
  '3:wiggle name:' && ret=0

return ret
