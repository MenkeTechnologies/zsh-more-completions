#compdef otbcli_ConcatenateVectorData
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ConcatenateVectorData.html
# Orfeo ToolBox: concatenate multiple vector data files

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-vd[vector data files to concatenate]:vectors:_files' \
  '-out[output concatenated vector data file]:output:_files' \
  '*::arg:_files' && ret=0

return ret
