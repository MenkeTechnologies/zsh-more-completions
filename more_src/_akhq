#compdef akhq akhq-cli
# _akhq — Tchiotludo AKHQ akhq CLI command-line frontend wrapping the AKHQ open-source web GUI for managing Apache Kafka clusters formerly known as KafkaHQ providing topics consumers groups acls schemas connect-clusters kafka-connect KSQL nodes brokers cluster-name connections configuration import-export auth-LDAP-OIDC-SAML (Tchiotludo team, Java); custom argparse
# upstream: https://akhq.io/

_akhq() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'cluster:cluster operations'
        'topic:topic operations'
        'consumer-group:consumer group operations'
        'broker:broker operations'
        'acl:ACL operations'
        'schema:schema operations'
        'connect:Kafka Connect operations'
        'connector:connector operations'
        'ksql:KSQL operations'
        'node:node operations'
        'config:configuration'
        'auth:authentication'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server=+[url]:str:' \
        '--api-url=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '--insecure[skip TLS verify]' \
        '-c+[config file]:file:_files -g "akhq.yml *.yml *.yaml *.json"' \
        '--config=+[file]:file:_files -g "akhq.yml *.yml *.yaml *.json"' \
        '--cluster=+[name]:str:' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'akhq subcommand' sub ;;
        args)
            case $words[1] in
                cluster|topic|consumer-group|broker|acl|schema|connect|connector|ksql|node) _arguments '1:op:(list get create update delete describe reset)' '*:name:' ;;
            esac
            ;;
    esac
}

_akhq "$@"
