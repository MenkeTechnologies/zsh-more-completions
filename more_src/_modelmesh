#compdef modelmesh
# Documentation: https://man.archlinux.org/search?q=modelmesh
# Reference accessed: 2026-05-16

# ModelMesh: high-density serving for ML models (KServe / IBM)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[config file]:file:_files' \
  '--bootstrap-address=[bootstrap address]:host:_hosts' \
  '--bootstrap-port=[bootstrap port]:port:' \
  '--debug[debug logging]' \
  '*::modelmesh args:_files' && ret=0
return ret
