#compdef clearml-init
# Documentation: https://github.com/clearml/clearml
# Reference accessed: 2026-05-23
# Verified: clearml-init --help (ClearML configuration wizard).

# Zsh completion for clearml-init - ClearML configuration wizard

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-F --file)'{-F+,--file=}'[target configuration file]:file:_files' && ret=0

return ret
