#compdef aqua-registry argd
# _aqua-registry — CLI to develop aqua Registry (aquaproj/registry-tool)
# upstream: https://github.com/aquaproj/registry-tool
# Subcommands from USAGE.md (urfave-cli-v3).

_aqua-registry() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--log-level=[log level]:level:(debug info warn error)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                scaffold:'scaffold a package'
                s:'scaffold a package'
                create-pr-new-pkg:'create PR to add new packages'
                new:'create PR to add new packages'
                generate-registry:'update registry.yaml'
                gr:'update registry.yaml'
                init:'create configuration files'
                patch-checksum:'patch a checksum configuration'
                list-assets:'list release assets of a GitHub release'
                lsa:'list release assets'
                check-repo:'check if GitHub repository was transferred'
                mv:'rename a package'
                fix:'fix a package'
                connect:'connect to Docker container with shell'
                con:'connect to Docker container'
                remove:'remove Docker containers'
                rm:'remove Docker containers'
                remove-package:'remove a package from Docker containers'
                rmp:'remove a package'
                resolve-conflict:'resolve registry.yaml merge conflict with main'
                start:'start Docker containers'
                stop:'stop Docker containers'
                test:'test a package in Docker containers'
                t:'test a package'
                version:'show version'
                completion:'output shell completion script'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                scaffold|s)
                    _arguments \
                        '--cmd=[list of commands joined with quotes]:cmds:' \
                        '(-l --limit)'{-l+,--limit=}'[max number of versions (0=all)]:n:' \
                        '(-r --recreate)'{-r,--recreate}'[recreate Docker containers]' \
                        '(-B --no-create-branch)'{-B,--no-create-branch}'[do not create a git branch]' \
                        '(-c --config)'{-c+,--config=}'[path to scaffold.yaml]:file:_files' \
                        '1:package name:' ;;
            esac
            ;;
    esac
}

_aqua-registry "$@"
