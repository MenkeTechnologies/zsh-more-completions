#compdef puppet-lookup
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/lookup.md
# puppet lookup - perform Hiera lookups from the command line

local ret=1

_arguments -s -S \
  '--help[display help information]' \
  '--explain[show details about how the lookup was performed]' \
  '--explain-options[reveal whether lookup_options affects the query]' \
  '--node=[node whose data to retrieve]:node:_hosts' \
  '--facts=[JSON or YAML facts file]:file:_files' \
  '--environment=[environment to use for the data search]:environment:' \
  '--merge=[merge behavior]:strategy:(first unique hash deep)' \
  '--knock-out-prefix=[deep-merge prefix to remove values]:prefix:' \
  '--sort-merged-arrays[sort all merged arrays in deep merge]' \
  '--merge-hash-arrays[deep-merge hashes within arrays by position]' \
  '--default=[fallback value if Hiera finds no data]:value:' \
  '--type=[verify returned value matches data type]:typestring:' \
  '--compile[run full catalog compilation before lookup]' \
  '--render-as=[output format]:format:(s json yaml binary msgpack)' \
  '*:key:' && ret=0

return ret
