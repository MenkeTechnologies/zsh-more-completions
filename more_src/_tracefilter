#compdef tracefilter
# Documentation: https://manpages.debian.org/testing/libtrace-tools/tracefilter.1.en.html
# copy all packets that match a bpf expression to an output file

local ret=1

_arguments -s -S \
  ':input uri:_files' \
  ':bpf expression' \
  '*:output uri:_files' && ret=0

return ret
