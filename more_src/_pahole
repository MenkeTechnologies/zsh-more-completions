#compdef pahole

# Zsh completion for pahole - show/manipulate data structure layout from DWARF

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-C --class_name)'{-C,--class_name}'=[show only specified class]:class name' \
  '(-c --cacheline_size)'{-c,--cacheline_size}'=[set cacheline size]:size in bytes' \
  '(-E --expand_types)'{-E,--expand_types}'[expand class members]' \
  '(-F --format_path)'{-F,--format_path}'=[path for format specifications]:path:_files' \
  '(-H --header_type)'{-H,--header_type}'=[use specified type as header]:type name' \
  '(-i --contains)'{-i,--contains}'=[show classes that contain specified type]:type name' \
  '(-I --show_decl_info)'{-I,--show_decl_info}'[show declaration info (file and line)]' \
  '(-J --btf_encode)'{-J,--btf_encode}'[encode BTF information in the ELF file]' \
  '--btf_encode_detached=[encode BTF to detached file]:file:_files' \
  '--btf_encode_force[force BTF encoding even for unsupported features]' \
  '(-l --show_first_biggest_size_base_type_member)'{-l,--show_first_biggest_size_base_type_member}'[show first biggest size base type member]' \
  '(-M --show_only_data_members)'{-M,--show_only_data_members}'[show only data members]' \
  '(-m --nr_members)'{-m,--nr_members}'[show number of members]' \
  '(-n --nr_methods)'{-n,--nr_methods}'[show number of methods]' \
  '(-N --class_name_len)'{-N,--class_name_len}'[show class name length]' \
  '(-O --dwarf_offset)'{-O,--dwarf_offset}'=[show tag at specified DWARF offset]:offset' \
  '(-p --expand_pointers)'{-p,--expand_pointers}'[expand pointer members]' \
  '(-P --packable)'{-P,--packable}'[show structs that can be packed]' \
  '(-q --quiet)'{-q,--quiet}'[be quiet]' \
  '(-R --reorganize)'{-R,--reorganize}'[reorganize struct to save space]' \
  '(-r --rel_offset)'{-r,--rel_offset}'[show relative offsets of members]' \
  '(-s --sizes)'{-s,--sizes}'[show size of classes]' \
  '(-S --show_reorg_steps)'{-S,--show_reorg_steps}'[show reorganization steps]' \
  '(-t --separator)'{-t,--separator}'=[field separator]:separator' \
  '(-T --nr_definitions)'{-T,--nr_definitions}'[show number of definitions]' \
  '(-V --verbose)'{-V,--verbose}'[be verbose]' \
  '(-x --exclude)'{-x,--exclude}'=[exclude types with specified prefix]:prefix' \
  '(-X --cu_exclude)'{-X,--cu_exclude}'=[exclude compilation units with specified prefix]:prefix' \
  '(-z --hole_size_ge)'{-z,--hole_size_ge}'=[show only holes >= specified size]:size' \
  '--flat_arrays[flatten arrays]' \
  '--skip_encoding_btf_vars[skip encoding BTF variables]' \
  '--btf_gen_floats[allow BTF encoding of float types]' \
  '--lang=[only process compilation units written in specified language]:language' \
  '*:object file:_files -g "*.(o|ko|so|debug)(-.)"' && ret=0

return ret
