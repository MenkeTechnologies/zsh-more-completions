#compdef lovable
# _lovable — GPT Engineer Lovable AI app builder CLI for generating full-stack web apps from natural-language prompts with Supabase/Tailwind/Vite/React (lovable-dev team, TypeScript); commander.js
# upstream: https://lovable.dev/

_lovable() {
    local -a sub=(
        'login:login to account'
        'logout:logout'
        'whoami:show current user'
        'create:create new project'
        'pull:pull project to local'
        'push:push local changes'
        'list:list projects'
        'open:open project in browser'
        'preview:preview project'
        'deploy:deploy project'
        'connect:connect Supabase project'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--cwd=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '--api-key=+[key]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lovable subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--name=+[name]:str:' \
                    '--prompt=+[prompt]:str:' \
                    '--template=+[t]:t:(blank dashboard ecommerce blog landing-page marketplace saas social ai-app)' \
                    '--framework=+[f]:f:(react vue svelte solid astro next)' \
                    '--styling=+[s]:s:(tailwind css styled-components emotion)' \
                    '--backend=+[b]:b:(supabase firebase mongodb prisma drizzle)' \
                    '--auth=+[a]:a:(supabase clerk auth0 firebase nextauth)' ;;
                pull|push|open|preview|deploy) _arguments \
                    '*:project name:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_lovable "$@"
