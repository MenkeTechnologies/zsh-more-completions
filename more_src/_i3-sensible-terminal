#compdef i3-sensible-terminal
# Documentation: https://man.archlinux.org/search?q=i3-sensible-terminal
# Reference accessed: 2026-05-16

# i3-sensible-terminal: pick a sensible terminal
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:command/arg:_files' && ret=0
return ret
