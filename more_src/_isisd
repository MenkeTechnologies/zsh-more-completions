#compdef isisd
# Documentation: https://docs.frrouting.org/en/latest/isisd.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (isisd uses only FRR common options).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[print command line options]' \
  '(- *)'{-v,--version}'[print version and build information]' \
  '(-d --daemon)'{-d,--daemon}'[launch in daemon mode]' \
  '(-t --terminal)'{-t,--terminal}'[open an interactive VTY session on the terminal]' \
  '(-f --config_file)'{-f,--config_file}'+[configuration file to use]:file:_files' \
  '(-C --dryrun)'{-C,--dryrun}'[load config, check validity, then exit]' \
  '(-i --pid_file)'{-i,--pid_file}'+[pid file location]:file:_files' \
  '(-z --socket)'{-z,--socket}'+[override the path of the ZAPI socket]:file:_files' \
  '(-N --pathspace)'{-N,--pathspace}'+[insert pathspace into all default paths]:pathspace:' \
  '(-u --user)'{-u,--user}'+[user the daemon will switch to]:user:_users' \
  '(-g --group)'{-g,--group}'+[group the daemon will switch to]:group:_groups' \
  '(-S --skip_runas)'{-S,--skip_runas}'[skip setting effective user and group]' \
  '(-A --vty_addr)'{-A,--vty_addr}'+[IP/IPv6 address to bind the VTY to]:addr:' \
  '(-P --vty_port)'{-P,--vty_port}'+[override default TCP VTY port]:port:' \
  '--vty_socket=[directory used for socket files]:dir:_files -/' \
  '*'{-M,--module}'+[load a dynamically loadable module]:module:' \
  '--moduledir=[look for modules in specified directory]:dir:_files -/' && ret=0

return ret
