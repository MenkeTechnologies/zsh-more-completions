#compdef forbidigo
# Documentation: https://man.archlinux.org/search?q=forbidigo
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-set=[built-in pattern set]:set:(sample stdlib strings crypto)' \
  '-p+[forbidden pattern regexp]:pattern:' \
  '-exclude=[exclusion regexp]:regexp:' \
  '-analyze-types[perform type-aware matching]' \
  '-fix[apply fixes (experimental)]' \
  '*:packages or files:_files -g "*.go"'
