#compdef Dtrios
# Documentation: https://github.com/millanek/Dsuite
# Dsuite Dtrios: D (ABBA-BABA) and f4-ratio statistics for population trios.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-k --JKnum)'{-k+,--JKnum=}'[number of jackknife blocks (default 20)]:num:' \
  '(-j --JKwindow)'{-j+,--JKwindow=}'[jackknife block size in SNPs]:snps:' \
  '(-r --region)'{-r+,--region=}'[process VCF subset start,length]:start,length:' \
  '(-t --tree)'{-t+,--tree=}'[Newick tree file]:file:_files' \
  '(-o --out-prefix)'{-o+,--out-prefix=}'[output file prefix]:prefix:' \
  '(-n --run-name)'{-n+,--run-name=}'[run name for output files]:name:' \
  '--no-f4-ratio[omit f4-ratio calculations]' \
  '-l+[VCF line count (required for piped input)]:numlines:' \
  '(-g --use-genotype-probabilities)'{-g,--use-genotype-probabilities}'[use GP/GL/PL tags]' \
  '(-p --pool-seq)'{-p+,--pool-seq=}'[pool-seq mode min read depth]:min_depth:' \
  '(-c --no-combine)'{-c,--no-combine}'[skip combine file output]' \
  '--ABBAclustering[test ABBA-site clustering along genome]' \
  '*:file:_files' && ret=0

return ret
