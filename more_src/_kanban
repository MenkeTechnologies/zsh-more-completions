#compdef kanban
# Documentation: https://man.archlinux.org/search?q=kanban
# Reference accessed: 2026-05-16

# https://github.com/fulsomenko/kanban — TUI kanban (`KANBAN_FILE` env also supported)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::kanban_args:_default' && return 0
