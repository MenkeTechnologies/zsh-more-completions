#compdef afl-sync
# Documentation: https://github.com/rc0r/afl-utils
# Push/pull/sync afl-fuzz state directories with a storage location (afl-utils)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-S --session)'{-S,--session}'=[only sync fuzzers belonging to this afl-multicore session]:session' \
  '1:command:(push pull sync)' \
  '2:src sync dir:_files -/' \
  '3:dst storage dir:_files -/' && ret=0

return ret
