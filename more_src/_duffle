#compdef duffle

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:build a CNAB bundle'
      'install:install a CNAB bundle'
      'upgrade:upgrade an installed bundle'
      'uninstall:uninstall a bundle'
      'status:show bundle installation status'
      'list:list installed bundles'
      'bundle:manage bundles'
      'claims:manage claims'
      'credentials:manage credential sets'
      'export:export a bundle'
      'import:import a bundle'
      'logs:show logs for an installation'
      'pull:pull a bundle from a registry'
      'push:push a bundle to a registry'
      'relocate:relocate a bundle'
      'run:run a bundle action'
      'show:show bundle details'
      'sign:sign a bundle'
      'verify:verify a signed bundle'
      'version:show version'
    )
    _describe -t commands 'duffle command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--bundle=[bundle reference]:bundle:' \
          '-f+[bundle file]:bundle file:_files' \
          '--file=[bundle file]:bundle file:_files' \
          '--set=[set parameter value]:key=value:' \
          '-c+[credential set]:credential:' \
          '--credentials=[credential set]:credential:' \
          '--driver=[driver to use]:driver:(docker debug)' \
          '--insecure[allow insecure connections]' \
          '1:installation name:' && ret=0
        ;;
      upgrade|uninstall)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--set=[set parameter value]:key=value:' \
          '-c+[credential set]:credential:' \
          '--credentials=[credential set]:credential:' \
          '--driver=[driver to use]:driver:(docker debug)' \
          '1:installation name:' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[duffle.json file]:file:_files' \
          '--file=[duffle.json file]:file:_files' \
          '-o+[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '--sign[sign the bundle]' && ret=0
        ;;
    esac
    ;;
esac

return ret
