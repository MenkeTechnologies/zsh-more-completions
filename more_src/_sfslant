#compdef sfslant
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mslant.c
# Madagascar: time-space-domain Radon transform (slant stack)

local ret=1

_arguments -s -S \
  'verb=[verbosity flag]:verb:(y n)' \
  'adj=[adjoint flag]:adj:(y n)' \
  'rho=[rho filtering]:rho:(y n)' \
  'anti=[antialiasing]:anti' \
  'np=[number of p values (if adj=y)]:np' \
  'dp=[p sampling (if adj=y)]:dp' \
  'p0=[p origin (if adj=y)]:p0' \
  'x0=[offset origin]:x0' \
  'dx=[offset sampling]:dx' \
  'nx=[number of offsets]:nx' \
  'p1=[reference slope]:p1' \
  '*:RSF file:_files' && ret=0

return ret
