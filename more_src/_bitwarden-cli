#compdef bw

# Zsh completion for Bitwarden CLI (bw)
# Note: bw might already exist as _bw, this is bitwarden-cli specifically

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:log into a user account'
  'logout:log out of the current user account'
  'lock:lock the vault and destroy active session'
  'unlock:unlock the vault and return a session key'
  'sync:pull the latest vault data'
  'generate:generate a password/passphrase'
  'encode:base64 encode stdin'
  'config:configure CLI settings'
  'update:check for updates'
  'completion:generate shell completions'
  'status:show server, last sync, user info, and vault status'
  'list:list objects from the vault'
  'get:get an object from the vault'
  'create:create an object in the vault'
  'edit:edit an object in the vault'
  'delete:delete an object from the vault'
  'restore:restore an object from the trash'
  'move:move an item to an organization'
  'confirm:confirm an object to the organization'
  'import:import vault data'
  'export:export vault data'
  'share:move an item to an organization (deprecated)'
  'send:manage Bitwarden Send'
  'receive:access a Bitwarden Send'
  'serve:start a local API server'
)

_arguments -s -S \
  '--pretty[format output (JSON)]' \
  '--raw[return raw output]' \
  '--response[return a JSON formatted version of response output]' \
  '--cleanexit[exit with return code 0 on error]' \
  '--quiet[do not return anything to stdout]' \
  '--nointeraction[do not prompt for interactive user input]' \
  '--session=[pass session key]:session key:' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'bw command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      list)
        _arguments \
          '1:object type:(items folders collections organizations org-members org-collections)' \
          '--search=[search string]:search:' \
          '--url=[filter by URL]:url:' \
          '--folderid=[filter by folder ID]:folder id:' \
          '--collectionid=[filter by collection ID]:collection id:' \
          '--organizationid=[filter by organization ID]:org id:' \
          '--trash[list items in trash]'
        ;;
      get)
        _arguments \
          '1:object type:(item username password uri totp exposed attachment folder collection org-collection organization template fingerprint send)' \
          '2:object ID or search term:' \
          '--itemid=[item ID for attachment]:item id:' \
          '--output=[output directory for attachment]:directory:_files -/'
        ;;
      create)
        _arguments \
          '1:object type:(item attachment folder org-collection)' \
          '--file=[file for attachment]:file:_files' \
          '--itemid=[item ID for attachment]:item id:'
        ;;
      delete)
        _arguments \
          '1:object type:(item attachment folder org-collection)' \
          '2:object ID:' \
          '--itemid=[item ID for attachment]:item id:' \
          '--permanent[permanently delete]' \
          '--organizationid=[organization ID]:org id:'
        ;;
      generate)
        _arguments \
          '(-u --uppercase)'{-u,--uppercase}'[include uppercase]' \
          '(-l --lowercase)'{-l,--lowercase}'[include lowercase]' \
          '(-n --number)'{-n,--number}'[include numbers]' \
          '(-s --special)'{-s,--special}'[include special characters]' \
          '--length=[password length]:length:' \
          '(-p --passphrase)'{-p,--passphrase}'[generate passphrase]' \
          '--words=[number of words]:words:' \
          '--separator=[word separator]:separator:' \
          '--capitalize[capitalize passphrase words]' \
          '--includeNumber[include number in passphrase]'
        ;;
      export)
        _arguments \
          '--output=[output file]:file:_files' \
          '--format=[export format]:format:(csv json encrypted_json)' \
          '--organizationid=[organization ID]:org id:' \
          '--password=[encryption password]:password:'
        ;;
      import)
        _arguments \
          '1:format:(bitwardencsv bitwardenjson lastpasscsv chromecsv firefoxcsv keepass2xml 1aboratoriescsv 1aboratories1pif dashlancsv dashlanjson keepercsv nordpasscsv)' \
          '2:input file:_files' \
          '--organizationid=[organization ID]:org id:'
        ;;
      config)
        _arguments \
          '1:setting:(server)' \
          '2:value:'
        ;;
    esac
    ;;
esac

return ret
