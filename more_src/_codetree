#compdef codetree
# Documentation: http://astrometry.net/doc/build-index.html
# build a kdtree from an N-star code (shape descriptor) file

local ret=1

_arguments -s \
  '-h[show help]' \
  '-i+[input filename]:input:_files' \
  '-o+[output filename]:output:_files' \
  '-b[build bounding boxes]' \
  '-s[build splitting planes]' \
  '-t+[tree type]:tree type:(double float u32 u16)' \
  '-d+[data type]:data type:(double float u32 u16)' \
  '-S[include separate splitdim array]' \
  '-R+[target leaf node size (default 25)]:leaf size:' && ret=0

return ret
