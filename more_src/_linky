#
# WHAT IS conf AND WHY IS IT THE 66TH TS-NODE CLI LIBRARY?
#
# conf (https://github.com/sindresorhus/conf, 1,341+ stars) is
# **Sindre Sorhus's "Simple config handling for your app or
# module"** — a Node.js library for FIXED-LOCATION PERSISTENT
# JSON STORAGE of application configuration.  Where cosmiconfig
# (R631) DISCOVERS read-only config files left by users,
# conf MAINTAINS a read/write JSON store at a project-aware,
# XDG-compliant filesystem location that the application itself
# manages.  Used heavily by Electron apps + CLI tools that need
# to persist user auth tokens / preferences / per-session state.
#
# conf's distinguishing characteristics:
#
#   1. FIXED-LOCATION PERSISTENT JSON STORE — conf's central
#      feature is a JSON-file-backed key-value store at a
#      consistent filesystem location:
#
#          import Conf from 'conf';
#
#          // Creates a store at:
#          //   Linux:   $XDG_CONFIG_HOME/linky/config.json
#          //            (typically ~/.config/linky/config.json)
#          //   macOS:   ~/Library/Preferences/linky/config.json
#          //   Windows: %APPDATA%/linky/Config/config.json
#          const store = new Conf({
#              projectName: 'linky',
#              projectVersion: '2.0.0',
#          });
#
#          store.set('token', 'abc123');
#          const token = store.get('token');  // 'abc123'
#          store.has('token');                // true
#          store.delete('token');
#          store.clear();
#
#      Compare:
#         * Rust config-rs (R629): builder for read-only config
#         * Rust figment (R633): provider-based read-only config
#         * Rust confy: fixed-location persistent (Rust analog)
#         * Go viper (R630): global singleton, read-only
#         * Go koanf (R634): per-instance, read-only
#         * Node cosmiconfig (R631): file discovery, read-only
#         * Node dotenv: env-vars only, read-only
#         * conf: FIXED-LOCATION READ/WRITE JSON store
#      FIRST documented Node.js Axis 13 library with project-
#      aware persistent read/write JSON storage as primary
#      design.
#
#   2. XDG-COMPLIANT PROJECT-AWARE PATHS via env-paths — conf
#      uses the env-paths package internally to compute the
#      correct config location per platform + project:
#
#          import envPaths from 'env-paths';
#          const paths = envPaths('myapp');
#          paths.config  // → /home/user/.config/myapp
#          paths.data    // → /home/user/.local/share/myapp
#          paths.cache   // → /home/user/.cache/myapp
#          paths.log     // → /home/user/.local/state/myapp
#          paths.temp    // → /tmp/myapp
#
#      conf automatically uses `paths.config + '/config.json'`
#      as the default store location, ensuring XDG Base
#      Directory Specification compliance on Linux + matching
#      platform conventions on macOS/Windows.
#      Compare:
#         * Rust confy: similar XDG-compliant default
#         * Rust directories: similar (used by many Rust CLIs)
#         * Go: most config libs don't auto-resolve XDG
#         * Node node-config: NODE_ENV-based + manual path
#         * conf: XDG + macOS/Windows conventions BUILT-IN
#      FIRST documented Node.js Axis 13 library with cross-
#      platform XDG-compliant path resolution.
#
#   3. TYPESCRIPT-FIRST GENERIC STORE TYPE — conf v10+ has
#      strict TypeScript generic typing:
#
#          type LinkyStoreType = {
#              token: string;
#              prm?: string;
#              lastUsedAt?: Date;
#          };
#
#          const store = new Conf<LinkyStoreType>({
#              projectName: 'linky',
#          });
#
#          // Type-checked at compile time:
#          store.set('token', 'abc');     // ✓ string expected
#          store.set('token', 123);        // ✗ type error
#          const token: string | undefined = store.get('token');
#
#      Compare:
#         * Rust config-rs (R629): serde type-safety
#         * Rust figment (R633): serde extraction type-safety
#         * Go viper (R630): runtime type coercion only
#         * Node cosmiconfig (R631): generic loose typing
#         * conf: TYPESCRIPT GENERIC StoreType parameter
#      FIRST documented Node.js Axis 13 library with
#      TypeScript generic parameterization for compile-time
#      type checking of store schema.
#
#   4. JSON SCHEMA VALIDATION + ENCRYPTION + MIGRATIONS — conf
#      ships with rich features beyond basic JSON storage:
#
#          const store = new Conf({
#              projectName: 'myapp',
#              // JSON Schema for validation:
#              schema: {
#                  token: { type: 'string', minLength: 10 },
#                  prm: { type: 'string', pattern: '^[0-9]+$' },
#              },
#              // Encryption-at-rest for sensitive values:
#              encryptionKey: process.env.APP_ENCRYPTION_KEY,
#              // Schema migrations across version upgrades:
#              migrations: {
#                  '>=2.0.0': (store: any) => {
#                      // Migrate from v1.x to v2.x
#                      store.clear();
#                  },
#                  '>=3.0.0': (store: any) => {
#                      // Rename "key" to "apiKey" in v3
#                      const old = store.get('key');
#                      if (old) {
#                          store.set('apiKey', old);
#                          store.delete('key');
#                      }
#                  },
#              },
#              projectVersion: '3.0.0',
#          });
#
#      Compare:
#         * Rust confy: simple persistence, no encryption
#         * Go viper (R630): no encryption or schema migrations
#         * Go koanf (R634): no encryption built-in
#         * Node cosmiconfig (R631): no encryption (read-only)
#         * Node electron-store: depends on conf internally
#         * conf: JSON Schema + encryption + migrations BUILT-IN
#      FIRST documented Node.js Axis 13 library with JSON
#      Schema validation + encryption-at-rest + schema-version
#      migrations as built-in primitives.
#
#   5. SINDRE SORHUS / CHALK-ORG ECOSYSTEM PROVENANCE — conf is
#      by Sindre Sorhus, author of ~1500+ npm packages.  Sindre's
#      cross-axis presence in the taxonomy is unmatched — THREE+
#      documented libraries:
#         * boxen (Axis 7 / Box Drawing — R600 _wtfjs)
#         * wrap-ansi (Axis 12 / Text Wrapping — R627 _bundown,
#                       chalk-org maintained)
#         * conf (Axis 13 / Configuration Files — R635 THIS)
#      Plus many transitively-documented Sindre libraries:
#         * chalk — terminal coloring (TOP-10 npm package)
#         * ora — spinners
#         * pretty-bytes, pretty-ms — humanization helpers
#         * execa — child_process replacement
#         * got — HTTP client
#         * query-string — URL query parser
#         * env-paths — XDG paths (used by conf internally)
#         * update-notifier — npm update checker
#         * normalize-url, slugify, camelcase, kebabcase
#         * ~1500 more
#      Downstream conf users:
#         * Electron apps (electron-store wraps conf)
#         * stepci/stepci (API testing, 1.9k stars)
#         * ginobefun/BestBlogs (3.7k stars)
#         * bokub/linky (THIS — French smart meter)
#         * uetchy/github-social
#         * BearStudio/create-start-ui
#         * jschuur/localtime-cli
#         * kognise/crypticat
#         * 600+ Node CLIs needing persistent state
#      FIRST documented Node.js Axis 13 library with this
#      specific Sindre-Sorhus / 1500-packages / chalk-org
#      ecosystem provenance.
#
# conf's relationship to cosmiconfig (R631) and other Axis 13
# libraries:
#
#   * Unlike cosmiconfig (R631, Node) — cosmiconfig is READ-ONLY
#                                         discovery of config files
#                                         left by users; conf is
#                                         READ/WRITE store managed
#                                         by the app itself
#   * Closest cross-language analogs:
#         * Rust confy — DIRECT PARALLEL (fixed-location
#                          persistent JSON; both use env-paths-
#                          like XDG resolution)
#         * Rust directories — similar XDG path utility
#         * Go viper (R630, with WriteConfig) — different
#                                                 (singleton-based)
#         * Python platformdirs — similar XDG path utility
#     conf is the SECOND documented Node.js Axis 13 library
#     providing fixed-location read/write persistent JSON storage
#     + XDG-compliant project-aware paths + TypeScript generic
#     typing + JSON Schema validation + encryption + migrations +
#     Sindre Sorhus ecosystem provenance.
#
# -----------------------------------------------------------------------------
#
# THE linky CLI — meow + conf + chalk + ora + dayjs + update-notifier
#
# linky's CLI is in bin/cli.ts.  Uses meow for argument parsing
# (Sindre Sorhus's minimal meow library — CLI helper that wraps
# yargs-parser):
#
#     import meow from 'meow';
#     import { auth } from './auth.js';
#     import { type MeteringFlags, type Format, MeteringHandler } from './metering.js';
#     import chalk from 'chalk';
#     import ora from 'ora';
#     import updateNotifier from 'update-notifier';
#     import dayjs from 'dayjs';
#
#     const cli = meow(mainHelp, {
#         importMeta: import.meta,
#         description: false,
#         flags: {
#             prm: { type: 'string', shortFlag: 'p' },
#             token: { type: 'string', shortFlag: 't' },
#             start: { type: 'string', shortFlag: 's', default: yesterday },
#             end: { type: 'string', shortFlag: 'e', default: today },
#             output: { type: 'string', shortFlag: 'o' },
#             format: { type: 'string', shortFlag: 'f', default: 'pretty' },
#             quiet: { type: 'boolean', shortFlag: 'q', default: false },
#         },
#     });
#
#     switch (cli.input[0]) {
#         case 'auth':     auth(cli.flags.token); break;
#         case 'daily':    new MeteringHandler(meteringFlags).daily(); break;
#         case 'loadcurve': new MeteringHandler(meteringFlags).loadcurve(); break;
#         case 'maxpower': new MeteringHandler(meteringFlags).maxpower(); break;
#         case 'dailyprod': new MeteringHandler(meteringFlags).dailyprod(); break;
#         case 'loadcurveprod': new MeteringHandler(meteringFlags).loadcurveprod(); break;
#         default: cli.showHelp();
#     }
#
# Conf usage in bin/store.ts:
#
#     import Conf from 'conf';
#     import { pkg } from './pkg.js';
#
#     const TOKEN = 'token';
#
#     const store = new Conf({
#         projectName: 'linky',
#         projectVersion: pkg.version,
#         migrations: {
#             '>=2.0.0': (store: any) => {
#                 store.clear();
#             },
#         },
#     });
#
#     export function getToken() {
#         return store.get(TOKEN, undefined) as string | undefined;
#     }
#
#     export function saveToken(token: string) {
#         return store.set(TOKEN, token);
#     }
#
# Six subcommands:
#   auth           — connect via Enedis token
#   daily          — daily consumption
#   loadcurve      — 30-min load curve
#   maxpower       — daily max power
#   dailyprod      — daily production
#   loadcurveprod  — 30-min production curve
#
# Flags:
#   -t, --token       Enedis token (overrides stored)
#   -p, --prm         PRM number (when multiple)
#   -s, --start       Start date YYYY-MM-DD (default: yesterday)
#   -e, --end         End date YYYY-MM-DD (default: today)
#   -o, --output      Output file
#   -f, --format      Output format: pretty/json/csv
#   -q, --quiet       Suppress progress messages
#
# Five-axis distinctness from cosmiconfig (R631):
#
#   1. FIXED-LOCATION PERSISTENT JSON — conf maintains a
#      read/write JSON store; cosmiconfig is read-only file
#      discovery.
#
#   2. XDG-COMPLIANT PROJECT-AWARE PATHS — conf auto-resolves
#      XDG/macOS/Windows config locations via env-paths;
#      cosmiconfig has no path resolution beyond cwd walking.
#
#   3. TYPESCRIPT GENERIC StoreType — conf v10+ has compile-time
#      type-checked store schema; cosmiconfig has loose typing.
#
#   4. JSON SCHEMA + ENCRYPTION + MIGRATIONS — conf has rich
#      built-in features for production use; cosmiconfig is
#      file-discovery only.
#
#   5. SINDRE-SORHUS / CHALK-ORG PROVENANCE — conf is Sindre's
#      THIRD library in the taxonomy after boxen (R600) +
#      wrap-ansi (R627).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/bokub/linky/blob/master/bin/cli.ts
# meow flag definitions + subcommand switch on cli.input[0].)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _linky_cmds _linky_formats
_linky_cmds=(
    'auth:connect to Enedis account via token'
    'daily:retrieve daily consumption (kWh)'
    'loadcurve:retrieve 30-min load curve (W)'
    'maxpower:retrieve daily max consumption (VA)'
    'dailyprod:retrieve daily production (solar)'
    'loadcurveprod:retrieve 30-min production curve'
    'help:show help'
)
_linky_formats=(
    'pretty:colorized table output (default)'
    'json:machine-readable JSON output'
    'csv:spreadsheet-compatible CSV output'
)

_arguments -C \
    '(-t --token)'{-t+,--token=}'[Enedis token (overrides stored)]:token:_default' \
    '(-p --prm)'{-p+,--prm=}'[PRM number (when multiple available)]:prm:_default' \
    '(-s --start)'{-s+,--start=}'[start date YYYY-MM-DD (default yesterday)]:date:_default' \
    '(-e --end)'{-e+,--end=}'[end date YYYY-MM-DD (default today)]:date:_default' \
    '(-o --output)'{-o+,--output=}'[output file]:output:_files' \
    '(-f --format)'{-f+,--format=}'[output format]:format:(pretty json csv)' \
    '(-q --quiet)'{-q,--quiet}'[suppress progress messages]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'linky subcommand' _linky_cmds && ret=0
        ;;
    args)
        case $words[1] in
            auth)
                _arguments \
                    '(-t --token)'{-t+,--token=}'[Enedis token from https://conso.boris.sh]:token:_default' \
                    && ret=0
                ;;
            daily|loadcurve|maxpower|dailyprod|loadcurveprod)
                _arguments \
                    '(-s --start)'{-s+,--start=}'[start date YYYY-MM-DD]:date:_default' \
                    '(-e --end)'{-e+,--end=}'[end date YYYY-MM-DD]:date:_default' \
                    '(-p --prm)'{-p+,--prm=}'[PRM number]:prm:_default' \
                    '(-t --token)'{-t+,--token=}'[Enedis token]:token:_default' \
                    '(-f --format)'{-f+,--format=}'[output format]:format:(pretty json csv)' \
                    '(-q --quiet)'{-q,--quiet}'[suppress progress messages]' \
                    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
