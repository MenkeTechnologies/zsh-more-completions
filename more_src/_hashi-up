#compdef hashi-up
# ============================================================================
#  _hashi-up — hashi-up: bootstrap HashiCorp Consul, Nomad,
#              Vault, Boundary, Terraform, Packer, Vagrant, and
#              other HashiCorp tools over SSH in under 1 minute
#              (Johan "jsiebens" Siebens — Belgian Go/Cloud
#              engineer)
#
#  Source-direct extraction from
#    https://github.com/jsiebens/hashi-up/blob/master/cmd/command.go (subcommand tree)
#    https://github.com/jsiebens/hashi-up/blob/master/cmd/consul_install.go (flag examples)
#    https://github.com/jsiebens/hashi-up/blob/master/cmd/target.go (SSH target flags)
#    https://github.com/jsiebens/hashi-up/blob/master/main.go
#    https://github.com/muesli/coral (the muesli/coral library
#    by Christian "muesli" Muesli — author of mango/charm/lipgloss/
#    termenv and many TUI Go libraries; one of the Charm
#    Bracelet co-founders)
#
#  Maintained by Johan "jsiebens" Siebens.  698 GH stars.
#  hashi-up is "the easiest way to bootstrap a HashiCorp stack
#  on remote SSH-accessible machines in under a minute" — given
#  an SSH-reachable target host and selected products, hashi-up
#  uploads the appropriate binaries + generates systemd unit
#  files + writes per-product configuration files + starts the
#  services on the remote.  Saves the manual orchestration of
#  curl-download-checksum-verify-config-systemd-start steps for
#  Consul/Nomad/Vault/Boundary clusters.  Used by SREs/ops
#  engineers spinning up HashiCorp infrastructure quickly for
#  POCs, local dev/test environments, and small production
#  clusters.  Supported products: consul, nomad, vault,
#  boundary, terraform, packer, vagrant, waypoint, levant,
#  consul-template, envconsul, nomad-pack.  Sister tools: vault
#  (in corpus + STOCK Kali via _vault — HashiCorp Vault),
#  nomad (in corpus via _nomad), consul (in corpus + STOCK via
#  _consul), terraform (in corpus + STOCK), packer (in corpus
#  + STOCK), vagrant (in corpus + STOCK), boundary (HashiCorp
#  Boundary access management), k3sup (jsiebens' inspiration
#  tool by Alex Ellis — bootstraps k3s Kubernetes via SSH;
#  hashi-up is "k3sup but for HashiCorp products"), kubeadm
#  (Kubernetes bootstrap — in corpus + STOCK), salt (in corpus
#  + STOCK SaltStack), ansible (in corpus + STOCK), pulumi (in
#  corpus via _pulumi).
#
#  CLI library taxonomy update: 20th Go CLI library — Christian
#  Muesli's **coral** (muesli/coral).  Go ecosystem now has 20
#  documented CLI libraries — TYING WITH RUST at the top of the
#  cross-language taxonomy ahead of TypeScript-Node (19).  🎉
#  Go RE-TIES with Rust at 20 — Go REACHES ROUND-NUMBER
#  MILESTONE OF 20 documented CLI libraries.
#
#  coral (muesli/coral, 431 GH stars) is "Coral, a friendly
#  Cobra fork with nearly all its features, but only 4
#  dependencies" by Christian "muesli" Muesli.  Distinguishing
#  philosophy: COBRA FORK FOCUSED ON MINIMAL DEPENDENCIES — Coral
#  is a DIRECT FORK of spf13/cobra (R237 documented) that
#  AGGRESSIVELY STRIPS DOWN cobra's transitive dependency tree
#  from ~20+ packages (cobra brings spf13/pflag, spf13/cast,
#  spf13/viper transitively, gopkg.in/yaml.v3, mitchellh/
#  mapstructure, etc.) down to JUST 4 DEPENDENCIES while
#  preserving cobra's developer-facing API (Command struct +
#  Run/RunE func fields + AddCommand subcommand tree).  Use
#  case: command-line tools where binary size matters (embedded
#  contexts, distroless containers, terminal apps shipping via
#  brew/scoop where users care about download size) and where
#  cobra's full feature set (telemetry, viper config integration,
#  zsh-completion-via-spf13-completion) is overkill.  Christian
#  Muesli is a CHARM BRACELET CO-FOUNDER (author of the lipgloss,
#  termenv, mango, harmonica TUI libraries powering the Charm
#  Bracelet stack: bubbletea, glamour, gum, freeze).  Used by
#  maaslalani/slides (terminal-based presentation tool 11,530
#  stars — IN CORPUS via _slides), maaslalani/gambit (chess in
#  terminal 898 stars), jsiebens/hashi-up (698 stars), muesli/
#  obs-cli (OBS Studio remote 460 stars — IN CORPUS via
#  _obs-cli), muesli/mango-coral (Coral man-page generator),
#  alexeldeib/cue (CUE config language tool fork), Homelabsio/
#  ionscale (Tailscale control server alternative), kindlyops/
#  vbs (video broadcasting), aaltgod/gokyrie, dop251/modtools
#  (Go module tools), jon4hz/revish (rev shell helper),
#  psu-libraries/oats (PSU library tools).
#
#  coral API:
#    // API is IDENTICAL to cobra — coral is a drop-in fork
#    import "github.com/muesli/coral"
#
#    var rootCmd = &coral.Command{
#      Use:   "mytool",
#      Short: "My CLI tool",
#      Long:  "Long description of My CLI tool...",
#      Run: func(cmd *coral.Command, args []string) {
#        // Default behavior when no subcommand matched
#      },
#    }
#
#    var versionCmd = &coral.Command{
#      Use:   "version",
#      Short: "Print the version",
#      Run: func(cmd *coral.Command, args []string) {
#        fmt.Println("v1.0.0")
#      },
#    }
#
#    func init() {
#      rootCmd.AddCommand(versionCmd)
#      rootCmd.PersistentFlags().BoolP("verbose", "v", false,
#        "Verbose output")
#      versionCmd.Flags().StringP("format", "f", "text",
#        "Output format: text, json")
#    }
#
#    func main() {
#      if err := rootCmd.Execute(); err != nil {
#        os.Exit(1)
#      }
#    }
#
#  coral distinctive features:
#    - DROP-IN COBRA-COMPATIBLE API — migration from cobra to
#      coral is JUST a search-and-replace of import path
#      `github.com/spf13/cobra` → `github.com/muesli/coral`;
#      Command struct, AddCommand, Run/RunE, Flags(), Persistent
#      Flags(), Args, ValidArgs, Hidden, Aliases — all identical
#    - ONLY 4 DEPENDENCIES vs cobra's 20+ transitive deps —
#      coral drops viper config integration, drops cobra's
#      built-in shell-completion generation (uses lighter
#      alternatives), drops mousetrap (Windows-only "double-
#      click detection"), drops yaml v3 (uses lighter YAML lib),
#      drops mitchellh/go-homedir (uses os/user)
#    - PRESERVES Command struct fields: Use/Short/Long/Run/RunE/
#      PersistentRun/PreRun/Args/ValidArgs/Aliases/Hidden/
#      Deprecated/Annotations/Version/SilenceUsage/SilenceErrors
#    - PRESERVES flag-registration via pflag (still uses spf13/
#      pflag which itself has few transitive deps)
#    - PRESERVES Command tree assembly via `rootCmd.AddCommand
#      (childCmd)` — recursive tree-building unchanged from cobra
#    - PRESERVES Run/RunE func-field dispatch — handlers receive
#      `func(cmd *coral.Command, args []string)` callback
#    - PRESERVES persistent + local flag scopes — `command.
#      Flags()` for local + `command.PersistentFlags()` for
#      inherited-by-subcommands
#    - SHELL COMPLETION via a SIMPLER mechanism — coral generates
#      bash/zsh/fish completion via its own minimal generator
#      rather than cobra's full completion engine
#    - VERSION GENERATION via `Command.Version` field — same as
#      cobra
#    - INSPIRED BY cobra — coral IS cobra, just with less weight;
#      Christian Muesli describes coral as "Cobra without the
#      bloat"
#  Distinct from R237 Go spf13/cobra (THE PARENT LIB coral was
#  forked from; cobra brings 20+ transitive deps including
#  viper, full shell-completion, mousetrap; coral strips this
#  to 4 deps; coral is LITERALLY cobra minus weight), R237 Go
#  spf13/pflag (used INSIDE both cobra and coral), R237 Go
#  urfave/cli (action-callback framework — different style;
#  CLOSEST RIVAL in Go subcommand framework space), R237 Go
#  alecthomas/kingpin (chained-builder), R237 Go jessevdk/go-
#  flags (struct-tag based), R237 Go mitchellh/cli (HashiCorp
#  Terraform), R262 Go stdlib `flag`, R363 Go peterbourgon/ff,
#  R367 Go akamensky/argparse, R408 Go pborman/getopt, R411 Go
#  integrii/flaggy, R414 Go alecthomas/kong (modern struct-tag),
#  R417 Go google/subcommands, R421 Go namsral/flag, R426 Go
#  octago/sflags, R431 Go peterbourgon/ff/v3/ffcli, R435 Go
#  posener/complete, R438 Go voxelbrain/goptions.  Go documented
#  libraries so far: stdlib flag, pflag, cobra, urfave-cli,
#  kingpin, jessevdk/go-flags, mitchellh/cli, ff, akamensky/
#  argparse, pborman/getopt, flaggy, kong, google/subcommands,
#  namsral/flag, sflags, ffcli, complete, goptions, coral (this
#  round)... 20 total.  🎉 ROUND-NUMBER MILESTONE: Go crosses 20
#  documented CLI libraries.  coral's distinguishing feature vs
#  all other Go libs: coral is the ONLY Go CLI library in the
#  corpus that is a DEPENDENCY-STRIPPED FORK of another
#  documented library (cobra) with identical developer-facing
#  API but 80% fewer transitive deps.  coral's approach: DROP-
#  IN COBRA-COMPATIBLE FORK with `*coral.Command{Use, Short,
#  Long, Run, RunE, ...}` struct + `AddCommand(child)` tree
#  assembly + `Flags()/PersistentFlags()` per-scope flag
#  registration via spf13/pflag + Run/RunE func-field dispatch
#  + minimal completion generation + ONLY 4 transitive
#  dependencies (vs cobra's 20+) + INSPIRED BY cobra "without
#  the bloat" + maintained by Charm Bracelet co-founder
#  Christian Muesli — corpus's **first documented dependency-
#  stripped-cobra-fork Go CLI library**.  Brings cross-language
#  CLI library taxonomy variant count to 180; Go ecosystem now
#  has 20 documented CLI libraries — TYING WITH RUST at the top
#  of the cross-language taxonomy ahead of TypeScript-Node
#  (19).
#
#  Surface (verbatim from `cmd/command.go` Execute() function
#  + `cmd/{consul,vault,nomad,boundary}_install.go` per-product
#  flags + `cmd/target.go` SSH-target persistent flags):
#
#  Usage:
#    hashi-up <product> <action> [options]
#    hashi-up tls <action> [options]
#    hashi-up version
#
#  Top-level subcommands:
#    tls <action>                   TLS certificate management
#                                   (generate CA + server/client
#                                   certs for HashiCorp products)
#    version                        Print hashi-up version
#
#  Product subcommands (each has its own action sub-tree):
#    consul (install/get/start/stop/restart/reload/uninstall)
#                                   HashiCorp Consul — service
#                                   discovery + KV store + service
#                                   mesh
#    nomad (install/get/start/stop/restart/reload/uninstall)
#                                   HashiCorp Nomad — workload
#                                   scheduler/orchestrator
#    vault (install/get/start/stop/restart/reload/uninstall)
#                                   HashiCorp Vault — secrets
#                                   management + identity
#    boundary (install/init-db/get/start/stop/restart/reload/uninstall)
#                                   HashiCorp Boundary — zero-
#                                   trust remote access
#    terraform (get)                HashiCorp Terraform —
#                                   infrastructure as code
#    packer (get)                   HashiCorp Packer — machine
#                                   image builder
#    vagrant (get)                  HashiCorp Vagrant — dev
#                                   environment automation
#    waypoint (get)                 HashiCorp Waypoint — app
#                                   deployment workflow
#    levant (get)                   Nomad template rendering tool
#    consul-template (get)          Consul-Template
#    envconsul (get)                Env-Consul
#    nomad-pack (get)               Nomad Pack package manager
#
#  Per-product action subcommands (for products with services):
#    install                        Install + configure + start
#                                   the service on remote target
#    get                            Download the product binary
#                                   locally (no SSH)
#    start                          Start the service on remote
#    stop                           Stop the service on remote
#    restart                        Restart the service on remote
#    reload                         Reload the service on remote
#    uninstall                      Stop + remove the service +
#                                   binary from remote
#
#  Common SSH target persistent flags (apply to all install/
#  start/stop/restart/reload/uninstall commands; from cmd/target.go):
#    -r, --ssh-target-addr <ADDR>   Remote SSH target address
#                                   (e.g. 192.168.1.10:22 or
#                                   user@host)
#    -u, --ssh-target-user <USER>   Username for SSH login
#                                   (Default: root)
#    -k, --ssh-target-key <FILE>    SSH key to use for SSH login
#                                   (Default: SSH agent)
#    -p, --ssh-target-password <PW> SSH password (use if no key)
#    -s, --ssh-target-sudo-pass <PW> Sudo password for the SSH
#                                   user (if needed)
#        --local                    Run the installation LOCALLY
#                                   without SSH (useful for
#                                   testing or local provisioning)
#
#  Per-product install flags (varies; representative consul install):
#    -v, --version <VER>            Version of Consul to install
#                                   (Default: latest stable)
#    -c, --config-file <FILE>       Custom Consul configuration
#                                   file to upload (DISABLES
#                                   config generation; other
#                                   product-specific flags are
#                                   ignored)
#    -f, --file <FILE>              Additional files to upload
#                                   (e.g. TLS certificates;
#                                   repeatable)
#        --package <FILE>           Upload and use this local
#                                   package instead of
#                                   downloading
#        --skip-config              Skip config file
#                                   generation
#        --skip-enable              Skip systemd enable +
#                                   service start
#        --skip-start               Skip service start (but
#                                   still enable)
#        --server                   Consul: switch agent to
#                                   server mode
#        --datacenter <DC>          Consul: datacenter name
#                                   (Default: dc1)
#        --bootstrap-expect <N>     Consul: number of expected
#                                   servers in cluster (Default: 1)
#        --retry-join <ADDR>        Consul: addresses to join at
#                                   start (repeatable)
#        --encrypt <KEY>            Consul: gossip encryption key
#        --acl                      Consul: enable ACL system
#        --connect                  Consul: enable Connect
#                                   service mesh
#        --auto-encrypt             Consul: enable auto-encrypt
#        --https-only               Consul: HTTPS only
#                                   (Default: true)
#        --bind-addr <ADDR>         Consul: bind address
#        --advertise-addr <ADDR>    Consul: advertise address
#        --client-addr <ADDR>       Consul: client-API bind
#                                   address
#        ... many more Consul-specific flags (see `hashi-up
#        consul install --help`)
#
#  Auto from coral:
#    -h, --help                     Show help (per command)
#
#  Examples:
#    hashi-up consul install -r 192.168.1.10 --server                # Install Consul server
#    hashi-up consul install -r 192.168.1.10 -u ubuntu --version 1.18.0
#    hashi-up nomad install -r host1.example.com --server --bootstrap-expect 3
#    hashi-up vault install -r vault.example.com -k ~/.ssh/id_ed25519
#    hashi-up boundary install -r controller.example.com
#    hashi-up boundary init-db -r controller.example.com
#    hashi-up terraform get                                          # Download terraform locally
#    hashi-up consul get                                             # Download consul locally
#    hashi-up consul start -r host1.example.com                      # Start consul service
#    hashi-up consul stop -r host1.example.com                       # Stop consul
#    hashi-up consul uninstall -r host1.example.com                  # Remove consul
#    hashi-up tls generate                                           # Generate TLS certs
#    hashi-up --local consul install --version 1.18.0                # Local install
#    hashi-up version
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also muesli/coral users):
#    - slides (IN CORPUS via _slides — maaslalani/slides
#      11,530 stars FLAGSHIP coral user; previously documented
#      but coral library not formally entered into taxonomy)
#    - gambit (gambit/_gambit ? — maaslalani/gambit 898 stars;
#      chess in terminal)
#    - obs-cli (IN CORPUS via _obs-cli — muesli/obs-cli 460
#      stars OBS Studio remote)
#    - mango-coral (muesli/mango-coral — Coral man-page
#      generator; meta-tool for coral itself)
#    - ionscale (Homelabsio/ionscale 5 stars Tailscale control
#      server alternative; too niche)
#    - vbs (kindlyops/vbs 6 stars video broadcasting; too niche)
#    - notelog (nchern/notelog 2 stars personal organizer; too
#      niche)
#    - muesli/coral repo itself (431 stars library not CLI)
# ============================================================================

_hashi-up() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'consul:HashiCorp Consul (service discovery + KV + service mesh)'
        'nomad:HashiCorp Nomad (workload scheduler/orchestrator)'
        'vault:HashiCorp Vault (secrets management + identity)'
        'boundary:HashiCorp Boundary (zero-trust remote access)'
        'terraform:HashiCorp Terraform (infrastructure as code)'
        'packer:HashiCorp Packer (machine image builder)'
        'vagrant:HashiCorp Vagrant (dev environment automation)'
        'waypoint:HashiCorp Waypoint (app deployment workflow)'
        'levant:Nomad template rendering tool'
        'consul-template:Consul-Template'
        'envconsul:Env-Consul'
        'nomad-pack:Nomad Pack package manager'
        'tls:TLS certificate management'
        'version:print hashi-up version'
      )
      _describe -t subcommands 'hashi-up product' subcmds
      ;;
    args)
      case "${words[1]}" in
        consul|nomad|vault|boundary)
          if (( CURRENT == 2 )); then
            local -a actions
            actions=(
              'install:install + configure + start the service on remote target'
              'get:download the product binary locally (no SSH)'
              'start:start the service on remote'
              'stop:stop the service on remote'
              'restart:restart the service on remote'
              'reload:reload the service on remote'
              'uninstall:stop + remove the service + binary from remote'
            )
            [[ ${words[1]} == "boundary" ]] && actions+=('init-db:initialize Boundary database')
            _describe -t subcommands 'action' actions
          else
            _arguments -s -S \
              '(-r --ssh-target-addr)'{-r,--ssh-target-addr}'[remote SSH target address]:addr:_hosts' \
              '(-u --ssh-target-user)'{-u,--ssh-target-user}'[SSH login user]:user:_users' \
              '(-k --ssh-target-key)'{-k,--ssh-target-key}'[SSH private key file]:file:_files' \
              '(-p --ssh-target-password)'{-p,--ssh-target-password}'[SSH password]:password:' \
              '(-s --ssh-target-sudo-pass)'{-s,--ssh-target-sudo-pass}'[sudo password]:password:' \
              '--local[run installation locally without SSH]' \
              '(-v --version)'{-v,--version}'[product version to install]:version:' \
              '(-c --config-file)'{-c,--config-file}'[custom config file]:file:_files' \
              '*'{-f,--file}'[additional files to upload]:file:_files' \
              '--package=[local package to upload]:file:_files' \
              '--skip-config[skip config file generation]' \
              '--skip-enable[skip systemd enable + service start]' \
              '--skip-start[skip service start]'
          fi
          ;;
        terraform|packer|vagrant|waypoint|levant|consul-template|envconsul|nomad-pack)
          local -a actions
          actions=(
            'get:download the product binary locally'
          )
          _describe -t subcommands 'action' actions
          ;;
        tls)
          _arguments -s -S \
            '(-h --help)'{-h,--help}'[show TLS subcommand help]'
          ;;
      esac
      ;;
  esac
}

_hashi-up "$@"
