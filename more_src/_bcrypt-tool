#compdef bcrypt-tool
# Documentation: https://man.archlinux.org/search?q=bcrypt-tool
# Reference accessed: 2026-05-16

# bcrypt-tool: hash/verify passwords using bcrypt
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'hash:hash a password'
  'match:check password against a hash'
  'cost:show estimated cost'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-c[bcrypt cost (4-31)]:cost:' \
  '--cost=[bcrypt cost (4-31)]:cost:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'bcrypt-tool command' commands && ret=0 ;;
esac
return ret
