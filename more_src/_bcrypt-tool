#compdef bcrypt-tool
# Documentation: https://github.com/shoenig/bcrypt-tool
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bcrypt-tool: hash/verify passwords using bcrypt

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'hash:generate a bcrypt hash given password and optional cost (4-31)'
  'match:check whether a password matches a hash'
  'cost:determine the cost (4-31) of a hash'
)
_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'bcrypt-tool command' commands && ret=0 ;;
esac
return ret
