#compdef listhen
# Documentation: https://github.com/unjs/listhen
# unjs HTTP listener and dev server

_arguments -s -S \
  '(-p --port)'{-p,--port}'[port to listen on]:port:' \
  '--host[host to listen on]:host:' \
  '--https[enable HTTPS]' \
  '--clipboard[copy URL to clipboard]' \
  '--open[open URL in browser]' \
  '--public[expose to public network]' \
  '--baseURL[base URL path]:path:' \
  '--name[server name]:name:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:entry point:_files' \
  && return 0
