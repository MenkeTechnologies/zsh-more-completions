#compdef encore
# Documentation: https://man.archlinux.org/search?q=encore
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'app:app commands'
  'auth:authentication'
  'build:build app'
  'check:check the app'
  'completion:generate shell completion'
  'daemon:daemon commands'
  'db:database commands'
  'eject:eject Docker artifact'
  'env:env commands'
  'gen:generate code'
  'help:show help'
  'k8s:k8s configure'
  'logs:show logs'
  'namespace:namespace commands'
  'redis:open redis CLI'
  'run:run app locally'
  'secret:secret commands'
  'test:run tests'
  'version:show version'
  'vpn:VPN management'
  'whoami:show user'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--app=[app id]:id:' \
  '*--env=[environment]:e:' \
  '*-c+[config]:c:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'encore command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--listen=[listen address]:addr:' \
          '--port=[port]:p:' \
          '--watch[watch for changes]' \
          '--debug[debug]' \
          '--browser=[browser auto/never/always]:b:(auto never always)' \
          '*: :' && ret=0 ;;
      (db)
        _arguments \
          '1:subcommand:(shell reset proxy conn-uri schema)' \
          '*: :' && ret=0 ;;
      (auth)
        _arguments \
          '1:subcommand:(login logout signup)' \
          '*: :' && ret=0 ;;
      (env)
        _arguments \
          '1:subcommand:(create get list set remove update)' \
          '*: :' && ret=0 ;;
      (secret)
        _arguments \
          '1:subcommand:(get list set archive unarchive)' \
          '*: :' && ret=0 ;;
      (app)
        _arguments \
          '1:subcommand:(create init list clone)' \
          '*: :' && ret=0 ;;
      (vpn)
        _arguments '1:subcommand:(start stop status)' '*: :' && ret=0 ;;
      (gen)
        _arguments '1:subcommand:(client wrappers)' '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
