#compdef shuffleBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/shuffle.html
# randomly permute genomic locations of features (bedtools shuffle)

local ret=1

_arguments -s -S \
  '-i[input BED/GFF/VCF file]:file:_files' \
  '-g[genome file defining chromosome sizes]:file:_files' \
  '-excl[BED of coordinates where features may not be placed]:file:_files' \
  '-incl[BED of coordinates where features should be placed]:file:_files' \
  '-chrom[keep features on their original chromosome]' \
  '-seed[integer seed for the shuffling]:seed' \
  '-f[max overlap (fraction of -i) with an -excl feature]:fraction' \
  '-chromFirst[select chromosome first, then random position]' \
  '-bedpe[treat input file as BEDPE format]' \
  '-maxTries[max attempts to place a shuffled interval]:n' \
  '-noOverlapping[prevent shuffled intervals from overlapping]' \
  '-allowBeyondChromEnd[permit intervals past chromosome boundaries]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
