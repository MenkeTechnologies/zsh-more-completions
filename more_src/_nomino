#compdef nomino

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --dir)'{-d,--dir}'=[directory to process]:directory:_directories' \
  '(-r --regex)'{-r,--regex}'=[regex pattern for matching]:pattern' \
  '(-s --sort)'{-s,--sort}'=[sort order]:order:(asc desc)' \
  '(-e --extension)'{-e,--extension}'=[filter by file extension]:extension' \
  '(-g --generate)'{-g,--generate}'=[generate output filename pattern]:pattern' \
  '(-m --mkdir)'{-m,--mkdir}'[create directories in output path]' \
  '(-p --print)'{-p,--print}'[print results without renaming]' \
  '(-t --test)'{-t,--test}'[test mode, show what would be renamed]' \
  '(-w --overwrite)'{-w,--overwrite}'[overwrite existing files]' \
  '--max-depth=[maximum directory depth]:depth' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:input pattern' && ret=0

return ret
