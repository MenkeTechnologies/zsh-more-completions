#compdef psrplot
# Documentation: http://psrchive.sourceforge.net/manuals/psrplot/
# PSRCHIVE: produce customized, publication quality plots.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-p+[which plot to use]:plot:' \
  '*-c+[plotting configuration options]:config:' \
  '-j+[preprocessing operations before plotting]:jobs:' \
  '-l+[index dimension for iterative plotting]:index:' \
  '-P[list all available plots]' \
  '-C+[show options specific to a plot type]:plot:' \
  '-A+[show common options and defaults for a plot]:plot:' \
  '*:archive:_files' && ret=0

return ret
