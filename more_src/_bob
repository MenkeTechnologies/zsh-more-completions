#compdef bob

# Zsh completion for bob (Neovim version manager)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'use:Switch to a specified Neovim version'
      'install:Install a specified Neovim version'
      'uninstall:Uninstall a specified Neovim version'
      'erase:Remove all Neovim versions and bob data'
      'list:List installed Neovim versions'
      'ls-remote:List available Neovim versions'
      'update:Update an installed Neovim version'
      'rollback:Rollback to a previous Neovim version'
      'complete:Generate shell completions'
    )
    _describe -t commands 'bob command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      use|install|uninstall|update)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:version:(stable nightly latest)' && ret=0
        ;;
      ls-remote)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      complete)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:shell:(bash zsh fish elvish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
