#compdef jfrog

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'rt:Artifactory commands'
      'ds:Distribution commands'
      'xr:Xray commands'
      'mc:Mission Control commands'
      'pl:Pipelines commands'
      'c:config commands'
      'atc:access commands'
      'completion:generate shell completion'
      'project:project commands'
      'docker:Docker commands'
      'npm:npm commands'
      'go:Go commands'
      'pip:pip commands'
      'pipenv:pipenv commands'
      'poetry:poetry commands'
      'nuget:NuGet commands'
      'dotnet:dotnet commands'
      'gradle:Gradle commands'
      'mvn:Maven commands'
      'terraform:Terraform commands'
      'scan:on-demand scanning'
      'audit:audit project dependencies'
      'curation:curation commands'
      'setup:set up JFrog environment'
    )
    _describe -t commands 'jfrog command' commands && ret=0
    ;;
  args)
    case $line[1] in
      rt)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--server-id=[server ID]:id' \
          '--url=[Artifactory URL]:url' \
          '--user=[username]:user' \
          '--password=[password]:password' \
          '--access-token=[access token]:token' \
          '1:subcommand:(upload download delete search copy move props set-props delete-props build-publish build-collect-env build-add-git build-scan build-promote build-distribute build-discard build-clean curl ping repo-create repo-update repo-delete permission-target-create permission-target-update permission-target-delete replication-create replication-delete transfer-config-merge transfer-files)' && ret=0
        ;;
      xr)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--server-id=[server ID]:id' \
          '--url=[Xray URL]:url' \
          '1:subcommand:(audit scan curl)' && ret=0
        ;;
      c)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(add edit delete show use export import)' && ret=0
        ;;
      docker)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--server-id=[server ID]:id' \
          '1:subcommand:(push pull scan promote)' && ret=0
        ;;
      npm)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--server-id=[server ID]:id' \
          '1:subcommand:(install ci publish)' && ret=0
        ;;
      go)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--server-id=[server ID]:id' \
          '1:subcommand:(build publish)' && ret=0
        ;;
      audit|scan)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--server-id=[server ID]:id' \
          '--watches=[watches list]:watches' \
          '--project=[project key]:project' \
          '--licenses[show licenses]' \
          '--format=[output format]:format:(table json sarif simple-json)' \
          '*:path:_files' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
