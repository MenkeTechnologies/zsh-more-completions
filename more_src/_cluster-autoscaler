#compdef cluster-autoscaler
# _cluster-autoscaler — Kubernetes Cluster Autoscaler
# upstream: https://github.com/kubernetes/autoscaler
# Flags from cluster-autoscaler/config/flags/flags.go on tip.

_cluster-autoscaler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--cluster-name=[autoscaled cluster name]:name:' \
        '--address=[Prometheus metrics bind host\:port]:host\:port:' \
        '--kubernetes=[Kubernetes master URL]:url:_urls' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--kube-api-content-type=[apiserver request content type]:type:' \
        '--kube-client-burst=[client burst]:n:' \
        '--kube-client-qps=[client QPS]:f:' \
        '--cloud-config=[cloud provider configuration file]:file:_files' \
        '--cloud-provider=[cloud provider name]:name:(aws gce azure alicloud bizflycloud cherryservers civo cloudstack digitalocean exoscale externalgrpc hetzner ionoscloud kamatera kubemark kwok linode magnum oci ovhcloud packet rancher scaleway tencentcloud vultr clusterapi gardener brightbox)' \
        '--namespace=[CA runtime namespace]:ns:' \
        '--enforce-node-group-min-size=[scale up to configured min size]:bool:(true false)' \
        '--scale-down-enabled[enable scale-down]' \
        '--scale-down-unready-enabled=[scale down unready nodes]:bool:(true false)' \
        '--scale-down-delay-after-add=[scale-down delay after scale-up]:dur:' \
        '--scale-down-delay-type-local=[per-node-group scale-down delay]:bool:(true false)' \
        '--scale-down-delay-after-delete=[scale-down delay after delete]:dur:' \
        '--scale-down-delay-after-failure=[scale-down delay after failure]:dur:' \
        '--scale-down-unneeded-time=[time before unneeded node is removed]:dur:' \
        '--scale-down-unready-time=[time before unready node is removed]:dur:' \
        '--scale-down-utilization-threshold=[utilization threshold for scale-down]:f:' \
        '--scale-down-gpu-utilization-threshold=[GPU utilization threshold]:f:' \
        '--scale-down-non-empty-candidates-count=[max non-empty scale-down candidates]:n:' \
        '--scale-down-candidates-pool-ratio=[scale-down candidate pool ratio]:f:' \
        '--scale-down-candidates-pool-min-count=[scale-down candidate pool min count]:n:' \
        '--scheduler-config=[in-tree scheduler plugin config]:file:_files' \
        '--node-deletion-delay-timeout=[max wait for delay-deletion annotations]:dur:' \
        '--node-deletion-batcher-interval=[scale-down node batching interval]:dur:' \
        '--scan-interval=[cluster re-evaluation interval]:dur:' \
        '--max-nodes-total=[hard cap on cluster node count]:n:' \
        '--cores-total=[cluster cores min:max]:min\:max:' \
        '--memory-total=[cluster memory min:max (GiB)]:min\:max:' \
        '--max-bulk-soft-taint-count=[max soft taints per loop]:n:' \
        '--max-bulk-soft-taint-time=[max time for soft taints per loop]:dur:' \
        '--max-graceful-termination-sec=[pod termination wait]:s:' \
        '--max-total-unready-percentage=[max %% unready nodes]:f:' \
        '--ok-total-unready-count=[allowed unready node count]:n:' \
        '--scale-up-from-zero=[allow scale-up from 0 nodes]:bool:(true false)' \
        '--parallel-scale-up[allow parallel node-group scale-up]' \
        '--salvo-scale-up[allow multiple scale-ups per loop]' \
        '--salvo-scale-up-budget=[max time spent on subsequent scale-ups per loop]:dur:' \
        '--max-node-provision-time=[default max wait for node to be provisioned]:dur:' \
        '--max-node-startup-time=[max wait from register to ready]:dur:' \
        '--max-pod-eviction-time=[max time to evict a single pod]:dur:' \
        '--estimator=[scale-up estimator]:name:(binpacking)' \
        '--expander=[node-group expander]:name:(random most-pods least-waste priority grpc price)' \
        '--grpc-expander-cert=[gRPC expander TLS cert]:file:_files' \
        '--grpc-expander-url=[gRPC expander server URL]:url:_urls' \
        '--ignore-daemonsets-utilization=[ignore daemonsets when computing utilization]:bool:(true false)' \
        '--ignore-mirror-pods-utilization=[ignore mirror pods when computing utilization]:bool:(true false)' \
        '--write-status-configmap=[write status to ConfigMap]:bool:(true false)' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '-v[klog verbosity level]:n:'
}

_cluster-autoscaler "$@"
