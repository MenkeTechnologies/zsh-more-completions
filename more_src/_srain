#compdef srain
# Documentation: https://man.archlinux.org/search?q=srain
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-gapplication[show GApplication options]' \
  '(- *)--help-gtk[show GTK+ options]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --no-auto)'{-a,--no-auto}'[do not auto-connect to configured servers]' \
  '--display=[X display to use]:display:' && ret=0

return ret
