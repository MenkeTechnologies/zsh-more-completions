#compdef ams
# _ams — ALSA Modular Synth (royvegard/ams)
# upstream: https://github.com/royvegard/ams
# Flags from src/main.cpp (getopt_long).

_ams() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--verbose}'[verbose output]'
        '(- *)'{-V,--version}'[show version]'
        '(-J --jack)'{-J,--jack}'[use the JACK audio backend]'
        '(-A --alsa)'{-A,--alsa}'[use the ALSA audio backend]'
        '--jack_session_uuid=[JACK session UUID]:uuid:'
        '(-d --device)'{-d+,--device=}'[ALSA device]:device:'
        '(-C --capture)'{-C+,--capture=}'[ALSA capture device]:device:'
        '(-P --playback)'{-P+,--playback=}'[ALSA playback device]:device:'
        '(-p --periodsize)'{-p+,--periodsize=}'[audio period size]:size:'
        '--nfrag=[number of audio period fragments]:n:'
        '(-r --rate)'{-r+,--rate=}'[sample rate]:rate:'
        '(-i --in)'{-i+,--in=}'[number of input channels]:n:'
        '(-o --out)'{-o+,--out=}'[number of output channels]:n:'
        '(-y --poly)'{-y+,--poly=}'[polyphony]:n:'
        '(-e --edge)'{-e+,--edge=}'[edge mode (smooth/sharp)]:mode:'
        '(-D --presetdir)'{-D+,--presetdir=}'[preset directory]:dir:_files -/'
        '--nogui[no graphical user interface]'
        '(-N --name)'{-N+,--name=}'[application / JACK client name]:name:'
        '*:preset / patch file:_files -g "*.{ams,cfg}"'
    )
    _arguments -s $args
}

_ams "$@"
