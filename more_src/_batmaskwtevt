#compdef batmaskwtevt
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/batmaskwtevt.html
# Compute BAT mask weighting for events at a given sky position (ray tracing)

local ret=1

_arguments -s -S \
  'infile=[input BAT event file]:infile:_files' \
  'attitude=[Swift attitude history file or NONE]:attitude:_files' \
  'ra=[right ascension in decimal degrees]:ra:' \
  'dec=[declination in decimal degrees]:dec:' \
  'aperture=[BAT aperture map file, CALDB or CALDB:apertype]:aperture:' \
  'coord_type=[coordinate system]:coord_type:(sky tanxy cartesian unit fswlonlat grmclonlat)' \
  'rebalance=[adjust mask weight map to zero mean]:rebalance:(yes no)' \
  'corrections=[corrections to apply]:corrections:' \
  'pcodethresh=[minimum partial coding fraction]:pcodethresh:' \
  'detmask=[detector quality map file]:detmask:_files' \
  'auxfile=[auxiliary diagnostics output file]:auxfile:_files' \
  'filtexpr=[event filtering expression]:filtexpr:' \
  'bat_z=[source BAT_Z position in cm]:bat_z:' \
  'maskwtcol=[mask weight column name]:maskwtcol:' \
  'distance=[default source distance in cm]:distance:' \
  'maskthickness=[lead mask tile thickness in cm]:maskthickness:' \
  'distfile=[distortion correction FITS file or CALDB]:distfile:' \
  'buffersize=[internal event buffer size]:buffersize:' \
  'subpixsize=[detector subpixel size in cm]:subpixsize:' \
  'teldef=[telescope description file or CALDB]:teldef:' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
