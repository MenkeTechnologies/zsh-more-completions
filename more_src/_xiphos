#compdef xiphos
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/xiphos.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed: -v/--version, -q/--quiet, -d/--debug, -r/--remote, -s/--systemcalls
# (none in upstream Ubuntu/Debian xiphos(1) manpage).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[display help options]' \
  '--help-all[show all available help options]' \
  '--help-gtk[display GTK+ specific options]' \
  '--display=[X display to use]:display:' \
  '*:passage:' && ret=0

return ret
