#compdef xiphos
# Documentation: https://man.archlinux.org/search?q=xiphos
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[do not print warnings]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-r --remote)'{-r,--remote}'+[send remote command]:cmd:' \
  '(-s --systemcalls)'{-s,--systemcalls}'[debug systemcalls]' \
  '*:passage:' && ret=0

return ret
