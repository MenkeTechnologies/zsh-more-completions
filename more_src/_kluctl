#compdef kluctl

_kluctl_commands() {
  local -a commands=(
    'deploy:Deploy to target cluster'
    'diff:Show diff between local and remote'
    'delete:Delete from target cluster'
    'prune:Prune orphaned resources'
    'poke-images:Poke images to update'
    'validate:Validate deployment'
    'render:Render deployment manifests'
    'list-images:List images used in deployment'
    'list-targets:List available targets'
    'controller:Kluctl controller commands'
    'gitops:GitOps commands'
    'oci:OCI commands'
    'completion:Generate shell completion'
    'version:Print version'
    'help:Show help'
    'webui:Start the Kluctl Web UI'
  )
  _describe -t commands 'kluctl command' commands
}

_kluctl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --version)'{-v,--version}'[Print version]' \
    '--debug[Enable debug logging]' \
    '--no-color[Disable colored output]' \
    '1:command:_kluctl_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        deploy|diff|delete|prune|validate)
          _arguments \
            '(-t --target)'{-t,--target}'[Target name]:target:' \
            '--target-context[Kubernetes context]:context:' \
            '(-a --arg)'{-a,--arg}'[Argument key=value]:arg:' \
            '(-f --from-archive)'{-f,--from-archive}'[Deploy from archive]:file:_files' \
            '--project-dir[Project directory]:dir:_directories' \
            '--kubeconfig[Kubeconfig path]:file:_files' \
            '--context[Kubernetes context]:context:' \
            '--dry-run[Dry run mode]' \
            '--force-apply[Force apply]' \
            '--replace-on-error[Replace on error]' \
            '--abort-on-error[Abort on first error]' \
            '--readiness-timeout[Readiness timeout]:timeout:' \
            '--no-wait[Do not wait for readiness]' \
            '--prune[Enable pruning]' \
            '-y[Skip confirmations]' \
            '--yes[Skip confirmations]' \
            '--output-format[Output format]:format:(text yaml)' \
            '--render-output-dir[Directory for rendered output]:dir:_directories' \
            '--inclusion[Resource inclusion]:inclusion:' \
            '--exclusion[Resource exclusion]:exclusion:'
          ;;
        render)
          _arguments \
            '(-t --target)'{-t,--target}'[Target name]:target:' \
            '(-a --arg)'{-a,--arg}'[Argument key=value]:arg:' \
            '--project-dir[Project directory]:dir:_directories' \
            '--output-dir[Output directory]:dir:_directories' \
            '--print-all[Print all rendered manifests]'
          ;;
        gitops)
          local -a subcommands=(
            'deploy:Deploy via GitOps'
            'diff:Show diff via GitOps'
            'prune:Prune via GitOps'
            'validate:Validate via GitOps'
            'reconcile:Reconcile deployment'
            'suspend:Suspend reconciliation'
            'resume:Resume reconciliation'
            'logs:Show controller logs'
          )
          _describe -t subcommands 'gitops subcommand' subcommands
          ;;
        oci)
          local -a subcommands=(
            'push:Push deployment to OCI'
            'pull:Pull deployment from OCI'
          )
          _describe -t subcommands 'oci subcommand' subcommands
          ;;
        controller)
          local -a subcommands=(
            'install:Install the controller'
            'run:Run the controller locally'
          )
          _describe -t subcommands 'controller subcommand' subcommands
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_kluctl "$@"
