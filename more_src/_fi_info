#compdef fi_info
# Documentation: https://man.archlinux.org/search?q=fi_info
# Reference accessed: 2026-05-16

# fi_info: libfabric provider info utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-n[node name]:host:_hosts' \
  '--node=[node name]:host:_hosts' \
  '-p[provider name]:provider:(verbs sockets tcp psm psm2 psm3 efa shm udp rxm rxd ofi_rxm ofi_rxd ucx opx cxi)' \
  '--provider=[provider name]:provider:(verbs sockets tcp psm psm2 psm3 efa shm udp rxm rxd ofi_rxm ofi_rxd ucx opx cxi)' \
  '-e[endpoint type]:type:(MSG DGRAM RDM SOCK_STREAM SOCK_DGRAM)' \
  '--ep_type=[endpoint type]:type:(MSG DGRAM RDM SOCK_STREAM SOCK_DGRAM)' \
  '-a[address format]:fmt:' \
  '--addr_format=[address format]:fmt:' \
  '-c[caps]:caps:' \
  '--caps=[caps]:caps:' \
  '-m[mode]:mode:' \
  '--mode=[mode]:mode:' \
  '-f[fabric name]:name:' \
  '--fabric=[fabric name]:name:' \
  '-d[domain name]:name:' \
  '--domain=[domain name]:name:' \
  '-t[op_flags]:flags:' \
  '--op_flags=[op_flags]:flags:' \
  '-l[list providers only]' \
  '--list[list providers only]' \
  '*::fi_info args:_files' && ret=0
return ret
