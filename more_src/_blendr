# WHAT IT IS
#   blendr is "the hacker's BLE (bluetooth low energy) browser terminal app"
#   — a Rust + ratatui + crossterm vim-style terminal client for inspecting
#   Bluetooth Low Energy peripherals around you.  It scans the local
#   Bluetooth radio for BLE devices, lets you browse their advertised
#   services and characteristics, connects to a chosen peripheral, and
#   reads / writes / subscribes-to characteristic values — all from a
#   TUI with hexyl-rendered binary payloads and copypasta clipboard
#   integration.  Optional name-map files let you alias raw UUIDs to
#   human-readable labels (e.g. `0000FFE0-...=Cpu Temperature`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/cli_args.rs clap-derive Args)
#   blendr [OPTIONS]
#
#   Options:
#     -a, --adapter-index <N>       Bluetooth adapter hardware index
#                                   (if many available)             [default 0]
#     -i, --scan-interval <MS>      Scan interval in milliseconds   [default 1000]
#     -r, --regex-flags <FLAGS>     Regex flags for filter queries  [default "(?i)"]
#                                   pass "" for case-sensitive
#     -d, --device <NAME>           Device name to search for on start
#                                   (auto-connects if only one match found)
#     -c, --characteristic <UUID|NAME>
#                                   Characteristic / service UUID or name
#                                   search applied on start (auto-selects
#                                   if only one match found)
#         --names-map-file <PATH>   Path to .ini-like UUID=NAME map file
#                                   (key-value pairs;  example:
#                                    `0000FFE0-0000-1000-8000-00805F9B34FB=Cpu Temperature`)
#         --sort <SORT>             Default sort type for all views and lists
#                                   (`name` | `default-sort`)
#         --log-level <LEVEL>       Log level (`debug` | `error`;
#                                   default `error`).  Logs written to
#                                   $TMPDIR/blendr/*-cli.log, rotated daily.
#     -h, --help                    Show help
#     -V, --version                 Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `btleplug = "0.11.5"` declared in Cargo.toml — the
#   canonical Rust BLE library maintained by the deviceplug organization
#   (the same project ecosystem behind buttplug.io).  btleplug provides a
#   unified async BLE API across CoreBluetooth (macOS / iOS), BlueZ
#   (Linux, via dbus), and WinRT (Windows).  blendr's `src/bluetooth.rs`
#   module wraps the `btleplug::platform::Manager` to scan, connect, and
#   exchange characteristic data with peripherals.  Verified via:
#     gh api repos/dmtrKovalenko/blendr/contents/Cargo.toml
#       → btleplug = "0.11.5"
#       → use btleplug::platform::Manager  (in src/main.rs)
#   This entry is the Rust=117 leader bump that OPENS Axis 62
#   (Bluetooth Low Energy (BLE) Library), pairing with future
#   Go=tinygo-org/bluetooth and TS-Node=noble / @abandonware/noble poles
#   to close the axis at 1/1/1.
#
#   No completion for `blendr` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_blendr() {
    _arguments -s \
        '(-a --adapter-index)'{-a+,--adapter-index=}'[Bluetooth adapter hardware index (default 0)]:index:' \
        '(-i --scan-interval)'{-i+,--scan-interval=}'[scan interval in milliseconds (default 1000)]:ms:' \
        '(-r --regex-flags)'{-r+,--regex-flags=}'[regex flags for filter queries (default "(?i)")]:flags:' \
        '(-d --device)'{-d+,--device=}'[device name to search for on start (auto-connects on single match)]:device name:' \
        '(-c --characteristic)'{-c+,--characteristic=}'[characteristic/service UUID or name search]:uuid or name:' \
        '--names-map-file=[path to .ini-like UUID=NAME map file]:names file:_files -g "*.(ini|map|conf|txt)"' \
        '--sort=[default sort type for views and lists]:sort:(name default-sort)' \
        '--log-level=[log level (default error)]:level:(debug error)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

_blendr "$@"
