#compdef pitivi
# Documentation: https://man.archlinux.org/search?q=pitivi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-all[show all help options]' \
  '--help-gtk[show GTK options]' \
  '--version[show version]' \
  '(-d --debug)'{-d,--debug}'[run with python debug enabled]' \
  '(-i --import)'{-i,--import}'[import sources into project]' \
  '*:project or media file:_files -g "*.xges *.mp4 *.mkv *.webm *.mov *.avi *.wav *.flac *.ogg *.mp3"' && ret=0

return ret
