#compdef pitivi
# Documentation: https://developer.pitivi.org/Command_line_tools.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pitivi is a GTK application; CLI surface is minimal.
# Treat positional args as project (.xges) or media files.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-all[show all help options]' \
  '--help-gtk[show GTK options]' \
  '--version[show version]' \
  '*:project or media file:_files -g "*.xges *.mp4 *.mkv *.webm *.mov *.avi *.wav *.flac *.ogg *.mp3"' && ret=0

return ret
