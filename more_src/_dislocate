#compdef dislocate
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/dislocate.1.html
# Disconnect and reconnect processes from a controlling terminal

local ret=1

_arguments -s \
  '-escape[set the escape character (default ^])]:char:' \
  '*::program:_command_names -e' && ret=0

return ret
