#compdef pizauth
# Documentation: https://github.com/ltratt/pizauth
# Source: ltratt/pizauth src/main.rs — command-line OAuth2 authentication daemon.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _pz_cmds
_pz_cmds=(
    'dump:dump the cache state'
    'info:show pizauth info (config path, version, etc.)'
    'refresh:force a token refresh for the given account'
    'restore:restore previously dumped cache state'
    'reload:reload the configuration file'
    'revoke:revoke and discard the token for the given account'
    'server:run the pizauth daemon'
    'show:show the access token for the given account'
    'shutdown:shut down the running daemon'
    'status:print accounts and their token status'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '*-v[increase verbosity (repeatable)]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'pizauth command' _pz_cmds && ret=0
        ;;
    args)
        case $words[1] in
            info)
                _arguments \
                    '-j[JSON output]' \
                    '-c+[path to pizauth.conf]:file:_files' \
                    && ret=0
                ;;
            refresh|show)
                _arguments \
                    '-u[do not wait for confirmation, retrieve token even if expired]' \
                    '1:account:_default' \
                    && ret=0
                ;;
            revoke)
                _arguments '1:account:_default' && ret=0
                ;;
            server)
                _arguments \
                    '-c+[path to pizauth.conf]:file:_files' \
                    '-d[run in foreground (do not daemonize)]' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
