#compdef pypeit_tellfit
# Documentation: https://pypeit.readthedocs.io/en/release/scripts.html
# Telluric correct a spectrum

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '--objmodel=[object model used for telluric fitting]:model:(qso star poly)' \
  '(-r --redshift)'{-r,--redshift}'[redshift for the object model]:redshift' \
  '(-g --tell_grid)'{-g,--tell_grid}'[file with telluric model spectra]:file:_files' \
  '(-p --pca_file)'{-p,--pca_file}'[QSO PCA file]:file:_files' \
  '(-t --tell_file)'{-t,--tell_file}'[configuration file for telluric parameters]:file:_files' \
  '--debug[show debug plots]' \
  '--plot[show the telluric corrected spectrum]' \
  '--par_outfile=[name of output file to save parameters]:file:_files' \
  '--chk_version[ensure datamodels are from the current PypeIt version]' \
  '*:spec1d or coadd file:_files -g "*.fits"' && ret=0

return ret
