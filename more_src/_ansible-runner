#compdef ansible-runner

# Zsh completion for ansible-runner (Ansible execution framework)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:Run ansible from a project directory'
  'start:Start an ansible-runner process in the background'
  'stop:Stop an ansible-runner process running in the background'
  'is-alive:Check if an ansible-runner process is running'
  'transmit:Transmit a job to a remote runner'
  'worker:Worker mode for receiving transmitted jobs'
  'process:Process results from a completed job'
)

_arguments -s -S -C \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'ansible-runner command' commands && ret=0
    ;;
  args)
    case $words[1] in
      run|start)
        _arguments -s -S \
          '(-p --playbook)'{-p,--playbook}'=[Playbook to run]:playbook:_files -g "*.{yml,yaml}"' \
          '(-r --role)'{-r,--role}'=[Role to run]:role' \
          '(-m --module)'{-m,--module}'=[Module to run]:module' \
          '-a+[Module arguments]:arguments' \
          '--hosts=[Host pattern]:pattern' \
          '(-i --ident)'{-i,--ident}'=[Runner identifier]:identifier' \
          '--rotate-artifacts=[Number of artifacts to keep]:count' \
          '--project-dir=[Project directory]:dir:_files -/' \
          '--artifact-dir=[Artifact directory]:dir:_files -/' \
          '--inventory=[Inventory source]:inventory:_files' \
          '-e+[Extra variables]:key=value' \
          '--forks=[Number of parallel processes]:forks' \
          '--limit=[Limit hosts]:limit' \
          '--tags=[Only run plays/tasks tagged with these]:tags' \
          '--skip-tags=[Skip plays/tasks tagged with these]:tags' \
          '--cmdline=[Extra command line parameters]:cmdline' \
          '-v[Increase verbosity]' \
          '--json[Output events as JSON]' \
          '--quiet[Quiet mode]' \
          ':private data dir:_files -/' && ret=0
        ;;
      stop|is-alive)
        _arguments -s -S \
          ':private data dir:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
