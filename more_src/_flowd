#compdef flowd
# Documentation: https://www.gsp.com/cgi-bin/man.cgi?section=8&topic=flowd
# Reference accessed: 2026-05-16
# Verified: flowd(8) manpage on gsp.com.
# Removed from prior file: fabricated --help/--version long flags and
# bogus man.archlinux.org search URL.

# flowd: NetFlow collector daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[display command-line usage]' \
  '-d[run in debugging mode]' \
  '-g[do not fork (log to stderr instead of syslog)]' \
  '-f[alternate configuration file]:file:_files' \
  '*-D[define a macro (name=value)]:macro:' && ret=0
return ret
