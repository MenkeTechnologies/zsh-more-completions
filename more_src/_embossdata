#compdef embossdata

# EMBOSS embossdata: find EMBOSS data files and show their locations
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-filename=[data filename to look up]:file:' \
  '-directory=[data directory to search]:dir:_files -/' \
  '-fetch[copy file to current directory]' \
  '-showtypes[show known data file types]' \
  '-reject[show rejected file paths]' \
  '-empty[also list empty entries]' \
  '-outfile=[output file]:file:_files' \
  '*:filename:' && ret=0
return ret
