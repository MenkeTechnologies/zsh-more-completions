#compdef trash-restore

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--sort=[sort method]:method:(date path none)' \
  '--all-users[list trashcans of all users]' \
  '--trash-dir=[specify trash directory]:directory:_directories' \
  '*:path pattern' && ret=0

return ret
