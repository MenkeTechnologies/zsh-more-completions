#compdef trash-restore
# Documentation: https://github.com/andreafrancia/trash-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs (trashcli/restore/restore_arg_parser.py).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--sort=[sort restore candidates]:field:(date path none)' \
  '--overwrite[overwrite existing files when restoring]' \
  '1:path:_files' && ret=0

return ret
