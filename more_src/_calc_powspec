#compdef calc_powspec
# Documentation: https://healpix.sourceforge.io/doc/html/Healpix_cxx/facilities.html
# HEALPix C++: extract a power spectrum from a_lm coefficients

local ret=1

_arguments -s -S \
  '1:first a_lm file:_files' \
  '2:second a_lm file or output:_files' \
  '3:power spectrum output file:_files' && ret=0

return ret
