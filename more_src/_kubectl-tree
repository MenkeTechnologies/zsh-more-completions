#compdef kubectl-tree
# Documentation: https://github.com/ahmetb/kubectl-tree
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[show resources in all namespaces]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '(-c --color)'{-c+,--color=}'[color output]:when:(always never auto)' \
  '(-l --selector)'{-l+,--selector=}'[label selector]:selector:' \
  '--condition-types=[comma-separated condition types]:types:' \
  '--api-groups=[filter API groups]:groups:' \
  '--resources=[filter resource types]:resources:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubernetes context]:context:' \
  '--cluster=[kubernetes cluster]:cluster:' \
  '1:resource kind:' \
  '2:resource name:' && ret=0

return ret
