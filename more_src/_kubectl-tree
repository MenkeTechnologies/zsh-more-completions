#compdef kubectl-tree

# Zsh completion for kubectl-tree - Kubernetes resource tree viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[show resources in all namespaces]' \
  '(-n --namespace)'{-n,--namespace}'[namespace]:namespace' \
  '--kubeconfig=[path to kubeconfig file]:kubeconfig:_files' \
  '--context=[kubernetes context]:context' \
  '--cluster=[kubernetes cluster]:cluster' \
  '1:resource type:(pods deployments services configmaps secrets statefulsets daemonsets replicasets jobs cronjobs ingresses persistentvolumeclaims nodes namespaces serviceaccounts)' \
  '2:resource name' && ret=0

return ret
