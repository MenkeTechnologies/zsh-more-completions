#compdef vpp
# _vpp — fd.io Vector Packet Processing dataplane CLI (FD.io / Cisco, C); custom argparse
# upstream: https://github.com/FDio/vpp

_vpp() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '-T+[input config]:str:' \
        '--gdb[run under gdb]' \
        '--unix=+[unix-section overrides]:str:' \
        '--api-segment=+[api segment overrides]:str:' \
        '--cpu=+[cpu config overrides]:str:' \
        '--memory=+[memory config overrides]:str:' \
        '--plugin_path=+[plugin search path]:dir:_files -/' \
        '--plugins=+[plugin config]:str:' \
        '--no-plugins[no plugins]' \
        '--logging=+[logging config overrides]:str:' \
        '--statseg=+[statseg overrides]:str:' \
        '--ip6=+[ip6 config overrides]:str:' \
        '--tcp=+[tcp config overrides]:str:' \
        '--socksvr=+[socksvr config]:str:' \
        '--vlib=+[vlib config]:str:' \
        '*:arg:'
}

_vpp "$@"
