#compdef ouroboros

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--cleanup[Remove old images after updating]' \
  '--cron[Cron expression for scheduling]:cron expression:' \
  '--dry-run[Only check for updates without pulling]' \
  '--ignore[Containers to ignore]:container names:' \
  '--interval[Update interval in seconds]:seconds:' \
  '--label-enable[Only watch containers with the enable label]' \
  '--latest[Pull latest tag instead of same tag]' \
  '--log-level[Log level]:level:(panic fatal error warn info debug trace)' \
  '--monitor[Monitor containers]:containers:' \
  '--notification-url[Notification URL]:url:' \
  '--no-pull[Do not pull new images, only notify]' \
  '--repo-user[Registry username]:user:' \
  '--repo-pass[Registry password]:password:' \
  '--run-once[Run once and exit]' \
  '--self-update[Allow updating the ouroboros container]' \
  '--stop-timeout[Timeout before killing container]:seconds:' \
  '(- *)--help[Show help]' \
  '(- *)--version[Show version]' && ret=0

return ret
