#compdef vrms
# Virtual Richard M. Stallman - reports non-free packages on Debian

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-e --explain)'{-e,--explain}'[give reasons why packages are non-free]' \
  '(-s --sparse)'{-s,--sparse}'[only list non-free packages]' \
  '--quiet[suppress headers]' \
  && return 0
