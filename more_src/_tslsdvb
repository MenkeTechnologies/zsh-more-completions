#compdef tslsdvb
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tslsdvb.cpp
# tslsdvb - list DVB tuner devices and their capabilities

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-e --extended-info)'{-e,--extended-info}'[display extended information]' \
  '--enumerate-devices[legacy, equivalent to --test enumerate-devices]' \
  '(-l --list-devices)'{-l,--list-devices}'[list all tuner and receiver devices]' \
  '(-t --test)'{-t,--test}'=[run a specific DirectShow test (debug only)]:test:' && ret=0

return ret
