#compdef dp_bands
# Documentation: https://gitlab.com/dftbplus/dftbplus/-/raw/main/tools/dptools/src/dptools/scripts/dp_bands.py
# DFTB+ dptools: create plottable band structure data from band.out

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-N --no-enumeration)'{-N,--no-enumeration}'[do not enumerate k-points in the first column]' \
  '(-s --separate-spins)'{-s,--separate-spins}'[create separate band structure per spin channel]' \
  '(-A --auto-align)'{-A,--auto-align}'[align half-occupation estimate to zero energy]' \
  '(-a --align)'{-a,--align}'+[manually define zero energy in eV]:energy:' \
  '1:input file:_files' \
  '2:output prefix:_files' && ret=0

return ret
