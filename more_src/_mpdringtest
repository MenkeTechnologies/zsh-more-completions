#compdef mpdringtest
# Documentation: https://www.intel.com/content/www/us/en/docs/mpi-library/developer-reference-linux/2021-8/
# Reference accessed: 2026-05-16
# Verified: Intel MPI Library reference (MPD daemon ring test utility).
# Deprecated, replaced by Hydra. No CLI flags documented; takes a single
# positional <n_loops> argument (e.g. mpdringtest 1000).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -h/--help/-V/-v/-f flags (do not exist).

# mpdringtest: MPD ring test utility (legacy Intel MPI; positional only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:n_loops:' && ret=0
return ret
