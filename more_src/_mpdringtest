#compdef mpdringtest
# Documentation: https://man.archlinux.org/search?q=mpdringtest
# Reference accessed: 2026-05-16

# mpdringtest: time a message around the MPD ring
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '-v[verbose]' \
  '-f[hosts file]:file:_files' \
  '*::mpdringtest args:_files' && ret=0
return ret
