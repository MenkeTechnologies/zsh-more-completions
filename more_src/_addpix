#compdef addpix
# _addpix — add a constant to specified FITS image pixels (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from addpix.c (single-letter getopt-style).

_addpix() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-n[output new file]' \
        '1:FITS file:_files -g "*.(fits|fit|fts|imh)"' \
        '*:x y value:'
}

_addpix "$@"
