#compdef v.db.addcolumn
# Documentation: https://grass.osgeo.org/grass-stable/manuals/v.db.addcolumn.html
# GRASS GIS: add one or more columns to the attribute table of a vector map

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--verbose[verbose output]' \
  '--quiet[quiet output]' \
  '--map=[vector map name]:name:' \
  '--layer=[layer where to add column(s)]:layer:' \
  '--columns=[name and type of the new column(s)]:columns:' && ret=0

return ret
