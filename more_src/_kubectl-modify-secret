#compdef kubectl-modify-secret
# Documentation: https://man.archlinux.org/search?q=kubectl-modify-secret
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'=[namespace]:namespace' \
  '--context=[kube context]:context' \
  '1:subcommand:(set append merge decode edit)' \
  '2:secret name: _default' \
  '*:keys or files: _default'
