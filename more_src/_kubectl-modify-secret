#compdef kubectl-modify-secret
# kubectl-modify-secret (krew plugin): modify a Kubernetes secret value interactively
# https://github.com/rajatjindal/kubectl-modify-secret

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-e --editor)'{-e+,--editor=}'[editor to use]:editor' \
  '--dry-run[print modified secret without applying]' \
  '1:secret name'
