#compdef sufrac
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/sufrac.c
# SUFRAC - take general (fractional) time derivative or integral

local ret=1

_arguments -s -S \
  'power=[exponent of (-i*omega)]:p:' \
  'sign=[sign in front of i*omega]:s:(-1 1)' \
  'dt=[time sample interval (sec)]:d:' \
  'phasefac=[phase shift by phase=phasefac*PI]:p:' \
  'verbose=[=1 for advisory messages]:v:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
