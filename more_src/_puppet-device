#compdef puppet-device
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/device.md
# puppet device - manage remote network devices via Puppet

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help message]' \
  '(-v --verbose)'{-v,--verbose}'[turn on verbose reporting]' \
  '(-d --debug)'{-d,--debug}'[enable full debugging]' \
  '(-l --logdest)'{-l,--logdest}'+[direct log messages to syslog, console or file]:dest:' \
  '--detailed-exitcodes[provide transaction details via exit codes]' \
  '--deviceconfig=[path to the device config file]:file:_files' \
  '(-w --waitforcert)'{-w,--waitforcert}'+[poll server for certificate signature]:seconds:' \
  '--libdir=[override per-device libdir]:dir:_files -/' \
  '(-a --apply)'{-a,--apply}'+[apply a manifest against a target device]:manifest:_files -g "*.pp"' \
  '(-f --facts)'{-f,--facts}'[display facts from a remote target device]' \
  '(-r --resource)'{-r,--resource}'+[display resource state as Puppet code]:type:' \
  '(-t --target)'{-t,--target}'+[specify a device in device.conf]:device:' \
  '--to_yaml[output resources in YAML format]' \
  '--user=[user account to run the command under]:user:_users' \
  '(-V --version)'{-V,--version}'[display version information]' && ret=0

return ret
