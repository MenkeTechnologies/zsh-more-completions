#compdef ezmlm-sub
# Documentation: https://untroubled.org/ezmlm/man/man1/ezmlm-sub.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-n[digest list]' \
  '-N[normal list]' \
  '-m[suppress mail notification]' \
  '-M[send notification]' \
  '1:dir:_files -/' \
  '*:address:' && ret=0

return ret
