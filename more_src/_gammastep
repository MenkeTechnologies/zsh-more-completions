#compdef gammastep

# Zsh completion for gammastep - adjust color temperature for Wayland/X11

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b)'-b'[screen brightness (day:night)]:brightness' \
  '(-c)'-c'[set config file]:file:_files' \
  '(-g)'-g'[additional gamma correction (R:G:B)]:gamma' \
  '(-l)'-l'[set latitude:longitude]:lat\:lon' \
  '(-m)'-m'[set adjustment method]:method:(wayland drm randr vidmode dummy)' \
  '(-o)'-o'[one-shot mode]' \
  '(-O)'-O'[one-shot with specific temperature]:temperature' \
  '(-p)'-p'[print mode (print parameters and exit)]' \
  '(-P)'-P'[reset existing adjustments on start]' \
  '(-r)'-r'[disable temperature transition]' \
  '(-t)'-t'[set color temperature (day:night)]:temp' \
  '(-x)'-x'[reset mode (remove adjustments)]' \
  '(-v)'-v'[verbose output]'
