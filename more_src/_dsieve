#compdef dsieve
# Documentation: https://github.com/trickest/dsieve
# Filter and enrich a list of subdomains by level.

local ret=1

_arguments -s -S \
  '-f[filter domain level (python slice notation, e.g. 3, 3:, 2:4, :3)]:level' \
  '-i[input url or domain]:url' \
  '-if[input file path, one url/domain per line]:file:_files' \
  '-o[output file path]:file:_files' \
  '-top[only consider top X subdomains of a level and return all their subdomains]:count' && ret=0

return ret
