#compdef nix2container container2nix
# _nix2container — build OCI images from Nix store paths (nlewo/nix2container)
# upstream: https://github.com/nlewo/nix2container
# Subcommands from cmd/{root,image,layers,utils}.go (cobra).

_nix2container() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --debug)'{-d,--debug}'[verbose logging]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'image:generate image.json from config + layers'
                'image-from-dir:write image.json from skopeo dir transport'
                'image-from-manifest:write image.json from skopeo raw manifest+blobs'
                'layers-from-reproducible-storepaths:layers.json from reproducible storepaths'
                'layers-from-non-reproducible-storepaths:layers.json from non-reproducible storepaths'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                image)
                    _arguments \
                        '--from-image=[base image filename]:file:_files -g "*.json"' \
                        '--arch=[image arch override]:arch:(amd64 arm64 386 arm ppc64le s390x riscv64)' \
                        '--created=[image created timestamp (RFC3339)]:ts:' \
                        '*:json file:_files -g "*.json"'
                    ;;
                layers-from-reproducible-storepaths|layers-from-non-reproducible-storepaths)
                    _arguments \
                        '--ignore=[regex of storepaths to ignore]:regex:' \
                        '--tar-directory=[directory for tarballs]:dir:_files -/' \
                        '--perms=[perms JSON file]:file:_files -g "*.json"' \
                        '--rewrites=[rewrites JSON file]:file:_files -g "*.json"' \
                        '--history=[history JSON file]:file:_files -g "*.json"' \
                        '--max-layers=[maximum number of layers]:n:' \
                        '*:json file:_files -g "*.json"'
                    ;;
            esac
            ;;
    esac
}

_nix2container "$@"
