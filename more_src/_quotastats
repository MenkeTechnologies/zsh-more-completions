#compdef quotastats
# Documentation: https://man.archlinux.org/search?q=quotastats
# Reference accessed: 2026-05-16

# quotastats: print kernel quota statistics
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-V[show version]' \
  '*::quotastats args:_files' && ret=0
return ret
