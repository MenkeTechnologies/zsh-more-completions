#compdef quotastats
# Documentation: https://manpages.debian.org/bookworm/quota/quotastats.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# quotastats: print kernel quota statistics
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-V[show version]' \
  '*::quotastats args:_files' && ret=0
return ret
