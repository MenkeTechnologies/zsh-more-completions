#compdef fcalc
# Calculates values for a column using an arithmetic expression

local ret=1

_arguments -s \
  "infile=[input FITS file]:file:_files" \
  "outfile=[output FITS file]:file:_files" \
  "clname=[name of column to create or modify]:" \
  "expr=[arithmetic expression]:" \
  "rowrange=[range of rows to operate on]:" \
  "tform=[TFORM of the new column]:" \
  "anull=[ASCII null value]:" \
  "inull=[integer null value]:" \
  "copycol=[copy all columns]:bool:(yes no)" \
  "histkw=[add HISTORY keyword]:bool:(yes no)" \
  "copyall=[copy all other extensions]:bool:(yes no)" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
