#compdef jlog
# Documentation: https://github.com/jrockway/json-logs/blob/master/README.md
# jlog - pretty-print JSON logs, like those from zap or logrus

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '(-l --lax)'{-l,--lax}'[suppress validation errors for non-JSON lines]' \
  '--levelkey=[JSON key containing log level]:key' \
  '--nolevelkey[disable log level detection and display]' \
  '--timekey=[JSON key containing timestamp]:key' \
  '--notimekey[disable timestamp detection and display]' \
  '--messagekey=[JSON key containing log message]:key' \
  '--nomessagekey[disable message detection]' \
  '*--delete=[remove specified JSON keys before processing]:key' \
  '*--upgrade=[merge object fields into main field set]:key' \
  '--no-elide[disable replacing duplicate field values]' \
  '(-r --relative)'{-r,--relative}'[show timestamps as duration since program start]' \
  '(-t --time-format)'{-t+,--time-format=}'[timestamp format]:format' \
  '(-s --only-subseconds)'{-s,--only-subseconds}'[show only fractional seconds for same-second lines]' \
  '--no-summary[suppress final summary statistics]' \
  '*'{-p+,--priority=}'[fields to display first]:field' \
  '*'{-H+,--highlight=}'[fields to highlight visually]:field' \
  '(-A --after-context)'{-A+,--after-context=}'[print N filtered lines after matches]:n' \
  '(-B --before-context)'{-B+,--before-context=}'[print N filtered lines before matches]:n' \
  '(-C --context)'{-C+,--context=}'[print N context lines around matches]:n' \
  '(-g --regex)'{-g+,--regex=}'[show only lines matching expression]:regex' \
  '(-G --no-regex)'{-G+,--no-regex=}'[hide lines matching expression]:regex' \
  '(-S --regex-scope)'{-S+,--regex-scope=}'[where to apply regex (m/k/v)]:scope' \
  '(-e --jq)'{-e+,--jq=}'[execute jq program on each record]:program' \
  '--jq-search-path=[directories for jq module imports]:paths' \
  '(-M --no-color)'{-M,--no-color}'[disable colored output]' \
  '(-c --no-monochrome)'{-c,--no-monochrome}'[force colored output]' \
  '--profile=[write CPU profile to file]:file:_files' \
  '*:log file:_files' && ret=0

return ret
