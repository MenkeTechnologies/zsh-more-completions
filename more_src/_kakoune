#compdef kak kakoune

# Zsh completion for Kakoune editor

_kakoune() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-c+[connect to given session]:session name:' \
    '-e+[execute argument on client initialization]:command:' \
    '-E+[execute argument on server initialization]:command:' \
    '-n[do not load resource files on startup]' \
    '-s+[set session name]:session name:' \
    '-d[run as a headless session]' \
    '-p+[send stdin to the given session]:session name:' \
    '-f+[enter filter mode]:keys:' \
    '-i+[enter filter mode with backup suffix]:suffix:' \
    '-q[suppress warnings about existing sessions]' \
    '-ui+[set the user interface type]:ui type:(ncurses dummy json)' \
    '-l[list existing sessions]' \
    '-clear[clear dead sessions]' \
    '-ro[start in readonly mode]' \
    '-debug=[set debug flags]:flags:(hooks shell profile commands)' \
    '--help[display help]' \
    '--version[display version]' \
    '+*[go to line\:column]:line\:column:' \
    '*:file:_files' \
    && ret=0

  return ret
}

_kakoune "$@"
