#compdef kak
# Documentation: https://manpages.debian.org/unstable/kakoune/kak.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream man page at the URL above.

# Kakoune editor. Corrected from prior file against the man page:
# -help/-version are single-dash (not --), -ui types are
# (terminal dummy json) not ncurses, fixed #compdef to just kak.

_kakoune() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-c+[connect to the given session]:session name:' \
    '-e+[execute command after client initialization]:command:' \
    '-E+[execute command after server initialization]:command:' \
    "-n[do not load the system's kakrc]" \
    '-s+[set the current session name]:session name:' \
    '-d[run as a headless session (requires -s)]' \
    '-p+[send stdin commands to the given session]:session name:' \
    "-f+[run in filter mode, like sed]:keys:" \
    '-i+[backup files on which a filter is applied]:suffix:' \
    "-q[in filter mode, don't print errors]" \
    '-ui+[set the user interface type]:ui type:(terminal dummy json)' \
    '-l[list existing sessions]' \
    '-clear[remove sessions terminated in an incorrect state]' \
    '-ro[begin in readonly mode]' \
    '-debug=[set debug flags]:flags:(hooks shell profile keys commands)' \
    '-help[display a help message and quit]' \
    '-version[display Kakoune version and quit]' \
    '+*[go to line\:column]:line\:column:' \
    '*:file:_files' \
    && ret=0

  return ret
}

_kakoune "$@"
