#compdef smtp4dev
# Documentation: https://man.archlinux.org/search?q=smtp4dev
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)'{-h,--help,-?}'[show help]' \
  '--baseappdatapath=[base app data path]:dir:_files -/' \
  '--hostname=[server hostname]:host:_hosts' \
  '--allowremoteconnections[allow remote connections]' \
  '--bindaddress=[bind address]:addr:' \
  '--disableipv6[disable IPv6]' \
  '--smtpport=[SMTP port]:port:' \
  '--db=[database file]:file:_files' \
  '--messagestokeep=[messages to keep]:n:' \
  '--sessionstokeep=[sessions to keep]:n:' \
  '--tlsmode=[TLS mode]:mode:(None StartTls ImplicitTls)' \
  '--tlscertificatestorethumbprint=[cert thumbprint]:thumb:' \
  '--tlscertificate=[cert path]:file:_files' \
  '--tlscertificateprivatekey=[cert key]:file:_files' \
  '--tlscertificatepassword=[cert password]:password:' \
  '--imapport=[IMAP port]:port:' \
  '--pop3port=[POP3 port]:port:' \
  '--pop3tlsmode=[POP3 TLS mode]:mode:(None StartTls ImplicitTls)' \
  '--pop3secureconnectionrequired[require secure POP3]' \
  '--relaysmtpserver=[relay server]:host:_hosts' \
  '--relaysmtpport=[relay port]:port:' \
  '--relayautomaticallyemails=[auto-relay addrs]:addrs:' \
  '--relaysenderaddress=[relay sender]:addr:' \
  '--relayusername=[relay username]:user:' \
  '--relaypassword=[relay password]:password:' \
  '--relaytlsmode=[relay TLS mode]:mode:(None StartTls ImplicitTls)' \
  '--nousersettings[do not load user settings]' \
  '--debugsettings[print effective settings]' \
  '--recreatedb[recreate database]' \
  '--locksettings[lock settings]' \
  '--installpath=[install path]:dir:_files -/' \
  '--disablemessagesanitisation[disable HTML sanitization]' \
  '--applicationName=[app name]:name:' \
  '--authenticationrequired[require auth]' \
  '--secureconnectionrequired[require secure connection]' \
  '--smtpallowanycredentials[allow any SMTP creds]' \
  '--webauthenticationrequired[require web auth]' \
  '--delivermessagestousersdefaultmailbox[deliver to default mailbox]' \
  '*--user=[user name=pass]:cred:' \
  '--maxmessagesize=[max message size]:bytes:' \
  '--tui[enable TUI]' \
  '--delivertostdout[deliver messages to stdout]' \
  '--exitafter=[exit after seconds]:s:' \
  '--oauth2authority=[OAuth2 authority]:url:' \
  '--oauth2audience=[OAuth2 audience]:audience:' \
  '--oauth2issuer=[OAuth2 issuer]:url:' \
  '--service[run as service]' \
  '--install-service[install as service]' \
  '--uninstall-service[uninstall service]' \
  '--urls=[Kestrel URLs]:urls:' \
  '--basepath=[base path]:path:'
