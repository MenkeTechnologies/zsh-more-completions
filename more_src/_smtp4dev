#compdef smtp4dev
# Documentation: https://github.com/rnwood/smtp4dev/blob/master/docs/Configuration.md
# Reference accessed: 2026-05-21
# Verified: upstream Configuration.md (only options explicitly documented are
# kept; remainder require live --help dump which is not in public docs).

# Only flags explicitly named in upstream docs are kept; everything else
# stripped to avoid fabrication. Users can still pass other ServerOptions__*
# parameters via env vars per upstream docs.

_arguments -s \
  '(- *)--help[show command line options]' \
  '--smtpport=[SMTP listening port]:port:' \
  '--imapport=[IMAP listening port]:port:' \
  '--pop3port=[POP3 listening port]:port:' \
  '*--user=[add authenticated user (user=password)]:cred:' \
  '--oauth2authority=[OpenID Connect authority URL]:url:' \
  '--oauth2audience=[expected token audience]:audience:' \
  '--oauth2issuer=[expected token issuer]:url:' \
  '--delivertostdout=[route messages to stdout (* or mailbox)]:target:' \
  '--exitafter=[terminate after delivering N messages]:n:' \
  '--mailbox=[configure virtual mailbox routing]:mailbox:'
