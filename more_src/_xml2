#compdef xml2 2xml html2 2html
# Documentation: https://manpages.debian.org/bookworm/xml2/xml2.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream xml2(1) manpage. xml2/2xml/html2/2html are filters that
# read stdin and write stdout and accept no command-line arguments.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:input file:_files -g "*.(xml|html|xhtml|svg)"' && ret=0
return ret
