#compdef xml2
# Documentation: https://man.archlinux.org/search?q=xml2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '*:input file:_files -g "*.{xml,html,xhtml,svg}"' && ret=0

return ret
