#compdef virtiofsd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--socket-path=[vhost-user socket path]:path:_files' \
  '--socket-group=[socket group name or GID]:group:_groups' \
  '--fd=[file descriptor for vhost-user socket]:fd' \
  '-o+[mount options]:options' \
  '--shared-dir=[path to shared directory]:dir:_directories' \
  '--tag=[tag for the virtio device]:tag' \
  '--inode-file-handles=[file handle support]:mode:(never prefer mandatory)' \
  '--xattr[enable extended attributes]' \
  '--xattrmap=[xattr mapping rules]:rules' \
  '--modcaps=[modify daemon capabilities]:caps' \
  '--sandbox=[sandboxing mode]:mode:(namespace chroot none)' \
  '--seccomp=[seccomp policy]:policy:(none log kill)' \
  '--cache=[caching policy]:policy:(auto always never none)' \
  '--thread-pool-size=[number of worker threads]:num' \
  '--allow-direct-io[honor O_DIRECT flags]' \
  '--announce-submounts[tell the guest about submounts]' \
  '--posix-acl[enable POSIX ACLs]' \
  '--log-level=[log level]:level:(error warn info debug trace)' \
  '--syslog[log to syslog]' \
  '-d[enable debug output]' \
  '-f[run in foreground]' && ret=0

return ret
