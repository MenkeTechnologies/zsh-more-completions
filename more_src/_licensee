#compdef licensee
# Documentation: source-direct extraction from upstream
# licensee/licensee bin/licensee Thor entrypoint + the 4 command
# implementations in lib/licensee/commands/{detect,diff,
# license_path,version}.rb (each is a Thor subclass with
# `desc <name>` + `option <flag>, type: ..., desc: ...`
# declarations). Note: licensee uses Ruby's Thor CLI framework
# (NOT optparse), so `option :foo` becomes `--foo` and the
# `--no-foo` negation form is auto-generated for boolean options.
# Reference accessed: 2026-05-30 via gh api.
# GitHub licensee R147c — Ruby gem used by GitHub to detect the
# open-source license of a repository. Also runs standalone as
# the `licensee` CLI. Sister to ratchet/reuse/cyclonedx/spdx
# software-licensing tools in the corpus.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '--remote[assume PATH is a github owner/repo path]' \
  '1:subcommand:((detect\:detect-the-license-of-a-project diff\:compare-license-text-to-a-known-license license-path\:return-path-to-projects-license-file version\:return-the-licensee-version))' \
  '*::: :->subcmd' && ret=0

case "$state" in
  subcmd)
    case "${line[1]}" in
      detect)
        _arguments -s -S \
          '--json[return output as JSON]' \
          '--packages[detect licenses in package-manager files (default true)]' \
          '--no-packages[do NOT detect licenses in package-manager files]' \
          '--readme[detect licenses in README files (default true)]' \
          '--no-readme[do NOT detect licenses in README files]' \
          '--confidence=[confidence threshold (default 98)]:percent:' \
          '--license=[SPDX ID or key of license to compare (implies --diff)]:spdx-id:' \
          '--diff[compare the license to the closest match]' \
          '--ref=[name of commit/branch/tag to search (github.com only)]:ref:' \
          '--filesystem[force looking at the filesystem (ignore git data)]' \
          '1:project path (or owner/repo if --remote):_files' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '--license=[SPDX ID or key of license to compare against]:spdx-id:' \
          '1:license file path:_files' && ret=0
        ;;
      license-path)
        _arguments -s -S \
          '1:project path:_files' && ret=0
        ;;
      version)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
