#compdef overpf
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Overlay polynomial fibre fits on a displayed fibre frame

local ret=1

_arguments -s -S \
  'IMAGE=[fibre frame of distorted fibre spectra]:image:_files' \
  'BLACK=[data value displayed as background]:black:' \
  'WHITE=[data value displayed as foreground]:white:' \
  'PFILE=[file containing the polynomial fits]:pfile:_files' \
  'YSTART=[first Y value to display]:ystart:' \
  'YEND=[last Y value to display]:yend:' \
  'XSTART=[first X value to display]:xstart:' \
  'XEND=[last X value to display]:xend:' \
  'EXTWID=[extraction width / tramline width]:extwid:' \
  'REPEAT=[make another display with new parameters]:repeat:(TRUE FALSE)' \
  '*:NDF data file:_files' && ret=0

return ret
