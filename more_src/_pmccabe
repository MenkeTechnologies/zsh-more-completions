#compdef pmccabe
# McCabe-style cyclomatic complexity for C/C++

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-n[no sort, output in file order]' \
  '-c[show only function count per file]' \
  '-C[show preprocessed code]' \
  '-f[show only filenames]' \
  '-F[show full path names]' \
  '-S[print summary statistics]' \
  '-T[use tab-delimited output]' \
  '-w[warn about unrecognized constructs]' \
  '*:source file:_files -g "*.(c|cc|cpp|cxx|h|hpp)"' \
  && return 0
