#compdef foamLog
# Documentation: https://man.archlinux.org/search?q=foamLog
# Reference accessed: 2026-05-16

# OpenFOAM foamLog: extract residuals/time info from a solver log
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-case[case directory]:dir:_files -/' \
  '-list[list available data]' \
  '-localTime[use local time instead of run time]' \
  '-quiet[no progress output]' \
  '-noscientific[no scientific notation in output]' \
  '*:OpenFOAM solver log file:_files' && ret=0
return ret
