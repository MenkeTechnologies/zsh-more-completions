#compdef fawltydeps
# _fawltydeps — find unused/undeclared Python dependencies (tweag/FawltyDeps)
# upstream: https://github.com/tweag/FawltyDeps
# Flags from fawltydeps/cli_parser.py (argparse).

_fawltydeps() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(--check --check-undeclared --check-unused --list-sources --list-imports --list-deps)--check[report undeclared and unused (default)]' \
        '(--check --check-undeclared --check-unused --list-sources --list-imports --list-deps)--check-undeclared[report only undeclared]' \
        '(--check --check-undeclared --check-unused --list-sources --list-imports --list-deps)--check-unused[report only unused]' \
        '(--check --check-undeclared --check-unused --list-sources --list-imports --list-deps)--list-sources[list input paths]' \
        '(--check --check-undeclared --check-unused --list-sources --list-imports --list-deps)--list-imports[list third-party imports]' \
        '(--check --check-undeclared --check-unused --list-sources --list-imports --list-deps)--list-deps[list declared dependencies]' \
        '*--code=[paths to analyze for imports]:path:_files' \
        '*--deps=[paths to analyze for declared deps]:path:_files' \
        '*--pyenv=[Python environments to look up packages]:path:_files -/' \
        '--base-dir=[base directory of project]:dir:_files -/' \
        '--config-file=[config file path]:file:_files' \
        '--custom-mapping-file=[custom import->package mapping]:file:_files' \
        '--deps-parser-choice=[force specific deps parser]:choice:(requirements.txt setup.cfg setup.py pyproject.toml pixi.toml environment.yml)' \
        '--detailed[show detailed report]' \
        '--summary[show summary report (default)]' \
        '--json[output report as JSON]' \
        '--generate-toml-config[print config TOML]' \
        '*--ignore-undeclared=[dependencies to ignore as undeclared]:dep:' \
        '*--ignore-unused=[dependencies to ignore as unused]:dep:' \
        '--install-deps[install deps into a temp env]' \
        '*--exclude=[exclude glob pattern]:glob:' \
        '*--exclude-from=[file with exclude patterns]:file:_files' \
        '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
        '(-q --quiet)*'{-q,--quiet}'[decrease verbosity]' \
        '*:basepath:_files -/'
}

_fawltydeps "$@"
