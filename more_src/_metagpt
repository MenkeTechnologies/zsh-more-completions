#compdef metagpt
# Documentation: https://github.com/FoundationAgents/MetaGPT
# Reference accessed: 2026-05-22
# Verified: metagpt/software_company.py Typer startup command and setup.py console_scripts.

# Zsh completion for metagpt - multi-agent software company simulation CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--init-config[initialize config2.yaml in config directory]' \
  '--investment[dollar amount to invest]:amount:' \
  '--n-round[number of simulation rounds]:rounds:' \
  '--code-review[enable code review]' \
  '--no-code-review[disable code review]' \
  '--run-tests[enable QA tests]' \
  '--no-implement[disable code implementation]' \
  '--project-name[unique project name]:name:' \
  '--inc[incremental mode with existing repo]' \
  '--project-path[directory of existing project]:directory:_directories' \
  '--reqa-file[source file for QA rewrite]:file:_files' \
  '--max-auto-summarize-code[max SummarizeCode invocations (-1 unlimited)]:count:' \
  '--recover-path[recover from serialized team storage]:directory:_directories' \
  '*:idea:' && ret=0

return ret
