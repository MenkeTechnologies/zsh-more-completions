#compdef cyrus-quota
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/quota.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org quota(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-quota: report and repair Cyrus mailbox quotas
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-d[limit to this domain]:domain:' \
  '(-n)-f[detect and fix quota inconsistencies]' \
  '(-f)-n[check without fixing inconsistencies]' \
  '-q[operate quietly]' \
  '-J[output quota values as JSON]' \
  '-u[interpret args as userids rather than mailboxes]' \
  '*:mailbox-spec:' && ret=0
return ret
