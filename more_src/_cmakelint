#compdef cmakelint cmake-lint
# Documentation: https://man.archlinux.org/search?q=cmakelint
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--filter[specify lint filters]:filters:' \
  '--config[config file]:config file:_files' \
  '--spaces[number of spaces for indent]:spaces:' \
  '--linelength[max line length]:length:' \
  '--quiet[quiet mode]' \
  '*:cmake file:_files -g "*(CMakeLists.txt|*.cmake)"' && ret=0

return ret
