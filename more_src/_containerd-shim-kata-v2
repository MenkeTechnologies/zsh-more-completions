#compdef containerd-shim-kata-v2

# containerd-shim-kata-v2: containerd shim for Kata Containers (v2)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '--version[show version]' \
  '-namespace[containerd namespace]:ns:' \
  '-address=[gRPC address]:addr:' \
  '-publish-binary=[event publish binary]:file:_files' \
  '-id=[container id]:id:' \
  '-bundle=[bundle path]:dir:_files -/' \
  '-debug[debug logging]' \
  '*::containerd-shim-kata-v2 args:_files' && ret=0
return ret
