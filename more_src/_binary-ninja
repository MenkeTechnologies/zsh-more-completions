#compdef binaryninja
# _binary-ninja — Binary Ninja interactive disassembler (Vector 35); cross-platform reverse-engineering platform
# upstream: https://binary.ninja

_binary-ninja() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--no-plugins[disable plugins]' \
        '--no-database[do not load BNDB database files]' \
        '--no-user-plugins[disable user plugins]' \
        '--script+[python script]:file:_files -g "*.py"' \
        '--stdin[read input from stdin]' \
        '--license+[license file]:file:_files' \
        '--debug[debug log]' \
        '--log+[log file]:file:_files' \
        '*:binary:_files'
}

_binary-ninja "$@"
