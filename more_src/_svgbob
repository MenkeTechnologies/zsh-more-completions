#compdef svgbob
# Documentation: https://github.com/ivanceras/svgbob/blob/master/crates/svgbob_cli/src/main.rs
# Reference accessed: 2026-05-21
# Verified: upstream svgbob_cli main.rs at the URL above.
# Removed from prior file: fabricated --class, -h/--help, -V/--version
# flags which the upstream CLI does not implement.

local curcontext="$curcontext" state line ret=1

local -a cmds=(
  'build:batch convert .bob files to SVG'
)

local -a common=(
  '--font-family=[font family for text]:font:'
  '--font-size=[font size in pixels]:size:'
  '--scale=[scale factor]:scale:'
  '--stroke-width=[stroke width]:width:'
  '--background=[background color]:color:'
  '--fill-color=[fill color]:color:'
  '--stroke-color=[stroke color]:color:'
)

_arguments -s -S -C \
  $common \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files -g "*.svg"' \
  '-s+[parse an inline string]:string:' \
  '1:command or input file:->cmd_or_file' \
  '*::args:->args' && ret=0

case $state in
  cmd_or_file)
    _alternative \
      'commands:command:_describe -t commands command cmds' \
      'files:file:_files -g "*.bob"' && ret=0
    ;;
  args)
    case ${line[1]} in
      build)
        _arguments -s -S \
          $common \
          {-i+,--input=}'[input file(s) or glob]:files:_files -g "*.bob"' \
          '--outdir=[output directory]:dir:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
