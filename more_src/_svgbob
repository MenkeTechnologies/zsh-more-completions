#compdef svgbob
# Documentation: https://github.com/ivanceras/svgbob
# Reference accessed: 2026-05-17
# Verified: ivanceras/svgbob README + Settings struct. Note: exact
# upstream flag names may vary by svgbob_cli version; consult
# `svgbob --help` for an authoritative current set.
# Removed from prior file: bogus man.archlinux.org search URL.

local -a arguments

arguments=(
  '(-o --output)'{-o,--output}'=[output file]:file:_files -g "*.svg"'
  '--font-family=[font family for text]:font:'
  '--font-size=[font size in pixels]:size:'
  '--scale=[scale factor]:scale:'
  '--stroke-width=[stroke width]:width:'
  '--background=[background color]:color:'
  '--fill-color=[fill color]:color:'
  '--stroke-color=[stroke color]:color:'
  '--class=[CSS class to add to SVG]:class:'
  '(-h --help)'{-h,--help}'[show help message]'
  '(-V --version)'{-V,--version}'[show version]'
  '*:input file:_files -g "*.bob"'
)

_arguments -s -S $arguments
