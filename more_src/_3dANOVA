#compdef 3dANOVA
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dANOVA.html
# AFNI one-way (single-factor) analysis of variance on datasets

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-levels[number of factor levels]:r' \
  '*-dset[assign dataset to a factor level]:level' \
  '-voxel[screen output for a particular voxel]:num' \
  '-diskspace[print disk space requirements]' \
  '-mask[use sub-brick 0 to define voxels to process]:dataset:_files' \
  '-debug[additional diagnostic output]:level' \
  '-ftr[F-statistic for treatment effect]:prefix' \
  '*-mean[estimate of factor level mean]:i' \
  '*-diff[difference between two factor levels]:i' \
  '*-contr[contrast among factor levels]:coef' \
  '-old_method[use previous computation method]' \
  '-OK[confirm understanding of older-method assumptions]' \
  '-assume_sph[assume sphericity for zero-sum contrasts]' \
  '-bucket[combine all output into single bucket dataset]:prefix' \
  '*:dataset:_files' && ret=0

return ret
