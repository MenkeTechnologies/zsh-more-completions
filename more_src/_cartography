#compdef cartography

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--neo4j-uri[Neo4j URI]:uri:' \
  '--neo4j-user[Neo4j username]:user:' \
  '--neo4j-password-env-var[Env var containing Neo4j password]:env var:' \
  '--neo4j-password-prompt[Prompt for Neo4j password]' \
  '--selected-modules[Comma-separated list of modules to sync]:modules:' \
  '--drift-detection-directory[Directory with drift detection queries]:directory:_directories' \
  '--aws-sync-all-profiles[Sync all AWS profiles]' \
  '--aws-requested-syncs[Comma-separated list of AWS sync jobs]:syncs:' \
  '--azure-sp-auth[Use Azure Service Principal authentication]' \
  '--azure-tenant-id[Azure tenant ID]:tenant id:' \
  '--azure-client-id[Azure client ID]:client id:' \
  '--azure-client-secret-env-var[Env var containing Azure client secret]:env var:' \
  '--gcp-requested-syncs[Comma-separated list of GCP sync jobs]:syncs:' \
  '--okta-org-id[Okta organization ID]:org id:' \
  '--github-config[Path to GitHub config file]:config file:_files' \
  '--statsd-enabled[Enable StatsD reporting]' \
  '--statsd-host[StatsD host]:host:_hosts' \
  '--statsd-port[StatsD port]:port:' \
  '--statsd-prefix[StatsD metric prefix]:prefix:' \
  '--permission-relationships-file[Path to permission relationships file]:file:_files' \
  '--verbose[Verbose output]' \
  '--debug[Debug output]' && ret=0

return ret
