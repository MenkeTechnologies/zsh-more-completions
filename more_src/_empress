#compdef empress
# Documentation: https://github.com/biocore/empress/blob/master/empress/scripts/_cli.py
# EMPRess interactive phylogenetic tree viewer for microbiome data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--tree=[input phylogenetic tree file]:file:_files' \
  '--table=[input feature table (biom)]:file:_files' \
  '--sample-metadata=[input sample metadata file]:file:_files' \
  '--feature-metadata=[input feature metadata file]:file:_files' \
  '--output-dir=[output directory location]:dir:_files -/' \
  '--pcoa=[input ordination (PCoA) file]:file:_files' \
  '--ignore-missing-samples[ignore samples missing from the table]' \
  '--filter-extra-samples[filter samples not present in the table]' \
  '--filter-missing-features[filter features not present in the tree]' \
  '--number-of-pcoa-features=[number of features to display per PCoA axis]:n' \
  '--shear-to-table[shear the tree to the table features]' \
  '--shear-to-feature-metadata[shear the tree to the feature metadata]' \
  '*:command:(tree-plot community-plot)' && ret=0

return ret
