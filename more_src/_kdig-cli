#compdef kdig-cli
# _kdig-cli — CZ.NIC Knot DNS kdig advanced DNS lookup utility CLI alias (CZ-NIC team, C); custom argparse
# upstream: https://github.com/CZ-NIC/knot

_kdig-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-4[ipv4]' \
        '-6[ipv6]' \
        '-b+[address]:str:' \
        '-c+[class]:c:(IN CH HS)' \
        '-d[debug]' \
        '-k+[tsig key file]:file:_files' \
        '-p+[port]:port:' \
        '-q+[query name]:str:' \
        '-t+[query type]:str:' \
        '-x+[reverse address]:str:' \
        '-y+[tsig spec]:str:' \
        '-E+[edns size]:n:' \
        '-F+[ack flag]:str:' \
        '+aaonly[aa only]' \
        '+aaflag[set aa flag]' \
        '+all[all sections]' \
        '+adflag[set ad flag]' \
        '+answer[show answer]' \
        '+authority[show authority]' \
        '+badcookie[bad cookie]' \
        '+besteffort[best effort]' \
        '+bufsize=+[size]:n:' \
        '+cd[checking disabled]' \
        '+class[show class]' \
        '+cmd[show command]' \
        '+comments[show comments]' \
        '+cookie=+[hex]:str:' \
        '+crypto[show crypto]' \
        '+dnssec[request DNSSEC]' \
        '+do[set DO flag]' \
        '+edns=+[version]:n:' \
        '+expire[request expire]' \
        '+fastopen[TCP fast open]' \
        '+generic[generic output]' \
        '+idn=+[level]:n:' \
        '+ignore[ignore TC bit]' \
        '+json[json output]' \
        '+jsonl[jsonl output]' \
        '+keepopen[keep TCP socket open]' \
        '+long[long output]' \
        '+multiline[multiline output]' \
        '+nsid[request NSID]' \
        '+norec[no recursion]' \
        '+opcode=+[opcode]:str:' \
        '+padding=+[bytes]:n:' \
        '+question[show question]' \
        '+rdflag[set RD flag]' \
        '+retry=+[count]:n:' \
        '+short[short form]' \
        '+showname[show name]' \
        '+stats[show stats]' \
        '+subnet=+[client subnet]:str:' \
        '+tcp[force TCP]' \
        '+timeout=+[seconds]:n:' \
        '+tls[force TLS]' \
        '+tls-ca=+[file]:file:_files' \
        '+tls-ciphers=+[ciphers]:str:' \
        '+tls-hostname=+[host]:host:_hosts' \
        '+tls-keyfile=+[file]:file:_files' \
        '+tls-pin=+[pin]:str:' \
        '+tls-sni=+[sni]:str:' \
        '+ttl[show ttl]' \
        '+ttlunits[show ttl units]' \
        '+vc[force TCP]' \
        '+http[force DoH]' \
        '+http-get[force DoH GET]' \
        '+quic[force DoQ]' \
        '*:queries:'
}

_kdig-cli "$@"
