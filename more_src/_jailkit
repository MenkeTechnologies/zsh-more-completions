#compdef jailkit

# jailkit umbrella: helpers to build chroot jails (jk_init, jk_lsh, jk_chrootsh, ...)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'jk_init:install programs and their deps into a chroot'
  'jk_cp:copy files into a chroot (with libs)'
  'jk_check:check a chroot for issues'
  'jk_chrootsh:shell that chroots before user shell'
  'jk_chrootlaunch:launch a daemon inside a chroot'
  'jk_lsh:limited shell with allowed-command list'
  'jk_addjailuser:add an existing user to a chroot'
  'jk_jailuser:add or move a user into a chroot'
  'jk_update:update a chroot (sync with host)'
  'jk_socketd:relay sockets into a chroot'
  'jk_uchroot:non-root chroot using setuid'
  'jk_procmailwrapper:procmail wrapper inside jails'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'jailkit command' commands && ret=0 ;;
esac
return ret
