#compdef jailkit
# Documentation: https://olivier.sessink.nl/jailkit/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jailkit umbrella: helpers to build chroot jails. Updated from upstream:
# removed jk_addjailuser (removed in jailkit 2.21); added jk_list.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'jk_init:install programs and their deps into a chroot'
  'jk_cp:copy files and their dependencies into a chroot'
  'jk_check:security test for a chroot'
  'jk_chrootsh:shell that chroots before the user shell'
  'jk_chrootlaunch:launch a daemon inside a chroot'
  'jk_lsh:limited shell with an allowed-command list'
  'jk_jailuser:place or move an existing user into a chroot'
  'jk_update:update a chroot (sync with the host)'
  'jk_socketd:relay sockets into a chroot (secure logging)'
  'jk_uchroot:non-root chroot using setuid'
  'jk_procmailwrapper:jailed and non-jailed mail delivery'
  'jk_list:list all jailed processes'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'jailkit command' commands && ret=0 ;;
esac
return ret
