#compdef firewall-cmd
# _firewall-cmd — firewalld firewall-cmd (online + offline NetworkManager-aware firewall configurator atop nftables/iptables; per-zone --add-/remove-service, --add-port, --add-source, --remove-port, --list-all, --list-services, --set-default-zone, --reload, --runtime-to-permanent, --direct passthrough; --permanent persists, --zone selects, --policy/--family for nftables rules)
# upstream: https://github.com/firewalld/firewalld
# Flags from firewalld src/firewall/cli/firewall-cmd.py on tip.

_firewall-cmd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--state[show state]' \
        '--reload[reload]' \
        '--complete-reload[complete reload]' \
        '--runtime-to-permanent[persist runtime config]' \
        '--check-config[check config]' \
        '--permanent[permanent config]' \
        '--offline[offline mode]' \
        '--zone+[zone]:zone:(public block dmz drop external home internal trusted work)' \
        '--policy+[policy]:policy:' \
        '--family+[family]:family:(ipv4 ipv6 eb)' \
        '--get-zones[get zones]' \
        '--get-default-zone[get default zone]' \
        '--set-default-zone+[zone]:zone:(public block dmz drop external home internal trusted work)' \
        '--list-all[list all rules]' \
        '--list-services[list services]' \
        '--list-ports[list ports]' \
        '--list-sources[list sources]' \
        '--list-interfaces[list interfaces]' \
        '*--add-service+[service]:service:' \
        '*--remove-service+[service]:service:' \
        '*--add-port+[port/protocol]:port/protocol:' \
        '*--remove-port+[port/protocol]:port/protocol:' \
        '*--add-source+[source]:source:' \
        '*--remove-source+[source]:source:' \
        '*--add-interface+[interface]:interface:_net_interfaces' \
        '*--remove-interface+[interface]:interface:_net_interfaces' \
        '*--add-masquerade[add masquerade]' \
        '*--remove-masquerade[remove masquerade]' \
        '*--add-rich-rule+[rule]:rule:' \
        '*--remove-rich-rule+[rule]:rule:' \
        '--direct[direct passthrough]' \
        '*::extra:_files'
}

_firewall-cmd "$@"
