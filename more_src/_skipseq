#compdef skipseq
# Documentation: https://man.archlinux.org/search?q=skipseq
# Reference accessed: 2026-05-16

# EMBOSS skipseq: read a sequence set and skip the first N entries
# (drop the head of a sequence stream). Output the remainder.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequences=[input sequence(s)]:sequence USA:_files' \
  '-skip=[number of sequences to discard from the start]:n:' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output sequence format]:format:(fasta embl genbank swiss gcg pir nbrf raw msf ace text)' \
  '*:sequence USA:_files' && ret=0

return ret
