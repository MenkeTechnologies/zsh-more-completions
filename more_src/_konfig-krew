#compdef konfig-krew

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a commands=(
      import:'merge kubeconfig snippets into the active config'
      merge:'concatenate kubeconfig files into one output'
      export:'emit a kubeconfig with only selected contexts'
    )
    _describe -t commands command commands && ret=0
    ;;
  (args)
    case $words[1] in
      import)
        _arguments -s -S \
          '--save[persist merged kubeconfig]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:kubeconfig file:_files' && ret=0
        ;;
      merge)
        _arguments -s -S \
          '--preserve-structure[keep credential file references]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:kubeconfig file:_files' && ret=0
        ;;
      export)
        _arguments -s -S \
          '(-k --kubeconfig)'{-k+,--kubeconfig=}'[comma separated kubeconfig paths]:paths:' \
          '(- *)'{-h,--help}'[show help]' \
          '*:context name:_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
