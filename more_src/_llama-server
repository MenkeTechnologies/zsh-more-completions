#compdef llama-server

# Zsh completion for llama-server - llama.cpp HTTP server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-m --model)'{-m,--model}'[model path]:model file:_files -g "*.gguf"' \
  '(-a --alias)'{-a,--alias}'[set model alias]:alias' \
  '--host=[IP address to listen on]:address' \
  '--port=[port to listen on]:port' \
  '(-c --ctx-size)'{-c,--ctx-size}'[size of the prompt context]:size' \
  '(-n --predict)'{-n,--predict}'[number of tokens to predict]:tokens' \
  '(-ngl --gpu-layers)'{-ngl,--gpu-layers}'[number of layers to offload to GPU]:layers' \
  '--split-mode=[how to split the model across GPUs]:mode:(none layer row)' \
  '--main-gpu=[the GPU to use for the model]:GPU index' \
  '--tensor-split=[how to split tensors across GPUs]:split ratios' \
  '(-t --threads)'{-t,--threads}'[number of threads]:threads' \
  '(-tb --threads-batch)'{-tb,--threads-batch}'[number of threads for batch processing]:threads' \
  '(-b --batch-size)'{-b,--batch-size}'[logical batch size]:size' \
  '(-ub --ubatch-size)'{-ub,--ubatch-size}'[physical batch size]:size' \
  '--rope-scaling=[RoPE scaling type]:type:(none linear yarn)' \
  '--rope-freq-base=[RoPE base frequency]:frequency' \
  '--rope-freq-scale=[RoPE frequency scaling factor]:factor' \
  '--yarn-ext-factor=[YaRN extrapolation mix factor]:factor' \
  '--yarn-attn-factor=[YaRN magnitude scaling factor]:factor' \
  '--yarn-beta-slow=[YaRN high correction dim]:dim' \
  '--yarn-beta-fast=[YaRN low correction dim]:dim' \
  '(-fa --flash-attn)'{-fa,--flash-attn}'[enable Flash Attention]' \
  '--cache-type-k=[KV cache data type for K]:type:(f16 f32 q8_0 q4_0 q4_1 q5_0 q5_1 iq4_nl)' \
  '--cache-type-v=[KV cache data type for V]:type:(f16 f32 q8_0 q4_0 q4_1 q5_0 q5_1 iq4_nl)' \
  '--mlock[force system to keep model in RAM]' \
  '--no-mmap[do not memory-map model]' \
  '--numa=[NUMA optimization]:strategy:(distribute isolate numactl)' \
  '--cont-batching[enable continuous batching]' \
  '--no-cont-batching[disable continuous batching]' \
  '-np[number of parallel sequences to decode]:slots' \
  '--parallel=[number of parallel sequences to decode]:slots' \
  '--system-prompt-file=[file containing system prompt]:file:_files' \
  '--chat-template=[set custom chat template]:template' \
  '--log-disable[disable logging to file]' \
  '--log-file=[specify log file path]:file:_files' \
  '--log-format=[set log output format]:format:(json text)' \
  '--metrics[enable Prometheus /metrics endpoint]' \
  '--no-slots[do not show slot data in /metrics endpoint]' \
  '--slot-save-path=[path to save slot KV cache]:directory:_files -/' \
  '--api-key=[set API key for authentication]:key' \
  '--api-key-file=[path to file containing API key]:file:_files' \
  '--ssl-key-file=[path to SSL private key file]:file:_files' \
  '--ssl-cert-file=[path to SSL certificate file]:file:_files' \
  '--embeddings[enable embedding extraction endpoint]' \
  '--reranking[enable reranking endpoint]' \
  '--timeout=[server timeout in seconds]:seconds' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--seed=[RNG seed]:seed' \
  '--temp=[temperature]:temperature' \
  '--top-k=[top-k sampling]:k' \
  '--top-p=[top-p sampling]:p' \
  '--min-p=[min-p sampling]:p' \
  '--repeat-penalty=[penalize repeat sequence of tokens]:penalty' \
  '--presence-penalty=[presence penalty]:penalty' \
  '--frequency-penalty=[frequency penalty]:penalty' \
  '--lora=[apply LoRA adapter]:file:_files' \
  '--lora-scaled=[apply LoRA adapter with scaling]:file scale' \
  '(-h --help)'{-h,--help}'[show help message and exit]' && ret=0

return ret
