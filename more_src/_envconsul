#compdef envconsul

# Zsh completion for envconsul - populate env from Consul/Vault

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'-version'[show version]' \
  '-config=[path to config file]:config file:_files' \
  '-consul-addr=[Consul HTTP API address]:address:_urls' \
  '-consul-auth=[Consul API basic auth (user\:pass)]:auth:' \
  '-consul-retry[enable Consul retry]' \
  '-consul-retry-attempts=[number of Consul retry attempts]:attempts:' \
  '-consul-retry-backoff=[Consul retry backoff duration]:duration:' \
  '-consul-ssl[enable Consul SSL]' \
  '-consul-ssl-ca-cert=[Consul SSL CA certificate]:ca cert:_files' \
  '-consul-ssl-ca-path=[Consul SSL CA directory]:ca path:_directories' \
  '-consul-ssl-cert=[Consul SSL client certificate]:cert:_files' \
  '-consul-ssl-key=[Consul SSL client key]:key:_files' \
  '-consul-ssl-server-name=[Consul SSL server name for SNI]:name:' \
  '-consul-ssl-verify[verify Consul SSL certificates]' \
  '-consul-token=[Consul API token]:token:' \
  '-kill-signal=[signal to send on change]:signal:(SIGHUP SIGTERM SIGINT SIGQUIT SIGKILL SIGUSR1 SIGUSR2)' \
  '-log-level=[log level]:level:(debug info warn err)' \
  '-max-stale=[maximum staleness of a query]:duration:' \
  '-once[run once and exit]' \
  '*-prefix=[Consul key prefix to watch]:prefix:' \
  '-pristine[do not inherit existing environment]' \
  '-sanitize[replace invalid characters in keys]' \
  '*-secret=[Vault secret path to watch]:secret path:' \
  '-syslog[send output to syslog]' \
  '-syslog-facility=[syslog facility]:facility:(LOCAL0 LOCAL1 LOCAL2 LOCAL3 LOCAL4 LOCAL5 LOCAL6 LOCAL7)' \
  '-upcase[convert environment variable keys to uppercase]' \
  '-vault-addr=[Vault API address]:address:_urls' \
  '-vault-renew-token[renew Vault token]' \
  '-vault-retry[enable Vault retry]' \
  '-vault-ssl[enable Vault SSL]' \
  '-vault-token=[Vault API token]:token:' \
  '-vault-unwrap-token[unwrap Vault token]' \
  '-wait=[minimum and maximum wait time]:wait (min\:max):' \
  '*:command and arguments: _normal'
