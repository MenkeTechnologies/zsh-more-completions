#compdef g.list
# GRASS GIS: list available data files matching specified types and patterns

local ret=1

_arguments -s -S \
  '--help[print usage summary]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  '--ui[force launching GUI dialog]' \
  '-i[disregard case when matching patterns]' \
  '-r[apply basic regular expressions]' \
  '-e[apply extended regular expressions]' \
  '-t[include data type information in output]' \
  '-m[show fully-qualified names with mapset]' \
  'type=[data type(s)]:type:(raster raster_3d vector label region group all)' \
  'pattern=[map name search pattern]:pattern' \
  'exclude=[map name exclusion pattern]:pattern' \
  'mapset=[mapset name(s) to search]:mapset' \
  'separator=[field delimiter]:sep:(pipe comma space tab newline)' \
  'region=[saved region name to filter by overlap]:region' \
  'output=[output file name]:file:_files' \
  'format=[output format]:format:(plain shell json)' && ret=0

return ret
