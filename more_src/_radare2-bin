#compdef radare2 r2
# _radare2-bin — radare2 reverse-engineering framework (pancake); CLI disassembler/debugger/hex editor with scripting
# upstream: https://github.com/radareorg/radare2

_radare2-bin() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-vv[verbose version]' \
        '-V[bare version]' \
        '-a+[force architecture]:arch:(arm arm64 mips ppc sparc x86)' \
        '-b+[bits per word]:n:(8 16 32 64)' \
        '-c+[run command]:cmd:' \
        '-d[debug mode]' \
        '-D+[backend debugger]:backend:(esil gdb wind native)' \
        '-e+[set option]:k=v:' \
        '-f[block size from file]' \
        '-F+[forced binary format]:fmt:' \
        '-i+[script file]:file:_files' \
        '-I+[init script]:file:_files' \
        '-k+[kernel hint]:str:' \
        '-l+[plugin path]:path:_files' \
        '-L+[list io plugins]:str:' \
        '-m+[map offset]:n:' \
        '-M[disable plugin loading]' \
        '-n[do not load rbin info]' \
        '-N[do not parse cfg]' \
        '-o+[file offset]:n:' \
        '-p+[load project]:project:' \
        '-P+[script file as cmd line]:file:_files' \
        '-q[quiet (no prompt)]' \
        '-qq[exit after batch]' \
        '-Q[silent run]' \
        '-r+[radare init file]:file:_files' \
        '-R+[set option (alias for -e)]:k=v:' \
        '-s+[seek address]:addr:' \
        '-t[load binary info in thread]' \
        '-T[do not compute file hashes]' \
        '-u[do not use rabin2 mapping]' \
        '-w[write mode]' \
        '-x[load symbol cache]' \
        '-X+[command output to var]:var:' \
        '-z[do not load strings]' \
        '-zz[load strings even in raw mode]' \
        '*:binary:_files'
}

_radare2-bin "$@"
