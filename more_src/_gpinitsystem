#compdef gpinitsystem

_arguments -s \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-c=[cluster configuration file]:file:_files' \
  '-I=[input configuration file]:file:_files' \
  '-h=[hostfile listing segment hosts]:file:_files' \
  '-O=[write configuration to output file]:file:_files' \
  '-B=[segments created in parallel]:n:' \
  '-D[debug log level]' \
  '-a[do not prompt for confirmation]' \
  '-l=[log directory]:dir:_files -/' \
  '-n=[locale name]:locale:' \
  '--locale=[default locale]:locale:' \
  '--lc-collate=[LC_COLLATE locale]:locale:' \
  '--lc-ctype=[LC_CTYPE locale]:locale:' \
  '--lc-messages=[LC_MESSAGES locale]:locale:' \
  '--lc-monetary=[LC_MONETARY locale]:locale:' \
  '--lc-numeric=[LC_NUMERIC locale]:locale:' \
  '--lc-time=[LC_TIME locale]:locale:' \
  '-e=[superuser password]:password:' \
  '-s=[standby coordinator host]:host:_hosts' \
  '-P=[standby coordinator port]:port:' \
  '-S=[standby coordinator data dir]:dir:_files -/' \
  '-m=[max connections (coordinator)]:n:' \
  '-b=[shared buffers]:size:' \
  '-p=[postgres conf parameters file]:file:_files' \
  '--mirror-mode=[mirroring mode]:mode:(spread grouped)' \
  '--max_connections=[coordinator max_connections]:n:' \
  '--shared_buffers=[coordinator shared_buffers]:size:'
