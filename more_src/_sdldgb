#compdef sdldgb
# Documentation: https://sourceforge.net/p/sdcc/code/HEAD/tree/trunk/sdcc/sdas/linksrc/lkmain.c
# Reference accessed: 2026-05-21
# Verified: lkmain.c usetxt[] usage strings (sdld/aslink shared core).

# sdldgb: SDCC Game Boy linker (aslink-derived)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-p[echo commands to stdout (default)]' \
  '-n[no echo of commands to stdout]' \
  '-c[interactive ASlink prompt input]' \
  '-f+[command file input (.lk)]:file:_files -g "*.lk"' \
  '-k+[library path specification]:path:_files -/' \
  '-l+[library file specification]:lib:_files -g "*.lib"' \
  '-b+[area base address (area=expression)]:area_expr:' \
  '-g+[global symbol value (sym=expression)]:sym_expr:' \
  '-m[generate map output (.map)]' \
  '-w[wide listing format for map file]' \
  '-x[hexadecimal map output (default)]' \
  '-d[decimal map output]' \
  '-q[octal map output]' \
  '-i[output Intel Hex (.ihx)]' \
  '-s[output Motorola S-record (.s19)]' \
  '-j[NoICE debug output (.noi)]' \
  '-y[SDCDB debug output (.cdb)]' \
  '-u[update listing file(s) with link data (.rst)]' \
  '-z[disable case sensitivity for symbols]' \
  '-e[end input]' \
  '*:object/library file:_files -g "*.(rel|lib|o)"' && ret=0
return ret
