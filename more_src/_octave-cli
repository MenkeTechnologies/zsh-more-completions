#compdef octave-cli
# Documentation: https://man.archlinux.org/search?q=octave-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug parser]' \
  '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
  '(-q --quiet --silent)'{-q,--quiet,--silent}'[suppress startup message]' \
  '(-f --no-init-file)'{-f,--no-init-file}'[do not read init files]' \
  '(-W --no-window-system)'{-W,--no-window-system}'[disable graphics]' \
  '(-H --no-history)'{-H,--no-history}'[do not save history]' \
  '(--eval)--eval=+[evaluate code]:code:' \
  '(--exec-path)--exec-path=+[exec path]:path:' \
  '(--image-path)--image-path=+[image path]:path:' \
  '(--info-file)--info-file=+[info file]:file:_files' \
  '(--info-program)--info-program=+[info program]:cmd:_command_names' \
  '(--norc)--norc[no rc files]' \
  '(--path)--path=+[search path]:path:' \
  '(--traditional --braindead)--traditional[matlab-compatible]' \
  '(--persist)--persist[stay interactive]' \
  '(--echo-commands)--echo-commands[echo commands]' \
  '(--line-editing)--line-editing[force line editing]' \
  '(--no-line-editing)--no-line-editing[disable line editing]' \
  '*:script:_files -g "*.{m,oct}"' && ret=0

return ret
