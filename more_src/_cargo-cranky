#compdef cargo-cranky
# Documentation: https://github.com/ericseppanen/cargo-cranky
# Source: ericseppanen/cargo-cranky src/main.rs — wrapper for cargo clippy with shared lint config.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-v --verbose)'{-v,--verbose}'[print the inner cargo clippy command]' \
    '--dry-run[print what would be run without running cargo clippy]' \
    '(- *)'{-h,--help}'[show help]' \
    '*::clippy-args:_default' \
    && ret=0

return ret
