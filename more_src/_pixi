#compdef pixi

local curcontext="$curcontext" state line ret=1

_pixi_commands() {
  local -a commands=(
    'add:add dependencies to the project'
    'clean:clean build artifacts'
    'completion:generate shell completions'
    'config:manage configuration'
    'global:manage global tools'
    'info:show project info'
    'init:initialize a new project'
    'install:install project dependencies'
    'list:list project dependencies'
    'project:manage project settings'
    'remove:remove dependencies'
    'run:run a task or command'
    'search:search for packages'
    'self-update:update pixi itself'
    'shell:start a shell in the environment'
    'shell-hook:print shell hook'
    'task:manage tasks'
    'tree:show dependency tree'
    'update:update dependencies'
    'upload:upload a package'
  )
  _describe -t commands 'pixi command' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' \
  '--color[coloring]:when:(always never auto)' \
  '--manifest-path[path to manifest]:file:_files' \
  '1:command:_pixi_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      add)
        _arguments -s -S \
          '--channel[channel to use]:channel' \
          '(-e --environment)'{-e,--environment}'[environment]:env' \
          '--feature[feature]:feature' \
          '--host[add as host dependency]' \
          '--build[add as build dependency]' \
          '--no-install[skip install after add]' \
          '--platform[platform]:platform' \
          '--pypi[add as PyPI dependency]' \
          '*:package' && ret=0
        ;;
      init)
        _arguments -s -S \
          '-c[channels]:channel' \
          '--format[manifest format]:format:(pixi conda)' \
          '--import[import from environment file]:file:_files' \
          '--platform[platform]:platform' \
          '*:directory:_directories' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(-e --environment)'{-e,--environment}'[environment]:env' \
          '--frozen[install from lockfile only]' \
          '--locked[require lockfile is up-to-date]' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(-e --environment)'{-e,--environment}'[environment]:env' \
          '--frozen[use frozen lockfile]' \
          '--locked[require lockfile is up-to-date]' \
          '*:task or command' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '(-e --environment)'{-e,--environment}'[environment]:env' \
          '--feature[feature]:feature' \
          '--host[remove host dependency]' \
          '--build[remove build dependency]' \
          '--pypi[remove PyPI dependency]' \
          '*:package' && ret=0
        ;;
      search)
        _arguments -s -S \
          '-c[channel]:channel' \
          '--limit[max results]:count' \
          '--platform[platform]:platform' \
          '*:query' && ret=0
        ;;
      global)
        _arguments -s -S \
          '1:action:(install remove list upgrade sync)' \
          '*:package' && ret=0
        ;;
      task)
        _arguments -s -S \
          '1:action:(add remove alias list)' \
          '*:task' && ret=0
        ;;
      shell)
        _arguments -s -S \
          '(-e --environment)'{-e,--environment}'[environment]:env' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
