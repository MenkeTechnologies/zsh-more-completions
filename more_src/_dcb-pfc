#compdef dcb-pfc
# Documentation: https://man.archlinux.org/man/dcb-pfc.8.en
# dcb pfc - manage Priority-based Flow Control

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'dcb pfc command' \
      'show[display PFC settings]' 'set[modify PFC settings]' \
      'dev[network device]' 'pfc-cap[supported PFC traffic classes]' \
      'prio-pfc[priority PFC map]' 'macsec-bypass[MACsec bypass on/off]' \
      'delay[PFC delay]' 'requests[PFC request counters]' \
      'indications[PFC indication counters]' && ret=0
    ;;
esac

return ret
