#compdef mpytool
# Documentation: https://github.com/cortexm/mpytool
# mpytool - manage files on devices running MicroPython

local ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(-p --port)'{-p,--port}'=[serial port]:port:_files -g "/dev/tty* /dev/cu*"' \
  '(-b --baud)'{-b,--baud}'=[serial baudrate]:baud:(9600 115200 230400 460800 921600)' \
  '(-a --address)'{-a,--address}'=[connect over TCP host:port]:address:' \
  '--ssl[enable SSL/TLS connection]' \
  '--ssl-ca=[SSL with custom CA certificate]:ca:_files' \
  '--ssl-no-hostname[skip SSL hostname verification]' \
  '--ssl-no-verify[skip all SSL verification]' \
  '(-c --chunk)'{-c,--chunk}'=[chunk size]:chunk:(512 1K 2K 4K 8K 16K 32K)' \
  '(-v --verbose)'{-v,--verbose}'[show commands being executed]' \
  '(-q --quiet)'{-q,--quiet}'[disable all output]' \
  '(-f --force)'{-f,--force}'[force operation]' \
  '(-m --mpy)'{-m,--mpy}'[compile .py to .mpy via mpy-cross]' \
  '(-w --writable)'{-w,--writable}'[mount as read-write]' \
  '(-y --yes)'{-y,--yes}'[accept without prompting]' \
  '--no-compress[disable compression]' \
  '--editor=[editor for file editing]:editor:' \
  '-V[show version]' \
  '*::command:(ls tree cat cp mv rm mkdir pwd cd df sha256 reset stop sleep wipe repl monitor exec run edit rtc mount ln info flash speedtest)' && ret=0

return ret
