#compdef gps
# Documentation: https://book.git-ps.sh/tool
# Git Patch Stack workflow CLI (git-ps-rs)

local ret=1
local curcontext="$curcontext" state line

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--no-color[disable color output]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'gps command' \
      'branch[create a normal git branch from a patch or series]' \
      'request-review-branch[create a request review branch and record association]' \
      'integrate[integrate the specified patch into upstream]' \
      'int[integrate the specified patch into upstream]' \
      'list[list the stack of patches and their state]' \
      'ls[list the stack of patches and their state]' \
      'rebase[interactively rebase your stack of patches]' \
      'pull[pull changes from upstream and rebase stack]' \
      'request-review[request review of the specified patch]' \
      'rr[request review of the specified patch]' \
      'show[show the identified patch in raw form]' \
      'sync[synchronize patch with the remote]' \
      'isolate[isolate a patch for manual testing]' \
      'iso[isolate a patch for manual testing]' \
      'checkout[checkout the patch, leaving a headless state]' \
      'co[checkout the patch, leaving a headless state]' \
      'create-patch[create a patch from staged changes]' \
      'c[create a patch from staged changes]' \
      'amend-patch[amend the top patch with staged changes]' \
      'a[amend the top patch with staged changes]' \
      'status[get the status of local and staged changes]' \
      's[get the status of local and staged changes]' \
      'add[add changes to the stage]' \
      'log[display a log of integrated patches]' \
      'unstage[unstage currently staged changes]' \
      'upstream-patches[list the upstream patches]' \
      'up[list the upstream patches]' \
      'fetch[fetch state from remote and show upstream patches]' \
      'f[fetch state from remote and show upstream patches]' \
      'backup-stack[backup current patch stack to a branch]' \
      'bs[backup current patch stack to a branch]' && ret=0
    ;;
  args)
    case $line[1] in
      integrate|int)
        _arguments -s \
          '-n[use the provided branch name]:branch name:' \
          '(-k --keep-branch)'{-k,--keep-branch}'[keep request-review branches around]' \
          '(-f --force)'{-f,--force}'[skip safety checks and publish]' \
          ':patch index:' && ret=0
        ;;
      request-review|rr|request-review-branch|sync)
        _arguments -s \
          '-n[use the provided branch name]:branch name:' \
          ':patch index:' && ret=0
        ;;
      branch)
        _arguments -s \
          '-n[use the provided branch name]:branch name:' \
          ':start patch index:' \
          '::end patch index:' && ret=0
        ;;
      rebase)
        _arguments -s \
          '--continue[continue a rebase that was paused]' && ret=0
        ;;
      add)
        _arguments -s \
          '(-i --interactive)'{-i,--interactive}'[interactive picking]' \
          '(-p --patch)'{-p,--patch}'[select hunks interactively]' \
          '(-e --edit)'{-e,--edit}'[edit current diff and apply]' \
          '(-A --all)'{-A,--all}'[add changes from all tracked and untracked files]' \
          '*:file:_files' && ret=0
        ;;
      unstage)
        _arguments -s '*:file:_files' && ret=0
        ;;
      show|checkout|co)
        _arguments -s ':patch index:' && ret=0
        ;;
      isolate|iso)
        _arguments -s '::patch index:' && ret=0
        ;;
      backup-stack|bs)
        _arguments -s ':branch name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
