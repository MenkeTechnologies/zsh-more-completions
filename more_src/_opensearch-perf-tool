#compdef opensearch-perf-tool
# Documentation: https://man.archlinux.org/search?q=opensearch-perf-tool
# Reference accessed: 2026-05-16

# opensearch-perf-tool: simple OpenSearch performance benchmarking tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--host=[OpenSearch host]:host:_hosts' \
  '--port=[OpenSearch port]:port:' \
  '--scheme=[scheme]:scheme:(http https)' \
  '--user=[user]:user:_users' \
  '--password=[password]:pass:' \
  '--ca=[CA cert]:file:_files' \
  '--index=[index]:index:' \
  '--bulk-size=[bulk size]:n:' \
  '--clients=[concurrent clients]:n:' \
  '--duration=[duration]:duration:' \
  '--warmup=[warmup duration]:duration:' \
  '--workload=[workload]:workload:(index search update delete)' \
  '*::opensearch-perf-tool args:_files' && ret=0
return ret
