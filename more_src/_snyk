#compdef snyk

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'auth:authenticate with Snyk'
      'test:test for vulnerabilities'
      'monitor:monitor for new vulnerabilities'
      'container:test and monitor container images'
      'iac:test infrastructure as code'
      'code:test source code'
      'log4shell:find Log4Shell vulnerabilities'
      'config:manage Snyk config'
      'policy:manage .snyk policy file'
      'ignore:ignore an issue'
      'wizard:interactive fix wizard'
      'protect:apply .snyk policy patches'
    )
    _describe -t commands 'snyk command' commands && ret=0
    ;;
  args)
    case $words[1] in
      test)
        _arguments -s -S \
          '--all-projects[test all projects]' \
          '--detection-depth=[detection depth]:depth' \
          '*--exclude=[directories to exclude]:dir' \
          '--prune-repeated-subdependencies[prune repeated subdeps]' \
          '--print-deps[print dependency tree]' \
          '--remote-repo-url=[remote repo URL]:url' \
          '--dev[include dev dependencies]' \
          '--org=[organization]:org' \
          '--file=[manifest file]:file:_files' \
          '--package-manager=[package manager]:manager' \
          '--severity-threshold=[severity threshold]:severity:(low medium high critical)' \
          '--fail-on=[fail condition]:condition:(all upgradable patchable)' \
          '--json[output as JSON]' \
          '--sarif[output as SARIF]' \
          '--json-file-output=[JSON output file]:file:_files' \
          '--sarif-file-output=[SARIF output file]:file:_files' \
          '*:path:_files' \
          && ret=0
        ;;
      monitor)
        _arguments -s -S \
          '--all-projects[monitor all projects]' \
          '--detection-depth=[detection depth]:depth' \
          '*--exclude=[directories to exclude]:dir' \
          '--dev[include dev dependencies]' \
          '--org=[organization]:org' \
          '--file=[manifest file]:file:_files' \
          '--project-name=[project name]:name' \
          '--remote-repo-url=[remote repo URL]:url' \
          '*:path:_files' \
          && ret=0
        ;;
      container)
        _arguments -s -S -C \
          '1:subcommand:(test monitor)' \
          '--severity-threshold=[severity threshold]:severity:(low medium high critical)' \
          '--file=[Dockerfile]:file:_files' \
          '--json[output as JSON]' \
          '--sarif[output as SARIF]' \
          '--org=[organization]:org' \
          '*:image' \
          && ret=0
        ;;
      iac)
        _arguments -s -S -C \
          '1:subcommand:(test describe update-exclude-policy)' \
          '--severity-threshold=[severity threshold]:severity:(low medium high critical)' \
          '--json[output as JSON]' \
          '--sarif[output as SARIF]' \
          '--org=[organization]:org' \
          '--rules=[custom rules path]:path:_files' \
          '*:path:_files' \
          && ret=0
        ;;
      code)
        _arguments -s -S -C \
          '1:subcommand:(test)' \
          '--severity-threshold=[severity threshold]:severity:(low medium high critical)' \
          '--json[output as JSON]' \
          '--sarif[output as SARIF]' \
          '--org=[organization]:org' \
          '*:path:_files' \
          && ret=0
        ;;
      auth)
        _arguments -s -S \
          '1:token' \
          && ret=0
        ;;
      config)
        _arguments -s -S -C \
          '1:subcommand:(set get unset clear)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
