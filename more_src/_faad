#compdef faad
# Documentation: faad -h (FAAD2 v2.11.2)
# Source: MPEG-4 AAC decoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-i[show info about input]' \
    '-a+[write MPEG-4 ADTS output]:file:_files -g "*.aac"' \
    '-t[assume old ADTS format]' \
    '-o+[output filename]:file:_files' \
    '-f+[output format]:format:(1\:WAV 2\:RAW)' \
    '-b+[output sample format]:format:(1\:16bit\ PCM 2\:24bit\ PCM 3\:32bit\ PCM 4\:32bit\ float 5\:64bit\ float)' \
    '-s+[force samplerate]:samplerate:' \
    '-l+[object type]:type:(1\:Main 2\:LC 4\:LTP 23\:LD)' \
    '-d[downmix 5.1 to 2 channels]' \
    '-w[write output to stdout]' \
    '-g[disable gapless decoding]' \
    '1:aac file:_files -g "*.(aac|m4a|mp4)"' \
    && ret=0

return ret
