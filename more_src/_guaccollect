#compdef guaccollect

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(* -)'{-v,--version}'[show version]' \
  '--gql-addr=[GraphQL endpoint]:addr:' \
  '--header-file=[header file]:file:_files' \
  '--csub-addr=[collectsubscribers address]:addr:' \
  '--csub-tls[use TLS for collectsubscribers]' \
  '--csub-tls-skip-verify[skip TLS verify]' \
  '1:collector subcommand: _default' \
  '*::args: _default'
