#compdef omnivore-cli
# _omnivore-cli — Omnivore open-source read-later CLI alias (omnivore-app team, TypeScript); commander
# upstream: https://github.com/omnivore-app/omnivore

_omnivore-cli() {
    local -a sub=(
        'login:save API key'
        'logout:clear API key'
        'whoami:show current user'
        'save:save url to library'
        'save-file:save HTML file to library'
        'save-bulk:save many urls'
        'list:list articles'
        'search:search library'
        'get:get article'
        'archive:archive article'
        'unarchive:unarchive article'
        'delete:delete article'
        'labels:list:list labels'
        'labels:create:create label'
        'labels:delete:delete label'
        'labels:add:add labels to article'
        'labels:remove:remove labels from article'
        'highlights:list:list highlights'
        'highlights:get:get highlight'
        'highlights:create:create highlight'
        'highlights:update:update highlight'
        'highlights:delete:delete highlight'
        'subscriptions:list:list subscriptions'
        'subscriptions:rss:add:subscribe rss'
        'subscriptions:rss:remove:unsubscribe rss'
        'subscriptions:newsletter:add:subscribe newsletter'
        'subscriptions:newsletter:remove:unsubscribe newsletter'
        'export:export library'
        'import:import library'
        'integrations:list:list integrations'
        'integrations:enable:enable integration'
        'integrations:disable:disable integration'
        'rules:list:list rules'
        'rules:create:create rule'
        'rules:delete:delete rule'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--api-key=+[api key]:str:' \
        '--endpoint=+[api endpoint]:url:_urls' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'omnivore subcommand' sub ;;
        args)
            case $words[1] in
                save) _arguments \
                    '1:url:_urls' \
                    '--labels=+[labels csv]:str:' \
                    '--archive[archive immediately]' ;;
                save-file) _arguments \
                    '1:html file:_files -g "*.{html,htm}"' \
                    '--url=+[source url]:url:_urls' \
                    '--labels=+[labels csv]:str:' ;;
                save-bulk) _arguments \
                    '1:url file:_files' \
                    '--labels=+[labels csv]:str:' \
                    '--rate-limit=+[per second]:n:' ;;
                list) _arguments \
                    '--query=+[search query]:str:' \
                    '-q+[search query]:str:' \
                    '--limit=+[limit]:n:' \
                    '--include-content[include content]' \
                    '--format=+[format]:f:(json csv markdown table)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_omnivore-cli "$@"
