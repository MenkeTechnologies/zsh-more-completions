#compdef eastwood
# _eastwood — Jonas Enlund Eastwood Clojure lint tool CLI alias (clojure-emacs team, Clojure); leiningen plugin
# upstream: https://github.com/clojure-emacs/eastwood

_eastwood() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config-files=+[config files]:file:_files' \
        '--source-paths=+[source paths]:dir:_files -/' \
        '--test-paths=+[test paths]:dir:_files -/' \
        '--namespaces=+[namespaces csv]:str:' \
        '--exclude-namespaces=+[exclude ns csv]:str:' \
        '--linters=+[linters csv]:str:' \
        '--exclude-linters=+[exclude linters csv]:str:' \
        '--debug=+[debug categories]:str:' \
        '--ignored-faults=+[ignored faults edn]:str:' \
        '--continue-on-exception[continue on exception]' \
        '--no-rethrow-exceptions[do not rethrow]' \
        '--out=+[output file]:file:_files' \
        '--no-color[no color]' \
        '*:command:'
}

_eastwood "$@"
