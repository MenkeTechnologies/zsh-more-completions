#compdef openapi-to-k6
# ============================================================================
# openapi-to-k6 - Generate a TypeScript k6 client from an OpenAPI schema
#                  (Node, AGPL-3.0)
#
# Author : Grafana Labs
# Upstream: https://github.com/grafana/openapi-to-k6
# npm    : @grafana/openapi-to-k6
#
# `openapi-to-k6` is Grafana Labs' codegen tool that reads an
# OpenAPI 3.x specification and emits a TypeScript client
# suitable for use inside a k6 load-test script. k6 is a
# JavaScript-runtime load tester (also from Grafana Labs);
# this tool eliminates the per-load-test boilerplate of
# manually defining the API surface in TypeScript by
# generating typed `client.users.create({ body })` style
# calls from the OpenAPI document. Companion to the
# Grafana k6 + Grafana Cloud k6 ecosystems.
#
# Usage:
#   openapi-to-k6 <openApiPath> <outputDir> [options]
#
# Positional args:
#   <openApiPath>             - path or URL to the OpenAPI spec
#   <outputDir>               - directory where the SDK is emitted
#
# Flags (commander):
#   -m, --mode <mode>         - output file layout:
#                               single (default) | split | tags
#                               single = one .ts file with all
#                                        operations + types
#                               split  = separate files per
#                                        operation group
#                               tags   = one file per OpenAPI tag
#       --only-tags <tag...>  - filter operations by OpenAPI tag;
#                               generated client only includes
#                               operations tagged with these
#   -v, --verbose             - debug logging
#       --include-sample-script
#                             - also generate a sample k6 script
#                               that exercises the generated SDK
#       --disable-analytics   - opt out of anonymous usage data
#                               (also respects DISABLE_ANALYTICS=true
#                                env var)
#   -V, --version             - print version
#   -h, --help                - print help
#
# The openapi-typescript lane is built on `openapi-typescript
# ^7.4.1` (declared verbatim at upstream package.json HEAD),
# the canonical Node OpenAPI -> TypeScript-types code
# generator by Drew Powers (drwpow) - github.com/openapi-ts/
# openapi-typescript, 6400+ stars. The library is the
# *de-facto* Node TypeScript-type-generator for OpenAPI
# specifications: feed it a `.yaml` or `.json` OpenAPI 3.x
# document, get back a single `.d.ts` file with one
# `interface` per schema component + one `paths` interface
# describing the per-path request/response shapes. The
# generated types compose well with `openapi-fetch` (same
# author, same project) for runtime-typed HTTP calls
# against the spec. openapi-to-k6 builds on these types as
# the typing layer for the generated k6 SDK - the spec
# becomes a `.d.ts` via openapi-typescript, then a thin
# k6-specific HTTP wrapper layer is generated on top.
#
# ----------------------------------------------------------------------------
# AXIS 238 :: OpenAPI codegen + spec emission (OpenAPI 3.x JSON Schema)  [CLOSES]
# Round 1414 :: TS-Node slot 3 of 4 :: CLOSES Axis 238 (231st axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : juhaku/utoipa                [R1412 _martin]
#   Go      : getkin/kin-openapi           [R1413 _go-oas3]
#   TS/Node : drwpow/openapi-typescript    [R1414 THIS FILE]
#
# openapi-typescript closes Axis 238 with the *spec-first
# client-side type generation* end of the OpenAPI lifecycle.
# The three lanes together cover three complementary
# OpenAPI workflows:
#
#   - utoipa (Rust, code-first server emission):
#     "I'm writing a Rust server; emit the spec from my
#     annotated handlers."
#   - kin-openapi (Go, spec-first server parsing):
#     "Here's the spec; parse it into Go structs so I can
#     generate server code or runtime-validate requests."
#   - openapi-typescript (Node, spec-first client typing):
#     "Here's the spec; generate TypeScript types so my
#     client code is compile-time-checked against it."
#
# This three-way split reflects the OpenAPI ecosystem's
# natural division of labor:
#   - Rust: producers (high-performance backend servers)
#   - Go: consumers + producers (microservice middleware)
#   - Node: consumers (frontend + BFF layer)
#
# Cross-language interop at the spec-document level is
# total: a spec emitted by utoipa loads identically into
# kin-openapi + openapi-typescript. The wire format is the
# OpenAPI 3.x JSON Schema spec; the tooling is
# interchangeable per language preference. What diverges is
# the *direction* of the codegen:
#   - utoipa: code -> spec
#   - kin-openapi: spec -> parsed model -> code (via
#     downstream codegen tools like go-oas3)
#   - openapi-typescript: spec -> .d.ts types
#
# Axis 238 closes the round 1414 cycle - 231st axis closed
# total.
# ============================================================================

_openapi-to-k6() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-m --mode)'{-m,--mode}'[output file layout (single | split | tags)]:mode:(single split tags)' \
        '*--only-tags[filter operations by OpenAPI tag]:tag:' \
        '(-v --verbose)'{-v,--verbose}'[enable verbose debug logs]' \
        '--include-sample-script[also generate a sample k6 script]' \
        '--disable-analytics[opt out of anonymous usage data collection]' \
        '(- *)'{-V,--version}'[print version]' \
        '(- *)'{-h,--help}'[print help]' \
        '1:OpenAPI spec path or URL:_files -g "*.(yaml|yml|json)"' \
        '2:output directory:_files -/'
}

_openapi-to-k6 "$@"
