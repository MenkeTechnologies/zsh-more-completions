#compdef minimap2

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-a[output in SAM format]' \
  '-o[output file]:output file:_files' \
  '-t[number of threads]:threads' \
  '-x[preset]:preset:(map-pb map-ont map-hifi asm5 asm10 asm20 splice splice\:hq sr lr\:hq)' \
  '-k[k-mer size]:kmer size' \
  '-w[minimizer window size]:window size' \
  '-H[use homopolymer-compressed k-mer]' \
  '-I[split index for every N bases]:bases' \
  '-d[dump index to file]:index file:_files' \
  '-f[filter out fraction of repetitive minimizers]:fraction' \
  '-g[stop chain enlongation if gap longer than N]:gap' \
  '-G[max intron length for RNA-seq]:length' \
  '-F[max fragment length for SR]:length' \
  '-r[chaining/alignment bandwidth]:bandwidth' \
  '-n[minimal number of minimizers on a chain]:count' \
  '-m[minimal chaining score]:score' \
  '-A[matching score]:score' \
  '-B[mismatch penalty]:penalty' \
  '-O[gap open penalty]:penalty' \
  '-E[gap extension penalty]:penalty' \
  '-z[Z-drop score]:score' \
  '-s[minimal peak DP alignment score]:score' \
  '-p[minimal secondary-to-primary score ratio]:ratio' \
  '-N[retain at most N secondary alignments]:count' \
  '--secondary=[output secondary alignments]:yn:(yes no)' \
  '--cs=[output cs tag]:tag:(short long)' \
  '--MD[output MD tag]' \
  '--eqx[output =/X CIGAR operators]' \
  '-Y[use soft clipping for supplementary alignments]' \
  '-R[SAM read group line]:read group' \
  '-c[output CIGAR in PAF]' \
  '--paf-no-hit[output unmapped queries in PAF]' \
  '--sam-hit-only[output only hits in SAM]' \
  '--no-long-join[disable long gap patching]' \
  '--splice[enable splice alignment mode]' \
  '--sr[short read alignment mode]' \
  '--for-only[only map to forward strand]' \
  '--rev-only[only map to reverse strand]' \
  '--heap-sort=[sort order]:order:(pos)' \
  '-K[minibatch size]:size' \
  '--seed=[random seed]:seed' \
  '--cap-kallisto[use k-mer counting]' \
  '-L[write CIGAR with >65535 ops in CG tag]' \
  '-Q[ignore base quality]' \
  '--no-kalloc[use the libc default allocator]' \
  '--print-qname[print query name]' \
  '-2[use two I/O threads]' \
  '--split-prefix=[prefix for split index]:prefix' \
  '1:target:_files -g "*.{fa,fasta,fna,fa.gz,fasta.gz,fq,fastq,fq.gz,fastq.gz,mmi}"' \
  '2:query:_files -g "*.{fa,fasta,fna,fa.gz,fasta.gz,fq,fastq,fq.gz,fastq.gz}"' && ret=0

return ret
