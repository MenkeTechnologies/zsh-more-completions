#compdef mkrepo

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-n --name)'{-n,--name}'[repository name]:name' \
  '(-d --description)'{-d,--description}'[repository description]:description' \
  '(-l --license)'{-l,--license}'[license type]:license:(MIT Apache-2.0 GPL-3.0 BSD-2-Clause BSD-3-Clause ISC MPL-2.0 Unlicense)' \
  '(-t --template)'{-t,--template}'[template to use]:template' \
  '--private[create private repository]' \
  '--no-git[skip git initialization]' \
  '--no-readme[skip README generation]' \
  '--gitignore[add .gitignore for language]:language' \
  '(-o --output)'{-o,--output}'[output directory]:directory:_directories' \
  '*:name:'
