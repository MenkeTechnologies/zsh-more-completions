#compdef argo-rollouts-cli
# _argo-rollouts-cli — Argo Rollouts progressive delivery K8s controller CLI alias (argoproj team, Go); cobra
# upstream: https://github.com/argoproj/argo-rollouts

_argo-rollouts-cli() {
    local -a sub=(
        'abort:abort rollout'
        'create:create rollout from file'
        'create analysisrun:create analysis run'
        'create experiment:create experiment'
        'dashboard:start dashboard'
        'get:get resource'
        'get rollout:get rollout'
        'get analysisrun:get analysis run'
        'get experiment:get experiment'
        'lint:lint manifests'
        'list:list resources'
        'list rollouts:list rollouts'
        'list experiments:list experiments'
        'notifications:notifications commands'
        'pause:pause rollout'
        'promote:promote rollout'
        'restart:restart pods'
        'retry:retry rollout'
        'set:set value on rollout'
        'set image:set image'
        'status:show rollout status'
        'terminate:terminate experiment'
        'terminate experiment:terminate experiment'
        'terminate analysisrun:terminate analysis run'
        'undo:undo rollout to revision'
        'version:show version'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--namespace=+[namespace]:str:' \
        '-n+[namespace]:str:' \
        '--context=+[context]:str:' \
        '--cluster=+[cluster]:str:' \
        '--kubeconfig=+[file]:file:_files' \
        '--user=+[user]:_users' \
        '--server=+[server]:str:' \
        '--token=+[token]:str:' \
        '--insecure-skip-tls-verify[skip tls verify]' \
        '-o+[format]:f:(yaml json wide name)' \
        '--output=+[format]:f:(yaml json wide name)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kubectl-argo-rollouts subcommand' sub ;;
        args)
            case $words[1] in
                get|status|abort|pause|promote|restart|retry|terminate|undo) _arguments \
                    '*:rollout:' \
                    '--full[full]' \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--timeout=+[timeout]:str:' \
                    '--no-color[no color]' ;;
                create|lint) _arguments \
                    '--filename=+[file]:file:_files' \
                    '-f+[file]:file:_files' \
                    '--no-color[no color]' ;;
                set:image|set) _arguments \
                    '1:rollout:' \
                    '2:container=image:' \
                    '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_argo-rollouts-cli "$@"
