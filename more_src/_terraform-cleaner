#compdef terraform-cleaner

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(* -)'{-v,--version}'[show version]' \
  '-dry-run[print unused names instead of rewriting]' \
  '-verbose[verbose logging]' \
  '-var-dir=[directory with tfvars]:dir:_files -/' \
  '1:terraform module directory:_files -/'
