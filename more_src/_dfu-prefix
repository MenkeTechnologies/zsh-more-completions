#compdef dfu-prefix

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --stellaris-address)'{-s,--stellaris-address}'+[stellaris addr]:addr:' \
  '(-T --stellaris)'{-T,--stellaris}'[stellaris file]' \
  '(-L --lpc-prefix)'{-L,--lpc-prefix}'[LPC prefix file]' \
  '(-c --check)'{-c,--check}'+[check]:file:_files' \
  '(-a --add)'{-a,--add}'+[add]:file:_files' \
  '(-D --delete)'{-D,--delete}'+[delete]:file:_files' && ret=0

return ret
