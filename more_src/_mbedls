#compdef mbedls
# Documentation: https://github.com/ARMmbed/mbed-os-tools/tree/master/packages/mbed-ls
# mbed-ls - list Mbed-enabled devices connected to the host

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-m,--mock}'[override platform name as platform_id:name]:mock:' \
  '(-j --json)'{-j,--json}'[output detected devices as JSON]' \
  '(-s --simple)'{-s,--simple}'[print simplified table without headers]' \
  '(-u --list-unmounted)'{-u,--list-unmounted}'[include unmounted devices]' \
  '--skip-retarget[skip retargeting and return unmodified results]' && ret=0

return ret
