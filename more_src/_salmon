#compdef salmon

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'index:build a salmon index'
      'quant:quantify transcript expression'
      'alevin:single-cell RNA-seq quantification'
      'swim:perform super-secret operation'
      'quantmerge:merge multiple quantification results'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      index)
        _arguments -s -S \
          '(-t --transcripts)'{-t,--transcripts}'[transcript FASTA file]:file:_files -g "*.{fa,fasta,fa.gz}"' \
          '(-i --index)'{-i,--index}'[index directory]:directory:_files' \
          '(-k --kmerLen)'{-k,--kmerLen}'[k-mer length]:length' \
          '--gencode[input is GENCODE formatted]' \
          '--keepDuplicates[keep duplicate transcripts]' \
          '--keepFixedFasta[keep fixed FASTA]' \
          '(-p --threads)'{-p,--threads}'[number of threads]:threads' \
          '--type=[index type]:type:(puff dense sparse)' \
          '-d[decoy sequences]:file:_files -g "*.{fa,fasta,txt}"' \
          '--decoys=[decoy sequences]:file:_files' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      quant)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'[index directory]:directory:_directories' \
          '(-l --libType)'{-l,--libType}'[library type]:type:(A IU ISF ISR MU MSF MSR OU OSF OSR)' \
          '(-r --unmatedReads)'{-r,--unmatedReads}'[unpaired reads]:file:_files -g "*.{fq,fastq,fq.gz,fastq.gz}"' \
          '(-1 --mates1)'{-1,--mates1}'[read1 files]:files:_files -g "*.{fq,fastq,fq.gz,fastq.gz}"' \
          '(-2 --mates2)'{-2,--mates2}'[read2 files]:files:_files -g "*.{fq,fastq,fq.gz,fastq.gz}"' \
          '(-o --output)'{-o,--output}'[output directory]:directory:_files' \
          '(-p --threads)'{-p,--threads}'[number of threads]:threads' \
          '--validateMappings[enable selective alignment]' \
          '--seqBias[enable sequence-specific bias correction]' \
          '--gcBias[enable GC bias correction]' \
          '--posBias[enable positional bias correction]' \
          '-g[gene map file]:file:_files' \
          '--geneMap=[gene map file]:file:_files' \
          '--numBootstraps=[number of bootstraps]:count' \
          '--numGibbsSamples=[number of Gibbs samples]:count' \
          '--incompatPrior=[prior for incompatible mappings]:prior' \
          '--writeMappings=[write mappings to file]:file:_files' \
          '--writeUnmappedNames[write unmapped read names]' \
          '--useVBOpt[use variational Bayesian optimization]' \
          '--rangeFactorizationBins=[range factorization bins]:bins' \
          '--fldMean=[fragment length mean]:mean' \
          '--fldSD=[fragment length standard deviation]:sd' \
          '-a[alignment-based mode]:file:_files -g "*.{bam,sam}"' \
          '--alignments=[alignment file]:file:_files -g "*.{bam,sam}"' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      alevin)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'[index directory]:directory:_directories' \
          '(-l --libType)'{-l,--libType}'[library type]:type:(A IU ISF ISR)' \
          '(-1 --mates1)'{-1,--mates1}'[CB+UMI read files]:files:_files' \
          '(-2 --mates2)'{-2,--mates2}'[read files]:files:_files' \
          '(-o --output)'{-o,--output}'[output directory]:directory:_files' \
          '(-p --threads)'{-p,--threads}'[number of threads]:threads' \
          '--chromium[10x Chromium v2]' \
          '--chromiumV3[10x Chromium v3]' \
          '--dropseq[Drop-seq]' \
          '--gemcode[10x Gemcode]' \
          '--citeseq[CITE-seq]' \
          '--celseq[CEL-seq]' \
          '--celseq2[CEL-seq2]' \
          '--inDropV2[inDropV2]' \
          '--splitseqV1[SPLiT-seq v1]' \
          '--splitseqV2[SPLiT-seq v2]' \
          '--tgMap=[transcript-to-gene map]:file:_files' \
          '--dumpCsv[dump CSV output]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      quantmerge)
        _arguments -s -S \
          '--quants=[quantification directories]:directories:_directories' \
          '--names=[sample names]:names' \
          '-o[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '--column=[column to merge]:column:(TPM NumReads)' \
          '--genes[merge at gene level]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
