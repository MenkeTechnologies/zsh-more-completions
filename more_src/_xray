#compdef xray
# Documentation: https://xtls.github.io/en/document/command.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (XTLS Xray-core).

_xray_subcommands() {
    local -a commands
    commands=(
        'run:run Xray with config (default command)'
        'version:show version'
        'api:call Xray API (gRPC, must be enabled in config)'
        'convert:convert config formats'
        'tls:TLS tools'
        'uuid:generate a UUID'
        'x25519:generate X25519 key pair'
        'wg:generate WireGuard key pair'
        'mldsa65:generate ML-DSA-65 post-quantum signature key pair'
        'mlkem768:generate ML-KEM-768 post-quantum key exchange pair'
        'vlessenc:generate VLESS encryption/decryption configuration'
        'help:show help'
    )
    _describe -t commands 'xray command' commands
}

_xray() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '1:command:_xray_subcommands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $line[1] in
                run)
                    _arguments \
                        '*-config=[specify config file]:file:_files' \
                        '*-c=[specify config file]:file:_files' \
                        '-confdir=[directory containing multiple config files]:dir:_directories' \
                        '-format=[config file format]:fmt:(json toml yaml)' \
                        '-test[validate configuration without launching]' \
                        '-dump[display merged configuration result]' && ret=0
                    ;;
                api)
                    local -a apicmds
                    apicmds=(
                        'restartlogger:restart the logger'
                        'stats:get statistics'
                        'statsquery:query statistics'
                        'statssys:get system statistics'
                        'adi:add inbounds'
                        'ado:add outbounds'
                        'rmi:remove inbounds'
                        'rmo:remove outbounds'
                    )
                    _describe -t apicmds 'api subcommand' apicmds && ret=0
                    ;;
                convert)
                    local -a convcmds
                    convcmds=(
                        'pb:convert JSON configs to protobuf'
                        'json:convert typedMessage to JSON'
                    )
                    _describe -t convcmds 'convert subcommand' convcmds && ret=0
                    ;;
                tls)
                    local -a tlscmds
                    tlscmds=(
                        'cert:generate TLS certificates'
                        'ping:ping domain with TLS handshake'
                        'certChainHash:calculate certificate hash'
                    )
                    _describe -t tlscmds 'tls subcommand' tlscmds && ret=0
                    ;;
                uuid)
                    _arguments \
                        '-i+[custom input for deterministic UUID]:input:' && ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_xray "$@"
