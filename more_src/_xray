#compdef xray

_xray_commands() {
    local -a commands
    commands=(
        'scan:Run a security scan'
        'audit:Audit project dependencies'
        'config:Manage configuration'
        'curl:Execute an HTTP request'
        'offline-update:Update offline security data'
        'version:Show version'
    )
    _describe -t commands 'xray command' commands
}

_xray() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '--url[Xray server URL]:url:' \
        '--user[Username]:user:' \
        '--password[Password]:password:' \
        '--access-token[Access token]:token:' \
        '1:command:_xray_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                scan)
                    _arguments \
                        '--target[Scan target URL or path]:target:_files' \
                        '--type[Scan type]:type:(sast dast iast sca)' \
                        '--output[Output file path]:file:_files' \
                        '--format[Output format]:format:(json xml html sarif)' \
                        '--severity[Minimum severity]:severity:(info low medium high critical)' \
                        '--timeout[Scan timeout in seconds]:seconds:' \
                        '--threads[Number of threads]:threads:' \
                        '--proxy[Proxy URL]:proxy:' \
                        '--exclude[Exclude pattern]:pattern:' \
                        '--include[Include pattern]:pattern:' \
                        '--recursive[Scan recursively]' \
                        '--follow-redirects[Follow HTTP redirects]' \
                        '--max-depth[Maximum crawl depth]:depth:'
                    ;;
                audit)
                    _arguments \
                        '--project[Project path]:path:_directories' \
                        '--format[Output format]:format:(json table sarif)' \
                        '--severity[Minimum severity]:severity:(info low medium high critical)' \
                        '--watches[Watches to use]:watches:' \
                        '--licenses[Check license compliance]' \
                        '--fail[Fail on violation]' \
                        '--output[Output file]:file:_files'
                    ;;
                config)
                    _arguments \
                        '1:action:(show edit)' \
                        '--interactive[Interactive configuration]'
                    ;;
            esac
            ;;
    esac
}

_xray "$@"
