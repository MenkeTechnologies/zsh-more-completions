#compdef accelsearch
# Documentation: https://github.com/scottransom/presto/blob/master/docs/accelsearch.1
# PRESTO: search a FFT for pulsars using the Fourier-domain acceleration method.

local ret=1

_arguments -s -S \
  '-ncpus=[number of OpenMP processors]:n:' \
  '-lobin=[first Fourier frequency in the data file]:lobin:' \
  '-numharm=[number of harmonics to sum (power-of-two)]:numharm:' \
  '-zmax=[max Fourier freq deriv to search]:zmax:' \
  '-wmax=[max Fourier freq double deriv to search]:wmax:' \
  '-sigma=[cutoff sigma for choosing candidates]:sigma:' \
  '-rlo=[lowest Fourier frequency to search]:rlo:' \
  '-rhi=[highest Fourier frequency to search]:rhi:' \
  '-flo=[lowest frequency (Hz) to search]:flo:' \
  '-fhi=[highest frequency (Hz) to search]:fhi:' \
  '-inmem[compute full f-fdot plane in memory]' \
  '-photon[poissonian data: use freq 0 for power norm]' \
  '-median[use block-median power normalization]' \
  '-locpow[use double-tophat local-power normalization]' \
  '-zaplist=[file of freqs+widths to zap from the FFT]:file:_files' \
  '-baryv=[radial velocity component (v/c) to target]:baryv:' \
  '-otheropt[use the alternative optimization]' \
  '-noharmpolish[do not use harmpolish by default]' \
  '-noharmremove[do not remove harmonically related cands]' \
  '*:input FFT or dat file:_files' && ret=0

return ret
