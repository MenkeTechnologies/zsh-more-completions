#compdef jpegoptim-cli
# _jpegoptim-cli — Timo Kokkonen jpegoptim utility to optimize/compress JPEG files CLI alias (tjko team, C); custom argparse
# upstream: https://github.com/tjko/jpegoptim

_jpegoptim-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-d+[dest dir]:dir:_files -/' \
        '--dest=+[dest dir]:dir:_files -/' \
        '-f[force]' \
        '--force[force]' \
        '-m+[quality 0-100]:n:' \
        '--max=+[quality 0-100]:n:' \
        '-n[no actions]' \
        '--noaction[no actions]' \
        '-p[preserve file modification times]' \
        '--preserve[preserve file modification times]' \
        '-P[preserve file permissions]' \
        '--preserve-perms[preserve file permissions]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-t[show total time]' \
        '--totals[show total time]' \
        '-T+[threshold pct]:n:' \
        '--threshold=+[threshold pct]:n:' \
        '-b+[buffer kbytes]:n:' \
        '--csv[print CSV stats]' \
        '--all-normal[force normal mode]' \
        '--all-progressive[force progressive mode]' \
        '--strip-none[do not strip]' \
        '--strip-all[strip all markers]' \
        '-s[strip all markers]' \
        '--strip-com[strip comments]' \
        '--strip-exif[strip EXIF]' \
        '--strip-iptc[strip IPTC]' \
        '--strip-icc[strip ICC]' \
        '--strip-xmp[strip XMP]' \
        '-o[overwrite original]' \
        '--overwrite[overwrite original]' \
        '-S+[size limit]:str:' \
        '--size=+[size limit]:str:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-w+[workers]:n:' \
        '--workers=+[workers]:n:' \
        '*:files:_files -g "*.{jpg,jpeg,JPG,JPEG}"'
}

_jpegoptim-cli "$@"
