#compdef qpwgraph
# Documentation: https://man.archlinux.org/man/qpwgraph.1.en
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-\? --help)'{-\?,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --activated)'{-a,--activated}'[activated patchbay]' \
  '(-d --deactivated)'{-d,--deactivated}'[deactivated patchbay]' \
  '(-x --exclusive)'{-x,--exclusive}'[exclusive patchbay]' \
  '(-n --nonexclusive)'{-n,--nonexclusive}'[non-exclusive patchbay]' \
  '(-m --minimized)'{-m,--minimized}'[start minimized]' \
  '(-r --remote)'{-r,--remote=}'[remote daemon name]:name:' \
  '*:patchbay file:_files -g "*.qpwgraph"' && ret=0

return ret
