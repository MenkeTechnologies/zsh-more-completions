#compdef kn knative
# _knative — Knative kn (kubectl-style CLI for Knative Serving + Eventing on K8s; service/revision/route/configuration/trigger/broker/source/channel/subscription/sink/binding/plugin/options subcommands)
# upstream: https://github.com/knative/client
# Subcommands from knative/client pkg/kn/commands on tip.

_knative() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '--context+[kubecontext]:context:' \
        '-n+[namespace]:namespace:' \
        '1: :->kind' \
        '*::arg:->args'
    case $state in
        kind)
            _describe -t commands 'kn resource' \
                '(service revision route configuration trigger broker source channel subscription sink-binding container-source apiserver-source ping-source plugin options completion version)'
            ;;
        args)
            _describe -t commands 'action' '(list describe create update apply delete get import export logs)' ;;
    esac
}

_knative "$@"
