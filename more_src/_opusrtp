#compdef opusrtp
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/opusrtp.1.html
# capture or generate Opus RTP streams

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message]' \
  '(-V --version)'{-V,--version}'[display version information]' \
  '--quiet[suppress program output]' \
  '--sniff[sniff the network for active RTP sessions and save to .opus files]' \
  '*:opus file:_files -g "*.opus"' && ret=0

return ret
