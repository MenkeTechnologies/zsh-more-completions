#compdef shmemrun
# Documentation: https://www.open-mpi.org/doc/v3.0/man1/shmemrun.1.php
# Execute serial and parallel jobs in Open SHMEM

local ret=1

_arguments -s -S \
  '(-np -c -n --n)'{-np,-c,-n,--n}'[run this many copies of the program on the given nodes]:count:' \
  '--hostfile[provide a hostfile to use]:file:_files' \
  '(--host -H)'{--host,-H}'[list of hosts on which to invoke processes]:hosts:_hosts' \
  '--map-by[map to the specified object (defaults to socket)]:object:' \
  '--bind-to[bind processes to the specified object (defaults to core)]:object:' \
  '--rank-by[rank in round-robin fashion according to the specified object]:object:' \
  '*-x[export the specified environment variable to the remote nodes]:var:' \
  '*--mca[send arguments to various MCA modules]:key:' \
  '(--wdir -wd)'{--wdir,-wd}'[change to the directory before the program executes]:dir:_directories' \
  '--display-map[display a table showing the mapped location of each process]' \
  '--tag-output[tag each line of output with jobid and rank]' \
  '--timestamp-output[timestamp each line of output]' \
  '--output-filename[redirect output of all processes to a process-unique file]:file:_files' \
  '--report-bindings[report any bindings for launched processes]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-V --version)'{-V,--version}'[print version number]' \
  '(-h --help)'{-h,--help}'[display help for this command]' \
  '*::command:_command_names -e' && ret=0

return ret
