#compdef afdconnectivity
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/afdconnectivity.html
# Source: MRtrix3/mrtrix3 cmd/afdconnectivity.cpp — AFD-based fibre connectivity estimate (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-wbft+[whole-brain track file to improve volume estimate]:file:_files -g "*.{tck,trk}"' \
    '-afd_map+[output an AFD map for the pathway]:file:_files -g "*.{nii,nii.gz,mif}"' \
    '-all_fixels[contribute all fixel AFD even with -wbft]' \
    '-quiet[suppress progress; output connectivity value only]' \
    '1:image (input FOD image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:tracks (input track file):_files -g "*.{tck,trk}"' \
    && ret=0

return ret
