#compdef mConvert
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mConvert.html
# Convert a FITS image between data types (BITPIX)

local ret=1

_arguments -s -S \
  '-d+[debugging level (1-3)]:level' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '-b+[output BITPIX value]:bitpix:(8 16 32 -32 -64)' \
  '-min+[input value treated as minimum in output]:minval' \
  '-max+[input value treated as maximum in output]:maxval' \
  '-blank+[value for blank/NaN pixels in output]:blankval' \
  '1:input FITS:_files -g "*.fits"' \
  '2:output FITS:_files -g "*.fits"' && ret=0

return ret
