#compdef escrotum
# Documentation: https://github.com/Roger/escrotum/blob/master/README.rst
# escrotum - Linux screen capture using pygtk, inspired by scrot

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-v --version)'{-v,--version}'[output version information and exit]' \
  '(-s --select)'{-s,--select}'[interactively choose a window or rectangle with the mouse]' \
  '(-x --xid)'{-x,--xid}'[take a screenshot of the xid window]:xid:' \
  '(-d --delay)'{-d,--delay}'[wait DELAY seconds before taking a shot]:delay:' \
  '--selection-delay=[delay in milliseconds between selection and screenshot]:milliseconds:' \
  '(-c --countdown)'{-c,--countdown}'[show a countdown before taking the shot (requires delay)]' \
  '(-C --clipboard)'{-C,--clipboard}'[store the image on the clipboard]' \
  '(-e --exec)'{-e,--exec}'[run the command after the image is taken]:command:' \
  '(-r --record)'{-r,--record}'[screen recording]' \
  '*:filename:_files' && ret=0

return ret
