#compdef enjarify
# Documentation: https://man.archlinux.org/search?q=enjarify
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output JAR]:file:_files -g "*.jar"' \
  '(-f --force)'{-f,--force}'[force overwrite]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--fast)--fast[fast mode]' \
  '*: :_files -g "*.apk *.dex *.jar"' && ret=0

return ret
