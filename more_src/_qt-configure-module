#compdef qt-configure-module
# Documentation: https://doc.qt.io/qt-6/qt-configure-module.html
# Reference accessed: 2026-05-20
# Verified: local `qt-configure-module --help` output:
#   Usage: qt-configure-module <module-source-dir> [options]
#   To display module options run: qt-configure-module <module-source-dir> -help
# Per-module options vary, so this completion just exposes -help and the
# module source directory positional argument.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-help[show help for the module]' \
  '*:module source directory:_files -/' && ret=0

return ret
