#compdef gdformat
# _gdformat — GDScript formatter from gdtoolkit (Scony/godot-gdscript-toolkit)
# upstream: https://github.com/Scony/godot-gdscript-toolkit
# Flags from gdtoolkit/formatter/__main__.py (docopt).

_gdformat() {
    local -a args
    args=(
        '(-c --check)'{-c,--check}'[only check whether files are formatted; do not rewrite]'
        '(-d --diff)'{-d,--diff}'[print suggested formatting changes (implies --check)]'
        '(-f --fast)'{-f,--fast}'[skip the safety checks]'
        '(-l --line-length)'{-l+,--line-length=}'[max characters per line]:n:'
        '(-s --use-spaces)'{-s+,--use-spaces=}'[use N spaces for indent instead of tabs]:n:'
        '--dump-default-config[dump default config to gdformatrc and exit]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '*:GDScript file or directory:_files -g "*.gd"'
    )
    _arguments -s -S $args
}

_gdformat "$@"
