#compdef scw
# _scaleway-cli — Scaleway Cloud CLI (Scaleway, Go); manage Scaleway resources from terminal
# upstream: https://github.com/scaleway/scaleway-cli

_scaleway-cli() {
    local -a sub=(
        'account:account commands'
        'apple-silicon:Apple silicon servers'
        'autocomplete:autocomplete commands'
        'baremetal:bare-metal servers'
        'billing:billing'
        'block:block storage'
        'cockpit:cockpit observability'
        'completion:print shell completion'
        'config:config commands'
        'container:serverless containers'
        'dns:DNS commands'
        'domain:domains'
        'edge-services:edge services'
        'feedback:send feedback'
        'function:serverless functions'
        'help:show help'
        'iam:IAM commands'
        'info:print info'
        'init:initialize CLI'
        'instance:Compute Instances'
        'iot:IoT Hub'
        'iotsdk:IoT SDK commands'
        'jobs:serverless jobs'
        'k8s:Kapsule managed k8s'
        'lb:load balancers'
        'login:login'
        'logout:logout'
        'mnq:Messaging + Queuing'
        'object:Object Storage (s3)'
        'rdb:Managed Databases'
        'redis:Redis instances'
        'registry:Container Registry'
        'secret:Secret Manager'
        'serverless-sqldb:Serverless SQL DB'
        'tem:Transactional Email'
        'version:show version'
        'vpc:VPCs'
        'vpcgw:VPC gateway'
        'webhosting:WebHosting'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-c+[config file]:file:_files' \
        '--config+[config file]:file:_files' \
        '-D[debug]' \
        '--debug[debug]' \
        '-o+[output format]:fmt:(human json yaml)' \
        '--output+[output format]:fmt:' \
        '-p+[profile]:profile:' \
        '--profile+[profile]:profile:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'scw subcommand' sub ;;
        args)
            case $words[1] in
                instance) _arguments '1:instance cmd:(server volume snapshot image placement-group ssh-key ip)' '*:args:' ;;
                k8s) _arguments '1:k8s cmd:(cluster pool node version kubeconfig)' '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_scaleway-cli "$@"
