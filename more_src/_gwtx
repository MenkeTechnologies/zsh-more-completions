autoload -U is-at-least

_gwtx() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_gwtx_commands" \
"*::: :->gwtx" \
&& ret=0
    case $state in
    (gwtx)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:gwtx-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
'--on-conflict=[How to handle conflicts\: abort, skip, overwrite, backup]:MODE:_default' \
'-b+[Create a new branch <name> starting at <commitish>]:name:_default' \
'-B+[Create or reset branch <name> to <commitish>]:name:_default' \
'(--no-color)--color=[When to use colored output (always, auto, never)]:WHEN:(auto always never)' \
'-i[Interactive mode\: select branch and path interactively]' \
'--interactive[Interactive mode\: select branch and path interactively]' \
'--dry-run[Preview actions without executing]' \
'--no-setup[Skip .gwtx.yaml setup, run git worktree add only]' \
'-f[Force creation even if branch is checked out elsewhere]' \
'--force[Force creation even if branch is checked out elsewhere]' \
'-d[Detach HEAD in the new worktree]' \
'--detach[Detach HEAD in the new worktree]' \
'--no-checkout[Do not checkout after creation]' \
'--lock[Lock the worktree after creation]' \
'--track[Set up tracking for the branch]' \
'--no-track[Do not set up tracking]' \
'--guess-remote[Guess remote for tracking]' \
'--no-guess-remote[Do not guess remote]' \
'-q[Suppress output from both gwtx and git worktree]' \
'--quiet[Suppress output from both gwtx and git worktree]' \
'--no-color[Disable colored output (equivalent to --color=never)]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Path for the new worktree (required unless --interactive):_files' \
'::commitish -- Branch or commit to checkout:_default' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
'(--no-color)--color=[When to use colored output (always, auto, never)]:WHEN:(auto always never)' \
'-i[Interactive mode\: select worktrees to remove]' \
'--interactive[Interactive mode\: select worktrees to remove]' \
'--dry-run[Preview actions without executing]' \
'-f[Force removal even if worktree is dirty or locked]' \
'--force[Force removal even if worktree is dirty or locked]' \
'-q[Suppress output]' \
'--quiet[Suppress output]' \
'--no-color[Disable colored output (equivalent to --color=never)]' \
'-h[Print help]' \
'--help[Print help]' \
'*::paths -- Worktree paths to remove (required unless --interactive):_files' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'(--no-color)--color=[When to use colored output (always, auto, never)]:WHEN:(auto always never)' \
'-p[Show only worktree paths]' \
'--path-only[Show only worktree paths]' \
'--header[Show header row]' \
'--no-color[Disable colored output (equivalent to --color=never)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ls)
_arguments "${_arguments_options[@]}" : \
'(--no-color)--color=[When to use colored output (always, auto, never)]:WHEN:(auto always never)' \
'-p[Show only worktree paths]' \
'--path-only[Show only worktree paths]' \
'--header[Show header row]' \
'--no-color[Disable colored output (equivalent to --color=never)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_gwtx__config_commands" \
"*::: :->config" \
&& ret=0

    case $state in
    (config)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:gwtx-config-command-$line[1]:"
        case $line[1] in
            (validate)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(schema)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_gwtx__config__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:gwtx-config-help-command-$line[1]:"
        case $line[1] in
            (validate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(schema)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(trust)
_arguments "${_arguments_options[@]}" : \
'(--no-color)--color=[When to use colored output (always, auto, never)]:WHEN:(auto always never)' \
'--show[Show trusted hooks without trusting]' \
'--no-color[Disable colored output (equivalent to --color=never)]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Path to repository (defaults to current directory):_files' \
&& ret=0
;;
(untrust)
_arguments "${_arguments_options[@]}" : \
'--list[List all trusted repositories]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Path to repository (defaults to current directory):_files' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(man)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_gwtx__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:gwtx-help-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
":: :_gwtx__help__config_commands" \
"*::: :->config" \
&& ret=0

    case $state in
    (config)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:gwtx-help-config-command-$line[1]:"
        case $line[1] in
            (validate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(schema)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
(trust)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(untrust)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(man)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_gwtx_commands] )) ||
_gwtx_commands() {
    local commands; commands=(
'add:Add a new worktree with setup' \
'remove:Remove worktrees with safety checks' \
'list:List all worktrees' \
'ls:List all worktrees' \
'config:Manage .gwtx.yaml configuration' \
'trust:Trust hooks in .gwtx.yaml for the current repository' \
'untrust:Revoke trust for hooks in .gwtx.yaml' \
'completions:Generate shell completion script' \
'man:Generate man page' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'gwtx commands' commands "$@"
}
