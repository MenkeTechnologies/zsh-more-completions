#compdef hgvsToVcf
# UCSC kent: convert HGVS terms to VCF tab-separated output

local ret=1

_arguments -s -S \
  '-noLeftShift[do not do the VCF-conventional left shifting of ambiguous placements]' \
  '1:database:' \
  '2:input hgvs:_files' \
  '3:output vcf:_files -g "*.vcf"' && ret=0

return ret
