#compdef unfchk
# Documentation: https://gaussian.com/unfchk/
# Convert a formatted Gaussian checkpoint file back to binary form

local ret=1

_arguments -s -S \
  '-m[memory to allocate to the utility]:amount' \
  '-matrix[convert Fortran unformatted matrix element file to binary checkpoint]' \
  '-rawmatrix[convert raw binary matrix element file to binary checkpoint]' \
  '-i8[8-byte integers in Fortran unformatted matrix element files]' \
  '-i4[4-byte integers in Fortran unformatted matrix element files]' \
  '-i2[2-byte integers for two-electron integral labels]' \
  '*:formatted checkpoint file:_files -g "*.fchk"' && ret=0

return ret
