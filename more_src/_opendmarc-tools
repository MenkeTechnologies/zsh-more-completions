#compdef opendmarc-check opendmarc-expire opendmarc-import opendmarc-importstats opendmarc-params opendmarc-reports
# Documentation: https://manpages.debian.org/bookworm/opendmarc-tools/
# Reference accessed: 2026-05-20
# Verified: Debian opendmarc-tools package manpages (opendmarc-check,
# opendmarc-expire, opendmarc-import, opendmarc-importstats, opendmarc-params,
# opendmarc-reports). Flag inventory follows the upstream manpages.

local curcontext="$curcontext" ret=1

case $service in
  (opendmarc-check)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '*:domain:' && ret=0 ;;
  (opendmarc-expire)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-c --config)'{-c,--config}'+[config file]:file:_files' \
      '(-d --database)'{-d,--database}'+[database name]:name:' \
      '(-x --expire-days)'{-x,--expire-days}'+[days to keep]:days:' \
      '(-u --user)'{-u,--user}'+[database user]:user:' \
      '(-p --password)'{-p,--password}'+[database password]:pw:' \
      '(-h --host)'{-h,--host}'+[database host]:host:_hosts' \
      '(-P --port)'{-P,--port}'+[database port]:port:' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0 ;;
  (opendmarc-import|opendmarc-importstats)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-d --database)'{-d,--database}'+[database name]:name:' \
      '(-u --user)'{-u,--user}'+[database user]:user:' \
      '(-p --password)'{-p,--password}'+[database password]:pw:' \
      '(-h --host)'{-h,--host}'+[database host]:host:_hosts' \
      '(-P --port)'{-P,--port}'+[database port]:port:' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '*:file:_files' && ret=0 ;;
  (opendmarc-reports)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-c --config)'{-c,--config}'+[config file]:file:_files' \
      '(-d --database)'{-d,--database}'+[database name]:name:' \
      '(-h --host)'{-h,--host}'+[database host]:host:_hosts' \
      '(-P --port)'{-P,--port}'+[database port]:port:' \
      '(-u --user)'{-u,--user}'+[database user]:user:' \
      '(-p --password)'{-p,--password}'+[database password]:pw:' \
      '(-r --report-org)'{-r,--report-org}'+[report org]:org:' \
      '(-e --report-email)'{-e,--report-email}'+[from email]:email:' \
      '(-i --interval)'{-i,--interval}'+[interval hours]:hours:' \
      '(-t --test)'{-t,--test}'[test mode]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-x --x-mailer)'{-x,--x-mailer}'+[X-Mailer header]:header:' \
      '(-A --aggregate)'{-A,--aggregate}'[aggregate reports]' \
      '(-F --forensic)'{-F,--forensic}'[forensic reports]' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0 ;;
esac

return ret
