#compdef twig twig-cli twigfmt
# _twig — Symfony Twig template engine helpers CLI alias (Symfony / SensioLabs, PHP); Symfony Console
# upstream: https://github.com/twigphp/Twig

_twig() {
    local -a sub=(
        'lint:lint Twig templates'
        'debug:debug Twig functions/filters/tags/tests'
        'render:render a Twig template'
        'fmt:format Twig templates'
        'compile:compile a Twig template to PHP'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'twig subcommand' sub ;;
        args)
            case $words[1] in
                lint) _arguments \
                    '--format=+[output format]:fmt:(txt json github)' \
                    '--show-deprecations[show deprecations]' \
                    '--no-config[no config]' \
                    '*:path:_files -g "*.twig *.html.twig"' ;;
                debug) _arguments \
                    '--format=+[output format]:fmt:(txt json text)' \
                    '*:filter:' ;;
                render) _arguments \
                    '--data=+[data json]:str:' \
                    '--data-file=+[data file]:file:_files' \
                    '*:template:_files -g "*.twig *.html.twig"' ;;
                fmt) _arguments \
                    '--check[check only]' \
                    '--diff[show diff]' \
                    '*:path:_files -g "*.twig *.html.twig"' ;;
                compile) _arguments \
                    '--output=+[output file]:file:_files' \
                    '*:template:_files -g "*.twig *.html.twig"' ;;
            esac
            ;;
    esac
}

_twig "$@"
