#compdef dataplaneapi
# Documentation: https://www.haproxy.com/documentation/haproxy-data-plane-api/reference/cli-reference/
# HAProxy Data Plane API server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version and build information]' \
  '(-c --config-file)'{-c,--config-file=}'[path to HAProxy configuration file]:file:_files' \
  '-f[path to Data Plane API configuration file]:file:_files' \
  '--host=[IP address to listen on]:host:_hosts' \
  '--port=[port for non-secure connections]:port:' \
  '--socket-path=[unix domain socket path]:socket:_files' \
  '--scheme=[listeners to enable]:scheme:(http https unix)' \
  '--tls-host=[IP address for TLS listening]:host:_hosts' \
  '--tls-port=[port for secure connections]:port:' \
  '--tls-certificate=[TLS certificate file]:file:_files' \
  '--tls-key=[TLS private key file]:file:_files' \
  '--tls-ca=[TLS certificate authority file]:file:_files' \
  '--read-timeout=[maximum read duration]:duration:' \
  '--write-timeout=[maximum write duration]:duration:' \
  '--cleanup-timeout=[grace period for idle connections]:duration:' \
  '--graceful-timeout=[shutdown grace period]:duration:' \
  '--keep-alive=[TCP keep-alive timeout]:duration:' \
  '--max-header-size=[maximum header size]:size:' \
  '(-t --transaction-dir)'{-t,--transaction-dir=}'[transaction directory]:dir:_files -/' \
  '--backups-dir=[backup files directory]:dir:_files -/' \
  '(-n --backups-number)'{-n,--backups-number=}'[number of backups to retain]:n:' \
  '(-p --maps-dir)'{-p,--maps-dir=}'[maps files directory]:dir:_files -/' \
  '--ssl-certs-dir=[SSL certificates directory]:dir:_files -/' \
  '--spoe-dir=[SPOE directory]:dir:_files -/' \
  '--log-to=[log target]:target:(stdout file syslog)' \
  '--log-file=[log file location]:file:_files' \
  '--log-level=[log level]:level:(trace debug info warning error)' \
  '--log-format=[log format]:format:(text JSON)' \
  '--syslog-address=[syslog server address]:address:' \
  '--syslog-protocol=[syslog protocol]:protocol:(tcp tcp4 tcp6 unix unixgram)' \
  '--syslog-facility=[syslog facility]:facility:' \
  '(-b --haproxy-bin)'{-b,--haproxy-bin=}'[path to HAProxy binary]:file:_files' \
  '(-m --master-runtime)'{-m,--master-runtime=}'[path to master runtime socket]:socket:_files' \
  '--master-worker-mode[enable master worker mode helpers]' \
  '(-r --reload-cmd)'{-r,--reload-cmd=}'[reload command]:cmd:' \
  '(-s --restart-cmd)'{-s,--restart-cmd=}'[restart command]:cmd:' \
  '(-d --reload-delay)'{-d,--reload-delay=}'[minimum delay between reloads in seconds]:seconds:' \
  '--reload-strategy=[reload strategy]:strategy:(systemd s6 custom)' \
  '--validate-cmd=[custom HAProxy configuration validation command]:cmd:' \
  '--uid=[user ID to set on startup]:uid:' \
  '--gid=[group ID to set on startup]:gid:' \
  '(-u --userlist)'{-u,--userlist=}'[userlist for API Basic Authentication]:userlist:' \
  '--userlist-file=[path to separate userlist file]:file:_files' \
  '--max-open-transactions=[active transaction limit]:n:' \
  '--update-map-files[sync map files with runtime values]' \
  '--disable-inotify[disable config file inotify watcher]' \
  '(-i --show-system-info)'{-i,--show-system-info}'[display system info on info endpoint]' \
  '--pid-file=[PID file path]:file:_files' && ret=0

return ret
