#compdef gpg-check-pattern
# Documentation: https://www.gnupg.org/documentation/manuals/gnupg/gpg_002dcheck_002dpattern.html
# GnuPG: check a passphrase given on stdin against a patternfile

local ret=1

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '--check[run only a syntax check on the patternfile]' \
  '(-0 --null)'{-0,--null}'[input is expected to be null delimited]' \
  '--version[print version information]' \
  '--help[show help]' \
  '1:patternfile:_files' && ret=0

return ret
