#compdef bigChainToChain
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# convert bigChain files back into a chain file

local ret=1

_arguments -s -S \
  '-chrom=[restrict to this chromosome]:chrom:' \
  '-start=[restrict to start coordinate]:n:' \
  '-end=[restrict to end coordinate]:n:' \
  '-bed=[restrict to ranges in BED file]:bed:_files' \
  '-positions=[restrict to positions in file]:positions:_files' \
  '-udcDir=[local cache dir for remote bigChain files]:dir:_files -/' \
  '-skipChromCheck[do not check chrom names against bigChain]' \
  '*:bigChain.bb bigLinks.bb output.chain:_files' && ret=0

return ret
