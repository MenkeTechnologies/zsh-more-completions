#compdef ip6tables-save
# _ip6tables-save — netfilter ip6tables-save (dump every IPv6 iptables chain in iptables-restore parseable text; -c include packet+byte counters, -t TABLE limit to one table (filter|nat|mangle|raw|security), -M MODULES module subdir override, -V version, -f file output instead of stdout)
# upstream: https://git.netfilter.org/iptables
# Flags from netfilter/iptables iptables/ip6tables-save.c on tip.

_ip6tables-save() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c[include counters]' \
        '-t+[table]:table:(filter nat mangle raw security)' \
        '-M+[module subdir]:dir:_files -/' \
        '-f+[output file]:file:_files'
}

_ip6tables-save "$@"
