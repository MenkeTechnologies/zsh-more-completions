#compdef sstruct
# Documentation: https://github.com/hypre-space/hypre/blob/master/src/test/sstruct.c
# hypre SStruct (semi-structured grid) linear-system test driver

local ret=1

_arguments -s -S \
  '-help[print usage and exit]' \
  '-in[read problem from input file]:file:_files' \
  '-fromfile[read system from file prefix]:prefix:_files' \
  '-P[processor topology]:Px Py Pz' \
  '-r[refinement per direction]:rx ry rz' \
  '-b[blocking per direction]:bx by bz' \
  '-solver[solver id]:id' \
  '-solver_type[solver type]:type' \
  '-tol[convergence tolerance]:tol' \
  '-itr[max iterations]:n' \
  '-interp[interpolation type]:type' \
  '-relax[relaxation type]:type' \
  '-relax_down[down-cycle relaxation type]:type' \
  '-relax_up[up-cycle relaxation type]:type' \
  '-relax_coarse[coarsest-level relaxation type]:type' \
  '-rap[RAP coarse-grid operator type]:type' \
  '-skip[skip relaxation flag]:flag' \
  '-sym[symmetric storage flag]:flag' \
  '-agg_nl[number of aggressive coarsening levels]:n' \
  '-coarsen[coarsening type]:type' \
  '-max_coarse[max coarse size]:n' \
  '-w[Jacobi relaxation weight]:weight' \
  '-rhsfromfile[read rhs from file]:file:_files' \
  '-rhsfromcosine[generate rhs from cosine function]' \
  '-rhsone[set rhs to all ones]' \
  '-rhsrand[generate random rhs]' \
  '-rhszero[set rhs to all zeros]' \
  '-x0one[initial guess all ones]' \
  '-x0rand[random initial guess]' \
  '-x0zero[zero initial guess]' \
  '-pcgitr[PCG iterations per preconditioner]:n' \
  '-pcgtol[PCG tolerance]:tol' \
  '-repeats[number of solve repeats]:n' \
  '-print[print system to file]' \
  '-seed[random seed]:seed' \
  '-v[verbosity level]:v' \
  '-version[print version and exit]' \
  '*:file:_files' && ret=0

return ret
