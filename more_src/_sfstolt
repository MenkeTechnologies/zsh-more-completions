#compdef sfstolt
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mstolt.c
# Madagascar: post-stack Stolt modeling/migration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'vel=[constant velocity (negative for modeling)]:velocity' \
  'pad=[padding on the time axis]:samples' \
  'stretch=[Stolt stretch parameter]:value' \
  'extend=[trace extension]:samples' \
  'mute=[mute zone]:samples' \
  'minstr=[minimum stretch allowed]:value' \
  '*:RSF file:_files' && ret=0

return ret
