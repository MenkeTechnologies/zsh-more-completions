#compdef ldattach
# _ldattach — OpenBSD ldattach (attach a line discipline to a serial line for in-kernel processing; commonly run from ttys(5) at boot or from rc; -2/-7 framing, -e even, -o odd, -m modem-status, -p hangup-on-close, -h CRTSCTS)
# upstream: https://github.com/openbsd/src (sbin/ldattach)
# Flags from sbin/ldattach/ldattach.8 on tip.

_ldattach() {
    _arguments \
        '-2[2 stop bits]' \
        '-7[7 data bits]' \
        '-d[debug (foreground + stderr)]' \
        '-e[even parity]' \
        '-h[CRTSCTS hardware flow control]' \
        '-m[monitor modem control lines]' \
        '-o[odd parity]' \
        '-p[hangup on close]' \
        '-s+[baud rate]:baud:(50 75 110 150 200 300 600 1200 1800 2400 4800 9600 19200 38400 57600 115200 230400 460800 921600)' \
        '-t+[trigger condition (DCD|carrier)]:cond:' \
        '1:discipline:(empty nmea endrun mskine kine slip ppp)' \
        '2:device:_files -g "/dev/tty*"'
}

_ldattach "$@"
