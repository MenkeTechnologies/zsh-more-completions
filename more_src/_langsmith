#compdef langsmith langsmith-cli
# Documentation: https://man.archlinux.org/search?q=langsmith
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'project:LangSmith project commands (list/get/create/delete/share)'
  'trace:trace commands (list/get/delete/share)'
  'run:run commands (list/get/share)'
  'dataset:dataset commands (list/get/create/delete/import/export)'
  'experiment:experiment commands (list/get/run/compare)'
  'thread:thread commands (list/get/share)'
  'sandbox:sandbox commands (list/get/tunnel/exec)'
  'feedback:feedback commands (list/get/create/delete)'
  'annotation-queue:annotation queue commands'
  'prompt:prompt commands (list/get/create/update/push/pull)'
  'tag:tag commands'
  'config:configure CLI defaults'
  'login:authenticate to LangSmith'
  'logout:clear stored credentials'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--api-key=[LangSmith API key]:key:' \
  '--api-url=[LangSmith API URL]:url:' \
  '--workspace=[workspace id]:id:' \
  '--format=[output format]:format:(json pretty table csv)' \
  '--limit=[pagination limit]:n:' \
  '--offset=[pagination offset]:n:' \
  '--since=[earliest timestamp]:ts:' \
  '--until=[latest timestamp]:ts:' \
  '--last-n-minutes=[lookback minutes]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'langsmith command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (project|run|trace|thread|sandbox|feedback|annotation-queue|prompt|tag|dataset|experiment)
        local -a verbs=(
          'list:list resources'
          'get:get a single resource'
          'create:create a resource'
          'update:update a resource'
          'delete:delete a resource'
          'share:share a resource'
          'tunnel:open a tunnel (sandbox)'
          'exec:execute in a sandbox'
          'import:import dataset/data'
          'export:export dataset/data'
          'run:run an experiment'
          'compare:compare experiments'
        )
        _describe -t verbs 'verb' verbs && ret=0
        _arguments \
          '--project=[filter by project]:project:' \
          '--name-contains=[name filter]:name:' \
          '--tags=[tag filter]:tags:' \
          '--error[errors only]' \
          '--min-latency=[minimum latency seconds]:n:' \
          '--min-tokens=[minimum token count]:n:' \
          '--run-type=[run type]:type:(llm chain tool retriever)' \
          '--include-metadata[include metadata]' \
          '--include-io[include input/output]' \
          '--include-feedback[include feedback]' \
          '--full[include all fields]' \
          '--show-hierarchy[show full run tree]' && ret=0 ;;
      (config)
        _arguments '*::sub:(get set list reset)' && ret=0 ;;
    esac ;;
esac

return ret
