#compdef csh
# _csh-bin — Berkeley C Shell (Bill Joy); original BSD C-style shell, often a tcsh symlink on modern systems
# upstream: https://github.com/csh-org/csh

_csh-bin() {
    _arguments \
        '-b[end of option processing]' \
        '-c+[command]:code:' \
        '-e[errexit]' \
        '-f[fast start]' \
        '-i[interactive]' \
        '-n[parse only]' \
        '-s[read from stdin]' \
        '-t[exit after one command]' \
        '-v[verbose]' \
        '-V[verbose from start]' \
        '-x[xtrace]' \
        '-X[xtrace from start]' \
        '*:script:_files'
}

_csh-bin "$@"
