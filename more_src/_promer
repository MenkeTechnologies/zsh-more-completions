#compdef promer
# Documentation: https://manpages.debian.org/testing/mummer/promer.1.en.html
# MUMmer alignment of two multi-FASTA sequences by amino acid translation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '--mum[use anchor matches unique in both reference and query]' \
  '--mumreference[use anchor matches unique in reference only]' \
  '--mumcand[same as --mumreference]' \
  '--maxmatch[use all anchor matches regardless of uniqueness]' \
  '(-b --breaklen)'{-b,--breaklen}'+[alignment extension distance in amino acids]:dist' \
  '(-c --mincluster)'{-c,--mincluster}'+[minimum cluster length in amino acids]:len' \
  '(-d --diagfactor)'{-d,--diagfactor}'+[clustering diagonal difference factor]:factor' \
  '(-g --maxgap)'{-g,--maxgap}'+[maximum gap between adjacent matches]:gap' \
  '(-l --minmatch)'{-l,--minmatch}'+[minimum single match length in amino acids]:len' \
  '(-m --masklen)'{-m,--masklen}'+[maximum bookend masking length in amino acids]:len' \
  '(-o --coords)'{-o,--coords}'[generate PROmer 1.1 coords output]' \
  '(-p --prefix)'{-p,--prefix}'+[output file prefix]:prefix' \
  '(-x --matrix)'{-x,--matrix}'+[alignment matrix number]:matrix:(1 2 3)' \
  '--delta[create delta file]' \
  '--nodelta[do not create delta file]' \
  '--extend[enable cluster extension step]' \
  '--noextend[disable cluster extension step]' \
  '--optimize[enable alignment score optimization]' \
  '--nooptimize[disable alignment score optimization]' \
  ':reference:_files' \
  ':query:_files' && ret=0

return ret
