#compdef tudu
# _tudu — meskio/tudu (curses-based hierarchical TODO list with XML storage in ~/.tudu.xml; -f loads a different file, --no-color disables color, -v shows version, --config-file picks alt config; positional arg opens a specific XML file)
# upstream: https://github.com/meskio/tudu
# Flags from tudu src/main.cc on tip.

_tudu() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-f+[todo XML file]:file:_files -g "*.xml"' \
        '--config-file+[config file]:file:_files' \
        '--no-color[disable color]' \
        '1:file:_files -g "*.xml"'
}

_tudu "$@"
