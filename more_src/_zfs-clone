#compdef zfs-clone
# _zfs-clone — OpenZFS zfs clone create dataset from snapshot CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-clone() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-p[create parent datasets]' \
        '-o+[property=value]:str:' \
        '*:snapshot dataset:'
}

_zfs-clone "$@"
