#compdef automake-cli
# _automake-cli — GNU automake generate Makefile.in from Makefile.am CLI alias (GNU team, Perl); custom argparse
# upstream: https://www.gnu.org/software/automake/

_automake-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[install missing files]' \
        '--add-missing[install missing files]' \
        '--copy[copy missing files]' \
        '-c[copy missing files]' \
        '--cygnus[cygnus mode]' \
        '-f[force missing]' \
        '--force-missing[force missing]' \
        '--foreign[foreign mode]' \
        '--gnits[gnits mode]' \
        '--gnu[gnu mode]' \
        '--include-deps[include deps]' \
        '-i[ignore automake-prereq]' \
        '--ignore-deps[ignore deps]' \
        '--no-force[no force]' \
        '--libdir=+[dir]:dir:_files -/' \
        '--print-libdir[show install dir]' \
        '-o+[dir]:dir:_files -/' \
        '--output-dir=+[dir]:dir:_files -/' \
        '-W+[warning category]:c:(all none cross syntax obsolete unsupported gnu portability extra-portability error no-error)' \
        '--warnings=+[warning category]:c:(all none cross syntax obsolete unsupported gnu portability extra-portability error no-error)' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '*:Makefile.am files:_files -g "Makefile.am"'
}

_automake-cli "$@"
