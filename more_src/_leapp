#compdef leapp
# Documentation: https://docs.leapp.cloud/latest/cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (Noovolari Leapp CLI).

# Zsh completion for leapp - Noovolari cloud credential management CLI

local curcontext="$curcontext" state line ret=1

local -a leapp_commands=(
  'help:display help'
  'idp-url:SAML 2.0 Identity providers URL management'
  'integration:Leapp Integrations management'
  'profile:Leapp AWS Multi-profile management'
  'region:Leapp regions management'
  'session:Sessions management'
  'set-workspace:Set the current Leapp workspace'
  'team:Login to your Team account'
  'version:Displays the CLI and Core versions'
  'workspace:Show the current workspace'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'leapp command' leapp_commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      session)
        local -a session_commands=(
          'add:add a new session'
          'change-profile:change session named-profile'
          'change-region:change session region'
          'current:display active session info'
          'delete:remove a session'
          'generate:generate STS temporary credentials'
          'get-id:retrieve session ID'
          'list:display sessions'
          'open-web-console:access AWS Web Console'
          'run-aws-credential-plugin:execute a Leapp plugin'
          'start:activate a session'
          'start-ssm-session:start an AWS SSM session'
          'stop:deactivate a session'
        )
        _arguments -s -S \
          '1:session command:->scmd' \
          '*::session args:->sargs' && ret=0
        case "$state" in
          scmd) _describe -t commands 'leapp session command' session_commands && ret=0 ;;
          sargs)
            _arguments -s -S \
              '--sessionId=[session ID]:session id:' \
              '--sessionName=[session alias]:name:' \
              '--profileId=[AWS named profile id]:profile id:' \
              '--region=[AWS region]:region:' \
              '(-x --extended)'{-x,--extended}'[show extra columns]' \
              '(-f --force)'{-f,--force}'[no confirmation]' \
              '--filter=[search filter]:filter:' \
              '--output=[output format]:format:(csv json yaml)' \
              '--noInteractive[disable interactive selection]' && ret=0
            ;;
        esac
        ;;
      integration)
        local -a integration_commands=(
          'create:create a new integration'
          'delete:remove an integration'
          'list:list integrations'
          'login:authenticate to sync sessions'
          'logout:sign out from integration'
          'sync:update sessions with latest data'
        )
        _arguments -s -S \
          '1:integration command:->icmd' \
          '*::integration args:->iargs' && ret=0
        case "$state" in
          icmd) _describe -t commands 'leapp integration command' integration_commands && ret=0 ;;
          iargs)
            _arguments -s -S \
              '--integrationId=[integration id]:id:' \
              '--integrationType=[integration type]:type:(AWS-SSO AZURE)' \
              '--integrationAlias=[integration alias]:alias:' \
              '--integrationPortalUrl=[portal URL]:url:' \
              '--integrationRegion=[AWS region]:region:' \
              '--integrationTenantId=[Azure tenant id]:tenant id:' \
              '--integrationLocation=[Azure location]:location:' && ret=0
            ;;
        esac
        ;;
      profile)
        local -a profile_commands=(
          'create:create a profile'
          'delete:delete a profile'
          'edit:edit a profile'
          'list:list profiles'
        )
        _describe -t commands 'leapp profile command' profile_commands && ret=0
        ;;
      region)
        local -a region_commands=(
          'get-default:show default region'
          'set-default:set default region'
        )
        _describe -t commands 'leapp region command' region_commands && ret=0
        ;;
      idp-url)
        local -a idp_commands=(
          'create:create idp url'
          'delete:delete idp url'
          'edit:edit idp url'
          'list:list idp urls'
        )
        _describe -t commands 'leapp idp-url command' idp_commands && ret=0
        ;;
      team)
        local -a team_commands=(
          'login:log in to team'
          'logout:log out of team'
        )
        _describe -t commands 'leapp team command' team_commands && ret=0
        ;;
      set-workspace)
        _arguments -s -S \
          '1:workspace:' && ret=0
        ;;
      *)
        _arguments -s -S '*: :' && ret=0
        ;;
    esac
    ;;
esac

return ret
