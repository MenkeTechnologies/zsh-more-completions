#compdef leapp

# Zsh completion for leapp - Cloud credential management

local curcontext="$curcontext" state line ret=1

local -a leapp_commands=(
  'start:start a session'
  'stop:stop a session'
  'session:manage sessions'
  'integration:manage integrations'
  'profile:manage profiles'
  'region:set default region'
  'idp-url:set identity provider URL'
  'workspace:show current workspace'
  'set-workspace:set workspace'
  'help:show help'
  'version:show version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'leapp command' leapp_commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      session)
        local -a session_commands=(
          'list:list sessions'
          'start:start a session'
          'stop:stop a session'
          'delete:delete a session'
          'change-profile:change session profile'
        )
        _arguments -s -S \
          '1:session command:_describe -t commands command session_commands' \
          '*::session args:->session_args' && ret=0
        case "$state" in
          session_args)
            case "${line[1]}" in
              start|stop|delete|change-profile)
                _arguments -s -S \
                  '--sessionId=[session ID]:session id: ' && ret=0
                ;;
              list)
                _arguments -s -S && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      integration)
        local -a integration_commands=(
          'create:create an integration'
          'edit:edit an integration'
          'list:list integrations'
          'delete:delete an integration'
        )
        _arguments -s -S \
          '1:integration command:_describe -t commands command integration_commands' \
          '*::integration args:->integration_args' && ret=0
        case "$state" in
          integration_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  '--integrationAlias=[integration alias]:alias: ' \
                  '--integrationType=[integration type]:type: ' \
                  '--portalUrl=[portal URL]:url: ' \
                  '--tenantId=[tenant ID]:tenant id: ' && ret=0
                ;;
              edit|delete)
                _arguments -s -S \
                  '--integrationId=[integration ID]:id: ' && ret=0
                ;;
              list)
                _arguments -s -S && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      profile)
        local -a profile_commands=(
          'list:list profiles'
          'create:create a profile'
          'edit:edit a profile'
          'delete:delete a profile'
        )
        _arguments -s -S \
          '1:profile command:_describe -t commands command profile_commands' \
          '*::profile args: ' && ret=0
        ;;
      region)
        _arguments -s -S \
          '1:region: ' && ret=0
        ;;
      idp-url)
        _arguments -s -S \
          '1:URL: ' && ret=0
        ;;
      set-workspace)
        _arguments -s -S \
          '1:workspace: ' && ret=0
        ;;
      *)
        _arguments -s -S '*:args: ' && ret=0
        ;;
    esac
    ;;
esac

return ret
