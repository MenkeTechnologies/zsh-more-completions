#compdef augenrules
# _augenrules — Linux audit augenrules (concatenate /etc/audit/rules.d/*.rules into /etc/audit/audit.rules so auditctl -R can load the combined ruleset; --check verify each rule with auditctl test syntax, --load reload via auditctl, --version, --help)
# upstream: https://github.com/linux-audit/audit-userspace
# Flags from linux-audit/audit-userspace src/augenrules on tip.

_augenrules() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--check[verify each rule]' \
        '--load[reload via auditctl]'
}

_augenrules "$@"
