#compdef nomad

# Zsh completion for HashiCorp Nomad

local curcontext="$curcontext" state line ret=1

local -a nomad_commands
nomad_commands=(
  'acl:interact with ACL policies and tokens'
  'agent:runs a Nomad agent'
  'agent-info:display status information about the local agent'
  'alloc:interact with allocations'
  'deployment:interact with deployments'
  'eval:interact with evaluations'
  'exec:execute commands in task'
  'fmt:rewrites Nomad config and job files to canonical format'
  'job:interact with jobs'
  'license:interact with the license'
  'login:login to Nomad using an auth method'
  'monitor:stream logs from a Nomad agent'
  'namespace:interact with namespaces'
  'node:interact with nodes'
  'operator:provides cluster-level tools'
  'plugin:inspect plugins'
  'quota:interact with quotas'
  'recommendation:interact with the Autopilot recommendations'
  'scaling:interact with the scaling API'
  'sentinel:interact with Sentinel policies'
  'server:interact with servers'
  'service:interact with registered services'
  'setup:interact with setup helpers'
  'status:display the status output for a resource'
  'system:interact with the system API'
  'tls:generate self-signed TLS certificates'
  'ui:open the Nomad Web UI'
  'var:interact with variables'
  'version:prints the Nomad version'
  'volume:interact with volumes'
)

local -a nomad_global_flags
nomad_global_flags=(
  '-address=[address of the Nomad server]:address:_urls'
  '-region=[the region of the Nomad server]:region:'
  '-namespace=[the target namespace]:namespace:'
  '-no-color[disables colored command output]'
  '-ca-cert=[path to a CA cert file]:ca cert:_files'
  '-ca-path=[path to a CA directory]:ca path:_directories'
  '-client-cert=[path to a client cert file]:client cert:_files'
  '-client-key=[path to a client key file]:client key:_files'
  '-tls-server-name=[the server name to use for SNI]:server name:'
  '-tls-skip-verify[do not verify TLS certificate]'
  '-token=[the SecretID of an ACL token]:token:'
)

_arguments -s -S \
  '-help[show help]' \
  '-h[show help]' \
  '-version[show version]' \
  '-v[show version]' \
  '-autocomplete-install[install shell autocompletion]' \
  '-autocomplete-uninstall[uninstall shell autocompletion]' \
  '1:command:_describe -t commands command nomad_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      agent)
        _arguments -s -S \
          '-bind=[address to bind]:address:' \
          '-config=[path to a config file or directory]:config:_files' \
          '-data-dir=[data directory]:directory:_directories' \
          '-dc=[datacenter]:datacenter:' \
          '-dev[start agent in development mode]' \
          '-dev-connect[start in dev mode with Consul Connect]' \
          '-dev-node-class=[node class for dev mode]:class:' \
          '-encrypt=[gossip encryption key]:key:' \
          '-join=[address to join]:address:' \
          '-log-file=[path to the log file]:log file:_files' \
          '-log-json[output logs in JSON format]' \
          '-log-level=[log level]:level:(trace debug info warn error)' \
          '-meta=[metadata key=value pair]:key=value:' \
          '-network-interface=[network interface to bind to]:interface:' \
          '-network-speed=[network speed override]:speed:' \
          '-node=[node name]:name:' \
          '-node-class=[node class]:class:' \
          '-node-pool=[node pool]:pool:' \
          '-plugin-dir=[path to plugin directory]:directory:_directories' \
          '-rejoin[attempt to rejoin after leaving]' \
          '-retry-interval=[time between join attempts]:interval:' \
          '-retry-join=[address to join with retries]:address:' \
          '-retry-max=[max join attempts]:number:' \
          '-server[run agent as a server]' \
          '-bootstrap-expect=[expected number of servers]:number:' \
          '-consul-address=[address of a Consul agent]:address:' \
          '-consul-auth=[HTTP basic auth for Consul]:user\:pass:' \
          '-consul-token=[Consul token]:token:' \
          '-vault-address=[address of a Vault server]:address:_urls' \
          '-vault-enabled[enable Vault integration]' \
          '-vault-token=[Vault token]:token:' && ret=0
        ;;
      job)
        local -a job_commands
        job_commands=(
          'deployments:list deployments for a job'
          'dispatch:dispatch an instance of a parameterized job'
          'eval:force an evaluation for a job'
          'history:display all tracked versions of a job'
          'init:create an example job file'
          'inspect:inspect the contents of a submitted job'
          'periodic:interact with periodic jobs'
          'plan:dry-run a job update'
          'promote:promote a canary deployment'
          'revert:revert to a prior version of the job'
          'run:run a new job or update an existing job'
          'scale:change the count of a task group'
          'scaling-events:display the recent scaling events'
          'status:display status information about a job'
          'stop:stop a running job'
          'tag:manage job version tags'
          'validate:checks a job specification is valid'
        )
        _arguments -s -S \
          $nomad_global_flags \
          '1:job command:_describe -t commands command job_commands' \
          '*::job args:->job_args' && ret=0
        case "$state" in
          job_args)
            case "${line[1]}" in
              run)
                _arguments -s -S \
                  $nomad_global_flags \
                  '-check-index=[check the job modify index]:index:' \
                  '-detach[return immediately instead of monitoring]' \
                  '-eval-priority=[set eval priority]:priority:' \
                  '-hcl1[force HCLv1 parser]' \
                  '-hcl2-strict[enable strict HCL2 parsing]' \
                  '-json[enable JSON input]' \
                  '-output[output the JSON that would be submitted]' \
                  '-policy-override[override soft mandatory Sentinel policies]' \
                  '-preserve-counts[preserve task group counts]' \
                  '-consul-token=[Consul token]:token:' \
                  '-vault-token=[Vault token]:token:' \
                  '-var=[HCL2 variable]:variable=value:' \
                  '-var-file=[path to HCL2 variables file]:var file:_files' \
                  '-verbose[show full information]' \
                  '1:job file:_files -g "*.{nomad,hcl,json}"' && ret=0
                ;;
              plan)
                _arguments -s -S \
                  $nomad_global_flags \
                  '-diff[show diff with current deployment]' \
                  '-hcl1[force HCLv1 parser]' \
                  '-hcl2-strict[enable strict HCL2 parsing]' \
                  '-json[enable JSON input]' \
                  '-policy-override[override Sentinel policies]' \
                  '-var=[HCL2 variable]:variable=value:' \
                  '-var-file=[path to HCL2 variables file]:var file:_files' \
                  '-verbose[show full information]' \
                  '1:job file:_files -g "*.{nomad,hcl,json}"' && ret=0
                ;;
              stop)
                _arguments -s -S \
                  $nomad_global_flags \
                  '-detach[return immediately]' \
                  '-eval-priority=[set eval priority]:priority:' \
                  '-global[stop multi-region job in all regions]' \
                  '-no-shutdown-delay[ignore the group/task shutdown_delay]' \
                  '-purge[purge job from system after stopping]' \
                  '-verbose[show full information]' \
                  '-yes[automatic yes to prompts]' \
                  '1:job id:' && ret=0
                ;;
              status)
                _arguments -s -S \
                  $nomad_global_flags \
                  '-all-allocs[display all allocations]' \
                  '-evals[display evaluations]' \
                  '-json[output in JSON format]' \
                  '-short[display short output]' \
                  '-t=[go template format string]:template:' \
                  '-verbose[show full information]' \
                  '1:job id:' && ret=0
                ;;
              validate)
                _arguments -s -S \
                  $nomad_global_flags \
                  '-hcl1[force HCLv1 parser]' \
                  '-hcl2-strict[enable strict HCL2 parsing]' \
                  '-json[enable JSON input]' \
                  '-var=[HCL2 variable]:variable=value:' \
                  '-var-file=[path to HCL2 variables file]:var file:_files' \
                  '1:job file:_files -g "*.{nomad,hcl,json}"' && ret=0
                ;;
              init)
                _arguments -s -S \
                  '-connect[create a job with Consul Connect]' \
                  '-short[emit a minimal job]' \
                  '-template=[use a predefined template]:template:' && ret=0
                ;;
              dispatch)
                _arguments -s -S \
                  $nomad_global_flags \
                  '-detach[return immediately]' \
                  '-idempotency-token=[idempotency token]:token:' \
                  '-meta=[metadata key=value]:key=value:' \
                  '-verbose[show full information]' \
                  '1:job id:' \
                  '2:payload file:_files' && ret=0
                ;;
              *)
                _arguments -s -S \
                  $nomad_global_flags \
                  '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      alloc)
        local -a alloc_commands
        alloc_commands=(
          'checks:display health check status for an allocation'
          'exec:execute commands in a running task'
          'fs:inspect the filesystem of an allocation'
          'logs:streams the logs of a task'
          'restart:restart a running allocation or task'
          'signal:signal a running allocation'
          'status:display allocation status information'
          'stop:stop and reschedule a running allocation'
        )
        _arguments -s -S \
          $nomad_global_flags \
          '1:alloc command:_describe -t commands command alloc_commands' \
          '*:args:' && ret=0
        ;;
      node)
        local -a node_commands
        node_commands=(
          'config:view or modify client configuration details'
          'drain:toggle drain mode on a given node'
          'eligibility:toggle scheduling eligibility'
          'meta:interact with node metadata'
          'pool:interact with node pools'
          'status:display status information about nodes'
        )
        _arguments -s -S \
          $nomad_global_flags \
          '1:node command:_describe -t commands command node_commands' \
          '*:args:' && ret=0
        ;;
      deployment)
        local -a deployment_commands
        deployment_commands=(
          'fail:manually fail a deployment'
          'list:list all deployments'
          'pause:pause a deployment'
          'promote:promote canaries in a deployment'
          'resume:resume a paused deployment'
          'status:display the status of a deployment'
          'unblock:unblock a blocked deployment'
        )
        _arguments -s -S \
          $nomad_global_flags \
          '1:deployment command:_describe -t commands command deployment_commands' \
          '*:args:' && ret=0
        ;;
      server)
        local -a server_commands
        server_commands=(
          'force-leave:force a server into the left state'
          'join:join Nomad servers'
          'members:display a list of server members'
        )
        _arguments -s -S \
          $nomad_global_flags \
          '1:server command:_describe -t commands command server_commands' \
          '*:args:' && ret=0
        ;;
      operator)
        local -a operator_commands
        operator_commands=(
          'api:interact with the HTTP API'
          'autopilot:provides tools for Autopilot'
          'debug:build a debug archive'
          'gossip:provides tools for gossip'
          'keygen:generate an encryption key'
          'keyring:manage the keyring'
          'metrics:view Nomad metrics'
          'raft:provides tools for Raft'
          'root:interact with root key material'
          'scheduler:view or modify scheduler configuration'
          'snapshot:saves, restores and inspects snapshots'
        )
        _arguments -s -S \
          $nomad_global_flags \
          '1:operator command:_describe -t commands command operator_commands' \
          '*:args:' && ret=0
        ;;
      volume)
        local -a volume_commands
        volume_commands=(
          'create:create an external volume'
          'delete:delete an external volume'
          'deregister:deregister an external volume'
          'detach:detach an external volume'
          'init:create an example volume specification file'
          'register:register an external volume'
          'snapshot:interact with volume snapshots'
          'status:display status information for a volume'
        )
        _arguments -s -S \
          $nomad_global_flags \
          '1:volume command:_describe -t commands command volume_commands' \
          '*:args:' && ret=0
        ;;
      var)
        local -a var_commands
        var_commands=(
          'get:read a variable'
          'init:create an example variable spec'
          'list:list variables'
          'lock:execute a command with a lock on a variable'
          'purge:permanently delete a soft-deleted variable'
          'put:create or update a variable'
        )
        _arguments -s -S \
          $nomad_global_flags \
          '1:var command:_describe -t commands command var_commands' \
          '*:args:' && ret=0
        ;;
      exec)
        _arguments -s -S \
          $nomad_global_flags \
          '-task=[task name to exec into]:task:' \
          '-job=[job ID]:job:' \
          '-i[pass stdin to the container]' \
          '-t[allocate a pseudo-TTY]' \
          '-e[escape character]:character:' \
          '1:allocation id:' \
          '*:command:_cmdstring' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '-check[check if input is formatted]' \
          '-list[list files whose formatting differs]' \
          '-recursive[process files in subdirectories]' \
          '-write[write result to source file]' \
          '*:file:_files -g "*.{nomad,hcl}"' && ret=0
        ;;
      status)
        _arguments -s -S \
          $nomad_global_flags \
          '-json[output in JSON format]' \
          '-t=[go template format string]:template:' \
          '-verbose[show full information]' \
          '1:id:' && ret=0
        ;;
      monitor)
        _arguments -s -S \
          $nomad_global_flags \
          '-log-level=[log level]:level:(trace debug info warn error)' \
          '-log-json[output logs in JSON format]' \
          '-node-id=[filter logs by node ID]:node id:' \
          '-server-id=[filter logs by server]:server id:' && ret=0
        ;;
      ui)
        _arguments -s -S \
          $nomad_global_flags \
          '-authenticate[include ACL token in URL]' \
          '-show-url[only output URL instead of opening]' \
          '1:identifier:' && ret=0
        ;;
      system)
        local -a system_commands
        system_commands=(
          'gc:run the system garbage collection'
          'reconcile-summaries:reconcile job summaries'
        )
        _arguments -s -S \
          $nomad_global_flags \
          '1:system command:_describe -t commands command system_commands' && ret=0
        ;;
      *)
        _arguments -s -S \
          $nomad_global_flags \
          '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
