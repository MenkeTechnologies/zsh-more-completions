#compdef fqgrep
# Documentation: https://github.com/indraniel/fqgrep
# fqgrep: grep for FASTA/Q files with approximate (mismatch) matching

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-V[show program and version information]' \
  '-p+[pattern to search for (required)]:pattern' \
  '-v[invert match; show sequences NOT matching]' \
  '-a[output all records regardless of match status]' \
  '-c[highlight matching strings with color]' \
  '-f[return results in FASTA format]' \
  '-r[output detailed statistics report format]' \
  '-b+[column delimiter for stats report (default tab)]:delimiter' \
  '-m+[maximum total mismatches allowed (default 0)]:mismatches' \
  '-s+[maximum substitution mismatches permitted]:substitutions' \
  '-i+[maximum insertion mismatches permitted]:insertions' \
  '-d+[maximum deletion mismatches permitted]:deletions' \
  '-S+[substitution cost (default 1)]:cost' \
  '-I+[insertion cost (default 1)]:cost' \
  '-D+[deletion cost (default 1)]:cost' \
  '-e[force TRE regexp engine usage]' \
  '-C[display only match count per file]' \
  '-o+[output file (default stdout)]:output file:_files' \
  '*:FASTA/Q file:_files' && ret=0

return ret
