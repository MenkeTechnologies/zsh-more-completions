#compdef u2f-host
# _u2f-host — perform U2F host-side operations on the command line (Yubico/libu2f-host)
# upstream: https://github.com/Yubico/libu2f-host
# Flags from src/cmdline.ggo (gengetopt).

_u2f-host() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-o --origin)'{-o+,--origin=}'[origin URL to use]:url:_urls' \
        '(-a --action)'{-a+,--action=}'[action to take]:action:(register authenticate sendrecv)' \
        '(-t --touch)'{-t,--touch}'[invert user-presence flag (on by default)]' \
        '(-d --debug)'{-d,--debug}'[print debug information to standard error]' \
        '(-c --command)'{-c+,--command=}'[command byte for sendrecv action]:command:'
}

_u2f-host "$@"
