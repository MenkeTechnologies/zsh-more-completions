#compdef phenix.maps
# Documentation: https://phenix-online.org/documentation/reference/maps.html
# Phenix: compute crystallographic maps and map coefficients from model and data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'map_type=[map type, e.g. 2mFo-DFc, mFo-DFc, anom]:type:' \
  'skip_twin_detection=[disable automatic twinning detection]:bool:(True False)' \
  '*:params/model/data file:_files -g "*.(params|eff|pdb|cif|mtz|hkl)"' && ret=0

return ret
