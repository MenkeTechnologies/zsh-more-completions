#compdef errcheck

# Zsh completion for errcheck - Go error check utility

local -a arguments

arguments=(
  '-abspath[print absolute paths to files]'
  '-asserts[report checked type assertions]'
  '-blank[report blank identifiers]'
  '-exclude[file listing functions to exclude]:file:_files'
  '-ignore[regex of function names to ignore]:pattern:'
  '-ignorepkg[comma-separated package prefixes to ignore]:packages:'
  '-ignoretests[do not check test files]'
  '-ignoregenerated[do not check generated files]'
  '-mod[module download mode]:mode:(mod readonly vendor)'
  '-tags[build tags]:tags:'
  '-tagfile[file listing build tags]:file:_files'
  '-verbose[produce verbose log]'
  '*:go package:'
)

_arguments -s $arguments
