#compdef errcheck
# Documentation: https://github.com/kisielk/errcheck
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# errcheck: checks unchecked errors in Go programs

local -a arguments

arguments=(
  '-abspath[print absolute paths to files with unchecked errors]'
  '-asserts[enable checking ignored type assertion results]'
  '-blank[enable checking assignments of errors to blank identifier]'
  '-exclude[file containing list of functions to exclude]:file:_files'
  '-excludeonly[disable built-in exclude list of stdlib functions]'
  '-ignore[comma-separated list of package:regex pairs]:pattern:'
  '-ignorepkg[comma-separated list of package import paths to ignore]:packages:'
  '-ignoretests[disable checking of _test.go files]'
  '-ignoregenerated[disable checking of generated source code]'
  '-mod[module download mode]:mode:(readonly vendor)'
  '-tags[space-separated build tags]:tags:'
  '-verbose[show resulting list of added excludes]'
  '*:go package:'
)

_arguments -s $arguments
