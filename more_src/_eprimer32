#compdef eprimer32
# Documentation: https://man.archlinux.org/search?q=eprimer32
# Reference accessed: 2026-05-16

# EMBOSS eprimer32: PCR primer design via primer3 v2 (extended interface)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input DNA sequence(s)]:DNA USA:_files' \
  '-task=[primer3 v2 task]:task:(generic check_primers pick_primer_list pick_sequencing_primers pick_cloning_primers pick_discriminative_primers)' \
  '-numreturn=[number of primer pairs to return]:n:' \
  '-osize=[optimum primer size]:size:' \
  '-minsize=[minimum primer size]:size:' \
  '-maxsize=[maximum primer size]:size:' \
  '-otm=[optimum Tm]:temp:' \
  '-mintm=[minimum Tm]:temp:' \
  '-maxtm=[maximum Tm]:temp:' \
  '-ogcpercent=[optimum %GC]:pct:' \
  '-mingc=[minimum %GC]:pct:' \
  '-maxgc=[maximum %GC]:pct:' \
  '-saltconc=[Na+ concentration (mM)]:mM:' \
  '-dnaconc=[primer DNA concentration (nM)]:nM:' \
  '-thermodynamicparameterspath=[primer3_config dir]:dir:_files -/' \
  '-includedregion=[region to include]:range:' \
  '-targetregion=[target region]:range:' \
  '-excludedregion=[region(s) to exclude]:range:' \
  '-productosize=[optimum product size]:size:' \
  '-productsizerange=[product size range]:range:' \
  '-explainflag[primer3 explanation flag]' \
  '-outfile=[output report file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
