#compdef samza-cli samza-run samza-job-runner
# _samza-cli — Apache Samza samza-cli CLI command-line frontend wrapping the Apache Samza distributed stream-processing framework providing run-app run-job kill-job describe-app status-app config-validator job-runner standalone YARN deployment Kafka-stream integration RocksDB state store local-Beam-checkpointing checkpoint-changelog (ASF Samza team, Java/Scala); custom argparse
# upstream: https://samza.apache.org/

_samza-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config-factory=+[class]:str:' \
        '--config-path=+[uri]:str:' \
        '--config=+[k=v]:str:' \
        '-c+[config]:str:' \
        '--job-name=+[name]:str:' \
        '--job-id=+[id]:str:' \
        '--operation=+[op]:o:(run kill status describe)' \
        '-o+[op]:o:(run kill status describe)' \
        '--container-id=+[id]:str:' \
        '--container-name=+[name]:str:' \
        '--executable=+[class]:str:' \
        '--log4j-config=+[file]:file:_files -g "log4j.xml *.properties"' \
        '--log-dir=+[dir]:dir:_files -/' \
        '--enable-jmx[enable JMX]' \
        '--jmx-port=+[port]:n:' \
        '--standalone[standalone mode]' \
        '--yarn[YARN mode]' \
        '*:job:_files -g "*.jar *.tar.gz"'
}

_samza-cli "$@"
