#compdef vg
# _vg — Erik Garrison vg CLI Variation Graph toolkit constructing manipulating mapping reads through pangenome graphs supporting GFA xg gbz gbwt vg-indexed formats with giraffe map mpmap surject augment call genotype deconstruct chunk explode pack pileup snarls dump prune index pipelines (Erik Garrison team, C++); cli11
# upstream: https://github.com/vgteam/vg

_vg() {
    local -a sub=(
        'autoindex:build all indexes for mapping'
        'construct:construct graph from VCF and FASTA'
        'view:convert between graph formats'
        'stats:graph statistics'
        'paths:extract or print paths'
        'index:create index for mapping'
        'gbwt:GBWT haplotype index operations'
        'minimizer:build minimizer index'
        'gbz:build or query a GBZ graph'
        'snarls:identify snarls'
        'simulate:simulate reads from a graph'
        'map:align reads with vg map'
        'mpmap:multipath mapping'
        'giraffe:fast graph-based read mapping'
        'augment:augment a graph with read alignments'
        'call:call variants from a packed graph'
        'genotype:legacy genotype command'
        'pack:compute read coverage'
        'mod:graph modification'
        'chunk:chunk a graph'
        'sim:simulate reads'
        'rna:RNA mode'
        'find:find a subgraph or alignment'
        'deconstruct:convert a GFA to VCF'
        'surject:project graph alignment to linear'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vg subcommand' sub ;;
        args)
            case $words[1] in
                view) _arguments \
                    '-g[gfa input]' \
                    '-j[json input]' \
                    '-J[json output]' \
                    '-d[dot output]' \
                    '-F[input is fastq]' \
                    '-a[aln input]' \
                    '-G[gam input]' \
                    '*:file:_files' ;;
                map|giraffe) _arguments \
                    '-x+[xg]:file:_files -g "*.xg"' \
                    '-g+[gcsa]:file:_files -g "*.gcsa"' \
                    '-Z+[gbz]:file:_files -g "*.gbz"' \
                    '-f+[fastq]:file:_files -g "*.fq *.fastq *.gz"' \
                    '*::' ;;
            esac
            ;;
    esac
}

_vg "$@"
