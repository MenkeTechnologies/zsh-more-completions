#compdef kyverno-background-controller background-controller
# _kyverno-background-controller — Kyverno background policy controller (kyverno/kyverno)
# upstream: https://github.com/kyverno/kyverno
# Flags from cmd/background-controller/main.go + cmd/internal/flag.go on tip.

_kyverno-background-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--genWorkers=[background controller workers]:n:' \
        '--maxQueuedEvents=[max queued events]:n:' \
        '--omitEvents=[comma-sep event types to suppress]:list:' \
        '--apiCallTimeout=[policy HTTP API call timeout]:dur:' \
        '--maxBackgroundReports=[max ephemeral reports]:n:' \
        '--controllerRuntimeMetricsAddress=[controller-runtime metrics bind addr (0 disables)]:host\:port:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--clientRateLimitQPS=[Kubernetes client QPS]:f:' \
        '--clientRateLimitBurst=[Kubernetes client burst]:n:' \
        '--eventsRateLimitQPS=[event client QPS]:f:' \
        '--eventsRateLimitBurst=[event client burst]:n:' \
        '--resyncPeriod=[informer resync period]:dur:' \
        '--crdWatcher=[watch CRDs to invalidate discovery cache]:bool:(true false)' \
        '--exceptionNamespace=[PolicyException namespace (*=all)]:ns:' \
        '--enablePolicyException=[enable PolicyException]:bool:(true false)' \
        '--enableConfigMapCaching=[cache configmaps]:bool:(true false)' \
        '--profile[enable pprof]' \
        '--profilePort=[pprof port]:port:' \
        '--profileAddress=[pprof bind address]:host\:port:' \
        '--metricsHost=[Prometheus metrics bind host]:host:' \
        '--metricsPort=[Prometheus metrics bind port]:port:' \
        '--disableMetrics=[disable metrics endpoint]:bool:(true false)' \
        '--enableTracing[enable OTLP tracing]' \
        '--tracingAddress=[tracing receiver host]:host:' \
        '--tracingPort=[tracing receiver port]:port:' \
        '--loggingFormat=[log format]:fmt:(text json)' \
        '-v[klog verbosity level]:n:'
}

_kyverno-background-controller "$@"
