#compdef crystal-shards
# _crystal-shards — Crystal shards dependency manager CLI alias (Crystal Lang team, Crystal); custom argparse
# upstream: https://github.com/crystal-lang/shards

_crystal-shards() {
    local -a sub=(
        'build:install dependencies and build'
        'check:check dependencies'
        'init:scaffold shard.yml'
        'install:install dependencies'
        'list:list installed deps'
        'lock:create lockfile'
        'outdated:show outdated deps'
        'prune:remove unused deps'
        'update:update deps'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--no-color[no color]' \
        '--no-update[no update]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--local[local]' \
        '--frozen[frozen lockfile]' \
        '--without-development[without dev deps]' \
        '--ignore-crystal-version[ignore crystal version]' \
        '--skip-postinstall[skip postinstall]' \
        '--skip-executables[skip executables]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'shards subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '--release[release build]' \
                    '--static[static build]' \
                    '--debug[debug build]' \
                    '--no-debug[no debug]' \
                    '--threads=+[threads]:n:' \
                    '--time[print time stats]' \
                    '*:target:' ;;
                update) _arguments '*:dep:' ;;
            esac
            ;;
    esac
}

_crystal-shards "$@"
