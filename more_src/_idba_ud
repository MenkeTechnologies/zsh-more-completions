#compdef idba_ud
# Documentation: https://github.com/loneknightpy/idba
# iterative de Bruijn graph assembler for uneven sequencing depth

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --out)'{-o,--out}'+[output directory]:dir:_files -/' \
  '(-r --read)'{-r,--read}'+[fasta read file]:file:_files' \
  '--read_level_2=[paired-end reads fasta for second level scaffolds]:file:_files' \
  '--read_level_3=[paired-end reads fasta for third level scaffolds]:file:_files' \
  '--read_level_4=[paired-end reads fasta for fourth level scaffolds]:file:_files' \
  '--read_level_5=[paired-end reads fasta for fifth level scaffolds]:file:_files' \
  '(-l --long_read)'{-l,--long_read}'+[fasta long read file]:file:_files' \
  '--mink=[minimum k value]:k' \
  '--maxk=[maximum k value]:k' \
  '--step=[increment of k-mer of each iteration]:step' \
  '--inner_mink=[inner minimum k value]:k' \
  '--inner_step=[inner increment of k-mer]:step' \
  '--prefix=[prefix length used to build sub k-mer table]:len' \
  '--min_count=[minimum multiplicity for filtering k-mer]:count' \
  '--min_support=[minimum support in each iteration]:support' \
  '--num_threads=[number of threads]:threads' \
  '--seed_kmer=[seed kmer size for alignment]:size' \
  '--min_contig=[minimum size of contig]:size' \
  '--similar=[similarity for alignment]:similar' \
  '--max_mismatch=[max mismatch of error correction]:mismatch' \
  '--min_pairs=[minimum number of pairs]:pairs' \
  '--no_bubble[do not merge bubble]' \
  '--no_local[do not use local assembly]' \
  '--no_coverage[do not iterate on coverage]' \
  '--no_correct[do not do correction]' \
  '--pre_correction[perform pre-correction before assembly]' && ret=0

return ret
