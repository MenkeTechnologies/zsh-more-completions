#compdef capi-operator-controller-manager
# _capi-operator-controller-manager — Cluster API Operator (kubernetes-sigs/cluster-api-operator)
# upstream: https://github.com/kubernetes-sigs/cluster-api-operator
# Flags from cmd/main.go InitFlags() on tip.

_capi-operator-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--watch-filter=[watch-filter label value]:value:' \
        '--watch-configsecret=[reconcile on referenced Secret changes]:bool:(true false)' \
        '--watch-configmap=[reconcile on referenced ConfigMap changes]:bool:(true false)' \
        '--namespace=[restrict watch to a namespace]:ns:' \
        '--profiler-address=[pprof bind host\:port]:host\:port:' \
        '--contention-profiling[enable contention profiling]' \
        '--concurrency=[concurrent reconciles per provider]:n:' \
        '--manager-concurrency=[concurrent manager-level reconciles]:n:' \
        '--sync-period=[informer resync period]:dur:' \
        '--webhook-port=[webhook server bind port]:port:' \
        '--webhook-cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--health-addr=[health probe bind host\:port]:host\:port:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_capi-operator-controller-manager "$@"
