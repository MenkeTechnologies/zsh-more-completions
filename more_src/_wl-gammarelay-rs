#compdef wl-gammarelay-rs
# Documentation: https://man.archlinux.org/search?q=wl-gammarelay-rs
# Reference accessed: 2026-05-16

# Zsh completion for wl-gammarelay-rs (Wayland gamma/brightness control daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' && ret=0

return ret
