#compdef wl-gammarelay-rs
# Documentation: https://github.com/MaxVerevkin/wl-gammarelay-rs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for wl-gammarelay-rs (Wayland gamma/brightness control daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' && ret=0

return ret
