#compdef presto-cli2 presto-cli3
# _presto-cli2 — Presto Foundation Meta presto-cli CLI command-line frontend wrapping the PrestoDB distributed SQL query engine (predecessor of Trino) providing interactive shell-mode batch-mode supporting catalog schema session execute SQL output-format CSV JSON ALIGNED VERTICAL NULL TABLE auto kerberos client info source client-tags trace-token (Presto Foundation team, Java); custom argparse
# upstream: https://prestodb.io/

_presto-cli2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server=+[host:port]:str:' \
        '--catalog=+[name]:str:' \
        '--schema=+[name]:str:' \
        '--user=+[user]:str:' \
        '--password[prompt for password]' \
        '--krb5-config-path=+[file]:file:_files' \
        '--krb5-credential-cache-path=+[file]:file:_files' \
        '--krb5-keytab-path=+[file]:file:_files' \
        '--krb5-principal=+[principal]:str:' \
        '--krb5-remote-service-name=+[name]:str:' \
        '--krb5-disable-remote-service-hostname-canonicalization[disable canonicalization]' \
        '--source=+[name]:str:' \
        '--client-info=+[info]:str:' \
        '--client-tags=+[tags]:str:' \
        '--client-request-timeout=+[duration]:str:' \
        '--trace-token=+[token]:str:' \
        '--debug[debug]' \
        '--insecure[insecure]' \
        '--keystore-path=+[file]:file:_files' \
        '--keystore-password=+[password]:str:' \
        '--truststore-path=+[file]:file:_files' \
        '--truststore-password=+[password]:str:' \
        '--access-token=+[token]:str:' \
        '--http-proxy=+[host:port]:str:' \
        '--socks-proxy=+[host:port]:str:' \
        '--output-format=+[fmt]:f:(CSV CSV_HEADER CSV_UNQUOTED CSV_HEADER_UNQUOTED TSV TSV_HEADER JSON ALIGNED VERTICAL TABLE AUTO NULL)' \
        '--no-progress[disable progress]' \
        '--pager=+[program]:_command_names' \
        '--history-file=+[file]:file:_files' \
        '--editor=+[editor]:_command_names' \
        '--execute=+[SQL]:str:' \
        '-e+[SQL]:str:' \
        '-f+[SQL file]:file:_files -g "*.sql"' \
        '--file=+[file]:file:_files -g "*.sql"' \
        '--session=+[k=v]:str:' \
        '--client-options=+[opts]:str:' \
        '--resource-estimate=+[k=v]:str:' \
        '*:presto URL:'
}

_presto-cli2 "$@"
