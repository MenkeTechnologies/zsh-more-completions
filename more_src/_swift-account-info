#compdef swift-account-info
# Documentation: https://manpages.debian.org/testing/swift-account/swift-account-info.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# swift-account-info: inspect an account DB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-d[swift_dir]:dir:_files -/' \
  '--swift-dir=[swift_dir]:dir:_files -/' \
  '-p[policy_name]:name:' \
  '--policy-name=[policy name]:name:' \
  '--sync[show sync info]' \
  '*:db or file:_files' && ret=0
return ret
