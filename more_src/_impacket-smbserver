#compdef impacket-smbserver

# Impacket smbserver.py: simple SMB share server (auth optional)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug output]' \
  '-comment[share comment]:text:' \
  '-username[username]:user:' \
  '-password[password]:pwd:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-ip[server IP to bind]:ip:' \
  '-port[server TCP port]:port:' \
  '-smb2support[advertise SMB2 support]' \
  '-outputfile[log file]:file:_files' \
  '*:share_name share_path:_files -/' && ret=0
return ret
