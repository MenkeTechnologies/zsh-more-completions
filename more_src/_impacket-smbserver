#compdef impacket-smbserver
# Documentation: https://github.com/fortra/impacket/blob/master/examples/smbserver.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-smbserver: simple SMB server exposing a single share for testing/relay
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[enable DEBUG output]' \
  '-ts[add timestamp to logging]' \
  '-comment[share comment]:comment:' \
  '-username[required username]:user:' \
  '-password[required password]:pass:' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-computeraccountname[machine account name]:name:' \
  '-computeraccounthash[machine account hash]:hash:' \
  '-computeraccountaes[machine account AES key]:hex:' \
  '-computeraccountpassword[machine account password]:pass:' \
  '-computeraccountdomain[machine account domain]:domain:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-port[listen port (default 445)]:port:' \
  '(-ip --interface-address)'{-ip,--interface-address}'[bind interface IP]:ip:' \
  '(-6 --ipv6)'{-6,--ipv6}'[listen on IPv6]' \
  '-smb2support[enable SMB2 negotiation]' \
  '-readonly[mark share read-only]' \
  '-dropssp[reject SSP authentication]' \
  '-disablekerberos[disable Kerberos]' \
  '-disablentlm[disable NTLM]' \
  '-outputfile[output log file]:file:_files' \
  '1:share name:' \
  '2:share path:_files -/' && ret=0
return ret
