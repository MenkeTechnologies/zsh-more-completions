#compdef impacket-smbserver

# impacket-smbserver: simple read-only SMB server
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "-debug[verbose debug output]" \
  "-ts[print timestamps in log]" \
  "-ts-utc[print timestamps in UTC]" \
  "-target-ip[target IP]:ip:" \
  "-dc-ip[domain controller IP]:ip:" \
  "-codec[codec for non-utf-8 strings]:codec:" \
  "-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:" \
  "-no-pass[do not ask for password]" \
  "-k[use Kerberos]" \
  "-aesKey[AES key in hex]:hex:" \
  "-cert-pem[pem certificate file]:file:_files" \
  "-cert-pfx[pkcs12 cert file]:file:_files" \
  "-pfx-pass[pkcs12 cert password]:pass:" \
  1:share_name: 2:share_path:_files -/ -comment[share comment]:comment: -smb2support[enable SMB2 negotiation] -ip[bind to IP]:ip: -port[port]:port: -password[require password]:pass: -username[require user]:user: -outputfile[output log]:file:_files \
  '*::impacket-smbserver args:_files' && ret=0
return ret
