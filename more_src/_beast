#compdef beast beast2 beauti beauti2 treeannotator treeannotator2 logcombiner logcombiner2 densitree densitree2 applauncher applauncher2 packagemanager packagemanager2
# Documentation: upstream src/beast/app/beastapp/BeastMain.java at
# github.com/CompEvol/BEAST.app + GUI helpers at
# github.com/CompEvol/BeastFX
# Reference accessed: 2026-05-30 via gh api inspection of the
# new Arguments.Option[] array in BeastMain.java.
# BEAST 2 R101 — 14-stem multi-binary harvest covering BEAST 2's
# Bayesian phylogenetic family. The `2` suffix variants exist
# because some installers ship both `beast` and `beast2` (or
# `treeannotator` and `treeannotator2`) as parallel binaries to
# coexist with BEAST 1.x. All variants share the same CLI surface
# per stem.

local curcontext="$curcontext" state line ret=1

case $service in

  beast|beast2)
    # BEAST 2 main MCMC engine: read XML, run MCMC, write log/tree
    # files. Uses jam Arguments parser (single-dash long options).
    local -a _loglevels _beagle_scaling
    _loglevels=( error warning info debug trace )
    _beagle_scaling=( default none dynamic always )
    _arguments -s -S \
      '-window[provide a console window (GUI mode)]' \
      '-options[display an options dialog before running]' \
      '-working[change working directory to input file directory]' \
      '-seed+[random number generator seed]:N:' \
      '-prefix+[file name prefix for all output files]:prefix:' \
      '-statefile+[filename for storing/restoring the state]:file:_files' \
      '-overwrite[allow overwriting of log files]' \
      '-resume[allow appending of log files (continue a run)]' \
      '-validate[parse the XML but do not run (debug XML)]' \
      '-threads+[number of computational threads (default 1, -1 for cores)]:N:' \
      '-java[use pure Java implementations only]' \
      '-noerr[suppress all output to stderr]' \
      '-loglevel+[log level]:level:($_loglevels)' \
      '-instances+[divide site patterns across threads (use with -threads)]:N:' \
      '-beagle[use BEAGLE library if available]' \
      '-beagle_info[BEAGLE: show information on available resources]' \
      '-beagle_order+[BEAGLE: order of resource use]:order:' \
      '-beagle_CPU[BEAGLE: use CPU instance]' \
      '-beagle_GPU[BEAGLE: use GPU instance if available]' \
      '-beagle_SSE[BEAGLE: use SSE extensions]' \
      '-beagle_single[BEAGLE: use single precision]' \
      '-beagle_double[BEAGLE: use double precision]' \
      '-beagle_scaling+[BEAGLE: scaling scheme]:scaling:($_beagle_scaling)' \
      '-strictversions[use only package versions specified in the required attribute]' \
      '*-D+[attribute-value pairs to substitute in the XML (e.g. arg1=10,arg2=20)]:definitions:' \
      '-DF+[file with attribute-value pairs to substitute (one set per line)]:file:_files' \
      '-DFout+[BEAST XML output written when -DF is used]:file:_files' \
      '-sampleFromPrior[sample from prior (set sampleFromPrior=true)]' \
      '(- *)-help[show help]' \
      '(- *)-version[show version]' \
      '*:BEAST 2 XML file:_files -g "*.xml"' \
      && ret=0
    ;;

  beauti|beauti2)
    # BEAUti — Bayesian Evolutionary Analysis Utility (GUI builder
    # for BEAST 2 XML files; CLI side just accepts a template file).
    _arguments \
      '-template+[XML template file]:file:_files -g "*.xml"' \
      '-prefix+[output file name prefix]:prefix:' \
      '-out+[output XML file]:file:_files' \
      '-create[create the XML file without launching the GUI]' \
      '*:NEXUS or FASTA input file:_files -g "*.(nex|nexus|fasta|fa)"' \
      && ret=0
    ;;

  treeannotator|treeannotator2)
    # TreeAnnotator — summarize a tree set into a single annotated
    # summary tree (Maximum Clade Credibility / User target).
    _arguments \
      '-burnin+[percentage of trees to discard as burn-in (e.g. 10)]:percent:' \
      '-burninTrees+[absolute number of trees to discard as burn-in]:N:' \
      '-limit+[posterior probability limit for node annotations]:p:' \
      '-heights+[node heights to use]:method:(keep median mean ca)' \
      '-target+[user target tree file]:file:_files' \
      '-help[show help]' \
      '1:input tree file:_files -g "*.(trees|tree|nex|nexus)"' \
      '2:output annotated tree file:_files' \
      && ret=0
    ;;

  logcombiner|logcombiner2)
    # LogCombiner — combine multiple BEAST log files / tree files
    # into a single trace (handles burn-in/resample).
    _arguments \
      '*-log+[input log/tree file (repeatable)]:file:_files -g "*.(log|trees|tree)"' \
      '*-burnin+[burn-in percentage per file (repeatable)]:percent:' \
      '-resample+[resample every N states]:N:' \
      '-renumber[renumber output samples sequentially]' \
      '-decimal[print state numbers as decimals]' \
      '-scale+[multiplier for branch lengths]:factor:' \
      '-strip[strip annotations from tree files]' \
      '-o+[output combined file]:file:_files' \
      '*:additional input files:_files -g "*.(log|trees|tree)"' \
      && ret=0
    ;;

  densitree|densitree2)
    # DensiTree — visualizer that overlays all sampled trees from a
    # posterior. CLI accepts a tree file and optional output image.
    _arguments \
      '-fontfile+[font file for taxa labels]:file:_files' \
      '-out+[output image file (PNG/SVG/PDF/EPS)]:file:_files' \
      '-width+[output image width]:px:' \
      '-height+[output image height]:px:' \
      '*:tree file:_files -g "*.(trees|tree|nex|nexus)"' \
      && ret=0
    ;;

  applauncher|applauncher2)
    # AppLauncher — invokes BEAST 2 package-installed sub-apps
    # (each package can register tools that show up here).
    _arguments \
      '-help[list installed applications]' \
      '1:application name:' \
      '*:application args:' \
      && ret=0
    ;;

  packagemanager|packagemanager2)
    # PackageManager — install / update / list / remove BEAST 2
    # packages (a.k.a. BEAUti add-ons).
    _arguments \
      '-list[list installed packages]' \
      '-add+[install named package]:package:' \
      '-del+[uninstall named package]:package:' \
      '-update[update installed packages]' \
      '-useAppDir[install into per-user app directory]' \
      '-dir+[explicit install directory]:dir:_directories' \
      '-version+[install specific package version]:version:' \
      '*:package name:' \
      && ret=0
    ;;

esac

return ret
