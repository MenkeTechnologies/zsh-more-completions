#compdef mashtree
# Documentation: https://github.com/lskatz/mashtree
# Create a tree using Mash distances between genomes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display version]' \
  '--tempdir=[directory for caching results]:dir:_files -/' \
  '--numcpus=[number of CPU threads]:cpus:' \
  '--outmatrix=[output distance matrix file]:file:_files' \
  '--outtree=[output tree file]:file:_files' \
  '--file-of-files[read filenames from input files]' \
  '--truncLength=[filename character limit]:len:' \
  '--sort-order=[neighbor-joining sort order]:order:(ABC random input-order)' \
  '--genomesize=[expected genome size]:size:' \
  '--mindepth=[minimum kmer abundance depth]:depth:' \
  '--kmerlength=[kmer length]:k:' \
  '--sketch-size=[sketch size]:size:' \
  '*:genome:_files' && ret=0

return ret
