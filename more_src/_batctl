#compdef batctl
# Documentation: source-direct extraction from upstream
# open-mesh-mirror/batctl. Subcommand list extracted by walking
# all 58 .c files in the source root and grepping for the
# `COMMAND(_type, _handler, _abbr, _flags, _arg, _usage)` and
# `COMMAND_NAMED(...)` macros (each file registers a subcommand
# via one of these macros; subcommand TYPE determines whether it
# is `SUBCOMMAND` (general), `SUBCOMMAND_MIF` (mesh-interface-
# scoped), `SUBCOMMAND_VID` (vlan-scoped), `SUBCOMMAND_HIF`
# (hard-interface-scoped), `DEBUGTABLE` (debug table query), or
# `JSON_*` (netlink query as JSON). Global flags from main.c's
# `getopt(argc, argv, "+hm:v")` invocation.
# Reference accessed: 2026-05-30 via gh api.
# B.A.T.M.A.N. batctl R146 — control + diagnostics utility for
# B.A.T.M.A.N.-advanced Layer-2 mesh routing protocol. Sister to
# the heavily-covered mesh-networking family (babeld/yggdrasil/
# yggdrasilctl/tinc/alfred). Carryforward from R145 hunt-skip log
# where the macro-table extraction was deferred for a dedicated
# round.

# 46 subcommand long-form names + their short aliases. Listed in
# the source file each is registered from (commented above each
# block).
local -a _batctl_subcmds
_batctl_subcmds=(
  # SUBCOMMAND (general; no interface scoping needed)
  'event:display events from batman-adv'
  'e:short alias for event'
  'routing_algo:select the routing algorithm to use'
  'ra:short alias for routing_algo'

  # SUBCOMMAND_MIF (mesh-interface scoped)
  'aggregation:get/set OGM aggregation'
  'ag:short alias for aggregation'
  'ap_isolation:get/set AP isolation'
  'ap:short alias for ap_isolation'
  'bonding:get/set bonding mode'
  'b:short alias for bonding'
  'bridge_loop_avoidance:get/set bridge loop avoidance'
  'bl:short alias for bridge_loop_avoidance'
  'distributed_arp_table:get/set distributed ARP table'
  'dat:short alias for distributed_arp_table'
  'fragmentation:get/set fragmentation mode'
  'f:short alias for fragmentation'
  'gw_mode:get/set gateway mode (off/client/server)'
  'gw:short alias for gw_mode'
  'hop_penalty:get/set hop penalty'
  'hp:short alias for hop_penalty'
  'interface:add/remove/list hard interfaces in a mesh'
  'if:short alias for interface'
  'isolation_mark:get/set isolation mark for AP isolation'
  'mark:short alias for isolation_mark'
  'loglevel:get/set runtime log level'
  'll:short alias for loglevel'
  'multicast_fanout:get/set multicast fanout count'
  'mo:short alias for multicast_fanout'
  'multicast_forceflood:get/set multicast force-flood mode'
  'mff:short alias for multicast_forceflood'
  'multicast_mode:get/set multicast mode'
  'mm:short alias for multicast_mode'
  'orig_interval:get/set originator broadcast interval (ms)'
  'it:short alias for orig_interval'
  'ping:ping another mesh node (L2 batman-adv ping)'
  'p:short alias for ping'
  'statistics:print received traffic statistics'
  's:short alias for statistics'
  'throughputmeter:run a TCP-like throughput test against a node'
  'tp:short alias for throughputmeter'
  'traceroute:trace L2 batman-adv route to a node'
  'tr:short alias for traceroute'
  'translate:translate originator MAC to client MAC'
  't:short alias for translate'

  # SUBCOMMAND_HIF (hard-interface scoped; requires `hardif <iface>` prefix)
  'elp_interval:get/set ELP probe interval on a hard interface (ms)'
  'et:short alias for elp_interval'
  'throughput_override:get/set throughput override on a hard interface'
  'to:short alias for throughput_override'

  # DEBUGTABLE (display the corresponding debug table)
  'backbonetable:display the bridge-loop-avoidance backbone table'
  'bbt:short alias for backbonetable'
  'claimtable:display the bridge-loop-avoidance claim table'
  'cl:short alias for claimtable'
  'dat_cache:display the distributed-ARP-table cache'
  'dc:short alias for dat_cache'
  'gateways:display the known gateways'
  'gwl:short alias for gateways'
  'mcast_flags:display the multicast flags'
  'mf:short alias for mcast_flags'
  'originators:display the originator table'
  'o:short alias for originators'
  'transglobal:display the global translation table'
  'tg:short alias for transglobal'
  'translocal:display the local translation table'
  'tl:short alias for translocal'

  # JSON_MIF (mesh-interface-scoped netlink JSON queries)
  'bla_backbone_json:JSON dump of BLA backbone entries'
  'bbj:short alias for bla_backbone_json'
  'bla_claim_json:JSON dump of BLA claim entries'
  'clj:short alias for bla_claim_json'
  'dat_cache_json:JSON dump of distributed-ARP-table cache'
  'dcj:short alias for dat_cache_json'
  'gateways_json:JSON dump of known gateways'
  'gwj:short alias for gateways_json'
  'hardifs_json:JSON dump of hard interfaces'
  'mcast_flags_json:JSON dump of multicast flags'
  'mfj:short alias for mcast_flags_json'
  'mesh_json:JSON dump of mesh interface state'
  'mj:short alias for mesh_json'
  'neighbors_json:JSON dump of neighbor entries'
  'nj:short alias for neighbors_json'
  'originators_json:JSON dump of originator table'
  'oj:short alias for originators_json'
  'transtable_global_json:JSON dump of global translation table'
  'tgj:short alias for transtable_global_json'
  'transtable_local_json:JSON dump of local translation table'
  'tlj:short alias for transtable_local_json'

  # JSON_HIF (hard-interface-scoped JSON queries)
  'hardif_json:JSON dump of a specific hard interface'
  'hj:short alias for hardif_json (collides with hardifs_json - upstream pick)'

  # JSON_VID (VLAN-scoped JSON queries)
  'vlan_json:JSON dump of a specific VLAN'
  'vj:short alias for vlan_json'
)

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-m)-m+[mesh interface to operate on (default bat0)]:meshif:_net_interfaces' \
  '(-v)-v[show version]' \
  '1:subcommand:->subcmd' \
  '*:: :_default'

if [[ "$state" == subcmd ]]; then
  # Some subcommands need `meshif <netdev>` / `hardif <netdev>` /
  # `vid <vid>` selector prefixes; offer those as completions
  # alongside the bare subcommand names.
  _describe -t subcommands 'batctl subcommands' _batctl_subcmds
  _describe -t selectors 'interface selectors' \
    '(meshif:select-mesh-interface hardif:select-hard-interface vid:select-vlan-id)'
fi
