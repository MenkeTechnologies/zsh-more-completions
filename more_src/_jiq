#compdef jiq
# Documentation: https://man.archlinux.org/search?q=jiq
# Reference accessed: 2026-05-16

# Zsh completion for jiq - interactive jq query builder

_arguments -s -S \
  '(-a --attribute)'{-a,--attribute}'[initial attribute]:attribute:' \
  '(-q --query)'{-q,--query}'[initial query]:query:' \
  '(-M --monochrome)'{-M,--monochrome}'[monochrome output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:file:_files'
