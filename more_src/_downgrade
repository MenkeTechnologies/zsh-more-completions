#compdef downgrade

# Zsh completion for downgrade - downgrade Arch Linux packages

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--ala-url[set Arch Linux Archive URL]:url' \
  '--ala-only[only use Arch Linux Archive]' \
  '--cached-only[only use cached packages]' \
  '--ignore[add package to IgnorePkg]:package' \
  '--maxdepth[max depth for cache search]:depth' \
  '--pacman[pacman command]:command' \
  '--pacman-conf[pacman config file]:file:_files' \
  '--pacman-cache[pacman cache directory]:directory:_files -/' \
  '--pacman-log[pacman log file]:file:_files' \
  '*:package:->packages' && return 0

case $state in
  packages)
    local -a packages
    packages=(${(f)"$(pacman -Qq 2>/dev/null)"})
    _describe -t packages 'installed packages' packages
    ;;
esac
