#compdef pffexport
# Documentation: https://github.com/libyal/libpff
# Source: libyal/libpff manuals/pffexport.1 — export Outlook PAB / OST / PST mailbox items.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a codepages=(ascii windows-874 windows-932 windows-936 windows-949 windows-950 windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)

_arguments -s \
    "-c[codepage of ASCII strings]:codepage:($codepages)" \
    '-d[dump item values to a separate ItemValues.txt]' \
    '-f[preferred output format]:format:(all html rtf text)' \
    '-h[show help]' \
    '-l[log file for info about exported items]:log:_files' \
    '-m[export mode]:mode:(all debug items recovered)' \
    '-q[quiet (minimal status info)]' \
    '-t[basename of target directory to export to]:basename:' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:PAB/OST/PST file:_files' \
    && ret=0

return ret
