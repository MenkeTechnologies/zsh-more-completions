#compdef dashd
# _dashd — Dash Core dashd daemon CLI for the X11 Hash PrivateSend InstantSend masternode-governance fork of Bitcoin running a full node maintaining the blockchain validating mixing transactions network sync RPC API memory pool wallet PoSe (dashpay team, C++); custom argparse
# upstream: https://github.com/dashpay/dash

_dashd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf dash.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-daemon[run as daemon]' \
        '-pid=+[file]:file:_files' \
        '-testnet[use testnet]' \
        '-devnet=+[name]:str:' \
        '-regtest[use regtest]' \
        '-printtoconsole[print to console]' \
        '-debug=+[category]:c:(net mempool http bench zmq rpc walletdb estimatefee addrman selectcoins reindex cmpctblock rand prune libevent coindb leveldb chainlocks gobject instantsend llmq masternode mempool mnpayments mnsync privatesend spork all)' \
        '-loglevel=+[level]:l:(info debug trace)' \
        '-logips[log IPs]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcport=+[port]:n:' \
        '-rpcbind=+[addr]:str:' \
        '-rpcallowip=+[cidr]:str:' \
        '-rpcserver[enable RPC server]' \
        '-listen[enable inbound]' \
        '-port=+[port]:n:' \
        '-bind=+[host]:str:' \
        '-externalip=+[ip]:str:' \
        '-onion=+[host:port]:str:' \
        '-proxy=+[host:port]:str:' \
        '-blocksonly[only blocks]' \
        '-maxconnections=+[N]:n:' \
        '-paytxfee=+[DASH/kB]:f:' \
        '-reindex[reindex]' \
        '-rescan[rescan]' \
        '-wallet=+[file]:file:_files' \
        '-masternode=+[b]:b:(0 1)' \
        '-masternodeblsprivkey=+[key]:str:' \
        '-llmqtype=+[t]:t:(llmq_50_60 llmq_400_60 llmq_400_85 llmq_5_60 llmq_test llmq_devnet llmq_devnet_dip0024 llmq_25_67)' \
        '-llmq-data-recovery=+[b]:b:(0 1)' \
        '-disablegovernance[disable governance]' \
        '-privatesendrounds=+[N]:n:' \
        '-privatesendamount=+[N]:n:' \
        '-zmqpubrawblock=+[address]:str:' \
        '-zmqpubrawtx=+[address]:str:' \
        '-zmqpubhashblock=+[address]:str:' \
        '-zmqpubhashtx=+[address]:str:' \
        '-zmqpubrawchainlock=+[address]:str:' \
        '-zmqpubrawtxlock=+[address]:str:' \
        '-zmqpubhashchainlock=+[address]:str:' \
        '-zmqpubhashtxlock=+[address]:str:'
}

_dashd "$@"
