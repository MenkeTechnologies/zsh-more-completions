#compdef webpack-bundle-analyzer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-m+[analyzer mode]:mode:(server static json disabled)' \
  '--mode=[analyzer mode]:mode:(server static json disabled)' \
  '-h+[host for server mode]:host' \
  '--host=[host for server mode]:host' \
  '-p+[port for server mode]:port' \
  '--port=[port for server mode]:port' \
  '-r+[output file for static/json mode]:file:_files' \
  '--report=[output file for static mode]:file:_files' \
  '--report-title=[title for HTML report]:title' \
  '-s+[module sizes to show]:size type:(stat parsed gzip)' \
  '--default-sizes=[module sizes to show]:size type:(stat parsed gzip)' \
  '-O[open report in browser]' \
  '--open[open report in browser]' \
  '--no-open[do not open report in browser]' \
  '-e+[modules to exclude]:pattern' \
  '--exclude=[modules to exclude]:pattern' \
  '--log-level=[log level]:level:(info warn error silent)' \
  '1:stats JSON file:_files -g "*.json"' && ret=0

return ret
