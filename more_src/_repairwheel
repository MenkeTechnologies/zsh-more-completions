#compdef repairwheel
# Documentation: https://pypi.org/project/repairwheel/
# platform-agnostic Python wheel repair tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output-dir)'{-o,--output-dir}'+[directory where the repaired wheel is written]:dir:_files -/' \
  '(-l --lib-dir)'{-l,--lib-dir}'+[optional library directory for dependency resolution]:dir:_files -/' \
  '1:wheel:_files -g "*.whl"' && ret=0

return ret
