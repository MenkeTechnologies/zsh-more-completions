#compdef casbin-rust-cli
# Source: cargo binstall casbin-rust-cli@1.4.0
# Probed via: completion zsh
# Repository: https://github.com/casbin-rs/casbin-rust-cli

autoload -U is-at-least

_casbin-rust-cli() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_casbin-rust-cli_commands" \
"*::: :->casbin-rust-cli" \
&& ret=0
    case $state in
    (casbin-rust-cli)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:casbin-rust-cli-command-$line[1]:"
        case $line[1] in
            (completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- The shell to generate the completions for:(bash elvish fish nushell powershell zsh)' \
&& ret=0
;;
(enforce)
_arguments "${_arguments_options[@]}" : \
'-m+[The path of the model file or model text]:MODEL:_default' \
'--model=[The path of the model file or model text]:MODEL:_default' \
'-p+[The path of the policy file or policy text]:POLICY:_default' \
'--policy=[The path of the policy file or policy text]:POLICY:_default' \
'-h[Print help]' \
'--help[Print help]' \
'*::command_args -- The arguments for the enforcer:_default' \
&& ret=0
;;
(enforceEx)
_arguments "${_arguments_options[@]}" : \
'-m+[The path of the model file or model text]:MODEL:_default' \
'--model=[The path of the model file or model text]:MODEL:_default' \
'-p+[The path of the policy file or policy text]:POLICY:_default' \
'--policy=[The path of the policy file or policy text]:POLICY:_default' \
'-h[Print help]' \
'--help[Print help]' \
'*::command_args -- The arguments for the enforcer:_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_casbin-rust-cli__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:casbin-rust-cli-help-command-$line[1]:"
        case $line[1] in
            (completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(enforce)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(enforceEx)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_casbin-rust-cli_commands] )) ||
_casbin-rust-cli_commands() {
    local commands; commands=(
'completion:Generate the autocompletion script for the specified shell' \
'enforce:Check permissions' \
'enforceEx:Check permissions and get which policy it is' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'casbin-rust-cli commands' commands "$@"
}
(( $+functions[_casbin-rust-cli__completion_commands] )) ||
_casbin-rust-cli__completion_commands() {
    local commands; commands=()
    _describe -t commands 'casbin-rust-cli completion commands' commands "$@"
}
(( $+functions[_casbin-rust-cli__enforce_commands] )) ||
_casbin-rust-cli__enforce_commands() {
    local commands; commands=()
    _describe -t commands 'casbin-rust-cli enforce commands' commands "$@"
}
(( $+functions[_casbin-rust-cli__enforceEx_commands] )) ||
_casbin-rust-cli__enforceEx_commands() {
    local commands; commands=()
    _describe -t commands 'casbin-rust-cli enforceEx commands' commands "$@"
}
(( $+functions[_casbin-rust-cli__help_commands] )) ||
_casbin-rust-cli__help_commands() {
    local commands; commands=(
'completion:Generate the autocompletion script for the specified shell' \
'enforce:Check permissions' \
'enforceEx:Check permissions and get which policy it is' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'casbin-rust-cli help commands' commands "$@"
}
(( $+functions[_casbin-rust-cli__help__completion_commands] )) ||
_casbin-rust-cli__help__completion_commands() {
    local commands; commands=()
    _describe -t commands 'casbin-rust-cli help completion commands' commands "$@"
}
(( $+functions[_casbin-rust-cli__help__enforce_commands] )) ||
_casbin-rust-cli__help__enforce_commands() {
    local commands; commands=()
    _describe -t commands 'casbin-rust-cli help enforce commands' commands "$@"
}
(( $+functions[_casbin-rust-cli__help__enforceEx_commands] )) ||
_casbin-rust-cli__help__enforceEx_commands() {
    local commands; commands=()
    _describe -t commands 'casbin-rust-cli help enforceEx commands' commands "$@"
}
(( $+functions[_casbin-rust-cli__help__help_commands] )) ||
_casbin-rust-cli__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'casbin-rust-cli help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_casbin-rust-cli" ]; then
    _casbin-rust-cli "$@"
else
    compdef _casbin-rust-cli casbin-rust-cli
fi
