#compdef systemd-import
# Documentation: source-direct extraction from upstream
# systemd/systemd src/import/import.c —
#   verb dispatch table at lines 142-212 (VERB declarations
#     for "tar" and "raw")
#   parse_argv() with the OptionParser FOREACH_OPTION_OR_RETURN
#     dispatch (OPTION_LONG entries) at lines 331-413
# Reference accessed: 2026-05-30 via gh api.
#
# systemd-import is the **per-format local-image importer** —
# the libexec binary that R220's importctl invokes for
# `importctl import-tar` and `importctl import-raw`.  Can
# also be run directly by the user (or by build scripts) for
# importing TAR or RAW container/VM images into the
# machined image store (`/var/lib/machines/`) without going
# through the importd D-Bus daemon.  Sister to systemd-pull
# (downloads from URLs) and systemd-export (writes images
# back out).
#
# Critical extraction note: systemd-import has ONLY 2 verbs
# (tar, raw) — it does NOT support OCI imports.  OCI imports
# require a network URL fetch step that's only in
# systemd-pull's `oci` verb.

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'tar:import a TAR image from local FILE'
  'raw:import a RAW container/VM image from local FILE'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--version[show package version and exit]' \
  '--force[force creation of image (overwrite existing)]' \
  '--image-root=[image root directory (default /var/lib/machines)]:dir:_files -/' \
  '--read-only[create a read-only image]' \
  '--direct[import directly to specified output file (skip image-root)]' \
  '--btrfs-subvol=[create image as a btrfs subvolume (yes|no)]:bool:(yes no true false 1 0)' \
  '--btrfs-quota=[apply default btrfs quota to image (yes|no)]:bool:(yes no true false 1 0)' \
  '--convert-qcow2=[convert qcow2 to raw before storing (yes|no)]:bool:(yes no true false 1 0)' \
  '--sync=[sync() data to disk before completing (yes|no)]:bool:(yes no true false 1 0)' \
  '--offset=[byte offset to seek to in destination]:bytes:' \
  '--size-max=[maximum number of bytes to write to destination]:bytes:' \
  '--class=[install as the specified TYPE]:type:(machine portable sysext confext)' \
  '1:verb (tar|raw):->subcmd' \
  '*::verb-args:->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'systemd-import verb' subcommands && ret=0
    ;;
  args)
    case $words[1] in
      tar)
        _arguments \
          '1:FILE (TAR archive):_files -g "*.tar*"' \
          '2:NAME (optional; default: derived from FILE):' && ret=0
        ;;
      raw)
        _arguments \
          '1:FILE (RAW disk image or qcow2):_files -g "*.(raw|img|qcow2)*"' \
          '2:NAME (optional; default: derived from FILE):' && ret=0
        ;;
    esac
    ;;
esac

return ret
