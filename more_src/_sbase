#compdef sbase
# _sbase — The Document Foundation LibreOffice sbase CLI symlink launching LibreOffice Base the database front-end opening .odb HSQLDB Firebird MySQL PostgreSQL ODBC JDBC connection-based databases for form report query designer wizards with options for headless connection-string invocation (LibreOffice team, C++); getopt
# upstream: https://www.libreoffice.org/

_sbase() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--writer[start as Writer]' \
        '--calc[start as Calc]' \
        '--draw[start as Draw]' \
        '--impress[start as Impress]' \
        '--base[start as Base]' \
        '--math[start as Math]' \
        '--show=+[file]:file:_files' \
        '--view=+[file]:file:_files' \
        '--norestore[no restore]' \
        '--nologo[no logo]' \
        '--nodefault[no default doc]' \
        '--invisible[no UI window]' \
        '--minimized[start minimized]' \
        '--headless[headless mode]' \
        '--accept=+[connection string]:str:' \
        '--language=+[lang]:str:' \
        '--safe-mode[safe mode]' \
        '--convert-to+[output filter]:str:' \
        '--outdir=+[dir]:dir:_files -/' \
        '*:database file:_files -g "*.odb *.fodb *.sdb"'
}

_sbase "$@"
