#compdef dh_builddeb
# Documentation: https://manpages.debian.org/dh_builddeb
# Source: Debian/debhelper dh_builddeb — build Debian binary packages (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a --arch)'{-a,--arch}'[only arch-dep packages]' \
    '(-i --indep)'{-i,--indep}'[only arch-indep packages]' \
    '*-p+[apply to package]:pkg:_default' \
    '*-N+[skip package]:pkg:_default' \
    '*-u+[option for dpkg-deb]:opt:_default' \
    '--no-act[do not act]' \
    '--filename=-[output filename]:filename:_default' \
    '--destdir=-[destination directory]:dir:_files -/' \
    '*-O+[passthrough option]:opt:_default' \
    && ret=0

return ret
