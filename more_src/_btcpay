#compdef btcpay btcpayserver btcpay-cli
# _btcpay — BTCPay Server btcpay CLI for the self-hosted open-source Bitcoin payment processor managing stores invoices payment requests pull payments crowdfunding apps lightning hot wallets webhooks API keys (btcpayserver team, C#); System.CommandLine
# upstream: https://github.com/btcpayserver/btcpayserver

_btcpay() {
    local -a sub=(
        'login:login to server'
        'logout:logout'
        'serverstatus:show server status'
        'store:store operations'
        'invoice:invoice operations'
        'payment-request:payment request operations'
        'pull-payment:pull payment operations'
        'app:app operations'
        'lightning:lightning operations'
        'wallet:wallet operations'
        'webhook:webhook operations'
        'apikey:API key operations'
        'user:user operations'
        'plugin:plugin operations'
        'health:check server health'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--server=+[url]:str:' \
        '-s+[url]:str:' \
        '--api-key=+[key]:str:' \
        '-k+[key]:str:' \
        '--store-id=+[id]:str:' \
        '--no-color[no color]' \
        '--insecure[insecure TLS]' \
        '--output=+[fmt]:f:(json yaml text csv)' \
        '-o+[fmt]:f:(json yaml text csv)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'btcpay subcommand' sub ;;
        args)
            case $words[1] in
                invoice) _arguments \
                    '1:action:(create get list void mark-as)' \
                    '--amount=+[BTC]:f:' \
                    '--currency=+[ccy]:str:' \
                    '--order-id=+[id]:str:' \
                    '--description=+[text]:str:' \
                    '*:invoice id:' ;;
                store) _arguments \
                    '1:action:(create get list update delete)' \
                    '*:store id:' ;;
                lightning) _arguments \
                    '1:action:(info create-invoice pay-invoice connect channels)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_btcpay "$@"
