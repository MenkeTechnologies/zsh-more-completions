#compdef nvidia-ctk-installer
# _nvidia-ctk-installer — installer DaemonSet that drops the NVIDIA Container Toolkit onto the host and rewires docker/containerd/crio to the nvidia runtime
# upstream: https://github.com/NVIDIA/nvidia-container-toolkit
# Flags from cmd/nvidia-ctk-installer/main.go on tip (urfave/cli/v3).

_nvidia-ctk-installer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '(-n --no-daemon)'{-n,--no-daemon}'[exit immediately after setup, no cleanup]' \
        '--no-runtime-config[skip container runtime configuration]' \
        '(-p --enable-nri-plugin)'{-p,--enable-nri-plugin}'[stand up an NRI plugin server that injects CDI devices]' \
        '--nri-plugin-index=[NRI plugin index]:n:' \
        '--nri-socket=[NRI socket path]:socket:_files' \
        '--nri-namespace=[namespace the toolkit NRI plugin runs in]:ns:' \
        '(-r --runtime)'{-r,--runtime}'=[runtime to configure on this node]:rt:(docker crio containerd)' \
        '(--toolkit-install-dir --root)'{--toolkit-install-dir,--root}'=[install directory for the NVIDIA Container Toolkit]:dir:_files -/' \
        '--toolkit-source-root=[folder containing toolkit artifacts]:dir:_files -/' \
        '--toolkit-package-type=[toolkit package type]:type:(deb rpm auto)' \
        '--pid-file=[toolkit.pid file for single-instance enforcement]:file:_files' \
        '--debug[enable debug-level logging]'
}

_nvidia-ctk-installer "$@"
