#compdef fits2ndf
# Documentation: https://starlink.eao.hawaii.edu/docs/sun55.htx/sun55ss5.html
# CONVERT FITS2NDF - convert FITS files into NDFs

local ret=1

_arguments -C \
  'IN=[FITS files to be converted]:FITS file:_files' \
  'OUT=[output NDF names]:NDF file:_files' \
  'CONTAINER=[write each HDU as a component of an HDS container]:flag:(TRUE FALSE)' \
  'ENCODINGS=[FITS keywords defining the WCS]:encodings:' \
  'EXTABLE=[text file associating sub-files with NDF components]:file:_files' \
  'FMTCNV=[apply BSCALE and BZERO scaling]:flag:(TRUE FALSE)' \
  'PROEXTS=[propagate FITS extensions to NDF extensions]:flag:(TRUE FALSE)' \
  'PROFITS=[write FITS headers to the NDF FITS extension]:flag:(TRUE FALSE)' \
  'TYPE=[data type of the output arrays]:type:(_REAL _DOUBLE _INTEGER _WORD _UWORD _BYTE _UBYTE)' \
  'WCSATTRS=[keyword=value pairs modifying WCS extraction]:atts:' \
  'WCSCOMP=[where coordinate information is stored]:comp:(Axis WCS Both None)' \
  '*:FITS file:_files' && ret=0

return ret
