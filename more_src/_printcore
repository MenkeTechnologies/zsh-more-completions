#compdef printcore
# Documentation: https://github.com/kliment/Printrun
# Printrun printcore: send a G-code file to a printer over serial

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-v --verbose)'{-v,--verbose}'[print additional progress information]' \
  '(-s --statusreport)'{-s,--statusreport}'[print progress as percentage]' \
  '(-b --baud)'{-b,--baud}'=[set baud rate (default 115200)]:baud:(9600 19200 38400 57600 115200 250000)' \
  '1:serial port:_files -g "/dev/*"' \
  '2:gcode file:_files -g "*.(gcode|gco|g|GCODE)"' && ret=0

return ret
