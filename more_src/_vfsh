#compdef vfsh vfs vfs-cli
# _vfsh — VirtualFileSystem virtual filesystem inspector shell CLI alias (vfs project, multiple); custom argparse
# upstream: https://github.com/jakulm/vfs

_vfsh() {
    local -a sub=(
        'ls:list directory'
        'cat:read file'
        'cd:change directory'
        'pwd:print working directory'
        'mkdir:create directory'
        'mv:move/rename file'
        'cp:copy file'
        'rm:remove file'
        'find:find files'
        'mount:mount a VFS'
        'umount:unmount a VFS'
        'stat:stat a file'
        'help:show help'
        'version:show version'
        'exit:exit shell'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--mount=+[mount spec]:str:' \
        '-m+[mount spec]:str:' \
        '--root=+[root dir]:dir:_files -/' \
        '-r+[root dir]:dir:_files -/' \
        '--read-only[read-only mode]' \
        '--debug[debug]' \
        '-d[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vfsh subcommand' sub ;;
        args)
            case $words[1] in
                ls|cat|find|stat|rm|cd|mkdir) _arguments '*:path:_files' ;;
                mv|cp) _arguments '*:src-and-dst:_files' ;;
                mount) _arguments '*:spec:' ;;
                umount) _arguments '*:mount-point:_files -/' ;;
            esac
            ;;
    esac
}

_vfsh "$@"
