#compdef bufr_filter
# Documentation: https://confluence.ecmwf.int/display/ECC/bufr_filter
# Source: ecmwf/eccodes tools/bufr_filter.cc — apply a filter file to BUFR messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[force, do not fail on error]' \
    '-o+[output file (default filter.out)]:file:_files' \
    '(- *)-V[show version]' \
    '-g[copy GTS header]' \
    '-T+[message type]:type:(T B M A)' \
    '-7[do not fail on wrong message length]' \
    '-v[verbose]' \
    '1:filter file:_files' \
    '*:bufr file:_files' \
    && ret=0

return ret
