#compdef config-connector
# _config-connector — GCP Config Connector export tool (GoogleCloudPlatform)
# upstream: https://github.com/GoogleCloudPlatform/k8s-config-connector

_config-connector() {
    local curcontext="$curcontext" state line ret=1

    local -a commands=(
        'export:export GCP resources as KRM'
        'bulk-export:export all resources from a project/folder/org'
        'apply:apply exported resources'
    )

    _arguments -C \
        '--help[show help]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'config-connector command' commands && ret=0 ;;
        args)
            case $line[1] in
                export|bulk-export)
                    _arguments \
                        '--project=[GCP project ID]:project:' \
                        '--folder=[GCP folder ID]:folder:' \
                        '--organization=[GCP organization ID]:org:' \
                        '--resource=[resource to export]:resource:' \
                        '--iam-format=[IAM policy format]:format:(policy policymember)' \
                        '--filter-deleted-iam-members[filter deleted IAM members]' \
                        '--output=[output directory]:dir:_directories' \
                        '--on-error=[error handling]:mode:(continue halt ignore)' \
                        '--help[show help]' && ret=0 ;;
                apply)
                    _arguments \
                        '--help[show help]' \
                        '*:file:_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_config-connector "$@"
