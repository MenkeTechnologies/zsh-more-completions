#compdef depx
# Documentation: https://github.com/projectdiscovery/depx
# malicious package and supply-chain intelligence CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-j --json)'{-j,--json}'[machine-readable JSON output]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-e --ecosystem)'{-e,--ecosystem}'=[restrict lookup to one ecosystem]:ecosystem' \
  '(-v --verbose)'{-v,--verbose}'[extra audit/github detail]' \
  '--silent[suppress banner and version info]' \
  '--no-color[disable ANSI colors]' \
  '--config=[config file path]:config file:_files' \
  '--update[update depx to the latest version]' \
  '--disable-update-check[disable the update check]' \
  '--since=[restrict to packages disclosed since]:since' \
  '(-n --limit)'{-n,--limit}'=[limit number of results]:limit' \
  '--list[plain list output]' \
  '--require-clean[require a clean result]' \
  '--exclude-pkg=[exclude package from audit]:package' \
  '(-o --output)'{-o,--output}'=[output file]:output file:_files' \
  '--output-format=[output format]:format' \
  '--sarif-export=[export SARIF report]:file:_files' \
  '--sbom-export=[export SBOM]:file:_files' \
  '--sbom-format=[SBOM format]:format' \
  '1:command:((feed\:"show recently disclosed malicious packages" audit\:"audit dependencies for malicious packages" github\:"audit GitHub repositories via dependency-graph SBOM" search\:"search known malicious packages by name" id\:"lookup advisory by ID" version\:"show version and check for updates" update\:"update depx to the latest version"))' \
  '*::arg:_default' && ret=0

return ret
