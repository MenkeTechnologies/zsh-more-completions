#compdef meilisearch

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--db-path+[database path]:dir:_files -/' \
  '--http-addr+[HTTP listen]:addr:' \
  '--master-key+[master key]:k:' \
  '--env+[environment]:e:(production development)' \
  '--no-analytics[disable analytics]' \
  '--http-payload-size-limit+[max payload]:size:' \
  '--log-level+[log level]:l:(off error warn info debug trace)' \
  '--max-indexing-memory+[indexing mem MB]:mb:' \
  '--max-indexing-threads+[indexing threads]:n:' \
  '--snapshot-dir+[snapshot dir]:dir:_files -/' \
  '--schedule-snapshot[schedule snapshot]' \
  '--snapshot-interval-sec+[snapshot interval]:s:' \
  '--import-snapshot+[import snapshot]:file:_files' \
  '--ignore-missing-snapshot[ignore missing snapshot]' \
  '--ignore-snapshot-if-db-exists[ignore if db exists]' \
  '--dump-dir+[dump dir]:dir:_files -/' \
  '--dumps-dir+[dumps dir]:dir:_files -/' \
  '--import-dump+[import dump]:file:_files' \
  '--ignore-missing-dump[ignore missing dump]' \
  '--ignore-dump-if-db-exists[ignore dump if db]' \
  '--ssl-cert-path+[SSL cert]:file:_files' \
  '--ssl-key-path+[SSL key]:file:_files' \
  '--ssl-auth-path+[SSL auth path]:file:_files' \
  '--ssl-ocsp-path+[SSL OCSP path]:file:_files' \
  '--ssl-require-auth[require SSL auth]' \
  '--ssl-resumption[SSL resumption]' \
  '--ssl-tickets[SSL tickets]' \
  '--config-file-path+[config file]:file:_files -g "*.toml"' \
  '--experimental-enable-metrics[enable metrics]' \
  '--experimental-search-queue-size+[search queue size]:n:' \
  '--experimental-logs-mode+[logs mode]:m:(human json)' \
  '--experimental-replication-parameters[replication params]' \
  '--experimental-dumpless-upgrade[dumpless upgrade]' \
  '--task-webhook-url+[task webhook URL]:url:' \
  '--task-webhook-authorization-header+[webhook auth]:s:' \
  '*: :_files' && ret=0

return ret
