#compdef meilisearch-cli
# Documentation: https://github.com/sanders41/meilisearch-cli
# Reference accessed: 2026-05-19
# Verified: upstream README. STUB — sanders41/meilisearch-cli is archived
# (Aug 2024) and its subcommand surface is not fully enumerated upstream;
# keep only the documented global flags and let users discover commands.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--url=[Meilisearch server URL]:url:' \
  '--master-key=[master key]:key:' \
  '1:command:(get-version add-documents get-document health)' \
  '*::arg:_files' && ret=0

return ret
