#compdef apify
# Documentation: https://man.archlinux.org/search?q=apify
# Reference accessed: 2026-05-16

# apify-cli (Node); Homebrew: Formula/a/apify-cli.rb — binary `apify`

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'apify command' compadd -- init run call push secrets datasets key-value-stores request-queues builds logs
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
