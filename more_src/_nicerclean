#compdef nicerclean
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/nicerclean.html
# Screen a calibrated MPU-merged NICER event file into a cleaned event file

local ret=1

_arguments -s -S \
  'infile=[input calibrated MPU-merged event file]:infile:_files' \
  'outfile=[output cleaned screened event file]:outfile:_files' \
  'gtifile=[GTI screening file, or NONE]:gtifile:_files' \
  'trumpetfilt=[apply PI_RATIO background filtering]:trumpetfilt:(yes no)' \
  'timerange=[event TIME range filter]:timerange:' \
  'fastconst=[trumpet ratio constant cut]:fastconst:' \
  'fastsig=[fast chain noise level in eV]:fastsig:' \
  'fastquart=[fast chain quartic gain error]:fastquart:' \
  'pirange=[pulse height screening range]:pirange:' \
  'filtexpr=[custom extractor filtering expression]:filtexpr:' \
  'datamode=[X-ray event type screening mode]:datamode:' \
  'keep_overshoots=[retain overshoot events]:keep_overshoots:(yes no)' \
  'keep_undershoots=[retain undershoot events]:keep_undershoots:(yes no)' \
  'keep_forced=[retain forced trigger events]:keep_forced:(yes no)' \
  'keep_noisering=[retain noise ringer events]:keep_noisering:(yes no)' \
  'cleanup=[remove temporary files]:cleanup:(yes no)' \
  'fpmsel=[modify FPM selection information]:fpmsel:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
