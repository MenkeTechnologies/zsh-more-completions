#compdef show-aligns
# Documentation: https://manpages.debian.org/testing/mummer/show-aligns.1.en.html
# MUMmer utility to display alignments from a delta file

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-q[sort alignments by the query start coordinate]' \
  '-r[sort alignments by the reference start coordinate]' \
  '-w+[set the screen width]:width' \
  '-x+[set the matrix type for amino acid alignments]:matrix:(1 2 3)' \
  ':delta file:_files -g "*.delta"' \
  ':reference id:' \
  ':query id:' && ret=0

return ret
