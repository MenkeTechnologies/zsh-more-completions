#compdef mpflash
# Documentation: https://github.com/Josverl/mpflash
# mpflash - flash and download MicroPython firmware to/from boards

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--dir=[firmware and database location]:dir:_files -/' \
  '1:command:(list download flash)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      list)
        _arguments -s \
          '(-s --serial)'{-s,--serial}'=[serial port(s) or globs]:serial:_files -g "/dev/tty* /dev/cu*"' \
          '(-i --ignore)'{-i,--ignore}'=[ignore serial port(s)]:serial:' \
          '(-b --bluetooth)'{-b,--bluetooth}'[include Bluetooth ports]' \
          '(-nb --no-bluetooth)'{-nb,--no-bluetooth}'[exclude Bluetooth ports]' && ret=0
        ;;
      download)
        _arguments -s \
          '--version=[firmware version (stable, preview, or x.y.z)]:version:(stable preview)' \
          '(-s --serial)'{-s,--serial}'=[select serial port(s)]:serial:_files -g "/dev/tty* /dev/cu*"' \
          '--board=[board(s) to download]:board:' \
          '--dir=[firmware directory location]:dir:_files -/' && ret=0
        ;;
      flash)
        _arguments -s \
          '--version=[firmware version to flash]:version:(stable preview)' \
          '(-s --serial)'{-s,--serial}'=[target serial port(s)]:serial:_files -g "/dev/tty* /dev/cu*"' \
          '--board=[firmware to flash]:board:' \
          '--variant=[board variant]:variant:' \
          '--bootloader=[bootloader mode]:mode:(touch1200 mpy manual none)' \
          '--dir=[firmware directory location]:dir:_files -/' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
