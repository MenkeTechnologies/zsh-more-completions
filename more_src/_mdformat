#compdef mdformat
# Documentation: https://mdformat.readthedocs.io/en/stable/users/installation_and_usage.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_mdformat() {
  _arguments \
    '--check[check if files are already formatted]' \
    '--no-validate[skip HTML consistency validation]' \
    '--wrap=[paragraph word wrap mode]:mode:(keep no)' \
    '--number[apply consecutive numbering for ordered lists]' \
    '--end-of-line=[output file line ending]:style:(lf crlf keep)' \
    '*--exclude=[exclude files matching glob pattern]:pattern:' \
    '*--extensions=[enable extension plugin]:extension:' \
    '*--no-extensions=[disable extension plugin]:extension:' \
    '*--codeformatters=[enable code formatter plugin]:language:' \
    '*--no-codeformatters=[disable code formatter plugin]:language:' \
    '--help[show help]' \
    '--version[show version]' \
    '*:file:_files'
}

_mdformat "$@"
