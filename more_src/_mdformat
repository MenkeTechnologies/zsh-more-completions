#compdef mdformat
# Documentation: https://man.archlinux.org/search?q=mdformat
# Reference accessed: 2026-05-16

_mdformat() {
  _arguments \
    '--check[check if file is already formatted]' \
    '--wrap=[wrap mode]:mode:(keep no INTEGER)' \
    '--number[use ordered list numbering]' \
    '--end-of-line=[line ending style]:style:(lf crlf keep)' \
    '--extensions=[enable extensions]:extensions' \
    '--codeformatters=[enable code formatters]:formatters' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '*:file:_files'
}

_mdformat "$@"
