# Zsh completion for create-ai-agent-setup - AI agent rule and project setup scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-t --type)'{-t,--type=}'[project type]:type:(backend frontend fullstack mobile)' \
  '(-f --framework)'{-f,--framework=}'[framework selection]:framework:(nextjs vite expo cli)' \
  '(-T --tier)'{-T,--tier=}'[rule tier]:tier:(starter standard strict)' \
  '(-d --db)'{-d,--db=}'[database backend]:database:(postgresql mysql sqlite none)' \
  '(-y --yes)'{-y,--yes}'[skip prompts; use defaults]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  ':project name:' && ret=0

return ret
