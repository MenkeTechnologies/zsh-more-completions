#compdef 3dTstat
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTstat.html
# AFNI per-voxel statistics across the time axis of a 3D+time dataset

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-sum[sum of input voxels]' \
  '-abssum[absolute sum]' \
  '-sos[sum of squares]' \
  '-l2norm[L2 norm]' \
  '-mean[mean]' \
  '-slope[slope vs time]' \
  '-stdev[standard deviation (detrended)]' \
  '-stdevNOD[standard deviation without detrending]' \
  '-cvar[coefficient of variation (detrended)]' \
  '-cvarNOD[coefficient of variation without detrending]' \
  '-cvarinv[inverse coefficient of variation]' \
  '-cvarinvNOD[inverse coefficient of variation, no detrend]' \
  '-tsnr[temporal signal-to-noise ratio]' \
  '-MAD[median absolute deviation]' \
  '-DW[Durbin-Watson statistic]' \
  '-median[median]' \
  '-nzmedian[median of non-zero voxels]' \
  '-nzstdev[standard deviation of non-zero voxels]' \
  '-bmv[biweight midvariance]' \
  '-MSSD[von Neumann mean of successive squared differences]' \
  '-MSSDsqrt[square root of MSSD]' \
  '-MASDx[median absolute successive differences]' \
  '-min[minimum value]' \
  '-max[maximum value]' \
  '-absmax[absolute maximum]' \
  '-signed_absmax[value with absolute maximum]' \
  '-percentile[P-th percentile]:P' \
  '-argmin[index of minimum]' \
  '-argmin1[index+1 of minimum]' \
  '-argmax[index of maximum]' \
  '-argmax1[index+1 of maximum]' \
  '-argabsmax[index of absolute maximum]' \
  '-argabsmax1[index+1 of absolute maximum]' \
  '-duration[duration above threshold around max]' \
  '-onset[beginning of duration threshold]' \
  '-offset[end of duration threshold]' \
  '-centroid[centroid of time curves]' \
  '-centduration[duration using centroid index]' \
  '-nzmean[mean of non-zero voxels]' \
  '-zcount[count of zero values]' \
  '-nzcount[count of non-zero values]' \
  '-autocorr[autocorrelation coefficients]:n' \
  '-autoreg[autoregression coefficients]:n' \
  '-accumulate[partial sums over time]' \
  '-centromean[mean of middle 50% of values]' \
  '-skewness[asymmetry measure]' \
  '-kurtosis[tailedness of distribution]' \
  '-firstvalue[first dataset value]' \
  '-tdiff[take first difference before processing]' \
  '-prefix[output dataset prefix]:prefix' \
  '-datum[output data type]:type:(byte short float)' \
  '-nscale[disable scaling for byte/short output]' \
  '-basepercent[percentage for duration calc]:nn' \
  '-mask[apply mask dataset]:dataset:_files' \
  '-mrange[restrict mask value range]:a' \
  '-cmask[compute mask with 3dcalc-like expr]:expr' \
  '*:dataset:_files' && ret=0

return ret
