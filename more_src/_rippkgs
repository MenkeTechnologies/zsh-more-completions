#compdef rippkgs

# Zsh completion for rippkgs - fast Nix package searcher

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '(-l --limit)'{-l,--limit}'[max results to show]:number:' \
  '(-f --flake)'{-f,--flake}'[flake reference to search]:flake:' \
  '--index[path to index directory]:dir:_directories' \
  '--no-color[disable color output]' \
  '*:query:' && return 0
