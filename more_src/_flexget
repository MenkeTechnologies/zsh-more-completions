    "(--help -h)"{--help,-h}"[show this help message and exit]" \
    "--tasks[run only specified task(s), optionally using glob patterns (\"tv-*\")]:TASK [TASK ...]:" \
    "--learn[matches are not downloaded but will be skipped in the future]" \
    "--no-cache[disable caches]" \
    "--dump[display all entries in task with fields they contain, use \`--dump eval\` to evaluate all lazy fields]: :(eval trace accepted rejected undecided failed title)" \
    "--dl-path[override path for download plugin, applies to all executed tasks]:PATH:_files" \
    "--dump-config[display the config of each feed after template merging/config generation occurs]" \
    "--cli-config[configuration parameters through commandline]:VARIABLE=VALUE [VARIABLE=VALUE ...]:" \
    "--try-regexp[try regular expressions interactively]" \
    "(-v --verbose)"{-v,--verbose}"[verbose undecided entries]" \
    "(-s --silent)"{-s,--silent}"[don't verbose any actions (accept, reject, fail)]" \
    "--now[run task(s) even if the interval plugin would normally prevent it]" \
    "(-T --template)"{-T,--template}"[execute tasks using given template]:NAME:" \
    "--tail-reset[reset tail position for a file]:FILE|TASK:_files" \
    "--discover-now[immediately try to discover everything]" \
    "--stop-waiting[stop timeframe for a given series]:NAME:"
  :
}
