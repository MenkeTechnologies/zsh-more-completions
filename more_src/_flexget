_flexget() {
  local context state state_descr line
  typeset -A opt_args
  _arguments -C \
    "(-V --version)"{-V,--version}"[print flexget version and exit]" \
    "--test[verbose what would happen on normal execution]" \
    "-c[specify configuration file]:CONFIG:_files" \
    "(--logfile -l)"{--logfile,-l}"[specify a custom logfile name/location]:LOGFILE:_files" \
    "(--loglevel -L)"{--loglevel,-L}"[set the verbosity of the logger]:LEVEL:(NONE CRITICAL ERROR WARNING INFO VERBOSE DEBUG TRACE)" \
    "--profile[use the python profiler for this run to debug performance issues]:[OUTFILE]:_files" \
    "--cron[use when executing flexget non-interactively]" \
    "(--help -h)"{--help,-h}"[show this help message and exit]" \
    "--debug-db-sessions[debug session starts and ends, for finding problems with db locks]" \
    "--debug-warnings[elevate warnings to errors for debugging purposes, so a traceback is shown]" \
    "1: :((\"execute:execute tasks now\" \"daemon:run continuously, executing tasks according to schedules defined in config\" \"export-schema:output the json schema for the config\" \"web:manage web server settings\" \"database:utilities to manage the flexget database\" \"plugins:print registered plugin summaries\" \"check:validate configuration file and print errors\" \"debug-info:display useful info for debugging\" \"templates:view all available templates\" \"doc:display plugin documentation\" \"jinja-filters:view registered jinja2 filters and their description\" \"torznab:query torznab indexer capabilities\" \"irc:view and manage irc connections\" \"backlog:view or clear entries from backlog plugin\" \"seen:view or forget entries remembered by the seen plugin\" \"history:view the history of entries that flexget has accepted\" \"archive:search and manipulate the archive database\" \"pending:view and manage pending entries\" \"trakt:view and manage trakt authentication.\" \"failed:list or clear remembered failures\" \"rejected:list or clear remembered rejections\" \"status:view task health status\" \"series:view and manipulate the series plugin database\" \"regexp-list:view and manage regexp lists\" \"movie-list:view and manage movie lists\" \"pending-list:view and manage pending lists\" \"entry-list:view and manage entry lists\" \"inject:inject an entry from command line into tasks\"))" \
    '*:: :->action'
  [[ -n $state ]] && (( $+functions[_flexget_$words[1]] )) && "_flexget_$words[1]"
  :
}
