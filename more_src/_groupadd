#compdef groupadd
# _groupadd — OpenBSD groupadd (low-level binary behind group add; appends a group line to /etc/group; -o lets a new group share a gid with an existing group)
# upstream: https://github.com/openbsd/src (usr.sbin/user)
# Flags from usr.sbin/user/groupadd.8 on tip.

_groupadd() {
    _arguments \
        '-o[allow duplicate gid]' \
        '-v[verbose]' \
        '-g+[gid]:gid:' \
        '1:group:_groups'
}

_groupadd "$@"
