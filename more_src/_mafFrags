#compdef mafFrags
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: extract maf sequences for regions in a bed file

local ret=1

_arguments -s -S \
  '-orgs=[file with list of databases/organisms in order]:file:_files' \
  '-bed12[in.bed is a bed 12 file, including exons]' \
  '-thickOnly[only extract subset between thickStart/thickEnd]' \
  '-meFirst[put native sequence first in maf]' \
  '-txStarts[add MAF txstart region definitions using BED name]' \
  '-refCoords[output actual reference genome coordinates in MAF]' \
  '1:database:' \
  '2:track:' \
  '3:input bed:_files -g "*.bed"' \
  '4:output maf:_files -g "*.maf"' && ret=0

return ret
