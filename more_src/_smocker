#compdef smocker
# ============================================================================
#  _smocker — smocker: simple and efficient HTTP mock server + proxy
#             for testing/development of HTTP clients and
#             distributed systems (smocker-dev project)
#
#  Source-direct extraction from
#    https://github.com/smocker-dev/smocker/blob/main/main.go
#    https://github.com/namsral/flag (the namsral/flag library by
#    Lars Wiegman / Namsral — env-var-merged drop-in replacement
#    for Go's stdlib flag package)
#
#  Maintained by smocker-dev / Thiht (Thibaut Rouffineau and
#  community).  1,279 GH stars.  Smocker is an HTTP mock server +
#  REVERSE PROXY designed for testing/development workflows where
#  you need to intercept HTTP calls from a system-under-test and
#  return canned or rule-driven responses.  Two server processes
#  ship in one binary: (1) the MOCK SERVER on port 8080 by default
#  (this is what your app POSTs/GETs to), and (2) the
#  ADMINISTRATION SERVER on port 8081 by default (Smocker UI +
#  REST API for defining mocks, viewing call history, replaying
#  scenarios, exporting/importing mock sessions).  Distinctive
#  feature: SESSIONS — every mock-call sequence is recorded as a
#  named session you can replay later, useful for capturing real
#  upstream behavior and turning it into a regression-test fixture.
#  Also supports TLS, dynamic-response generation (templated
#  responses driven by request body/headers), and persistence to
#  disk for restart-survival.  Sister tools: wiremock (Java mock
#  server — industry standard for JVM-based testing), mockoon (in
#  corpus via _mockoon — Electron-based GUI mock server),
#  prism-cli (Stoplight Prism OpenAPI mock — in corpus via
#  _prism), mockserver (Java — MockServer project), mountebank
#  (Node.js — in corpus via _mb), httpbin (Postman's HTTP
#  inspection service — in corpus via _httpbin), beeceptor (SaaS
#  mock — not CLI), localtunnel (in corpus via _lt — tunnels not
#  mocks), ngrok (in corpus + STOCK + tunnels not mocks).
#
#  CLI library taxonomy update: 15th Go CLI library — Lars
#  "namsral" Wiegman's **namsral/flag**.  Go ecosystem now has 15
#  documented CLI libraries — TYING WITH RUST at the top of the
#  cross-language taxonomy ahead of TypeScript-Node (14).  🎉 Go
#  RE-TIES with Rust at 15.
#
#  namsral/flag (531 GH stars) is Lars Wiegman's DROP-IN
#  REPLACEMENT for Go's stdlib `flag` package — adds 12-factor-
#  style ENV-VAR FALLBACK and CONFIG-FILE FALLBACK on top of the
#  exact same `flag.StringVar/BoolVar/IntVar/etc.` API as stdlib.
#  Distinguishing philosophy: stdlib `flag` is the simplest
#  possible Go flag parser — namsral/flag inherits that minimalism
#  and adds JUST ENOUGH ergonomics (env vars + config files) to
#  cover the 12-factor-app deployment model without reaching for a
#  heavier framework (cobra/urfave/kong).  Used by smocker-dev/
#  smocker (HTTP mock server 1,279 stars), rehacktive/caffeine
#  (basic REST service for JSON data 1,175 stars), ligato/vpp-
#  agent (Cisco FD.io VPP control plane 276 stars), ligato/sfc-
#  controller (Service Function Chain controller 47 stars), titpetric/
#  books (Go books example code), startdusk/finance-app-backend,
#  lehajam/gooption (option pricing tool), telekom/k8s-edge-
#  scheduler (Deutsche Telekom Kubernetes edge scheduler), and
#  many other Go services that want stdlib-flag ergonomics with
#  env-var fallback for cloud-native deployments.
#
#  namsral/flag API:
#    import (
#      "github.com/namsral/flag"
#      "os"
#    )
#
#    // Drop-in replacement for stdlib flag package — same API
#    // surface (StringVar/BoolVar/IntVar/Int64Var/Uint64Var/
#    // Float64Var/DurationVar) but with env-var fallback
#
#    // OPTION A: Replace the default FlagSet with an env-prefixed one
#    // Env-prefix is auto-applied: --log-level reads from
#    // SMOCKER_LOG_LEVEL env var, --listen-port from
#    // SMOCKER_LISTEN_PORT, etc.
#    flag.CommandLine = flag.NewFlagSetWithEnvPrefix(
#      os.Args[0],
#      "SMOCKER",         // env prefix
#      flag.ExitOnError,
#    )
#
#    // OPTION B: Use the global default (no prefix)
#    // flag.String("log-level", "info", "Log level")  // reads
#    // LOG_LEVEL env var
#
#    // OPTION C: Specify config file path via -config FLAG
#    // flag.String("config", "", "Config file path")  // auto-
#    // reads key=value pairs from that file
#
#    // REGISTER FLAGS — identical to stdlib flag API
#    flag.StringVar(&logLevel, "log-level", "info",
#      "Available levels: panic, fatal, error, warning, info, debug, trace")
#    flag.IntVar(&listenPort, "listen-port", 8080,
#      "Listen port")
#    flag.BoolVar(&tlsEnable, "tls-enable", false,
#      "Enable TLS")
#    flag.StringVar(&tlsCertFile, "tls-cert-file",
#      "/etc/smocker/tls/cert.pem", "TLS cert file path")
#
#    flag.Parse()
#
#  namsral/flag distinctive features:
#    - 100% API-COMPATIBLE WITH stdlib flag — same function
#      signatures (StringVar/BoolVar/IntVar/etc.), same
#      `flag.Parse()`, same `flag.PrintDefaults()`, same FlagSet
#      type.  Migration from stdlib is one import-path change.
#    - ENV VAR FALLBACK — if a flag isn't provided on argv,
#      namsral/flag CHECKS THE CORRESPONDING ENV VAR.  Naming
#      convention: `--log-level` → `LOG_LEVEL` (UPPERCASE + dashes-
#      to-underscores).  With env prefix `SMOCKER`: `--log-level`
#      → `SMOCKER_LOG_LEVEL`.
#    - `NewFlagSetWithEnvPrefix(name, prefix, errorHandling)` —
#      creates a new FlagSet that reads from env vars with the
#      given UPPERCASE prefix; `flag.CommandLine =` replaces the
#      default global FlagSet with the env-prefixed one
#    - CONFIG FILE FALLBACK — `flag.String("config", ...)` reads
#      KEY=VALUE pairs from a config file path (auto-detected
#      from -config flag); useful for 12-factor app deployments
#      where /etc/myapp/config.cfg is the canonical config source
#    - PRECEDENCE ORDER: argv > env var > config file > default
#      (highest-priority source wins per flag)
#    - INHERITS stdlib flag's SINGLE-DASH LONG-FLAG style —
#      smocker uses `-log-level` NOT `--log-level` (this is stdlib
#      flag's convention which namsral/flag preserves; POSIX
#      double-dash flags require switching to spf13/pflag or similar)
#    - NO subcommand framework (caller pairs with google/
#      subcommands or peterbourgon/ffcli for subcommand dispatch)
#    - NO automatic --help/--version (caller writes manually like
#      stdlib flag; flag.Usage() prints registered flags + their
#      env-var equivalents)
#    - INSPIRED BY 12-FACTOR APP methodology (config in env vars) —
#      Heroku-style deployment philosophy applied to Go CLI tools
#  Distinct from R237 Go spf13/cobra (subcommand-TREE with Command
#  structs — Hugo/Kubernetes/Docker), R237 Go spf13/pflag (POSIX-
#  flag-compat replacement for stdlib flag — used inside cobra),
#  R237 Go urfave/cli (action-callback — Docker pre-cobra, restic),
#  R237 Go alecthomas/kingpin (chained-builder — Prometheus), R237
#  Go jessevdk/go-flags (struct-tag — Helm earlier), R237 Go
#  mitchellh/cli (HashiCorp Terraform), R262 Go stdlib `flag`
#  (POSIX-INCOMPATIBLE single-dash long-flag — gofmt/go test;
#  namsral/flag is a DROP-IN with env-var ADDITIONS), R363 Go
#  peterbourgon/ff (functional-options 3-way config flag/env/file
#  merge — CLOSEST RIVAL to namsral/flag; peterbourgon/ff was
#  INSPIRED BY namsral/flag and the same 12-factor philosophy
#  but uses functional-options API instead of namsral/flag's
#  stdlib-flag-compatible API), R367 Go akamensky/argparse
#  (Python-argparse-style port), R408 Go pborman/getopt (POSIX-
#  getopt(3) faithful BSD/C-style — oklog/ulid), R411 Go integrii/
#  flaggy (package-level functional-builder — joanbono/Gurp +
#  jesseduffield/lazydocker), R414 Go alecthomas/kong (modern
#  struct-tag — charmbracelet/freeze + gum + mtg), R417 Go google/
#  subcommands (pure subcommand dispatch using stdlib flag —
#  future-architect/vuls + gvisor + Google Kf).  Go documented
#  libraries so far: stdlib flag, pflag, cobra, urfave-cli,
#  kingpin, jessevdk/go-flags, mitchellh/cli, ff, akamensky/
#  argparse, pborman/getopt, flaggy, kong, google/subcommands,
#  namsral/flag (this round)... 15 total.  namsral/flag's
#  distinguishing feature vs ALL other Go libs: namsral/flag is
#  the ONLY one that is a 100% API-COMPATIBLE drop-in for stdlib
#  flag.  Migration from stdlib flag is a one-line import change;
#  no API changes required.  Conceptually similar to R363
#  peterbourgon/ff in PURPOSE (12-factor env-var merge) but
#  OPPOSITE in API STYLE: ff uses functional-options + ParseConfig
#  combinators; namsral/flag uses stdlib-flag's pointer-first
#  setters.  namsral/flag's approach: STDLIB-FLAG-COMPATIBLE
#  DROP-IN with `flag.StringVar/BoolVar/IntVar/etc.` pointer-first
#  setters + `flag.NewFlagSetWithEnvPrefix(name, prefix,
#  errorHandling)` for env-prefixed FlagSet + AUTO env-var
#  fallback (UPPERCASE_DASHES_TO_UNDERSCORES naming) + CONFIG-FILE
#  fallback via -config flag (KEY=VALUE pairs) + PRECEDENCE argv
#  > env > config > default + STDLIB SINGLE-DASH LONG-FLAG style
#  (`-log-level` not `--log-level`) + NO subcommand framework
#  (pair with google/subcommands or peterbourgon/ffcli) + NO
#  automatic --help/--version + INSPIRED BY 12-factor app
#  methodology — corpus's **first documented stdlib-flag-drop-in
#  Go CLI library**.  Brings cross-language CLI library taxonomy
#  variant count to 160; Go ecosystem now has 15 documented CLI
#  libraries — TYING WITH RUST at the top of the cross-language
#  taxonomy ahead of TypeScript-Node (14).
#
#  Surface (verbatim from `main.go` namsral/flag registrations):
#
#  Usage:
#    smocker [options]
#
#  Options (note SINGLE-DASH style — stdlib flag convention
#  preserved by namsral/flag):
#    -log-level <LEVEL>             Log level (default: info;
#                                   env: SMOCKER_LOG_LEVEL).
#                                   Available: panic, fatal,
#                                   error, warning, info, debug,
#                                   trace
#    -config-base-path <PATH>       Base path applied to Smocker
#                                   UI (default: /;
#                                   env: SMOCKER_CONFIG_BASE_PATH)
#    -config-listen-port <PORT>     Listening port of Smocker
#                                   administration server
#                                   (default: 8081;
#                                   env: SMOCKER_CONFIG_LISTEN_PORT)
#    -mock-server-listen-port <PORT> Listening port of Smocker
#                                   mock server (default: 8080;
#                                   env: SMOCKER_MOCK_SERVER_LISTEN_PORT)
#    -static-files <DIR>            Location of static files to
#                                   serve (index.html, etc.;
#                                   default: client;
#                                   env: SMOCKER_STATIC_FILES)
#    -history-retention <N>         Maximum number of calls to
#                                   keep in the history per
#                                   session (0 = no limit;
#                                   default: 0;
#                                   env: SMOCKER_HISTORY_RETENTION)
#    -persistence-directory <DIR>   If defined, the directory
#                                   where sessions will be
#                                   synchronized
#                                   (env: SMOCKER_PERSISTENCE_DIRECTORY)
#    -tls-enable                    Enable TLS using the provided
#                                   certificate (default: false;
#                                   env: SMOCKER_TLS_ENABLE)
#    -tls-cert-file <FILE>          Path to TLS certificate file
#                                   (default:
#                                   /etc/smocker/tls/certs/cert.pem;
#                                   env: SMOCKER_TLS_CERT_FILE)
#    -tls-private-key-file <FILE>   Path to TLS key file
#                                   (default:
#                                   /etc/smocker/tls/private/key.pem;
#                                   env: SMOCKER_TLS_PRIVATE_KEY_FILE)
#    -h, -help                      Show help (auto from stdlib
#                                   flag.Usage)
#
#  Examples:
#    smocker                                            # Start with all defaults (mock on :8080, admin on :8081)
#    smocker -log-level=debug                           # Debug logging
#    smocker -mock-server-listen-port=9090              # Mock server on :9090
#    smocker -config-listen-port=9091                   # Admin server on :9091
#    smocker -persistence-directory=/var/lib/smocker    # Persist sessions
#    smocker -tls-enable                                # Enable TLS (uses default cert paths)
#    smocker -tls-enable -tls-cert-file=/my/cert.pem -tls-private-key-file=/my/key.pem
#    SMOCKER_LOG_LEVEL=debug smocker                    # Env var override
#    SMOCKER_MOCK_SERVER_LISTEN_PORT=9090 smocker       # Env var port override
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also namsral/flag users):
#    - caffeine (rehacktive/caffeine 1,175 stars — basic REST
#      service for JSON; FUTURE candidate — high stars but
#      thinner flag surface)
#    - vpp-agent (ligato/vpp-agent 276 stars — Cisco FD.io VPP
#      control plane; multi-component infrastructure project,
#      FUTURE candidate but complex flag surface)
#    - sfc-controller (ligato/sfc-controller 47 stars — Service
#      Function Chain controller; FUTURE candidate)
#    - finance-app-backend (3 stars too niche)
#    - refresh-host-cert (0 stars too niche)
# ============================================================================

_smocker() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '-h[show help]' \
    '-help[show help]' \
    '-log-level=[log level (env: SMOCKER_LOG_LEVEL)]:level:(panic fatal error warning info debug trace)' \
    '-config-base-path=[base path applied to Smocker UI]:path:' \
    '-config-listen-port=[listening port of Smocker administration server]:port:' \
    '-mock-server-listen-port=[listening port of Smocker mock server]:port:' \
    '-static-files=[location of static files to serve]:dir:_directories' \
    '-history-retention=[max calls to keep in history per session (0 = no limit)]:n:' \
    '-persistence-directory=[directory where sessions will be synchronized]:dir:_directories' \
    '-tls-enable[enable TLS using the provided certificate]' \
    '-tls-cert-file=[path to TLS certificate file]:file:_files -g "*.pem"' \
    '-tls-private-key-file=[path to TLS key file]:file:_files -g "*.pem"'
}

_smocker "$@"
