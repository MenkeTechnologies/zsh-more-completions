#compdef ray

# Zsh completion for Ray (distributed computing framework)

_ray() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'start:start Ray processes on the local machine'
    'stop:stop Ray processes on the local machine'
    'up:create or update a Ray cluster'
    'down:tear down a Ray cluster'
    'exec:execute a command on the Ray cluster'
    'submit:submit a Ray job'
    'attach:attach to a Ray cluster session'
    'dashboard:open the Ray dashboard'
    'status:show the status of the cluster'
    'job:manage Ray jobs'
    'rsync-down:download files from the cluster'
    'rsync-up:upload files to the cluster'
    'monitor:tail the log files of the cluster'
    'disable-usage-stats:disable usage stats collection'
    'enable-usage-stats:enable usage stats collection'
    'timeline:dump timeline of a Ray cluster'
    'microbenchmark:run microbenchmarks'
    'memory:print object store memory usage'
    'debug:debug a Ray program'
    'healthcheck:check the health of the cluster'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'ray command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        start)
          _arguments -s -S \
            '--head[start the head node]' \
            '--address=[address of the Ray cluster]:address:' \
            '--port=[port for the Ray head node]:port:' \
            '--node-ip-address=[IP address of this node]:IP:' \
            '--redis-password=[password for connecting to Redis]:password:' \
            '--num-cpus=[number of CPUs]:cpus:' \
            '--num-gpus=[number of GPUs]:gpus:' \
            '--resources=[custom resources as JSON]:JSON:' \
            '--object-store-memory=[object store memory in bytes]:bytes:' \
            '--dashboard-host=[dashboard host]:host:_hosts' \
            '--dashboard-port=[dashboard port]:port:' \
            '--block[block forever after starting]' \
            '--include-dashboard=[include the dashboard]:enabled:(true false)' \
            '--disable-usage-stats[disable usage stats]' \
            '--temp-dir=[temp directory]:directory:_files -/' \
            '--storage=[storage URI]:URI:' \
            '--system-config=[JSON system config]:config:' \
            '--log-style=[log style]:style:(auto record pretty)' \
            '--log-color=[log color]:enabled:(auto true false)' \
            '-v[verbose]' \
            '--verbose[verbose]' \
            && ret=0
          ;;
        stop)
          _arguments -s -S \
            '-f[force stop]' \
            '--force[force stop]' \
            '-g+[grace period in seconds]:seconds:' \
            '--grace-period=[grace period in seconds]:seconds:' \
            '-v[verbose]' \
            '--verbose[verbose]' \
            && ret=0
          ;;
        up)
          _arguments -s -S \
            '--no-restart[do not restart Ray on head node]' \
            '--restart-only[only restart Ray]' \
            '-y[skip confirmation prompt]' \
            '--yes[skip confirmation prompt]' \
            '--cluster-name=[cluster name]:name:' \
            '--no-config-cache[disable config caching]' \
            '--redirect-command-output[redirect command output to file]' \
            '--use-login-shells=[use login shells]:enabled:(true false)' \
            '-v[verbose]' \
            '--verbose[verbose]' \
            '1:cluster config:_files -g "*.{yaml,yml}"' \
            && ret=0
          ;;
        down)
          _arguments -s -S \
            '-y[skip confirmation prompt]' \
            '--yes[skip confirmation prompt]' \
            '--workers-only[only destroy worker nodes]' \
            '--cluster-name=[cluster name]:name:' \
            '--keep-min-workers[keep minimum worker count]' \
            '-v[verbose]' \
            '1:cluster config:_files -g "*.{yaml,yml}"' \
            && ret=0
          ;;
        job)
          _arguments -s -S \
            '1:subcommand:(submit status stop list logs)' \
            '--address=[Ray cluster address]:address:' \
            '*:: :->job_args' \
            && ret=0
          ;;
        submit)
          _arguments -s -S \
            '--address=[Ray cluster address]:address:' \
            '--job-id=[job ID]:ID:' \
            '--runtime-env=[runtime environment as JSON]:JSON:' \
            '--runtime-env-json=[runtime environment JSON]:JSON:' \
            '--working-dir=[working directory]:directory:_files -/' \
            '--no-wait[do not wait for the job to finish]' \
            '*:script and arguments:_files' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '-v[verbose]' \
            '--verbose[verbose]' \
            '*:files:_files' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_ray "$@"
