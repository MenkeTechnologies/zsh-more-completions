#compdef benchstat

# Zsh completion for benchstat - Go benchmark statistics tool

_arguments -s -S \
  '-alpha+[significance level (default 0.05)]:float' \
  '-csv[output as CSV]' \
  '-delta-test+[test for significance]:test:(utest ttest none)' \
  '-geomean[show geometric mean]' \
  '-html[output as HTML]' \
  '-norange[suppress range columns]' \
  '-sort+[sort order]:order:(none delta)' \
  '-split+[split benchmarks by labels]:labels' \
  '-filter+[filter benchmarks]:expression' \
  '-col+[column order]:expression' \
  '-row+[row grouping]:expression' \
  '-table+[table grouping]:expression' \
  '*:benchmark files:_files -g "*.txt"'
