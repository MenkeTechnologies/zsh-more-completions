#compdef benchstat
# Documentation: https://pkg.go.dev/golang.org/x/perf/cmd/benchstat
# Reference accessed: 2026-05-16
# Verified: golang.org/x/perf/cmd/benchstat current package docs.
# The modern benchstat has -filter/-table/-row/-col/-ignore only;
# the old options below (-alpha, -csv, -delta-test, -geomean, -html,
# -norange, -sort, -split) are from pre-2022 versions and no longer
# present.
# Removed from prior file: bogus man.archlinux.org search URL;
# legacy -alpha/-csv/-delta-test/-geomean/-html/-norange/-sort/-split.

# benchstat: Go benchmark statistics tool (modern API)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-filter=[filter expression]:expr:' \
  '-table=[table keys (default .config)]:keys:' \
  '-row=[row keys (default .fullname)]:keys:' \
  '-col=[col keys (default .file)]:keys:' \
  '-ignore=[ignored keys]:keys:' \
  '*:benchmark files (or label=path):_files' && ret=0
return ret
