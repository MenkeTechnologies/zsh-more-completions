#compdef tectonic

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  '--color[when to use color]:when:(auto always never)' \
  '1:command:->command' \
  '*::arg:->args' \
  && ret=0

case $state in
  command)
    local -a commands=(
      'build:build the document'
      'bundle:interact with Tectonic bundles'
      'compile:compile a standalone TeX document'
      'dump:dump internal information'
      'init:initialize a new Tectonic workspace'
      'new:create a new Tectonic workspace'
      'show:show various useful information'
      'watch:watch input files and rebuild on changes'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      compile)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '(-o --outdir)'{-o,--outdir}'[output directory]:directory:_directories' \
          '--outfmt[output format]:format:(pdf xdv aux html)' \
          '--makefile-rules[write Makefile rules]:file:_files' \
          '--bundle[use specified bundle]:bundle:_files' \
          '(-w --web-bundle)'{-w,--web-bundle}'[use specified web bundle]:URL' \
          '--only-cached[require all files to be cached]' \
          '--keep-intermediates[keep intermediate files]' \
          '--keep-logs[keep log files]' \
          '--synctex[generate SyncTeX data]' \
          '--untrusted[run in untrusted mode]' \
          '(-p --print)'{-p,--print}'[print output to stdout]:type' \
          '(-r --reruns)'{-r,--reruns}'[rerun count]:count' \
          '--hide[hide output from specified pass]:pass' \
          '--pass[only run specified pass]:pass:(default bibtex biber)' \
          '(-C --chatter)'{-C,--chatter}'[chatter level]:level:(default minimal)' \
          '*:TeX file:_files -g "*.tex"' \
          && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '--keep-intermediates[keep intermediate files]' \
          '--keep-logs[keep log files]' \
          '--only-cached[require all files to be cached]' \
          '--open[open output file after build]' \
          && ret=0
        ;;
      init|new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '1:project path:_directories' \
          && ret=0
        ;;
      watch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '-x[execute command on rebuild]:command' \
          && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
