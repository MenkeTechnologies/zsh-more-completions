#compdef pblat
# Documentation: https://genome.ucsc.edu/goldenPath/help/blatSpec.html
# pblat: parallelized BLAT, fast sequence-to-genome aligner

local ret=1

_arguments -s -S \
  '-t=[database type]:type:(dna prot dnax)' \
  '-q=[query type]:type:(dna rna prot rnax dnax)' \
  '-prot[protein database and query]' \
  '-ooc=[use overused tile file N.ooc]:ooc file:_files' \
  '-tileSize=[size of match that triggers an alignment]:n:' \
  '-stepSize=[spacing between tiles]:n:' \
  '-oneOff=[allow one mismatch in tile and still trigger alignment]:n:(0 1)' \
  '-minMatch=[number of tile matches]:n:' \
  '-minScore=[minimum score]:n:' \
  '-minIdentity=[minimum sequence identity in percent]:n:' \
  '-maxGap=[maximum gap between tiles in a clump]:n:' \
  '-noHead[suppress PSL header output]' \
  '-makeOoc=[create overused tile file for the target genome]:ooc file:_files' \
  '-repMatch=[repetitions of a tile allowed before marked overused]:n:' \
  '-mask=[mask out repeats]:type:(lower upper out file.out)' \
  '-qMask=[mask out repeats on query]:type:(lower upper out file.out)' \
  '-repeats=[report matches in repeat areas separately]:type:(lower upper out file.out)' \
  '-minRepDivergence=[minimum percent divergence of repeats to unmask]:n:' \
  '-dots=[output a dot every N query sequences]:n:' \
  '-trimT[trim leading poly-T]' \
  '-noTrimA[do not trim trailing poly-A]' \
  '-trimHardA[remove poly-A tail from qSize and psl output]' \
  '-fastMap[fast DNA/DNA remapping, no introns, high %ID]' \
  '-out=[output file format]:format:(psl pslx axt maf sim4 wublast blast blast8 blast9)' \
  '-fine[for high-quality mRNAs, look harder for small terminal exons]' \
  '-maxIntron=[maximum intron size]:n:' \
  '-extendThroughN[allow extension through large blocks of Ns]' \
  '-threads=[number of threads]:n:' \
  '1:database:_files' \
  '2:query:_files' \
  '3:output psl:_files' && ret=0

return ret
