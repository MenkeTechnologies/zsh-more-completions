#compdef setlock
# Documentation: https://man.archlinux.org/search?q=setlock
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-n[non-blocking]' \
  '-N[fail silently]' \
  '-x[no error on conflict]' \
  '-X[obtain exclusive lock]' \
  '1:lock file:_files' \
  '*::cmd:_command_names' && ret=0

return ret
