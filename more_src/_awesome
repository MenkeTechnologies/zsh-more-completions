#compdef awesome
# _awesome — Awesome WM Lua-configurable window manager binary (Awesome WM team, C/Lua); custom argparse
# upstream: https://github.com/awesomeWM/awesome

_awesome() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "rc.lua *.lua"' \
        '-c+[config file]:file:_files -g "rc.lua *.lua"' \
        '--check[parse syntax and exit]' \
        '-k[parse syntax and exit]' \
        '--no-argb[no ARGB visual]' \
        '-a[no ARGB visual]' \
        '--reap=+[reap orphans of pid]:pid:_pids' \
        '-r+[reap orphans of pid]:pid:_pids' \
        '--search=+[lua searcher dir]:dir:_files -/' \
        '-s+[lua searcher dir]:dir:_files -/' \
        '--screen=+[screen mode]:s:(on off)' \
        '--xrm=+[xrdb override]:str:' \
        '*:arg:'
}

_awesome "$@"
