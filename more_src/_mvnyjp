#compdef mvnyjp

local curcontext="$curcontext" state line ret=1

(( $+functions[_mvn] )) || autoload -Uz _mvn 2>/dev/null
if (( $+functions[_mvn] )); then
  _mvn "$@"
  return
fi

_arguments -s -S \
  {-X,--debug}'[produce execution debug output]' \
  {-e,--errors}'[produce execution error messages]' \
  {-q,--quiet}'[quiet output]' \
  {-o,--offline}'[work offline]' \
  '*-D+[define system property]:property=value:' \
  '*-P+[comma-separated profiles]:profiles:' \
  '-pl+[projects]:projects:' \
  '-am[also build dependent projects]' \
  '*::goal:' && ret=0

return ret
