#compdef croc-cli
# _croc-cli — Zack Scholl croc easy and secure file transfer between computers CLI alias (schollz team, Go); urfave/cli
# upstream: https://github.com/schollz/croc

_croc-cli() {
    local -a sub=(
        'send:send file or folder'
        'relay:start a relay'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--remember[remember settings]' \
        '--internal-dns[use internal DNS]' \
        '--classic[run in classic mode]' \
        '--ignore-stdin[ignore stdin]' \
        '--throttleUpload=+[rate]:str:' \
        '--out=+[output dir]:dir:_files -/' \
        '--code=+[code]:str:' \
        '--multi[multiple recipients]' \
        '--testing[testing mode]' \
        '--relay=+[relay address]:str:' \
        '--relay6=+[ipv6 relay address]:str:' \
        '--pass=+[password]:str:' \
        '--ports=+[ports csv]:str:' \
        '--no-compress[no compress]' \
        '--qrcode[show qr code]' \
        '-q[show qr code]' \
        '--curve=+[curve]:c:(p256 p384 p521 siec)' \
        '--ip=+[ip address]:str:' \
        '--throttleDownload=+[rate]:str:' \
        '--socks5=+[address]:str:' \
        '--connect=+[address]:str:' \
        '--yes[yes to all prompts]' \
        '-y[yes to all prompts]' \
        '--overwrite[overwrite without prompt]' \
        '--git[honor .gitignore]' \
        '--no-local[disable local discovery]' \
        '--no-multi[disable multi-mode]' \
        '--zip[zip folder]' \
        '--ask[ask to overwrite]' \
        '-a[ask to overwrite]' \
        '--text=+[send text]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'croc subcommand' sub ;;
        args)
            case $words[1] in
                send) _arguments \
                    '--code=+[code]:str:' \
                    '-c+[code]:str:' \
                    '--text=+[text]:str:' \
                    '--ports=+[ports]:str:' \
                    '--zip[zip folder]' \
                    '--no-compress[no compress]' \
                    '--hash=+[hash]:h:(xxhash imohash md5)' \
                    '--git[honor .gitignore]' \
                    '*:file or text:_files' ;;
                relay) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--ports=+[ports csv]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_croc-cli "$@"
