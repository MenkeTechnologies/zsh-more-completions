#compdef qmidinet
# _qmidinet — MIDI network gateway (ALSA + JACK over UDP/multicast) (rncbc/qmidinet)
# upstream: https://github.com/rncbc/qmidinet
# Flags from src/qmidinetOptions.cpp (QCommandLineParser).

_qmidinet() {
    _arguments \
        '(- *)'{-h,--help,-?}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-n --num-ports)'{-n+,--num-ports=}'[number of MIDI ports]:n:' \
        '(-i --interface)'{-i+,--interface=}'[network interface]:iface:' \
        '(-u --udp-addr)'{-u+,--udp-addr=}'[UDP/IP multicast address]:addr:' \
        '(-p --udp-port)'{-p+,--udp-port=}'[UDP/IP port]:port:' \
        '(-a --alsa-midi)'{-a+,--alsa-midi=}'[enable ALSA MIDI]:flag:(0 1 yes no on off)' \
        '(-j --jack-midi)'{-j+,--jack-midi=}'[enable JACK MIDI]:flag:(0 1 yes no on off)' \
        '(-g --no-gui)'{-g,--no-gui}'[disable the GUI]'
}

_qmidinet "$@"
