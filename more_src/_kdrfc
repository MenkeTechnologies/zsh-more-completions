#compdef kdrfc
# Documentation: https://github.com/cabo/kramdown-rfc/blob/master/bin/kdrfc
# Process kramdown-rfc Markdown into RFC XML/text/html/pdf

local ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-H --help)'{-H,--help}'[show option summary and exit]' \
  '(-v --verbose)'{-v,--verbose}'[run verbosely]' \
  '--no-verbose[do not run verbosely]' \
  '(-r --remote)'{-r,--remote}'[run xml2rfc remotely even if there is a local one]' \
  '--no-remote[do not run xml2rfc remotely]' \
  '(-x --xml)'{-x,--xml}'[convert to xml only]' \
  '--no-xml[do not convert to xml only]' \
  '(-p --prep)'{-p,--prep}'[convert xml to prepped xml]' \
  '--no-prep[do not convert xml to prepped xml]' \
  '(-P -f --pdf)'{-P,-f,--pdf}'[convert xml to PDF]' \
  '--no-pdf[do not convert xml to PDF]' \
  '(-c --convert)'{-c,--convert}'[convert xml to v3 xml]' \
  '--no-convert[do not convert xml to v3 xml]' \
  '(-i --idnits)'{-i,--idnits}'[run idnits on the resulting text]' \
  '--no-idnits[do not run idnits]' \
  '(-h --html)'{-h,--html}'[convert to html as well]' \
  '--no-html[do not convert to html]' \
  '(-t --txt)'{-t,--txt}'[convert to txt as well]' \
  '(-n --no-txt)'{-n,--no-txt}'[do not convert to txt]' \
  '(-3 --v3)'{-3,--v3}'[use RFCXML v3 processing rules]' \
  '(-2 --v2)'{-2,--v2}'[use RFCXML v2 processing rules]' \
  '--docrev=[replace -latest by -NN in docname]:NN' \
  '*:file:_files' && ret=0

return ret
