#compdef grdblend
# Documentation: https://docs.generic-mapping-tools.org/latest/grdblend.html
# Source: GenericMappingTools/gmt classic-mode grdblend — blend overlapping grids into one.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-C+[clobber mode (no blend)]:mode:(f l o u)' \
    '-Q[create headerless grid (raw output)]' \
    '-Z+[scale output values]:scale:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[output weights (append z for weight*z)]:opts:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-n+[grid interpolation mode]:mode:_default' \
    '-r[pixel registration (default gridline)]' \
    '*:blend file or input grid(s):_files -g "*.(grd|nc|tif|cdf|txt|lis)(-.)"' \
    && ret=0

return ret
