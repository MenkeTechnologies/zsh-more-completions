#compdef 3dDWItoDT
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dDWItoDT.html
# AFNI: compute diffusion tensor from diffusion-weighted images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-prefix[output dataset prefix]:pname:_files' \
  '-automask[create mask from input]' \
  '-mask[mask dataset]:dset:_files' \
  '-bmatrix_NZ[b-matrix file without zero rows]:file:_files' \
  '-bmatrix_Z[b-matrix file with zero rows]:file:_files' \
  '-bmatrix_FULL[full b-matrix file]:file:_files' \
  '-scale_out_1000[scale output diffusivities by 1000]' \
  '-bmax_ref[max b-value for reference image]:thr:' \
  '(-linear -nonlinear)-nonlinear[use nonlinear tensor fitting]' \
  '(-linear -nonlinear)-linear[use linear tensor fitting]' \
  '-reweight[use weighted least squares]' \
  '-max_iter[max nonlinear iterations]:n:' \
  '-max_iter_rw[max reweight iterations]:n:' \
  '-eigs[compute eigenvalues and eigenvectors]' \
  '-debug_briks[output extra debug sub-bricks]' \
  '-cumulative_wts[output cumulative weights]' \
  '-verbose[verbosity level]:nnnnn:' \
  '-drive_afni[drive AFNI to show progress]:nnnnn:' \
  '-sep_dsets[write output as separate datasets]' \
  '-csf_val[diffusivity value for CSF voxels]:n.nnn:' \
  '-min_bad_md[min mean diffusivity flagged as bad]:N:' \
  '-csf_fa[FA value assigned to CSF voxels]:n.nnn:' \
  '-opt[nonlinear optimization method]:mname:' \
  '-mean_b0[use mean of b=0 images]' \
  '*:dataset:_files' && ret=0

return ret
