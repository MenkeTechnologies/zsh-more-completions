#compdef aac-enc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-r+[bitrate]:bitrate:' \
  '-t+[audio object type]:aot:((2\:AAC-LC 5\:HE-AAC 29\:HE-AACv2 23\:AAC-LD 39\:AAC-ELD))' \
  '-a+[afterburner]:flag:(0 1)' \
  '-s+[SBR]:flag:(0 1)' \
  '-v+[VBR]:level:(1 2 3 4 5)' \
  '1:input:_files -g "*.wav"' \
  '2:output:_files -g "*.aac"' && ret=0

return ret
