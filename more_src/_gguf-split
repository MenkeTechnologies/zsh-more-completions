# Zsh completion for gguf-split - split/merge GGUF model files (llama.cpp)

_arguments \
  '--split[split GGUF into multiple files (default operation)]' \
  '--split-max-size[maximum size per split (e.g. 500M or 2G)]:size:' \
  '--split-max-tensors[maximum tensors per split (default 128)]:count:' \
  '--merge[merge multiple GGUF files into a single one]' \
  '*:file:_files -g "*.gguf"'
