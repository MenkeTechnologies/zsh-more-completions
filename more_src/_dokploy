#compdef dokploy

_dokploy() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '(-h --help)'{-h,--help}'[Display help for command]'
        '--json[Output the result in raw JSON format]'
    )

    subcmds=(
        'auth:Authenticate with your Dokploy server'
        'application:Manage applications'
        'project:Manage projects'
        'postgres:Manage Postgres databases'
        'mysql:Manage MySQL databases'
        'mongo:Manage MongoDB databases'
        'mariadb:Manage MariaDB databases'
        'redis:Manage Redis instances'
        'compose:Manage Docker Compose deployments'
        'domain:Manage domains and SSL'
        'environment:Manage project environments'
        'server:Server-level configurations'
        'update:Update the CLI to the latest version'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'dokploy commands' subcmds
            ;;
        args)
            case $line[1] in
                application)
                    local -a application_subcmds
                    application_subcmds=(
                        'all:List all applications'
                        'one:Get details for a specific application'
                        'create:Create a new application'
                        'deploy:Trigger a deployment'
                        'stop:Stop an application'
                        'delete:Delete an application'
                    )
                    _describe -t commands 'application subcommands' application_subcmds
                    ;;
                project)
                    local -a project_subcmds
                    project_subcmds=(
                        'all:List all projects'
                        'one:Get details for a specific project'
                        'create:Create a new project'
                        'delete:Delete a project'
                    )
                    _describe -t commands 'project subcommands' project_subcmds
                    ;;
                postgres|mysql|mongo|mariadb|redis)
                    local -a db_subcmds
                    db_subcmds=(
                        'all:List all database instances'
                        'one:Get details for a specific database'
                        'create:Create a new database instance'
                        'stop:Stop a database instance'
                        'delete:Delete a database instance'
                    )
                    _describe -t commands "$line[1] subcommands" db_subcmds
                    ;;
                auth)
                    _arguments \
                        '(-u --url)'{-u,--url}'[Dokploy server URL]:url:' \
                        '(-t --token)'{-t,--token}'[API Key]:token:'
                    ;;
            esac
            ;;
    esac
}

_dokploy "$@"
