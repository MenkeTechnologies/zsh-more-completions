#compdef wakelan
# Documentation: https://man.archlinux.org/search?q=wakelan
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a+[destination address]:addr:' \
  '-p+[destination port]:port:' \
  '*:mac_address:' && ret=0

return ret
