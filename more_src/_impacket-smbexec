#compdef impacket-smbexec

# Impacket smbexec.py: SMB-based command execution (no PSEXEC service)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-share[share to use]:share:' \
  '-mode[execution mode]:mode:(SERVER SHARE)' \
  '-codec[output encoding]:codec:' \
  '-shell-type[shell type]:type:(cmd powershell)' \
  '-service-name[service name on target]:name:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos auth]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-target-ip[target IP]:ip:' \
  '*:domain/user[:password]@host [command]:' && ret=0
return ret
