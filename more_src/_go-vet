#compdef go-vet
# _go-vet — go vet wrapper completion; runs go vet analyzers on packages
# upstream: https://pkg.go.dev/cmd/vet

_go-vet() {
    _arguments \
        '-n[print commands without running]' \
        '-x[print commands]' \
        '-vettool+[external vet tool]:tool:_files' \
        '-tags+[build tags]:tags:' \
        '-v[verbose]' \
        '-c+[surrounding code context lines]:n:' \
        '-flags[print available analyzer flags]' \
        '-json[json output]' \
        '*:packages:'
}

_go-vet "$@"
