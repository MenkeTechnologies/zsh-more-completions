#compdef mem_image
# Documentation: https://www.libraw.org/docs/Samples-LibRaw.html
# LibRaw sample: demonstrates dcraw_make_mem_image/dcraw_make_mem_thumb, output PPM

local ret=1

_arguments -s -S \
  '-6[output 16-bit PPM]' \
  '-4[linear 16-bit data, auto-brightness disabled]' \
  '-e[extract thumbnails from raw files]' \
  '-h[use half-size processing]' \
  '-j+[output JPEG with quality nn]:quality' \
  '*:RAW file:_files' && ret=0

return ret
