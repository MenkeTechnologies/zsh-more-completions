#compdef cpdf

# Zsh completion for cpdf - Coherent PDF command line tools

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-o[output file]:file:_files -g "*.pdf"' \
  '-merge[merge PDF files]' \
  '-split[split PDF into pages]' \
  '-split-bookmarks[split PDF at bookmarks]:level' \
  '-scale-page=[scale page by factor]:factor' \
  '-scale-to-fit=[scale page to fit]:dimensions (WxH)' \
  '-shift=[shift page content]:offset (dx dy)' \
  '-rotate=[rotate pages]:angle:(0 90 180 270)' \
  '-rotateby=[rotate pages by angle]:angle:(0 90 180 270)' \
  '-upright[make pages upright]' \
  '-hflip[flip pages horizontally]' \
  '-vflip[flip pages vertically]' \
  '-crop=[set crop box]:box (x y w h)' \
  '-trim=[set trim box]:box (x y w h)' \
  '-bleed=[set bleed box]:box (x y w h)' \
  '-art=[set art box]:box (x y w h)' \
  '-mediabox=[set media box]:box (x y w h)' \
  '-remove-crop[remove crop box]' \
  '-remove-trim[remove trim box]' \
  '-remove-bleed[remove bleed box]' \
  '-remove-art[remove art box]' \
  '-frombox=[copy from named box]:box:(media crop trim bleed art)' \
  '-tobox=[copy to named box]:box:(media crop trim bleed art)' \
  '-encrypt[encrypt the PDF]' \
  '-decrypt[decrypt the PDF]' \
  '-no-edit[disable editing permission]' \
  '-no-print[disable printing permission]' \
  '-no-copy[disable copying permission]' \
  '-no-annot[disable annotation permission]' \
  '-owner=[set owner password]:password' \
  '-user=[set user password]:password' \
  '-AES[use AES encryption]' \
  '-AES256[use AES-256 encryption]' \
  '-stamp-on=[stamp PDF on pages]:file:_files -g "*.pdf"' \
  '-stamp-under=[stamp PDF under pages]:file:_files -g "*.pdf"' \
  '-combine-pages=[combine two PDFs page by page]:file:_files -g "*.pdf"' \
  '-add-text=[add text to pages]:text' \
  '-font=[set font]:font' \
  '-font-size=[set font size]:size' \
  '-color=[set color]:color' \
  '-opacity=[set opacity]:opacity' \
  '-topleft=[position at top left]:offset (x y)' \
  '-topright=[position at top right]:offset (x y)' \
  '-midleft=[position at middle left]:offset (x y)' \
  '-center=[position at center]:offset (x y)' \
  '-midright=[position at middle right]:offset (x y)' \
  '-bottomleft=[position at bottom left]:offset (x y)' \
  '-bottomright=[position at bottom right]:offset (x y)' \
  '-add-bookmarks=[add bookmarks from file]:file:_files' \
  '-remove-bookmarks[remove all bookmarks]' \
  '-list-bookmarks[list all bookmarks]' \
  '-set-metadata=[set metadata from file]:file:_files -g "*.xml"' \
  '-remove-metadata[remove all metadata]' \
  '-print-metadata[print metadata]' \
  '-set-title=[set document title]:title' \
  '-set-author=[set document author]:author' \
  '-set-subject=[set document subject]:subject' \
  '-set-keywords=[set document keywords]:keywords' \
  '-set-creator=[set creator]:creator' \
  '-set-producer=[set producer]:producer' \
  '-info[show document info]' \
  '-pages[show page count]' \
  '-page-info[show page info]' \
  '-list-fonts[list fonts]' \
  '-attach-file=[attach file to PDF]:file:_files' \
  '-remove-files[remove attachments]' \
  '-list-attached-files[list attachments]' \
  '-extract-images[extract images]' \
  '-squeeze[optimize file size]' \
  '-linearize[linearize for fast web view]' \
  '-clean[clean and re-save the file]' \
  '-compress[compress streams]' \
  '-decompress[decompress streams]' \
  '-blacktext[make all text black]' \
  '-blacklines[make all lines black]' \
  '-blackfills[make all fills black]' \
  '-thinlines=[set minimum line width]:width' \
  '-remove-clipping[remove clipping]' \
  '-draft[replace images with boxes]' \
  '-remove-all-text[remove all text]' \
  '-json[output in JSON format]' \
  '-utf8[use UTF-8 encoding]' \
  '*:PDF file:_files -g "*.pdf"'
