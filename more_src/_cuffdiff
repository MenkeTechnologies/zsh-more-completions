#compdef cuffdiff

# Cuffdiff: differential expression / splicing analysis
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '-h[help]' \
  '(-o --output-dir)'{-o,--output-dir=}'[output directory]:dir:_files -/' \
  '(-p --num-threads)'{-p,--num-threads=}'[threads]:n:' \
  '(-L --labels)'{-L,--labels=}'[condition labels, comma-separated]:labels:' \
  '(-M --mask-file)'{-M,--mask-file=}'[mask GTF]:file:_files' \
  '(-b --frag-bias-correct)'{-b,--frag-bias-correct=}'[bias correction FASTA]:file:_files' \
  '(-u --multi-read-correct)'{-u,--multi-read-correct}'[multi-mapped correction]' \
  '--library-type=[library type]:type:(ff-firststrand ff-secondstrand ff-unstranded fr-unstranded fr-firststrand fr-secondstrand transfrags)' \
  '--library-norm-method=[library normalization]:method:(classic-fpkm geometric quartile)' \
  '--FDR=[false discovery rate]:val:' \
  '(-c --min-alignment-count)'{-c,--min-alignment-count=}'[minimum alignment count]:n:' \
  '--upper-quartile-norm[upper-quartile normalization]' \
  '--total-hits-norm[total hits normalization]' \
  '--compatible-hits-norm[compatible hits normalization]' \
  '--no-update-check[skip update check]' \
  '--num-frag-count-draws=[count posterior draws]:n:' \
  '--num-frag-assign-draws=[assign posterior draws]:n:' \
  '--max-frag-multihits=[max multihits per fragment]:n:' \
  '*:GTF file and condition BAMs:_files' && ret=0
return ret
