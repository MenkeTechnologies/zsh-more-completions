#compdef sendgrid sendgrid-cli

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-k --api-key)'{-k+,--api-key=}'[API key]:k:' \
  '(-f --from)'{-f+,--from=}'[from address]:addr:' \
  '(-t --to)*'{-t+,--to=}'[to address]:addr:' \
  '(-c --cc)*'{-c+,--cc=}'[cc address]:addr:' \
  '(-b --bcc)*'{-b+,--bcc=}'[bcc address]:addr:' \
  '(--from-name)--from-name=[from name]:n:' \
  '(--reply-to)--reply-to=[reply to]:addr:' \
  '(-s --subject)'{-s+,--subject=}'[subject]:s:' \
  '(--text)--text=[plain text]:t:' \
  '(--html)--html=[HTML]:h:' \
  '(-T --template)'{-T+,--template=}'[template ID]:id:' \
  '(--template-data)--template-data=[template data JSON]:json:' \
  '(-a --attachment)*'{-a+,--attachment=}'[attachment]:file:_files' \
  '(--send-at)--send-at=[send at unix]:t:' \
  '(--categories)--categories=[categories csv]:list:' \
  '(--mail-settings)--mail-settings=[mail settings JSON]:s:' \
  '(--tracking-settings)--tracking-settings=[tracking settings JSON]:s:' \
  '(--sandbox)--sandbox[sandbox mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(--dry-run)--dry-run[dry run]' \
  '*: :_files' && ret=0

return ret
