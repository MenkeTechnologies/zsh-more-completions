#compdef uvfit
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvfit.html
# MIRIAD uvfit - fit source components to visibility data

local ret=1

_arguments -s -S \
  'vis=[input visibility file name]:vis:_files' \
  'stokes=[polarization parameter (single)]:stokes' \
  'line=[line-type processing]:line' \
  'select=[data selection criteria]:select' \
  'object=[component type(s) to fit]:object:(point disk gaussian shell ring)' \
  'spar=[initial parameter estimates per object]:spar' \
  'bin=[frequency and time binning]:bin' \
  'fix=[parameters held constant (f,x,y,a,b,p,c,-)]:fix' \
  'fix2=[fixed parameters after initial fit]:fix2' \
  'out=[output model or residual visibilities]:out:_files' \
  'options=[residual]:options' \
  '*:visibility data:_files' && ret=0

return ret
