#compdef krunner

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--clipboard[run with clipboard contents as query]' \
  '--replace[replace existing instance]' \
  '--daemon[daemon mode]' \
  '--help-all[show all options including Qt]' \
  '--display=[X display]:display:' \
  '*:query:' && ret=0

return ret
