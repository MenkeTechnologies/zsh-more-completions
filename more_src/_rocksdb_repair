#compdef rocksdb_repair
# Documentation: https://man.archlinux.org/search?q=rocksdb_repair
# Reference accessed: 2026-05-16

# rocksdb_repair: try to repair a corrupted RocksDB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--db=[database directory]:dir:_files -/' \
  '--verbose[verbose]' \
  '*:directory:_files -/' && ret=0
return ret
