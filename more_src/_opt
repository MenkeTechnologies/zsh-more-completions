#compdef opt
# _opt — LLVM optimizer (LLVM project, C++); run analysis + transformation passes on LLVM bitcode/IR
# upstream: https://github.com/llvm/llvm-project

_opt() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-f[force overwrite]' \
        '-S[output LLVM IR]' \
        '-o+[output file]:file:_files' \
        '-disable-output[no output]' \
        '-passes=+[pass pipeline]:str:' \
        '-print-passes[print passes]' \
        '-print-before=+[print IR before pass]:pass:' \
        '-print-after=+[print IR after pass]:pass:' \
        '-print-before-all[print IR before each]' \
        '-print-after-all[print IR after each]' \
        '-print-module-scope[print module scope]' \
        '-debug[debug]' \
        '-debug-pass=+[debug pass]:val:(None Arguments Structure Executions Details)' \
        '-stats[print stats]' \
        '-time-passes[time passes]' \
        '-cl-opt=+[OpenCL opt level]:n:' \
        '-O0[no optimization]' \
        '-O1[optimization 1]' \
        '-O2[optimization 2]' \
        '-O3[optimization 3]' \
        '-Os[optimize for size]' \
        '-Oz[optimize for size aggressively]' \
        '-mcpu=+[cpu]:cpu:' \
        '-mtriple=+[triple]:triple:' \
        '-mattr=+[mattr]:str:' \
        '-disable-loop-unrolling[disable loop unrolling]' \
        '-disable-loop-idiom[disable loop idiom]' \
        '-disable-promote-alloca-to-vector[disable promote alloca to vector]' \
        '-pass-remarks=+[pass remarks regex]:regex:' \
        '-pass-remarks-missed=+[missed pass remarks regex]:regex:' \
        '-pass-remarks-analysis=+[analysis pass remarks regex]:regex:' \
        '-pass-remarks-output=+[remarks output]:file:_files' \
        '-pass-remarks-format=+[remarks format]:fmt:(bitstream yaml)' \
        '-load=+[load plugin]:file:_files' \
        '-load-pass-plugin=+[load pass plugin]:file:_files' \
        '-print-after-pass=+[print IR after pass]:pass:' \
        '-print-cse-prefix=+[CSE prefix]:str:' \
        '*:file:_files -g "*.(bc|ll)"'
}

_opt "$@"
