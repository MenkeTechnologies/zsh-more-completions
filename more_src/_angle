#compdef angle gmx-angle
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-angle.html
# Compute angle and dihedral distributions from trajectories

local ret=1

_arguments -s -S \
  '-f+[trajectory input]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-n+[index file specifying atom groups]:index file:_files -g "*.ndx"' \
  '-od+[output angle distribution]:xvg file:_files -g "*.xvg"' \
  '-ov+[output average angles vs time]:xvg file:_files -g "*.xvg"' \
  '-of+[output trans dihedral fraction vs time]:xvg file:_files -g "*.xvg"' \
  '-ot+[output dihedral transition times]:xvg file:_files -g "*.xvg"' \
  '-oh+[output histogram of transition intervals]:xvg file:_files -g "*.xvg"' \
  '-oc+[output dihedral correlation function]:xvg file:_files -g "*.xvg"' \
  '-or+[output trajectory with cos/sin of dihedrals]:trr file:_files -g "*.trr"' \
  '-b+[starting time ps]:time:' \
  '-e+[ending time ps]:time:' \
  '-dt+[frame sampling interval ps]:time:' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-type+[angle type]:type:(angle dihedral improper ryckaert-bellemans)' \
  '-binwidth+[distribution bin width degrees]:value:' \
  '-acflen+[autocorrelation function length]:n:' \
  '-P+[Legendre polynomial order]:order:(0 1 2 3)' \
  '-fitfn+[fitting function type]:fn:(none exp aexp exp_exp exp5 exp7 exp9)' \
  '-beginfit+[exponential fit start time]:time:' \
  '-endfit+[exponential fit end time]:time:' \
  '-w[view output files]' \
  '-all[plot individual angles separately]' \
  '-periodic[wrap dihedrals to +/-180]' \
  '-chandler[use Chandler correlation function]' \
  '-avercorr[average correlation across angles]' \
  '-normalize[normalize autocorrelation function]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
