#compdef rabbitmq-diagnostics
# Documentation: https://man.archlinux.org/search?q=rabbitmq-diagnostics
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:show usage'
  'version:CLI tools version'
  'wait:wait for node readiness'
  'cluster_status:cluster membership and status'
  'list_users:enumerate users'
  'list_permissions:user permissions'
  'list_topic_permissions:topic permissions'
  'list_user_permissions:user permissions'
  'list_user_topic_permissions:user topic permissions'
  'list_vhosts:list virtual hosts'
  'alarms:active resource alarms'
  'certificates:TLS certificates for listeners'
  'check_alarms:verify no cluster alarms'
  'check_certificate_expiration:validate cert expiry'
  'check_local_alarms:verify no node alarms'
  'check_port_connectivity:test TCP listener'
  'check_port_listener:confirm port listening'
  'check_protocol_listener:verify protocol listener'
  'check_running:confirm app active'
  'check_virtual_hosts:validate vhosts'
  'cipher_suites:TLS cipher suites'
  'command_line_arguments:node runtime arguments'
  'consume_event_stream:stream internal events'
  'discover_peers:run peer discovery'
  'environment:env config'
  'erlang_cookie_hash:auth secret hash'
  'erlang_version:Erlang version'
  'is_booting:check if initializing'
  'is_running:check if operational'
  'list_bindings:queue bindings'
  'list_channels:active channels'
  'list_ciphers:available ciphers'
  'list_connections:active connections'
  'list_consumers:message consumers'
  'list_exchanges:exchanges'
  'list_hashes:hash algorithms'
  'list_queues:enumerate queues'
  'list_unresponsive_queues:stuck queues'
  'listeners:bound sockets/protocols'
  'log_tail:recent log lines'
  'log_tail_stream:stream logs'
  'maybe_stuck:sample Erlang stack traces'
  'memory_breakdown:memory usage breakdown'
  'observer:launch CLI observer'
  'ping:connectivity test'
  'report:diagnostic report'
  'runtime_thread_stats:sample thread activity'
  'schema_info:schema info'
  'server_version:RabbitMQ version'
  'status:node status'
  'tls_versions:supported TLS versions'
  'list_global_parameters:cluster-wide parameters'
  'list_parameters:vhost parameters'
  'list_operator_policies:operator policies'
  'list_policies:queue/exchange policies'
  'list_vhost_limits:resource limits'
  'log_location:log file paths'
  'list_feature_flags:feature flags'
  'quorum_status:quorum queue health'
  'check_if_cluster_has_classic_queue_mirroring_policy:detect mirroring'
  'check_if_node_is_quorum_critical:is node quorum-critical'
)

_arguments -C \
  '(-q --quiet)'{-q,--quiet}'[reduce messages]' \
  '(-s --silent)'{-s,--silent}'[suppress messages]' \
  '-n+[node name]:node:' \
  '(-t --timeout)'{-t,--timeout=}'[timeout secs]:secs:' \
  '(-l --longnames)'{-l,--longnames}'[FQDN node names]' \
  '--erlang-cookie=[shared secret]:cookie:' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rabbitmq-diagnostics subcommand' subcommands && ret=0
    ;;
esac

return ret
