#compdef surfer
# _surfer — Surfer Project surfer modern extensible WebAssembly-aware waveform viewer for VCD FST GHW (surfer-project team, Rust); clap-derive
# upstream: https://gitlab.com/surfer-project/surfer

_surfer() {
    local -a sub=(
        'server:start Surfer remote server'
        'wcp:Wave Communication Protocol session'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--state-file=+[state file]:file:_files -g "*.json *.surf *.ron"' \
        '-s+[state file]:file:_files -g "*.json *.surf *.ron"' \
        '--command-file=+[command file]:file:_files' \
        '-c+[command file]:file:_files' \
        '--wcp-port=+[port]:port:_ports' \
        '--wcp-host=+[host]:host:_hosts' \
        '--wcp-no-block[no block]' \
        '--variable-format=+[format]:f:(Hex Octal Binary Unsigned Signed FloatingPoint ASCII Group)' \
        '--variable-name-style=+[style]:s:(Full Last)' \
        '--time-precision=+[precision]:str:' \
        '--time-format=+[format]:f:(ScientificNotation Auto)' \
        '--clock-highlight-type=+[type]:t:(None Cycle Line)' \
        '--hierarchy-style=+[style]:s:(Separate Sub)' \
        '--theme=+[theme]:t:(light dark dynamic)' \
        '--start-tick=+[N]:n:' \
        '--end-tick=+[N]:n:' \
        '--alphabetize-signals[alphabetize signals]' \
        '--no-progress[no progress bar]' \
        '--log-level=+[level]:l:(trace debug info warn error off)' \
        '--log-file=+[log file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'surfer subcommand' sub ;;
        args)
            case $words[1] in
                server) _arguments \
                    '--port=+[port]:port:_ports' \
                    '--host=+[host]:host:_hosts' \
                    '--token=+[token]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
            esac
            ;;
    esac
}

_surfer "$@"
