#compdef lasboundary
# LAStools: compute a boundary polygon (concave/convex hull) of LAS/LAZ points

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[report tool version]' \
  '-gui[launch with GUI]' \
  '-demo[run in demo mode]' \
  '-concavity+[granularity for concave hull (default 50)]:meters' \
  '-convex[compute convex hull instead of concave]' \
  '-disjoint[allow polygon to fragment into separate hulls]' \
  '-holes[find and output interior holes]' \
  '-use_bb[use rectangular bounding box as boundary]' \
  '-use_lax[approximate boundary from LAX spatial index]' \
  '-use_tile_bb[use tile bounding box for boundary]' \
  '-labels[add labels with file info and point counts]' \
  '-overview[combine multiple outputs into single file]' \
  '-utm+[UTM projection zone for georeferencing]:zone' \
  '-sp83+[State Plane NAD83 projection]:state' \
  '*-i+[input file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-merged[merge multiple input files]' \
  '-o+[output file]:output:_files' \
  '-oshp[export as ESRI shapefile]' \
  '-okml[export as KML]' \
  '-owkt[export as well-known-text]' \
  '-otxt[export as ASCII text]' \
  '-cores+[process on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
