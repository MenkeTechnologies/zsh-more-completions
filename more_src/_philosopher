#compdef philosopher
# Documentation: https://github.com/Nesvilab/philosopher/wiki/Philosopher-Basics
# Philosopher proteomics toolkit (FragPipe backend).

local ret=1
local context state line
typeset -A opt_args

_philosopher_cmds=(
  'workspace:initialize or manage the analysis workspace'
  'database:format and annotate a protein sequence database'
  'peptideprophet:peptide assignment validation (PeptideProphet)'
  'iprophet:combine evidence across searches (iProphet)'
  'proteinprophet:protein inference and validation (ProteinProphet)'
  'ptmprophet:localize post-translational modifications (PTMProphet)'
  'filter:statistical filtering, validation and FDR estimation'
  'freequant:label-free MS1 quantification'
  'labelquant:isobaric label-based quantification'
  'bioquant:cluster-based protein quantification'
  'abacus:combine results into a multi-experiment report'
  'report:generate tabular reports from filtered results'
  'pipeline:run a full analysis pipeline from a config file'
  'slack:send a notification to Slack'
  'version:print the version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'philosopher command' _philosopher_cmds && ret=0
    ;;
  args)
    case $line[1] in
      workspace)
        _arguments -s \
          '--init[initialize the workspace in this directory]' \
          '--clean[remove the workspace and all metadata]' \
          '--backup[create a .zip backup of experiment metadata]' \
          '--analytics[report workspace creation for usage estimation]' \
          '--temp=[custom temporary folder]:dir:_files -/' && ret=0
        ;;
      filter)
        _arguments -s \
          '--pepxml=[path to pepXML file or directory]:path:_files' \
          '--protxml=[path to protXML file]:file:_files' \
          '--psm=[PSM FDR level]:level' \
          '--pep=[peptide FDR level]:level' \
          '--ion=[peptide ion FDR level]:level' \
          '--prot=[protein FDR level]:level' \
          '--pepProb=[peptide probability threshold]:prob' \
          '--protProb=[protein probability threshold]:prob' \
          '--razor[use razor peptides for protein FDR scoring]' \
          '--picked[apply picked FDR algorithm]' \
          '--sequential[sequential FDR estimation algorithm]' \
          '--cappedsequential[capped sequential FDR algorithm]' \
          '--mapmods[map modifications]' \
          '--models[print model distribution for analyzed pepXML]' \
          '--tag=[decoy prefix on decoy sequences]:prefix' \
          '--weight=[threshold for peptide uniqueness]:weight' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
