#compdef aconvolve
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/aconvolve.html
# Convolve an N-dimensional image with a kernel

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input image file]:file:_files' \
  'outfile=[output image file]:file:_files' \
  'kernelspec=[kernel specification]:kernelspec:' \
  'writekernel=[output kernel to an image]:writekernel:(yes no)' \
  'kernelfile=[file name for kernel image]:file:_files' \
  'writefft=[output FFT of data and kernel]:writefft:(yes no)' \
  'fftroot=[root file name for FFT output files]:root:' \
  'method=[convolution method]:method:(slide fft)' \
  'edges=[how to handle edges]:edges:(wrap nearest mirror constant renorm)' \
  'const=[constant value to use at edges]:const:' \
  'pad=[pad data to the next integer power of 2]:pad:(yes no)' \
  'center=[center FFT output]:center:(yes no)' \
  'normkernel=[normalize the kernel]:normkernel:(yes no)' \
  'clobber=[clobber existing output]:clobber:(yes no)' \
  'verbose=[verbosity level]:verbose:(0 1 2 3 4 5)' && ret=0

return ret
