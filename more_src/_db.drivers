#compdef db.drivers
# Documentation: https://grass.osgeo.org/grass-stable/manuals/db.drivers.html
# GRASS GIS: list all database drivers

local ret=1

_arguments -s -S \
  '--help[print usage summary]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  '--ui[force launching GUI dialog]' \
  '-f[full output]' \
  '-p[print drivers and exit]' && ret=0

return ret
