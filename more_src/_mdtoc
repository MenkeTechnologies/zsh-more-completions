#compdef mdtoc
# Documentation: https://man.archlinux.org/search?q=mdtoc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--inplace[edit in place]' \
  '--max-depth=+[max heading depth]:n:(1 2 3 4 5 6)' \
  '--min-depth=+[min heading depth]:n:(1 2 3 4 5 6)' \
  '--toc=+[toc placeholder]:marker:' \
  '--header=+[header text]:text:' \
  '*:markdown:_files -g "*.{md,markdown}"' && ret=0

return ret
