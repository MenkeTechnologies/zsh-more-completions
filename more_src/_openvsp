#compdef openvsp
# Documentation: https://man.archlinux.org/search?q=openvsp
# Reference accessed: 2026-05-16

# OpenVSP: NASA Vehicle Sketch Pad - parametric aircraft geometry
local curcontext="$curcontext" ret=1
_arguments -C \
  '-script[run a VSPaero / Angelscript file at startup]:file:_files -g "*.(vsppro|vspscript)"' \
  '-noweld[do not weld solid model after loading]' \
  '-batch[batch mode without GUI]' \
  '-makeAirfoilLib[regenerate airfoil library from VSP_AIRFOIL_DIR]' \
  '-version[show version]' \
  '*:VSP file:_files -g "*.(vsp3|vsp|vspaero|cgns)"' && ret=0
return ret
