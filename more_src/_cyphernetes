#compdef cyphernetes
# Documentation: https://github.com/AvitalTamir/cyphernetes
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cyphernetes: Cypher-style query language for Kubernetes

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'web:launch web client interface at http://localhost:8080'
  'shell:start interactive shell for executing queries'
  'query:execute a single query from command line'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'cyphernetes subcommand' subcommands && ret=0
    ;;
esac

return ret
