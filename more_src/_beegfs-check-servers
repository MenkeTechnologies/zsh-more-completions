#compdef beegfs-check-servers
# Documentation: https://man.archlinux.org/search?q=beegfs-check-servers
# Reference accessed: 2026-05-16

# beegfs-check-servers: list reachable BeeGFS servers
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*::beegfs-check-servers args:_files' && ret=0
return ret
