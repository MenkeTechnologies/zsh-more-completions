#compdef RNAmultifold
# RNAmultifold — compute secondary structures of multiple interacting RNAs (ViennaRNA)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--detailed-help[print help with all details and hidden options]' \
  '--full-help[print help including hidden options]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-j --jobs)'{-j,--jobs}'=[number of parallel jobs (0 for auto)]::number' \
  '--unordered[do not assume a fixed order of input sequences]' \
  '--noconv[do not substitute nucleotide T with U]' \
  '--auto-id[automatically generate an ID for each sequence]' \
  '--id-prefix=[prefix for automatically generated IDs]:prefix' \
  '--id-delim=[delimiter for automatically generated IDs]:char' \
  '--id-digits=[number of digits for automatically generated IDs]:digits' \
  '--id-start=[start number for automatically generated IDs]:start' \
  '--filename-delim=[filename delimiter character]:char' \
  '--filename-full[use full sequence ID for filenames]' \
  '--log-level=[set log level threshold]:level' \
  '--log-file=[print log messages to file]::file:_files' \
  '--log-time[include timestamp in log messages]' \
  '--log-call[include file and line of logging function]' \
  '(-p --partfunc)'{-p,--partfunc}'=[calculate partition function]::int' \
  '(-a --all_pf)'{-a,--all_pf}'=[compute partition functions for all complexes]::int' \
  '(-c --concentrations)'{-c,--concentrations}'[compute equilibrium concentrations]' \
  '(-f --concfile)'{-f,--concfile}'=[file with concentration dependencies]:file:_files' \
  '--absolute-concentrations[interpret concentrations as absolute values]' \
  '--betaScale=[scaling of Boltzmann factors]:double' \
  '(-S --pfScale)'{-S,--pfScale}'=[scale factor for partition function]:double' \
  '--bppmThreshold=[base pair probability cutoff]:cutoff' \
  '(-g --gquad)'{-g,--gquad}'[incorporate G-quadruplex formation]' \
  '--maxBPspan=[maximum base pair span]:int' \
  '--commands=[read additional commands from file]:file:_files' \
  '(-T --temp)'{-T,--temp}'=[rescale energy parameters to temperature in C]:double' \
  '(-P --paramFile)'{-P,--paramFile}'=[read energy parameters from file]:file:_files' \
  '(-4 --noTetra)'{-4,--noTetra}'[exclude stabilizing energies for tetra-loop hairpins]' \
  '--salt=[set salt concentration in molar]:double' \
  '(-d --dangles)'{-d,--dangles}'=[treat dangling end energies]:mode:(0 1 2 3)' \
  '--noLP[produce structures without lonely pairs]' \
  '--noGU[disallow GU pairs]' \
  '--noClosingGU[disallow GU pairs at helix ends]' \
  '--nsp=[allow additional non-standard pairs]:pairs' \
  '--energyModel=[set energy model]:model' \
  '--helical-rise=[set helical rise in Angstrom]:float' \
  '--backbone-length=[set backbone length in Angstrom]:float' && ret=0

return ret
