#compdef vimpc
# Documentation: https://www.gsp.com/cgi-bin/man.cgi?section=1&topic=vimpc
# vi/vim inspired ncurses client for the Music Player Daemon (mpd)

local ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[print the version of vimpc]' \
  '(-h --host)'{-h,--host}'[connect to MPD on hostname or unix socket]:host:_hosts' \
  '(-p --port)'{-p,--port}'[port to connect to mpd]:port:_ports' && ret=0

return ret
