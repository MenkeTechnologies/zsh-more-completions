#compdef murex
# Documentation: https://github.com/lmorg/murex/blob/master/flags.go
# Reference accessed: 2026-05-19
# Verified: upstream flags.go readFlags() source at the URL above.

# Zsh completion for murex - smarter shell and scripting environment

_arguments -s \
  '-i[start interactive shell after -c execution]' \
  '-c[run code block]:command:' \
  '--execute[execute a command from tokenized parameters]' \
  '--setsid[set session ID for POSIX job-control compatibility]' \
  '--load-modules[load modules and profile when non-interactive]' \
  '-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '--debug[debug mode]' \
  '--run-tests[run all tests and exit]' \
  '--echo[echo on]' \
  '--murex[reserved]' \
  '--quiet[suppress profile/module load messages]' \
  '--ignore-whatsnew[suppress one-time what'\''s-new message]' \
  '--try[enable global try block]' \
  '--trypipe[enable global trypipe block]' \
  '--tryerr[enable global tryerr block]' \
  '--trypipeerr[enable global trypipeerr block]' \
  '*:script file:_files'
