#compdef murex

# Zsh completion for murex - Murex shell

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c[execute command string]:command:' \
  '--load-modules[load modules on startup]' \
  '--no-load-modules[do not load modules on startup]' \
  '--safe-commands[only run safe commands]' \
  '--tty[force TTY mode]' \
  '--no-tty[disable TTY mode]' \
  '--run-tests[run unit tests]' \
  '*:script file:_files -g "*.mx"'
