#compdef las2tin
# LAStools: triangulate LAS/LAZ points into a TIN

local ret=1

_arguments -s -S \
  '-help[display help]' \
  '-version[display version information]' \
  '-gui[launch with GUI]' \
  '-demo[run in demo mode]' \
  '-first_only[triangulate only first return points]' \
  '-last_only[triangulate only last return points]' \
  '*-keep_class+[include only points with classification]:code' \
  '-concavity+[remove large boundary triangles (default 50)]:units' \
  '-kill+[remove interior triangles with edges >= n meters]:meters' \
  '-histo_edge_length+[edge length histogram with bin size]:n' \
  '-histo_min_edge_length+[minimum edge length histogram]:n' \
  '-histo_max_edge_length+[maximum edge length histogram]:n' \
  '-histo_only[output histogram only, skip TIN]' \
  '-lakes+[enforce closed polygons from file]:file:_files' \
  '-creeks+[integrate hard breaklines from file]:file:_files' \
  '*-i+[input file(s) or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-merged[combine multiple input files]' \
  '-o+[output file]:output:_files' \
  '-oshp[output as ESRI shapefile]' \
  '-oobj[output as OBJ]' \
  '-odxf[output as CAD DXF]' \
  '-otxt[output as ASCII text]' \
  '-cores+[process inputs on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
