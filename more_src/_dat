#compdef dat
# Peer-to-peer file sharing protocol CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'clone:download a dat archive'
      'create:create a new dat archive'
      'doctor:run diagnostics'
      'keys:print dat keys'
      'log:show history'
      'pull:pull updates from a remote dat'
      'push:sync local changes to a remote dat'
      'satoshi:show dat donation address'
      'share:start sharing a dat archive'
      'status:show dat archive status'
      'sync:sync a dat archive'
    )
    _describe -t commands 'dat command' commands && ret=0
    ;;
  args)
    _arguments \
      '--temp[use a temporary directory]' \
      '--sparse[enable sparse download]' \
      '--empty[create an empty archive]' \
      '--utp[use UTP for connections]' \
      '*:path:_files' && ret=0
    ;;
esac

return ret
