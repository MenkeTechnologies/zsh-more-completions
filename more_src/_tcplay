#compdef tcplay
# Documentation: https://man.archlinux.org/search?q=tcplay
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --create)'{-c,--create}'[create new TC volume]' \
  '(-i --info)'{-i,--info}'[show TC volume info]' \
  '(-j --info-mapped)'{-j,--info-mapped}'+[show mapped volume info]:mapname:' \
  '(-f --device)'{-f,--device}'+[device file]:dev:_files' \
  '(-m --map)'{-m,--map}'+[map to dm name]:mapname:' \
  '(-u --unmap)'{-u,--unmap}'+[unmap dm name]:mapname:' \
  '(-l --modify)'{-l,--modify}'[modify volume]' \
  '(-e --protect-hidden)'{-e,--protect-hidden}'[protect hidden volume]' \
  '(-x --pbkdf-prf)'{-x,--pbkdf-prf}'+[outer PRF hash]:hash:(RIPEMD160 SHA512 whirlpool SHA256 streebog)' \
  '(-y --pbkdf-prf-hidden)'{-y,--pbkdf-prf-hidden}'+[hidden PRF hash]:hash:(RIPEMD160 SHA512 whirlpool SHA256 streebog)' \
  '(-a --cipher)'{-a,--cipher}'+[outer cipher chain]:cipher:(AES-128-XTS TWOFISH-128-XTS SERPENT-128-XTS AES-256-XTS TWOFISH-256-XTS SERPENT-256-XTS)' \
  '(-A --cipher-hidden)'{-A,--cipher-hidden}'+[hidden cipher chain]:cipher:' \
  '(-z --backup)'{-z,--backup}'[backup headers]' \
  '(-r --restore)'{-r,--restore}'[restore headers]' \
  '(-g --hidden)'{-g,--hidden}'[create hidden volume]' \
  '(-b --backup-hdr)'{-b,--backup-hdr}'+[header backup file]:file:_files' \
  '(-k --keyfile)'{-k,--keyfile}'+[key file]:file:_files' \
  '(-K --keyfile-hidden)'{-K,--keyfile-hidden}'+[hidden key file]:file:_files' \
  '(-d --no-retries)'{-d,--no-retries}'[do not retry on bad password]' \
  '(-w --weak)'{-w,--weak}'[use weak password (testing only)]' \
  '(-F --header)'{-F,--header}'+[header file]:file:_files' \
  '(-G --use-backup)'{-G,--use-backup}'[use backup header]' \
  '(-t --truecrypt)'{-t,--truecrypt}'[use TrueCrypt compatibility]' \
  '(-T --veracrypt)'{-T,--veracrypt}'[use VeraCrypt compatibility]' \
  '(-I --iter)'{-I,--iter}'+[VeraCrypt PBKDF iteration count]:n:' && ret=0

return ret
