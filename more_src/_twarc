#compdef twarc twarc2
# Documentation: https://twarc-project.readthedocs.io/
# Reference accessed: 2026-05-21
# Verified: twarc-project.readthedocs.io twarc2 top-level command listing.
# Removed prior fake commands (replies, jobs); added verified twarc2 commands.

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--verbose[debug logging]' \
  '--consumer-key=[Twitter consumer key]:key:' \
  '--consumer-secret=[Twitter consumer secret]:secret:' \
  '--access-token=[Twitter access token]:token:' \
  '--access-token-secret=[Twitter access token secret]:secret:' \
  '--bearer-token=[Twitter bearer token]:token:' \
  '--app-auth[use OAuth1 app credentials]' \
  '--user-auth[use user credentials]' \
  '(-l --log)'{-l,--log}'=[log file]:file:_files' \
  '--metadata[include metadata]' \
  '--no-metadata[exclude metadata]' \
  '--config=[config file]:file:_files' \
  '1:command:(configure search searches stream sample timeline timelines conversation conversations users user followers following liked-tweets liking-users retweeted-by quotes mentions tweet dehydrate hydrate flatten places counts compliance-job lists stream-rules version)' \
  '*::arguments:_default'
