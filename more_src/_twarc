#compdef twarc

# https://github.com/DocNow/twarc — click CLI (`twarc2 --help`; formula installs as twarc)
_arguments -s -S \
  '--help[help]' \
  '--version[version]' \
  '--verbose[debug logging]' \
  '--app-auth[OAuth1 app credentials]' \
  '1:command:(configure replies mentions timeline following followers users search dehydrate stream jobs)' \
  '*::arguments:_default'
