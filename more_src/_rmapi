#compdef rmapi

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'put:upload a file to the reMarkable cloud'
  'mput:upload multiple files'
  'get:download a file from the reMarkable cloud'
  'mget:download multiple files'
  'ls:list files and directories'
  'mkdir:create a directory'
  'mv:move a file or directory'
  'cp:copy a file or directory'
  'rm:delete a file or directory'
  'find:find files by name'
  'stat:display file metadata'
  'geta:download a file with annotations'
  'version:print version information'
  'help:display help information'
  'env:display environment variables'
  'quit:exit the interactive shell'
  'exit:exit the interactive shell'
)

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' \
  '(-ni --non-interactive)'{-ni,--non-interactive}'[run in non-interactive mode]' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'rmapi command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (put|mput)
        _arguments '*:local file:_files' && ret=0
        ;;
      (get|mget|geta)
        _arguments '*:remote path:' && ret=0
        ;;
      (ls|stat|find)
        _arguments '1:remote path:' && ret=0
        ;;
      (mkdir)
        _arguments '1:directory name:' && ret=0
        ;;
      (mv|cp)
        _arguments '1:source:' '2:destination:' && ret=0
        ;;
      (rm)
        _arguments '*:remote path:' && ret=0
        ;;
    esac
    ;;
esac

return ret
