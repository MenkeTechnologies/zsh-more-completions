#compdef restate
# Documentation: https://github.com/restatedev/restate (cli/src/app.rs Cling-based parser)
# Reference accessed: 2026-05-29
# Restate durable execution platform CLI.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'dev:development mode'
  'up:development mode (alias)'
  'whoami:print general info about the configured environment'
  'services:manage Restate service registry'
  'deployments:manage your service deployments'
  'kafka-clusters:manage Kafka clusters'
  'subscriptions:manage Kafka subscriptions'
  'invocations:manage active invocations'
  'sql:run SQL queries against the data fusion service'
  'example:download Restate examples'
  'examples:download Restate examples (alias)'
  'state:manage service state'
  'kv:manage service state (alias)'
  'completions:generate shell completions'
  'config:manage CLI config'
  'conf:manage CLI config (alias)'
  'cloud:manage Restate Cloud'
  'lambda:run as an AWS Lambda server'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-e --environment)'{-e,--environment=}'[environment from config file]:env:' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'restate subcommand' _subcmds && ret=0
    ;;
  args)
    local -a _services _deployments _invocations _state _config _cloud _kafka _subs
    _services=(
      'list:list registered services'
      'get:get details of a service'
      'patch:patch a service'
    )
    _deployments=(
      'list:list deployments'
      'register:register a new deployment (rpc)'
      'remove:remove a deployment'
      'get:get details of a deployment'
    )
    _invocations=(
      'list:list active invocations'
      'get:get details of an invocation'
      'cancel:cancel an invocation'
      'kill:kill an invocation'
      'pause:pause an invocation'
      'resume:resume an invocation'
    )
    _state=(
      'edit:edit service state'
      'get:get service state'
      'clear:clear service state'
    )
    _config=(
      'list:list available environments'
      'view:view current environment configuration'
      'edit:edit environment configuration'
      'add:add a new environment'
      'remove:remove an environment'
      'use:switch to an environment'
    )
    _cloud=(
      'login:login to Restate Cloud'
      'environments:manage cloud environments'
      'tunnel:run a local tunnel to the cloud'
    )
    _kafka=(
      'list:list Kafka clusters'
      'add:add a Kafka cluster'
      'remove:remove a Kafka cluster'
    )
    _subs=(
      'list:list subscriptions'
      'add:add a subscription'
      'remove:remove a subscription'
    )
    case $line[1] in
      services|svc) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'services' _services && ret=0 ;;
      deployments|dep) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'deployments' _deployments && ret=0 ;;
      invocations|inv) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'invocations' _invocations && ret=0 ;;
      state|kv) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'state' _state && ret=0 ;;
      config|conf) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'config' _config && ret=0 ;;
      cloud) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'cloud' _cloud && ret=0 ;;
      kafka-clusters) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'kafka' _kafka && ret=0 ;;
      subscriptions) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'subscriptions' _subs && ret=0 ;;
      completions) _arguments '1:shell:(bash zsh fish elvish powershell)' && ret=0 ;;
    esac
    ;;
esac

return ret
