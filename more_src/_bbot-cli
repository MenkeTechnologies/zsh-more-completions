# upstream: https://github.com/blacklanternsecurity/bbot

_bbot-cli() {
    local -a sub=(
        'modules:list/inspect modules'
        'flags:list flags'
        'presets:list presets'
        'list:list things'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-s[silent]' \
        '--silent[silent]' \
        '--force[force run]' \
        '--strict-scope[strict scope]' \
        '-t+[target]:str:' \
        '*-t+[target]:str:' \
        '--targets=+[targets]:str:' \
        '-w+[whitelist]:str:' \
        '--whitelist=+[items]:str:' \
        '-b+[blacklist]:str:' \
        '--blacklist=+[items]:str:' \
        '-n+[scan name]:str:' \
        '--name=+[name]:str:' \
        '-m+[modules]:str:' \
        '*-m+[module]:str:' \
        '--modules=+[mods]:str:' \
        '-l[list modules]' \
        '--list-modules[list modules]' \
        '-em+[exclude modules]:str:' \
        '--exclude-modules=+[mods]:str:' \
        '-f+[flags]:str:' \
        '*-f+[flag]:str:' \
        '--flags=+[flags]:str:' \
        '-rf+[required flags]:str:' \
        '--require-flags=+[flags]:str:' \
        '-ef+[exclude flags]:str:' \
        '--exclude-flags=+[flags]:str:' \
        '--allow-deadly[allow deadly]' \
        '-c+[config k=v]:str:' \
        '*-c+[config k=v]:str:' \
        '--config=+[file]:file:_files -g "*.yml *.yaml"' \
        '-p+[preset]:str:' \
        '*-p+[preset]:str:' \
        '--preset=+[name]:str:' \
        '--list-presets[list presets]' \
        '--list-flags[list flags]' \
        '--list-output-modules[list output modules]' \
        '--list-output-types[list output types]' \
        '--list-event-types[list event types]' \
        '--all-presets[all presets]' \
        '--allow-deadly-presets[allow deadly presets]' \
        '--dump-attributes[dump attributes]' \
        '--no-deps[no deps]' \
        '--force-deps[force deps]' \
        '--retry-deps[retry deps]' \
        '--ignore-failed-deps[ignore failed deps]' \
        '--install-all-deps[install all deps]' \
        '-o+[output modules]:str:' \
        '--output-modules=+[mods]:str:' \
        '-od+[output dir]:dir:_files -/' \
        '--output-dir=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bbot subcommand' sub ;;
        args) _arguments '*:arg:' ;;
    esac
}

_bbot-cli "$@"
