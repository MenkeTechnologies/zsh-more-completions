#compdef proto

# Zsh completion for proto - Version manager by moonrepo

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_proto_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '(-l --log)'{-l,--log}'[log level]:level:(off error warn info debug trace)'
  '--dump[dump a trace profile]'
  '--json[output as JSON]'
  '(-y --yes)'{-y,--yes}'[auto confirm prompts]'
)

_proto_tools() {
  local -a tools
  tools=(node npm pnpm yarn bun deno go rust python ruby java kotlin php)
  _describe -t tools 'tool' tools
}

_arguments -s -S -C \
  "${_proto_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'install:Install a tool'
      'uninstall:Uninstall a tool'
      'list:List installed versions of a tool'
      'list-remote:List available remote versions of a tool'
      'use:Download and install all tools from .prototools'
      'pin:Pin a global or local version of a tool'
      'clean:Clean stale tools and plugins'
      'run:Run a tool with the given arguments'
      'setup:Setup proto for your shell'
      'status:Display the current state of all tools'
      'alias:Add an alias to a tool'
      'unalias:Remove an alias from a tool'
      'bin:Display the absolute path to a tools binary'
      'completions:Generate shell completions'
      'outdated:Check if configured tool versions are outdated'
      'plugin:Manage tool plugins'
      'activate:Activate proto for the current shell'
      'diagnose:Diagnose potential issues'
      'regen:Regenerate shims and bins'
      'upgrade:Upgrade proto to the latest version'
    )
    _describe -t commands 'proto commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      install)
        _arguments -s -S \
          "${_proto_global_flags[@]}" \
          '--pin[pin the version after installing]' \
          '--canary[install a canary version]' \
          '1:tool:_proto_tools' \
          '2:version:' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          "${_proto_global_flags[@]}" \
          '1:tool:_proto_tools' \
          '2:version:' && ret=0
        ;;
      list)
        _arguments -s -S \
          "${_proto_global_flags[@]}" \
          '1:tool:_proto_tools' && ret=0
        ;;
      list-remote)
        _arguments -s -S \
          "${_proto_global_flags[@]}" \
          '1:tool:_proto_tools' && ret=0
        ;;
      pin)
        _arguments -s -S \
          "${_proto_global_flags[@]}" \
          '--global[pin globally]' \
          '1:tool:_proto_tools' \
          '2:version:' && ret=0
        ;;
      run)
        _arguments -s -S \
          "${_proto_global_flags[@]}" \
          '1:tool:_proto_tools' \
          '*:arguments:' && ret=0
        ;;
      alias)
        _arguments -s -S \
          "${_proto_global_flags[@]}" \
          '1:tool:_proto_tools' \
          '2:alias name:' \
          '3:version:' && ret=0
        ;;
      unalias)
        _arguments -s -S \
          "${_proto_global_flags[@]}" \
          '1:tool:_proto_tools' \
          '2:alias name:' && ret=0
        ;;
      bin)
        _arguments -s -S \
          "${_proto_global_flags[@]}" \
          '--shim[return shim path instead]' \
          '1:tool:_proto_tools' \
          '2:version:' && ret=0
        ;;
      completions)
        _arguments -s -S \
          "${_proto_global_flags[@]}" \
          '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      plugin)
        _arguments -s -S -C \
          "${_proto_global_flags[@]}" \
          '1:subcommand:->plugin_cmd' \
          '*::arg:->plugin_args' && ret=0
        case "$state" in
          plugin_cmd)
            local -a plugin_commands
            plugin_commands=(
              'add:Add a plugin'
              'info:Display information about a plugin'
              'list:List installed plugins'
              'remove:Remove a plugin'
              'search:Search for available plugins'
            )
            _describe -t commands 'plugin commands' plugin_commands && ret=0
            ;;
          plugin_args)
            case "${line[1]}" in
              add)
                _arguments -s -S \
                  "${_proto_global_flags[@]}" \
                  '--global[add globally]' \
                  '1:plugin id:' \
                  '2:plugin locator:' && ret=0
                ;;
              remove)
                _arguments -s -S \
                  "${_proto_global_flags[@]}" \
                  '--global[remove globally]' \
                  '1:plugin id:' && ret=0
                ;;
              info)
                _arguments -s -S \
                  "${_proto_global_flags[@]}" \
                  '1:plugin id:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      clean|setup|status|use|activate|diagnose|regen|upgrade|outdated)
        _arguments -s -S \
          "${_proto_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
