#compdef nirt
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=nirt&sektion=1
# BRL-CAD interactive ray-tracer (Natalie's Interactive Ray-Tracer)

local ret=1

_arguments -s \
  '*-A[add attribute names to reported list]:attribute' \
  '-M[read eye point/orientation from stdin and fire single ray]' \
  '-b[backout before first shoot command]' \
  '-B[set rt_bot_minpieces value]:value' \
  '-e[run script string before reading stdin]:script' \
  '-f[load format or script file before reading stdin]:file:_files' \
  '-E[ignore previous -e and -f options]' \
  '-L[list output formatting options]' \
  '-s[silent (non-verbose) mode]' \
  '-v[verbose mode]' \
  '-H[enable/disable informational header]:flag' \
  '-u[set useair member value]:n' \
  '-O[multiple-region overlap claim action]:action' \
  '-x[librt debug flags (hex)]:flags' \
  '-X[nirt debug flags (hex)]:flags' \
  '1:database:_files -g "*.g"' \
  '*:object:_default' && ret=0

return ret
