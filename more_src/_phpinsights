#compdef phpinsights

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'analyse:analyze code quality'
  'fix:fix code quality issues'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config-path=[path to config file]:config file:_files -g "*.php"' \
  '--min-quality=[minimum quality score]:score' \
  '--min-complexity=[minimum complexity score]:score' \
  '--min-architecture=[minimum architecture score]:score' \
  '--min-style=[minimum style score]:score' \
  '--disable-security-check[disable security check]' \
  '--fix[fix issues found]' \
  '-s[show sniff codes in output]' \
  '--summary[show only summary]' \
  '--no-interaction[do not ask interactive questions]' \
  '--format=[output format]:format:(console json checkstyle codeclimate github-action)' \
  '-v[verbose mode]' \
  '-vv[more verbose]' \
  '-vvv[debug mode]' \
  '--ansi[force ANSI output]' \
  '--no-ansi[disable ANSI output]' \
  '1:command:->command' \
  '*:path:_files' && ret=0

case "$state" in
  command)
    _describe -t commands 'phpinsights command' commands && ret=0
    ;;
esac

return ret
