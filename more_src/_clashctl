#compdef clashctl
# Documentation: https://github.com/George-Miao/clashctl
# clashctl - CLI and TUI to interact with the Clash RESTful API

local ret=1
local context curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config-path)'{-c,--config-path}'=[config file location]:file:_files' \
  '--config-dir=[config directory]:dir:_files -/' \
  '(-t --timeout)'{-t,--timeout}'=[request timeout in milliseconds]:ms' \
  '--test-url=[URL for testing proxy endpoints]:url' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'clashctl command' \
      'tui[open the terminal user interface]' \
      'proxy[interact with proxies]' \
      'server[interact with servers]' \
      'completion[generate auto-completion scripts]' && ret=0
    ;;
esac

return ret
