#compdef hyprpm

# Zsh completion for hyprpm (Hyprland plugin manager)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:Install a plugin repository from URL'
  'remove:Remove a plugin repository'
  'update:Update all plugin repositories'
  'list:List all installed plugin repositories and plugins'
  'enable:Enable a plugin'
  'disable:Disable a plugin'
  'reload:Reload all plugins'
)

_arguments -s -S -C \
  '(-v --verbose)'{-v,--verbose}'[Enable verbose output]' \
  '--no-shallow[Disable shallow cloning]' \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-V --version)'{-V,--version}'[Print version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'hyprpm command' commands && ret=0
    ;;
  args)
    case $words[1] in
      add)
        _arguments ':repository URL' && ret=0
        ;;
      remove)
        _arguments ':repository name' && ret=0
        ;;
      enable|disable)
        _arguments ':plugin name' && ret=0
        ;;
    esac
    ;;
esac

return ret
