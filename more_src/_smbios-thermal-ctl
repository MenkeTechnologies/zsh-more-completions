#compdef smbios-thermal-ctl
# Documentation: https://man.archlinux.org/man/smbios-thermal-ctl.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# smbios-thermal-ctl: control Dell thermal mode
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  "--get-thermal-info[get thermal info]" "--set-thermal-mode=[set thermal mode]:mode:(balanced cool-bottom quiet performance)" \
  '*::smbios-thermal-ctl args:_files' && ret=0
return ret
