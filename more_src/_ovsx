#compdef ovsx

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create-namespace:create a new namespace'
  'publish:publish an extension'
  'get:get metadata of an extension'
  'help:show help for a command'
)

_arguments -s -S \
  '(-r --registryUrl)'{-r,--registryUrl}'[use the given URL for the registry]:URL' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      publish)
        _arguments \
          '(-p --pat)'{-p,--pat}'[personal access token]:token' \
          '(-r --registryUrl)'{-r,--registryUrl}'[registry URL]:URL' \
          '--packagePath=[path to .vsix package]:package:_files -g "*.vsix"' \
          '--baseContentUrl=[base URL for relative content links]:URL' \
          '--baseImagesUrl=[base URL for relative image links]:URL' \
          '--yarn[use yarn instead of npm]' \
          '--pre-release[mark as pre-release]' \
          '*:VSIX file:_files -g "*.vsix"' && ret=0
        ;;
      get)
        _arguments \
          '(-r --registryUrl)'{-r,--registryUrl}'[registry URL]:URL' \
          '(-o --output)'{-o,--output}'[save to file]:output file:_files' \
          '--metadata[output metadata as JSON]' \
          '1:extension ID (publisher.name)' && ret=0
        ;;
      create-namespace)
        _arguments \
          '(-p --pat)'{-p,--pat}'[personal access token]:token' \
          '(-r --registryUrl)'{-r,--registryUrl}'[registry URL]:URL' \
          '1:namespace' && ret=0
        ;;
    esac
    ;;
esac

return ret
