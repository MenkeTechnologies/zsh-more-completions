#compdef rife-ncnn-vulkan-extra
# Documentation: https://github.com/nihui/rife-ncnn-vulkan
# RIFE ncnn Vulkan video frame interpolation (extra-models fork)

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose output]' \
  '-0+[first input image path]:input0:_files' \
  '-1+[second input image path]:input1:_files' \
  '-i+[input directory]:input dir:_files -/' \
  '-o+[output image path or directory]:output:_files' \
  '-m+[rife model path]:model dir:_files -/' \
  '-g+[gpu device to use]:gpu id' \
  '-j+[thread count for load:proc:save]:threads' \
  '-n+[target frame count]:num frame' \
  '-s+[time step (0~1)]:time step' \
  '-x[enable spatial tta mode]' \
  '-z[enable temporal tta mode]' \
  '-u[enable UHD mode]' \
  '-f+[output filename pattern format]:format' && ret=0

return ret
