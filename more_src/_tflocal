#compdef tflocal tflocal-init tflocal-plan tflocal-apply

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize working directory'
  'plan:show execution plan'
  'apply:apply changes'
  'destroy:destroy infrastructure'
  'validate:validate configuration'
  'fmt:format files'
  'console:interactive console'
  'state:state management'
  'show:show plan or state'
  'output:show outputs'
  'workspace:manage workspaces'
  'import:import resource into state'
  'taint:mark resource for recreation'
  'untaint:remove taint from resource'
  'refresh:refresh state'
  'graph:dot graph of resources'
  'login:login to terraform cloud'
  'logout:logout'
  'providers:show providers'
  'force-unlock:force unlock state'
  'get:download modules'
  'test:run tests'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-chdir=[change to directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tflocal command' commands && ret=0 ;;
esac

return ret
