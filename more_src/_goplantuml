#compdef goplantuml
# Documentation: https://github.com/jfeliu007/goplantuml
# goplantuml - generate PlantUML class diagrams from Go source

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-recursive[walk all directories recursively]' \
  '-hide-connections[hides all connections in the diagram]' \
  '-hide-fields[hides fields]' \
  '-hide-methods[hides methods]' \
  '-hide-private-members[hides all private members (fields and methods)]' \
  '-aggregate-private-members[show aggregations for private members]' \
  '-show-aggregations[render public aggregations even when -hide-connections is used]' \
  '-show-compositions[show compositions even when -hide-connections is used]' \
  '-show-implementations[show implementations even when -hide-connections is used]' \
  '-show-aliases[show aliases even when -hide-connections is used]' \
  '-show-connection-labels[show labels identifying the connection types]' \
  '-show-options-as-note[show a note in the diagram with the options used]' \
  '-title[assign a title to the generated diagram]:title' \
  '-output[output file path (default stdout)]:output:_files' \
  '-ignore[comma separated list of folders to ignore]:folders' \
  '-notes[comma separated list of notes to add to the diagram]:notes' \
  '*:directory:_files -/' && ret=0

return ret
