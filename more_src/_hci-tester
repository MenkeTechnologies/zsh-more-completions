#compdef hci-tester mgmt-tester smp-tester gap-tester rfcomm-tester bnep-tester 6lowpan-tester
# Documentation: https://github.com/bluez/bluez/tree/master/tools
# Source: BlueZ src/shared/tester.c — shared GOptionContext used by every *-tester binary.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-v,--version}'[show version and exit]' \
    '(-q --quiet)'{-q,--quiet}'[run tests without logging]' \
    '(-d --debug)'{-d,--debug}'[run tests with debug output]' \
    '(-m --monitor)'{-m,--monitor}'[enable monitor output]' \
    '(- *)'{-l,--list}'[only list the tests to be run]' \
    '(-p --prefix)'{-p+,--prefix=}'[run tests matching prefix]:prefix:' \
    '(-s --string)'{-s+,--string=}'[run tests matching string]:substring:' \
    && ret=0

return ret
