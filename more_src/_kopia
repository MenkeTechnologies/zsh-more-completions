#compdef kopia

# Zsh completion for kopia - backup tool

_kopia() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a global_flags=(
        '--config-file=[specify config file]:file:_files'
        '--log-level=[set log level]:level:(debug info warning error)'
        '--log-file=[set log file]:file:_files'
        '--password=[repository password]:password:'
        '--help[show help]'
    )

    local -a commands=(
        'repository:manipulate repository'
        'snapshot:manipulate snapshots'
        'policy:manipulate snapshotting policies'
        'restore:restore a snapshot'
        'mount:mount a snapshot as a local filesystem'
        'server:start the Kopia server'
        'cache:manage content cache'
        'content:manipulate content in repository'
        'blob:manipulate BLOBs in repository'
        'index:manipulate content index'
        'manifest:manipulate manifest items'
        'maintenance:repository maintenance'
        'benchmark:run performance benchmarks'
        'session:manage sessions'
        'logs:manage log retention'
    )

    _arguments -C \
        $global_flags \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'kopia command' commands
            ;;
        args)
            case $words[1] in
                repository)
                    local -a repo_commands=(
                        'create:create new repository'
                        'connect:connect to an existing repository'
                        'disconnect:disconnect from repository'
                        'status:show repository status'
                        'sync-to:synchronize repository to another backend'
                        'set-client:set client options'
                        'set-parameters:set repository parameters'
                        'repair:repair repository'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:repository command:->repocmd' \
                        '*::arg:->repoargs'
                    case $state in
                        repocmd)
                            _describe -t repo_commands 'repository command' repo_commands
                            ;;
                    esac
                    ;;
                snapshot)
                    local -a snap_commands=(
                        'create:create a snapshot of given directory'
                        'delete:delete a snapshot'
                        'estimate:estimate the snapshot size'
                        'expire:remove old snapshots'
                        'list:list snapshots'
                        'migrate:migrate snapshots from another repository'
                        'pin:pin a snapshot'
                        'unpin:unpin a snapshot'
                        'verify:verify the contents of a snapshot'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:snapshot command:->snapcmd' \
                        '*::arg:->snapargs'
                    case $state in
                        snapcmd)
                            _describe -t snap_commands 'snapshot command' snap_commands
                            ;;
                        snapargs)
                            case $line[1] in
                                create)
                                    _arguments -s -S \
                                        $global_flags \
                                        '*:source directory:_directories'
                                    ;;
                                list)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--all[show all snapshots (not only own)]'
                                    ;;
                                delete)
                                    _arguments -s -S \
                                        $global_flags \
                                        '1:snapshot ID:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                policy)
                    local -a pol_commands=(
                        'delete:remove a policy'
                        'edit:edit policy for a target'
                        'list:list policies'
                        'set:set policy for a target'
                        'show:show policy for a target'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:policy command:->polcmd' \
                        '*::arg:->polargs'
                    case $state in
                        polcmd)
                            _describe -t pol_commands 'policy command' pol_commands
                            ;;
                    esac
                    ;;
                restore)
                    _arguments -s -S \
                        $global_flags \
                        '--overwrite-directories[overwrite existing directories]' \
                        '--overwrite-files[overwrite existing files]' \
                        '--overwrite-symlinks[overwrite existing symlinks]' \
                        '--consistent-attributes[fail if attributes are inconsistent]' \
                        '1:object ID:' \
                        '2:target path:_files'
                    ;;
                mount)
                    _arguments -s -S \
                        $global_flags \
                        '--fuse-allow-other[allow other users to access FUSE mount]' \
                        '1:object ID:' \
                        '2:mount point:_directories'
                    ;;
                server)
                    local -a srv_commands=(
                        'start:start the Kopia server'
                        'refresh:refresh server state'
                        'status:show server status'
                        'pause:pause scheduled snapshots'
                        'resume:resume scheduled snapshots'
                        'shutdown:shutdown the server'
                        'users:manage server users'
                        'acl:manage server access control'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:server command:->srvcmd' \
                        '*::arg:->srvargs'
                    case $state in
                        srvcmd)
                            _describe -t srv_commands 'server command' srv_commands
                            ;;
                        srvargs)
                            case $line[1] in
                                start)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--address=[listen address]:address:' \
                                        '--insecure[allow insecure connections]' \
                                        '--tls-cert-file=[TLS certificate file]:file:_files' \
                                        '--tls-key-file=[TLS key file]:file:_files' \
                                        '--auto-shutdown=[auto-shutdown interval]:duration:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                cache)
                    local -a cache_commands=(
                        'clear:clear content cache'
                        'info:show cache information'
                        'set:set cache parameters'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:cache command:->cachecmd'
                    case $state in
                        cachecmd)
                            _describe -t cache_commands 'cache command' cache_commands
                            ;;
                    esac
                    ;;
                content)
                    local -a content_commands=(
                        'delete:delete content'
                        'list:list contents'
                        'show:show content'
                        'stats:show content statistics'
                        'verify:verify contents'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:content command:->contentcmd'
                    case $state in
                        contentcmd)
                            _describe -t content_commands 'content command' content_commands
                            ;;
                    esac
                    ;;
                blob)
                    local -a blob_commands=(
                        'delete:delete blobs'
                        'list:list blobs'
                        'show:show blob'
                        'stats:show blob statistics'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:blob command:->blobcmd'
                    case $state in
                        blobcmd)
                            _describe -t blob_commands 'blob command' blob_commands
                            ;;
                    esac
                    ;;
                index|manifest|maintenance|benchmark|session|logs)
                    _arguments -s -S $global_flags
                    ;;
            esac
            ;;
    esac
}

_kopia "$@"
