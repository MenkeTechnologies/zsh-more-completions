#compdef manix
# Documentation: https://github.com/mlvzk/manix
# Reference accessed: 2026-05-19
# Verified: upstream source (src/bin/manix.rs) at the URL above.

# Zsh completion for manix - a fast documentation searcher for Nix

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-u --update-cache)'{-u,--update-cache}'[force update cache]' \
  '(-s --strict)'{-s,--strict}'[match entries strictly]' \
  '--source=[restrict search to sources (csv)]:sources:_values -s , "source" nixos_options hm_options nixpkgs_doc nixpkgs_tree nixpkgs_comments' \
  '*:query' && ret=0

return ret
