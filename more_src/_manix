#compdef manix

# Zsh completion for manix - a fast documentation searcher for Nix

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-s --source)'{-s,--source}'[show source locations]' \
  '--strict[only exact matches]' \
  '--update-cache[update cache before searching]' \
  '*:query' && ret=0

return ret
