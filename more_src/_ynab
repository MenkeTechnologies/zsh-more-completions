#compdef ynab ynab-cli

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'accounts:account commands (list/view/transactions)'
  'budgets:budget commands (list-all/view/settings/months)'
  'categories:category commands (list/view/update/budget/transactions)'
  'transactions:transaction commands (list/view/create/update/delete/search/split)'
  'payees:payee commands (list/view/update/locations/transactions)'
  'payee-locations:payee location commands'
  'months:budget month commands'
  'scheduled:scheduled transactions'
  'api:invoke YNAB API directly'
  'config:CLI configuration'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--access-token=[YNAB personal access token]:token:' \
  '--budget=[default budget id]:id:' \
  '--compact[minified JSON output]' \
  '--color=[colored output]:mode:(auto always never)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ynab command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (accounts)
        _arguments '*::sub:(list view transactions)' && ret=0 ;;
      (budgets)
        _arguments '*::sub:(list-all view settings)' && ret=0 ;;
      (categories)
        _arguments \
          '*::sub:(list view update budget transactions)' \
          '--set-budgeted=[set budgeted amount (milliunits)]:amount:' \
          '--set-note=[set note]:note:' && ret=0 ;;
      (transactions)
        _arguments \
          '*::sub:(list view create update delete search split bulk-update)' \
          '--account=[account id or name]:account:' \
          '--type=[transaction type]:type:(uncategorized unapproved)' \
          '--since-date=[only return >= date]:date:' \
          '--set-amount=[set amount in milliunits]:amount:' \
          '--set-memo=[set memo]:memo:' \
          '--set-cleared=[set cleared status]:status:(cleared uncleared reconciled)' \
          '--set-approved=[set approved]:bool:(true false)' \
          '--set-flag-color=[set flag color]:color:(red orange yellow green blue purple)' \
          '--set-payee-id=[set payee id]:id:' \
          '--set-payee-name=[set payee name]:name:' \
          '--set-category-id=[set category id]:id:' \
          '--set-account-id=[set account id]:id:' && ret=0 ;;
      (payees)
        _arguments '*::sub:(list view update locations transactions)' && ret=0 ;;
      (payee-locations)
        _arguments '*::sub:(list view)' && ret=0 ;;
      (months)
        _arguments '*::sub:(list view)' && ret=0 ;;
      (scheduled)
        _arguments '*::sub:(list view create update delete)' && ret=0 ;;
      (api)
        _arguments \
          '--method=[HTTP method]:method:(GET POST PATCH PUT DELETE)' \
          '*::endpoint:' && ret=0 ;;
      (config)
        _arguments '*::sub:(get set list reset)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
