#compdef kdu_compress kdu_expand kdu_buffered_compress kdu_buffered_expand kdu_render kdu_show kakadu
# _kakadu — Kakadu Software kdu_compress kdu_expand reference JPEG 2000 codec SDK utilities (Kakadu team, C++); getopt
# upstream: https://kakadusoftware.com

_kakadu() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-version[show version]' \
        '-i+[input file]:file:_files -g "*.jp2 *.j2c *.j2k *.jpx *.tif *.tiff *.bmp *.pgm *.ppm *.raw *.rawl *.pgx *.tga"' \
        '-o+[output file]:file:_files -g "*.jp2 *.j2c *.j2k *.jpx *.tif *.tiff *.bmp *.pgm *.ppm *.raw *.tga"' \
        '-precise[precise mode]' \
        '-tolerance+[F]:f:' \
        '-quiet[quiet]' \
        '-fastest[fastest mode]' \
        '-frag+[N N N N]:str:' \
        '-record+[file]:file:_files' \
        '-no_alpha[ignore alpha]' \
        '-display+[display]:str:' \
        '-jpx_box+[csv]:str:' \
        '-jpx_layers+[N]:n:' \
        '-mem[mem mode]' \
        '-no_palette[no palette]' \
        '-rotate+[degrees]:n:(0 90 180 270)' \
        '-resilient[resilient]' \
        '-num_threads+[N]:n:' \
        '-double_buffering+[N]:n:' \
        '-jp2_space+[colour space]:str:' \
        '-codestream_components+[csv]:str:' \
        '-skip_components+[N]:n:' \
        '-stiles[show tiles]' \
        '-cpu_complexity[show cpu complexity]' \
        '-flush_period+[N]:n:' \
        '-rate+[csv]:str:' \
        '-slope+[csv]:str:' \
        '-tolerance+[F]:f:' \
        '-no_weights[no weights]' \
        '-roi+[region]:str:' \
        '-no_codestream_comments[no codestream comments]' \
        '-no_info[no info]' \
        '-add_info[add info]' \
        '-Cprecincts+[csv]:str:' \
        '-Sprecincts+[csv]:str:' \
        '*:input file:_files -g "*.jp2 *.j2c *.j2k *.jpx *.tif *.tiff *.bmp *.pgm *.ppm *.raw"'
}

_kakadu "$@"
