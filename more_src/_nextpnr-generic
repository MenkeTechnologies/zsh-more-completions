#compdef nextpnr-generic
# Documentation: https://github.com/YosysHQ/nextpnr/blob/master/common/kernel/command.cc
# nextpnr generic place-and-route tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, only errors and warnings displayed]' \
  '--Werror[turn warnings into errors]' \
  '(-l --log)'{-l,--log}'=[log file]:file:_files' \
  '--debug[debug output]' \
  '--debug-placer[debug output from placer only]' \
  '--debug-router[debug output from router only]' \
  '--threads=[number of threads]:num' \
  '(-f --force)'{-f,--force}'[keep running after errors]' \
  '--gui[start gui]' \
  '--gui-no-aa[disable anti aliasing]' \
  '--run=[python file to execute instead of default flow]:file:_files' \
  '--pre-pack=[python file to run before packing]:file:_files' \
  '--pre-place=[python file to run before placement]:file:_files' \
  '--pre-route=[python file to run before routing]:file:_files' \
  '--post-route=[python file to run after routing]:file:_files' \
  '--on-failure=[python file to run on crash]:file:_files' \
  '--json=[JSON design file to ingest]:file:_files' \
  '--write=[JSON design file to write]:file:_files' \
  '--top=[name of top module]:name' \
  '--seed=[seed value for random number generator]:seed' \
  '(-r --randomize-seed)'{-r,--randomize-seed}'[randomize seed value]' \
  '--placer=[placer algorithm to use]:algo' \
  '--router=[router algorithm to use]:algo' \
  '--cstrweight=[placer weighting for relative constraint satisfaction]:weight' \
  '--starttemp=[placer SA start temperature]:temp' \
  '--pack-only[pack design only without placement or routing]' \
  '--no-route[process design without routing]' \
  '--no-place[process design without placement]' \
  '--no-pack[process design without packing]' \
  '--ignore-loops[ignore combinational loops in timing analysis]' \
  '--ignore-rel-clk[ignore clock-to-clock relations]' \
  '--test[check architecture database integrity]' \
  '--freq=[set target frequency in MHz]:mhz' \
  '--timing-allow-fail[allow timing to fail in design]' \
  '--no-tmdriv[disable timing-driven placement]' \
  '--sdc=[generic timing constraints SDC file to load]:file:_files' \
  '--sdf=[SDF delay back-annotation file to write]:file:_files' \
  '--sdf-cvc[enable tweaks for SDF CVC simulator compatibility]' \
  '--report=[write timing and utilization report JSON to file]:file:_files' \
  '--detailed-timing-report[append detailed net timing data to JSON report]' \
  '--placed-svg=[write render of placement to SVG file]:file:_files' \
  '--routed-svg=[write render of routing to SVG file]:file:_files' && ret=0

return ret
