#compdef pyproject-build python-build
# Documentation: https://man.archlinux.org/search?q=pyproject-build
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[reduce output verbosity]' \
  '(-v --verbose)'{-v,--verbose}'[increase output verbosity]' \
  '(-s --sdist)'{-s,--sdist}'[create a source distribution]' \
  '(-w --wheel)'{-w,--wheel}'[create a wheel distribution]' \
  '(-o --outdir)'{-o+,--outdir=}'[output directory (default dist/)]:dir:_files -/' \
  '--metadata[output wheel metadata as JSON]' \
  '*'{-C+,--config-setting=}'[pass key[=value] setting to backend]:setting:' \
  '--config-json=[backend settings as JSON]:json:' \
  '--installer=[package installer]:installer:(pip uv)' \
  '(-n --no-isolation)'{-n,--no-isolation}'[disable isolated build env]' \
  '--dependency-constraints-txt=[constraints file]:file:_files -g "*.txt"' \
  '(-x --skip-dependency-check)'{-x,--skip-dependency-check}'[skip dependency check]' \
  '*::srcdir:_files -/' && ret=0

return ret
