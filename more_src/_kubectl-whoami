#compdef kubectl-whoami
# Documentation: https://man.archlinux.org/search?q=kubectl-whoami
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-k --kubeconfig)'{-k,--kubeconfig}'=[Kubeconfig path]:file:_files' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '--token-file=[Path to bearer token]:file:_files' \
  '*::args: _default'
