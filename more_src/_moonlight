#compdef moonlight

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'pair:pair with a host'
  'unpair:unpair from a host'
  'stream:start streaming a game'
  'list:list available games on host'
  'quit:quit the running game on host'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'moonlight command' commands && ret=0
    ;;
  args)
    case $words[1] in
      pair|unpair|list|quit)
        _arguments \
          '1:host:_hosts' && ret=0
        ;;
      stream)
        _arguments \
          '--720[use 1280x720 resolution]' \
          '--1080[use 1920x1080 resolution]' \
          '--1440[use 2560x1440 resolution]' \
          '--4k[use 3840x2160 resolution]' \
          '--width=[custom width]:width' \
          '--height=[custom height]:height' \
          '--fps=[target FPS]:fps:(30 60 120)' \
          '--bitrate=[bitrate in Kbps]:bitrate' \
          '--packet-size=[packet size]:size' \
          '--codec=[video codec]:codec:(auto h264 h265 av1)' \
          '--hdr[enable HDR]' \
          '--no-audio[disable audio]' \
          '--surround-sound=[surround sound config]:config:(stereo 5.1 7.1)' \
          '--app=[game or app name]:app' \
          '--windowed[run in windowed mode]' \
          '--fullscreen[run in fullscreen mode]' \
          '--borderless[run in borderless windowed mode]' \
          '--quit-after[quit app on exit]' \
          '--multi-controller[enable multi-controller support]' \
          '--mouse-buttons-swap[swap mouse buttons]' \
          '--no-gamepad[disable gamepad support]' \
          '1:host:_hosts' && ret=0
        ;;
    esac
    ;;
esac

return ret
