#compdef dm
# CCP4: density modification of electron-density maps

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'HKLIN[input MTZ reflection file]:mtz:_files -g "*.mtz"' \
  'HKLOUT[output MTZ reflection file]:mtz:_files' \
  'SOLIN[input solvent mask]:mask:_files' \
  'SOLOUT[output solvent mask]:mask:_files' \
  'NCSOUT[output NCS averaging mask]:mask:_files' \
  'VUOUT[output NCS symmetry visualization file]:file:_files' \
  '*:keyword:(SOLC MODE COMBINE NCYCLE SCHEME LABIN LABOUT AVERAGE NCSMASK GRID END)' && ret=0

return ret
