#compdef xqilla

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-b[XQuery 1.0/3.0/3.1 base URI]' \
  '-i+[input XML file]:file:_files' \
  '-n+[run N times for benchmarking]:n:' \
  '-o+[output file]:file:_files' \
  '-p[XPath 2.0/3.0/3.1 mode]' \
  '-q[XQuery 1.0/3.0/3.1 mode]' \
  '-Q[XQuery Update 1.0 mode]' \
  '-x[XQuery 3.1 mode]' \
  '-X[XQuery 4 mode]' \
  '-f[full text language extensions]' \
  '-s[strip whitespace from input]' \
  '-t[do not preserve whitespace]' \
  '-w+[XQuery base URI for warnings]:uri:' \
  '-d+[stylesheet output method]:method:(xml html xhtml text json)' \
  '-D+[stylesheet output indent]:indent:(yes no)' \
  '-T+[output type]:type:(xml json)' \
  '-V+[bind external variable name=value]:var:' \
  '*:query_file:_files -g "*.xq"' && ret=0

return ret
