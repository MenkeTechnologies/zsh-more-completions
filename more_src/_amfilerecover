#compdef amfilerecover
# _amfilerecover — Zmanda Amanda amfilerecover CLI for the interactive file-level recovery tool browsing Amanda backup indexes restoring specific files directories from holding-disk tape with Amanda Indexd helper (zmanda team, C); getopt
# upstream: https://github.com/zmanda/amanda

_amfilerecover() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-C+[config]:str:' \
        '--config=+[config]:str:' \
        '-s+[server]:h:_hosts' \
        '--server=+[server]:h:_hosts' \
        '-t+[tape server]:h:_hosts' \
        '--tape-server=+[tape server]:h:_hosts' \
        '-d+[tape device]:file:_files' \
        '--device=+[tape device]:file:_files' \
        '-o+[option]:str:' \
        '*:config hostname diskname date:'
}

_amfilerecover "$@"
