#compdef bcmfw
# Documentation: https://github.com/bluez/bluez/blob/master/tools/bcmfw.c
# Source: BlueZ tools/bcmfw.c — Broadcom controller firmware upload.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:firmware file:_files' \
    && ret=0

return ret
