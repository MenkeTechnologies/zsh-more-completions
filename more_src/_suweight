#compdef suweight
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/amplitudes/suweight.c
# SUWEIGHT - weight traces by header parameter such as offset

local ret=1

_arguments -s -S \
  'key=[keyword of header field to weight by]:k:' \
  'a=[constant weighting parameter]:a:' \
  'b=[variable weighting parameter]:b:' \
  'key2=[keyword of header field to draw weights from]:k:' \
  'scale=[scale factor to apply to header values]:s:' \
  'inv=[weight by header value]:i:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
