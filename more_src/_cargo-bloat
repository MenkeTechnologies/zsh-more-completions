#compdef cargo-bloat

# Zsh completion for cargo-bloat (Rust binary size profiler)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--crates[per-crate bloat]' \
  '--time[per-crate build time]' \
  '--filter=[filter functions by name]:pattern' \
  '--split-std[split std crate to its sub-crates]' \
  '--symbols-section=[use specified section]:section:(text data)' \
  '--no-relative-size[hide relative size column]' \
  '-n+[number of lines to show]:count' \
  '--full-fn[print full function name]' \
  '-w[use wide output]' \
  '--wide[use wide output]' \
  '--message-format=[output format]:format:(table json)' \
  '-p+[package to build]:package' \
  '--package=[package to build]:package' \
  '--lib[profile library target]' \
  '--bin=[profile specified binary]:binary' \
  '--example=[profile specified example]:example' \
  '--test=[profile specified test]:test' \
  '--release[build in release mode]' \
  '--profile=[build with specified profile]:profile' \
  '-j+[number of parallel jobs]:jobs' \
  '--jobs=[number of parallel jobs]:jobs' \
  '--features=[space-separated list of features]:features' \
  '--all-features[activate all features]' \
  '--no-default-features[do not activate default features]' \
  '--target=[target triple]:target' \
  '--target-dir=[directory for generated artifacts]:directory:_directories' \
  '--manifest-path=[path to Cargo.toml]:file:_files' \
  '-v[use verbose output]' \
  '--verbose[use verbose output]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[require Cargo.lock is up to date]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without network access]'
