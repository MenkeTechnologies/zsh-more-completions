#compdef filebeat metricbeat auditbeat winlogbeat heartbeat journalbeat packetbeat

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'export:export config or index template'
  'help:show help'
  'keystore:keystore management'
  'modules:modules management'
  'run:run beat (default)'
  'setup:setup index template/dashboards/policy'
  'test:test config or output'
  'version:show version'
  'completion:generate shell completion'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-E+[overwrite config]:setting:' \
  '-N[disable publish]' \
  '*-c+[config file]:file:_files -g "*.yml"' \
  '*-d+[debug selectors]:list:' \
  '--environment+[environment]:env:(systemd container default)' \
  '*--path.config=[config path]:dir:_files -/' \
  '*--path.data=[data path]:dir:_files -/' \
  '*--path.home=[home path]:dir:_files -/' \
  '*--path.logs=[logs path]:dir:_files -/' \
  '--strict.perms=[strict perms]:b:(true false)' \
  '-v[verbose]' \
  '-e[log to stderr]' \
  '*--once[run once]' \
  '*--system.hostfs=[hostfs path]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'beat command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (modules)
        _arguments \
          '1:subcommand:(enable disable list)' \
          '*: :' && ret=0 ;;
      (keystore)
        _arguments \
          '1:subcommand:(add create list remove)' \
          '*: :' && ret=0 ;;
      (export)
        _arguments \
          '1:subcommand:(config index-pattern template ilm-policy dashboard)' \
          '*: :' && ret=0 ;;
      (test)
        _arguments \
          '1:subcommand:(config output)' \
          '*: :' && ret=0 ;;
      (setup)
        _arguments \
          '--dashboards[setup dashboards]' \
          '--ilm-policy[setup ILM policy]' \
          '--index-management[setup index management]' \
          '--pipelines[setup ingest pipelines]' \
          '--enable-all-filesets[enable all filesets]' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
