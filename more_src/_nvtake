#compdef nvtake
# Documentation: https://github.com/lilydjwg/nvchecker (nvchecker/tools.py take() + core.add_common_arguments)
# Reference accessed: 2026-05-29
# nvtake — update version records of nvchecker (move newver entries into oldver).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-V,--version}'[show version and exit]' \
  '(-l --logging)'{-l,--logging=}'[logging level]:level:(debug info warning error)' \
  '--logger=[select logger]:logger:(pretty json both)' \
  '--json-log-fd=[fd to send JSON logs to (stdout by default)]:fd:' \
  '(-c --file)'{-c,--file=}'[software version configuration file (TOML)]:file:_files -g "*.(toml|TOML)"' \
  '--all[take all updates]' \
  '--ignore-nonexistent[ignore nonexistent names]' \
  '*:name (NAME or NAME=VERSION):' \
  && ret=0

return ret
