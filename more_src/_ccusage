#compdef ccusage

local curcontext="$curcontext" state line ret=1

local -a __cc=(
  '(-s --since)'{-s,--since=}'[include usage on/after date (YYYYMMDD)]:date:'
  '(-u --until)'{-u,--until=}'[include usage on/before date (YYYYMMDD)]:date:'
  '(-j --json)'{-j,--json}'[emit JSON]'
  '(-m --mode)'{-m,--mode=}'[cost mode]:mode:(auto calculate display)'
  '(-d --debug)'{-d,--debug}'[print pricing mismatch diagnostics]'
  '--debug-samples=[number of sample discrepancies in debug output]:count:'
  '(-o --order)'{-o,--order=}'[sort order]:order:(asc desc)'
  '(-b --breakdown)'{-b,--breakdown}'[include per-model breakdown]'
  '(-O --offline)'{-O,--offline}'[use cached Claude pricing data]'
  '--no-offline[allow live pricing fetch]'
  '--color[force colored output]'
  '--no-color[disable colored output]'
  '(-z --timezone)'{-z,--timezone=}'[IANA timezone for grouping]:timezone:'
  '(-l --locale)'{-l,--locale=}'[BCP-47 locale for formatting]:locale:'
  '(-q --jq)'{-q,--jq=}'[pipe JSON through jq expression]:jq filter:'
  '--config=[path to JSON config]:file:_files'
  '--compact[compact tables for narrow terminals]'
)

local -a __cc_sess=("${__cc[@]:#*--order*}")

_arguments -C \
  '1: :->cmd' \
  '*::args:->args' && ret=0

case $state in
  (cmd)
    local -a subs=(
      'daily:default report grouped by day'
      'weekly:report grouped by ISO week'
      'monthly:report grouped by month'
      'session:report grouped by Claude session'
      'blocks:5-hour billing block dashboard'
      'statusline:hook-friendly single-line summary'
    )
    _describe -t commands 'ccusage command' subs && ret=0
    ;;
  (args)
    case $line[1] in
      (daily)
        _arguments -s -S \
          $__cc \
          '(-i --instances)'{-i,--instances}'[group totals by project/instance]' \
          '(-p --project)'{-p,--project=}'[limit to a single project label]:project:' && ret=0
        ;;
      (weekly)
        _arguments -s -S \
          $__cc \
          '(-w --start-of-week)'{-w,--start-of-week=}'[week starts on]:day:(sunday monday tuesday wednesday thursday friday saturday)' && ret=0
        ;;
      (monthly)
        _arguments -s -S $__cc && ret=0
        ;;
      (session)
        _arguments -s -S \
          $__cc_sess \
          '(-i --id)'{-i,--id=}'[load a specific session id]:session id:' && ret=0
        ;;
      (blocks)
        _arguments -s -S \
          $__cc \
          '(-a --active)'{-a,--active}'[show only the active block with projections]' \
          '(-r --recent)'{-r,--recent}'[limit to recent days (including active block)]' \
          '(-t --token-limit)'{-t,--token-limit=}'[token quota for warnings]:tokens:' \
          '(-n --session-length)'{-n,--session-length=}'[block length in hours]:hours:' && ret=0
        ;;
      (statusline)
        _arguments -s -S \
          '(-O --offline)'{-O,--offline}'[offline pricing (default on for this command)]' \
          '--no-offline[allow live pricing fetch]' \
          '(-B --visual-burn-rate)'{-B,--visual-burn-rate=}'[burn rate indicator style]:style:(off emoji text emoji-text)' \
          '--cost-source=[cost numbers source]:source:(auto ccusage cc both)' \
          '--cache[enable cache output]' \
          '--no-cache[disable cache]' \
          '--refresh-interval=[cache refresh interval seconds]:seconds:' \
          '--context-low-threshold=[context %% green upper bound (0-100)]:percent:' \
          '--context-medium-threshold=[context %% yellow upper bound (0-100)]:percent:' \
          '--config=[JSON config path]:file:_files' \
          '(-d --debug)'{-d,--debug}'[debug logging]' && ret=0
        ;;
    esac
    ;;
esac

return ret
