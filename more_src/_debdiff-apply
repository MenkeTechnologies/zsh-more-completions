#compdef debdiff-apply
# Documentation: https://manpages.debian.org/debdiff-apply
# Source: debian/devscripts scripts/debdiff-apply — apply a debdiff(1) patch to a Debian source (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-c --changelog)'{-c+,--changelog=}'[debian/changelog path]:file:_files' \
    '(-D --distribution)'{-D+,--distribution=}'[distribution to use]:dist:_default' \
    '--repl[run Python REPL after processing]' \
    '(--target-version)--source-version[print source package version then exit]' \
    '(--source-version)--target-version[print new package version then exit]' \
    '--no-clean[do not clean temp dirs on failure]' \
    '--quilt-refresh[refresh quilt patches if build fails]' \
    '1::orig dsc or directory:_files' \
    '2::patch file:_files -g "*.{patch,diff,debdiff}"' \
    && ret=0

return ret
