#compdef virusbreakend
# Documentation: https://github.com/PapenfussLab/gridss/blob/master/VIRUSBreakend_Readme.md
# GRIDSS VIRUSBreakend viral integration detection tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kraken2db=[path to the Kraken2 database directory]:dir:_files -/' \
  '(-o --output)'{-o,--output}'=[output VCF filename]:vcf:_files' \
  '(-r --reference)'{-r,--reference}'=[host reference genome FASTA]:fasta:_files' \
  '--viralreferences=[custom list of viral reference sequences]:fasta:_files' \
  '*:bam:_files' && ret=0

return ret
