#compdef kubelinter kube-linter

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'lint:lint Kubernetes YAML files and Helm charts'
  'checks:list available lint checks'
  'templates:list available check templates'
  'version:print version'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'kube-linter command' commands && ret=0
    ;;
  args)
    case $line[1] in
      lint)
        _arguments -s -S \
          '--config[config file]:file:_files -g "*.yaml(|.yml)"' \
          '--add-all-built-in[enable all built-in checks]' \
          '--do-not-auto-add-defaults[do not auto-add default checks]' \
          '--exclude[exclude checks]:checks:' \
          '--include[include checks]:checks:' \
          '--format[output format]:format:(plain json sarif)' \
          '--fail-if-no-objects-found[fail if no objects found]' \
          '--help[show help]' \
          '*:path:_files' && ret=0
        ;;
      checks)
        _arguments -s -S \
          '--format[output format]:format:(plain json markdown)' \
          '--help[show help]' && ret=0
        ;;
      templates)
        _arguments -s -S \
          '--format[output format]:format:(plain json markdown)' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
