#compdef mucho
# Documentation: https://github.com/solana-foundation/mucho
# mucho - Solana Toolkit superCLI for local development tooling

local curcontext="$curcontext" state line ret=1
local -a sub

sub=(
  'install:install and manage the Solana Toolkit local tooling'
  'clone:clone accounts and programs (fixtures) from any cluster'
  'validator:run solana-test-validator with cloned fixtures'
  'build:build all or a single Solana program in the workspace'
  'deploy:deploy a Solana program in the workspace'
  'coverage:run code coverage tests (powered by Zest)'
  'info:gather troubleshooting info about your setup'
  'docs:open documentation websites for Solana tools'
  'balance:get an accounts balances across all clusters'
  'inspect:inspect transactions, accounts, and blocks'
  'token:create, mint, and transfer tokens'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-u --url)'{-u,--url}'=[cluster URL or moniker]:url:' \
  '--keypair=[signer keypair file]:file:_files' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd) _describe -t commands 'mucho command' sub && ret=0 ;;
  args)
    case $words[1] in
      token) _arguments '1:token cmd:(create mint transfer)' && ret=0 ;;
      validator) _arguments '--reset[reset ledger before starting]' '--output-only[inspect/output only]' && ret=0 ;;
    esac
    ;;
esac

return ret
