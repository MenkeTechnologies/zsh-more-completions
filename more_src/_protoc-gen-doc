#compdef protoc-gen-doc
# Documentation: https://man.archlinux.org/search?q=protoc-gen-doc
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/protoc-gen-doc — protoc documentation generator plugin

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
