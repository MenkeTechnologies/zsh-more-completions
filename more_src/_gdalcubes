#compdef gdalcubes
# Documentation: https://github.com/appelmar/gdalcubes_cpp/blob/master/src/gdalcubes.cpp
# gdalcubes command line client for Earth observation data cubes from GDAL image collections

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version information]' \
  '(-d --debug)'{-d,--debug}'[print debug messages]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'info:print metadata of a GDAL image collection file'
      'create_collection:create a new image collection from GDAL datasets'
      'exec:evaluate a data cube and store the result as a NetCDF file'
      'addo:build overview images for an existing image collection'
      'translate_gtiff:translate all images in a collection to GeoTiff files'
    )
    _describe -t commands 'gdalcubes command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      create_collection)
        _arguments -s \
          '(-f --format)'{-f,--format}'=[path of the collection format JSON file]:format:_files' \
          '(-R --recursive)'{-R,--recursive}'[do a recursive file listing]' \
          '--noarchives[do not scan within archive files]' \
          '(-s --strict)'{-s,--strict}'[cancel if a dataset cannot be added]' \
          '(-d --debug)'{-d,--debug}'[print debug messages]' \
          '*:input:_files' && ret=0
        ;;
      exec)
        _arguments -s \
          '--deflate=[deflate compression level (0-9)]:level' \
          '(-t --threads)'{-t,--threads}'=[number of threads]:threads' \
          '(-c --chunk)'{-c,--chunk}'=[compute only one specific chunk]:chunk' \
          '--swarm=[file of gdalcubes server API endpoints]:file:_files' \
          '(-d --debug)'{-d,--debug}'[print debug messages]' \
          '*:source:_files' && ret=0
        ;;
      addo)
        _arguments -s \
          '(-t --threads)'{-t,--threads}'=[number of threads]:threads' \
          '(-l --levels)'{-l,--levels}'=[overview levels]:levels' \
          '(-r --resampling)'{-r,--resampling}'=[resampling algorithm]:alg:(AVERAGE AVERAGE_MAGPHASE BILINEAR CUBIC CUBICSPLINE GAUSS LANCZOS MODE NEAREST NONE)' \
          '(-d --debug)'{-d,--debug}'[print debug messages]' \
          '*:source:_files' && ret=0
        ;;
      translate_gtiff)
        _arguments -s \
          '(-t --threads)'{-t,--threads}'=[number of threads]:threads' \
          '(-f --force)'{-f,--force}'[force translation even for existing files]' \
          '(-d --debug)'{-d,--debug}'[print debug messages]' \
          '*:source:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
