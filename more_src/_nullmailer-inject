#compdef nullmailer-inject
# Documentation: https://github.com/bruceg/nullmailer/blob/master/doc/nullmailer-inject.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '-a[recipients from args only]' \
  '-b[recipients from args and header]' \
  '-e[recipients from either]' \
  '-f[envelope sender]:sender:' \
  '-h[recipients from header]' \
  '-n[print without queueing]' \
  '-v[verbose]' \
  '*:recipient:'
