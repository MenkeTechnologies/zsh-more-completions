#compdef nullmailer-inject
# Documentation: https://man.archlinux.org/search?q=nullmailer-inject
# Reference accessed: 2026-05-16

_arguments -s \
  '-a[recipients from args only]' \
  '-b[recipients from args and header]' \
  '-e[recipients from either]' \
  '-f[envelope sender]:sender:' \
  '-h[recipients from header]' \
  '-n[print without queueing]' \
  '-v[verbose]' \
  '*:recipient:'
