#compdef dpdk-testpmd
# Documentation: https://doc.dpdk.org/guides/testpmd_app_ug/run_app.html
# DPDK testpmd forwarding test application

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-i --interactive)'{-i,--interactive}'[run testpmd in interactive mode]' \
  '(-a --auto-start)'{-a,--auto-start}'[begin forwarding immediately]' \
  '--cmdline-file=[execute commands from file at startup]:file:_files' \
  '--tx-first[send a packet burst before forwarding starts]' \
  '--nb-cores=[set the number of forwarding cores]:N' \
  '--nb-ports=[configure forwarding ports count]:N' \
  '--coremask=[hexadecimal bitmask for packet forwarding cores]:mask' \
  '--portmask=[set the hexadecimal bitmask of the ports used]:mask' \
  '--portlist=[specify ports using range/list notation]:list' \
  '--rxq=[set the number of RX queues per port]:N' \
  '--txq=[set the number of TX queues per port]:N' \
  '--rxd=[set the number of RX ring descriptors]:N' \
  '--txd=[set the number of TX ring descriptors]:N' \
  '--hairpinq=[set the number of hairpin queues per port]:N' \
  '--mbuf-size=[set the data size of the mbufs in bytes]:N' \
  '--total-num-mbufs=[total mbuf pool allocation count]:N' \
  '--max-pkt-len=[maximum packet size configuration]:N' \
  '--forward-mode=[select forwarding mode]:mode:(io mac macswap flowgen rxonly txonly csum icmpecho ieee1588 noisy 5tswap)' \
  '--port-topology=[choose port topology]:mode:(paired chained loop)' \
  '--enable-lro[large receive offload activation]' \
  '--enable-rx-cksum[hardware RX checksum offload]' \
  '--burst=[packets per burst (1-512, default 32)]:N' \
  '*::arg:_default' && ret=0

return ret
