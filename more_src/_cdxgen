#compdef cdxgen
# Documentation: https://man.archlinux.org/search?q=cdxgen
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '(-o --output)'{-o,--output}'=[Output SBOM file]:file:_files' \
  '(-t --type)'{-t,--type}'=[Project type]:type:(nodejs python golang rust java csharp)' \
  '--multi-lang[Scan multiple languages]' \
  '--spec-version=[CycloneDX spec version]:version:' \
  '*:path:_files -/'
