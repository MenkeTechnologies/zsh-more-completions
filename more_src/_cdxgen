#compdef cdxgen
# Documentation: https://github.com/cdxgen/cdxgen/blob/master/docs/CLI.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '(-o --output)'{-o,--output}'=[Output SBOM file]:file:_files' \
  '(-t --type)'{-t,--type}'=[Project type]:type:(nodejs python golang rust java csharp)' \
  '--multi-lang[Scan multiple languages]' \
  '--spec-version=[CycloneDX spec version]:version:' \
  '*:path:_files -/'
