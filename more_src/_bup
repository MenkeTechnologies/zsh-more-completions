#compdef bup

# Zsh completion for bup (backup tool using git packfiles)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d[BUP_DIR location]:directory:_files -/' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'init:initialize a bup repository'
      'index:create or display a bup index'
      'save:save files to a bup repository'
      'split:save individual file to a bup repository'
      'join:retrieve data from a bup repository'
      'cat-file:extract specific file from backup'
      'ls:list files in a bup repository'
      'ftp:browse backup sets with FTP-like interface'
      'fuse:mount backup sets as FUSE filesystem'
      'web:start web server for browsing backups'
      'restore:extract files from backup'
      'damage:deliberately damage a repository for testing'
      'fsck:check backup sets for damage'
      'margin:show how close packfiles are to overflow'
      'midx:create a multi-pack index'
      'bloom:create or update bloom filters'
      'memtest:test memory usage'
      'random:generate random data'
      'server:bup server for remote backups'
      'tag:tag a commit in the repository'
      'gc:remove unreferenced data'
      'rm:remove backup sets'
      'get:copy data between repositories'
      'prune-older:remove older backups'
      'on:run bup on a remote host'
      'version:show version'
      'help:show help'
    )
    _describe -t commands 'bup command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (init)
        _arguments \
          '-r[remote repository]:remote' && ret=0
        ;;
      (index)
        _arguments \
          '-u[update index]' \
          '-p[print index entries]' \
          '-m[print modified files]' \
          '-s[print status]' \
          '-x[do not cross filesystem boundaries]' \
          '--fake-valid[mark all entries as valid]' \
          '--fake-invalid[mark all entries as invalid]' \
          '--check[check index]' \
          '--clear[clear index]' \
          '-f[index file]:file:_files' \
          '*:path:_files' && ret=0
        ;;
      (save)
        _arguments \
          '-r[remote repository]:remote' \
          '-t[output tree hash]' \
          '-c[output commit hash]' \
          '-n[backup name]:name' \
          '-d[date]:date' \
          '--strip[strip leading path components]' \
          '--strip-path[strip specified path prefix]:path:_files -/' \
          '--graft[remap paths]:old_path=new_path' \
          '-v[verbose]' \
          '-q[quiet]' \
          '*:path:_files' && ret=0
        ;;
      (restore)
        _arguments \
          '-C[change to directory]:directory:_files -/' \
          '-v[verbose]' \
          '-q[quiet]' \
          '--exclude-rx[exclude paths matching regex]:regex' \
          '--exclude-rx-from[exclude patterns from file]:file:_files' \
          '*:path' && ret=0
        ;;
      (ls)
        _arguments \
          '-s[show hash]' \
          '-l[long listing]' \
          '-a[show hidden files]' \
          '*:path' && ret=0
        ;;
      (fuse)
        _arguments \
          '-d[debug mode]' \
          '-f[foreground]' \
          '-o[mount options]:options' \
          '--meta[include metadata]' \
          '-v[verbose]' \
          '1:mountpoint:_files -/' && ret=0
        ;;
      (web)
        _arguments \
          '--human-readable[human-readable sizes]' \
          '1:address\:port' && ret=0
        ;;
      (fsck)
        _arguments \
          '-r[repair]' \
          '-g[verify pack generation counts]' \
          '-v[verbose]' \
          '-j[number of parallel checks]:jobs' && ret=0
        ;;
      (tag)
        _arguments \
          '-d[delete tag]' \
          '-f[force]' \
          '1:tag name' \
          '2:commit' && ret=0
        ;;
      (prune-older)
        _arguments \
          '--keep-all-for[keep all backups for period]:period' \
          '--keep-dailies-for[keep daily backups for period]:period' \
          '--keep-monthlies-for[keep monthly backups for period]:period' \
          '--keep-yearlies-for[keep yearly backups for period]:period' \
          '--wrt[with respect to date]:date' \
          '-v[verbose]' \
          '--pretend[dry run]' \
          '*:path' && ret=0
        ;;
    esac
    ;;
esac

return ret
