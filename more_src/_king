#compdef king
# Documentation: https://www.kingrelatedness.com/manual.shtml
# KING: Kinship-based INference for Genome-wide association studies

local ret=1

_arguments -s -S \
  '(-b)-b[input PLINK binary dataset]:file:_files -g "*.bed"' \
  '--fam=[PLINK fam file]:file:_files -g "*.fam"' \
  '--bim=[PLINK bim file]:file:_files -g "*.bim"' \
  '--kinship[estimate pairwise kinship coefficients]' \
  '--ibdseg[infer IBD segments]' \
  '--related[integrated inference for close relationships]' \
  '--duplicate[identify duplicates or MZ twins]' \
  '--ibs[IBS summary statistics]' \
  '--homog[estimate kinship assuming homogeneous population]' \
  '--unrelated[extract list of unrelated individuals]' \
  '--build[reconstruct pedigrees from SNP data]' \
  '--cluster[group relatives into families]' \
  '--rplot[generate relationship plots in PDF]' \
  '--pngplot[generate plots in PNG format]' \
  '--rpath=[full path to R program]:file:_files' \
  '--prefix=[output filename prefix]:prefix:_files' \
  '--degree=[relatedness degree filter]:num' \
  '--seglength=[minimum IBD segment length threshold]:num' \
  '--cpus=[number of CPU cores]:num' \
  '--sexchr=[sex chromosome pair number]:num' \
  '*:file:_files' && ret=0

return ret
