#compdef comma ,
# Documentation: https://github.com/nix-community/comma
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for comma (run commands from nix packages without installing)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--install[install the command permanently]' \
  '--update[update the command index]' \
  '1:command:_command_names -e' \
  '*:arguments' && ret=0

return ret
