#compdef tg-bot
# ============================================================================
# _tg-bot — zsh completion for amitizle/telegram-bot-cli (`tg-bot`),
#            a simple CLI to send messages on behalf of Telegram bots
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/amitizle/telegram-bot-cli
#   Author     : Amit Levy (amitizle)
#   License    : Apache-2.0
#   Language   : Go
#   Module     : github.com/amitizle/telegram-bot-cli
#   Binary     : tg-bot  (rootCmd.Use = "tg-bot" in cmd/root.go;
#                          built from root main.go calling cmd.Execute)
#   Version    : 0.1.0  (cmd/version.go)
#   Last push  : 2019-06-08
#
# WHAT IT IS
#   `tg-bot` is "a simple CLI to send messages on behalf of Telegram
#   bots" — Amit Levy's focused operational utility for one-shot
#   Telegram Bot API sends from shell scripts, cron jobs, CI hooks,
#   and notification pipelines.  Authentication is per-invocation
#   (`--token`) or persistent (`$HOME/.telegram-bot-cli.yaml` or
#   `TELEGRAM_*` env vars via viper).  Three payload kinds are
#   supported:  text messages, document file uploads, and photo
#   uploads (with optional captions).
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/{root,message,version}.go
#                       spf13/cobra Command tree)
#   tg-bot [GLOBAL_FLAGS] <SUBCOMMAND> [args...]
#
#   Global flag (inherited by every subcommand):
#     -c, --config <FILE>     Config file
#                               [default: $HOME/.telegram-bot-cli.yaml]
#
#   Subcommands:
#     message                 Send a message to the specified chat ID
#       Persistent flags (required for every subcommand under message):
#         -i, --chatid <ID>     Chat ID to send the message to
#                               [REQUIRED]
#         -t, --token  <TOK>    Telegram bot token   [REQUIRED]
#
#       text <MESSAGE>          Send a text message
#       doc  <FILE>             Send a document
#         -a, --caption <TEXT>    Document caption (optional)
#       photo <FILE>            Send a photo
#         -a, --caption <TEXT>    Photo caption (optional)
#
#     version                 Print the CLI version and exit
#
#   Standard cobra auto-flags:
#     -h, --help              Show help
#
#   Environment variable overrides (viper AutomaticEnv with envPrefix
#   "TELEGRAM"):  any flag can be set as `TELEGRAM_<FLAG>` (e.g.
#   `TELEGRAM_TOKEN`, `TELEGRAM_CHATID`).
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/go-telegram-bot-api/telegram-
#   bot-api v4.6.4+incompatible` declared in go.mod — the canonical
#   Go Telegram Bot API client (Syfaro / go-telegram-bot-api).
#   telegram-bot-api covers the full Bot API:  message / photo /
#   document / audio / video / sticker / poll send + edit + delete,
#   inline keyboards, callback queries, webhooks, long-polling
#   updates, and File uploads with multipart-form encoding.
#   tg-bot's `internal/bot/bot.go` constructs a
#   `tgbotapi.NewBotAPI(token)` once and dispatches each subcommand
#   through `bot.Send(tgbotapi.NewMessage(chatID, text))`,
#   `bot.Send(tgbotapi.NewDocumentUpload(chatID, filePath))`, and
#   `bot.Send(tgbotapi.NewPhotoUpload(chatID, filePath))`.  Verified
#   via:
#     gh api repos/amitizle/telegram-bot-cli/contents/go.mod
#       → github.com/go-telegram-bot-api/telegram-bot-api
#         v4.6.4+incompatible
#     gh api repos/amitizle/telegram-bot-cli/contents/internal/bot/bot.go
#       → import tgbotapi "github.com/go-telegram-bot-api/telegram-bot-api"
#       → tgbot, err := tgbotapi.NewBotAPI(token)
#   This entry is the Go=130 leader bump that continues Axis 75
#   (Telegram Bot API Client Library) opened at R889 with Rust=
#   teloxide 0.3 (mxseev/logram).  Round-number R890 commit landmark.
#
#   No completion for `tg-bot` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_tg-bot() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-c --config)'{-c+,--config=}'[config file (default $HOME/.telegram-bot-cli.yaml)]:config file:_files -g "*.{yaml,yml}"' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_tg-bot_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                message)
                    _tg-bot_message && ret=0 ;;
                version)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_tg-bot_message] )) ||
_tg-bot_message() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '(-i --chatid)'{-i+,--chatid=}'[chat ID to send to (required)]:chat id:' \
        '(-t --token)'{-t+,--token=}'[Telegram bot token (required)]:token:' \
        '(- *)'{-h,--help}'[help]' \
        '1: :_tg-bot_message_commands' \
        '*::arg:->margs' && ret=0

    case $state in
        margs)
            case $words[1] in
                text)
                    _arguments \
                        ':message text:' && ret=0 ;;
                doc)
                    _arguments \
                        '(-a --caption)'{-a+,--caption=}'[document caption (optional)]:caption:' \
                        ':document file:_files' && ret=0 ;;
                photo)
                    _arguments \
                        '(-a --caption)'{-a+,--caption=}'[photo caption (optional)]:caption:' \
                        ':photo file:_files -g "*.{png,jpg,jpeg,gif,webp}"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_tg-bot_commands] )) ||
_tg-bot_commands() {
    local -a commands
    commands=(
        'message:send a message to the specified chat ID'
        'version:print the CLI version'
    )
    _describe -t commands 'tg-bot command' commands
}

(( $+functions[_tg-bot_message_commands] )) ||
_tg-bot_message_commands() {
    local -a sub
    sub=(
        'text:send a text message'
        'doc:send a document'
        'photo:send a photo'
    )
    _describe -t commands 'message subcommand' sub
}

_tg-bot "$@"
