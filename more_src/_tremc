#compdef tremc

_arguments -s -S \
  '(- *)'{-h,--help}'[display help and exit]' \
  '(- *)'{-v,--version}'[display version and exit]' \
  {-c,--connect=}'[connect to transmission-daemon]:host\:port:' \
  {-s,--ssl}'[use HTTPS for connection]' \
  {-p,--port=}'[port number]:port:' \
  {-P,--path=}'[RPC path]:path:' \
  {-f,--config=}'[configuration file]:file:_files' \
  '--create[create torrent]' \
  '--add=[add torrent file]:file:_files' \
  {-n,--netrc=}'[netrc file for authentication]:file:_files' \
  '--debug[enable debug mode]' \
  '*:torrent file:_files'
