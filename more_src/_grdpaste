#compdef grdpaste
# Documentation: https://docs.generic-mapping-tools.org/latest/grdpaste.html
# Source: GenericMappingTools/gmt classic-mode grdpaste — paste two grids together along a shared edge.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files -g "*.(nc|grd)(-.)"' \
    '-S[just print code + side description, no paste]' \
    '*-V[verbose (stackable)]' \
    '-f+[I/O column data types]:types:_default' \
    '(- *)-\?[show help]' \
    '1:grid file A:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    '2:grid file B:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
