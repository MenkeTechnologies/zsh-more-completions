#compdef llvm-readelf
# _llvm-readelf — LLVM readelf-compatible ELF dumper (LLVM project, C++); show ELF metadata
# upstream: https://github.com/llvm/llvm-project

_llvm-readelf() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-a[all info]' \
        '--all[all info]' \
        '-e[equivalent to -h -l -S]' \
        '--headers[equivalent to -h -l -S]' \
        '-A[arch specific]' \
        '--arch-specific[arch specific]' \
        '-d[dynamic table]' \
        '--dynamic-table[dynamic table]' \
        '-g[section groups]' \
        '--section-groups[section groups]' \
        '-I[histogram of bucket list]' \
        '--histogram[histogram of bucket list]' \
        '-l[program headers]' \
        '--program-headers[program headers]' \
        '--segments[program headers]' \
        '-n[notes]' \
        '--notes[notes]' \
        '-r[relocations]' \
        '--relocs[relocations]' \
        '-S[section headers]' \
        '--section-headers[section headers]' \
        '--sections[section headers]' \
        '-s[symbol table]' \
        '--syms[symbol table]' \
        '--symbols[symbol table]' \
        '--dyn-symbols[dynamic symbol table]' \
        '--dyn-syms[dynamic symbol table]' \
        '-u[unwind info]' \
        '--unwind[unwind info]' \
        '-V[version info]' \
        '--version-info[version info]' \
        '-W[wide output]' \
        '--wide[wide output]' \
        '-x+[hex dump section]:section:' \
        '--hex-dump=+[hex dump section]:section:' \
        '-p+[string dump section]:section:' \
        '--string-dump=+[string dump section]:section:' \
        '--demangle[demangle names]' \
        '-C[demangle names]' \
        '--elf-output-style=+[output style]:style:(LLVM GNU JSON)' \
        '--needed-libs[needed libraries]' \
        '--cg-profile[call graph profile]' \
        '--stack-sizes[stack sizes]' \
        '--bb-addr-map[basic block address map]' \
        '-z[print decompressed contents]' \
        '*:file:_files'
}

_llvm-readelf "$@"
