#compdef vcfstreamsort
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfstreamsort.md
# vcflib: sort a VCF stream within a sliding window of sites

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-w --window)'{-w,--window}'[number of sites to sort (default 10000)]:N' \
  '(-a --all)'{-a,--all}'[load all sites and then sort in memory]' \
  '*:vcf file:_files' && ret=0

return ret
