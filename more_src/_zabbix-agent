#compdef zabbix-agent zabbix_agentd
# Documentation: https://manpages.debian.org/bookworm/zabbix-agent/zabbix_agentd.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm zabbix_agentd(8) manpage.

# zabbix-agent: Zabbix monitoring agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[alternate config file]:file:_files' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-R --runtime-control)'{-R,--runtime-control=}'[runtime option]:opt:(userparameter_reload log_level_increase log_level_decrease)' \
  '(-p --print)'{-p,--print}'[print known items and exit]' \
  '(-t --test)'{-t,--test=}'[test single item and exit]:key:' && ret=0
return ret
