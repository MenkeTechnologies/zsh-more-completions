#compdef vcd2lxt2
# Convert VCD dumpfiles to LXT2

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help screen]' \
  '(-v --vcdname)'{-v+,--vcdname=}'[specify VCD input filename]:file:_files -g "*.vcd"' \
  '(-l --lxtname)'{-l+,--lxtname=}'[specify LXT2 output filename]:file:_files -g "*.lxt2"' \
  '(-d --depth)'{-d+,--depth=}'[gzip compression depth 0..9 (default 4)]:depth' \
  '(-m --maxgranule)'{-m+,--maxgranule=}'[granules per section (default 8)]:value' \
  '(-b --break)'{-b+,--break=}'[break size (default 0 = off)]:value' \
  '(-p --partialmode)'{-p+,--partialmode=}'[partial zip mode 0=monolithic 1=separation]:mode:(0 1)' \
  '(-c --checkpoint)'{-c+,--checkpoint=}'[checkpoint mode 0=on (default) 1=off]:mode:(0 1)' \
  '*:VCD file:_files -g "*.vcd"' && ret=0

return ret
