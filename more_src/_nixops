#compdef nixops

# Zsh completion for nixops - NixOps deployment tool

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'backup:make a backup of the persistent disks of the machines'
  'backup-status:get status of backups'
  'check:check the state of machines'
  'clean-backups:remove old backups'
  'clone:clone a deployment'
  'create:create a new deployment'
  'delete:delete a deployment'
  'deploy:deploy the network'
  'destroy:destroy all resources in the deployment'
  'edit:open the deployment in an editor'
  'export:export a deployment'
  'import:import a deployment'
  'info:show deployment information'
  'list:list all known deployments'
  'list-generations:list previous deployment configurations'
  'modify:modify a deployment'
  'mount:mount a directory from a machine'
  'reboot:reboot machines'
  'rename:rename a deployment'
  'restore:restore persistent disks from backup'
  'rollback:roll back to a previous deployment'
  'send-keys:send encryption keys'
  'set-args:set deployment arguments'
  'show-console-output:show console output of a machine'
  'show-option:show the value of a configuration option'
  'show-physical:show the physical specification'
  'ssh:login via SSH to a machine'
  'ssh-for-each:execute a command on each machine via SSH'
  'start:start machines'
  'stop:stop machines'
  'unlock:remove the state file lock'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-d --deployment)'{-d,--deployment}'=[deployment name or UUID]:deployment' \
  '(-s --state)'{-s,--state}'=[path to state file]:file:_files' \
  '--confirm[confirm dangerous operations]' \
  '--debug[enable debug output]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'nixops command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      create|modify)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--name=[deployment name]:name' \
          '*:nix expression:_files -g "*.nix"' && ret=0
        ;;
      deploy)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--check[check if deployment is up to date]' \
          '--dry-run[show what would be done]' \
          '--build-only[only build, do not deploy]' \
          '--create-only[only create resources, do not deploy]' \
          '--copy-only[only copy closures, do not activate]' \
          '--dry-activate[activate in dry-run mode]' \
          '--force-reboot[force a reboot after activation]' \
          '--allow-reboot[allow rebooting if needed]' \
          '--allow-recreate[allow destroying and recreating resources]' \
          '--max-concurrent-copy=[max parallel nix-copy-closure]:number' \
          '--include=[only deploy these machines]:machine' \
          '--exclude=[do not deploy these machines]:machine' \
          '(-j --max-jobs)'{-j,--max-jobs}'=[max parallel builds]:number' \
          '--keep-going[keep going on build failure]' \
          '--kill-obsolete[kill machines not in deployment]' && ret=0
        ;;
      destroy)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--include=[only destroy these machines]:machine' \
          '--exclude=[do not destroy these machines]:machine' \
          '--all[destroy all resources]' \
          '--confirm[confirm destruction]' && ret=0
        ;;
      info)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--plain[print in machine-readable format]' \
          '--no-eval[do not evaluate the deployment]' && ret=0
        ;;
      ssh)
        _arguments \
          '1:machine' \
          '*:command' && ret=0
        ;;
      ssh-for-each)
        _arguments \
          '--include=[only these machines]:machine' \
          '--exclude=[exclude these machines]:machine' \
          '--parallel[run in parallel]' \
          '*:command' && ret=0
        ;;
      rollback)
        _arguments \
          '--generation=[generation number to roll back to]:number' && ret=0
        ;;
      delete|clone|rename)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
