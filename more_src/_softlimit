#compdef softlimit
# Documentation: https://man.archlinux.org/search?q=softlimit
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a+[address space limit bytes]:bytes:' \
  '-c+[core file size]:bytes:' \
  '-d+[data segment size]:bytes:' \
  '-f+[file size]:bytes:' \
  '-l+[locked memory]:bytes:' \
  '-m+[same as -a -d -s -l]:bytes:' \
  '-o+[open files]:n:' \
  '-p+[processes]:n:' \
  '-r+[resident set size]:bytes:' \
  '-s+[stack size]:bytes:' \
  '-t+[cpu time]:sec:' \
  '*::cmd:_command_names' && ret=0

return ret
