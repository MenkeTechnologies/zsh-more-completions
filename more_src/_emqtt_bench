#compdef emqtt_bench
# Documentation: https://github.com/emqx/emqtt-bench
# emqtt_bench - lightweight MQTT v5.0 benchmark tool written in Erlang

local ret=1
local -a cmds

cmds=(
  'pub:create clients that publish messages'
  'sub:create clients that subscribe to topics'
  'conn:create a large number of connections'
)

_arguments -s -S \
  '(-h --host)'{-h,--host}'+[MQTT server hostname or IP address]:host:_hosts' \
  '(-p --port)'{-p,--port}'+[MQTT server port number]:port:' \
  '(-c --count)'{-c,--count}'+[max count of clients]:count:' \
  '(-i --interval)'{-i,--interval}'+[interval of connecting to the broker]:ms:' \
  '(-q --qos)'{-q,--qos}'+[QoS level]:qos:(0 1 2)' \
  '(-t --topic)'{-t,--topic}'+[MQTT topic for publishing or subscribing]:topic:' \
  '(-s --size)'{-s,--size}'+[message payload size in bytes]:size:' \
  '(-u --username)'{-u,--username}'+[username for connecting to server]:user:' \
  '(-P --password)'{-P,--password}'+[password for connecting to server]:password:' \
  '(-k --keepalive)'{-k,--keepalive}'+[keep alive in seconds]:n:' \
  '(-C --clean)'{-C,--clean}'+[clean session]:bool:(true false)' \
  '(-S --ssl)'{-S,--ssl}'[enable SSL socket for connecting to server]' \
  '1:command:->cmd' && ret=0

case $state in
  cmd) _describe -t commands 'emqtt_bench command' cmds && ret=0 ;;
esac

return ret
