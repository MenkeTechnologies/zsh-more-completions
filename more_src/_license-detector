#compdef license-detector
# _license-detector — probable-license guesser for code repos (go-enry/go-license-detector)
# upstream: https://github.com/go-enry/go-license-detector
# Flags from cmd/license-detector/main.go (pflag).

_license-detector() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-f --format)'{-f+,--format=}'[output format]:fmt:(json text)' \
        '*:path or URL:_files'
}

_license-detector "$@"
