#compdef sonar
# Documentation: https://man.archlinux.org/search?q=sonar
# Reference accessed: 2026-05-16

_sonar() {
    local line state
    local -a commands
    commands=(
        'kill:Identify and terminate process by port number'
        'list:List everything listening on localhost'
        'info:Get full details about a specific port'
        'open:Open localhost:port in browser'
        'logs:Tail logs for the process on a port'
        'wait:Block until a port is ready'
        'attach:Shell into Docker container or attach to process'
    )

    _arguments -C \
        '--version[Show version]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'sonar command' commands
            ;;
        args)
            case $line[1] in
                list)
                    _arguments '--stats[Fetch CPU/memory usage]' '-a[Include system services]'
                    ;;
                wait)
                    _arguments '--http[Wait for valid HTTP response]'
                    ;;
            esac
            ;;
    esac
}

_sonar "$@"
