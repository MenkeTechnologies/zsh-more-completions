#compdef datasets-cli
# Documentation: https://github.com/huggingface/datasets (src/datasets/commands/datasets_cli.py + test.py)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'env:provide environment information utilities'
  'test:run tests for a dataset'
  'delete_from_hub:delete a dataset (or revision) from the Hugging Face Hub'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'datasets-cli subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      test)
        _arguments \
          '--name=[dataset processing name]:name:' \
          '--cache_dir=[cache directory]:dir:_directories' \
          '--data_dir=[manual directory to get files from]:dir:_directories' \
          '--all_configs[test all dataset configurations]' \
          '--save_info[save dataset info in dataset card (README.md)]' \
          '--save_infos[alias to --save_info]' \
          '--ignore_verifications[run test without checksum/split checks]' \
          '--force_redownload[force dataset redownload]' \
          '--clear_cache[remove downloaded files and cached datasets after each config test]' \
          '--num_proc=[number of processes]:n:' \
          ':dataset name:' && ret=0
        ;;
      delete_from_hub)
        _arguments \
          '--token=[Hugging Face Hub token]:token:' \
          '--revision=[branch/tag to delete]:revision:' \
          ':dataset id:' \
          ':config name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
