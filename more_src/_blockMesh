#compdef blockMesh

# OpenFOAM blockMesh: structured mesh generator from blockMeshDict
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-case[case directory]:dir:_files -/' \
  '-region[mesh region]:region:' \
  '-dict[alternative blockMeshDict]:file:_files' \
  '-blockTopology[output topology only]' \
  '-merge-points[merge close points]:val:' \
  '-noClean[do not delete existing mesh]' \
  '-time[start time directory for mesh]:time:' \
  '*::blockMesh options:_files' && ret=0
return ret
