#compdef gptcommit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--preview[preview the generated commit message without committing]' \
  '--force[force commit without confirmation]' \
  '--model[GPT model to use]:model' \
  '--openai-api-key[OpenAI API key]:key' \
  '--allow[allow list for file patterns]:pattern' \
  '--ignore[ignore list for file patterns]:pattern' \
  '--max-tokens[maximum tokens for the response]:tokens' \
  '--lang[language for the commit message]:language' \
  '--conventional-commit[use conventional commit format]' \
  '--no-confirm[skip confirmation prompt]' \
  '*:file:_files' && ret=0

return ret
