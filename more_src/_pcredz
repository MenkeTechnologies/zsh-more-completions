#compdef Pcredz pcredz
# Documentation: https://github.com/lgandx/PCredz
# Extract credentials and credit cards from pcap files or live interfaces

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-f+[PCAP file to parse]:file:_files' \
  '-d+[directory to parse recursively]:dir:_files -/' \
  '-i+[interface for live capture]:interface:' \
  '-v[verbose mode (print duplicate credentials)]' \
  '-t[print timestamps]' \
  '-o+[output directory for logs]:dir:_files -/' \
  '-c[disable credit card scanning]' \
  '*--disable[disable a protocol]:proto:(NTLM HTTP FTP IRC LDAP SMTP Kerberos SNMP MSSQL)' \
  '*--exclude-host[exclude host IP from capture]:ip:' && ret=0

return ret
