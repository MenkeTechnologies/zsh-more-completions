#compdef urlget
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/urlget.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS urlget: retrieve URL data resource entries
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' \
  '-auto[turn off prompts]' \
  '-stdout[write to stdout]' \
  '-filter[read stdin, write stdout]' \
  '-options[prompt for additional qualifiers]' \
  '-debug[write debug output]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying errors]' \
  '-version[show version]' \
  '-outfile=[output URL filename]:file:_files' \
  '-url=[input URL query filename and optional format]:URL:' \
  '-iformat1=[input URL format]:format:' \
  '-idbname1=[user-provided database name]:dbname:' \
  '-accession1=[primary accession for source data]:accession:' \
  '-identifier1=[identifier term name in EDAM]:identifier:' \
  '-odirectory2=[output directory]:dir:_files -/' \
  '-oformat2=[URL output format]:format:' \
  '*:URL:' && ret=0

return ret
