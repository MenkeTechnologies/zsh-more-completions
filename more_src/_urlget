#compdef urlget

# EMBOSS urlget: retrieve URL data resource entries
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' '-outfile=[output]:file:_files' \
  '-url=[URL or URL data USA]:URL:' \
  '-html[include HTML formatting]' \
  '*:URL:' && ret=0

return ret
