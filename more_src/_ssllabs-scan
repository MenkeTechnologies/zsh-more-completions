#compdef ssllabs-scan-v4 ssllabs-scan

_arguments -s \
  '--api=[API endpoint]:url:' \
  '--verbosity=[verbosity]:level:(error info debug trace)' \
  '--quiet[suppress status output]' \
  '--ignore-mismatch[continue on cert mismatch]' \
  '--json-flat[flat JSON output]' \
  '--hostfile=[file of hosts]:file:_files' \
  '--usecache[accept cached results]' \
  '--grade[host:grade output]' \
  '--hostcheck[fail on resolution error]' \
  '--email=[registered org email]:email:' \
  '(- *)--help[show help]' \
  '*:host:_hosts'
