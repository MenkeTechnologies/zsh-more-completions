#compdef zbctl
# Documentation: https://docs.camunda.io/docs/8.5/apis-tools/cli-client/
# Reference accessed: 2026-05-17
# Verified: Camunda Zeebe zbctl CLI client docs.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'activate:activate jobs'
  'broadcast:broadcast a signal'
  'cancel:cancel a process instance'
  'complete:complete a job'
  'create:create resources (instance, decision, etc.)'
  'deploy:deploy resources from files'
  'evaluate:evaluate decisions'
  'fail:fail a job'
  'generate:generate documentation'
  'publish:publish a message'
  'resolve:resolve an incident'
  'set:set a variable'
  'status:show cluster status'
  'throwError:throw an error for a job'
  'update:update a resource (timeout/retries/variables)'
  'version:show zbctl version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--address=[Zeebe gateway address]:address:' \
  '--audience=[OAuth audience]:audience:' \
  '--authzUrl=[OAuth authorization URL]:url:' \
  '--clientId=[OAuth client id]:id:' \
  '--clientSecret=[OAuth client secret]:secret:' \
  '--clientCache=[OAuth client cache file]:file:_files' \
  '--certPath=[TLS cert]:file:_files' \
  '--insecure[skip TLS verification]' \
  '--host=[gateway host]:host:_hosts' \
  '--port=[gateway port]:port:' \
  '--requestTimeout=[request timeout (ms)]:ms:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zbctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '*::sub:(instance worker)' \
          '--processId=[BPMN process id]:id:' \
          '--variables=[variables JSON]:json:' \
          '--withResult[return data when complete]' \
          '--version=[process version]:n:' && ret=0 ;;
      (deploy)
        _arguments \
          '--resourceName=[explicit resource name]:name:' \
          '*::file:_files -g "*.{bpmn,dmn,form,rpa}"' && ret=0 ;;
      (publish)
        _arguments \
          '*::sub:(message)' \
          '--correlationKey=[correlation key]:key:' \
          '--messageId=[unique message id]:id:' \
          '--ttl=[message TTL]:duration:' \
          '--variables=[variables JSON]:json:' && ret=0 ;;
      (activate)
        _arguments \
          '*::sub:(jobs)' \
          '--maxJobsToActivate=[max jobs]:n:' \
          '--worker=[worker name]:worker:' \
          '--timeout=[job timeout]:duration:' \
          '--fetchVariables=[variables to fetch]:list:' && ret=0 ;;
      (complete|fail|resolve)
        _arguments \
          '*::sub:(job incident)' \
          '--variables=[variables JSON]:json:' \
          '--errorMessage=[error message]:msg:' \
          '--retries=[remaining retries]:n:' && ret=0 ;;
      (cancel)
        _arguments '*::sub:(instance)' && ret=0 ;;
      (broadcast)
        _arguments \
          '*::sub:(signal)' \
          '--variables=[variables JSON]:json:' && ret=0 ;;
      (evaluate)
        _arguments \
          '*::sub:(decision)' \
          '--decisionId=[decision id]:id:' \
          '--decisionKey=[decision key]:key:' \
          '--variables=[input variables JSON]:json:' && ret=0 ;;
      (set)
        _arguments \
          '*::sub:(variables)' \
          '--variables=[variables JSON]:json:' \
          '--local[set as local variables]' && ret=0 ;;
      (update)
        _arguments \
          '*::sub:(job retries timeout variables)' \
          '--retries=[remaining retries]:n:' \
          '--timeout=[job timeout]:duration:' && ret=0 ;;
      (throwError)
        _arguments \
          '*::sub:(job)' \
          '--errorCode=[error code]:code:' \
          '--errorMessage=[error message]:msg:' && ret=0 ;;
    esac ;;
esac

return ret
