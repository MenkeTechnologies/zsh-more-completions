#compdef tsterinfo
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tsterinfo.cpp
# tsterinfo - compute or convert DVB-T terrestrial modulation parameters

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-b --bitrate)'{-b,--bitrate}'=[transport stream bitrate in b/s to guess OFDM params]:bitrate:' \
  '(-c --constellation)'{-c,--constellation}'=[OFDM constellation]:constellation:(QPSK 16-QAM 64-QAM)' \
  '(-d --default-region)'{-d,--default-region}'[display the default UHF/VHF band region]' \
  '(-f --frequency)'{-f,--frequency}'=[carrier frequency in Hz]:hz:' \
  '(-g --guard-interval)'{-g,--guard-interval}'=[OFDM guard interval]:guard:(1/32 1/16 1/8 1/4)' \
  '--high-priority-fec=[OFDM high-priority FEC]:fec:(1/2 2/3 3/4 5/6 7/8)' \
  '(-m --max-guess)'{-m,--max-guess}'=[max number of modulation parameter sets to display]:n:' \
  '(-o --offset-count)'{-o,--offset-count}'=[number of offsets from the channel]:n:' \
  '(-n --region-names)'{-n,--region-names}'[list all known regions with band layout]' \
  '(-s --simple)'{-s,--simple}'[produce simple numeric output for scripts]' \
  '(-u --uhf-channel)'{-u,--uhf-channel}'=[UHF channel number of the carrier]:n:' \
  '(-v --vhf-channel)'{-v,--vhf-channel}'=[VHF channel number of the carrier]:n:' \
  '(-w --bandwidth)'{-w,--bandwidth}'=[bandwidth in Hz (default 8000000)]:hz:' && ret=0

return ret
