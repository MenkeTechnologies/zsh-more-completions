#compdef metalctl
# _metalctl — Metal Stack metalctl official CLI for managing bare-metal-as-a-service infrastructure (metal-stack team, Go); cobra
# upstream: https://github.com/metal-stack/metal-go

_metalctl() {
    local -a sub=(
        'audit:audit log subcommands'
        'completion:generate completion'
        'context:context subcommands'
        'docs:generate docs'
        'filesystemlayout:filesystem layout subcommands'
        'firewall:firewall subcommands'
        'firmware:firmware subcommands'
        'health:show api health'
        'image:image subcommands'
        'ip:ip subcommands'
        'login:authenticate'
        'logout:logout'
        'machine:machine subcommands'
        'network:network subcommands'
        'partition:partition subcommands'
        'project:project subcommands'
        'size:size subcommands'
        'sizeimageconstraint:size image constraint'
        'switch:switch subcommands'
        'tenant:tenant subcommands'
        'user:show user info'
        'version:show version'
        'whoami:show current user'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--api-token=+[token]:str:' \
        '--api-url=+[api url]:url:_urls' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--debug[debug]' \
        '--force-color[force color]' \
        '--no-headers[no headers]' \
        '-o+[format]:f:(table wide markdown json yaml)' \
        '--output-format=+[format]:f:(table wide markdown json yaml)' \
        '--order=+[order field]:str:' \
        '--template=+[go template]:str:' \
        '--yes-i-really-mean-it[non-interactive confirm]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'metalctl subcommand' sub ;;
        args)
            case $words[1] in
                machine) _arguments '1:machine cmd:(create describe list issues remove update logs console power reset on off cycle bootbios bootdisk bootpxe ipmi consolepassword update-firmware reinstall edit lock reserve)' ;;
                firewall) _arguments '1:firewall cmd:(create describe list logs ssh remove)' ;;
                project|tenant|partition|switch|size|image|network|ip|filesystemlayout|firmware|sizeimageconstraint) _arguments '1:cmd:(create describe list update remove)' ;;
                context) _arguments '1:context cmd:(list set current)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_metalctl "$@"
