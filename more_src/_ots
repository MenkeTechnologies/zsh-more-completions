#compdef ots opentimestamps-client
# Documentation: https://man.archlinux.org/search?q=ots
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'stamp:create timestamps for files'
  'upgrade:upgrade incomplete timestamps to complete'
  'verify:verify a timestamp'
  'info:show timestamp info'
  'git-extract:extract a timestamp from git history'
  'git-gpg-sign:add timestamps to GPG signatures'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-l --logfile)'{-l,--logfile}'+[log file]:file:_files' \
  '--no-default-whitelist[no default whitelist]' \
  '--no-bitcoin[do not connect to a Bitcoin node]' \
  '--bitcoin-node=[Bitcoin node]:url:' \
  '--socks5-proxy=[SOCKS5 proxy]:host\:port:' \
  '--no-cache[disable cache]' \
  '--cache=[cache directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ots command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (stamp)
        _arguments \
          '-c+[calendar URL]:url:' \
          '-m+[min calendars]:n:' \
          '*:file:_files' && ret=0 ;;
      (upgrade|verify|info)
        _arguments '*:file:_files -g "*.ots"' && ret=0 ;;
    esac ;;
esac

return ret
