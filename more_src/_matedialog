#compdef matedialog
# Documentation: https://man.archlinux.org/search?q=matedialog
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--calendar[calendar dialog]' \
  '--entry[text entry]' \
  '--error[error dialog]' \
  '--info[info dialog]' \
  '--file-selection[file selection dialog]' \
  '--list[list dialog]' \
  '--notification[notification icon]' \
  '--progress[progress dialog]' \
  '--question[question dialog]' \
  '--warning[warning dialog]' \
  '--scale[scale dialog]' \
  '--text-info[text info]' \
  '--password[password]' \
  '--color-selection[color selection]' \
  '--forms[forms dialog]' \
  '--title=+[title]:title:' \
  '--window-icon=+[icon]:file:_files' \
  '--width=+[width]:n:' \
  '--height=+[height]:n:' \
  '--text=+[text]:text:' \
  '--ok-label=+[ok label]:label:' \
  '--cancel-label=+[cancel label]:label:' \
  '--timeout=+[timeout sec]:sec:' \
  '--icon-name=+[icon name]:name:' \
  '--display=+[X display]:disp:' && ret=0

return ret
