#compdef gvisor-cli runsc-cli
# _gvisor-cli — Google gVisor runsc sandbox runtime CLI alias (Google, Go); custom argparse
# upstream: https://github.com/google/gvisor

_gvisor-cli() {
    local -a sub=(
        'checkpoint:checkpoint container'
        'create:create container'
        'delete:delete container'
        'do:run command in new sandbox'
        'events:get container events'
        'exec:exec command in container'
        'gofer:run gofer host process'
        'install:install gvisor as docker runtime'
        'kill:kill container'
        'list:list containers'
        'pause:pause container'
        'ps:list processes in container'
        'restore:restore container'
        'resume:resume container'
        'run:create and run container'
        'spec:generate config.json template'
        'start:start container'
        'state:show container state'
        'wait:wait for container'
        'symbolize:symbolize trace'
        'mitigate:run mitigations'
        'verity-prepare:prepare verity image'
        'syscalls:print supported syscalls'
        'debug:debug info'
        'usage:show resource usage'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--rootless[rootless]' \
        '--root=+[root dir]:dir:_files -/' \
        '--log=+[log file]:file:_files' \
        '--log-format=+[log format]:fmt:(text json json-k8s)' \
        '--debug[debug]' \
        '--strace[strace]' \
        '--strace-syscalls=+[syscalls to strace]:list:' \
        '--strace-log-size=+[strace log size]:n:' \
        '--platform=+[platform]:p:(systrap kvm ptrace nginx)' \
        '--network=+[network]:n:(sandbox host none)' \
        '--file-access=+[file access]:m:(exclusive shared)' \
        '--fsgofer-host-uds[gofer host uds]' \
        '--overlay[enable overlay]' \
        '--overlay2=+[overlay 2 options]:str:' \
        '--watchdog-action=+[watchdog action]:a:(log panic)' \
        '--profile-block=+[profile block file]:file:_files' \
        '--profile-cpu=+[cpu profile file]:file:_files' \
        '--profile-heap=+[heap profile file]:file:_files' \
        '--profile-mutex=+[mutex profile file]:file:_files' \
        '--trace=+[trace file]:file:_files' \
        '--metrics=+[metrics endpoint]:str:' \
        '--debug-log=+[debug log file]:file:_files' \
        '--debug-log-format=+[debug log format]:fmt:(text json)' \
        '--vfs2[enable vfs2]' \
        '--lisafs[enable lisafs]' \
        '--rootless=+[rootless]:b:(true false)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gvisor subcommand' sub ;;
        args)
            case $words[1] in
                run|create) _arguments \
                    '--bundle=+[bundle dir]:dir:_files -/' \
                    '-b+[bundle dir]:dir:_files -/' \
                    '--console-socket=+[console socket]:file:_files' \
                    '--pid-file=+[pid file]:file:_files' \
                    '--detach[detach]' \
                    '-d[detach]' \
                    '*:container-id:' ;;
                exec) _arguments \
                    '--process=+[process spec file]:file:_files' \
                    '-p+[process spec file]:file:_files' \
                    '--console-socket=+[console socket]:file:_files' \
                    '--cwd=+[cwd]:dir:_files -/' \
                    '--env=+[env]:list:' \
                    '-e+[env]:list:' \
                    '--tty[tty]' \
                    '-t[tty]' \
                    '--user=+[user]:str:_users' \
                    '-u+[user]:str:_users' \
                    '--detach[detach]' \
                    '-d[detach]' \
                    '*:container-id-and-cmd:' ;;
                delete|kill|pause|resume|start|state|wait|ps|events|spec|list|symbolize|debug|usage) _arguments '*:container-id:' ;;
                checkpoint) _arguments \
                    '--image-path=+[image path]:dir:_files -/' \
                    '*:container-id:' ;;
                restore) _arguments \
                    '--image-path=+[image path]:dir:_files -/' \
                    '--bundle=+[bundle dir]:dir:_files -/' \
                    '-b+[bundle dir]:dir:_files -/' \
                    '*:container-id:' ;;
                install) _arguments \
                    '--runtime=+[runtime name]:str:' \
                    '--config-file=+[config file]:file:_files' \
                    '--runtime-arg=+[runtime arg]:list:' ;;
            esac
            ;;
    esac
}

_gvisor-cli "$@"
