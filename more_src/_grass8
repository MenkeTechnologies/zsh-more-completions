#compdef grass8 grass
# Documentation: https://github.com/OSGeo/grass/blob/main/lib/init/grass.py
# Reference accessed: 2026-05-27
# Verified: upstream lib/init/grass.py parse_cmdline / help_message

# Zsh completion for GRASS GIS 8.x launcher

_arguments -s -S \
  '(- *)'{-h,--help}'[print help message]' \
  '(- *)'{-v,--version}'[show version information and exit]' \
  '--text[use text-based interface (skip graphical welcome screen)]' \
  '--gtext[use text-based interface (show graphical welcome screen)]' \
  '--gui[use default graphical user interface]' \
  '-c[create the given database, project or mapset if it does not exist]:CRS (EPSG\:code | geofile | XY):' \
  '-e[exit after creation of project or mapset (requires -c)]' \
  '(-f --force-remove-lock)'{-f,--force-remove-lock}'[force removal of .gislock if it exists (text mode only)]' \
  '--tmp-project=[create a temporary project]:CRS (EPSG\:code | geofile | XY):' \
  '--tmp-location=[deprecated alias for --tmp-project]:CRS (EPSG\:code | geofile | XY):' \
  '--tmp-mapset=[create a temporary mapset in the specified project]:project path:_directories' \
  '--exec[execute a GRASS module or script with the remaining arguments]:executable:_files' \
  '--config[print GRASS configuration parameter(s)]:param:(arch build compiler date path python_path revision svn_revision version)' \
  '--timeout=[mapset locking timeout in seconds (default 30)]:seconds:' \
  '*:GISDBASE/PROJECT/MAPSET or geofile:_files'
