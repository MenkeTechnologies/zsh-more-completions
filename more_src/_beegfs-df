#compdef beegfs-df
# Documentation: https://doc.beegfs.io/latest/
# Reference accessed: 2026-05-17
# Verified: BeeGFS docs (beegfs-df is a wrapper around beegfs-ctl).
# Removed from prior file: bogus man.archlinux.org search URL;
# duplicate -h definition (both --help and -h human readable); -p flag
# is not in upstream.

# beegfs-df: BeeGFS free space / inode reporter (beegfs-ctl wrapper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--cfgFile=[client config file]:file:_files' \
  '--mount=[BeeGFS mount point]:dir:_files -/' \
  '--nodetype=[node type]:type:(management metadata storage client)' \
  '--hidenodeid[do not show node IDs]' \
  '--pools[show storage pools]' \
  '--listtargets[list storage targets]' \
  '--spaceinfo[show space info]' \
  '--logLevel=[client config logLevel override]:n:' && ret=0
return ret
