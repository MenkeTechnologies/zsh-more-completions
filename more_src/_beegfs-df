#compdef beegfs-df
# Documentation: https://man.archlinux.org/search?q=beegfs-df
# Reference accessed: 2026-05-16

# beegfs-df: BeeGFS disk usage stats
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-p[show storage pool info]' \
  '-h[human readable]' \
  '--mount=[BeeGFS mount point]:dir:_files -/' \
  '*::beegfs-df args:_files' && ret=0
return ret
