#compdef victoria-metrics

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--storageDataPath=[data directory]:path:_files -/' \
  '--retentionPeriod=[data retention period]:period' \
  '--httpListenAddr=[HTTP listen address]:address' \
  '--maxLabelsPerTimeseries=[max labels per timeseries]:count' \
  '--search.maxUniqueTimeseries=[max unique timeseries per search]:count' \
  '--search.maxQueryDuration=[max query duration]:duration' \
  '--search.maxConcurrentRequests=[max concurrent search requests]:count' \
  '--search.maxPointsPerTimeseries=[max points per timeseries]:count' \
  '--search.maxSeries=[max series per search]:count' \
  '--search.cacheTimestampOffset=[cache timestamp offset]:duration' \
  '--dedup.minScrapeInterval=[minimum scrape interval for dedup]:duration' \
  '--promscrape.config=[Prometheus scrape config file]:config file:_files' \
  '--promscrape.configCheckInterval=[config check interval]:duration' \
  '--graphiteListenAddr=[Graphite listen address]:address' \
  '--opentsdbListenAddr=[OpenTSDB listen address]:address' \
  '--influxListenAddr=[InfluxDB listen address]:address' \
  '--loggerLevel=[log level]:level:(INFO WARN ERROR FATAL PANIC)' \
  '--loggerFormat=[log format]:format:(default json)' \
  '--loggerOutput=[log output]:output:(stderr stdout)' \
  '--tls[enable TLS for incoming requests]' \
  '--tlsCertFile=[TLS certificate file]:cert file:_files' \
  '--tlsKeyFile=[TLS key file]:key file:_files' \
  '--envflag.enable[enable reading flags from environment variables]' \
  '--envflag.prefix=[environment variable prefix]:prefix' \
  '--fs.disableMmap[disable mmap for data files]' \
  '--dryRun[dry run to check configuration]'
