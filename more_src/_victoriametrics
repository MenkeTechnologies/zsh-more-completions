#compdef victoria-metrics
# Documentation: https://docs.victoriametrics.com/victoriametrics/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (single-server flags).
# Go flag package: single-dash, both -flag value and -flag=value accepted.
# Subset of well-known flags; use `victoria-metrics -help` for the full list.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-storageDataPath=[directory for storing all data]:path:_files -/' \
  '-retentionPeriod=[data retention period]:duration:' \
  '-httpListenAddr=[HTTP listen address]:address:' \
  '-search.maxExportDuration=[max duration for export requests]:duration:' \
  '-search.maxExportSeries=[max series for export]:n:' \
  '-search.maxTagKeys=[max label names to return]:n:' \
  '-search.maxTagValues=[max label values to return]:n:' \
  '-search.maxSeries=[max series in responses]:n:' \
  '-search.maxDeleteSeries=[limit for delete operations]:n:' \
  '-search.latencyOffset=[hide recent samples from queries]:duration:' \
  '-search.queryStats.lastQueriesCount=[query stats track count]:n:' \
  '-search.queryStats.minQueryDuration=[min query duration to track]:duration:' \
  '-dedup.minScrapeInterval=[deduplication setting]:duration:' \
  '-promscrape.config=[path to Prometheus scrape config]:file:_files' \
  '-promscrape.config.strictParse[enforce strict config parsing]' \
  '-metricsAuthKey=[auth key for metrics]:key:' \
  '-deleteAuthKey=[protection for delete endpoint]:key:' \
  '-forceMergeAuthKey=[protection for force merge endpoint]:key:' \
  '-forceFlushAuthKey=[protection for force flush endpoint]:key:' \
  '-loggerFormat=[log format]:format:(default json)' \
  '-loggerOutput=[log output]:output:(stderr stdout)' \
  '-envflag.enable[allow setting flags via environment]' \
  '-envflag.prefix=[env var prefix]:prefix:' \
  '-snapshotsMaxAge=[auto-delete old snapshots]:duration:' \
  '-import.maxLineLen=[max JSON line length for imports]:bytes:' \
  '-dryRun[validate configuration without starting]'
