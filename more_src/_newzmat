#compdef newzmat
# Documentation: https://gaussian.com/newzmat/
# Convert between molecular geometry formats (Z-matrix, Cartesian, PDB, MOPAC, checkpoint)

local ret=1

_arguments -s -S \
  '-m[memory to allocate (must precede other arguments)]:amount' \
  '-izmat[input Z-matrix format]' \
  '-ozmat[output Z-matrix format]' \
  '-icart[input Cartesian coordinates]' \
  '-ocart[output Cartesian coordinates]' \
  '-ichk[input Gaussian checkpoint]' \
  '-ochk[output Gaussian checkpoint]' \
  '-ipdb[input Protein Data Bank format]' \
  '-opdb[output Protein Data Bank format]' \
  '-imopac[input MOPAC format]' \
  '-omopac[output MOPAC format]' \
  '-ient[input Brookhaven format]' \
  '-oent[output Brookhaven format]' \
  '-ixyz[input XYZ Cartesian coordinates]' \
  '-oxyz[output XYZ Cartesian coordinates]' \
  '-ngeom[use geometry from Nth checkpoint structure]:N' \
  '-ot[extract multiple structures (e.g. 3,7 or 2-5)]:list' \
  '-step[use structure from step N of optimization]:N' \
  '-ubohr[input distances in Bohr]' \
  '-urad[input angles in radians]' \
  '-prompt[prompt for route, title, charge, multiplicity]' \
  '-optprompt[prompt for parameters to optimize]' \
  '-qmul[Mulliken charges]' \
  '-qesp[ESP-fit charges]' \
  '-qaim[AIM charges]' \
  '-qnpa[NPA charges]' \
  '*:file:_files' && ret=0

return ret
