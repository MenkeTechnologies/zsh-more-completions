#compdef hdfcomp
# Documentation: https://manpages.debian.org/testing/hdf4-tools/hdfcomp.1.en.html
# Compress RIS8 HDF files into a single output file

local ret=1

_arguments -s \
  '*-c[run-length encoding compression for following input]' \
  '*-i[IMCOMP compression for following input]' \
  '*-r[no compression for following input (default)]' \
  '*:hdf file:_files -g "*.(hdf|h4)"' && ret=0

return ret
