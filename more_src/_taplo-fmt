#compdef taplo-fmt

local curcontext="$curcontext" state line ret=1

(( $+functions[_taplo] )) || autoload -Uz _taplo 2>/dev/null
if (( $+functions[_taplo] )); then
  _taplo "$@"
  return
fi

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--check[check if files are formatted]' \
  '--config=[config file]:file:_files -g "*.toml"' \
  '*:TOML file:_files -g "*.toml"' && ret=0

return ret
