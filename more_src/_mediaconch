#compdef mediaconch

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--policy[policy file]:file:_files -g "*.xml(|.xsl)"' \
  '--display[display file]:file:_files' \
  '--format[output format]:format:(text xml maxml html csv)' \
  '--implementationverbosity[verbosity level]:level:' \
  '--force[force parsing]' \
  '--full[full analysis]' \
  '--list[list policies]' \
  '--file[file to analyze]:file:_files' \
  '-mi[MediaInfo output]' \
  '-mt[MediaTrace output]' \
  '--plugins[plugins path]:directory:_directories' \
  '*:files:_files' \
  && ret=0

return ret
