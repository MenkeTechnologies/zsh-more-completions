#compdef pacemaker-based
# Documentation: https://man.archlinux.org/search?q=pacemaker-based
# Reference accessed: 2026-05-16

# Pacemaker CIB (cluster info base) subdaemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-$,--version}'[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '*::pacemaker-based args:_files' && ret=0
return ret
