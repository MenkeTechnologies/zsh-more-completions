#compdef pikepdf
# _pikepdf — James R. Barlow pikepdf Python CLI wrapping QPDF for PDF inspection optimization linearization decryption encryption page extraction and metadata editing (pikepdf team, Python); argparse
# upstream: https://github.com/pikepdf/pikepdf

_pikepdf() {
    local -a sub=(
        'info:show PDF info'
        'extract-pages:extract pages'
        'extract-images:extract images'
        'reduce-size:reduce file size'
        'merge:merge PDFs'
        'split:split PDF'
        'linearize:linearize PDF'
        'encrypt:encrypt PDF'
        'decrypt:decrypt PDF'
        'sign:sign PDF'
        'verify:verify signature'
        'remove-metadata:strip metadata'
        'edit-metadata:edit metadata'
        'compress:compress streams'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pikepdf subcommand' sub ;;
        args)
            case $words[1] in
                extract-pages|extract-images|reduce-size|linearize|compress) _arguments \
                    '-o+[output]:file:_files -g "*.pdf"' \
                    '--output=+[output]:file:_files -g "*.pdf"' \
                    '--pages=+[range]:str:' \
                    '--password=+[password]:str:' \
                    '*:input PDF:_files -g "*.pdf"' ;;
                encrypt) _arguments \
                    '--owner=+[password]:str:' \
                    '--user=+[password]:str:' \
                    '--R=+[N]:n:(2 3 4 5 6)' \
                    '--allow-print[allow print]' \
                    '--allow-modify[allow modify]' \
                    '--allow-extract[allow extract]' \
                    '--allow-annotate[allow annotate]' \
                    '--allow-form[allow form]' \
                    '*:input output:_files -g "*.pdf"' ;;
                decrypt) _arguments \
                    '--password=+[password]:str:' \
                    '*:input output:_files -g "*.pdf"' ;;
                merge|split) _arguments \
                    '-o+[output]:file:_files' \
                    '*:input files:_files -g "*.pdf"' ;;
                info) _arguments '*:PDF file:_files -g "*.pdf"' ;;
            esac
            ;;
    esac
}

_pikepdf "$@"
