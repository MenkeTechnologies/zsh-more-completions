#compdef spdx-tools
# _spdx-tools — Linux Foundation SPDX tools CLI (SPDX Working Group, Java); validate, convert, compare SPDX documents
# upstream: https://github.com/spdx/tools-java

_spdx-tools() {
    local -a sub=(
        'Convert:convert SPDX between formats'
        'Verify:verify SPDX file'
        'CompareSpdxDocs:compare two SPDX docs'
        'RDFToSpreadsheet:RDF -> XLSX'
        'SpreadsheetToRDF:XLSX -> RDF'
        'RDFToTagValue:RDF -> tag/value'
        'TagToRDF:tag/value -> RDF'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spdx-tools subcommand' sub ;;
    esac
}

_spdx-tools "$@"
