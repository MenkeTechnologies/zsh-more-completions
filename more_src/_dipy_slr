#compdef dipy_slr
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_slr.html
# DIPY: streamline-based linear registration (SLR)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--x0=[transformation model]:model:(rigid similarity affine)' \
  '--rm_small_clusters=[minimum cluster size threshold]:n' \
  '--qbx_thr=[QuickBundlesX thresholds]:thr' \
  '--num_threads=[OpenMP thread count]:n' \
  '--greater_than=[minimum streamline length]:len' \
  '--less_than=[maximum streamline length]:len' \
  '--nb_pts=[streamline discretization points]:n' \
  '--progressive=[enable progressive registration]:bool:(True False)' \
  '--bbox_valid_check=[verify voxel coordinates]:bool:(True False)' \
  '--remove_invalid_streamlines=[remove out-of-bounds streamlines]:bool:(True False)' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_moved=[moved tractogram filename]:file:_files' \
  '--out_affine=[affine transformation filename]:file:_files' \
  '--out_stat_centroids=[static centroids filename]:file:_files' \
  '--out_moving_centroids=[moving centroids filename]:file:_files' \
  '--out_moved_centroids=[moved centroids filename]:file:_files' \
  '*:input (static moving):_files' && ret=0

return ret
