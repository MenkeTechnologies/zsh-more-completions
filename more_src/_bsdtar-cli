#compdef bsdtar-cli
# _bsdtar-cli — libarchive bsdtar BSD tar implementation CLI alias (libarchive team, C); custom argparse
# upstream: https://github.com/libarchive/libarchive

_bsdtar-cli() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-c[create new archive]' \
        '--create[create new archive]' \
        '-r[append to archive]' \
        '--append[append to archive]' \
        '-t[list archive contents]' \
        '--list[list archive contents]' \
        '-u[update archive]' \
        '--update[update archive]' \
        '-x[extract from archive]' \
        '--extract[extract from archive]' \
        '-f+[archive file]:file:_files' \
        '--file=+[archive file]:file:_files' \
        '-C+[change directory]:dir:_files -/' \
        '--directory=+[change directory]:dir:_files -/' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-z[gzip]' \
        '--gunzip[gzip]' \
        '--gzip[gzip]' \
        '-j[bzip2]' \
        '--bunzip2[bzip2]' \
        '--bzip2[bzip2]' \
        '-J[xz]' \
        '--xz[xz]' \
        '--lzma[lzma]' \
        '--lz4[lz4]' \
        '--zstd[zstd]' \
        '--lzip[lzip]' \
        '--lzop[lzop]' \
        '-a[auto-detect compression]' \
        '--auto-compress[auto-detect compression]' \
        '-T+[file list]:file:_files' \
        '--files-from=+[file list]:file:_files' \
        '-X+[exclude file]:file:_files' \
        '--exclude-from=+[exclude file]:file:_files' \
        '--exclude=+[pattern]:str:' \
        '--include=+[pattern]:str:' \
        '-W[arg]' \
        '--option=+[option]:str:' \
        '-l[follow symbolic links]' \
        '--check-links[follow symbolic links]' \
        '--strip-components=+[count]:n:' \
        '--newer=+[date]:str:' \
        '--newer-mtime=+[date]:str:' \
        '--older=+[date]:str:' \
        '--older-mtime=+[date]:str:' \
        '-y[bzip2]' \
        '-p[preserve permissions]' \
        '-q[stop after first match]' \
        '--no-recursion[no recursion]' \
        '--null[input is null-separated]' \
        '--keep-newer-files[keep newer files]' \
        '-S[handle sparse files]' \
        '--sparse[handle sparse files]' \
        '--totals[totals after operation]' \
        '-P[absolute paths]' \
        '--absolute-paths[absolute paths]' \
        '--acls[include acls]' \
        '--xattrs[include xattrs]' \
        '--mac-metadata[include mac metadata]' \
        '-O[output to stdout]' \
        '--to-stdout[output to stdout]' \
        '--format=+[format]:f:(ar cpio mtree pax shar shar dump tar ustar v7tar gnutar oldtar paxr restore xar zip 7zip iso9660 raw)' \
        '*:files:_files'
}

_bsdtar-cli "$@"
