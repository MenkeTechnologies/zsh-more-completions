#compdef dotslash

# Zsh completion for dotslash (portable executable scripts)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'build-manifest:build a DotSlash manifest'
      'cache:manage the DotSlash cache'
      'clean:clean the cache'
      'create-url-entry:create a URL entry for a manifest'
      'fetch:fetch an artifact'
      'parse:parse a DotSlash file'
      'sha256:compute SHA-256 hash'
    )
    _describe -t commands 'dotslash command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (cache)
        _arguments '1:action:(clean info)' && ret=0
        ;;
      (fetch)
        _arguments '1:dotslash file:_files' && ret=0
        ;;
      (parse)
        _arguments '1:dotslash file:_files' && ret=0
        ;;
      (sha256)
        _arguments '1:file:_files' && ret=0
        ;;
      (create-url-entry)
        _arguments \
          '--format[output format]:format:(json toml)' \
          '1:url' && ret=0
        ;;
    esac
    ;;
esac

return ret
