#compdef tfmigrate
# Documentation: https://man.archlinux.org/search?q=tfmigrate
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      plan:'show migration plan'
      apply:'apply state migration'
      get:'get remote state'
      hcl2json:'convert HCL to JSON'
      version:'print version'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
