autoload -U is-at-least

_envcheck() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_envcheck_commands" \
"*::: :->envcheck" \
&& ret=0
    case $state in
    (envcheck)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:envcheck-command-$line[1]:"
        case $line[1] in
            (lint)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'*::files:_files' \
&& ret=0
;;
(fix)
_arguments "${_arguments_options[@]}" : \
'--commit[Auto-commit fixes to current branch]' \
'--pr[Create a PR with fixes (requires gh CLI)]' \
'-h[Print help]' \
'--help[Print help]' \
'*::files:_files' \
&& ret=0
;;
(compare)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'*::files -- Reference file (e.g. .env.example):_files' \
&& ret=0
;;
(k8s-sync)
_arguments "${_arguments_options[@]}" : \
'--env=[The .env file to check against]:ENV:_files' \
'-h[Print help]' \
'--help[Print help]' \
'*::manifests -- K8s manifest files or glob patterns:_default' \
&& ret=0
;;
(terraform)
_arguments "${_arguments_options[@]}" : \
'-e+[Path to .env file]:ENV:_files' \
'--env=[Path to .env file]:ENV:_files' \
'-h[Print help]' \
'--help[Print help]' \
'::dir -- Directory to scan for .tf files:_files' \
&& ret=0
;;
(ansible)
_arguments "${_arguments_options[@]}" : \
'-e+[Path to .env file]:ENV:_files' \
'--env=[Path to .env file]:ENV:_files' \
'-h[Print help]' \
'--help[Print help]' \
'::dir -- Directory to scan for Ansible files:_files' \
&& ret=0
;;
(actions)
_arguments "${_arguments_options[@]}" : \
'-e+[Path to .env file]:ENV:_files' \
'--env=[Path to .env file]:ENV:_files' \
'-h[Print help]' \
'--help[Print help]' \
'::dir -- Directory to scan for workflow files (defaults to .github/workflows if exists, else .):_files' \
&& ret=0
;;
(helm)
_arguments "${_arguments_options[@]}" : \
'-e+[Path to .env file]:ENV:_files' \
'--env=[Path to .env file]:ENV:_files' \
'-h[Print help]' \
'--help[Print help]' \
'::dir -- Directory to scan for values.yaml files:_files' \
&& ret=0
;;
(argo)
_arguments "${_arguments_options[@]}" : \
'-e+[Path to .env file]:ENV:_files' \
'--env=[Path to .env file]:ENV:_files' \
'-h[Print help]' \
'--help[Print help]' \
'::dir -- Directory to scan for Application manifests:_files' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(tui)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'*::files -- .env files to compare:_files' \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_envcheck__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:envcheck-help-command-$line[1]:"
        case $line[1] in
            (lint)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(fix)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(compare)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(k8s-sync)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(terraform)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(ansible)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(actions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(helm)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(argo)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(tui)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_envcheck_commands] )) ||
_envcheck_commands() {
    local commands; commands=(
'lint:Lint .env files' \
'fix:Fix .env files (sort keys, remove whitespace)' \
'compare:Compare .env files' \
'k8s-sync:Detect mismatches between K8s manifests and .env files' \
'terraform:Check Terraform variables' \
'ansible:Check Ansible playbooks' \
'actions:Check GitHub Actions workflows' \
'helm:Check Helm Chart values' \
'argo:Check ArgoCD Application manifests' \
'completions:Generate shell completions' \
'tui:Interactive TUI for comparing .env files' \
'doctor:Lint all .env files in the current directory' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'envcheck commands' commands "$@"
}
