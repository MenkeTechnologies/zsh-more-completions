#compdef git-sweep
# _git-sweep — arc90/git-sweep (find local branches whose tips have been merged into a base ref and delete them; preview/cleanup subcommands, --master picks base ref, --skip protects branches, --force deletes unmerged ones)
# upstream: https://github.com/arc90/git-sweep
# Subcommands from git-sweep cli.py on tip.

_git-sweep() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--nofetch[skip git fetch]' \
        '--force[force delete unmerged]' \
        '--master+[base branch]:branch:' \
        '--origin+[remote]:remote:' \
        '--skip+[branches to skip (comma list)]:branches:' \
        '1:command:(preview cleanup)'
}

_git-sweep "$@"
