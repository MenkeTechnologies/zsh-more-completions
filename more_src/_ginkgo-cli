#compdef ginkgo
# _ginkgo-cli — Ginkgo BDD testing framework for Go (Onsi Fakhouri); flake-detection, parallel test runs
# upstream: https://github.com/onsi/ginkgo

_ginkgo-cli() {
    local -a sub=(
        'bootstrap:generate bootstrap file'
        'build:build all test binaries'
        'generate:generate spec file'
        'help:show help'
        'labels:print used labels'
        'outline:print outline of spec tree'
        'run:run specs (default)'
        'unfocus:strip Focus tags from spec'
        'watch:run + watch'
        'version:show version'
        'tags:print build tags'
        'docs:open ginkgo docs'
        'precompile:precompile suites'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ginkgo subcommand' sub ;;
        args)
            case $words[1] in
                run|watch) _arguments \
                    '-r[recurse]' \
                    '-p[parallel]' \
                    '-procs+[parallel proc count]:n:' \
                    '-trace[show full trace on failure]' \
                    '-race[run with race detector]' \
                    '-cover[generate coverage]' \
                    '-coverprofile+[coverage file]:file:_files' \
                    '-coverpkg+[cover packages]:pkgs:' \
                    '-covermode+[cover mode]:mode:(set count atomic)' \
                    '-timeout+[timeout]:duration:' \
                    '-poll-progress-after+[poll progress after]:duration:' \
                    '-poll-progress-interval+[poll progress interval]:duration:' \
                    '-randomize-all[randomize all specs]' \
                    '-randomize-suites[randomize suites]' \
                    '-fail-fast[stop on first failure]' \
                    '-fail-on-pending[fail on pending specs]' \
                    '-keep-going[keep going after fail]' \
                    '-flake-attempts+[flake attempts]:n:' \
                    '-no-color[no color]' \
                    '-output-dir+[output dir]:dir:_files -/' \
                    '-junit-report+[junit output]:file:_files' \
                    '-json-report+[json output]:file:_files' \
                    '-teamcity-report+[teamcity output]:file:_files' \
                    '-focus+[focus regex]:regex:' \
                    '-skip+[skip regex]:regex:' \
                    '-focus-file+[focus file]:file:_files' \
                    '-skip-file+[skip file]:file:_files' \
                    '-label-filter+[label filter]:filter:' \
                    '-vv[verbose]' \
                    '-v[verbose]' \
                    '-succinct[succinct]' \
                    '*:dirs:_files -/' ;;
                generate|bootstrap) _arguments '*:name:' ;;
                build) _arguments '-r[recurse]' '*:dirs:_files -/' ;;
            esac
            ;;
    esac
}

_ginkgo-cli "$@"
