#compdef nsq_stat

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-version[show version]' \
  '-topic=[NSQ topic]:topic:' \
  '-channel=[NSQ channel]:channel:' \
  '*-nsqd-http-address=[nsqd HTTP address (repeatable)]:address:' \
  '*-lookupd-http-address=[lookupd HTTP address (repeatable)]:address:' \
  '-status-every=[poll interval]:duration:' \
  '-count=[number of polls before exiting]:n:' \
  '-http-client-connect-timeout=[HTTP connect timeout]:duration:' \
  '-http-client-request-timeout=[HTTP request timeout]:duration:' && ret=0

return ret
