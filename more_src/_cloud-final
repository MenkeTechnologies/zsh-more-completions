#compdef cloud-final
# Documentation: https://docs.cloud-init.io/en/latest/reference/cli.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cloud-init "final" stage runs runcmd / scripts-user / package upgrades
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-d[debug]' \
  '--debug[debug]' \
  '--force[run regardless of cloud-init disabled file]' \
  '*::cloud-init args:_files' && ret=0
return ret
