#compdef normcap
# Documentation: https://github.com/dynobo/normcap/blob/main/normcap/argparser.py
# OCR-powered screen-capture tool to capture text instead of images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --color)'{-c,--color}'=[set primary color for UI, e.g. #FF2E88]:color' \
  '(-l --language)'{-l,--language}'=[set language(s) for text recognition, e.g. eng deu]:language' \
  '--parse-text=[parse and format detected text]:parse:(True False)' \
  '--detect-codes=[detect barcodes and QR codes]:detect:(True False)' \
  '--detect-text=[detect text using ocr]:detect:(True False)' \
  '(-n --notification)'{-n,--notification}'=[enable notification after ocr detection]:notify:(True False)' \
  '(-t --tray)'{-t,--tray}'=[enable system tray]:tray:(True False)' \
  '(-u --update)'{-u,--update}'=[enable check for updates]:update:(True False)' \
  '--show-introduction=[show introductional screen on start]:intro:(True False)' \
  '--reset[reset all settings to default values]' \
  '(-v --verbosity)'{-v,--verbosity}'=[set level of detail for console output]:level:(error warning info debug)' \
  '--log-file=[save console output to a file]:file:_files' \
  '--version[print NormCap version and exit]' \
  '--cli-mode[print text after detection to stdout and exit immediately]' \
  '--background-mode[start minimized to tray, without capturing]' \
  '--screenshot-handler=[force using specific screenshot handler]:handler' \
  '--clipboard-handler=[force using specific clipboard handler]:handler' \
  '--notification-handler=[force using specific notification handler]:handler' && ret=0

return ret
