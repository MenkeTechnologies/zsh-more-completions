#compdef fabio
# Documentation: https://man.archlinux.org/search?q=fabio
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '(-cfg -config)'{-cfg,-config}'=[Config file or URL]:file:_files' \
  '(-proxy.addr)'--proxy.addr+'[Proxy listen address]:addr:' \
  '(-ui.addr)'--ui.addr+'[UI listen address]:addr:' \
  '-dryrun[Print configuration and exit]' \
  '*::args: _default'
