#compdef emacs-nox

# emacs-nox: terminal-only Emacs build (no X support compiled in)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-q[skip user init file]' \
  '-Q[skip site/init files and splash]' \
  '--no-init-file[skip user init file]' \
  '--no-site-file[skip site-start.el]' \
  '--no-splash[skip startup splash]' \
  '--debug-init[debug init errors]' \
  '-u[load init from named user]:user:_users' \
  '-l[load Emacs Lisp file]:file:_files -g "*.el"' \
  '--load=[load Emacs Lisp file]:file:_files -g "*.el"' \
  '-L[prepend dir to load-path]:dir:_files -/' \
  '--directory=[load-path entry]:dir:_files -/' \
  '-f[call Emacs Lisp function]:function:' \
  '--funcall=[call Emacs Lisp function]:function:' \
  '--eval=[evaluate Emacs Lisp expression]:expr:' \
  '--execute=[evaluate Emacs Lisp expression]:expr:' \
  '--batch[batch mode]' \
  '--script[batch script mode]:file:_files' \
  '--daemon=[start server with name]:name:' \
  '*:file to edit:_files' && ret=0
return ret
