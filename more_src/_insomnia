#compdef insomnia

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'export:export data'
      'generate:generate configuration'
      'lint:lint API specifications'
      'run:run test suites'
      'script:run custom scripts'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      export)
        _arguments -s -S \
          '-s[source]:source:_files' \
          '--src=[source]:source:_files' \
          '-o[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '--format=[output format]:format:(insomnia-4 har openapi-3)' \
          '--ci[CI mode]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      lint)
        _arguments -s -S \
          '-s[source]:source:_files' \
          '--src=[source]:source:_files' \
          '--ci[CI mode]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      run)
        _arguments -s -S \
          '-s[source]:source:_files' \
          '--src=[source]:source:_files' \
          '-e[environment]:environment' \
          '--env=[environment]:environment' \
          '--ci[CI mode]' \
          '--bail[stop on first failure]' \
          '--delay-request=[delay between requests in ms]:ms' \
          '--keep-file[do not delete test file]' \
          '--reporter=[reporter]:reporter:(spec dot min)' \
          '--test-name-pattern=[filter tests by name]:pattern' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
