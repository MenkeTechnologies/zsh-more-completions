#compdef kafka-get-offsets
# Documentation: https://man.archlinux.org/search?q=kafka-get-offsets
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--topic[Topic name]:topic:'
    '--topic-partitions[Comma-separated list of topic-partitions]:topic-partitions:'
    '--time[Timestamp to look up or -1 for latest, -2 for earliest, -3 for max-timestamp]:timestamp:'
    '--exclude-internal-topics[Exclude internal topics]'
    '--broker-list[DEPRECATED - Use --bootstrap-server]:host\:port:'
)

_arguments -s -S $arguments
