#compdef kubectl-view-secret

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-n+[namespace]:namespace:' \
  '--namespace=[namespace]:namespace:' \
  '-a[decode all secret keys]' \
  '--all[decode all secret keys]' \
  '-q[quiet, only show decoded values]' \
  '--quiet[quiet, only show decoded values]' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--context=[kubernetes context]:context:' \
  '1:secret name:' \
  '2:secret key:' && ret=0

return ret
