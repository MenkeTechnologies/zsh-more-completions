#compdef kubectl-view-secret
# Documentation: https://github.com/elsesiy/kubectl-view-secret
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --all)'{-a,--all}'[decode all secrets without specifying individual keys]' \
  '(-q --quiet)'{-q,--quiet}'[suppress info output]' \
  '(-n --namespace)'{-n+,--namespace=}'[override the namespace defined in the current context]:namespace:' \
  '(-c --context)'{-c+,--context=}'[override the current context]:context:' \
  '(-k --kubeconfig)'{-k+,--kubeconfig=}'[explicitly provide the kubeconfig to use]:file:_files' \
  '--as=[username to impersonate for the operation]:user:' \
  '--as-group=[groups to impersonate for the operation (comma separated)]:groups:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(text json yaml)' \
  '1:secret name:' \
  '2:secret key:' && ret=0

return ret
