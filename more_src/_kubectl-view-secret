#compdef kubectl-view-secret
# kubectl-view-secret (krew plugin): decode Kubernetes secrets easily
# https://github.com/elsesiy/kubectl-view-secret

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '(-A --all)'{-A,--all}'[show all keys]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-d --decode)'{-d,--decode}'[decode base64 values]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output except secret value]' \
  '1:secret name' \
  '2:key'
