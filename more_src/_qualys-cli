#compdef qualys-cli qualys
# _qualys-cli — Qualys qualys-cli CLI command-line frontend to the Qualys Cloud Platform REST API supporting Vulnerability Management VMDR Policy Compliance PCI Cloud Security PaaS CSPM File Integrity Monitoring FIM Web Application Scanning WAS endpoint detection response EDR XDR SaaS asset inventory IT asset (Qualys team, Python); click
# upstream: https://www.qualys.com/

_qualys-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'asset:asset inventory operations'
        'vm:vulnerability management'
        'pc:policy compliance'
        'was:web application scanning'
        'fim:file integrity monitoring'
        'cs:container security'
        'cspm:cloud security posture management'
        'edr:endpoint detection response'
        'scan:scan operations'
        'report:report operations'
        'tag:tag operations'
        'user:user operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '--platform=+[p]:p:(US1 US2 US3 EU1 EU2 EU3 IN1 CA1 AE1 UK1)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table xml)' \
        '--format=+[format]:f:(json yaml csv table xml)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qualys-cli subcommand' sub ;;
        args)
            case $words[1] in
                asset|vm|pc|was|fim|cs|cspm|edr|scan|report|tag|user) _arguments '1:op:(list get create update delete launch download)' '*:id:' ;;
            esac
            ;;
    esac
}

_qualys-cli "$@"
