#compdef swc
# _swc-cli — SWC Rust JS/TS compiler CLI (Donny Wong / Vercel); next-gen Babel replacement, powers Next.js, Vercel, Deno
# upstream: https://github.com/swc-project/swc

_swc-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --out-dir)'{-d,--out-dir}'+[output dir]:dir:_files -/' \
        '(-o --out-file)'{-o,--out-file}'+[output file]:file:_files' \
        '--config+[config JSON]:file:_files' \
        '--config-file+[swcrc path]:file:_files' \
        '--env-name+[env name]:name:' \
        '--source-maps+[sourcemap]:mode:(true false inline both)' \
        '--source-map-target+[sourcemap target]:str:' \
        '--source-file-name+[source file name]:name:' \
        '--source-root+[source root]:str:' \
        '--no-swcrc[ignore .swcrc]' \
        '--ignore+[ignore glob]:glob:' \
        '--only+[only glob]:glob:' \
        '(-w --watch)'{-w,--watch}'[watch and rebuild]' \
        '(-q --quiet)'{-q,--quiet}'[suppress output]' \
        '(-s --sync)'{-s,--sync}'[synchronous mode]' \
        '--filename+[filename for stdin]:name:' \
        '--copy-files[copy non-JS files]' \
        '--include-dotfiles[include dotfiles]' \
        '--strip-leading-paths[strip leading path]' \
        '--extensions+[file extensions]:ext:' \
        '--log-watch-compilation[log watch builds]' \
        '*:file:_files'
}

_swc-cli "$@"
