#compdef cilium-cli
# _cilium-cli — Cilium CLI alias for managing Cilium and Hubble (Cilium project, Go); spf13/cobra
# upstream: https://github.com/cilium/cilium-cli

_cilium-cli() {
    local -a sub=(
        'install:install cilium'
        'uninstall:uninstall cilium'
        'upgrade:upgrade cilium'
        'status:show cilium status'
        'config:manage runtime config'
        'connectivity:run connectivity tests'
        'hubble:hubble subcommands'
        'clustermesh:clustermesh subcommands'
        'context:list available kube contexts'
        'sysdump:collect sysdump'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
        'bgp:bgp subcommands'
        'ip:ip pool subcommands'
        'identity:show identity info'
        'features:show feature status'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--kubeconfig=+[kubeconfig]:file:_files' \
        '--context=+[kube context]:ctx:' \
        '-n+[k8s namespace]:ns:' \
        '--namespace=+[k8s namespace]:ns:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cilium subcommand' sub ;;
        args)
            case $words[1] in
                install|upgrade) _arguments \
                    '--version=+[cilium version]:ver:' \
                    '--chart-directory=+[chart dir]:dir:_files -/' \
                    '--helm-set=+[helm set values]:str:' \
                    '--helm-values=+[values file]:file:_files -g "*.yaml *.yml"' \
                    '--dry-run[dry run]' \
                    '--dry-run-helm-values[dry run helm values]' \
                    '--datapath-mode=+[datapath mode]:mode:(tunnel native aws-eni gke azure)' \
                    '--cluster-id=+[cluster id]:id:' \
                    '--cluster-name=+[cluster name]:name:' \
                    '--restart-unmanaged-pods[restart unmanaged pods]' ;;
                uninstall) _arguments \
                    '--wait[wait]' \
                    '--timeout=+[timeout]:dur:' ;;
                status) _arguments \
                    '--wait[wait]' \
                    '--ignore-warnings[ignore warnings]' \
                    '--output=+[output]:fmt:(summary json yaml)' \
                    '-o+[output]:fmt:(summary json yaml)' ;;
                connectivity) _arguments \
                    '1:cmd:(test perf)' \
                    '--all-flows[print all flows]' \
                    '--test=+[test list]:list:' \
                    '--collect-sysdump-on-failure[collect sysdump on failure]' \
                    '--external-target=+[external target host]:host:_hosts' ;;
                hubble) _arguments \
                    '1:cmd:(enable disable ui port-forward)' \
                    '*:arg:' ;;
                clustermesh) _arguments \
                    '1:cmd:(enable disable connect disconnect status external-workloads)' \
                    '*:arg:' ;;
                bgp) _arguments \
                    '1:cmd:(peers routes)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_cilium-cli "$@"
