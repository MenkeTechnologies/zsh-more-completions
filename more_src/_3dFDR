#compdef 3dFDR
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dFDR.html
# Compute False Discovery Rate (FDR) thresholds for voxel p-values

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-input[input 3D functional dataset]:dataset:_files' \
  '-input1D[.1D file with column of p-values]:file:_files' \
  '-mask_file[use mask values from file]:dataset:_files' \
  '-mask[use mask values from file]:dataset:_files' \
  '-mask_thr[only consider voxels with mask value >= m]:m:' \
  '-cind[set c(N)=1 for independent p-values]' \
  '-cdep[set c(N)=sum(1/i) for any joint distribution]' \
  '-quiet[suppress screen output]' \
  '-list[write sorted list of voxel q-values to screen]' \
  '-prefix[output dataset prefix]:prefix:' \
  '-output[output dataset prefix]:prefix:' \
  '-old[use original mode of operation]' \
  '-new[use current mode of operation (default)]' \
  '-pmask[ignore p=1 voxels]' \
  '-nopmask[include p=1 voxels in calculations]' \
  '-force[convert all sub-bricks as p-values]' \
  '-float[output z-scores in floating point]' \
  '-qval[output q-values instead of z-scores]' \
  '*:dataset:_files' && ret=0

return ret
