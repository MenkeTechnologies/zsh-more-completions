#compdef grub-emu
# _grub-emu — GRUB grub-emu (userland GRUB binary that emulates the bootloader inside a normal Linux process; -d module dir, -m memdisk image, -r root device prefix, -H hold to allow attaching gdb, -v verbose, -t terminal selection)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub grub-core/kern/emu/main.c on tip.

_grub-emu() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[module directory]:dir:_files -/' \
        '--directory+[module directory]:dir:_files -/' \
        '-m+[memdisk image]:file:_files' \
        '--memdisk+[memdisk image]:file:_files' \
        '-r+[root device]:device:' \
        '--root+[root device]:device:' \
        '-H+[hold for N seconds]:seconds:' \
        '--hold+[hold for N seconds]:seconds:' \
        '-t+[terminal]:term:(console serial)'
}

_grub-emu "$@"
