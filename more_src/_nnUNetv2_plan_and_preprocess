#compdef nnUNetv2_plan_and_preprocess
# Documentation: https://github.com/MIC-DKFZ/nnUNet/blob/master/documentation/how_to_use_nnunet.md
# nnU-Net v2 dataset fingerprint extraction, planning and preprocessing

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-d[dataset id(s)]:dataset id:' \
  '--verify_dataset_integrity[validate common error sources]' \
  '-c[configuration to preprocess]:configuration:(2d 3d_fullres 3d_lowres)' \
  '--no_pbar[suppress progress bar]' \
  '-np[number of processes]:num processes:' \
  '*:arg:' && ret=0

return ret
