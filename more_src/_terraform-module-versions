#compdef terraform-module-versions
# Documentation: https://github.com/keilerkonzept/terraform-module-versions
# Reference accessed: 2026-05-21
# Verified: upstream README — keilerkonzept/terraform-module-versions.
# Subcommands: list, check, version.
# Global flags: -o/-output (json/jsonl/junit/markdown/markdown-wide),
# -q/-quiet.
# list flags: -module (repeatable), -o/-output.
# check flags: -a/-all, -module, -pre-release, -sed,
# -updates-found-nonzero-exit/-e, -any-updates-found-nonzero-exit/-n,
# -H/-registry-header, -o/-output.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list referenced terraform modules with detected versions'
  'check:check for newer versions of referenced modules'
  'version:print version and exit'
)

local -a global_flags=(
  '(-o -output)'{-o,-output}'[output format]:format:(json jsonl junit markdown markdown-wide)'
  '(-q -quiet)'{-q,-quiet}'[suppress log output on stderr]'
  '(- *)-h[show help]'
)

_arguments -s -S -C \
  $global_flags \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t cmds 'terraform-module-versions command' commands && ret=0 ;;
  args)
    case $line[1] in
      list)
        _arguments -s -S \
          $global_flags \
          '*-module=[include specific module (repeatable)]:module' \
          '*:path:_files -g "*.tf"' && ret=0
        ;;
      check)
        _arguments -s -S \
          $global_flags \
          '(-a -all)'{-a,-all}'[include modules without available updates]' \
          '*-module=[include specific module (repeatable)]:module' \
          '-pre-release[include pre-release versions]' \
          '-sed[generate sed statements for upgrading]' \
          '(-e -updates-found-nonzero-exit)'{-e,-updates-found-nonzero-exit}'[nonzero exit when matching updates exist]' \
          '(-n -any-updates-found-nonzero-exit)'{-n,-any-updates-found-nonzero-exit}'[nonzero exit when any updates found]' \
          '*'{-H,-registry-header}'=[extra HTTP header KEY:VALUE (repeatable)]:header' \
          '*:path:_files -g "*.tf"' && ret=0
        ;;
    esac
    ;;
esac

return ret
