#compdef conftest2
# _conftest2 — Open Policy Agent conftest2 CLI command-line frontend wrapping the Conftest helper for writing tests against structured configuration data using the Rego language from Open Policy Agent open-source written in Go test policies against YAML JSON INI TOML HCL Cue Dockerfile EDN Hocon Jsonnet VCL XML Properties stdin verify parse push pull policy bundle plugin verify-output JUnit TAP SARIF Stdout (Open Policy Agent CNCF team, Go); cobra
# upstream: https://www.conftest.dev/

_conftest2() {
    local -a sub=(
        'test:test configuration files'
        'verify:verify Rego unit tests'
        'parse:parse and print files'
        'pull:pull policies from registry'
        'push:push policies to registry'
        'plugin:plugin operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--no-color[no color]' \
        '--trace[trace]' \
        '-p+[policy path]:_files' \
        '*-p+[policy path]:_files' \
        '--policy=+[path]:_files' \
        '*--policy=+[path]:_files' \
        '-d+[data file/dir]:_files' \
        '*-d+[data file/dir]:_files' \
        '--data=+[file]:_files' \
        '-n+[namespace]:str:' \
        '*-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '*--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-i+[input type]:i:(json yaml hcl1 hcl2 toml cue ini dockerfile edn hocon jsonnet properties spdx vcl xml)' \
        '--input=+[i]:i:(json yaml hcl1 hcl2 toml cue ini dockerfile edn hocon jsonnet properties spdx vcl xml)' \
        '-o+[output]:o:(stdout json table junit github gitlab tap sarif)' \
        '--output=+[o]:o:(stdout json table junit github gitlab tap sarif)' \
        '--parser=+[p]:p:(json yaml hcl1 hcl2 toml cue ini dockerfile edn hocon jsonnet properties spdx vcl xml)' \
        '--ignore=+[regex]:str:' \
        '--combine[combine inputs]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-fail[no fail]' \
        '--fail-on-warn[fail on warn]' \
        '--strict[strict mode]' \
        '--show-builtin-errors[show builtin errors]' \
        '--capabilities=+[file]:file:_files -g "*.json"' \
        '--report=+[r]:r:(notes fails full)' \
        '--update=+[url]:str:' \
        '*--update=+[url]:str:' \
        '--proto-file-dirs=+[dirs]:str:' \
        '*--proto-file-dirs=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'conftest subcommand' sub ;;
        args)
            case $words[1] in
                test|parse) _arguments '*:file:_files' ;;
                pull) _arguments '*:registry url:' ;;
                push) _arguments '1:registry url:' '*:policy file:_files' ;;
                plugin) _arguments '1:op:(install list)' '*:name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_conftest2 "$@"
