#compdef secret-share-split secret-share-combine
# Documentation: https://man.archlinux.org/search?q=secret-share-split
# Reference accessed: 2026-05-16

# Zsh completion for sss-cli shamir tools

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-n --shares)'{-n,--shares}'[number of shares]' \
  '(-t --threshold)'{-t,--threshold}'[threshold]' \
  '*:secret:_files' && ret=0

return ret
