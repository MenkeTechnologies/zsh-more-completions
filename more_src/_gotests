#compdef gotests

_arguments \
  '-all[generate tests for all functions and methods]' \
  '-excl[regex for functions/methods to exclude]:regex' \
  '-exported[generate tests for exported functions only]' \
  '-i[print test inputs in error messages]' \
  '-only[regex for functions/methods to include]:regex' \
  '-nosubtests[disable subtests]' \
  '-parallel[enable parallel subtests]' \
  '-w[write output to source files]' \
  '-template[custom template directory]:directory:_directories' \
  '-template_dir[custom template directory]:directory:_directories' \
  '-named[generate named return values]' \
  '*:go file:_files -g "*.go"'
