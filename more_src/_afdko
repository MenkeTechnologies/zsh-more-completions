#compdef afdko makeotf makeotfexe makeinstancesufo checkoutlinesufo tx spot mergefonts otc2otf otf2otc otf2ttf ttf2otf
# _afdko — Adobe afdko Adobe Font Development Kit for OpenType wrapper CLI delegating to makeotf checkoutlinesufo tx mergeFonts spot type1to1 ConvertFontToCID and stemHist (adobe-type-tools team, Python+C); argparse
# upstream: https://github.com/adobe-type-tools/afdko

_afdko() {
    local -a sub=(
        'makeotf:compile UFO to OTF'
        'makeotfexe:lower-level OTF compiler'
        'makeinstancesufo:generate UFO instances from design space'
        'checkoutlinesufo:check outline integrity'
        'tx:type-tools convert subset autohint'
        'spot:show OpenType tables'
        'mergefonts:merge fonts'
        'otc2otf:split OTC into OTF'
        'otf2otc:assemble OTF into OTC'
        'otf2ttf:convert CFF OTF to TTF'
        'ttf2otf:convert TTF to CFF OTF'
        'comparefamily:compare family'
        'kerncheck:check kerning'
        'autohint:apply autohinting'
        'sfntdiff:diff two fonts'
        'sfntedit:edit sfnt table'
        'stemhist:stem histogram'
        'checkufovalues:check UFO values'
        'addfeatures:add features'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'afdko subcommand' sub ;;
        args) ;;
    esac
}

_afdko "$@"
