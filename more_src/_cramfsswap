#compdef cramfsswap
# Documentation: https://man.archlinux.org/search?q=cramfsswap
# Reference accessed: 2026-05-16

# cramfsswap: swap byte order of a CRAMFS image
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:input image:_files' \
  '2:output image:_files' && ret=0
return ret
