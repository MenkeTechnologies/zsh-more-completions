#compdef cramfsswap
# Documentation: https://manpages.debian.org/bookworm/cramfsswap/cramfsswap.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cramfsswap: swap endianness of a CRAMFS image. No flags; two positional args.

local curcontext="$curcontext" ret=1
_arguments -C \
  '1:input image:_files' \
  '2:output image:_files' && ret=0
return ret
