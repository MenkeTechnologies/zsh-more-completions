#compdef pcp2json
# Documentation: https://man.archlinux.org/man/pcp2json.1.en
# Performance Co-Pilot metrics exporter to JSON

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[display version and exit]' \
  '(-a --archive)'{-a+,--archive=}'[retrieve metrics from PCP archive]:archive:_files' \
  '--archive-folio=[read archives from PCP archive folio]:folio:_files' \
  '(-A --align)'{-A+,--align=}'[align initial sample on time boundary]:align' \
  '(-c --config)'{-c+,--config=}'[configuration file or directory]:config:_files' \
  '--container=[fetch metrics from specified container]:container' \
  '(-C --check)'{-C,--check}'[exit after parsing config]' \
  '--daemonize[start as daemon process]' \
  '(-e --derived)'{-e+,--derived=}'[specify derived metrics]:derived' \
  '(-E --exact-types)'{-E,--exact-types}'[write numbers as number data types]' \
  '(-f --timestamp-format)'{-f+,--timestamp-format=}'[strftime timestamp format]:format' \
  '(-F --output-file)'{-F+,--output-file=}'[output file path]:outfile:_files' \
  '(-G --no-globals)'{-G,--no-globals}'[exclude global metrics]' \
  '(-h --host)'{-h+,--host=}'[fetch metrics from pmcd on host]:host:_hosts' \
  '(-H --no-header)'{-H,--no-header}'[omit all headers]' \
  '(-i --instances)'{-i+,--instances=}'[report only specified instances]:instances' \
  '(-I --ignore-incompat)'{-I,--ignore-incompat}'[silently omit incompatible metrics]' \
  '(-j --live-filter)'{-j,--live-filter}'[perform instance live filtering]' \
  '(-J --rank)'{-J+,--rank=}'[limit to highest/lowest ranked instances]:rank' \
  '(-K --spec-local)'{-K+,--spec-local=}'[DSO PMDAs in local context]:spec' \
  '(-L --local-PMDA)'{-L,--local-PMDA}'[collect from DSO PMDAs without PMCD]' \
  '(-m --include-labels)'{-m,--include-labels}'[include PCP metric labels]' \
  '(-n --invert-filter)'{-n,--invert-filter}'[rank before live filtering]' \
  '(-N --predicate)'{-N+,--predicate=}'[predicate filter reference metrics]:predicate' \
  '(-O --origin)'{-O+,--origin=}'[start reporting archived metrics at origin]:origin' \
  '(-P --precision)'{-P+,--precision=}'[precision for numeric output]:precision' \
  '(-r --raw)'{-r,--raw}'[output raw values, not rates]' \
  '(-R --raw-prefer)'{-R,--raw-prefer}'[like raw without overriding specs]' \
  '(-s --samples)'{-s+,--samples=}'[number of samples to report]:samples' \
  '(-S --start)'{-S+,--start=}'[archived metrics at or after time]:starttime' \
  '(-t --interval)'{-t+,--interval=}'[reporting interval]:interval' \
  '(-T --finish)'{-T+,--finish=}'[archived metrics before or at time]:endtime' \
  '(-v --omit-flat)'{-v,--omit-flat}'[report only set-valued metrics]' \
  '(-x --with-extended)'{-x,--with-extended}'[write extended metric information]' \
  '(-X --with-everything)'{-X,--with-everything}'[write everything known]' \
  '(-z --hostzone)'{-z,--hostzone}'[use timezone of metrics source host]' \
  '(-Z --timezone)'{-Z+,--timezone=}'[use specified timezone]:timezone' \
  '*:metric:_default' && ret=0

return ret
