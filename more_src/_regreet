#compdef regreet
# Documentation: https://man.archlinux.org/search?q=regreet
# Reference accessed: 2026-05-16

# Zsh completion for ReGreet (GTK4 based greeter for greetd)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[path to configuration file]:config file:_files' \
  '--style=[path to CSS style file]:css file:_files' && ret=0

return ret
