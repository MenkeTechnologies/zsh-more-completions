#compdef regreet
# Documentation: https://github.com/rharish101/ReGreet
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above.
# Added documented --logs/--verbose/--demo flags (previously absent).

# Zsh completion for ReGreet (GTK4-based greeter for greetd)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[path to configuration file]:config file:_files' \
  '(-s --style)'{-s+,--style=}'[path to CSS style file]:css file:_files' \
  '--logs=[directory for log files]:directory:_directories' \
  '--verbose[also log to stdout]' \
  '--demo[run in demo mode independent of greetd]' && ret=0

return ret
