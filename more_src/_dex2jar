#compdef dex2jar d2j-dex2jar d2j-jar2dex d2j-apk-sign d2j-baksmali d2j-smali d2j-asm-verify d2j-class-version-switch d2j-decrypt-string d2j-init-deobf d2j-jasmin2jar d2j-jar-access d2j-jar-remap d2j-jar-weaver

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--skip-exceptions[skip exceptions]' \
  '(-d --debug-info)'{-d,--debug-info}'[translate debug info]' \
  '(-e --exception-file)'{-e+,--exception-file=}'[error zip file]:file:_files' \
  '(-f --force)'{-f,--force}'[overwrite output]' \
  '(-n --not-handle-exception)'{-n,--not-handle-exception}'[do not handle dex2jar exceptions]' \
  '(-nc --no-code)'{-nc,--no-code}'[no code translation]' \
  '(-o --output)'{-o+,--output=}'[output jar]:file:_files -g "*.jar"' \
  '(-os --optimize-synchronized)'{-os,--optimize-synchronized}'[optimize synchronized]' \
  '(-p --print-ir)'{-p,--print-ir}'[print IR to stdout]' \
  '(-r --reuse-reg)'{-r,--reuse-reg}'[reuse register]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:dex/apk file:_files -g "*.dex *.apk *.zip"' && ret=0

return ret
