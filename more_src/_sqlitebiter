#compdef sqlitebiter

# sqlitebiter: convert CSV/HTML/Excel/JSON/markdown/SQL/TSV to SQLite tables
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'file:import data files'
  'url:import from URL'
  'gs:import from Google Sheets'
  'configure:show/edit config'
  'completion:emit shell completion'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-o[output sqlite file]:file:_files -g "*.(sqlite|sqlite3|db)"' \
  '--output-path=[output sqlite file]:file:_files -g "*.(sqlite|sqlite3|db)"' \
  '-a[append mode]' \
  '--append[append mode]' \
  '-i[index file]:file:_files' \
  '--index=[index file]:file:_files' \
  '--no-type-inference[no type inference]' \
  '--type-hint-header[use header for type hints]' \
  '--replace-symbol[replace symbols in column names]:symbol:' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-q[quiet]' \
  '--debug[debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'sqlitebiter command' commands && ret=0 ;;
esac
return ret
