#compdef sqlitebiter
# Documentation: https://github.com/thombashi/sqlitebiter
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# sqlitebiter: convert CSV/HTML/Excel/JSON/markdown/SQL/TSV to SQLite tables
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'file:convert tabular data files to SQLite'
  'url:extract tabular data from web pages'
  'gs:convert Google Sheets to SQLite'
  'stdin:convert tabular data from standard input'
  'configure:adjust application settings'
  'completion:emit shell completion'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output-path)'{-o+,--output-path=}'[output sqlite database file]:file:_files -g "*.(sqlite|sqlite3|db)"' \
  '(-a --append)'{-a,--append}'[add tables to existing database]' \
  '--add-primary-key=[insert PRIMARY KEY AUTOINCREMENT column]:name:' \
  '(-i --index)'{-i+,--index=}'[comma-separated index attribute names]:attrs:' \
  '--no-type-inference[treat all columns as TEXT]' \
  '--type-hint-header[use header suffixes for type hints]' \
  '--matrix-formatting=[table formatting strategy]:strategy:(header_aligned trim)' \
  '--replace-symbol=[replace symbols in attribute names]:symbol:' \
  '*'{-v,--verbose}'[verbosity level]' \
  '--max-workers=[max worker threads]:n:' \
  '--debug[enable debug output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress execution messages]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'sqlitebiter command' commands && ret=0 ;;
esac
return ret
