#compdef create-qwik
# Documentation: https://github.com/QwikDev/qwik/tree/main/packages/create-qwik
# Reference accessed: 2026-05-17
# Verified: upstream src/run-create-cli.ts at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --force)'{-f,--force}'[overwrite target directory if it exists]' \
  '(-i --installDeps)'{-i,--installDeps}'[install dependencies]' \
  '1:template:' \
  '2:project directory:_directories' && ret=0

return ret
