#compdef create-qwik
# Documentation: https://man.archlinux.org/search?q=create-qwik
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-y --yes)'{-y,--yes}'[accept all defaults]' \
  '1:project directory:_directories' && ret=0

return ret
