#compdef render
# Documentation: https://render.com/docs/cli-reference
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'completion:generate shell completion'
  'config:CLI config'
  'deploys:deploy commands'
  'help:show help'
  'jobs:job commands'
  'login:log in'
  'logs:show logs'
  'projects:project commands'
  'psql:open psql to a database'
  'redis-cli:open redis-cli'
  'restart:restart a service'
  'services:service commands'
  'ssh:SSH into a service'
  'workspace:workspace commands'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-o+[output]:o:(json yaml interactive)' \
  '*--output=[output]:o:(json yaml interactive)' \
  '*--confirm[confirm prompt]' \
  '*--non-interactive[non-interactive]' \
  '*--profile=[profile]:p:' \
  '*--workspace=[workspace ID]:id:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'render command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploys)
        _arguments \
          '1:subcommand:(create list cancel)' \
          '*: :' && ret=0 ;;
      (services)
        _arguments \
          '1:subcommand:(create list update restart suspend resume scale)' \
          '*: :' && ret=0 ;;
      (jobs)
        _arguments \
          '1:subcommand:(list create cancel rerun)' \
          '*: :' && ret=0 ;;
      (logs)
        _arguments \
          '--resources=[resource IDs csv]:list:' \
          '--limit=[limit]:n:' \
          '--start=[start time]:t:' \
          '--end=[end time]:t:' \
          '--type=[log type csv]:list:' \
          '--level=[log level csv]:list:' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
