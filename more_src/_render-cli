#compdef render-cli
# Documentation: https://render.com/docs/cli-reference
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. Alias completion that defers to _render.

local curcontext="$curcontext" state line ret=1

(( $+functions[_render] )) || autoload -Uz _render 2>/dev/null
if (( $+functions[_render] )); then
  _render "$@"
  return
fi

_arguments \
  '*::render arg:_files' && ret=0

return ret
