#compdef sqlfmt

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-u+[upper case keywords]' \
  '-l+[line length]:length:' \
  '--line-length=[line length]:length:' \
  '-U+[upper case function names]' \
  '--use-spaces[use spaces instead of tabs]' \
  '--tab-width=[tab width]:width:' \
  '--no-simplify[do not simplify expressions]' \
  '--align[align columns]' \
  '--indent=[indentation]:indent:' \
  '-n+[no output, check only]' \
  '--check[check formatting only]' \
  '-d+[diff mode]' \
  '--diff[show diff]' \
  '*:file:_files' && ret=0

return ret
