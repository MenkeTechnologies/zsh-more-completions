#compdef cosmic-screenshot
# _cosmic-screenshot — take a screenshot via xdg-desktop-portal (pop-os/cosmic-screenshot)
# upstream: https://github.com/pop-os/cosmic-screenshot
# Flags from src/main.rs (clap derive).

_cosmic-screenshot() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--interactive=[interactive portal mode]:bool:(true false)' \
        '--modal=[modal portal mode]:bool:(true false)' \
        '--notify=[send notification with saved path]:bool:(true false)' \
        '(-s --save-dir)'{-s+,--save-dir=}'[save directory]:dir:_files -/'
}

_cosmic-screenshot "$@"
