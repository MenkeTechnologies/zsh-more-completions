#compdef minetest-server
# Documentation: https://wiki.minetest.net/Server
# Reference accessed: 2026-05-16

# minetest-server: headless build of Minetest server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--port=[port]:port:' \
  '--config=[config file]:file:_files' \
  '--world=[world directory]:dir:_files -/' \
  '--worldname=[world name]:name:' \
  '--gameid=[game id]:game:' \
  '--info[info messages]' \
  '--verbose[verbose]' \
  '--trace[trace messages]' \
  '--logfile=[log file]:file:_files' \
  '--quiet[print only errors]' \
  '--migrate=[migrate map backend]:backend:(sqlite3 leveldb redis postgresql files dummy)' \
  '--migrate-players=[migrate player backend]:backend:' \
  '--migrate-auth=[migrate auth backend]:backend:' \
  '--migrate-mod-storage=[migrate mod storage backend]:backend:' \
  '--terminal[use terminal interface]' \
  '*::minetest-server args:_files' && ret=0
return ret
