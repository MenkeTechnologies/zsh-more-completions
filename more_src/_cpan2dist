#compdef cpan2dist
# Documentation: man cpan2dist(1)
# Source: CPANPLUS bin/cpan2dist (master) — build distribution packages from CPAN modules (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--format=[distribution format]:format:_default' \
    '--archive[create tarball archive]' \
    '(--verbose --noverbose)--verbose[verbose output]' \
    '(--verbose --noverbose)--noverbose[suppress output]' \
    '--force[force build]' \
    '--skiptest[skip tests]' \
    '--keepsource[keep source after build]' \
    '--makefile[use Makefile.PL]' \
    '--buildprereq[build prerequisites]' \
    '--help[show help]' \
    '--flushcache[flush CPANPLUS cache]' \
    '*--ban=[ban module pattern]:pattern:_default' \
    '*--banlist=[file with banned modules]:file:_files' \
    '*--ignore=[ignore module pattern]:pattern:_default' \
    '*--ignorelist=[file with ignored modules]:file:_files' \
    '--defaults[use default answers for all prompts]' \
    '*--modulelist=[file with modules to build]:file:_files' \
    '--logfile=[log file]:file:_files' \
    '--timeout=[timeout in seconds]:seconds:_default' \
    '*--dist-opts=[dist option key=value]:opt:_default' \
    '*--set-config=[CPANPLUS config key=value]:opt:_default' \
    '--default-banlist[use default ban list]' \
    '*--set-program=[program path key=value]:opt:_default' \
    '--default-ignorelist[use default ignore list]' \
    '--edit-metafile[edit dist metafile]' \
    '(--install --noinstall)--install[install built distribution]' \
    '(--install --noinstall)--noinstall[do not install built distribution]' \
    '*:module name:_default' \
    && ret=0

return ret
