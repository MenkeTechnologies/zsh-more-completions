#compdef nix-bundle

# Zsh completion for nix-bundle - bundle Nix derivations to run anywhere

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --bundler)'{-b,--bundler}'[specify bundler]:bundler' \
  '(-o --out-link)'{-o,--out-link}'[output link path]:path:_files' \
  '(-f --flake)'{-f,--flake}'[flake reference to bundle]:flake ref' \
  '1:package or derivation:'
