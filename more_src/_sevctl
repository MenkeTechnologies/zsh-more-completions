#compdef sevctl
# _sevctl — AMD SEV management tool (virtee/sevctl)
# upstream: https://github.com/virtee/sevctl
# Subcommands from src/main.rs (clap).

_sevctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-q --quiet)'{-q,--quiet}'[quiet output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'export:export SEV / full cert chain'
                'generate:generate self-signed OCA cert + key'
                'ok:probe system for SEV support'
                'provision:take ownership of SEV platform'
                'reset:reset SEV platform state'
                'rotate:rotate PDH'
                'session:generate a SEV launch session'
                'show:display SEV platform info'
                'verify:verify certificate chain'
                'validate:validate attestation report'
                'vmsa:VMSA-related subcommands'
                'measurement:measurement subcommands'
                'secret:secret subcommands'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                export) _arguments '(-f --full)'{-f,--full}'[export full SEV+CA chain]' '1:destination:_files' ;;
                generate) _arguments '1:cert file:_files' '2:key file:_files' ;;
                ok) _arguments '1:generation:(sev sev-es sev-snp)' ;;
                provision) _arguments '1:cert:_files' '2:key:_files' ;;
                session)
                    _arguments \
                        '(-n --name)'{-n+,--name=}'[name for filenames]:name:' \
                        '1:pdh file:_files' \
                        '2:policy:'
                    ;;
                verify)
                    _arguments \
                        '--sev=[SEV chain file]:file:_files' \
                        '--oca=[OCA cert file]:file:_files' \
                        '--ca=[CA chain file]:file:_files'
                    ;;
                validate) _arguments '1:sev-cert-chain:_files' '2:attestation-report:_files' ;;
                show) _arguments '1:subcommand:(flags guest identifier version vcek vcek-pem)' ;;
                vmsa) _arguments '1:subcommand:(build update show)' ;;
                measurement) _arguments '1:subcommand:(build show)' ;;
                secret) _arguments '1:subcommand:(build)' ;;
            esac
            ;;
    esac
}

_sevctl "$@"
