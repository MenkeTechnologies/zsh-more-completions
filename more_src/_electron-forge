#compdef electron-forge

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a new Electron Forge project'
  'import:import an existing Electron project'
  'package:package application for distribution'
  'make:create distributable installers'
  'publish:publish distributable artifacts'
  'start:launch the application'
  'lint:lint the application'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'electron-forge command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments \
          '--template=[template to use]:template' \
          '--copy-ci-files[copy CI config files]' \
          '1:directory:_directories' && ret=0
        ;;
      (import)
        _arguments '1:directory:_directories' && ret=0
        ;;
      (package)
        _arguments \
          '--arch=[target architecture]:arch:(x64 arm64 ia32 universal)' \
          '--platform=[target platform]:platform:(darwin linux win32 mas)' \
          '-p+[target platform]:platform:(darwin linux win32 mas)' \
          '--out=[output directory]:directory:_directories' && ret=0
        ;;
      (make)
        _arguments \
          '--arch=[target architecture]:arch:(x64 arm64 ia32 universal)' \
          '--platform=[target platform]:platform:(darwin linux win32 mas)' \
          '-p+[target platform]:platform:(darwin linux win32 mas)' \
          '--targets=[comma-separated maker targets]:targets' \
          '--skip-package[skip packaging step]' \
          '--out=[output directory]:directory:_directories' && ret=0
        ;;
      (publish)
        _arguments \
          '--target=[publish target]:target' \
          '--dry-run[do not actually publish]' \
          '--from-dry-run[publish artifacts from a dry run]' && ret=0
        ;;
      (start)
        _arguments \
          '--app-path=[path to application]:path:_directories' \
          '--enable-logging[enable logging]' \
          '--run-as-node[run as node process]' \
          '--inspect-electron[debug main process]' \
          '--inspect-brk-electron[debug main process with breakpoint]' \
          '*:extra arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
