#compdef sinch-cli sinch
# _sinch-cli — Sinch sinch-cli CLI command-line frontend wrapping the Sinch Customer Communications Cloud REST API managing messages SMS MMS WhatsApp RCS Telegram Viber voice calls conversations flow agents numbers verification SIP Trunks campaign apps brand reseller-billing campaign-management (Sinch team, Go); cobra
# upstream: https://www.sinch.com/

_sinch-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'message:message operations'
        'sms:SMS operations'
        'mms:MMS operations'
        'whatsapp:WhatsApp operations'
        'rcs:RCS operations'
        'telegram:Telegram operations'
        'viber:Viber operations'
        'voice:voice operations'
        'conversation:conversation operations'
        'flow:flow operations'
        'agent:agent operations'
        'number:number operations'
        'verification:verification operations'
        'sip-trunk:SIP trunk operations'
        'campaign:campaign operations'
        'app:app operations'
        'brand:brand operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--access-key=+[key]:str:' \
        '--access-secret=+[secret]:str:' \
        '--project-id=+[id]:str:' \
        '--service-plan-id=+[id]:str:' \
        '--api-url=+[url]:str:' \
        '--region=+[r]:r:(us eu br au)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sinch-cli subcommand' sub ;;
        args)
            case $words[1] in
                message|sms|mms|whatsapp|rcs|telegram|viber|voice|conversation|flow|agent|number|verification|sip-trunk|campaign|app|brand) _arguments '1:op:(list get create update delete send hangup transfer)' '*:id:' ;;
            esac
            ;;
    esac
}

_sinch-cli "$@"
