#compdef coolify-cli
# _coolify-cli — Coolify open-source self-hostable Heroku/Vercel alternative CLI alias (coollabsio team, Bash/TypeScript); custom argparse
# upstream: https://github.com/coollabsio/coolify

_coolify-cli() {
    local -a sub=(
        'install:install coolify server'
        'upgrade:upgrade coolify'
        'uninstall:uninstall coolify'
        'login:login to instance'
        'logout:logout'
        'whoami:show current user'
        'instance:status:show server status'
        'instance:health:check health'
        'instance:logs:show coolify logs'
        'instance:reset:reset instance'
        'instance:nuke:nuke all data'
        'instance:export:export config'
        'instance:import:import config'
        'instance:cleanup:cleanup unused'
        'instance:set-env:set instance env'
        'app:list:list applications'
        'app:create:create application'
        'app:get:get app info'
        'app:update:update app'
        'app:delete:delete app'
        'app:deploy:deploy app'
        'app:redeploy:redeploy app'
        'app:restart:restart app'
        'app:stop:stop app'
        'app:start:start app'
        'app:logs:show app logs'
        'app:env:list:list app env vars'
        'app:env:set:set app env var'
        'app:env:unset:unset app env var'
        'app:env:bulk-set:bulk set env'
        'db:list:list databases'
        'db:create:create database'
        'db:get:get db info'
        'db:delete:delete database'
        'db:backup:backup database'
        'db:restore:restore database'
        'service:list:list services'
        'service:create:create service'
        'service:get:get service info'
        'service:delete:delete service'
        'service:deploy:deploy service'
        'service:restart:restart service'
        'service:stop:stop service'
        'service:logs:show service logs'
        'server:list:list servers'
        'server:add:add server'
        'server:remove:remove server'
        'server:validate:validate server'
        'project:list:list projects'
        'project:create:create project'
        'project:delete:delete project'
        'environment:list:list envs'
        'environment:create:create env'
        'team:list:list teams'
        'team:invite:invite user'
        'webhook:list:list webhooks'
        'webhook:create:create webhook'
        'webhook:delete:delete webhook'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--url=+[coolify url]:url:_urls' \
        '--token=+[api token]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coolify subcommand' sub ;;
        args)
            case $words[1] in
                app:create) _arguments \
                    '--name=+[name]:str:' \
                    '--git-repository=+[git url]:url:_urls' \
                    '--git-branch=+[branch]:str:' \
                    '--build-pack=+[build pack]:p:(nixpacks dockerfile static docker-compose)' \
                    '--project-uuid=+[project uuid]:str:' \
                    '--server-uuid=+[server uuid]:str:' \
                    '--environment-uuid=+[env uuid]:str:' \
                    '--destination-uuid=+[dest uuid]:str:' \
                    '--ports-exposes=+[ports]:str:' \
                    '--instant-deploy[instant deploy]' ;;
                db:create) _arguments \
                    '--type=+[type]:t:(postgresql mysql mariadb mongodb redis keydb dragonfly clickhouse)' \
                    '--name=+[name]:str:' \
                    '--project-uuid=+[project uuid]:str:' \
                    '--environment-uuid=+[env uuid]:str:' \
                    '--server-uuid=+[server uuid]:str:' \
                    '--instant-deploy[instant deploy]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_coolify-cli "$@"
