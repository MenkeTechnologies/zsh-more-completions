#compdef filebrowser

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'config:manage configuration'
      'cmds:manage command hooks'
      'hash:generate a password hash'
      'rules:manage file rules'
      'upgrade:upgrade the database'
      'users:manage users'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (config)
        local -a subcmds=(
          'cat:print current configuration'
          'export:export configuration'
          'import:import configuration'
          'init:initialize configuration'
          'set:set a configuration value'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (users)
        local -a subcmds=(
          'add:add a user'
          'find:find a user by id or username'
          'ls:list all users'
          'rm:remove a user'
          'update:update a user'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (rules)
        local -a subcmds=(
          'add:add a rule'
          'ls:list rules'
          'rm:remove a rule'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (cmds)
        local -a subcmds=(
          'add:add a command'
          'ls:list commands'
          'rm:remove a command'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

_arguments \
  '(-a --address)'{-a,--address}'+[address to listen on]:address:' \
  '(-r --root)'{-r,--root}'+[root directory to serve]:directory:_files -/' \
  '(-p --port)'{-p,--port}'+[port to listen on]:port:' \
  '(-d --database)'{-d,--database}'+[database path]:file:_files' \
  '(-l --log)'{-l,--log}'+[log file]:file:_files' \
  '--baseurl+[base URL]:URL:' \
  '--cache-dir+[cache directory]:directory:_files -/' \
  '--cert+[TLS certificate file]:file:_files' \
  '--key+[TLS key file]:file:_files' \
  '--disable-exec[disable command execution]' \
  '--disable-preview-resize[disable image preview resize]' \
  '--disable-type-detection-by-header[disable file type detection by header]' \
  '--noauth[disable authentication]' \
  '--perm+[default permissions]:permissions:' && ret=0

return ret
