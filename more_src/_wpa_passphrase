#compdef wpa_passphrase
# Documentation: https://manpages.debian.org/bookworm/wpasupplicant/wpa_passphrase.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:SSID:' \
  '2:passphrase:' && ret=0

return ret
