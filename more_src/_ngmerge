#compdef NGmerge ngmerge
# _ngmerge — John Gaspar harvardinformatics NGmerge paired-end Illumina read merger with adapter removal (harvardinformatics team, C); getopt
# upstream: https://github.com/jsh58/NGmerge

_ngmerge() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-1+[forward reads file]:file:_files -g "*.fq *.fq.gz *.fastq *.fastq.gz"' \
        '-2+[reverse reads file]:file:_files -g "*.fq *.fq.gz *.fastq *.fastq.gz"' \
        '-o+[output file]:file:_files' \
        '-y+[overlap distance]:n:' \
        '-m+[min overlap]:n:' \
        '-p+[max mismatch fraction]:f:' \
        '-q+[min quality score]:n:' \
        '-a[stitcher adapter mode]' \
        '-d[allow dovetailed alignment]' \
        '-e+[min trimmed length]:n:' \
        '-s[skip adapter removal]' \
        '-u+[interleaved input]:b:(0 1)' \
        '-i[interleaved input]' \
        '-c+[failed reads output file]:file:_files' \
        '-w+[Phred ASCII offset]:n:' \
        '-g+[log file]:file:_files' \
        '-z[gzip output]' \
        '-Z[do not gzip output]' \
        '-r[print log to stderr]' \
        '-l+[verbose log file]:file:_files' \
        '-x+[suffix to trim]:str:' \
        '-t+[threads]:n:' \
        '-v[verbose]'
}

_ngmerge "$@"
