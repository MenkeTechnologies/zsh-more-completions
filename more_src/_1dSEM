#compdef 1dSEM
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dSEM.html
# Compute path coefficients for connection matrix in Structural Equation Modeling

local ret=1

_arguments -s -S \
  '-theta[connection matrix 1D file with initial representation]:file:_files' \
  '-C[correlation matrix 1D file]:file:_files' \
  '-psi[residual variance vector 1D file]:file:_files' \
  '-DF[degrees of freedom]:nn.n' \
  '-max_iter[max iterations for convergence (default 10000)]:n' \
  '-nrand[number of random trials before optimization (default 100)]:n' \
  '-limits[lower and upper limits for connection coefficients]:m.mmm' \
  '-calccost[calculate cost function without modeling]' \
  '-verbose[print info every nnnnn steps]:nnnnn' \
  '-tree_growth[search for best model by growing incrementally]' \
  '-model_search[search for best model by growing from previous]' \
  '-max_paths[max number of paths to include (default 1000)]:n' \
  '-stop_cost[stop searching when cost below this value]:n.nnn' \
  '-forest_growth[search all models at increasing coefficients]' \
  '-grow_all[search all possible model combinations]' \
  '-leafpicker[expand optimization search to avoid local minimum]' \
  '*:file:_files' && ret=0

return ret
