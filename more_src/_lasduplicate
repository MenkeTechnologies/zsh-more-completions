#compdef lasduplicate
# LAStools: remove duplicate points from LAS/LAZ files

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[display tool version]' \
  '-gui[launch with GUI]' \
  '(-v -verbose)'{-v,-verbose}'[print detailed processing information]' \
  '-unique_xyz[remove only points with identical x y z]' \
  '-lowest_z[keep lowest point among xy-duplicates]' \
  '-highest_z[keep highest point among duplicates]' \
  '-nearby+[remove nearby points within distance n]:distance' \
  '-single_returns[mark single returns]' \
  '-record_removed[save removed points to separate file]' \
  '-flag_as_withheld[flag duplicates as withheld instead of removing]' \
  '-hash_map[use hash_map for duplicate detection]' \
  '-hash_set[use hash_set for duplicate detection]' \
  '-two_pass[find duplicates in two passes]' \
  '*-i+[input file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-merged[merge multiple input files]' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-cores+[process on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
