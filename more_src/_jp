#compdef jp
# Documentation: https://man.archlinux.org/search?q=jp
# Reference accessed: 2026-05-16

_arguments -s \
  '(-f --filename)'{-f,--filename=}'[read JSON from file]:file:_files -g "*.json"' \
  '(-u --unquoted)'{-u,--unquoted}'[print string results without quotes]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  ':jmespath expression:'
