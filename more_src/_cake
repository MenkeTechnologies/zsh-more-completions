#compdef cake
# Documentation: https://pyrocko.org/docs/current/apps/cake/manual.html
# Pyrocko cake: travel-times and ray paths for 1D layered media

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--phase --phases)'{--phase=,--phases=}'[phases in cake syntax]:phases:' \
  '--classic=[phases in classic nomenclature]:phases:' \
  '--model=[builtin model name or filename]:model:(prem ak135-f-continental.m ak135-f-average.m iasp91)' \
  '--format=[model file format]:format:(nd hyposat)' \
  '--crust2loc=[CRUST2.0 profile location lat,lon]:latlon:' \
  '--sdepth=[source depths in km]:km:' \
  '--rdepth=[receiver depths in km]:km:' \
  '--distances=[surface distances in km]:km:' \
  '--degrees[distances given in degrees]' \
  '--vp=[P velocity]:vp:' \
  '--vs=[S velocity]:vs:' \
  '--rho=[density]:rho:' \
  '--qp=[P quality factor]:qp:' \
  '--qs=[S quality factor]:qs:' \
  '--poisson=[Poisson ratio]:val:' \
  '--lambda=[Lame lambda]:val:' \
  '--mu=[Lame mu]:val:' \
  '--vred=[reduction velocity]:val:' \
  '--slowness=[surface slowness s/km]:val:' \
  '--interface=[interface name or depth]:iface:' \
  '1:command:(print arrivals paths plot-xt plot-xp plot-rays plot plot-model list-models list-phase-map simplify-model scatter)' \
  '*::args:_files' && ret=0

return ret
