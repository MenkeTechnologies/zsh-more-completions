#compdef shot-scraper

# Zsh completion for shot-scraper - command-line utility for taking screenshots of websites

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'shot:take a screenshot of a URL'
      'multi:take multiple screenshots from a YAML config'
      'javascript:execute JavaScript against a URL'
      'accessibility:get accessibility snapshot of a URL'
      'pdf:create a PDF of a URL'
      'html:get rendered HTML of a URL'
      'auth:save authentication credentials for a URL'
    )
    _describe -t commands 'shot-scraper command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      shot)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output}'+[output file]:file:_files' \
          {-s,--selector}'+[CSS selector]:selector' \
          {-w,--width}'+[browser width]:width' \
          '--height+[browser height]:height' \
          '--retina[use retina resolution]' \
          '--quality+[JPEG quality (1-100)]:quality' \
          '--wait+[wait time in ms]:milliseconds' \
          '--wait-for+[wait for CSS selector]:selector' \
          '--padding+[padding around element]:padding' \
          '--javascript+[JavaScript to execute]:code' \
          '--js-selector+[CSS selector returned by JavaScript]:selector' \
          '--timeout+[timeout in ms]:milliseconds' \
          {-b,--browser}'+[browser to use]:browser:(chromium firefox webkit)' \
          '--browser-arg+[extra browser argument]:argument' \
          '--auth+[authentication file]:file:_files' \
          '--user-agent+[custom user agent string]:string' \
          '--reduced-motion[enable reduced motion]' \
          '--log-console[log console output]' \
          '--fail[fail on page errors]' \
          '--skip[skip on errors]' \
          '1:url' && ret=0
        ;;
      multi)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output}'+[output directory]:directory:_directories' \
          {-b,--browser}'+[browser to use]:browser:(chromium firefox webkit)' \
          '--auth+[authentication file]:file:_files' \
          '--retina[use retina resolution]' \
          '--timeout+[timeout in ms]:milliseconds' \
          '1:config file:_files -g "*.{yml,yaml}"' && ret=0
        ;;
      javascript)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output}'+[output file]:file:_files' \
          {-b,--browser}'+[browser to use]:browser:(chromium firefox webkit)' \
          '--auth+[authentication file]:file:_files' \
          '--user-agent+[custom user agent string]:string' \
          '--timeout+[timeout in ms]:milliseconds' \
          '1:url' \
          '2:javascript code' && ret=0
        ;;
      accessibility)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output}'+[output file]:file:_files' \
          {-b,--browser}'+[browser to use]:browser:(chromium firefox webkit)' \
          '--auth+[authentication file]:file:_files' \
          '--javascript+[JavaScript to execute]:code' \
          '--timeout+[timeout in ms]:milliseconds' \
          '1:url' && ret=0
        ;;
      pdf)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output}'+[output file]:file:_files' \
          {-b,--browser}'+[browser to use]:browser:(chromium firefox webkit)' \
          '--auth+[authentication file]:file:_files' \
          '--javascript+[JavaScript to execute]:code' \
          '--wait+[wait time in ms]:milliseconds' \
          '--timeout+[timeout in ms]:milliseconds' \
          '--landscape[landscape orientation]' \
          '--format+[paper format]:format:(letter legal tabloid ledger a0 a1 a2 a3 a4 a5 a6)' \
          '--media-type+[media type]:type' \
          '1:url' && ret=0
        ;;
      html)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output}'+[output file]:file:_files' \
          {-b,--browser}'+[browser to use]:browser:(chromium firefox webkit)' \
          '--auth+[authentication file]:file:_files' \
          '--javascript+[JavaScript to execute]:code' \
          '--timeout+[timeout in ms]:milliseconds' \
          '1:url' && ret=0
        ;;
      auth)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-b,--browser}'+[browser to use]:browser:(chromium firefox webkit)' \
          '1:url' \
          '2:auth file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
