#compdef calibre-customize calibre-debug calibre-smtp
# Documentation: source-direct extraction from upstream
# kovidgoyal/calibre
#   src/calibre/customize/ui.py:option_parser() -> 7 add_option
#                                                   calls.
#   src/calibre/debug.py:option_parser()        -> 25 add_option
#                                                   calls (incl.
#                                                   --default-
#                                                   programs
#                                                   choices=
#                                                   register|
#                                                   unregister).
#   src/calibre/utils/smtp.py:option_parser()   -> 14 add_option
#                                                   calls split
#                                                   across COMPOSE
#                                                   MAIL (2) +
#                                                   SMTP RELAY (8)
#                                                   + top-level (4)
#                                                   groups.
# Reference accessed: 2026-05-30 via gh api.
# kovidgoyal calibre R174 — 3-stem multi-binary harvest of the
# calibre command-line companion tools shipped alongside the
# already-covered calibre/calibredb/calibre-cli + ebook-meta/
# ebook-convert/ebook-edit/ebook-polish/ebook-viewer/fetch-
# ebook-metadata family.  calibre-customize manages calibre
# plugins; calibre-debug exposes the calibre Python runtime,
# diff tool, kepubify, book-explode/implode, and many internal-
# state inspection helpers; calibre-smtp sends an email through
# calibre's mail-relay code (used for ebook-attachment delivery
# to e-readers).

case $service in

  calibre-customize)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '--version[print version and exit]' \
      '(-a --add-plugin)'{-a+,--add-plugin=}'[add plugin by path to ZIP file]:file:_files -g "*.zip"' \
      '(-b --build-plugin)'{-b+,--build-plugin=}'[zip up the in-development plugin folder and install]:dir:_files -/' \
      '(-r --remove-plugin)'{-r+,--remove-plugin=}'[remove a custom plugin by name (no effect on builtins)]:name:' \
      '--customize-plugin=[customize plugin (name,customization-string)]:name,string:' \
      '(-l --list-plugins)'{-l,--list-plugins}'[list all installed plugins]' \
      '--enable-plugin=[enable the named plugin]:name:' \
      '--disable-plugin=[disable the named plugin]:name:'
    ;;

  calibre-debug)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '--version[print version and exit]' \
      '(-c --command)'{-c+,--command=}'[run Python code inline]:code:' \
      '(-e --exec-file)'{-e+,--exec-file=}'[run Python code from file]:file:_files -g "*.py"' \
      '(-f --subset-font)'{-f,--subset-font}'[subset the specified font (-- to pass options to font subsetter)]' \
      '(-d --debug-device-driver)'{-d,--debug-device-driver}'[debug device detection]' \
      '(-g --gui)'{-g,--gui}'[run the GUI with debugging enabled]' \
      '--gui-debug=[run the GUI with a debug console, logging to path (internal)]:file:_files' \
      '--run-without-debug[do not run with the DEBUG flag set]' \
      '(-w --viewer)'{-w,--viewer}'[run the e-book viewer in debug mode]' \
      '--paths[output paths needed to set up the calibre environment]' \
      '--add-simple-plugin=[add a simple .py-only plugin]:file:_files -g "*.py"' \
      '(-m --inspect-mobi)'{-m,--inspect-mobi}'[inspect the MOBI file(s) at the specified path(s)]' \
      '(-t --edit-book)'{-t,--edit-book}'[launch the calibre Edit-book tool in debug mode]' \
      '(-x --explode-book)'{-x,--explode-book}'[explode book into folder (-x file.epub output_dir)]' \
      '(-i --implode-book)'{-i,--implode-book}'[implode a previously exploded book]' \
      '--export-all-calibre-data[export books/settings/plugins (optional positional export-folder + libraries or "all")]' \
      '--import-calibre-data[import previously exported calibre data]' \
      '(-s --shutdown-running-calibre)'{-s,--shutdown-running-calibre}'[shut down a running calibre instance (aborts running jobs!)]' \
      '--test-build[test binary modules in build]' \
      '(-r --run-plugin)'{-r+,--run-plugin=}'[run a plugin that provides a command-line interface]:name:' \
      '(-t --run-test)'{-t+,--run-test=}'[run named test(s); "all" for all; .name=module; @name=category]:name:' \
      '--diff[run the calibre diff tool]' \
      '--default-programs=[(un)register calibre as a Windows default program]:action:(register unregister)' \
      '--kepubify[convert specified EPUB to KEPUB (Kobo-driver inverse of un-kepubify)]' \
      '--un-kepubify[convert specified KEPUB to EPUB (Kobo-driver inverse of kepubify)]' \
      '*::positional / -- / passthrough args:_files'
    ;;

  calibre-smtp)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '--version[print version and exit]' \
      '(-a --attachment)'{-a+,--attachment=}'[file to attach to the email (compose mode)]:file:_files' \
      '(-s --subject)'{-s+,--subject=}'[subject of the email (compose mode)]:subject:' \
      '(-l --localhost)'{-l+,--localhost=}'[hostname of localhost (used when connecting to SMTP server)]:host:_hosts' \
      '(-r --relay)'{-r+,--relay=}'[SMTP relay server to use to send mail]:host:_hosts' \
      '(-p --port)'{-p+,--port=}'[port on relay server (default 465 for SSL, 25 otherwise)]:port:' \
      '(-u --username)'{-u+,--username=}'[username for relay]:user:_users' \
      '(-p --password)'{-p+,--password=}'[password for relay]:password:' \
      '(-e --encryption-method)'{-e+,--encryption-method=}'[TLS/SSL/NONE (default TLS; NONE is highly insecure)]:method:(TLS SSL NONE)' \
      '--dont-verify-server-certificate[do not verify TLS server certificate]' \
      '--cafile=[path to PEM-format CA certificates file for TLS verification]:file:_files -g "*.(pem|crt)"' \
      '(-o --outbox)'{-o+,--outbox=}'[path to maildir folder to store failed messages]:dir:_files -/' \
      '(-f --fork)'{-f,--fork}'[fork and deliver in background (pair with --outbox for failure-handling)]' \
      '(-t --timeout)'{-t+,--timeout=}'[connection timeout in seconds]:sec:' \
      '*'{-v,--verbose}'[be more verbose (repeatable)]' \
      '*:: positional / from / to / text (omit text to read RFC 5322 message from stdin):'
    ;;

esac
