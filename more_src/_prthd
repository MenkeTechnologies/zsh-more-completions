#compdef prthd
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/prthd.html
# MIRIAD prthd - print header information for datasets

local ret=1

_arguments -s -S \
  'in=[input image and/or uv data-sets]:in:_files' \
  'log=[output destination]:log:_files' \
  'options=[brief,full]:options:(brief full)' \
  '*:dataset:_files' && ret=0

return ret
