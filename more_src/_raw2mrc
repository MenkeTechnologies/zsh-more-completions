#compdef raw2mrc
# Documentation: https://bio3d.colorado.edu/imod/doc/man/raw2mrc.html
# Convert raw image data to an MRC file

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-input -InputFile)'{-input,-InputFile}'[Input image file. Input files may also be entered after]:file:_files' \
  '(-output -OutputFile)'{-output,-OutputFile}'[Output image file. If this entry is omitted, the last n]:file:_files' \
  '(-x -XSize)'{-x,-XSize}'[Set the width of the image; this entry is required]:value:' \
  '(-y -YSize)'{-y,-YSize}'[Set the height of the input image; this entry is requir]:value:' \
  '(-z -SectionsPerFile)'{-z,-SectionsPerFile}'[Set the number of sections in each input image file, th]:value:' \
  '(-t -DataType)'{-t,-DataType}'[Set the type of input data; the default is byte data. T]:value:' \
  '(-s -SwapBytes)'{-s,-SwapBytes}'[Swap input bytes. Does not work for doubles]' \
  '(-o -OffsetToImageData)'{-o,-OffsetToImageData}'[Set the offset value used at the beginning of the file,]:value:' \
  '(-oz -SkipBetweenSections)'{-oz,-SkipBetweenSections}'[Set the offset value used at the end of each section, t]:value:' \
  '(-f -FlipInY)'{-f,-FlipInY}'[Flip the images around the X axis]' \
  '(-i -InvertInZ)'{-i,-InvertInZ}'[Produce an inverted output stack by both inverting the ]' \
  '(-iz -ReadInvertedInZ)'{-iz,-ReadInvertedInZ}'[Invert the order of reading Z slices from each individu]' \
  '(-d -DivideBy2)'{-d,-DivideBy2}'[Divide unsigned 16-bit values by 2, or divide any 32-bi]' \
  '(-u -UnsignedOutput)'{-u,-UnsignedOutput}'[Store unsigned 16-bit values without modification in an]' \
  '(-c -ConvertTo16BitInt)'{-c,-ConvertTo16BitInt}'[Convert 32-bit integers or 64-bit doubles to 16-bit int]' \
  '(-p -PixelSpacing)'{-p,-PixelSpacing}'[Set the pixel spacing of the MRC file header to the giv]:value:' \
  '(-pz -ZPixelSpacing)'{-pz,-ZPixelSpacing}'[Set the Z pixel spacing of the MRC file header to the g]:value:' \
  '-StandardInput[Read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
