#compdef xenmon

# xenmon: Xen domain scheduling/IO monitor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-l[live mode]' \
  '-n[number of samples]:n:' \
  '-i[sampling interval ms]:ms:' \
  '-d[debug]' \
  '-t[show CPU details]' \
  '-f[output file]:file:_files' \
  '*::xenmon args:_files' && ret=0
return ret
