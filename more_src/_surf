#compdef surf

# Completion for surf - Suckless web browser

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b[disable scrollbars]' \
  '-B[enable scrollbars]' \
  '-c+[cookie file]:cookie file:_files' \
  '-C+[style sheet file]:style file:_files -g "*.css"' \
  '-d[disable disk cache]' \
  '-D[enable disk cache]' \
  '-e+[embed into window]:window ID' \
  '-f[start in fullscreen]' \
  '-F[start windowed]' \
  '-g[disable giving geolocation]' \
  '-G[enable giving geolocation]' \
  '-i[disable images]' \
  '-I[enable images]' \
  '-k[disable kiosk mode]' \
  '-K[enable kiosk mode]' \
  '-m[disable smooth scrolling]' \
  '-M[enable smooth scrolling]' \
  '-n[disable inspector]' \
  '-N[enable inspector]' \
  '-p[disable plugins]' \
  '-P[enable plugins]' \
  '-r+[script file]:script file:_files' \
  '-s[disable JavaScript]' \
  '-S[enable JavaScript]' \
  '-t+[style file]:style file:_files -g "*.css"' \
  '-u+[user agent string]:user agent' \
  '-x+[window ID]:window ID' \
  '-z+[zoom level]:zoom level' \
  '1:URI' && ret=0

return ret
