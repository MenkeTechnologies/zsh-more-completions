#compdef surf
# Documentation: https://git.suckless.org/surf/file/surf.1.html
# Reference accessed: 2026-05-21
# Verified: upstream surf(1) manpage.

# Completion for surf - Suckless web browser

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a+[cookie policy order]:policies:' \
  '-b[disable scrollbars]' \
  '-B[enable scrollbars]' \
  '-c+[cookie file]:cookie file:_files' \
  '-C+[user stylesheet file]:style file:_files -g "*.css"' \
  '-d[disable disk cache]' \
  '-D[enable disk cache]' \
  '-e+[reparent into window (xid)]:xid:' \
  '-f[windowed mode]' \
  '-F[fullscreen mode]' \
  '-g[disable geolocation]' \
  '-G[enable geolocation]' \
  '-i[disable images]' \
  '-I[enable images]' \
  '-k[disable kiosk mode]' \
  '-K[enable kiosk mode]' \
  '-m[disable user stylesheets]' \
  '-M[enable user stylesheets]' \
  '-n[disable Web Inspector]' \
  '-N[enable Web Inspector]' \
  '-r+[user script file]:script file:_files' \
  '-s[disable JavaScript]' \
  '-S[enable JavaScript]' \
  '-t[disable strict TLS check]' \
  '-T[enable strict TLS check]' \
  '-u+[user agent string]:user agent:' \
  '-v[print version]' \
  '-w[print xid to stdout]' \
  '-x[disable custom certificates]' \
  '-X[enable custom certificates]' \
  '-z+[zoom level]:zoom level:' \
  '1:URI' && ret=0

return ret
