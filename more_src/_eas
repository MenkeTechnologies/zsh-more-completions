#compdef eas

# Zsh completion for EAS CLI (Expo Application Services)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:build app binary'
      'build:list:list recent builds'
      'build:cancel:cancel a build'
      'build:configure:configure project for EAS Build'
      'build:inspect:inspect build artifacts'
      'build:resign:re-sign a build'
      'build:run:run build on simulator/emulator'
      'build:version:manage build versions'
      'submit:submit app binary to store'
      'update:publish an update'
      'update:configure:configure updates'
      'update:delete:delete an update group'
      'update:list:list updates'
      'update:republish:republish an update'
      'update:roll-back-to-embedded:roll back channel'
      'branch:list:list branches'
      'branch:create:create a branch'
      'branch:delete:delete a branch'
      'branch:rename:rename a branch'
      'channel:list:list channels'
      'channel:create:create a channel'
      'channel:edit:edit a channel'
      'channel:rollout:manage channel rollouts'
      'credentials:manage app credentials'
      'device:list:list registered devices'
      'device:create:register a device'
      'device:delete:remove a registered device'
      'device:rename:rename a device'
      'env:manage environment variables'
      'init:create or link an EAS project'
      'login:log in to EAS'
      'logout:log out of EAS'
      'metadata:manage store metadata'
      'open:open project page in browser'
      'project:init:initialize a project'
      'project:info:show project info'
      'secret:list:list secrets'
      'secret:create:create a secret'
      'secret:delete:delete a secret'
      'webhook:list:list webhooks'
      'webhook:create:create a webhook'
      'webhook:delete:delete a webhook'
      'webhook:update:update a webhook'
      'whoami:show current user'
      'diagnostics:show environment diagnostics'
    )
    _describe -t commands 'eas command' commands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-p+[platform]:platform:(android ios all)' \
          '--platform=[platform]:platform:(android ios all)' \
          '--profile=[build profile]:profile' \
          '-e+[build profile]:profile' \
          '--local[build locally]' \
          '--non-interactive[non-interactive mode]' \
          '--no-wait[do not wait for build to complete]' \
          '--clear-cache[clear build cache]' \
          '--auto-submit[auto-submit after build]' \
          '--json[output as JSON]' && ret=0
        ;;
      submit)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-p+[platform]:platform:(android ios)' \
          '--platform=[platform]:platform:(android ios)' \
          '--profile=[submit profile]:profile' \
          '-e+[submit profile]:profile' \
          '--latest[submit latest build]' \
          '--id=[build ID to submit]:id' \
          '--path=[path to binary]:path:_files' \
          '--url=[URL to binary]:url' \
          '--non-interactive[non-interactive mode]' && ret=0
        ;;
      update)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--branch=[branch to publish to]:branch' \
          '--channel=[channel to publish to]:channel' \
          '--message=[update message]:message' \
          '-p+[platform]:platform:(android ios all)' \
          '--platform=[platform]:platform:(android ios all)' \
          '--auto[use default options]' \
          '--non-interactive[non-interactive mode]' \
          '--json[output as JSON]' && ret=0
        ;;
    esac
    ;;
esac

return ret
