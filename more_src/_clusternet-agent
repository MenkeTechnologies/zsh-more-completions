#compdef clusternet-agent
# _clusternet-agent — Clusternet child-cluster agent (clusternet/clusternet)
# upstream: https://github.com/clusternet/clusternet
# Flags from pkg/agent/options/ (pflag).

_clusternet-agent() {
    _arguments \
        '--cluster-reg-parent-url=[parent cluster registration URL]:url:_urls' \
        '--cluster-reg-token=[bootstrap token for registration]:token:' \
        '--cluster-reg-name=[explicit cluster registration name]:name:' \
        '--cluster-reg-name-prefix=[cluster registration name prefix]:prefix:' \
        '--cluster-reg-namespace=[cluster registration namespace]:ns:' \
        '--cluster-reg-type=[cluster type]:type:' \
        '--cluster-sync-mode=[cluster sync mode]:mode:(Push Pull Dual)' \
        '--cluster-labels=[cluster labels (k=v,...)]:labels:' \
        '--cluster-status-update-frequency=[cluster status update interval]:duration:' \
        '--cluster-status-collect-frequency=[cluster status collect interval]:duration:' \
        '--use-metrics-server[query metrics-server for node metrics]' \
        '--predictor-addr=[predictor address]:url:_urls' \
        '--predictor-direct-access[direct access to predictor (no tunnel)]' \
        '--predictor-port=[predictor port]:port:' \
        '--labels-aggregate-threshold=[label aggregation threshold]:n:' \
        '--labels-aggregate-prefix=[label aggregation prefix]:prefix:' \
        '--enable-tunnel-logging[enable tunnel logging]' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_clusternet-agent "$@"
