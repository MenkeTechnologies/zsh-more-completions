#compdef nsqd
# Documentation: https://nsq.io/components/nsqd.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '*-auth-http-address=[auth HTTP address (repeatable)]:address:'
  '-broadcast-address=[address registered with lookupd]:address:'
  '-broadcast-http-port=[HTTP port registered with lookupd]:port:'
  '-broadcast-tcp-port=[TCP port registered with lookupd]:port:'
  '-config=[path to config file]:file:_files'
  '-data-path=[path for disk-backed messages]:path:_files -/'
  '-deflate[enable deflate feature negotiation]'
  '-e2e-processing-latency-percentile=[percentile for end-to-end latency]:percentile:'
  '-e2e-processing-latency-window-time=[window time for latency quantiles]:duration:'
  '*-enable-experiment=[experimental feature to enable (repeatable)]:name:'
  '-http-address=[address for HTTP clients]:address:'
  '-http-client-connect-timeout=[HTTP client connect timeout]:duration:'
  '-http-client-request-timeout=[HTTP client request timeout]:duration:'
  '-https-address=[address for HTTPS clients]:address:'
  '-log-level=[log level]:level:(debug info warn error fatal)'
  '-log-prefix=[log message prefix]:prefix:'
  '*-lookupd-tcp-address=[lookupd TCP address (repeatable)]:address:'
  '-max-body-size=[max command body size]:bytes:'
  '-max-bytes-per-file=[max bytes per diskqueue file]:bytes:'
  '-max-channel-consumers=[max channel consumer connections per instance]:count:'
  '-max-deflate-level=[max deflate compression level]:level:(1 2 3 4 5 6 7 8 9)'
  '-max-defer-timeout=[max defer duration for deferred publish]:duration:'
  '-max-heartbeat-interval=[max client heartbeat interval]:duration:'
  '-max-msg-size=[max single message size]:bytes:'
  '-max-msg-timeout=[max message timeout]:duration:'
  '-max-output-buffer-size=[max client output buffer size]:bytes:'
  '-max-output-buffer-timeout=[max output buffer flush duration]:duration:'
  '-max-rdy-count=[max RDY count for a client]:count:'
  '-max-req-timeout=[max requeue timeout]:duration:'
  '-mem-queue-size=[in-memory message queue size]:size:'
  '-min-output-buffer-timeout=[min output buffer flush duration]:duration:'
  '-msg-timeout=[default message auto-requeue wait]:duration:'
  '-node-id=[unique part for message IDs (0-1024)]:id:'
  '-output-buffer-timeout=[default output buffer flush duration]:duration:'
  '-snappy[enable snappy feature negotiation]'
  '-statsd-address=[UDP address for statsd]:address:'
  '-statsd-interval=[duration between statsd pushes]:duration:'
  '-statsd-mem-stats[toggle memory and GC stats to statsd]'
  '-statsd-prefix=[stats key prefix]:prefix:'
  '-statsd-udp-packet-size=[statsd UDP packet size]:bytes:'
  '-sync-every=[messages per diskqueue fsync]:count:'
  '-sync-timeout=[duration per diskqueue fsync]:duration:'
  '-tcp-address=[address for TCP clients]:address:'
  '-tls-cert=[TLS certificate file]:file:_files'
  '-tls-client-auth-policy=[TLS client auth policy]:policy:(require require-verify)'
  '-tls-key=[TLS key file]:file:_files'
  '-tls-min-version=[min TLS version]:version:(tls1.0 tls1.1 tls1.2)'
  '-tls-required[require TLS for clients]'
  '-tls-root-ca-file=[TLS root CA file]:file:_files'
  '-topology-region=[region for topology-aware-consumption experiment]:region:'
  '-topology-zone=[zone for topology-aware-consumption experiment]:zone:'
  '-verbose[deprecated; use -log-level]'
  '-version[print version string]'
  '-worker-id=[DEPRECATED use -node-id]:id:'
)

_arguments -s -S $arguments
