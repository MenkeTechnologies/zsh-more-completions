#compdef nsqd

local -a arguments

arguments=(
  '--auth-http-address=[auth HTTP address]:address:'
  '--broadcast-address=[address to broadcast to lookupd]:address:'
  '--broadcast-http-port=[HTTP port to broadcast]:port:'
  '--broadcast-tcp-port=[TCP port to broadcast]:port:'
  '--data-path=[path to store disk-backed messages]:path:_files -/'
  '--deflate[enable deflate negotiation]'
  '--e2e-processing-latency-percentile=[percentile for latency calc]:percentile:'
  '--e2e-processing-latency-window-time=[window time for latency calc]:duration:'
  '--http-address=[address to listen on for HTTP clients]:address:'
  '--https-address=[address to listen on for HTTPS clients]:address:'
  '--log-level=[log level]:level:(debug info warn error fatal)'
  '--log-prefix=[log message prefix]:prefix:'
  '--lookupd-tcp-address=[address of lookupd (may be given multiple times)]:address:'
  '--max-body-size=[max size of a single command body]:bytes:'
  '--max-bytes-per-file=[max bytes per diskqueue file]:bytes:'
  '--max-channel-consumers=[max channel consumers before pausing]:count:'
  '--max-deflate-level=[max deflate compression level]:level:(1 2 3 4 5 6 7 8 9)'
  '--max-heartbeat-interval=[max client heartbeat interval]:duration:'
  '--max-msg-size=[max size of a single message]:bytes:'
  '--max-msg-timeout=[max message timeout]:duration:'
  '--max-output-buffer-size=[max client output buffer size]:bytes:'
  '--max-output-buffer-timeout=[max client output buffer timeout]:duration:'
  '--max-rdy-count=[max RDY count]:count:'
  '--max-req-timeout=[max requeue timeout]:duration:'
  '--mem-queue-size=[in-memory message queue size]:size:'
  '--msg-timeout=[default message timeout]:duration:'
  '--node-id=[unique node ID]:id:'
  '--snappy[enable snappy negotiation]'
  '--statsd-address=[address to send stats]:address:'
  '--statsd-interval=[interval between stats updates]:duration:'
  '--statsd-mem-stats[toggle sending memory and GC stats]'
  '--statsd-prefix=[stats key prefix]:prefix:'
  '--statsd-udp-packet-size=[size of UDP packets for stats]:bytes:'
  '--sync-every=[number of messages between diskqueue syncs]:count:'
  '--sync-timeout=[duration between diskqueue syncs]:duration:'
  '--tcp-address=[address to listen on for TCP clients]:address:'
  '--tls-cert=[TLS certificate file]:file:_files'
  '--tls-client-auth-policy=[TLS client auth policy]:policy:(require require-verify)'
  '--tls-key=[TLS key file]:file:_files'
  '--tls-min-version=[min TLS version]:version:(tls1.0 tls1.1 tls1.2)'
  '--tls-required[require TLS for clients]'
  '--tls-root-ca-file=[TLS root CA file]:file:_files'
  '--verbose[enable verbose logging]'
  '--version[show version]'
  '--worker-id=[DEPRECATED use --node-id]:id:'
)

_arguments -s -S $arguments
