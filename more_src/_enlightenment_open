#compdef enlightenment_open
# Documentation: https://github.com/Enlightenment/enlightenment
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# enlightenment_open: helper to open a file with the configured E app
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:file:_files' && ret=0
return ret
