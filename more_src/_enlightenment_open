#compdef enlightenment_open
# Documentation: https://man.archlinux.org/search?q=enlightenment_open
# Reference accessed: 2026-05-16

# enlightenment_open: helper to open a file with the configured E app
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:file:_files' && ret=0
return ret
