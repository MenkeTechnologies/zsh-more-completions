local curcontext="$curcontext" state line ret=1

_arguments \
    '1:request-id:_default' \
    '2:limit:_default' \
    '3:timeout (seconds):_default' \
    '4:user-id:_default' \
    '5:options:_default' \
    && ret=0

return ret
