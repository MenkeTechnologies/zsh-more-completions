#compdef sooperlooper slgui slconsole

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-l --loopcount)'{-l,--loopcount}'+[number of loops]:n:' \
  '(-c --channels)'{-c,--channels}'+[channels per loop]:n:' \
  '(-t --looptime)'{-t,--looptime}'+[seconds of buffer]:sec:' \
  '(-D --discrete-io)'{-D,--discrete-io}'[discrete IO ports]' \
  '(-p --port)'{-p,--port}'+[OSC port]:port:' \
  '(-j --jack-name)'{-j,--jack-name}'+[JACK client name]:name:' \
  '(-S --jack-server-name)'{-S,--jack-server-name}'+[JACK server]:srv:' \
  '(-L --load-session)'{-L,--load-session}'+[load session]:file:_files -g "*.slsess"' \
  '(-m --load-midi-binding)'{-m,--load-midi-binding}'+[midi bind file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-x --exit-on-disconnect)'{-x,--exit-on-disconnect}'[exit when JACK disconnects]' \
  '*:loop file:_files' && ret=0

return ret
