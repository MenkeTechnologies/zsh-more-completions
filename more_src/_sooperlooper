#compdef sooperlooper slgui slconsole
# Documentation: https://manpages.debian.org/bullseye/sooperlooper/sooperlooper.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[display usage information]' \
  '(- *)'{-V,--version}'[show version only]' \
  '(-l --loopcount)'{-l+,--loopcount=}'[number of loopers]:n:' \
  '(-c --channels)'{-c+,--channels=}'[channel count per looper]:n:' \
  '(-t --looptime)'{-t+,--looptime=}'[seconds of loop memory per channel]:sec:' \
  '(-D --discrete-io)'{-D+,--discrete-io=}'[discrete input/output ports]:flag:(yes no)' \
  '(-p --osc-port)'{-p+,--osc-port=}'[UDP port for OSC server]:port:' \
  '(-j --jack-name)'{-j+,--jack-name=}'[JACK client name]:name:' \
  '(-S --jack-server-name)'{-S+,--jack-server-name=}'[specify JACK server name]:srv:' \
  '(-L --load-session)'{-L+,--load-session=}'[load initial session]:file:_files -g "*.slsess"' \
  '(-m --load-midi-binding)'{-m+,--load-midi-binding=}'[load MIDI bindings from file or preset]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress status output to stderr]' && ret=0

return ret
