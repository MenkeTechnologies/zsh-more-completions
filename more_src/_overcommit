#compdef overcommit
# Documentation: https://github.com/sds/overcommit
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --install)'{-i,--install}'[install hooks into repository]' \
  '(-u --uninstall)'{-u,--uninstall}'[uninstall hooks from repository]' \
  '(-f --force)'{-f,--force}'[overwrite existing hooks on install]' \
  '(-r --run)'{-r,--run}'[run pre-commit hook against all tracked files]' \
  '--diff=[run pre-commit against files changed relative to ref]:ref:' \
  '--sign[sign hooks configuration]' \
  '(-t --template-dir)'{-t,--template-dir}'[print template directory path]' \
  '(-l --list-hooks)'{-l,--list-hooks}'[list installed hooks]' && ret=0

return ret
