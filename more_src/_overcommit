#compdef overcommit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--install[install hooks into repository]' \
  '--uninstall[uninstall hooks from repository]' \
  '-r[run hooks]:hook type:(pre-commit commit-msg pre-push pre-rebase post-checkout post-commit post-merge post-rewrite)' \
  '--run=[run hooks]:hook type:(pre-commit commit-msg pre-push pre-rebase post-checkout post-commit post-merge post-rewrite)' \
  '--sign[sign hooks configuration]' \
  '--template-dir[print template directory path]' \
  '-l[list installed hooks]' \
  '--list-hooks[list installed hooks]' && ret=0

return ret
