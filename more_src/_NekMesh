#compdef NekMesh
# Documentation: https://doc.nektar.info/userguide/latest/user-guidese19.html
# Nektar++ NekMesh mesh generation and conversion utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '*'{-m,--module}'=[apply processing module (e.g. -m jac:list)]:module' \
  '(-l --modules-list)'{-l,--modules-list}'[list available modules]' \
  '(-p --modules-opt)'{-p,--modules-opt}'=[print options for a given module]:module' \
  '(-f --force-output)'{-f,--force-output}'[force output, disable backup file creation]' \
  '(-i --input-format)'{-i,--input-format}'=[specify input module/format]:format' \
  '(-o --output-format)'{-o,--output-format}'=[specify output module/format]:format' \
  '*:file:_files' && ret=0

return ret
