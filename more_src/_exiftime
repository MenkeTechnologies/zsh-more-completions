#compdef exiftime
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/exiftime.1.html
# Display or adjust date & time Exif tags; list files ordered by Exif date & time

local ret=1

_arguments -s -S \
  '-f[write adjusted tags without prompting]' \
  '-i[prompt before overwriting a tag (default)]' \
  '-l[list input files in ascending order by timestamp]' \
  '-q[suppress adjustment details on stdout with -w]' \
  '-s+[field/value separator string]:delim' \
  '-t+[select date/time tags (a c d g)]:tags' \
  '-v+[adjust tags by value]:adjustment' \
  '-w[write the adjusted date and time tags]' \
  '*:JPEG file:_files -g "*.(jpg|jpeg|JPG|JPEG)"' && ret=0

return ret
