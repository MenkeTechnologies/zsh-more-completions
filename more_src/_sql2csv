#compdef sql2csv
# Documentation: https://csvkit.readthedocs.io/en/latest/scripts/sql2csv.html
# Reference accessed: 2026-05-21
# Verified: csvkit sql2csv official docs (flags table).

# Zsh completion for sql2csv (csvkit)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v)-v[verbose error output]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--db=[SQLAlchemy database connection string]:connection string:' \
  '--query=[SQL query (overrides FILE and STDIN)]:query:' \
  '*--engine-option[SQLAlchemy create_engine() arg (repeatable, key value)]:option:' \
  '*--execution-option[SQLAlchemy execution_options() arg (repeatable, key value)]:option:' \
  '(-e --encoding)'{-e+,--encoding=}'[encoding of input query file]:encoding:' \
  '(-H --no-header-row)'{-H,--no-header-row}'[do not output column names]' \
  '*:sql file:_files -g "*.sql"' && return 0
