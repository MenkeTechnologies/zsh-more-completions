#compdef virt-qemu-sev-validate
# Documentation: https://libvirt.org/manpages/virt-qemu-sev-validate.html
# validate a launch measurement of a SEV/SEV-ES confidential guest

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display command line help then exit]' \
  '(-d --debug)'{-d,--debug}'[show debug information while running]' \
  '(-q --quiet)'{-q,--quiet}'[do not print info about the attestation result]' \
  '--measurement=[launch measurement reported by hypervisor (base64)]:measurement' \
  '--api-major=[SEV API major version of the hypervisor]:version' \
  '--api-minor=[SEV API minor version of the hypervisor]:version' \
  '--build-id=[SEV build ID of the hypervisor]:id' \
  '--policy=[policy bitmask for session launch data]:policy' \
  '(-f --firmware)'{-f,--firmware=}'[path to firmware loader binary]:firmware:_files' \
  '(-k --kernel)'{-k,--kernel=}'[path to kernel binary for direct boot]:kernel:_files' \
  '(-r --initrd)'{-r,--initrd=}'[path to initrd binary for direct boot]:initrd:_files' \
  '(-e --cmdline)'{-e,--cmdline=}'[kernel command line parameters]:cmdline' \
  '(-n --num-cpus)'{-n,--num-cpus=}'[number of virtual CPUs]:count' \
  '(-0 --vmsa-cpu0)'{-0,--vmsa-cpu0=}'[VMSA initial state for boot CPU]:path:_files' \
  '(-1 --vmsa-cpu1)'{-1,--vmsa-cpu1=}'[VMSA initial state for non-boot CPU]:path:_files' \
  '--tik=[TIK file (16 bytes)]:path:_files' \
  '--tek=[TEK file (16 bytes)]:path:_files' \
  '--tk=[combined TEK/TIK file (32 bytes)]:path:_files' \
  '(-c --connect)'{-c,--connect=}'[libvirt connection URI]:uri' \
  '(-o --domain)'{-o,--domain=}'[domain identifier for attestation]:domain' \
  '(-i --insecure)'{-i,--insecure}'[proceed despite insecure usage scenarios]' \
  '(-g --ignore-config)'{-g,--ignore-config}'[skip sanity checks on domain config]' \
  '--inject-secret=[secret file to inject on success]:alias-or-guid:path' \
  '--secret-header=[output file for injected secret header]:path:_files' \
  '--secret-payload=[output file for injected secret payload]:path:_files' && ret=0

return ret
