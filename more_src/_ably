#compdef ably
# Documentation: https://man.archlinux.org/search?q=ably
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'accounts:Control API: manage accounts'
  'apps:Control API: manage apps'
  'auth:authentication helpers (keys, JWT, token request)'
  'channels:Pub/Sub channel commands'
  'presence:channel presence commands'
  'connections:realtime connection helpers'
  'log:log commands'
  'integrations:Control API: manage integrations (rules)'
  'queues:Control API: manage Reactor queues'
  'rooms:Chat: manage chat rooms'
  'spaces:Spaces: real-time collaboration'
  'support:Ably support commands'
  'status:Ably status'
  'config:configure CLI default account/app/key'
  'autocomplete:install shell tab completion'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
  '--json[JSON output]' \
  '--pretty-json[colorized JSON output]' \
  '(-D --duration)'{-D+,--duration=}'[exit after N seconds]:seconds:' \
  '--api-key=[Ably API key]:key:' \
  '--token=[Ably token]:token:' \
  '--client-id=[client id]:id:' \
  '--access-token=[Control API access token]:token:' \
  '--host=[realtime host override]:host:_hosts' \
  '--env=[environment]:env:(production sandbox)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ably command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (channels)
        local -a chan_subs=(
          'publish:publish a message to a channel'
          'subscribe:subscribe to a channel'
          'history:retrieve message history'
          'list:list active channels'
          'occupancy:get channel occupancy metrics'
          'inspect:open the Ably dashboard for a channel'
          'batch-publish:publish to multiple channels'
          'logs:tail channel-related logs'
          'presence:channel presence commands'
        )
        _describe -t cscmds 'channels subcommand' chan_subs && ret=0 ;;
      (presence)
        local -a pres_subs=(
          'enter:enter the channel as a present member'
          'leave:leave the channel'
          'subscribe:subscribe to presence events'
          'list:list current presence members'
        )
        _describe -t pcmds 'presence subcommand' pres_subs && ret=0 ;;
      (accounts)
        _arguments '*::sub:(login logout list current stats me)' && ret=0 ;;
      (apps)
        _arguments '*::sub:(create list update delete current logs stats keys channel-rules namespaces)' && ret=0 ;;
      (auth)
        _arguments '*::sub:(keys revoke-token request-token issue-token issue-jwt-token)' && ret=0 ;;
      (rooms)
        _arguments '*::sub:(messages presence reactions occupancy typing)' && ret=0 ;;
      (spaces)
        _arguments '*::sub:(members locations cursors)' && ret=0 ;;
      (integrations)
        _arguments '*::sub:(create list update delete)' && ret=0 ;;
      (queues)
        _arguments '*::sub:(create list delete)' && ret=0 ;;
      (logs|log)
        _arguments '*::sub:(app channel push connection-lifecycle)' && ret=0 ;;
      (connections)
        _arguments '*::sub:(stats logs test)' && ret=0 ;;
      (config)
        _arguments '*::sub:(show set unset list)' && ret=0 ;;
      (autocomplete)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
