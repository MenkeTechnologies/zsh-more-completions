#compdef ThermoRawFileParser
# Documentation: https://github.com/compomics/ThermoRawFileParser
# Convert Thermo RAW files to open mass spectrometry formats.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-v --version)'{-v,--version}'[display executable version]' \
  '(-i --input)'{-i,--input}'=[raw file input]:file:_files' \
  '(-d --input_directory)'{-d,--input_directory}'=[directory containing raw files]:dir:_files -/' \
  '(-b --output)'{-b,--output}'=[single output file location]:file:_files' \
  '(-o --output_directory)'{-o,--output_directory}'=[output directory]:dir:_files -/' \
  '(-s --stdout)'{-s,--stdout}'[write to standard output]' \
  '(-f --format)'{-f,--format}'=[spectra output format]:fmt:((0\:MGF 1\:mzML 2\:indexed-mzML 3\:Parquet 4\:None))' \
  '(-m --metadata)'{-m,--metadata}'=[metadata output format]:fmt:((0\:JSON 1\:TXT 2\:None))' \
  '(-g --gzip)'{-g,--gzip}'[compress output files using gzip]' \
  '(-p --noPeakPicking)'{-p,--noPeakPicking}'[disable native peak picking]' \
  '(-z --noZlibCompression)'{-z,--noZlibCompression}'[disable m/z and intensity compression]' \
  '(-a --allDetectors)'{-a,--allDetectors}'[extract additional detector data (UV/PDA)]' \
  '(-L --msLevel)'{-L,--msLevel}'=[MS levels to include]:levels' \
  '(-N --noiseData)'{-N,--noiseData}'[include noise data in mzML output]' \
  '(-C --chargeData)'{-C,--chargeData}'[include detected charge states in mzML]' \
  '(-P --mgfPrecursor)'{-P,--mgfPrecursor}'[include precursor scan number in MGF TITLE]' \
  '(-l --logging)'{-l,--logging}'=[logging level 0-4]:level:(0 1 2 3 4)' \
  '(-e --ignoreInstrumentErrors)'{-e,--ignoreInstrumentErrors}'[handle missing instrument properties]' \
  '(-w --warningsAreErrors)'{-w,--warningsAreErrors}'[non-zero exit code for warnings]' \
  '(-x --excludeExceptionData)'{-x,--excludeExceptionData}'[exclude reference and exception data]' \
  '(-u --s3_url)'{-u,--s3_url}'=[S3 storage endpoint URL]:url' \
  '(-k --s3_accesskeyid)'{-k,--s3_accesskeyid}'=[AWS access key for S3]:key' \
  '(-t --s3_secretaccesskey)'{-t,--s3_secretaccesskey}'=[AWS secret key for S3]:key' \
  '(-n --s3_bucketName)'{-n,--s3_bucketName}'=[target S3 bucket name]:bucket' \
  '*:raw file:_files' && ret=0

return ret
