#compdef monika

# Zsh completion for Monika synthetic monitor (Hyperjump)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-c+[path to config YAML]:file:_files -g "*.yml *.yaml"' \
  '-r+[repeat period seconds]:seconds' \
  '-1[one probe cycle then exit]' \
  '*::args:{ _message "see monika --help" }' && ret=0

return ret
