#compdef xautolock
# _xautolock — xautolock X idle session locker; launches locker after configurable idle period
# upstream: https://www.ibiblio.org/pub/Linux/X11/screensavers

_xautolock() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-time+[idle minutes]:min:' \
        '-locker+[locker command]:cmd:_command_names -e' \
        '-killer+[killer command]:cmd:_command_names -e' \
        '-killtime+[kill after idle minutes]:min:' \
        '-corners+[corner action]:abcd:' \
        '-cornersize+[corner size px]:n:' \
        '-cornerdelay+[corner delay sec]:n:' \
        '-cornerredelay+[corner re-delay sec]:n:' \
        '-bell+[bell percent]:pct:' \
        '-disable[disable]' \
        '-enable[enable]' \
        '-toggle[toggle enable/disable]' \
        '-exit[exit daemon]' \
        '-restart[restart daemon]' \
        '-locknow[lock now]' \
        '-unlocknow[unlock now]' \
        '-detectsleep[detect sleep wakeup]' \
        '-noclose[do not close stdio]' \
        '-secure[do not lock when xss messages mode]' \
        '-resetsaver[reset xss timer]' \
        '-nowlocker+[now locker]:cmd:_command_names -e' \
        '-notify+[notify before lock min]:min:' \
        '-notifier+[notifier cmd]:cmd:_command_names -e'
}

_xautolock "$@"
