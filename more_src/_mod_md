#compdef mod_md a2md
# Documentation: https://github.com/icing/mod_md/blob/master/src/md_cmd_main.c
# Reference accessed: 2026-05-16
# Verified: upstream src/md_cmd_main.c. Real binary is `a2md`; no `md-helper`
# binary exists in upstream mod_md.

# a2md: Apache mod_md certificate manager CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-a --acme)'{-a,--acme=}'[ACME server directory URL]:url:' \
  '(-C --cafile)'{-C,--cafile=}'[root certificate PEM file]:file:_files' \
  '(-d --dir)'{-d,--dir=}'[directory for file data]:dir:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-j --json)'{-j,--json}'[produce json output]' \
  '(-p --proxy)'{-p,--proxy=}'[HTTP proxy URL]:url:' \
  '(-q --quiet)'{-q,--quiet}'[less output]' \
  '(-t --terms)'{-t,--terms=}'[agree to ACME terms URL]:url:' \
  '(-v --verbose)'{-v,--verbose}'[more output]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0
return ret
