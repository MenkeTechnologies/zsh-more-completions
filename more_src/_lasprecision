#compdef lasprecision
# Documentation: https://github.com/LAStools/LAStools
# LAStools: analyze actual precision of LAS/LAZ coordinates

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help documentation]' \
  '-version[display tool version]' \
  '-gui[launch with GUI]' \
  '(-v -verbose)'{-v,-verbose}'[enable verbose output]' \
  '-vv[enable very verbose output]' \
  '-silent[output only errors and warnings]' \
  '-quiet[suppress all output]' \
  '-all[analyze all points (default limits to 5M)]' \
  '-diff_diff[report differences of differences too]' \
  '-diff_diff_only[report only differences of differences]' \
  '-gps[report GPS timestamp statistics]' \
  '-rgb[report RGB color statistics]' \
  '-lines+[limit report output to n lines (default 20)]:n' \
  '-no_x[exclude x coordinate statistics]' \
  '-no_y[exclude y coordinate statistics]' \
  '-no_z[exclude z coordinate statistics]' \
  '-number+[limit analysis to first n points]:n' \
  '-rescale+[apply new scale factors x y z]:x' \
  '-reoffset+[apply new offsets x y z]:x' \
  '-week_to_adjusted+[convert GPS week to adjusted standard]:week' \
  '*-i+[input LAS/LAZ file]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-obin[output as terrasolid BIN]' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-otxt[output as text]' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
