#compdef outline-ss-server
# _outline-ss-server — Outline Shadowsocks server (Jigsaw-Code/outline-ss-server)
# upstream: https://github.com/Jigsaw-Code/outline-ss-server
# Flags from cmd/outline-ss-server/main.go (flag).

_outline-ss-server() {
    _arguments \
        '(- *)-h[show help]' \
        '-config=[configuration filename]:file:_files' \
        '-metrics=[Prometheus metrics bind address]:addr:' \
        '-ip_country_db=[IP-to-country mmdb file]:file:_files -g "*.mmdb"' \
        '-ip_asn_db=[IP-to-ASN mmdb file]:file:_files -g "*.mmdb"' \
        '-udptimeout=[UDP tunnel timeout]:duration:' \
        '-replay_history=[replay buffer size (# handshakes)]:n:' \
        '-verbose[enable verbose logging]' \
        '(- *)-version[show server version]'
}

_outline-ss-server "$@"
