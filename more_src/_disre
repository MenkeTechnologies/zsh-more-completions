#compdef disre gmx-disre
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-disre.html
# gmx disre: analyze distance restraints

local ret=1

_arguments -s \
  '-s[portable xdr run input file]:file:_files' \
  '-f[trajectory file]:file:_files' \
  '-n[index file]:file:_files' \
  '-c[cluster index file]:file:_files' \
  '-ds[distance restraint sum output]:file:_files' \
  '-da[distance restraint average output]:file:_files' \
  '-dn[distance restraint number output]:file:_files' \
  '-dm[distance restraint maximum output]:file:_files' \
  '-dr[restraint output file]:file:_files' \
  '-l[log file]:file:_files' \
  '-q[PDB output file]:file:_files' \
  '-x[matrix file]:file:_files' \
  '-b[first frame time]:time:' \
  '-e[last frame time]:time:' \
  '-dt[frame sampling interval]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-ntop[large violations to store per step]:int:' \
  '-maxdr[maximum violation threshold for matrix]:real:' \
  '-nlevels[matrix output levels]:int:' \
  '-third[use inverse third power averaging]' && ret=0

return ret
