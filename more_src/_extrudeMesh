#compdef extrudeMesh
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/mesh/generation/extrudeMesh — extrude mesh from existing surface/patch (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-roots+[per-host case roots (parallel)]:roots:_default' \
    '-hostRoots+[host-specific case roots]:roots:_default' \
    '-noFunctionObjects[disable function objects]' \
    '-dict+[dictionary file]:file:_files' \
    '-region+[region name]:region:_default' \
    && ret=0

return ret
