#compdef openapi-tui
# Documentation: https://man.archlinux.org/search?q=openapi-tui
# Reference accessed: 2026-05-16

# Zsh completion for openapi-tui (zaghaghi/openapi-tui).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-i --input)'{-i,--input=}'[OpenAPI spec file or URL]:path or url:'
