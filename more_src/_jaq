#compdef jaq
# Documentation: https://gedenkt.at/jaq/manual/
# Reference accessed: 2026-05-19
# Verified: jaq upstream manual options list. Removed --jsonargs
# (explicitly unsupported in jaq); added in-place/sort-keys/color/
# monochrome/from-file/library-path/raw-*0/from/to options.

# Zsh completion for jaq (jq clone in Rust)

_arguments -s -S \
  '(-n --null-input)'{-n,--null-input}'[use null as single input value]' \
  '(-R --raw-input)'{-R,--raw-input}'[read lines of input as strings]' \
  '--raw-input0[read NUL-delimited input as strings]' \
  '(-s --slurp)'{-s,--slurp}'[read all inputs into an array]' \
  '--from[input format]:format:' \
  '(-c --compact-output)'{-c,--compact-output}'[compact instead of pretty output]' \
  '(-r --raw-output)'{-r,--raw-output}'[write strings without escaping]' \
  '--raw-output0[implies -r and terminate values with NUL]' \
  '(-j --join-output)'{-j,--join-output}'[implies -r and disable newlines between outputs]' \
  '(-i --in-place)'{-i,--in-place}'[overwrite input file with its output]' \
  '(-S --sort-keys)'{-S,--sort-keys}'[sort keys of objects in output]' \
  '(-C --color-output -M --monochrome-output)'{-C,--color-output}'[always color output]' \
  '(-C --color-output -M --monochrome-output)'{-M,--monochrome-output}'[do not color output]' \
  '--tab[use tabs for indentation]' \
  '--indent[use given number of spaces for indentation]:n:' \
  '--to[output format]:format:' \
  '(-f --from-file)'{-f,--from-file}'[read filter from a file]' \
  '*'{-L,--library-path}'[search for modules and data in given directory]:dir:_files -/' \
  '*--arg[set variable to string value]:name: :value:' \
  '*--argjson[set variable to JSON value]:name: :json:' \
  '*--slurpfile[set variable to array of JSON values from file]:name: :file:_files' \
  '*--rawfile[set variable to string contents of file]:name: :file:_files' \
  '--args[collect remaining positional arguments into $ARGS.positional as strings]' \
  '(-e --exit-status)'{-e,--exit-status}'[set exit status code based on output]' \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-V,--version}'[print version]' \
  '1:filter:' \
  '*:file:_files' && return 0
