#compdef imhead delhead gethead sethead sky2xy xy2sky
# Documentation: source-direct extraction from upstream
# olebole/wcstools (Jessica Mink's WCSTools 3.9.7 series)
#   imhead.c:  case-arm switch + 4 fprintf usage lines.
#   delhead.c: case-arm switch + 6 fprintf usage lines.
#   gethead.c: case-arm switch + 20 fprintf usage lines.
#   sethead.c: case-arm switch + 14 fprintf usage lines.
#   sky2xy.c:  case-arm switch + 14 fprintf usage lines.
#   xy2sky.c:  case-arm switch + 20 fprintf usage lines.
# Reference accessed: 2026-05-30 via gh api.
# olebole wcstools R180 — follow-up to R179's hunt-skip note on
# the wcstools binary family (14+ binaries each with own getopt
# loops; deferred).  Picks off the 6 most-used WCSTools binaries
# - the FITS header inspection/manipulation pair (imhead,
# delhead, gethead, sethead) + the sky-to-pixel coordinate
# conversion pair (sky2xy, xy2sky).  Sister tools to the heavily
# covered astromatic.net family (R179 psfex/stuff, scamp/swarp/
# sextractor/solve-field/stilts already in corpus) and the
# broader astronomy stack.

case $service in

  imhead)
    # FITS header dumper.  4 short flags + positional FITS file(s) or @listfile.
    _arguments -s -S \
      '-f[write exact FITS header]' \
      '-i[drop primary header even if inherited]' \
      '-v[verbose output]' \
      '-z[set BITPIX to 0 for dataless header]' \
      '*:FITS file or @listfile:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

  delhead)
    # Delete FITS header keywords.  6 short flags + positional
    # FITS files + keyword names.
    _arguments -s -S \
      '-b[leave blank line in header for each deleted line]' \
      '-c[delete blank COMMENT lines]' \
      '-n[write new file]' \
      '-o[overwrite file]' \
      '-v[verbose]' \
      '-w[delete all WCS keywords in header]' \
      '*:FITS file / @listfile / KEYWORD / @keylistfile:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

  gethead)
    # Extract FITS header keywords.  20 short flags + positional
    # FITS files + keyword names.
    _arguments -s -S \
      '-a[list file even if keywords are not found or null]' \
      '-b[replace blanks in strings with underscores]' \
      '-c[read all files as plain ASCII]' \
      '-d+[root directory for input files (default cwd)]:dir:_files -/' \
      '-e[output keyword=value on one line per file]' \
      '-f+[never print filenames (default print if >1)]:n:' \
      '-g[output keyword=value on one line per keyword]' \
      '-h[print column headings]' \
      '-j[print output RA and Dec in J2000]' \
      '-m+[max length of IRAF multi-line value]:n:' \
      '-n+[number of decimal places in numeric output]:n:' \
      '-o[OR conditions instead of ANDing them]' \
      '-p[print full pathnames of files]' \
      '-r[precede each value by first keyword character]' \
      '-s[do not pad tab-separated table with spaces]' \
      '-t[output in tab-separated table format]' \
      '-u[always print ___ if keyword not found or null]' \
      '-v[verbose]' \
      '-x[read header for these extensions (no arg = all)]' \
      '*:FITS file / @listfile / KEYWORD / @keylistfile:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

  sethead)
    # Set FITS header keywords.  14 short flags + positional
    # FITS files + key=value pairs.
    _arguments -s -S \
      '-d+[root directory for input files]:dir:_files -/' \
      '-e[add Ecliptic coordinate WCS]' \
      '-g[add Galactic coordinate WCS]' \
      '-h[write HISTORY line]' \
      '-j[add J2000 coordinate WCS]' \
      '-k[write SETHEAD keyword]' \
      '-l[log files as processed (on one line)]' \
      '-m+[max number of keywords changed]:n:' \
      '-n[write a new file (add e before the extension)]' \
      '-r-[rename reset keywords with char (default X)]::char:' \
      '-s-[replace this character with space in string values]::char:' \
      '-v[verbose]' \
      '-x[read header for these extensions (no arg = all)]' \
      '*:FITS file / @listfile / KEYWORD=VALUE / @keylistfile:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

  sky2xy)
    # Convert sky to pixel coordinates.  13 short flags +
    # positional FITS file + RA Dec [sys] triplets or @listfile.
    _arguments -s -S \
      '-a+[rotation angle (counterclockwise degrees)]:rot:' \
      '-b[input in B1950 (FK4) [image reference sky position]]' \
      '-e[input in Ecliptic coordinates [image reference sky position]]' \
      '-g[input in Galactic coordinates [image reference sky position]]' \
      '-j[input in J2000 (FK5) [image reference sky position]]' \
      '-n+[number of decimal places in output]:n:' \
      '-o+[print only x, y, or both coordinate]:axis:(x y z)' \
      '-p+[plate scale in arcsec/pixel]:scale:' \
      '-s+[size of image in pixels (nx ny)]:nx:ny:' \
      '-v[verbose]' \
      '-x+[reference image position in pixels (x y)]:x:y:' \
      '-y+[epoch as fractional year or FITS date]:date:' \
      '-z[use AIPS classic projections instead of WCSLIB]' \
      '*:FITS file / RA Dec [sys] / @listfile:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

  xy2sky)
    # Convert pixel to sky coordinates.  20 short flags +
    # positional FITS file + x y pairs or @listfile.
    _arguments -s -S \
      '-a[append input line after output position]' \
      '-b[output (center) in B1950 (FK4)]' \
      '-c+[file with coefficients for magnitude conversion]:file:_files' \
      '-d[RA and Dec output in degrees]' \
      '-e[output (center) in Ecliptic coordinates]' \
      '-f+[face number for 3-d projection]:n:' \
      '-g[output (center) in Galactic coordinates]' \
      '-h[print column heading]' \
      '-i[first column is star id; 2nd, 3rd are x,y position]' \
      '-j[output (center) in J2000 (FK5)]' \
      '-k+[column for image X coordinate; Y follows]:col:' \
      '-l[mode for output of LINEAR WCS coordinates]' \
      '-m+[column for magnitude (defaults to 3 if -c used)]:col:' \
      '-n+[number of decimal places in output RA seconds]:n:' \
      '-o+[print only x, y, or both coordinate]:axis:(x y z)' \
      '-p[print plate scale]' \
      '-q+[equinox for output]:eqx:' \
      '-s+[image size in pixels (nx ny)]:nx:ny:' \
      '-t[output in tab table format]' \
      '-v[verbose]' \
      '*:FITS file / x y / @listfile:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

esac
