#compdef serie
# Documentation: https://github.com/lusingander/serie
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.
# Removed from prior file: fabricated -p/--path option; wrong --protocol
# values (https/ssh) — real values are auto/iterm/kitty/kitty-unicode;
# wrong --order placement (-o, not bare --order).

# serie: rich git commit graph TUI
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-n --max-count)'{-n,--max-count}'[maximum number of commits to render]:number:' \
  '(-p --protocol)'{-p,--protocol}'[image protocol to render graph]:protocol:(auto iterm kitty kitty-unicode)' \
  '(-o --order)'{-o,--order}'[commit ordering algorithm]:order:(chrono topo)' \
  '(-g --graph-width)'{-g,--graph-width}'[commit graph image cell width]:width:(auto double single)' \
  '(-s --graph-style)'{-s,--graph-style}'[commit graph image edge style]:style:(rounded angular)' \
  '(-i --initial-selection)'{-i,--initial-selection}'[initial selection of commit]:selection:(latest head)' && return 0
