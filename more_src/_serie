#compdef serie

# Zsh completion for serie - TUI git log viewer

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --path)'{-p,--path}'[repository path]:dir:_directories' \
  '--protocol[protocol for opening URLs]:protocol:(https ssh)' \
  '--order[commit sort order]:order:(date topo)' \
  '*:ref:' && return 0
