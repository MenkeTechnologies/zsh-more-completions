#compdef lpad
# Documentation: https://materialsproject.github.io/fireworks/fireworks.scripts.html
# FireWorks LaunchPad CLI (manage the FireWorks database / workflows)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'[output format]:format:(json yaml)' \
  '(-l --launchpad_file)'{-l,--launchpad_file}'[path to launchpad file]:file:_files' \
  '(-c --config_dir)'{-c,--config_dir}'[path to a directory containing the config file]:dir:_files -/' \
  '--logdir=[path to a directory for logging]:dir:_files -/' \
  '--loglvl=[level to print log messages]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '(-s --silencer)'{-s,--silencer}'[shortcut to mute log messages]' \
  '1:command:(version init reset add check_wflow get_launchdir append_wflow dump_wflow add_scripts get_fws get_fws_in_wflows track_fws rerun_fws defuse_fws pause_fws reignite_fws resume_fws update_fws get_wflows defuse_wflows pause_wflows reignite_wflows archive_wflows delete_wflows get_qids cancel_qid detect_unreserved detect_lostruns set_priority webgui recover_offline forget_offline report introspect admin)' \
  '*::arg:_files' && ret=0

return ret
