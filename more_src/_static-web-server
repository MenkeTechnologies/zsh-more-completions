#compdef static-web-server sws

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-a --host)'{-a,--host}'=[host address to bind]:host' \
  '(-p --port)'{-p,--port}'=[port to listen on]:port' \
  '(-d --root)'{-d,--root}'=[root directory to serve]:root dir:_directories' \
  '--log-level=[logging level]:level:(error warn info debug trace)' \
  '--config-file=[path to config file]:config file:_files -g "*.toml"' \
  '--cors-allow-origins=[allowed CORS origins]:origins' \
  '--cors-allow-headers=[allowed CORS headers]:headers' \
  '--cors-expose-headers=[exposed CORS headers]:headers' \
  '--directory-listing[enable directory listing]' \
  '--directory-listing-order=[directory listing sort order]:order:(0 1 2 3 4 5 6)' \
  '--cache-control-headers[enable cache control headers]' \
  '--compression[enable compression]:enabled:(true false)' \
  '--compression-level=[compression level]:level:(default fastest best)' \
  '--page404=[custom 404 page path]:file:_files -g "*.html"' \
  '--page50x=[custom 50x page path]:file:_files -g "*.html"' \
  '--http2[enable HTTP/2]' \
  '--http2-tls-cert=[TLS certificate for HTTP/2]:cert file:_files -g "*.pem"' \
  '--http2-tls-key=[TLS key for HTTP/2]:key file:_files -g "*.pem"' \
  '--security-headers[enable security headers]' \
  '(-t --threads)'{-t,--threads}'=[number of worker threads]:threads' \
  '(-g --grace-period)'{-g,--grace-period}'=[graceful shutdown timeout in seconds]:seconds' \
  '--log-remote-address[log remote IP address]' \
  '--redirect-trailing-slash[redirect trailing slash]' \
  '--ignore-hidden-files[ignore hidden files and directories]' \
  '--health[enable health endpoint]' \
  '--basic-auth=[basic auth credentials]:user\:password' \
  '--fd=[file descriptor to listen on]:fd' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
