#compdef flink

local curcontext="$curcontext" state line ret=1

_flink_run_options() {
  _arguments -s -S \
    '-c[class with the program entry point]:class' \
    '*-C[URL to add to classpath]:url' \
    '-d[run in detached mode]' \
    '-p[parallelism level]:parallelism' \
    '-py[Python script]:file:_files' \
    '-pym[Python module]:module' \
    '-pyfs[Python files]:files:_files' \
    '-pyarch[Python archives]:archives:_files' \
    '-pyreq[Python requirements file]:file:_files' \
    '-pyexec[Python executable]:path:_files' \
    '-s[savepointPath to restore from]:path:_files' \
    '(-n --allowNonRestoredState)'{-n,--allowNonRestoredState}'[allow non-restored state]' \
    '*-D[dynamic property]:property=value' \
    '-m[address of the JobManager]:host\:port' \
    '-yid[attach to running YARN session]:application-id' \
    '*:jar file:_files -g "*.jar"'
}

_flink_commands() {
  local -a commands=(
    'run:run a program'
    'run-application:run an application in application mode'
    'info:display optimized execution plan'
    'list:list running and scheduled programs'
    'stop:stop a running program with a savepoint'
    'cancel:cancel a running program'
    'savepoint:trigger a savepoint or dispose existing ones'
    'stop-with-savepoint:stop a running program with a savepoint'
  )
  _describe -t commands 'flink command' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:_flink_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      run|run-application)
        _flink_run_options && ret=0
        ;;
      info)
        _arguments -s -S \
          '-c[class with the program entry point]:class' \
          '-p[parallelism level]:parallelism' \
          '*:jar file:_files -g "*.jar"' && ret=0
        ;;
      list)
        _arguments -s -S \
          '-a[show all programs]' \
          '-r[show only running programs]' \
          '-s[show only scheduled programs]' \
          '-m[address of the JobManager]:host\:port' && ret=0
        ;;
      stop|cancel)
        _arguments -s -S \
          '-m[address of the JobManager]:host\:port' \
          '*:job-id' && ret=0
        ;;
      savepoint)
        _arguments -s -S \
          '-d[dispose an existing savepoint]:savepoint-path:_files' \
          '-m[address of the JobManager]:host\:port' \
          '*:job-id' && ret=0
        ;;
      stop-with-savepoint)
        _arguments -s -S \
          '-m[address of the JobManager]:host\:port' \
          '-d[drain the pipeline]' \
          '*:job-id' && ret=0
        ;;
    esac
    ;;
esac

return ret
