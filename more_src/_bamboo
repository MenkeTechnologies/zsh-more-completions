#compdef bamboo bamboo-cli
# _bamboo — Bob Swift Atlassian Bamboo CLI command-line interface for the Bamboo CI/CD server REST API (atlassian team, Java); custom argparse
# upstream: https://bobswift.atlassian.net/wiki/spaces/BCLI/overview

_bamboo() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--action=+[action]:str:' \
        '-a+[action]:str:' \
        '--server=+[Bamboo URL]:url:_urls' \
        '-s+[Bamboo URL]:url:_urls' \
        '--user=+[username]:user:_users' \
        '-u+[username]:user:_users' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--token=+[api token]:str:' \
        '--cookies=+[cookie file]:file:_files' \
        '--name=+[entity name]:str:' \
        '-n+[entity name]:str:' \
        '--description=+[description]:str:' \
        '-d+[description]:str:' \
        '--build=+[build key]:str:' \
        '-b+[build key]:str:' \
        '--project=+[project key]:str:' \
        '--plan=+[plan key]:str:' \
        '--branch=+[branch name]:str:' \
        '--stage=+[stage name]:str:' \
        '--job=+[job name]:str:' \
        '--task=+[task name]:str:' \
        '--issue=+[issue key]:str:' \
        '--label=+[label]:str:' \
        '--variable=+[variable]:str:' \
        '--value=+[value]:str:' \
        '--file=+[file path]:file:_files' \
        '-f+[file path]:file:_files' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '--outputType=+[type]:t:(json yaml table csv xml plain)' \
        '--encoding=+[encoding]:str:' \
        '--continue[continue on error]' \
        '--field=+[field]:str:' \
        '--type=+[type]:str:' \
        '--ssl-insecure[skip SSL verify]' \
        '--proxy=+[proxy url]:url:_urls'
}

_bamboo "$@"
