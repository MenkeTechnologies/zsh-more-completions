#compdef reveal-md

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--theme=[reveal.js theme]:theme:(black white league beige sky night serif simple solarized moon blood dracula)' \
  '--highlight-theme=[highlight.js theme]:theme' \
  '--css=[path to custom CSS file]:CSS file:_files -g "*.css"' \
  '--scripts=[comma-separated list of extra scripts]:scripts' \
  '--template=[path to custom template]:template file:_files' \
  '--listing-template=[path to custom listing template]:template file:_files' \
  '--preprocessor=[path to custom preprocessor script]:script:_files' \
  '--print=[export to PDF at specified path]:PDF file:_files -g "*.pdf"' \
  '--static=[export as static HTML to directory]:directory:_files -/' \
  '--static-dirs=[extra directories to copy to static output]:directories' \
  '--assets-dir=[assets directory name for static export]:directory name' \
  '(-w --watch)'{-w,--watch}'[watch for file changes and reload]' \
  '--port=[port for the local server]:port' \
  '--host=[hostname for the local server]:host' \
  '--disable-auto-open[do not open browser automatically]' \
  '--title=[title of the presentation]:title' \
  '--separator=[horizontal slide separator]:separator' \
  '--vertical-separator=[vertical slide separator]:separator' \
  '--featured-slide=[index of featured slide for og\:image]:slide index' \
  '--glob=[glob pattern for markdown files]:pattern' \
  '--puppeteer-launch-args=[Puppeteer launch arguments]:args' \
  '--puppeteer-chromium-executable=[path to Chromium for Puppeteer]:path:_files' \
  '--absolute-url=[absolute URL for og\:image]:URL' \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '*:markdown file:_files -g "*.md"' && ret=0

return ret
