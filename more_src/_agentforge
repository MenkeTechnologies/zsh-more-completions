#compdef agentforge
# Documentation: https://github.com/TVScoundrel/agentforge
# Reference accessed: 2026-05-22
# Verified: packages/cli/src/index.ts Commander program.

# Zsh completion for agentforge - AgentForge project scaffolding CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'agentforge command' \
      'create[create new AgentForge project]' \
      'dev[start development server]' \
      'build[production build]' \
      'test[run tests]' \
      'lint[lint and format code]' \
      'agent[manage agents]' \
      'tool[manage tools]' && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments \
          '(-t --template)'{-t,--template}'[project template]:template:(minimal full api cli)' \
          '(-p --package-manager)'{-p,--package-manager}'[package manager]:pm:(npm pnpm yarn)' \
          '--no-install[skip dependency installation]' \
          '--no-git[skip git initialization]' \
          '1:project name:' && ret=0
        ;;
      dev)
        _arguments \
          '(-p --port)'{-p,--port}'[port number]:port:' \
          '--no-open[do not open browser]' && ret=0
        ;;
      build)
        _arguments '--no-minify[skip minification]' '--no-sourcemap[skip sourcemaps]' && ret=0
        ;;
      test)
        _arguments \
          '(-w --watch)'{-w,--watch}'[watch mode]' \
          '--ui[open test UI]' \
          '--coverage[generate coverage report]' && ret=0
        ;;
      lint)
        _arguments '--fix[auto-fix issues]' '--no-format[skip formatting]' && ret=0
        ;;
      agent)
        _values 'agent command' create create-reusable list test deploy && ret=0
        ;;
      tool)
        _values 'tool command' create list test publish && ret=0
        ;;
    esac
    ;;
esac

return ret
