#compdef jsonnet-language-server
# _jsonnet-language-server — LSP for Jsonnet (grafana/jsonnet-language-server)
# upstream: https://github.com/grafana/jsonnet-language-server
# Flags from main.go.

_jsonnet-language-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '*'{-J+,--jpath=}'[additional library search dir]:dir:_files -/' \
        '(-t --tanka)'{-t,--tanka}'[init Jsonnet VM with Tanka]' \
        '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(trace debug info warn error fatal panic)' \
        '--eval-diags[evaluate files to find errors/warnings]' \
        '--lint[enable linting]'
}

_jsonnet-language-server "$@"
