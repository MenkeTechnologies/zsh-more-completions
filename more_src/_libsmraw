#compdef smrawmount smrawverify
# _libsmraw — libsmraw tools (libyal storage media RAW (.raw / .dd) parser with split + checksum support; smrawmount FUSE-mounts a raw image, smrawverify computes / checks per-chunk hashes; -h help, -V version, -v verbose, -d digest type list, -X exclusive; positional argument is the .raw file or first .raw.001 segment)
# upstream: https://github.com/libyal/libsmraw
# Flags from libyal/libsmraw smrawtools/smrawmount.c on tip.

_libsmraw() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-d+[digest types csv]:csv:(md5 sha1 sha256)' \
        '-X[exclusive lock]' \
        '*:RAW image:_files'
}

_libsmraw "$@"
