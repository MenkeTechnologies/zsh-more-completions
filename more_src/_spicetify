#compdef spicetify spicetify-cli

# Zsh completion for spicetify - command-line tool to customize the Spotify client

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'backup:back up the original Spotify files'
  'apply:apply customization'
  'update:update custom colors and theme'
  'restore:restore Spotify to original state'
  'clear:clear current Spotify backup files'
  'enable-devtools:enable Spotify developer tools (Ctrl+Shift+I)'
  'watch:rerun apply whenever changes in theme directory and config file detected'
  'config-dir:open user config directory'
  'config:change a configuration field''s value'
  'color:change a value of a color in current theme'
  'path:display path based on argument'
  'upgrade:check and update spicetify to latest version'
  'info:print information about spicetify'
  'auto:automatically run backup, apply and enable-devtools'
)

_arguments -s -S \
  '1:command:->command' \
  '(-c --config)'{-c,--config}'[print config file path]' \
  '(-n --no-restart)'{-n,--no-restart}'[do not restart Spotify after running command]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'spicetify command' commands && ret=0
    ;;
esac

return ret
