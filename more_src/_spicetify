#compdef spicetify spicetify-cli
# Documentation: https://github.com/spicetify/cli (spicetify.go)
# Reference accessed: 2026-05-21
# Verified: upstream spicetify.go command list + flag table.

# Zsh completion for spicetify - command-line tool to customize the Spotify client

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'backup:start backup and preprocessing of app files'
  'apply:apply customization'
  'refresh:refresh theme CSS, JS, colors, and assets'
  'restore:restore Spotify to original state'
  'clear:clear current backup files'
  'enable-devtools:enable Spotify developer tools'
  'watch:enter watch mode for live updates'
  'restart:restart Spotify client'
  'auto:automatic processing'
  'spotify-updates:block or unblock Spotify updates'
  'path:print paths for executables, userdata, and more'
  'config:display or modify configuration settings'
  'color:display or modify color values'
  'config-dir:show config directory in file viewer'
  'upgrade:update spicetify to latest version'
  'update:update spicetify to latest version'
)

_arguments -s -S \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-e --extension)'{-e,--extension}'[focus on extensions]' \
  '(-a --app)'{-a,--app}'[focus on custom apps]' \
  '(-s --style)'{-s,--style}'[focus on active theme]' \
  '(-l --live-refresh)'{-l,--live-refresh}'[auto-reload on all changes]' \
  '(-n --no-restart)'{-n,--no-restart}'[skip Spotify restart]' \
  '(-c --config)'{-c,--config}'[print config file path]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--bypass-admin[skip admin privilege check]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'spicetify command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (spotify-updates)
        _values 'mode' 'block' 'unblock' && ret=0
        ;;
    esac
    ;;
esac

return ret
