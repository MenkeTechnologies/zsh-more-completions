#compdef suhrot
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/multicomponent/suhrot.c
# horizontal rotation of three-component data

local ret=1

_arguments -s -S \
  'angle=[unit of angles]:angle:(rad deg gon)' \
  'inv=[1 = inverse rotation (counter-clockwise)]:inv' \
  'verbose=[1 = echo angle for each 3-C station]:verbose' \
  'a=[array of user-supplied rotation angles]:a' \
  'x=[array of corresponding header values]:x' \
  'key=[header word defining 3-C station]:key' \
  'n=[number of x and a values in input files]:n' \
  'xfile=[file containing the x values]:file:_files' \
  'afile=[file containing the a values]:file:_files' \
  '*:file:_files' && ret=0


return ret
