#compdef subtractBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/subtract.html
# remove the portion of A that overlaps B (bedtools subtract)

local ret=1

_arguments -s -S \
  '-a[input file A to be subtracted from]:file:_files' \
  '-b[input file B containing features to subtract]:file:_files' \
  '-A[remove entire feature if any overlap]' \
  '-N[like -A but overlap is sum of all overlapping features]' \
  '-f[minimum overlap as fraction of A]:fraction' \
  '-F[minimum overlap as fraction of B]:fraction' \
  '-r[require reciprocal overlap]' \
  '-e[satisfy minimum fraction for A OR B]' \
  '-s[force strandedness (same strand)]' \
  '-S[require opposite strandedness]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
