#compdef clipcat-menu

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --finder)'{-f,--finder}'[set finder program]:finder:(skim fzf rofi dmenu custom)' \
  '--rofi-extra-arguments=[extra arguments for rofi]:arguments' \
  '--dmenu-extra-arguments=[extra arguments for dmenu]:arguments' \
  '--custom-finder=[custom finder command]:command' \
  '--line-length=[maximum line length for display]:length' \
  '--log-level=[set log level]:level:(error warn info debug trace)' \
  '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '1:action:(insert remove edit)' && ret=0

return ret
