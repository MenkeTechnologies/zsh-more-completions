#compdef mem2d
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss114.html
# KAPPA: performs a Maximum-Entropy deconvolution of a 2-d NDF

local ret=1

_arguments -s \
  'IN=[input NDF to be deconvolved]:ndf:_files -g "*.sdf"' \
  'OUT=[output deconvolved NDF]:ndf:_files -g "*.sdf"' \
  'PSF=[NDF holding the point-spread function]:ndf:_files -g "*.sdf"' \
  'MASK=[NDF holding a mask]:ndf:_files -g "*.sdf"' \
  'MODEL=[input model NDF]:ndf:_files -g "*.sdf"' \
  'MODELOUT=[output model NDF]:ndf:_files -g "*.sdf"' \
  'ANALYSE=[analyse results only]:bool:(TRUE FALSE)' \
  'PSFTYPE=[type of point-spread function]:type' \
  'FWHMPSF=[FWHM of the PSF]:value' \
  'XCENTRE=[x centre of the PSF]:value' \
  'YCENTRE=[y centre of the PSF]:value' \
  'THRESH=[PSF threshold]:value' \
  'DEF=[default image value]:value' \
  'FWHMICF=[FWHM of the intrinsic correlation function]:value' \
  'NITER=[maximum number of iterations]:n' \
  'RATE=[convergence rate]:value' \
  'NOISE=[noise level]:value' \
  'ILEVEL=[information reporting level]:n' \
  'EXTEND=[extend the model]:bool:(TRUE FALSE)' \
  'UPDATE=[update the model in place]:bool:(TRUE FALSE)' \
  'TITLE=[title for the output NDF]:title' \
  'SUM=[total flux result]:value' \
  'DSUM=[error on the total flux]:value' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
