#compdef ibcheckwidth
# Documentation: https://man7.org/linux/man-pages/man8/ibcheckwidth.8.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# ibcheckwidth: scan IB subnet for 1x links by validating active widths.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[enable verbose output]' \
  '-N[use mono rather than color mode]' \
  '-nocolor[use mono rather than color mode]' \
  '-C+[channel adapter name]:ca name:' \
  '-P+[channel adapter port]:ca port:' \
  '-t+[override default timeout for solicited MADs]:timeout (ms):' \
  '*:topology file:_files' && ret=0
return ret
