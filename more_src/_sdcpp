#compdef sdcpp

# sdcpp: Small Device C Compiler preprocessor (sdcc cpp)
# Documentation: https://sdcc.sourceforge.net/doc/sdccman.pdf
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-D[define macro]:macro:' \
  '-U[undefine macro]:macro:' \
  '-I[include dir]:dir:_files -/' \
  '-iquote[quote include dir]:dir:_files -/' \
  '-isystem[system include dir]:dir:_files -/' \
  '-include[include file]:file:_files' \
  '-imacros[include macros]:file:_files' \
  '-M[generate makefile deps]' \
  '-MD[deps and continue]' \
  '-MM[deps without system headers]' \
  '-MMD[deps without sys, continue]' \
  '-MP[phony targets]' \
  '-MF[deps output file]:file:_files' \
  '-MT[deps target]:target:' \
  '-MQ[quoted deps target]:target:' \
  '-W[warning]:type:' \
  '-w[no warnings]' \
  '-pedantic[strict ISO]' \
  '-trigraphs[allow trigraphs]' \
  '-traditional[K&R mode]' \
  '-undef[no predefined macros]' \
  '-nostdinc[no standard include]' \
  '-C[keep comments]' \
  '-CC[keep all comments]' \
  '-P[no line markers]' \
  '*:source file:_files -g "*.(c|h|i|S|s)"' && ret=0
return ret
