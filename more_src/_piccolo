#compdef piccolo
# Documentation: https://piccolo-orm.readthedocs.io/en/latest/piccolo/migrations/running.html
# Piccolo ORM command-line tool

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:group:(migrations app asgi user schema fixtures meta shell sql_shell tester)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    if [[ $words[1] == migrations ]]; then
      _arguments -s \
        '2:command:(new forwards backwards check clean)' \
        '*::mig:->mig' && ret=0
      case $words[2] in
        forwards)
          _arguments -s \
            '--fake[record migration as run without executing it]' \
            '--preview[print the SQL queries without executing them]' && ret=0
          ;;
        backwards)
          _arguments -s \
            '--auto-agree[automatically confirm input prompts]' \
            '--clean[remove migration files after reversing them]' \
            '--preview[print the SQL queries without executing them]' && ret=0
          ;;
      esac
    fi
    ;;
esac

return ret
