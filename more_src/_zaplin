#compdef zaplin
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss213.html
# KAPPA: replaces regions in a 2-d NDF by bad values or linear interpolation

local ret=1

_arguments -s \
  'IN=[input image NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output image NDF]:ndf:_files -g "*.sdf"' \
  'MODE=[how area bounds are obtained]:mode:(Interface Cursor File)' \
  'LINCOL=[type of area to replace]:type:(Lines Columns Region)' \
  'ZAPTYPE=[replacement method]:type:(Bad Linear)' \
  'LINES=[y range of lines to replace]:range' \
  'COLUMNS=[x range of columns to replace]:range' \
  'COLIN=[input text file of area bounds]:file:_files' \
  'COLOUT=[output text file of replaced areas]:file:_files' \
  'DEVICE=[graphics device for cursor mode]:device' \
  'NOISE=[add gaussian noise to interpolation]:bool:(TRUE FALSE)' \
  'MARKER=[PGPLOT marker type]:n' \
  'PLOT=[graphics type for cursor marking]:plot' \
  'STYLE=[plotting style]:style' \
  'TITLE=[title for the output image]:title' \
  'USEAXIS=[axes to use]:axes' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
