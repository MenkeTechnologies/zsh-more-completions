#compdef llvm-yaml2obj
# _llvm-yaml2obj — LLVM YAML to object file converter (LLVM project, C++); generate ELF/COFF/Mach-O/wasm from YAML
# upstream: https://github.com/llvm/llvm-project

_llvm-yaml2obj() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '--docnum=+[document number]:n:' \
        '-D+[macro]:KEY=VAL:' \
        '--max-size=+[max size]:n:' \
        '*:file:_files -g "*.yaml"'
}

_llvm-yaml2obj "$@"
