#compdef ffmsindex
# Documentation: https://github.com/FFMS/ffms2/blob/master/src/index/ffmsindex.cpp
# ffms2 indexer: build a frame/keyframe index for a media file

local ret=1

_arguments -s -S \
  '-f[force overwriting of existing index file]' \
  '*-v[set FFmpeg verbosity level (repeatable)]' \
  '-p[disable progress reporting]' \
  '-c[write timecodes for all video tracks]' \
  '-k[write keyframes for all video tracks]' \
  '-t[set audio indexing mask (-1 all, 0 none)]:mask:' \
  '-s[set audio decoding error handling mode]:mode:' \
  '-u[set progress update frequency in seconds]:seconds:' \
  '-o[set demuxer options as key=val:key=val]:options:' \
  '--enable_drefs[enable drefs demuxer option]' \
  '--use_absolute_path[enable use_absolute_path demuxer option]' \
  '1:input file:_files' \
  '2:output index file:_files' && ret=0

return ret
