#compdef eclipse-clp eclipse_clp eclipse-tkconsole
# _eclipse-clp — Coninfer eclipse-clp CLI ECLiPSe Constraint Logic Programming System command-line shell Prolog superset with Constraint Handling Rules CHR finite-domain interval real-set Boolean-domain constraint solvers integration with SICStus Mercury libraries goal-driven shell-mode batch-script (Coninfer team, C); custom argparse
# upstream: https://eclipseclp.org/

_eclipse-clp() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-e+[goal]:str:' \
        '--exec=+[goal]:str:' \
        '-b+[bootfile]:file:_files' \
        '--boot=+[file]:file:_files' \
        '-f+[file]:file:_files -g "*.ecl *.pl *.eco"' \
        '--file=+[file]:file:_files -g "*.ecl *.pl *.eco"' \
        '-g+[heap size]:str:' \
        '--heap=+[size]:str:' \
        '-G+[global stack size]:str:' \
        '--global=+[size]:str:' \
        '-L+[local stack size]:str:' \
        '--local=+[size]:str:' \
        '-D+[directory]:dir:_files -/' \
        '--directory=+[dir]:dir:_files -/' \
        '-l+[library]:str:' \
        '-P+[priority]:n:' \
        '-T+[trail size]:str:' \
        '--trail=+[size]:str:' \
        '-d+[debug level]:n:' \
        '--debug-level=+[N]:n:' \
        '--debug[debug]' \
        '--use-tcl[use Tcl/Tk]' \
        '--use-gui[use GUI]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[no banner]' \
        '--no-banner[no banner]' \
        '-c+[code]:str:' \
        '*:program:_files -g "*.ecl *.pl *.eco"'
}

_eclipse-clp "$@"
