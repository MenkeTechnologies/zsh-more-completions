#compdef swagger-merger
# Documentation: https://github.com/WindomZ/swagger-merger
# Merge multi-file Swagger/OpenAPI definitions into a single file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[output usage information]' \
  '(-V --version)'{-V,--version}'[output the version number]' \
  '(-i --input)'{-i,--input}'=[input main/entry JSON/YAML swagger file]:file:_files' \
  '(-o --output)'{-o,--output}'=[output merged JSON/YAML swagger file]:file:_files' \
  '(-c --compact)'{-c,--compact}'[compact JSON/YAML format string]' \
  '--debug[debug mode, such as print error tracks]' \
  '*:file:_files' && ret=0

return ret
