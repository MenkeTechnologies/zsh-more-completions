#compdef regrid_data_plane
# Documentation: https://metplus.readthedocs.io/projects/met/en/latest/Users_Guide/reformat_grid.html
# regrid_data_plane - MET tool to regrid gridded data to an output grid

local ret=1

_arguments -s \
  '*-field[field to regrid]:field:' \
  '-method[regridding method override]:method:(MIN MAX MEDIAN UW_MEAN DW_MEAN AW_MEAN LS_FIT BILIN NEAREST BUDGET FORCE GAUSSIAN MAXGAUSS LOWER UPPER)' \
  '-width[regridding width override]:width:' \
  '-gaussian_dx[delta distance for Gaussian smoothing]:dx:' \
  '-gaussian_radius[radius of influence for Gaussian interpolation]:radius:' \
  '-shape[interpolation shape override]:shape:(SQUARE CIRCLE)' \
  '-vld_thresh[required ratio of valid data for regridding]:thresh:' \
  '-name[comma-separated output variable names]:names:' \
  '-log[direct output and errors to log file]:file:_files' \
  '-v[verbosity level]:level:' \
  '-compress[NetCDF deflate compression level (0-9)]:level:' \
  '*:file:_files' && ret=0

return ret
