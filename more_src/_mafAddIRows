#compdef mafAddIRows
# UCSC kent: add i rows to a maf

local ret=1

_arguments -s -S \
  '-nBeds=[list of bed files, one per species, with N locations]:file:_files' \
  '-addN[add rows of N into maf blocks rather than just annotating]' \
  '-addDash[add rows of dashes into maf blocks rather than just annotating]' \
  '1:input maf:_files -g "*.maf"' \
  '2:2bit file:_files -g "*.2bit"' \
  '3:output maf:_files -g "*.maf"' && ret=0

return ret
