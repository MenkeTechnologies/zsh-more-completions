#compdef templ
# Documentation: https://templ.guide/developer-tools/cli
# Reference accessed: 2026-05-21
# Verified: upstream templ.guide CLI reference.
# Removed from prior file: double-dash variants of templ's flags (templ uses
# Go-style single-dash flags). Renamed --keep-orphaned-outputs ->
# -keep-orphaned-files (real upstream name). Renamed -w (watch) -> -watch
# (the -w flag actually means 'worker count' upstream). Replaced --log-level
# with -log-level. Removed fabricated --http long form, --pprof-port (real
# name is -pprof for boolean), --goplsLog/--goplsRPCTrace/--log long-dash
# forms, --stdin-filepath, and the 'migrate' subcommand which IS in the docs
# but with different flags.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-help[print help]' \
  '-version[print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'generate:generate Go code from templ files'
      'fmt:format templ files'
      'lsp:start the templ language server'
      'info:display information about the templ environment'
      'version:print the version'
    )
    _describe -t commands 'templ command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      generate)
        _arguments -s -S \
          '-help[print help]' \
          '-path=[path to process]:path:_directories' \
          '-f=[single file to generate]:file:_files' \
          '-source-map-visualisations[generate source map visualisations]' \
          '-include-version[include version in generated files]' \
          '-include-timestamp[include timestamp in generated files]' \
          '-watch[watch for file changes and regenerate]' \
          '-cmd=[command to run after generation]:command:' \
          '-proxy=[URL to proxy after generation]:url:' \
          '-proxyport=[port to run the proxy on]:port:' \
          '-proxybind=[address to bind the proxy to]:address:' \
          '-w=[worker count]:n:' \
          '-lazy[only regenerate changed files]' \
          '-pprof[enable pprof debugging]' \
          '-keep-orphaned-files[keep output files with no matching source]' \
          '-v[debug verbosity]' \
          '-log-level=[log level]:level:(debug info warn error)' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '-help[print help]' \
          '*:files:_files' && ret=0
        ;;
      lsp)
        _arguments -s -S \
          '-help[print help]' \
          '-goplsLog=[log gopls to file]:file:_files' \
          '-goplsRPCTrace[enable gopls RPC tracing]' \
          '-gopls-remote=[gopls remote address]:addr:' \
          '-http=[enable HTTP server on address]:addr:' \
          '-log=[log to file]:file:_files' \
          '-pprof[enable pprof debugging]' && ret=0
        ;;
      info)
        _arguments -s -S '-help[print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
