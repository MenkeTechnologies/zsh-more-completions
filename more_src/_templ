#compdef templ

# Zsh completion for templ (Go templ HTML templating CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'generate:Generate Go code from templ files'
      'fmt:Format templ files'
      'lsp:Start the templ language server'
      'migrate:Migrate files from older templ versions'
      'version:Print the version'
    )
    _describe -t commands 'templ command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      generate)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-f+[Specify a single file to generate]:file:_files' \
          '--file=[Specify a single file to generate]:file:_files' \
          '--path=[Path to process]:path:_directories' \
          '-w[Watch for file changes and regenerate]' \
          '--watch[Watch for file changes and regenerate]' \
          '--cmd=[Command to run after generation]:command' \
          '--proxy=[URL to proxy after generation]:url' \
          '--proxyport=[Port to run the proxy on]:port' \
          '--proxybind=[Address to bind the proxy to]:address' \
          '--notify-proxy[Notify the proxy of updates]' \
          '--keep-orphaned-outputs[Keep output files with no matching source]' \
          '--lazy[Only regenerate changed files]' \
          '-v[Use verbose output]' \
          '--log-level=[Log level]:level:(debug info warn error)' \
          '--pprof-port=[Enable pprof debugging on this port]:port' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--stdin-filepath=[Filepath for stdin input]:file:_files' \
          '-v[Use verbose output]' \
          '--log-level=[Log level]:level:(debug info warn error)' \
          '*:files:_files' && ret=0
        ;;
      lsp)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--http=[Enable HTTP server on address]:addr' \
          '--goplsLog=[Log gopls to specified file]:file:_files' \
          '--goplsRPCTrace[Enable gopls RPC tracing]' \
          '--log=[Log to specified file]:file:_files' \
          '-v[Use verbose output]' \
          '--pprof-port=[Enable pprof debugging on this port]:port' && ret=0
        ;;
      migrate)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-f+[Specify a single file to migrate]:file:_files' \
          '--file=[Specify a single file to migrate]:file:_files' \
          '--path=[Path to process]:path:_directories' \
          '-v[Use verbose output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
