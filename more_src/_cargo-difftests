#compdef cargo-difftests
# Documentation: https://github.com/dnbln/cargo-difftests
# Source: dnbln/cargo-difftests cargo-difftests/src/bin/cargo-difftests/ops/mod.rs — selective re-test framework for Rust.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _cd_cmds
_cd_cmds=(
    'discover-difftests:discover the difftests in a given directory'
    'analyze:analyze a single difftest'
    'analyze-all:analyze all difftests in a given directory'
    'analyze-all-from-index:analyze all difftests via their index files'
    'collect-profiling-data:collect profiling data for all tests known to cargo'
    'rerun-dirty-from-indexes:rerun dirty difftests from their indexes'
    'low-level:low-level commands for debugging and development'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'cargo-difftests command' _cd_cmds && ret=0
        ;;
esac

return ret
