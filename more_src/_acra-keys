#compdef acra-keys
# _acra-keys — Acra keystore management CLI (cossacklabs/acra)
# upstream: https://github.com/cossacklabs/acra
# Subcommands from cmd/acra-keys/acra-keys.go.

_acra-keys() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)-h[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'list:list available keys'
                'export:export keys from a keystore'
                'import:import keys into a keystore'
                'migrate:migrate v1 keystore to v2'
                'read:read raw key data'
                'destroy:destroy a key'
                'generate:generate keys'
                'extract-client-id:extract client ID from TLS cert'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_acra-keys "$@"
