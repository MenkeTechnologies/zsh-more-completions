#compdef trackhub_from_excel
# Documentation: https://daler.github.io/trackhub/excelinstructions.html
# trackhub - build a UCSC track hub from an Excel workbook

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--excel-file=[location of the input Excel file]:file:_files' \
  '--staging=[name of the staging output directory]:dir:_files -/' \
  '--template=[write a template Excel file with the given name]:file:_files' \
  '--create-example=[write an example filled-in Excel file]:file:_files' \
  '--validation=[turn validation of track parameters on or off]:validation' && ret=0

return ret
