#compdef rathole
# Documentation: https://github.com/rapiz1/rathole
# Reference accessed: 2026-05-20
# Verified: upstream src/cli.rs clap definitions.

# Zsh completion for rathole - secure tunnel

local ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-s --server -c --client)'{-s,--server}'[operate in server mode]' \
  '(-s --server -c --client)'{-c,--client}'[operate in client mode]' \
  '--genkey=[generate keypair for noise protocol]:curve:(X25519 X448)' \
  '*:config file:_files -g "*.toml"' && ret=0

return ret
