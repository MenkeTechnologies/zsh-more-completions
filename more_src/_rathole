#compdef rathole

# Zsh completion for rathole - secure tunnel

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--server[run in server mode]' \
  '--client[run in client mode]' \
  '(-c --config-path)'{-c,--config-path}'=[config file]:file:_files' \
  '--genkey[generate a keypair for noise protocol]' \
  '(-t --threads)'{-t,--threads}'=[number of threads]:threads' \
  && ret=0

return ret
