#compdef chpasswd-cli
# _chpasswd-cli — shadow chpasswd update passwords in batch mode CLI alias (shadow-maint team, C); custom argparse
# upstream: https://github.com/shadow-maint/shadow

_chpasswd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-c+[crypt method]:m:(DES MD5 NONE SHA256 SHA512 BCRYPT YESCRYPT)' \
        '--crypt-method=+[crypt method]:m:(DES MD5 NONE SHA256 SHA512 BCRYPT YESCRYPT)' \
        '-e[encrypted passwords]' \
        '--encrypted[encrypted passwords]' \
        '-m[md5]' \
        '--md5[md5]' \
        '-s+[salt rounds]:n:' \
        '--sha-rounds=+[salt rounds]:n:' \
        '-R+[chroot]:dir:_files -/' \
        '--root=+[chroot]:dir:_files -/' \
        '-P+[prefix]:dir:_files -/' \
        '--prefix=+[prefix]:dir:_files -/' \
        '*:input file:_files'
}

_chpasswd-cli "$@"
