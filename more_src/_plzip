#compdef plzip
# Documentation: https://www.nongnu.org/lzip/manual/plzip_manual.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for plzip - parallel lzip file compressor/decompressor

_arguments -s -S \
  '(-h)-h[print informative help and exit]' \
  '(--help)--help[print full help and exit]' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '(-a --trailing-error)'{-a,--trailing-error}'[exit with error status if trailing data detected]' \
  '(-B --data-size)'{-B,--data-size=}'[set input data block size]:bytes' \
  '(-c --stdout)'{-c,--stdout}'[write to standard output, keep input files unchanged]' \
  '(-d --decompress)'{-d,--decompress}'[decompress files]' \
  '(-f --force)'{-f,--force}'[force overwrite of output files]' \
  '(-F --recompress)'{-F,--recompress}'[force re-compression of compressed files]' \
  '(-k --keep)'{-k,--keep}'[keep (do not delete) input files]' \
  '(-l --list)'{-l,--list}'[list compressed file contents]' \
  '(-m --match-length)'{-m,--match-length=}'[set match length limit in bytes]:bytes' \
  '(-n --threads)'{-n,--threads=}'[set maximum number of worker threads]:n' \
  '(-o --output)'{-o,--output=}'[write output to FILE]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress all messages]' \
  '(-s --dictionary-size)'{-s,--dictionary-size=}'[set dictionary size limit in bytes]:bytes' \
  '(-t --test)'{-t,--test}'[check integrity of files (test only)]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '--fast[alias for compression level -1 (gzip compat)]' \
  '--best[alias for compression level -9 (gzip compat)]' \
  '--loose-trailing[when decompressing/testing/listing, allow trailing data]' \
  '--in-slots=[number of 1 MiB input packets buffered per thread]:n' \
  '--out-slots=[number of 1 MiB output packets buffered per thread]:n' \
  '--check-lib[compare version of lzlib in use with built-in]' \
  '-0[compression level 0 (fastest)]' \
  '-1[compression level 1]' \
  '-2[compression level 2]' \
  '-3[compression level 3]' \
  '-4[compression level 4]' \
  '-5[compression level 5]' \
  '-6[compression level 6 (default)]' \
  '-7[compression level 7]' \
  '-8[compression level 8]' \
  '-9[compression level 9 (best)]' \
  '*:file:_files'
