#compdef ipapatch

# https://github.com/asdfzxcvbn/ipapatch — go-arg v2.1.x (cmd.go helpText)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage]' \
  '--version[show version]' \
  '--input=[IPA to patch]:ipa:_files -g "*.ipa"' \
  '--output=[patched IPA path]:ipa:_files' \
  '--dylib=[replace embedded inject dylib]:dylib:_files' \
  '--inplace[overwrite --input IPA]' \
  '--noconfirm[skip interactive overwrite prompts]' \
  '--plugins-only[inject only plugin app extensions]' \
  '--zip[use external zip for removals]'
