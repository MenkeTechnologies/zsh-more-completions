#compdef valdcli
# Documentation: https://github.com/vdaas/vald-client-clj
# valdcli: command-line client for the Vald distributed vector search engine

local ret=1

_arguments -s -S \
  '--help[show usage]' \
  '--version[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-h --host)'{-h,--host}'=[Vald host (default localhost)]:host:_hosts' \
  '(-p --port)'{-p,--port}'=[Vald port (default 8080)]:port:' \
  '--json[read vectors as JSON instead of EDN]' \
  '1:command:((
    insert\:"insert a vector"
    update\:"update a vector"
    remove\:"remove a vector"
    search\:"search for nearest neighbors"
    search-by-id\:"search nearest neighbors by id"
    exists\:"check whether a vector id exists"
    get-object\:"get a vector object by id"
    index-info\:"show index information"
    create-index\:"create an index"
    save-index\:"save the index"
    create-and-save-index\:"create and save the index"
    rand-vec\:"generate a random vector"
    rand-vecs\:"generate random vectors"
    stream-insert\:"stream insert vectors"
    stream-update\:"stream update vectors"
    stream-remove\:"stream remove vectors"
    stream-search\:"stream search vectors"
    stream-search-by-id\:"stream search by id"
    stream-get-object\:"stream get objects"
  ))' \
  '*::arg:->args' && ret=0

return ret
