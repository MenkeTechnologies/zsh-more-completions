#compdef pg_format

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-u+[keywords in upper case]:level:(0 1 2 3)' \
  '-f+[function names in upper case]:level:(0 1 2 3)' \
  '-s+[spaces per indent]:spaces:' \
  '--spaces=[spaces per indent]:spaces:' \
  '-t[use tabs for indentation]' \
  '--tabs[use tabs for indentation]' \
  '-L[add extra newline between statements]' \
  '-n[add newline between top-level SQL]' \
  '-W+[line wrapping limit]:width:' \
  '--wrap-limit=[line wrapping limit]:width:' \
  '-a+[wrap after N columns]:columns:' \
  '--wrap-after=[wrap after N columns]:columns:' \
  '-C[use comma at start of new line]' \
  '--comma-start[use comma at start of new line]' \
  '-B[use comma at end of line]' \
  '--comma-end[use comma at end of line]' \
  '-b[add comma on same line as break]' \
  '-g[group insert values]' \
  '-T[output as HTML table]' \
  '-k[keep formatting of comments]' \
  '-e[expand empty parenthesis across lines]' \
  '-p+[placeholder regex pattern]:pattern:' \
  '--placeholder=[placeholder regex pattern]:pattern:' \
  '-o+[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '-d[debug mode]' \
  '--debug[debug mode]' \
  '*:file:_files -g "*.sql"' && ret=0

return ret
