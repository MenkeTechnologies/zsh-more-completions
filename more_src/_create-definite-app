#compdef create-definite-app
# Documentation: https://github.com/definite-app/definite-data-apps
# Reference accessed: 2026-05-24
# Verified: npm view create-definite-app bin; npm readme Flags section.

# Zsh completion for create-definite-app - Definite data app scaffolder from app.json manifest

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--from=[source manifest path or - for stdin]:file:_files' \
  '--toolkit-dir=[existing @definite-app/data-apps install root]:directory:_directories' \
  '--no-install[do not run npm install]' \
  '--no-build[do not run the build]' \
  '--force[overwrite target directory if it exists]' \
  '--validate=[validation levels]:levels:(none static schema render)' \
  '--api-key=[Definite API key for schema validation]:key:' \
  '(-o --out)'{-o,--out=}'[target directory]:directory:_directories' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':app name:' && ret=0

return ret
