#compdef crxjs
# Documentation: https://man.archlinux.org/search?q=crxjs
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[Vite config file]:file:_files' \
  '--mode=[Vite mode]:mode' \
  '--root=[project root]:directory:_directories' && ret=0

return ret
