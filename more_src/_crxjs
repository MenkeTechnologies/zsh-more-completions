#compdef crxjs
# Documentation: https://github.com/crxjs/chrome-extension-tools
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[Vite config file]:file:_files' \
  '--mode=[Vite mode]:mode' \
  '--root=[project root]:directory:_directories' && ret=0

return ret
