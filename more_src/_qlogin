#compdef qlogin
# Grid Engine: submit an interactive login session to the cluster

local ret=1

_arguments -s \
  '-help[display all options]' \
  '-@+[use the options contained in the given file]:option file:_files' \
  '-ac+[add context variables]:context' \
  '-ar+[assign the job to an existing advance reservation]:ar id' \
  '-A+[account string to charge for resource consumption]:account' \
  '-binding+[request a specific processor core binding]:binding' \
  '-clear[reset the job to its default status]' \
  '-cwd[execute the job from the current working directory]' \
  '-dc+[remove context variables]:context' \
  '-display+[X display specifier]:display' \
  '-dl+[deadline initiation time]:date time' \
  '-e+[standard error stream path]:path:_files' \
  '-hard[following resource requirements are hard]' \
  '-h[place a user hold on the job]' \
  '-hold_jid+[job dependency list]:job list' \
  '-hold_jid_ad+[array job dependency list]:job list' \
  '-j+[merge stderr into stdout]:value:(y yes n no)' \
  '-js+[job share value]:job share' \
  '-jsv+[JSV instance to verify the job specification]:jsv url' \
  '-l+[launch in a queue meeting the resource request list]:resource' \
  '-m+[circumstances under which mail is sent]:events' \
  '-M+[list of users to which mail is sent]:users' \
  '-masterq+[master queue list]:queues' \
  '-N+[name of the job]:name' \
  '-now+[start the job immediately or queue if unavailable]:value:(y yes n no)' \
  '-p+[priority of the job]:priority' \
  '-pe+[parallel environment to instantiate]:pe' \
  '-q+[list of cluster queues which may be used]:queues' \
  '-R+[whether a reservation should be done]:value:(y yes n no)' \
  '-sc+[set context variables]:context' \
  '-soft[following resource requirements are soft]' \
  '-S+[interpreting shell for the job]:shell:_files' \
  '-v+[environment variables to export]:variable' \
  '-V[export all current environment variables]' \
  '-verbose[print session establishment information]' \
  '-verify[print job details without submitting]' \
  '-w+[validation level applied to the job]:level:(e w n p v)' \
  '-wd+[execute the job from the given directory]:dir:_files -/' && ret=0

return ret
