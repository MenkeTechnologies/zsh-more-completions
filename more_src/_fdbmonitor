#compdef fdbmonitor
# Documentation: https://man.archlinux.org/search?q=fdbmonitor
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)'{-h,-?,--help}'[show help]' \
  '--conffile=[config file]:file:_files' \
  '--lockfile=[lockfile path]:file:_files' \
  '--loggroup=[log group name]:name:' \
  '--daemonize[run as daemon]'
