#compdef swanctl vici
# _vici — strongSwan swanctl + libvici (control client + Python/Perl/C bindings to the strongSwan charon Vici socket; subcommands: --load-all, --terminate, --redirect, --rekey, --initiate, --list-sas, --list-conns, --list-certs, --list-policies, --list-pools, --list-algs, --counters, --stats, --version, --version, --uri Vici socket override, --help)
# upstream: https://github.com/strongswan/strongswan (src/swanctl)
# Subcommands from strongSwan src/swanctl/swanctl.c on tip.

_vici() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--uri+[Vici socket]:file:_files' \
        '--load-all[load all config]' \
        '--load-conns[load conns]' \
        '--load-creds[load creds]' \
        '--load-pools[load pools]' \
        '--load-authorities[load authorities]' \
        '--initiate+[child SA]:child:' \
        '--terminate+[SA]:sa:' \
        '--rekey+[SA]:sa:' \
        '--redirect+[SA]:sa:' \
        '--list-sas[list IKE+CHILD SAs]' \
        '--list-conns[list conns]' \
        '--list-certs[list certs]' \
        '--list-policies[list policies]' \
        '--list-pools[list pools]' \
        '--list-algs[list crypto algs]' \
        '--counters[list counters]' \
        '--stats[stats]'
}

_vici "$@"
