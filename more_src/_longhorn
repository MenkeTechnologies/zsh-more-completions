#compdef longhorn
# _longhorn — Longhorn block-storage engine binary (longhorn/longhorn-engine)
# upstream: https://github.com/longhorn/longhorn-engine
# Flags from main.go + app/cmd/*.go (urfave/cli v1) on tip.

_longhorn() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print version and exit]' \
        '--url=[engine controller URL]:url:_urls' \
        '--volume-name=[Longhorn volume name]:name:' \
        '--engine-instance-name=[engine instance name]:name:' \
        '--debug[enable debug logging]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                controller:'run the engine controller'
                replica:'run a replica server'
                sync-agent:'run the replica sync agent'
                sync-agent-server-reset:'reset sync-agent server state'
                start-with-replicas:'start controller with given replica list'
                add-replica:'add a replica to the controller'
                verify-rebuild-replica:'verify a rebuilt replica'
                ls-replica:'list replicas attached to the controller'
                rm-replica:'remove a replica from the controller'
                update-replica:'update replica mode'
                rebuild-status:'show replica rebuild status'
                snapshot:'snapshot operations'
                snapshot-hash:'start a snapshot hash job'
                snapshot-hash-cancel:'cancel a snapshot hash job'
                snapshot-hash-status:'show snapshot hash status'
                backup:'backup operations'
                expand:'expand the volume size'
                unmap-mark-snap-chain-removed:'manage unmap snap-chain marking'
                journal:'inspect engine journal'
                info:'show engine info'
                frontend:'manage volume frontend'
                system-backup:'create or restore a system backup'
                profiler:'profile the engine'
            )
            _describe -t commands 'longhorn command' cmds
            ;;
        args)
            case $words[1] in
                controller)
                    _arguments \
                        '--listen=[controller listen address]:host\:port:' \
                        '--size=[volume size]:bytes:' \
                        '--current-size=[current volume size]:bytes:' \
                        '--frontend=[frontend driver]:driver:(tgt-blockdev tgt-iscsi rdma-blockdev)' \
                        '*--enable-backend=[enabled backend protocols]:proto:(tcp rdma)' \
                        '*--replica=[replica address]:addr:' \
                        '--upgrade[upgrade running controller]' \
                        '--disableRevCounter[disable revision counter]' \
                        '--salvageRequested[mark salvage requested]' \
                        '--engine-replica-timeout=[engine-replica timeout (s)]:n:' \
                        '--data-server-protocol=[data server protocol]:proto:(tcp rdma)' \
                        '--unmap-mark-snap-chain-removed[mark snap chain on unmap]'
                    ;;
            esac
            ;;
    esac
}

_longhorn "$@"
