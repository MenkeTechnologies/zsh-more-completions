#compdef langfuse langfuse-cli

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'api:invoke any Langfuse API endpoint (resource + action)'
  'login:save Langfuse credentials'
  'logout:clear stored credentials'
  'config:manage local CLI configuration'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--public-key=[Langfuse public key]:key:' \
  '--secret-key=[Langfuse secret key]:key:' \
  '--host=[Langfuse host URL]:url:' \
  '--json[output JSON]' \
  '--curl[print curl command for the request]' \
  '--limit=[pagination limit]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'langfuse command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (api)
        local -a resources=(
          '__schema:print full OpenAPI schema'
          'traces:traces (list/get/delete)'
          'observations:observations'
          'sessions:sessions'
          'prompts:prompts (list/get/create/update/delete)'
          'datasets:datasets'
          'dataset-items:dataset items'
          'dataset-runs:dataset run items'
          'score-v2s:scores v2'
          'score-configs:score configs'
          'projects:projects'
          'organizations:organizations'
          'metrics:metrics'
          'media:media files'
          'comments:comments'
          'annotations:annotation queues'
          'health:server health'
          'ingestion:ingestion endpoint'
        )
        _describe -t res 'resource' resources && ret=0
        local -a actions=(
          'list:list resources'
          'get:fetch a single resource'
          'create:create a resource'
          'update:update a resource'
          'delete:delete a resource'
          'patch:patch a resource'
          'put:replace a resource'
        )
        _describe -t actions 'action' actions && ret=0 ;;
      (config)
        _arguments '*::sub:(get set list reset)' && ret=0 ;;
    esac ;;
esac

return ret
