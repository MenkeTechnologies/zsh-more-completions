#compdef qucs-cli
# Documentation: https://man.archlinux.org/search?q=qucs-cli
# Reference accessed: 2026-05-16

# qucs-cli: command-line interface to Qucs simulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-i[input netlist file]:file:_files' \
  '-o[output dataset file]:file:_files' \
  '-V[verbose]' \
  '--version[show version]' \
  '*:netlist file:_files' && ret=0
return ret
