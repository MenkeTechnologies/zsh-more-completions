#compdef mhost

autoload -U is-at-least

_mhost() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--resolv-conf=[Uses alternative resolv.conf file]:FILE:_default' \
'--ndots=[Sets number of dots to qualify domain name as FQDN]:NUMBER:_default' \
'--search-domain=[Sets the search domain to append if HOSTNAME has less than ndots dots]:DOMAIN:_default' \
'*--system-nameserver=[Adds system nameserver for system lookups; only IP addresses allowed]:IP ADDR:_default' \
'*-s+[Adds nameserver for lookups]:HOSTNAME | IP ADDR:_default' \
'*--nameserver=[Adds nameserver for lookups]:HOSTNAME | IP ADDR:_default' \
'*--predefined-filter=[Filters predefined nameservers by protocol]:PROTOCOL:(udp tcp https tls)' \
'-f+[Adds nameservers from file]:FILE:_default' \
'--nameservers-from-file=[Adds nameservers from file]:FILE:_default' \
'--limit=[Sets max. number of nameservers to query]:NUMBER:_default' \
'--max-concurrent-servers=[Sets max. concurrent nameservers]:NUMBER:_default' \
'--max-concurrent-requests=[Sets max. concurrent requests per nameserver]:NUMBER:_default' \
'--retries=[Sets number of retries if first lookup to nameserver fails]:NUMBER:_default' \
'--timeout=[Sets timeout in seconds for responses]:TIMEOUT:_default' \
'-m+[Sets resolvers lookup mode]:MODE:(multi uni)' \
'--resolvers-mode=[Sets resolvers lookup mode]:MODE:(multi uni)' \
'-o+[Sets the output format for result presentation]:FORMAT:(json summary)' \
'--output=[Sets the output format for result presentation]:FORMAT:(json summary)' \
'*--output-options=[Sets output options]:OPTIONS:_default' \
'--max-worker-threads=[Set the max. number of worker threads overriding derived value]:NUMBER:_default' \
'--use-system-resolv-opt[Uses options set in /etc/resolv.conf]' \
'--no-system-nameservers[Ignores nameservers from /etc/resolv.conf]' \
'-S[Ignores system nameservers for lookups]' \
'--no-system-lookups[Ignores system nameservers for lookups]' \
'-p[Adds predefined nameservers for lookups]' \
'--predefined[Adds predefined nameservers for lookups]' \
'--list-predefined[Lists all predefined nameservers]' \
'--wait-multiple-responses[Waits until timeout for additional responses from nameservers]' \
'--continue-on-error[Continues lookups even when nameservers return errors]' \
'--continue-on-timeout[Continues lookups even when nameservers time out]' \
'--continue-on-all-errors[Continues lookups on all errors and timeouts from nameservers]' \
'(-q --quiet)--show-errors[Shows error counts]' \
'-q[Does not print anything but results]' \
'--quiet[Does not print anything but results]' \
'(-6 --ipv6-only)-4[Only use IPv4 for DNS connections (avoids IPv6 timeouts)]' \
'(-6 --ipv6-only)--ipv4-only[Only use IPv4 for DNS connections (avoids IPv6 timeouts)]' \
'(-4 --ipv4-only)-6[Only use IPv6 for DNS connections]' \
'(-4 --ipv4-only)--ipv6-only[Only use IPv6 for DNS connections]' \
'--no-color[Disables colorful output]' \
'--ascii[Uses only ASCII compatible characters for output]' \
'*-v[Sets the level of verbosity]' \
'--debug[Uses debug formatting for logging -- much more verbose]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_mhost_commands" \
"*::: :->mhost" \
&& ret=0
    case $state in
    (mhost)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:mhost-command-$line[1]:"
        case $line[1] in
            (check)
_arguments "${_arguments_options[@]}" : \
'-p[Shows results after each check step]' \
'--show-partial-results[Shows results after each check step]' \
'-i[Shows all lookups made during by all checks]' \
'--show-intermediate-lookups[Shows all lookups made during by all checks]' \
'--no-cnames[Does not run cname lints]' \
'--no-soa[Does not run SOA check]' \
'--no-spf[Does not run SPF check]' \
'--no-dmarc[Does not run DMARC check]' \
'--no-ns[Does not run NS delegation check]' \
'--no-mx[Does not run MX hygiene check]' \
'--no-caa[Does not run CAA check]' \
'--no-ttl[Does not run TTL sanity check]' \
'--no-dnssec[Does not run DNSSEC check]' \
'--no-https-svcb[Does not run HTTPS/SVCB check]' \
'--no-axfr[Does not run AXFR zone transfer security check]' \
'--no-open-resolver[Does not run open resolver detection check]' \
'--no-delegation[Does not run delegation consistency check]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':domain name -- domain name to check:_default' \
&& ret=0
;;
(diff)
_arguments "${_arguments_options[@]}" : \
'*-t+[Sets record types to compare]:RECORD TYPE:(A AAAA ANAME ANY CAA CNAME DNSKEY DS HINFO HTTPS MX NAPTR NSEC NSEC3 NSEC3PARAM NULL NS OPENPGPKEY PTR RRSIG SOA SRV SSHFP SVCB TLSA TXT)' \
'*--record-type=[Sets record types to compare]:RECORD TYPE:(A AAAA ANAME ANY CAA CNAME DNSKEY DS HINFO HTTPS MX NAPTR NSEC NSEC3 NSEC3PARAM NULL NS OPENPGPKEY PTR RRSIG SOA SRV SSHFP SVCB TLSA TXT)' \
'*-l+[Left nameserver(s) to query]:NAMESERVER:_default' \
'*--left=[Left nameserver(s) to query]:NAMESERVER:_default' \
'(-l --left)--left-from-file=[Load left side from a JSON snapshot file (from lookup --output json)]:FILE:_default' \
'*-r+[Right nameserver(s) to query]:NAMESERVER:_default' \
'*--right=[Right nameserver(s) to query]:NAMESERVER:_default' \
'(-r --right)--right-from-file=[Load right side from a JSON snapshot file (from lookup --output json)]:FILE:_default' \
'--all[Enables comparison for all record types]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':domain name -- domain name to compare:_default' \
&& ret=0
;;
(discover)
_arguments "${_arguments_options[@]}" : \
'-w+[Uses wordlist from file]:FILE:_default' \
'--wordlist-from-file=[Uses wordlist from file]:FILE:_default' \
'--rnd-names-number=[Sets number of random domain names to generate for wildcard resolution check]:NUMBER:_default' \
'--rnd-names-len=[Sets length of random domain names to generate for wildcard resolution check]:LEN:_default' \
'--depth=[Sets recursive discovery depth for found subdomains (max 3)]:N:_default' \
'-p[Shows results after each lookup step]' \
'--show-partial-results[Shows results after each lookup step]' \
'-s[Shows subdomains only omitting all other discovered names]' \
'--subdomains-only[Shows subdomains only omitting all other discovered names]' \
'--no-ct-logs[Skips Certificate Transparency log queries (external HTTP to crt.sh)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':domain name -- domain name to discover:_default' \
&& ret=0
;;
(dnssec)
_arguments "${_arguments_options[@]}" : \
'--max-hops=[Sets maximum number of delegation hops]:NUMBER:_default' \
'-p[Shows results as each delegation level completes]' \
'--show-partial-results[Shows results as each delegation level completes]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':domain name -- domain name to validate:_default' \
&& ret=0
;;
(domain-lookup)
_arguments "${_arguments_options[@]}" : \
'-p[Shows results after each lookup step]' \
'--show-partial-results[Shows results after each lookup step]' \
'--all[Includes extended well-known subdomains (Tier 3+4)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':domain name -- domain name to look up:_default' \
&& ret=0
;;
(info)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::topic -- Record type, TXT sub-type, or well-known subdomain to explain:_default' \
&& ret=0
;;
(lookup)
_arguments "${_arguments_options[@]}" : \
'*-t+[Sets record type to lookup, will be ignored in case of IP address lookup]:RECORD TYPE:(A AAAA ANAME ANY CAA CNAME DNSKEY DS HINFO HTTPS MX NAPTR NSEC NSEC3 NSEC3PARAM NULL NS OPENPGPKEY PTR RRSIG SOA SRV SSHFP SVCB TLSA TXT)' \
'*--record-type=[Sets record type to lookup, will be ignored in case of IP address lookup]:RECORD TYPE:(A AAAA ANAME ANY CAA CNAME DNSKEY DS HINFO HTTPS MX NAPTR NSEC NSEC3 NSEC3PARAM NULL NS OPENPGPKEY PTR RRSIG SOA SRV SSHFP SVCB TLSA TXT)' \
'--all[Enables lookups for all record types]' \
'(--all)-s[Parses ARG as service spec and set record type to SRV]' \
'(--all)--service[Parses ARG as service spec and set record type to SRV]' \
'-w[Retrieves Whois information about A, AAAA, and PTR records]' \
'--whois[Retrieves Whois information about A, AAAA, and PTR records]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':domain name -- domain name, IP address, or CIDR block to lookup:_default' \
&& ret=0
;;
(propagation)
_arguments "${_arguments_options[@]}" : \
'*-t+[Sets record types to check]:RECORD TYPE:(A AAAA ANAME ANY CAA CNAME DNSKEY DS HINFO HTTPS MX NAPTR NSEC NSEC3 NSEC3PARAM NULL NS OPENPGPKEY PTR RRSIG SOA SRV SSHFP SVCB TLSA TXT)' \
'*--record-type=[Sets record types to check]:RECORD TYPE:(A AAAA ANAME ANY CAA CNAME DNSKEY DS HINFO HTTPS MX NAPTR NSEC NSEC3 NSEC3PARAM NULL NS OPENPGPKEY PTR RRSIG SOA SRV SSHFP SVCB TLSA TXT)' \
'--all[Enables propagation check for all record types]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':domain name -- domain name to check propagation for:_default' \
&& ret=0
;;
(server-lists)
_arguments "${_arguments_options[@]}" : \
'-o+[Sets path to output file]:FILE:_default' \
'--output-file=[Sets path to output file]:FILE:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':server_list_spec -- server list specification:_default' \
&& ret=0
;;
(trace)
_arguments "${_arguments_options[@]}" : \
'-t+[Sets record type to query at the final authoritative server]:RECORD TYPE:(A AAAA ANAME ANY CAA CNAME DNSKEY DS HINFO HTTPS MX NAPTR NSEC NSEC3 NSEC3PARAM NULL NS OPENPGPKEY PTR RRSIG SOA SRV SSHFP SVCB TLSA TXT)' \
'--record-type=[Sets record type to query at the final authoritative server]:RECORD TYPE:(A AAAA ANAME ANY CAA CNAME DNSKEY DS HINFO HTTPS MX NAPTR NSEC NSEC3 NSEC3PARAM NULL NS OPENPGPKEY PTR RRSIG SOA SRV SSHFP SVCB TLSA TXT)' \
'--max-hops=[Sets maximum number of delegation hops]:NUMBER:_default' \
'--show-all-servers[Shows individual server details (IP, latency, outcome) for each hop]' \
'-p[Shows results after each delegation hop completes]' \
'--show-partial-results[Shows results after each delegation hop completes]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':domain name -- domain name to trace:_default' \
&& ret=0
;;
(verify)
_arguments "${_arguments_options[@]}" : \
'--origin=[Override zone origin (\$ORIGIN)]:NAME:_default' \
'(--ignore-type)*--only-type=[Only verify these record types (repeatable, comma-delimited)]:TYPE:(A AAAA ANAME ANY CAA CNAME DNSKEY DS HINFO HTTPS MX NAPTR NSEC NSEC3 NSEC3PARAM NULL NS OPENPGPKEY PTR RRSIG SOA SRV SSHFP SVCB TLSA TXT)' \
'(--only-type)*--ignore-type=[Skip these record types during verification (repeatable, comma-delimited)]:TYPE:(A AAAA ANAME ANY CAA CNAME DNSKEY DS HINFO HTTPS MX NAPTR NSEC NSEC3 NSEC3PARAM NULL NS OPENPGPKEY PTR RRSIG SOA SRV SSHFP SVCB TLSA TXT)' \
'--strict[Report TTL differences as mismatches]' \
'--ignore-extra[Suppress extra-record reporting (live records not in zone file)]' \
'--ignore-soa[Skip SOA serial comparison]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':zone-file -- Path to BIND zone file:_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for \[bash, elvish, fish, powershell, zsh\]:(bash elvish fish powershell zsh)' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_mhost_commands] )) ||
_mhost_commands() {
    local commands; commands=(
'check:Checks all available records for known misconfigurations or mistakes' \
'diff:Compares DNS records from two different nameserver sets or snapshot files' \
'discover:Discovers records of a domain using multiple heuristics' \
'dnssec:Visualizes the DNSSEC trust chain from root to the target domain' \
'domain-lookup:Looks up a domain'\''s apex and well-known subdomains in a single operation' \
'info:Shows information about DNS record types and well-known subdomains' \
'lookup:Looks up a name, IP address or CIDR block' \
'propagation:Checks DNS record propagation across public resolvers' \
'server-lists:Downloads known lists of name servers' \
'trace:Traces DNS delegation path from root servers to authoritative nameservers' \
'verify:Verifies DNS records against a BIND zone file' \
'completions:Generate shell completions for mhost' \
    )
    _describe -t commands 'mhost commands' commands "$@"
}
(( $+functions[_mhost__check_commands] )) ||
_mhost__check_commands() {
    local commands; commands=()
    _describe -t commands 'mhost check commands' commands "$@"
}
