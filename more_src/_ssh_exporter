#compdef ssh_exporter
# Documentation: https://github.com/treydock/ssh_exporter
# Prometheus exporter that probes SSH endpoints

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--config.file=[path to exporter config file]:file:_files' \
  '--web.listen-address=[address to listen on for web interface and telemetry]:addr' \
  '--collector.ssh.default-timeout=[default timeout for SSH connections]:dur' \
  '--version[show application version]' && ret=0

return ret
