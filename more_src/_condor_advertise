#compdef condor_advertise
# Documentation: https://man.archlinux.org/search?q=condor_advertise
# Reference accessed: 2026-05-16

# condor_advertise: send ClassAd updates to the collector
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-pool[pool/collector]:pool:' \
  '-tcp[send via TCP]' \
  '-udp[send via UDP]' \
  '-multiple[multiple ads]' \
  '*:update-type files:_files' && ret=0
return ret
