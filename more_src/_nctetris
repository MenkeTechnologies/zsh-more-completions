#compdef nctetris
# Documentation: https://www.mankier.com/1/nctetris
# nctetris - a tetris clone rendered with Notcurses

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '-l[log everything (high level) or nothing (0) to stderr]:loglevel:(0 1 2 3 4 5 6 7)' && ret=0

return ret
