#compdef grib_check_gaussian_grid
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_check_gaussian_grid
# Source: ecmwf/eccodes tools/grib_check_gaussian_grid.cc — check geometry of Gaussian-grid GRIB fields (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[do not exit on first error]' \
    '-v[verbose]' \
    '(- *)-V[print ecCodes version]' \
    '*:grib file:_files' \
    && ret=0

return ret
