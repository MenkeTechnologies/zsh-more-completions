#compdef wordbreaker

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d[dictionary file]:file:_files' \
  '--dict[dictionary file]:file:_files' \
  '-l[minimum word length]:length:' \
  '--len[minimum word length]:length:' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:input text:' \
  && ret=0

return ret
