#compdef fapolicyd fapolicyd-cli

local curcontext="$curcontext" ret=1

case $service in
  (fapolicyd-cli)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-c --check-config)'{-c,--check-config}'[validate config file]' \
      '(-D --dump-db)'{-D,--dump-db}'[dump trust database]' \
      '(-d --delete-db)'{-d,--delete-db}'[delete trust database]' \
      '(-f --file)'{-f,--file}'+[file to operate on]:op file:_files' \
      '(-l --list)'{-l,--list}'[list rules]' \
      '(-R --reload-rules)'{-R,--reload-rules}'[reload rules]' \
      '(-t --ftype)'{-t,--ftype}'+[query file type]:path:_files' \
      '(-u --update)'{-u,--update}'[update database]' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-d --debug)'{-d,--debug}'[debug mode]' \
      '(-p --permissive)'{-p,--permissive}'[permissive mode (log only)]' \
      '(--debug-deny)--debug-deny[log only denials]' \
      '(--no-details)--no-details[suppress event details]' && ret=0 ;;
esac

return ret
