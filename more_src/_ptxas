#compdef ptxas
# Documentation: https://docs.nvidia.com/cuda/cuda-compiler-driver-nvcc/index.html
# Reference accessed: 2026-05-20
# Verified: upstream NVIDIA CUDA Compiler Driver NVCC manual, section 4.2.9.1 (ptxas options).

# ptxas: NVIDIA PTX assembler (PTX -> SASS)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '(--compile-only -c)'{--compile-only,-c}'[compile only; do not assemble]' \
  '(--opt-level -O)'{--opt-level=,-O+}'[optimization level 0-3]:level:(0 1 2 3)' \
  '--maxrregcount=[max registers per thread]:n:' \
  '--allow-expensive-optimizations=[allow expensive optimizations]:bool:(true false)' \
  '(--def-load-cache -dlcm)'{--def-load-cache=,-dlcm=}'[default load cache mode]:mode:(ca cg cs cv)' \
  '(--def-store-cache -dscm)'{--def-store-cache=,-dscm=}'[default store cache mode]:mode:(wb cg cs wt)' \
  '(--force-load-cache -flcm)'{--force-load-cache=,-flcm=}'[force load cache mode]:mode:' \
  '(--force-store-cache -fscm)'{--force-store-cache=,-fscm=}'[force store cache mode]:mode:' \
  '--fmad=[fused multiply-add]:bool:(true false)' \
  '--disable-optimizer-constants[disable optimizer constants]' \
  '(--position-independent-code -pic)'{--position-independent-code=,-pic=}'[generate PIC]:bool:(true false)' \
  '(--device-debug -g)'{--device-debug,-g}'[generate debug info]' \
  '(--generate-line-info -lineinfo)'{--generate-line-info,-lineinfo}'[generate line info]' \
  '(--verbose -v)'{--verbose,-v}'[verbose output]' \
  '--warn-on-double-precision-use[warn on double precision use]' \
  '--warn-on-local-memory-usage[warn on local memory usage]' \
  '--warn-on-spills[warn on register spills]' \
  '(--gpu-name -arch)'{--gpu-name=,-arch=}'[target GPU architecture]:arch:' \
  '(--entry -e)'{--entry=,-e+}'[entry function]:entry:' \
  '(--machine -m)'{--machine=,-m+}'[machine bit width]:bits:(32 64)' \
  '*:PTX file:_files -g "*.ptx(-.)"' && ret=0
return ret
