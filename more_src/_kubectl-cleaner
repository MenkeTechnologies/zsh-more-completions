#compdef kubectl-cleaner
# Documentation: https://github.com/ratulbasak/kubectl-cleaner
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (cmd/*.go flag definitions).

# kubectl-cleaner (ratulbasak/kubectl-cleaner): persistent flags below; no
# -n short form and no --all-namespaces (single --namespace only).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--namespace=[Kubernetes namespace]:namespace:' \
  '--dry-run=[simulate actions only]:bool:(true false)' \
  '--rules-file=[YAML config file for analyzer rules]:file:_files' \
  '--deployments-replicas=[Deployment stale if replicas <= N (-1 disables)]:n:' \
  '--jobs-completed-only[only include completed Jobs as stale]' \
  '--pvc-phases=[comma-separated PVC phases to consider unused]:phases:' \
  '--secret-types=[comma-separated secret types to consider]:types:' \
  '--orphaned-services-only[include only orphaned services]' \
  '--orphaned-secrets-only[include only orphaned secrets]' \
  '--orphaned-configmaps-only[include only orphaned configmaps]' \
  '--older-than=[stale if older than N days (-1 disables)]:days:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'analyze:examine namespace for stale or orphaned resources'
      'purge:delete unused/orphaned resources'
      'completion:generate shell autocompletion script'
      'help:display command information'
    )
    _describe -t commands 'kubectl cleaner command' commands && ret=0
    ;;
esac

return ret
