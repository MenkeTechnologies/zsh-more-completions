#compdef drbd-utils drbdadm
# Documentation: https://github.com/LINBIT/drbd-utils
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# drbdadm: DRBD top-level admin tool (umbrella for drbd-utils)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'attach:attach lower disk to resource'
  'detach:detach lower disk from resource'
  'connect:connect peer'
  'disconnect:disconnect peer'
  'up:bring resource up'
  'down:take resource down'
  'primary:promote resource to primary'
  'secondary:demote resource to secondary'
  'verify:start online verification'
  'resize:resize the device'
  'create-md:create DRBD metadata'
  'wipe-md:wipe DRBD metadata'
  'dump:dump configuration of resource'
  'adjust:adjust running config to file'
  'invalidate:re-fetch data from peer'
  'invalidate-remote:invalidate peer data'
  'pause-sync:pause sync'
  'resume-sync:resume sync'
  'role:show role for resource'
  'status:show status of resource'
  'cstate:show connection state'
  'dstate:show disk state'
  'state:show overall state'
  'syncer:set sync parameters'
  'show:show running config'
  'wait-connect:wait until connected'
  'wait-sync:wait until sync done'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-d[dry-run]' \
  '--dry-run[dry-run]' \
  '-c[config file]:file:_files' \
  '--config-file=[config file]:file:_files' \
  '-t[config file is a template]' \
  '-s[drbdsetup binary]:file:_files' \
  '-m[drbdmeta binary]:file:_files' \
  '-S[stacked mode]' \
  '--stacked[stacked mode]' \
  '-P[peer-only mode]' \
  '--peer[peer-only mode]' \
  '-W[wait for completion]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'drbd command' commands && ret=0 ;;
esac
return ret
