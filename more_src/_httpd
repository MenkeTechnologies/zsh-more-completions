#compdef httpd
# _httpd — OpenBSD httpd (HTTP server with FastCGI + TLS; logs to syslog or per-server files; rereads config on SIGHUP and reopens logs on SIGUSR1; sibling of relayd(8))
# upstream: https://github.com/openbsd/src (usr.sbin/httpd)
# Flags from usr.sbin/httpd/httpd.8 on tip.

_httpd() {
    _arguments \
        '-d[debug (foreground single-server)]' \
        '-n[validate config + exit]' \
        '*-v[verbose (repeatable)]' \
        '*-D+[define macro=value]:macro=value:' \
        '-f+[config file (default /etc/httpd.conf)]:file:_files'
}

_httpd "$@"
