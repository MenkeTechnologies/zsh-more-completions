#compdef kexec-tools kexec

# kexec: load a new kernel for kexec / boot it
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-l[load kernel]:file:_files' \
  '--load=[load kernel]:file:_files' \
  '-p[load kdump (panic) kernel]:file:_files' \
  '--load-panic=[load kdump (panic) kernel]:file:_files' \
  '-u[unload current kernel]' \
  '--unload[unload current kernel]' \
  '-e[execute previously loaded kernel]' \
  '--exec[execute previously loaded kernel]' \
  '-f[force kexec even if signature check fails]' \
  '--force[force kexec even if signature check fails]' \
  '-x[do not call shutdown]' \
  '--no-shutdown[do not call shutdown]' \
  '-y[no syscall, use sys_kexec_file_load]' \
  '--syscall[no syscall, use sys_kexec_file_load]' \
  '-s[use kexec_file_load syscall]' \
  '--kexec-file-syscall[use kexec_file_load syscall]' \
  '--kexec-syscall[use kexec_load syscall]' \
  '--kexec-syscall-auto[autoselect syscall]' \
  '-t[kernel type]:type:(elf-x86 elf-x86_64 bzImage multiboot multiboot2 elf-ppc elf-ppc64 elf-mips beoboot-x86 image-arm64 uimage)' \
  '--type=[kernel type]:type:(elf-x86 elf-x86_64 bzImage multiboot multiboot2 elf-ppc elf-ppc64 elf-mips beoboot-x86 image-arm64 uimage)' \
  '--initrd=[initrd file]:file:_files' \
  '--append=[kernel command line]:cmdline:' \
  '--reuse-cmdline[reuse current kernel cmdline]' \
  '--command-line=[kernel command line]:cmdline:' \
  '--dtb=[device tree blob]:file:_files' \
  '--mem-min=[minimum address for new kernel]:addr:' \
  '--mem-max=[maximum address for new kernel]:addr:' \
  '--print-ckr-size[print kdump reserve size]' \
  '--reserve-pages=[reserved pages]:n:' \
  '--debug[enable debug]' \
  '*::kexec args:_files' && ret=0
return ret
