#compdef nmctl
# Documentation: https://docs.netmaker.io/docs/references/nmctl
# nmctl - Netmaker command line interface for managing networks, nodes and ACLs

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--endpoint=[Netmaker server API endpoint URL]:url:_urls' \
  '--master_key=[authenticate using the server master key]:key:' \
  '--username=[authenticate using this username]:username:' \
  '--password=[authenticate using this password]:password:' \
  '1:command:(acl completion context dns enrollment_key ext_client host logs metrics network network_user node server user usergroup)' \
  '*::arg:->args' && ret=0

return ret
