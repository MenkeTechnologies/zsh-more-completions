#compdef stats
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss194.html
# KAPPA STATS - compute simple statistics of an NDF's pixels

local ret=1

_arguments -C \
  'NDF=[NDF data structure to analyse]:NDF file:_files' \
  'COMP=[array component (Data/Error/Quality/Variance)]:component:(Data Error Quality Variance)' \
  'CLIP=[k-sigma clipping levels]:clip levels:' \
  'ORDER=[calculate order statistics (median/percentiles)]:flag:(TRUE FALSE)' \
  'PERCENTILES=[percentile values 0.0-100.0]:percentiles:' \
  'LOGFILE=[text file for results]:log file:_files' \
  '*:NDF file:_files' && ret=0

return ret
