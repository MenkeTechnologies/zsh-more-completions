#compdef netFilter
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: filter out parts of a net, passing what survives to stdout

local ret=1

_arguments -s -S \
  '-q=[restrict query side sequence to those named]:chroms' \
  '-notQ=[restrict query side sequence to those not named]:chroms' \
  '-t=[restrict target side sequence to those named]:chroms' \
  '-notT=[restrict target side sequence to those not named]:chroms' \
  '-minScore=[restrict to those scoring at least N]:n' \
  '-maxScore=[restrict to those scoring less than N]:n' \
  '-minGap=[restrict to those with gap size (tSize) >= minSize]:n' \
  '-minAli=[restrict to those with at least given bases aligning]:n' \
  '-maxAli=[restrict to those with at most given bases aligning]:n' \
  '-minSizeT=[restrict to those at least this big on target]:n' \
  '-minSizeQ=[restrict to those at least this big on query]:n' \
  '*-type=[restrict to given type (may be repeated)]:type' \
  '-syn[do filtering based on synteny (tuned for human/mouse)]' \
  '-minTopScore=[minimum score for top level alignments (default 300000)]:n' \
  '-minSynScore=[min syntenic block score (def 200000)]:n' \
  '-minSynSize=[min syntenic block size (def 20000)]:n' \
  '-minSynAli=[min syntenic alignment size (def 10000)]:n' \
  '-maxFar=[max distance to allow synteny (def 200000)]:n' \
  '-nonsyn[do inverse filtering based on synteny]' \
  '-chimpSyn[do filtering based on synteny (tuned for human/chimp)]' \
  '-fill[only pass fills, not gaps (only useful with -line)]' \
  '-gap[only pass gaps, not fills (only useful with -line)]' \
  '-line[do this a line at a time, not recursing]' \
  '-noRandom[suppress chains involving random chromosomes]' \
  '-noHap[suppress chains involving _hap or _alt chromosome names]' \
  '*:net file:_files -g "*.net"' && ret=0

return ret
