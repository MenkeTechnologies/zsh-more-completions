#compdef tuic-client
# _tuic-client — TUIC v5 QUIC-based proxy client (Itsusinn/tuic)
# upstream: https://github.com/Itsusinn/tuic
# Flags from tuic-client/src/config.rs (clap derive).

_tuic-client() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[config file path]:file:_files -g "*.(yml|yaml|json|toml)"'
}

_tuic-client "$@"
