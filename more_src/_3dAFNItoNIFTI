#compdef 3dAFNItoNIFTI
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dAFNItoNIFTI.html
# AFNI: convert an AFNI dataset to NIfTI-1.1 format

local ret=1

_arguments -s -S \
  '-prefix[output NIfTI filename]:prefix:' \
  '*-verb[verbose output (repeatable up to 3x)]' \
  '-float[convert output to 32-bit floats]' \
  '-pure[omit AFNI extension field]' \
  '-denote[remove text notes from AFNI extension]' \
  '-oldid[preserve input AFNI ID code]' \
  '-newid[assign new AFNI ID code (default)]' \
  '*:dataset:_files' && ret=0

return ret
