#compdef 3dSurf2Vol
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dSurf2Vol.html
# Map data from a surface domain to a volume domain

local ret=1

_arguments -s \
  '-spec[SUMA spec file]:spec file:_files' \
  '-surf_A[primary surface name]:surface' \
  '-surf_B[optional second surface name]:surface' \
  '-sv[surface volume dataset]:dataset:_files' \
  '-surf_xyz_1D[ASCII file with xyz coordinates]:file:_files' \
  '-grid_parent[dataset defining output grid]:dataset:_files' \
  '-map_func[function combining surface points]:func' \
  '-prefix[output dataset prefix]:prefix' \
  '-sdata_1D[1D node indices and data]:file:_files' \
  '-sdata[NIML or GIFTI surface dataset]:dataset:_files' \
  '-f_steps[points dividing each segment]:num' \
  '-f_index[index by points or voxels]:type:(points voxels)' \
  '-f_p1_fr[first endpoint fractional offset]:frac' \
  '-f_pn_fr[second endpoint fractional offset]:frac' \
  '-f_p1_mm[first endpoint offset mm]:dist' \
  '-f_pn_mm[second endpoint offset mm]:dist' \
  '-stop_gap[terminate segments at zero mask]' \
  '-cmask[apply mask command]:mask' \
  '-data_expr[math expression on input data]:expr' \
  '-datum[output data type]:type:(byte short float)' \
  '-debug[verbosity level 0-5]:level' \
  '-dnode[debug output for a node]:node' \
  '-dvoxel[debug output for a voxel]:voxel' \
  '-noscale[disable integer scale factor]' \
  '-sxyz_orient_as_gpar[treat coords as grid parent orient]' \
  '-hist[revision history]' \
  '-help[display help]' \
  '-version[version info]' && ret=0

return ret
