#compdef gammu

# Zsh completion for gammu (mobile phone management tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'identify:Identify the connected phone'
  'getfirmware:Get firmware version'
  'getmanufacturer:Get manufacturer name'
  'getmodel:Get phone model'
  'getimei:Get IMEI number'
  'getsignal:Get signal strength'
  'getbattery:Get battery status'
  'getdatetime:Get phone date/time'
  'setdatetime:Set phone date/time'
  'getphonebook:Get phonebook entries'
  'getallphonebook:Get all phonebook entries'
  'getsms:Get SMS message'
  'getallsms:Get all SMS messages'
  'sendsms:Send an SMS message'
  'deletesms:Delete an SMS message'
  'getsmsc:Get SMS center number'
  'setsmsc:Set SMS center number'
  'getcalendar:Get calendar entries'
  'getallcalendar:Get all calendar entries'
  'gettodo:Get todo entries'
  'getalltodo:Get all todo entries'
  'getfilesystem:Get filesystem information'
  'getfilesystemstatus:Get filesystem usage'
  'monitor:Monitor phone status'
  'networkinfo:Display network information'
  'reset:Reset the phone'
  'dialvoice:Dial a voice call'
  'cancelcall:Cancel a call'
  'answercall:Answer a call'
  'savefile:Save a file to phone'
  'getfile:Get a file from phone'
  'backup:Backup phone data'
  'restore:Restore phone data'
)

_arguments -s -S -C \
  '-c+[Use specified config file]:config file:_files' \
  '-s+[Use specified config section]:section number' \
  '-d+[Enable debugging]:debug level:(text textall binary errors)' \
  '-f+[Redirect debug output to file]:file:_files' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'gammu command' commands && ret=0
    ;;
  args)
    case $words[1] in
      sendsms)
        _arguments -s -S \
          '1:type:(TEXT EMS MMSINDICATOR RINGTONE OPERATOR PICTURE CALENDAR BOOKMARK WAPINDICATOR)' \
          '2:phone number' \
          '-text+[Message text]:text' \
          '-len+[Message length]:length' \
          '-unicode[Send as unicode]' \
          '-flash[Send as flash message]' \
          '-smscset+[Use specified SMSC set]:number' \
          '-reply[Request delivery report]' && ret=0
        ;;
      getphonebook|getallphonebook)
        _arguments -s -S \
          '1:memory type:(ME SM DC MC RC ON FD)' \
          '2:start position' && ret=0
        ;;
      getsms|deletesms)
        _arguments -s -S \
          '1:folder number' \
          '2:position' && ret=0
        ;;
    esac
    ;;
esac

return ret
