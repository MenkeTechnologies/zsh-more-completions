#compdef hyprshot
# Documentation: https://man.archlinux.org/search?q=hyprshot
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --mode)'{-m+,--mode=}'[capture mode]:mode:(output window region active)' \
  '(-o --output-folder)'{-o+,--output-folder=}'[save folder]:dir:_files -/' \
  '(-f --filename)'{-f+,--filename=}'[output filename]:file:' \
  '(-D --delay)'{-D+,--delay=}'[delay seconds]:secs:' \
  '(-z --freeze)'{-z,--freeze}'[freeze screen]' \
  '(-d --debug)'{-d,--debug}'[print debug info]' \
  '(-s --silent)'{-s,--silent}'[no notifications]' \
  '(-r --raw)'{-r,--raw}'[output raw image data]' \
  '--clipboard-only[copy to clipboard only, do not save]' \
  '--current[capture current monitor]' \
  '*:: command :' && ret=0

return ret
