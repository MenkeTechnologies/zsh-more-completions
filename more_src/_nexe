#compdef nexe

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-i+[input entry point]:input file:_files -g "*.{js,mjs,cjs}"' \
  '--input=[input entry point]:input file:_files -g "*.{js,mjs,cjs}"' \
  '-o+[output executable]:output file:_files' \
  '--output=[output executable]:output file:_files' \
  '-t+[target node version]:target' \
  '--target=[target node version]:target' \
  '-n+[name of the binary]:name' \
  '--name=[name of the binary]:name' \
  '-r+[resource glob pattern]:glob' \
  '--resource=[resource glob pattern]:glob' \
  '-p+[python executable]:python:_files' \
  '--python=[python executable]:python:_files' \
  '--build[build Node.js from source]' \
  '--no-build[do not build from source]' \
  '--clean[clean the build cache]' \
  '--temp=[temp build directory]:directory:_directories' \
  '--ico=[icon file for Windows]:icon file:_files -g "*.ico"' \
  '--rc-*[Windows resource settings]' \
  '--sourceUrl=[URL for Node.js source]:url' \
  '--enableNodeCli[enable node CLI flags]' \
  '-f[force overwrite]' \
  '--fakeArgv[fake process.argv\[0\]]' \
  '--verbose[verbose logging]' \
  '--silent[suppress all output]' \
  '*:entry file:_files -g "*.{js,mjs,cjs}"' && ret=0

return ret
