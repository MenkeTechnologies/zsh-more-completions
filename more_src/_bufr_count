#compdef bufr_count
# Documentation: https://confluence.ecmwf.int/display/ECC/bufr_count
# Print the total number of BUFR messages in the given files (ecCodes).

local ret=1

_arguments -s \
  '-v[verbose, count per file]' \
  '-f[force, do not fail on error]' \
  '*:bufr file:_files' && ret=0

return ret
