#compdef cyrus-reconstruct
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/reconstruct.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org reconstruct(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-reconstruct: rebuild Cyrus mailbox metadata from spool contents
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-p[search non-existent mailboxes on this partition]:partition:' \
  '-x[discard existing metadata and rebuild from scratch]' \
  '-r[recursive: include sub-mailboxes]' \
  '-f[examine filesystem and add directories with cyrus.header]' \
  '-s[skip stat of underlying files (faster, less thorough)]' \
  '-q[quiet: less verbose syslog output]' \
  '-n[dry-run: report only, no changes]' \
  '-G[force re-parsing of underlying messages (GUID check)]' \
  '-I[assign new UNIQUEIDs to duplicates]' \
  '-R[UID upgrade for GUID-mismatched files]' \
  '-U[corrupt-spool recovery mode]' \
  '-o[ignore odd files in mailbox directories]' \
  '-O[delete odd files]' \
  '-M[prefer mailboxes.db over cyrus.header]' \
  '-V[target cyrus.index minor version]:version:' \
  '-u[arguments are userids]' \
  '-P[arguments are paths to cyrus.header files]' \
  '*:mailbox:' && ret=0
return ret
