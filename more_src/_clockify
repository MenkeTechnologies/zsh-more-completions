#compdef clockify-cli
# _clockify — Clockify CLI for time tracking (nicories/clockify-cli)
# upstream: https://github.com/nicories/clockify-cli

_clockify() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--token=[API token]:token:' \
        '--workspace=[workspace ID]:workspace:' \
        '--format=[output format]:format:(json table)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'in:start a time entry'
                'out:stop current time entry'
                'report:show time entries report'
                'edit:edit a time entry'
                'delete:delete a time entry'
                'tags:list tags'
                'projects:list projects'
                'workspaces:list workspaces'
                'config:manage configuration'
                'manual:add a manual time entry'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                in|manual)
                    _arguments -s -S \
                        '--project=[project name or ID]:project:' \
                        '(-d --description)'{-d,--description}'=[entry description]:description:' \
                        '--task=[task name]:task:' \
                        '--tag=[tag name]:tag:' \
                        '--billable[mark as billable]' \
                        '(-i --interactive)'{-i,--interactive}'[interactive mode]'
                    ;;
                edit)
                    _arguments -s -S \
                        '--project=[project name or ID]:project:' \
                        '(-d --description)'{-d,--description}'=[entry description]:description:' \
                        '--task=[task name]:task:' \
                        '--tag=[tag name]:tag:' \
                        '--billable[mark as billable]' \
                        '*:entry ID:'
                    ;;
                report)
                    _arguments -s -S \
                        '--format=[output format]:format:(json table)' \
                        '--project=[filter by project]:project:'
                    ;;
                delete)
                    _arguments '*:entry ID:'
                    ;;
            esac
            ;;
    esac
}

_clockify "$@"
