#compdef apt-cli
# _apt-cli — Debian APT package manager CLI alias (Debian project, C++); custom argparse
# upstream: https://salsa.debian.org/apt-team/apt

_apt-cli() {
    local -a sub=(
        'autoremove:remove automatically installed and no longer needed'
        'changelog:show changelog'
        'depends:show package dependencies'
        'download:download package'
        'edit-sources:edit source list'
        'full-upgrade:perform full upgrade'
        'help:show help'
        'install:install packages'
        'list:list packages'
        'moo:moo'
        'policy:show repository policy'
        'purge:remove packages and configuration'
        'rdepends:show reverse dependencies'
        'remove:remove packages'
        'reinstall:reinstall packages'
        'search:search packages'
        'show:show package details'
        'showsrc:show source package details'
        'source:download source'
        'update:update package index'
        'upgrade:upgrade installed packages'
        'satisfy:satisfy dependency strings'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--simulate[simulate]' \
        '-s[simulate]' \
        '--dry-run[dry run]' \
        '--no-act[no act]' \
        '--yes[assume yes]' \
        '-y[assume yes]' \
        '--assume-yes[assume yes]' \
        '--assume-no[assume no]' \
        '--no-install-recommends[no install recommends]' \
        '--install-recommends[install recommends]' \
        '--install-suggests[install suggests]' \
        '--no-install-suggests[no install suggests]' \
        '--download-only[download only]' \
        '-d[download only]' \
        '--fix-broken[fix broken]' \
        '-f[fix broken]' \
        '--fix-missing[fix missing]' \
        '-m[fix missing]' \
        '--no-download[no download]' \
        '--ignore-missing[ignore missing]' \
        '--force-yes[force yes]' \
        '--allow-unauthenticated[allow unauthenticated]' \
        '--allow-downgrades[allow downgrades]' \
        '--allow-remove-essential[allow remove essential]' \
        '--allow-change-held-packages[allow change held packages]' \
        '--option=+[apt option]:str:' \
        '-o+[apt option]:str:' \
        '--config-file=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--target-release=+[target release]:str:' \
        '-t+[target release]:str:' \
        '--auto-remove[auto remove]' \
        '--reinstall[reinstall]' \
        '--no-list-cleanup[no list cleanup]' \
        '--source[source]' \
        '--allow-insecure-repositories[allow insecure repositories]' \
        '--show-progress[show progress]' \
        '--print-uris[print URIs]' \
        '--installed[installed]' \
        '--upgradable[upgradable]' \
        '--manual-installed[manual installed]' \
        '--all-versions[all versions]' \
        '--verbose-versions[verbose versions]' \
        '--name-only[name only]' \
        '--full[full]' \
        '--no-color[no color]' \
        '--with-source=+[with source]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'apt subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|purge|search|show|reinstall|source|download|changelog|depends|rdepends|policy|satisfy|edit-sources) _arguments '*:package:' ;;
                list) _arguments \
                    '--installed[installed]' \
                    '--upgradable[upgradable]' \
                    '--manual-installed[manual installed]' \
                    '--all-versions[all versions]' \
                    '--verbose[verbose]' ;;
            esac
            ;;
    esac
}

_apt-cli "$@"
