#compdef conform-gt
# Documentation: https://faculty.washington.edu/browning/conform-gt.html
# conform-gt aligns a target VCF to a reference VCF (allele order and strand)

local ret=1

_arguments -s -S \
  'gt=-[target VCF file with genotypes]:file:_files' \
  'ref=-[reference VCF file with genotypes]:file:_files' \
  'chrom=-[chromosome or interval chr or chr\:start-end]:chrom' \
  'out=-[output filename prefix]:prefix:_files' \
  'match=-[match field ID or POS]:field:(ID POS)' \
  'excludesamples=-[file of samples to exclude]:file:_files' \
  'strict=-[strict strand determination true or false]:bool:(true false)' \
  '*:arg:_files' && ret=0

return ret
