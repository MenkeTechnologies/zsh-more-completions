#compdef relayctl
# _relayctl — OpenBSD relayctl (control + introspect a running relayd(8): show relays/redirects/routers/sessions, enable/disable hosts/tables/redirects, reload config, poll checks)
# upstream: https://github.com/openbsd/src (usr.sbin/relayctl)
# Commands from usr.sbin/relayctl/relayctl.8 on tip.

_relayctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'relayctl command' \
                '(show:show subsystem state (hosts|redirects|relays|routers|sessions|summary) monitor:stream live status changes poll:trigger immediate check of all hosts load:reload config from a specific file reload:reload current config file log:set log level (brief|verbose) host:enable/disable a backend host table:enable/disable a table redirect:enable/disable a redirect)'
            ;;
        args)
            case $line[1] in
                show) _describe -t commands 'show target' '(hosts redirects relays routers sessions summary)' ;;
                log) _describe -t commands 'log level' '(brief verbose)' ;;
                host|table|redirect) _describe -t commands 'subcommand' '(enable disable)' ;;
                load) _arguments '1:filename:_files' ;;
            esac
            ;;
    esac
}

_relayctl "$@"
