#compdef cvc-operator
# _cvc-operator — OpenEBS cStor CVC (CStorVolumeConfig) operator (reconciles CStorVolume + CStorVolumeReplica + serves the CVC REST API)
# upstream: https://github.com/openebs/cstor-operators
# Flags from pkg/controllers/cstorvolumeconfig/start.go on tip + klog v2 flags.

_cvc-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[absolute path to kubeconfig (out-of-cluster only)]:file:_files' \
        '--leader-election[enable leader election]' \
        '--leader-election-namespace=[namespace holding the leader-election resource]:ns:' \
        '--bind=[IP address to bind the CVC-Operator REST server to]:addr:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_cvc-operator "$@"
