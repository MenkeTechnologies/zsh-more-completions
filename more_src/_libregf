#compdef regftools regfinfo regfexport regfmount
# _libregf — libregf tools (libyal Windows registry hive parser; regfinfo dumps hive metadata, regfexport walks an entire hive into structured text, regfmount FUSE-mounts a hive read-only with each key as a directory and each value as a file; -h help, -V version, -v verbose, -m mountpoint, -o image offset; positional argument is the hive file)
# upstream: https://github.com/libyal/libregf
# Flags from libyal/libregf regftools/regfinfo.c on tip.

_libregf() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-m+[mountpoint]:dir:_files -/' \
        '-o+[image offset]:bytes:' \
        '*:hive file:_files'
}

_libregf "$@"
