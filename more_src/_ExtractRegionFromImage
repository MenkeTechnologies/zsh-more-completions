#compdef ExtractRegionFromImage
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ExtractRegionFromImage.cxx — extract a rectangular sub-image (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:inputImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outputImage:_files' \
    '*:remaining (minIndex maxIndex | label | domainImage | label labelImage 1):_default' \
    && ret=0

return ret
