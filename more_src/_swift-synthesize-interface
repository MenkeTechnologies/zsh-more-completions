#compdef swift-synthesize-interface

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-help[display available options]' \
  '-clang-target=[set the target for internal Clang instance]:target:' \
  '-clang-target-variant=[set the target for zippered macCatalyst code]:target:' \
  '-cxx-interoperability-mode=[enable C++ interoperability]:mode:(default off)' \
  '*-Fsystem+[add directory to system framework search path]:dir:_files -/' \
  '*-F+[add directory to framework search path]:dir:_files -/' \
  '-include-submodules[print declarations synthesized for Clang submodules]' \
  '*-Isystem+[add directory to system import search path]:dir:_files -/' \
  '*-I+[add directory to import search path]:dir:_files -/' \
  '-language-mode=[interpret input according to a Swift language mode]:mode:' \
  '-module-cache-path=[specifies the module cache path]:path:_files -/' \
  '-module-name=[name of the module to build]:name:' \
  '-o+[write output to file]:file:_files' \
  '-print-fully-qualified-types[always print fully qualified type names]' \
  '-project-name=[name of the project the module belongs to]:name:' \
  '-resource-dir=[directory that holds the compiler resource files]:dir:_files -/' \
  '-sdk=[compile against SDK]:sdk:' \
  '-strict-memory-safety[enable strict memory safety checking]' \
  '-strict-memory-safety:migrate[enable migration to strict memory safety checking]' \
  '-swift-version=[interpret input according to Swift language version]:version:' \
  '-sysroot=[native platform sysroot]:path:_files -/' \
  '-target=[generate code for the given target triple]:triple:' \
  '-target-arch-variant=[generate additional arch variant in fat mach-o]:variant:' \
  '-v[verbose output]' \
  '*-Xcc+[pass argument to the C/C++/Objective-C compiler]:arg:' \
  '*:input file:_files -g "*.swift"' && ret=0

return ret
