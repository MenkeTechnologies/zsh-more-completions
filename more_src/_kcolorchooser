#compdef kcolorchooser
# Documentation: https://github.com/KDE/kcolorchooser/blob/master/kcolorchooser.cpp
# A small KDE utility to select a color

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--print[print the selected color to stdout]' \
  '--color=[set initially selected color]:color' \
  '--version[show version]' && ret=0

return ret
