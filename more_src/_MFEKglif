#compdef MFEKglif
# Documentation: https://github.com/MFEK/glif
# MFEK standalone UFO .glif glyph viewer and editor

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '*:glif file:_files -g "*.glif *.glifjson"' && ret=0

return ret
