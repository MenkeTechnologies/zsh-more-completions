#compdef zplug

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'check:check if packages are installed'
      'clean:remove unneeded packages'
      'clear:clear cache'
      'install:install packages'
      'list:list installed packages'
      'load:load packages'
      'status:show status of packages'
      'update:update installed packages'
      'info:show package info'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (check|info)
        _arguments '--verbose[verbose output]' '1:package:' && ret=0
        ;;
      (clean)
        _arguments \
          '--force[force clean without confirmation]' \
          '--select[interactively select packages to clean]' && ret=0
        ;;
      (install)
        _arguments '--verbose[verbose output]' && ret=0
        ;;
      (list)
        _arguments \
          '--select[interactively select packages]' \
          '--loaded[list only loaded packages]' \
          '--installed[list only installed packages]' && ret=0
        ;;
      (status)
        _arguments '--select[interactively select packages]' && ret=0
        ;;
      (update)
        _arguments \
          '--select[interactively select packages to update]' \
          '--self[update zplug itself]' \
          '1:package:' && ret=0
        ;;
    esac
    ;;
esac

return ret
