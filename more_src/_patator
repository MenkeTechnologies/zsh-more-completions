#compdef patator
# Documentation: https://github.com/lanjelot/patator
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a modules

modules=(
  'ftp_login:FTP brute force'
  'ssh_login:SSH brute force'
  'telnet_login:telnet brute force'
  'smtp_login:SMTP brute force'
  'smtp_vrfy:SMTP VRFY enumeration'
  'smtp_rcpt:SMTP RCPT enumeration'
  'finger_lookup:finger lookup'
  'http_fuzz:HTTP fuzzer'
  'rdp_gateway:RDP gateway'
  'ajp_fuzz:AJP fuzzer'
  'pop_login:POP3 login'
  'pop_passd:POP passd'
  'imap_login:IMAP login'
  'ldap_login:LDAP login'
  'dcom_login:DCOM login'
  'smb_login:SMB login'
  'smb_lookupsid:SMB SID enum'
  'rlogin_login:rlogin'
  'vmauthd_login:VMware auth'
  'mssql_login:MSSQL login'
  'oracle_login:Oracle login'
  'mysql_login:MySQL login'
  'mysql_query:MySQL query'
  'rdp_login:RDP login'
  'pgsql_login:PostgreSQL login'
  'vnc_login:VNC login'
  'dns_forward:DNS forward'
  'dns_reverse:DNS reverse'
  'ike_enum:IKE enum'
  'snmp_login:SNMP login'
  'unzip_pass:zip password'
  'keystore_pass:keystore password'
  'sqlcipher_pass:SQLCipher password'
  'umbraco_crack:Umbraco password crack'
)

_arguments -C \
  '*-x+[actions and conditions]:expr:' \
  '--start=[start offset]:N:' \
  '--stop=[stop offset]:N:' \
  '--resume=[resume previous run]:r1[,rN]*:' \
  '*-e+[encode everything between two tags]:encoding:' \
  '-C+[delimiter string in combo files]:char:' \
  '-X+[delimiter string in conditions]:char:' \
  '--allow-ignore-failures[override the no-ignore-failures safeguard]' \
  '-y[automatically answer yes]' \
  '--rate-limit=[wait N seconds between each attempt]:N:' \
  '--timeout=[wait N seconds for a response before retrying]:N:' \
  '--max-retries=[skip payload after N retries]:N:' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:N:' \
  '--groups=[iteration spec]:spec:' \
  '-l+[save output and response data into DIR]:dir:_files -/' \
  '-L+[automatically save into DIR/date/time_SFX]:suffix:' \
  '-R+[save output to FILE]:file:_files' \
  '--csv=[save CSV results to FILE]:file:_files' \
  '--xml=[save XML results to FILE]:file:_files' \
  '--hits=[save found candidates to FILE]:file:_files' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '--auto-progress=[display progress every N seconds]:N:' \
  '1: :->module' \
  '*::arg: ' && ret=0

case $state in
  (module) _describe -t modules 'patator module' modules && ret=0 ;;
esac

return ret
