#compdef avbutil
# Documentation: https://keith.github.io/xcode-man-pages/avbutil.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:show help'
  'virtual-audio:interact with virtual audio devices'
  'mvrp:interact with Multiple VLAN Registration Protocol'
  'controller:configure or launch the general AVDECC Controller'
  'custom-audio:interact with custom audio devices'
  'convert-aem:convert AEM file between aemxml/aemplist/C code'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'avbutil subcommand' subcommands && ret=0
    ;;
esac

return ret
