#compdef vcfld
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfld.md
# vcflib: compute linkage disequilibrium between target and background populations

local ret=1

_arguments -s -S \
  '(-t --target)'{-t,--target}'[zero-based comma-separated list of target individuals (VCF columns)]:target' \
  '(-b --background)'{-b,--background}'[zero-based comma-separated list of background individuals]:background' \
  '(-f --file)'{-f,--file}'[a properly formatted phased VCF file]:vcf file:_files' \
  '(-y --type)'{-y,--type}'[type of genotype likelihood]:type:(PL GL GP)' \
  '(-w --window)'{-w,--window}'[window size to average LD (default 1000)]:N' \
  '(-e --external)'{-e,--external}'[population to calculate LD expectation (default target)]' \
  '(-d --derived)'{-d,--derived}'[which haplotype to count: 00 vs 11 (default 00)]' && ret=0

return ret
