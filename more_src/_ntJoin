#compdef ntJoin
# Documentation: https://github.com/bcgsc/ntJoin
# ntJoin: reference-guided assembly scaffolding and assembly comparison

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'ntJoin command' \
      'assemble[scaffold a target assembly using reference assemblies]' \
      'help[display the help documentation]' && ret=0
    ;;
esac

return ret
