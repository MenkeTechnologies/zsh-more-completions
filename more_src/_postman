#compdef postman newman

# Zsh completion for Postman / Newman CLI

_postman() {
  local curcontext="$curcontext" state line ret=1
  local prog=${words[1]:t}

  case $prog in
    newman)
      local -a commands=(
        'run:run a Postman collection'
      )
      _arguments -s -S \
        '1:command:->command' \
        '*:: :->args' \
        && ret=0

      case $state in
        (command)
          _describe -t commands 'newman command' commands && ret=0
          ;;
        (args)
          case ${words[1]} in
            run)
              _arguments -s -S \
                '(-e --environment)'{-e,--environment}'[environment file]:file:_files -g "*.json"' \
                '(-g --globals)'{-g,--globals}'[globals file]:file:_files -g "*.json"' \
                '-d+[data file]:data file:_files -g "*.{json,csv}"' \
                '--iteration-data=[data file]:data file:_files -g "*.{json,csv}"' \
                '-n+[number of iterations]:count:' \
                '--iteration-count=[number of iterations]:count:' \
                '--folder=[run only specified folder]:folder name:' \
                '--timeout=[timeout in ms]:ms:' \
                '--timeout-request=[request timeout in ms]:ms:' \
                '--timeout-script=[script timeout in ms]:ms:' \
                '--delay-request=[delay between requests in ms]:ms:' \
                '-k[disable SSL verification]' \
                '--insecure[disable SSL verification]' \
                '--bail[stop run on first error]' \
                '--ignore-redirects[ignore HTTP redirects]' \
                '--silent[disable terminal output]' \
                '--color=[enable/disable color]:mode:(on off auto)' \
                '--disable-unicode[force ASCII encoding]' \
                '--suppress-exit-code[always exit with code 0]' \
                '-r+[reporters]:reporters:' \
                '--reporters=[reporters]:reporters:' \
                '--reporter-cli-no-summary[do not show summary]' \
                '--reporter-cli-no-failures[do not show failures]' \
                '--reporter-cli-no-assertions[do not show assertions]' \
                '--reporter-cli-no-banner[do not show banner]' \
                '--reporter-json-export=[JSON export file]:file:_files -g "*.json"' \
                '--reporter-junit-export=[JUnit export file]:file:_files -g "*.xml"' \
                '--reporter-html-export=[HTML export file]:file:_files -g "*.html"' \
                '--reporter-htmlextra-export=[HTML extra export file]:file:_files -g "*.html"' \
                '--export-globals=[export globals file]:file:_files -g "*.json"' \
                '--export-environment=[export environment file]:file:_files -g "*.json"' \
                '--export-collection=[export collection file]:file:_files -g "*.json"' \
                '--working-dir=[working directory]:directory:_files -/' \
                '--no-insecure-file-read[prevent reading files outside working dir]' \
                '--ssl-client-cert=[client certificate]:cert file:_files' \
                '--ssl-client-key=[client key]:key file:_files' \
                '--ssl-client-passphrase=[client cert passphrase]:passphrase:' \
                '--ssl-extra-ca-certs=[extra CA certificates]:cert file:_files' \
                '--env-var=[environment variable]:name=value:' \
                '--global-var=[global variable]:name=value:' \
                '--verbose[show detailed info of collection run]' \
                '1:collection:_files -g "*.json"' \
                && ret=0
              ;;
          esac
          ;;
      esac
      ;;
    *)
      _arguments -s -S '--help[display help]' && ret=0
      ;;
  esac

  return ret
}

_postman "$@"
