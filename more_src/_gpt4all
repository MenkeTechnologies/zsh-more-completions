#compdef gpt4all

# Zsh completion for GPT4All CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--model=[model to use]:model' \
  '--model-path=[path to model directory]:directory:_directories' \
  '--device=[device to use]:device:(cpu gpu)' \
  '--ngl=[number of GPU layers]:layers' \
  '--temp=[temperature]:temperature' \
  '--top-p=[top-p sampling]:value' \
  '--top-k=[top-k sampling]:value' \
  '--repeat-penalty=[repeat penalty]:penalty' \
  '--repeat-last-n=[context for repeat penalty]:tokens' \
  '--n-batch=[batch size]:size' \
  '--n-ctx=[context window size]:size' \
  '--threads=[number of CPU threads]:threads' \
  '--prompt=[initial prompt]:prompt' \
  '--system-prompt=[system prompt]:prompt' \
  '--chat[start in chat mode]' && ret=0

return ret
