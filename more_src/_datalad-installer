#compdef datalad-installer
# Documentation: https://github.com/datalad/datalad-installer
# Installation script for DataLad and related components

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage information and exit]' \
  '(-V --version)'{-V,--version}'[show script version and exit]' \
  '(-l --log-level)'{-l,--log-level}'=[set log level]:level:(CRITICAL ERROR WARNING INFO DEBUG)' \
  '*'{-E,--env-write-file}'=[append shell commands needed to use new components to file]:file:_files' \
  '--sudo=[behavior when sudo is needed]:mode:(ask error ok)' \
  '*:component:(venv miniconda conda-env neurodebian git-annex datalad rclone git-annex-remote-rclone)' && ret=0

return ret
