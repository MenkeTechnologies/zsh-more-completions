#compdef macoserror
# Documentation: macoserror -h (Apple/Xcode utility; no man page; help string is canonical)
# Reference accessed: 2026-05-19
# Verified: macoserror -h on Darwin 25 (Xcode command-line utility).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)'{-h,--help}'[show usage]' \
  '*:numeric error code:' && ret=0

return ret
