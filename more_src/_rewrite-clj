#compdef rewrite-clj
# _rewrite-clj — Bozhidar Batsov rewrite-clj rewriter for Clojure/EDN preserving whitespace and comments CLI alias (clj-commons team, Clojure); tools.deps function CLI
# upstream: https://github.com/clj-commons/rewrite-clj

_rewrite-clj() {
    local -a sub=(
        'parse:parse file to zipper'
        'rewrite:rewrite file in place'
        'format:format a file'
        'expand:expand all comments and whitespace nodes'
        'find:find form in file'
        'replace:replace form'
        'doc:show docs for a node'
        'walk:walk tree printing nodes'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--auto-resolve=+[auto resolve edn map]:str:' \
        '--features=+[features edn vec]:str:' \
        '--read-cond=+[read-cond]:r:(allow preserve)' \
        '--throw-on-error[throw on error]' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rewrite-clj subcommand' sub ;;
        args)
            case $words[1] in
                parse|rewrite|format|expand|walk) _arguments \
                    '*:files:_files -g "*.{clj,cljs,cljc,edn}"' ;;
                find|replace) _arguments \
                    '1:pattern:' \
                    '*:files:_files -g "*.{clj,cljs,cljc,edn}"' ;;
            esac
            ;;
    esac
}

_rewrite-clj "$@"
