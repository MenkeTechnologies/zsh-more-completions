#compdef splot
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Plot a spectrum

local ret=1

_arguments -s -S \
  'SPECTRUM=[spectrum to be plotted]:spectrum:_files' \
  'HARDCOPY=[send plot to hardcopy device]:hardcopy:(TRUE FALSE)' \
  'WHOLE=[plot the whole spectrum]:whole:(TRUE FALSE)' \
  'AUTOSCALE=[autoscale plot to fit data]:autoscale:(TRUE FALSE)' \
  'XSTART=[first X value to plot]:xstart:' \
  'XEND=[last X value to plot]:xend:' \
  'HIGH=[maximum data value to plot]:high:' \
  'LOW=[minimum data value to plot]:low:' \
  'BIAS=[vertical displacement applied to data]:bias:' \
  'LABEL=[label at top of plot]:label:' \
  'ERASE=[erase screen before plotting]:erase:(TRUE FALSE)' \
  'AXES=[draw plot axes]:axes:(TRUE FALSE)' \
  'LINES=[draw a line plot instead of histogram]:lines:(TRUE FALSE)' \
  'COLOUR=[colour to plot the data in]:colour:' \
  'THICKNESS=[line thickness for hardcopy plots]:thickness:' \
  '*:NDF data file:_files' && ret=0

return ret
