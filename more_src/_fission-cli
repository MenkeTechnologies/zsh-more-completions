#compdef fission-cli fission-cli2
# _fission-cli — Fission Project fission-cli CLI command-line frontend wrapping the Fission Function-as-a-Service FaaS framework Kubernetes-native serverless functions runtime managing functions environments packages triggers httptriggers timetriggers messagequeuetriggers kubewatchers canaries-canary-deployment-source-code-build-pipeline (Fission team, Go); cobra
# upstream: https://fission.io/

_fission-cli() {
    local -a sub=(
        'function:function operations'
        'environment:environment operations'
        'package:package operations'
        'route:HTTP trigger management'
        'httptrigger:HTTP trigger management'
        'timetrigger:time trigger management'
        'mqtrigger:message queue trigger'
        'kubewatcher:kubewatcher operations'
        'canary-config:canary config operations'
        'support:dump support bundle'
        'archive:archive operations'
        'spec:spec apply'
        'check:check installation'
        'token:token operations'
        'plugins:plugin management'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '--server=+[url]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'fission-cli subcommand' sub ;;
        args)
            case $words[1] in
                function) _arguments \
                    '1:op:(list get create update delete test log run getmeta describe)' \
                    '--name=+[name]:str:' \
                    '--code=+[file]:file:_files' \
                    '--env=+[env]:str:' \
                    '--package=+[name]:str:' \
                    '--entrypoint=+[name]:str:' \
                    '--builder=+[image]:str:' \
                    '--runtime=+[image]:str:' \
                    '*:name:' ;;
                environment|package|httptrigger|timetrigger|mqtrigger|kubewatcher|canary-config) _arguments \
                    '1:op:(list get create update delete describe)' \
                    '*:name:' ;;
            esac
            ;;
    esac
}

_fission-cli "$@"
