#compdef mksub
# Documentation: https://github.com/trickest/mksub
# Generate tens of thousands of subdomain combinations from a wordlist.

local ret=1

_arguments -s -S \
  '-d[input domain]:domain' \
  '-df[input domain file, one domain per line]:file:_files' \
  '-l[subdomain level to generate (default 1)]:level' \
  '-o[output file (stdout used when omitted)]:file:_files' \
  '-r[regex to filter words from wordlist file]:regex' \
  '-silent[skip writing generated subdomains to stdout (faster)]' \
  '-t[number of threads for every subdomain level (default 100)]:threads' \
  '-w[wordlist file]:file:_files' && ret=0

return ret
