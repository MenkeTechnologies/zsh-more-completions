#compdef zpool-offline
# _zpool-offline — OpenZFS zpool offline (mark a vdev offline so writes skip it; -f explicitly mark faulted, -t temporary (until reboot); positional pool followed by devices to offline)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_offline) on tip.

_zpool-offline() {
    _arguments \
        '-f[mark faulted]' \
        '-t[temporary offline]' \
        '1:pool:' \
        '*:device:'
}

_zpool-offline "$@"
