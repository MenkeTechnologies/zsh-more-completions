#compdef sqlpkg
# Documentation: https://github.com/nalgeon/sqlpkg-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'init:initialize sqlpkg'
  'install:install package'
  'uninstall:uninstall package'
  'update:update packages'
  'list:list installed packages'
  'info:show package info'
  'which:print package path'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sqlpkg command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install|uninstall|info|which|update)
        _arguments \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
