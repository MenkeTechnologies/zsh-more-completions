#compdef sqlpkg

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'init:initialize sqlpkg'
  'install:install package'
  'uninstall:uninstall package'
  'remove:alias of uninstall'
  'update:update packages'
  'upgrade:alias of update'
  'list:list installed packages'
  'info:show package info'
  'which:print package path'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sqlpkg command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install|uninstall|remove|info|which|update|upgrade)
        _arguments \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
