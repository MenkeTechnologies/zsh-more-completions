#compdef fsck_fskit
# Documentation: https://man.archlinux.org/search?q=fsck_fskit
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--progress[display fsck progress]' \
  '-t+[file system type]:fstype:(msdos exfat hfs apfs)' \
  '*:device:_files -g "/dev/(r)disk*"' && ret=0

return ret
