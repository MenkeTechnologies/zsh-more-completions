#compdef hmmalign
# Documentation: https://man.archlinux.org/search?q=hmmalign
# Reference accessed: 2026-05-16

# HMMER hmmalign: align sequence(s) to a profile HMM
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output alignment file]:file:_files' \
  '--mapali[add MA from HMM map alignment]:file:_files' \
  '--trim[trim alignment to match-states only]' \
  '--amino[assert amino acid sequences]' \
  '--dna[assert DNA sequences]' \
  '--rna[assert RNA sequences]' \
  '--allcol[include all columns of HMM in output]' \
  '--outformat[output alignment format]:fmt:(stockholm pfam a2m afa clustal psiblast phylip phylips selex)' \
  '--informat[input sequence format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip phylips selex)' \
  '*:HMM file and sequence file:_files' && ret=0
return ret
