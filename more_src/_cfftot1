#compdef cfftot1
# Documentation: cfftot1 --help (lcdf-typetools)
# Source: lcdf-typetools cfftot1 — convert Compact Font Format (CFF) to PostScript Type 1.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a --pfa -b --pfb)'{-a,--pfa}'[output PFA font]' \
    '(-a --pfa -b --pfb)'{-b,--pfb}'[output PFB font (default)]' \
    '(-n --name)'{-n,--name=}'[select font NAME from CFF]:name:' \
    '(-o --output)'{-o,--output=}'[output file]:file:_files' \
    '(-q --quiet)'{-q,--quiet}'[no error messages]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1:input CFF or OpenType font:_files -g "*.{cff,otf}"' \
    '2:output Type 1 font:_files' \
    && ret=0

return ret
