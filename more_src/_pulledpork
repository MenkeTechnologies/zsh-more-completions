#compdef pulledpork pulledpork.pl
# Documentation: https://github.com/shirkdog/pulledpork
# Reference accessed: 2026-05-16
# Verified: upstream README. Perl 5 script; case-sensitive flags.

# pulledpork: Snort/Suricata rule updater (Perl)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-V[show version]' \
  '-b[dropsid config file]:file:_files' \
  '-C[snort.conf path]:file:_files -g "*.conf"' \
  '-c[pulledpork config file]:file:_files' \
  '-d[do not verify signature of rules tarball]' \
  '-D[Linux distribution for SO rules]:distro:' \
  '-e[enablesid config file]:file:_files' \
  '-E[write only enabled rules to output]' \
  '-g[grabonly: download but do not process]' \
  '-h[sid_changelog path]:file:_files' \
  '-H[signal SIGHUP/SIGUSR2 to pids]:signal:(SIGHUP SIGUSR2)' \
  '-I[base ruleset]:level:(security connectivity balanced)' \
  '-i[disablesid config file]:file:_files' \
  '-k[keep rules in separate files]' \
  '-K[output directory for separate rules]:dir:_files -/' \
  '-l[log to syslog]' \
  '-L[local.rules path for sid-msg.map]:file:_files' \
  '-m[sid-msg.map output path]:file:_files' \
  '-M[modifysid config file]:file:_files' \
  '-n[skip download]' \
  '-o[generic rules output file]:file:_files' \
  '-O[oinkcode]:code:' \
  '-p[Snort binary path]:file:_files' \
  '-P[process rules even if no new download]' \
  '-R[restore enablesid rules to original state]' \
  '-r[reference docs output directory]:dir:_files -/' \
  '-S[Snort/Suricata version]:version:' \
  '-s[so_rules output directory]:dir:_files -/' \
  '-T[text rules only; skip so_rules]' \
  '-u[custom rules tarball URL]:url:' \
  '-v[verbose]' \
  '-vv[extra verbose]' \
  '-w[skip SSL verification]' \
  '-W[LWP proxy workaround]' && ret=0
return ret
