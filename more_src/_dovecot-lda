#compdef dovecot-lda
# Documentation: https://www.mankier.com/1/dovecot-lda
# Reference accessed: 2026-05-16
# Verified: dovecot-lda(1) manpage.

# dovecot-lda: Dovecot Local Delivery Agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '-a[destination address (user+ext@domain)]:address:' \
  '-c[alternative config file]:file:_files' \
  '-d[destination username (userdb lookup)]:user:_users' \
  '-e[write rejection reason to stderr, exit 77]' \
  '-f[envelope sender address]:address:' \
  '-k[do not clear environment at startup]' \
  '-m[destination mailbox (default INBOX)]:mailbox:' \
  '-o[override configuration setting]:setting=value:' \
  '-p[path to mail (instead of stdin)]:file:_files' \
  '-r[final envelope recipient address]:address:' && ret=0
return ret
