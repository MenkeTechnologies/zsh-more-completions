#compdef codacy-analysis-cli
# Documentation: https://github.com/codacy/codacy-cli-v2
# Reference accessed: 2026-05-23
# Verified: codacy-cli docs (see also _codacy-cli).

# Zsh completion for codacy-analysis-cli - Codacy local analysis CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'analyze:run code analysis'
  'analyse:run code analysis (alias)'
  'install:install dependencies'
  'init:initialize configuration'
  'update:update CLI components'
  'config:print or edit configuration'
  'discover:auto-discover tools'
  'upload:upload results to Codacy'
  'sarif:emit SARIF results'
  'plugins:plugin management'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--verbose[verbose logging]' \
  '--debug[debug logging]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    _describe -t cmds 'codacy command' commands && ret=0
    ;;
esac

return ret
