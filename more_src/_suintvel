#compdef suintvel
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/data_conversion/suintvel.c
# Convert stacking velocity model to interval velocity model

local ret=1

_arguments -s -S \
  'vs=[stacking velocities]:vs' \
  't0=[normal incidence times]:t0' \
  'mode=[=0 output h= v= ; =1 output v= t=]:mode:(0 1)' \
  'outpar=[output parameter file]:outpar:_files' \
  'par=[input parameter file]:par:_files' \
  '*:file:_files' && ret=0

return ret
