#compdef cargo-stylus

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'new:create new project'
  'init:init in current dir'
  'export-abi:export Solidity ABI'
  'check:check contract'
  'deploy:deploy contract'
  'verify:verify contract'
  'cgen:generate C bindings'
  'replay:replay tx'
  'trace:trace tx'
  'simulate:simulate tx'
  'cache:cache management'
  'activate:activate program'
  'estimate-gas:estimate gas'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cargo-stylus command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (check|deploy)
        _arguments \
          '(--endpoint)--endpoint=[RPC URL]:url:' \
          '(--no-verify)--no-verify[skip verify]' \
          '(--wasm-file)--wasm-file=[wasm path]:file:_files' \
          '(--contract-address)--contract-address=[address]:addr:' \
          '(--private-key)--private-key=[private key]:k:' \
          '(--private-key-path)--private-key-path=[private key path]:file:_files' \
          '(--keystore-path)--keystore-path=[keystore]:file:_files' \
          '(--keystore-password-path)--keystore-password-path=[keystore pwd]:file:_files' \
          '(--max-fee-per-gas-gwei)--max-fee-per-gas-gwei=[max fee]:n:' \
          '(--estimate-gas)--estimate-gas[estimate only]' \
          '*: :_files' && ret=0 ;;
      (export-abi)
        _arguments \
          '(--release)--release[release]' \
          '*: :' && ret=0 ;;
      (cache)
        _arguments \
          '1:subcommand:(bid status suggestion)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
