#compdef cargo-stylus
# Documentation: https://github.com/OffchainLabs/cargo-stylus
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'new:create new Stylus project'
  'init:init Stylus project in current dir'
  'export-abi:export Solidity ABI'
  'check:check contract is deployable'
  'deploy:deploy contract'
  'verify:verify deployed contract'
  'cgen:generate C bindings'
  'replay:replay tx in gdb'
  'trace:trace tx via debug_traceTransaction'
  'cache:cache management (bid/status/suggestion)'
  'activate:activate a deployed contract'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cargo-stylus command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (new)
        _arguments \
          '--minimal[create minimal project]' \
          '*: :_files -/' && ret=0 ;;
      (check|deploy)
        _arguments \
          '--endpoint=[RPC URL]:url:' \
          '--no-verify[skip Docker reproducible verification]' \
          '--wasm-file=[wasm path]:file:_files' \
          '--contract-address=[contract address]:addr:' \
          '--private-key=[private key]:k:' \
          '--private-key-path=[private key path]:file:_files' \
          '--keystore-path=[keystore]:file:_files' \
          '--keystore-password-path=[keystore pwd]:file:_files' \
          '--max-fee-per-gas-gwei=[max fee gwei]:n:' \
          '--estimate-gas[estimate only]' \
          '--no-activate[skip activation]' \
          '*: :_files' && ret=0 ;;
      (verify)
        _arguments \
          '--endpoint=[RPC URL]:url:' \
          '--deployment-tx=[deployment tx hash]:hash:' \
          '--no-verify[skip Docker verification]' \
          '*: :' && ret=0 ;;
      (export-abi)
        _arguments \
          '--release[release build]' \
          '--output=[output file path]:file:_files' \
          '--json[output JSON ABI]' \
          '--rust-features=[Rust features]:features:' \
          '*: :' && ret=0 ;;
      (cache)
        _arguments \
          '1:subcommand:(bid status suggestion)' \
          '*: :' && ret=0 ;;
      (replay|trace)
        _arguments \
          '--endpoint=[RPC URL]:url:' \
          '--tx=[tx hash]:hash:' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
