#compdef bedJoinTabOffset
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# Add file offset and length of line in a text file with the same name as the BED name to each row of BED

local ret=1

_arguments -s -S \
  '-bedKey=[0-based index key, defaults to 3 for name field]:index:' \
  '*:inTabFile inBedFile outBedFile:_files' && ret=0

return ret
