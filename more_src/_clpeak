#compdef clpeak
# Documentation: https://github.com/krrishnarraj/clpeak
# Reference accessed: 2026-05-30
# clpeak — Krishnaraj Bhat's accelerator peak-throughput micro-benchmark.
# Single binary that probes OpenCL / Vulkan / CUDA / Metal back-ends and
# reports compute/memory/transfer peaks; widely used on Linux + macOS for
# tuning ML and crypto workloads.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show full flag documentation]' \
  '(--no-opencl)--opencl[enable OpenCL backend]' \
  '(--opencl)--no-opencl[disable OpenCL backend]' \
  '(--no-vulkan)--vulkan[enable Vulkan backend]' \
  '(--vulkan)--no-vulkan[disable Vulkan backend]' \
  '(--no-cuda)--cuda[enable CUDA backend]' \
  '(--cuda)--no-cuda[disable CUDA backend]' \
  '(--no-metal)--metal[enable Metal backend]' \
  '(--metal)--no-metal[disable Metal backend]' \
  '--single-precision-compute[run only SP compute tests]' \
  '--wmma[CUDA tensor-core tests (hand-rolled WMMA)]' \
  '--cublas[CUDA vendor-SDK GEMM peak (cuBLASLt)]' \
  '--simdgroup-matrix[Apple matrix-engine tests]' \
  '--mps-gemm[Apple vendor-SDK GEMM peak]' \
  '--coopmat[Vulkan tensor-core tests]' \
  '--cl-platform=[OpenCL platform index]:N:' \
  '--cl-device=[OpenCL device index]:N:' \
  '--vk-device=[Vulkan physical-device index]:N:' \
  '--cuda-device=[CUDA device ordinal]:N:' \
  '--mtl-device=[Metal device index]:N:' \
  '--xml-file=[save results as XML]:file:_files' \
  '--json-file=[save results as JSON]:file:_files' \
  '--csv-file=[save results as CSV]:file:_files' \
  '--compare=[compare against baseline JSON]:file:_files -g "*.json"' \
  '(- *)--list-devices[enumerate devices and exit]' \
  && ret=0

return ret
