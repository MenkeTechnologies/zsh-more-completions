#compdef gnushogi
# Documentation: https://man.archlinux.org/search?q=gnushogi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-a[output ASCII board]' \
  '-A+[ascii flag]:flag:' \
  '-b+[opening book file]:file:_files' \
  '-B+[binbook file]:file:_files' \
  '-C+[input chunk]:chunk:' \
  '-l+[load game file]:file:_files' \
  '-L+[log file]:file:_files' \
  '-P+[max tree depth]:depth:' \
  '-R+[random seed]:seed:' \
  '-s+[save file]:file:_files' \
  '-t+[depth limit]:depth:' \
  '-T+[think mode]:flag:' \
  '-X[disable book]' \
  '*:command:' && ret=0

return ret
