#compdef img

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-b+[backend]:backend:(auto native overlayfs)' \
  '--backend=[backend]:backend:(auto native overlayfs)' \
  '-d[debug mode]' \
  '--debug[debug mode]' \
  '-s+[state directory]:directory:_directories' \
  '--state=[state directory]:directory:_directories' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:build an image from a Dockerfile'
      'du:show image disk usage'
      'inspect:inspect image'
      'login:log in to a registry'
      'logout:log out from a registry'
      'ls:list images'
      'prune:prune unused data'
      'pull:pull an image'
      'push:push an image'
      'rm:remove an image'
      'save:save image to tar'
      'tag:tag an image'
      'unpack:unpack image to rootfs'
      'version:show version'
    )
    _describe -t commands 'img command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build)
        _arguments -s -S \
          '-f+[Dockerfile path]:dockerfile:_files' \
          '--file=[Dockerfile path]:dockerfile:_files' \
          '-t+[image tag]:tag' \
          '--tag=[image tag]:tag' \
          '--build-arg=[build argument]:arg' \
          '--target=[target build stage]:stage' \
          '--no-cache[do not use cache]' \
          '--platform=[target platform]:platform' \
          '-o+[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '1:context:_directories' && ret=0
        ;;
      pull|push|rm|inspect|tag)
        _arguments '1:image:' && ret=0
        ;;
      save)
        _arguments -s -S \
          '-o+[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '1:image:' && ret=0
        ;;
    esac
    ;;
esac

return ret
