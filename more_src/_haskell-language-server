#compdef haskell-language-server haskell-language-server-wrapper hls
# _haskell-language-server — Haskell Language Server CLI alias (Haskell Foundation / HLS team, Haskell); custom argparse
# upstream: https://github.com/haskell/haskell-language-server

_haskell-language-server() {
    local -a sub=(
        'lsp:start LSP server'
        'vscode-extension-schema:emit VSCode extension schema'
        'plugins-custom-config-markdown-reference:plugin reference'
        'plugins-custom-config-json-schema:plugin config schema'
        'print-libdir:print lib dir'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--numeric-version[print numeric version]' \
        '--probe-tools[probe tools]' \
        '--print-libdir[print lib dir]' \
        '--vscode-extension-schema[print vscode extension schema]' \
        '--plugins-custom-config-format-markdown[plugin config markdown]' \
        '--plugins-custom-config-format-json[plugin config json]' \
        '--list-plugins[list plugins]' \
        '--cwd=+[change working dir]:dir:_files -/' \
        '-d+[change working dir]:dir:_files -/' \
        '--debug[debug]' \
        '--lsp[run LSP]' \
        '--example[run example]' \
        '--vfs-extras[vfs extras]' \
        '--shake-profiling=+[shake profiling]:dir:_files -/' \
        '--ot-memory-profiling[ot memory profiling]' \
        '--ot-profiling=+[ot profiling]:dir:_files -/' \
        '--report-build-events[report build events]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--log-file=+[log file]:file:_files' \
        '-l+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '--testdata-dir=+[testdata dir]:dir:_files -/' \
        '--ignore-fingerprint[ignore fingerprint]' \
        '--retain-life-time=+[retain life time]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'haskell-language-server subcommand' sub ;;
    esac
}

_haskell-language-server "$@"
