#compdef helm-secrets

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'enc:encrypt secrets file'
  'dec:decrypt secrets file'
  'view:view decrypted secrets'
  'edit:edit encrypted secrets'
  'clean:clean decrypted files'
  'dir:show decrypted directory'
  'install:wrapper for helm install with secret decryption'
  'upgrade:wrapper for helm upgrade with secret decryption'
  'template:wrapper for helm template with secret decryption'
  'lint:wrapper for helm lint with secret decryption'
  'diff:wrapper for helm diff with secret decryption'
  'downloader:downloader proxy for sops encrypted files'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--driver=[encryption driver]:driver:(sops vals)' \
  '--backend=[encryption backend]:backend:(sops vals)' \
  '--backend-args=[args for the backend]:args' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '-v[verbose mode]' \
  '--verbose[verbose mode]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'helm-secrets command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      enc|dec|view|edit|clean)
        _arguments -s -S \
          '*:secrets file:_files -g "*.(yaml|yml)"' && ret=0
        ;;
      install|upgrade|template|lint|diff)
        _arguments -s -S \
          '-f+[decrypted values file]:values file:_files -g "*.(yaml|yml)"' \
          '--values=[decrypted values file]:values file:_files -g "*.(yaml|yml)"' \
          '*:helm args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
