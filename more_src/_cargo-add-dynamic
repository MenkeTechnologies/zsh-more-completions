#compdef cargo-add-dynamic
# Documentation: https://github.com/rksm/cargo-add-dynamic
# Source: rksm/cargo-add-dynamic src/main.rs — add a dependency as a dylib via a wrapper sub-package.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--optional[mark the dependency as optional]' \
    '(-v --verbose)'{-v,--verbose}'[additional (debug) logging]' \
    '--offline[run without accessing the network]' \
    '--no-default-features[disable the default features]' \
    '(-F --features)'{-F+,--features=}'[space/comma separated list of features to activate]:features:_default' \
    '--path=[filesystem path to local crate to add]:path:_files -/' \
    '--rename=[rename the dependency]:name:_default' \
    '(-n --name)'{-n+,--name=}'[name of the dynamic library (defaults to <DEP>-dynamic)]:name:_default' \
    '--lib-dir=[directory for the new sub-package]:dir:_files -/' \
    '(-p --package)'{-p+,--package=}'[package to modify]:spec:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:dep:_default' \
    && ret=0

return ret
