#compdef sustolt
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/migration_inversion/sustolt.c
# Stolt migration for stacked or prestack SU data

local ret=1

_arguments -s -S \
  'cdpmin=[minimum cdp number in dataset]:cdpmin' \
  'cdpmax=[maximum cdp number in dataset]:cdpmax' \
  'dxcdp=[distance between adjacent cdp bins]:dxcdp' \
  'noffmix=[number of offsets to mix]:noffmix' \
  'tmig=[times corresponding to rms velocities in vmig]:tmig' \
  'vmig=[rms velocities corresponding to times in tmig]:vmig' \
  'smig=[stretch factor]:smig' \
  'vscale=[scale factor to apply to velocities]:vscale' \
  'fmax=[maximum frequency in input data]:fmax' \
  'lstaper=[length of side tapers in traces]:lstaper' \
  'lbtaper=[length of bottom taper in samples]:lbtaper' \
  'verbose=[1 for diagnostic print]:verbose:(0 1)' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
