#compdef lascanopy
# LAStools: compute forestry canopy metrics from LAS/LAZ points

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help documentation]' \
  '-version[show tool version]' \
  '-gui[launch graphical interface]' \
  '-demo[run in demo mode]' \
  '-verbose[extended output information]' \
  '-silent[suppress non-error output]' \
  '-license[display licensing details]' \
  '-step+[grid cell size (default 20)]:size' \
  '-height_cutoff+[height threshold for metrics (default 1.37)]:meters' \
  '-cover_cutoff+[cutoff level for canopy coverage]:meters' \
  '-min[lowest elevation per grid cell]' \
  '-max[highest elevation per grid cell]' \
  '-avg[mean elevation per grid cell]' \
  '-std[standard deviation of heights]' \
  '-ske[height distribution skewness]' \
  '-kur[height distribution kurtosis]' \
  '-qav[average of squared heights above cutoff]' \
  '-p+[height percentiles (e.g. 25 50 75)]:percentiles' \
  '-b+[percentage of points between cutoff and max]:n' \
  '-c+[count points in height intervals]:min' \
  '-d+[relative height density as percentage]:min' \
  '-cov[canopy cover (first returns above cutoff)]' \
  '-dns[canopy density (all points above cutoff)]' \
  '-gap[inverse of canopy cover/density]' \
  '-abv[count points above cutoff]' \
  '-all[total point count]' \
  '-int_min[minimum intensity]' \
  '-int_max[maximum intensity]' \
  '-int_avg[mean intensity]' \
  '-loc+[circular plots from text file]:file:_files' \
  '-lor+[rectangular plots from text file]:file:_files' \
  '-lop+[polygonal plots from shapefile]:file:_files -g "*.(shp|SHP)"' \
  '-names[include plot names in output]' \
  '-files_are_plots[input files represent individual plots]' \
  '-ll+[lower-left raster corner x y]:x' \
  '-ncols+[maximum raster columns]:n' \
  '-nrows+[maximum raster rows]:n' \
  '-fractions[output as decimals instead of percentages]' \
  '-nodata+[no-data value for output]:value' \
  '-mem+[memory allocation in MB]:mb' \
  '*-i+[input file(s) or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-merged[combine multiple input files]' \
  '-o+[output file]:output:_files' \
  '-oasc[ASCII output]' \
  '-obil[BIL output]' \
  '-ocsv[CSV output]' \
  '-otif[GeoTIFF output]' \
  '-olaz[LAZ output]' \
  '-oxyz[XYZ text output]' \
  '-stdout[pipe output to standard output]' \
  '-cores+[parallel processing on n cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
