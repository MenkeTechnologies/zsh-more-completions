#compdef keepass2
# Documentation: https://documentation.help/KeePass/cmdline.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# KeePass: cross-platform password manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '--auto-type[invoke global auto-type]' \
  '--lock-all[lock databases of all KeePass instances]' \
  '--unlock-all[unlock databases of all KeePass instances]' \
  '--exit-all[exit all KeePass instances]' \
  '*:database:_files -g "*.kdbx"' && ret=0
return ret
