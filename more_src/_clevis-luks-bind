#compdef clevis-luks-bind
# Documentation: https://github.com/latchset/clevis/blob/master/src/luks/clevis-luks-bind
# Reference accessed: 2026-05-16
# Verified: upstream src/luks/clevis-luks-bind getopts ":hfyd:s:k:t:e:".

# clevis-luks-bind: bind clevis pin to a LUKS slot
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-f[force (no prompts)]' \
  '-y[yes + force]' \
  '-d[LUKS device]:device:_files -g "/dev/*"' \
  '-s[slot number]:slot:' \
  '-k[existing passphrase/keyfile]:keyfile:_files' \
  '-t[LUKS2 token ID]:token:' \
  '-e[existing token ID]:token:' \
  '*:PIN [CONFIG]:' && ret=0
return ret
