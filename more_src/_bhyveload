#compdef bhyveload
# _bhyveload — FreeBSD bhyveload (load a FreeBSD kernel + supporting modules into a bhyve VM's memory before bhyve(8) is invoked to run it; -c console device, -d disk, -e env var, -h host bootdir, -l line-buffered, -m memsize, -k bootdir, -S secure boot, -s console-stdout; positional vm name required)
# upstream: https://cgit.freebsd.org/src (usr.sbin/bhyveload)
# Flags from FreeBSD usr.sbin/bhyveload/bhyveload.c on tip.

_bhyveload() {
    _arguments \
        '-c+[console device]:dev:_files -g "/dev/tty*"' \
        '-d+[disk image]:file:_files' \
        '*-e+[env var=val]:env:' \
        '-h+[host bootdir]:dir:_files -/' \
        '-k+[bootdir]:dir:_files -/' \
        '-l[line-buffered console]' \
        '-m+[memory size]:size:' \
        '-s[interact via stdin]' \
        '-S[secure boot]' \
        '1:vm name:'
}

_bhyveload "$@"
