#compdef kalliope

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start the kalliope core'
  'gui:run the kalliope GUI'
  'install:install a community resource'
  'uninstall:remove a resource'
  'list:list installed resources'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--brain-file=[brain file]:file:_files -g "*.yml"' \
  '--debug[debug output]' \
  '--no-color[disable color output]' \
  '--no-voice[disable voice output]' \
  '--deaf[start in deaf mode]' \
  '--mute[start muted]' \
  '--run-synapse=[run a synapse]:name:' \
  '--run-order=[run with order]:order:' \
  '--user-id=[user id]:id:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kalliope command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '--git-url=[community repo URL]:url:' && ret=0 ;;
      (uninstall)
        _arguments \
          '--neuron-name=[neuron to remove]:name:' \
          '--stt-name=[STT to remove]:name:' \
          '--tts-name=[TTS to remove]:name:' \
          '--trigger-name=[trigger to remove]:name:' && ret=0 ;;
    esac ;;
esac

return ret
