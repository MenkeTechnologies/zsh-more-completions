#compdef kalliope
# Documentation: https://github.com/kalliope-project/kalliope/blob/master/kalliope/__init__.py
# Reference accessed: 2026-05-19
# Verified: upstream kalliope/__init__.py argparse at the URL above.

# Kalliope voice assistant. Corrected from prior file against the
# argparse source: actions are only (start gui install uninstall);
# removed invented list/help actions and --no-color/--no-voice/
# --mute/--user-id flags; added --signal-name to uninstall;
# version flag is -v/--version.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start the kalliope core'
  'gui:run the kalliope GUI'
  'install:install a community resource'
  'uninstall:remove a resource'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--brain-file=[full path to a brain file]:file:_files -g "*.yml"' \
  '--debug[enable debug output]' \
  '--deaf[start without audio input capability]' \
  '--run-synapse=[name of a synapse to load]:name:' \
  '--run-order=[order to execute]:order:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kalliope command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '--git-url=[git repository URL of the module]:url:' && ret=0 ;;
      (uninstall)
        _arguments \
          '--neuron-name=[neuron to remove]:name:' \
          '--stt-name=[STT to remove]:name:' \
          '--tts-name=[TTS to remove]:name:' \
          '--trigger-name=[trigger to remove]:name:' \
          '--signal-name=[signal to remove]:name:' && ret=0 ;;
    esac ;;
esac

return ret
