#compdef mged
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=mged&sektion=1
# BRL-CAD interactive geometry editor (Multi-device Geometry EDitor)

local ret=1

_arguments -s -S \
  '(- *)'{-h,-\?}'[show brief startup help]' \
  '-a[display manager to auto-attach on start]:display manager:(nu X ogl wgl tk ps plot)' \
  '-b[start as background process]' \
  '-c[start in classic command-line mode]' \
  '-d[X server display to connect to]:display' \
  '-r[open database read-only]' \
  '-x[librt debug level]:level' \
  '-X[libbu debug level]:level' \
  '-v[print version and exit]' \
  '1:database:_files -g "*.g"' \
  '*:mged command:_default' && ret=0

return ret
