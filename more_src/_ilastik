#compdef ilastik run_ilastik.sh
# Documentation: https://www.ilastik.org/documentation/basics/headless
# ilastik: headless interactive learning and segmentation toolkit

local ret=1

_arguments -s \
  '--headless[invoke headless classification mode]' \
  '--project=[path to your trained project file]:project:_files' \
  '--readonly=[open the project in read-only mode]:bool:(0 1 true false)' \
  '--input_axes=[specify axis meaning for datasets]:axes:' \
  '--stack_along=[axis to stack image sequences along]:axis:(c t z)' \
  '--raw_data[path to raw data input]:file:_files' \
  '--prediction_maps[path to probability map input]:file:_files' \
  '--segmentation_image[segmentation image input]:file:_files' \
  '--export_source=[the data to export (Source dropdown option)]:source:' \
  '--output_format=[result file format]:format:(tiff hdf5 png numpy dvid n5)' \
  '--output_filename_format=[path to the output file to write]:format:' \
  '--output_internal_path=[HDF5 dataset name to write to]:path:' \
  '--cutout_subregion=[subregion of the original to operate on]:region:' \
  '--export_dtype=[pixel type to convert results to]:dtype:(uint8 int16 float32)' \
  '--output_axis_order=[transpose storage order of results]:order:' \
  '--pipeline_result_drange=[pipeline result data range before normalization]:min,max:' \
  '--export_drange=[exported data range after normalization]:min,max:' \
  '--table_filename=[export object features to CSV]:file:_files' \
  '--csv-export-file=[file path for object counts CSV]:file:_files' \
  '--export_plugin=[plugin type for export]:plugin:' \
  '--distributed[enable distributed MPI-based processing]' \
  '--distributed-block-roi=[block dimensions to split input data]:roi:' \
  '*:file:_files' && ret=0

return ret
