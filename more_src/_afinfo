#compdef afinfo

local -a arguments

arguments=(
    '-h[Show help]'
    '-b[Brief output (one line per file)]'
    '-r[Show all information about data formats]'
    '-i[Show all info dictionary items]'
    '--info[Show specific info key]:info key'
    '--xml[Output as XML property list]'
    '--json[Output as JSON]'
    '--leaks[Run leaks analysis]'
    '*:audio file:_files -g "*.{aif,aiff,wav,mp3,m4a,aac,caf,flac,alac,au,snd,sd2}"'
)

_arguments -s -S $arguments
