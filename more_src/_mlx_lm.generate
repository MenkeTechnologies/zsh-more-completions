#compdef mlx_lm.generate
# Documentation: https://github.com/ml-explore/mlx-lm/blob/main/mlx_lm/generate.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--model=[model id or local path]:model:' \
  '--trust-remote-code[trust remote code]' \
  '--adapter-path=[LoRA adapter path]:dir:_files -/' \
  '*--extra-eos-token=[extra EOS token(s)]:token:' \
  '--system-prompt=[system prompt]:prompt:' \
  '(-p --prompt)'{-p+,--prompt=}'[text prompt (use - for stdin)]:prompt:' \
  '--prefill-response=[prefill response text]:text:' \
  '(-m --max-tokens)'{-m+,--max-tokens=}'[max generated tokens]:n:' \
  '--temp=[sampling temperature]:f:' \
  '--top-p=[top-p sampling]:f:' \
  '--min-p=[min-p sampling]:f:' \
  '--top-k=[top-k sampling]:n:' \
  '--xtc-probability=[XTC probability]:f:' \
  '--xtc-threshold=[XTC threshold]:f:' \
  '--min-tokens-to-keep=[min tokens to keep]:n:' \
  '--seed=[random seed]:n:' \
  '--ignore-chat-template[do not apply chat template]' \
  '--use-default-chat-template[force default chat template]' \
  '--chat-template-config=[chat template config]:cfg:' \
  '--verbose[verbose output]' \
  '--max-kv-size=[max KV cache size]:n:' \
  '--prompt-cache-file=[prompt cache file]:file:_files' \
  '(-qa --quantize-activations)'{-qa,--quantize-activations}'[quantize activations]' \
  '--kv-bits=[KV cache quantization bits]:n:' \
  '--kv-group-size=[KV cache group size]:n:' \
  '--quantized-kv-start=[quantize KV after step]:n:' \
  '--draft-model=[speculative decoding draft model]:model:' \
  '--num-draft-tokens=[draft tokens per step]:n:' && ret=0

return ret
