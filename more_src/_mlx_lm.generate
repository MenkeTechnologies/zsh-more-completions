#compdef mlx_lm.generate mlx_lm.chat

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--model=[model id or local path]:model:' \
  '--adapter-path=[LoRA adapter path]:dir:_files -/' \
  '--prompt=[text prompt or - for stdin]:prompt:' \
  '--system-prompt=[system prompt]:prompt:' \
  '--max-tokens=[max generated tokens]:n:' \
  '--temp=[sampling temperature]:f:' \
  '--top-p=[top-p sampling]:f:' \
  '--top-k=[top-k sampling]:n:' \
  '--min-p=[min-p sampling]:f:' \
  '--seed=[random seed]:n:' \
  '--repetition-penalty=[repetition penalty]:f:' \
  '--repetition-context-size=[context size for penalty]:n:' \
  '--xtc-probability=[XTC probability]:f:' \
  '--xtc-threshold=[XTC threshold]:f:' \
  '--ignore-chat-template[do not apply chat template]' \
  '--use-default-chat-template[force default chat template]' \
  '--chat-template-args=[chat template kwargs JSON]:json:' \
  '--trust-remote-code[trust remote code]' \
  '--eos-token=[explicit EOS token]:token:' \
  '--prefill-step-size=[prefill step size]:n:' \
  '--draft-model=[speculative decoding draft model]:model:' \
  '--num-draft-tokens=[draft tokens per step]:n:' \
  '--kv-bits=[KV cache quantization bits]:n:(2 3 4 8)' \
  '--kv-group-size=[KV cache group size]:n:' \
  '--quantized-kv-start=[quantize KV after step]:n:' \
  '--max-kv-size=[max kv cache size]:n:' \
  '--cache-limit-gb=[GPU cache limit (GB)]:n:' \
  '--verbose=[verbose output]:bool:(True False)' \
  '--top-logprobs=[show top N logprobs]:n:' \
  '--prompt-cache-file=[prompt cache file]:file:_files' \
  '*::positional:' && ret=0

return ret
