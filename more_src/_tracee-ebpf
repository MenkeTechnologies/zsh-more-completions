#compdef tracee-ebpf
# _tracee-ebpf — Aqua Security Tracee eBPF runtime tracer (Aqua Security, Go); urfave/cli, predecessor to merged `tracee` binary
# upstream: https://github.com/aquasecurity/tracee

_tracee-ebpf() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--trace=+[event filter]:filter:' \
        '-t+[event filter]:filter:' \
        '--filter=+[event filter]:filter:' \
        '-f+[event filter]:filter:' \
        '--output=+[output format/option]:opt:' \
        '-o+[output format/option]:opt:' \
        '--capture=+[capture artifact]:cap:(write read network exec module mem bpf signature)' \
        '-c+[capture artifact]:cap:(write read network exec module mem bpf signature)' \
        '--cache=+[cache options]:opt:(type=mem size=)' \
        '--metrics[enable metrics endpoint]' \
        '-m[enable metrics endpoint]' \
        '--metrics-addr=+[metrics addr]:addr:' \
        '--healthz[enable health endpoint]' \
        '--listen-addr=+[listen addr]:addr:' \
        '--log=+[log option]:opt:(debug info warn error fatal file aggregate)' \
        '--install-path=+[install path]:dir:_files -/' \
        '--containers=+[container option]:opt:' \
        '--cri=+[cri socket]:sock:' \
        '--crs=+[container runtime]:rt:(docker containerd crio podman)' \
        '--blob=+[blob storage]:opt:' \
        '--perf-buffer-size=+[perf buffer size]:n:' \
        '--blob-perf-buffer-size=+[blob perf buffer size]:n:' \
        '--pid-file=+[pid file]:file:_files' \
        '--policy=+[policy file]:file:_files -g "*.yaml *.yml"' \
        '-p+[policy file]:file:_files -g "*.yaml *.yml"' \
        '--scope=+[scope]:str:' \
        '-s+[scope]:str:' \
        '--proctree=+[proctree options]:str:' \
        '--rego=+[rego flag]:str:' \
        '--signatures-dir=+[signatures dir]:dir:_files -/' \
        '*:arg:'
}

_tracee-ebpf "$@"
