#compdef soci
# Documentation: https://github.com/awslabs/soci-snapshotter
# Seekable OCI (SOCI) CLI for lazy-loading container images (awslabs/soci-snapshotter)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    create:"create a SOCI index for an existing image"
    convert:"convert an image and create a SOCI index"
    push:"push a SOCI index and zTOCs to a registry"
    index:"manage SOCI indices"
    ztoc:"manage zTOCs"
    prefetch:"manage prefetch state"
    rebuild_db:"rebuild the local artifacts database"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      create)
        _arguments -s \
          '--span-size[span size]:bytes:' \
          '--min-layer-size[minimum layer size for a zTOC]:bytes:' \
          '(-f --force)'{-f,--force}'[recreate zTOCs even if present]' \
          '--optimizations[enable optimizations]:opt:' \
          '*:image:' && ret=0
        ;;
      convert)
        _arguments -s \
          '--span-size[span size]:bytes:' \
          '--min-layer-size[minimum layer size for a zTOC]:bytes:' \
          '--optimizations[enable optimizations]:opt:' \
          '--all-platforms[convert all platforms]' \
          '--platform[target platform]:platform:' \
          '--standalone[convert OCI layout on disk without containerd]' \
          '--format[output format]:format:(oci-archive oci-dir)' \
          '*:image:' && ret=0
        ;;
      push)
        _arguments -s \
          '--max-concurrent-uploads[max concurrent uploads]:n:' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '*:image:' && ret=0
        ;;
      index)
        _arguments -s \
          '1:subcommand:((info list ls remove rm))' \
          '--ref[image reference]:ref:' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '(-p --platform)'{-p,--platform}'[target platform]:platform:' && ret=0
        ;;
      ztoc)
        _arguments -s \
          '1:subcommand:((info list ls get-file))' \
          '--ztoc-digest[zTOC digest]:digest:' \
          '--image-ref[image reference]:ref:' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '(-o --output)'{-o,--output}'[output file]:file:_files' && ret=0
        ;;
      prefetch)
        _arguments -s \
          '1:subcommand:((list ls info))' \
          '--json[output as JSON]' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
