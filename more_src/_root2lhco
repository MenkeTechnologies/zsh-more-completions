#compdef root2lhco
# Documentation: https://github.com/delphes/delphes/blob/master/converters/root2lhco.cpp
# root2lhco - convert Delphes ROOT output to LHCO format

local ret=1

_arguments -s -S \
  '--jet-branch=[name of the jet branch to use]:branch:(Jet)' \
  '1:input file (ROOT):_files -g "*.root"' \
  '2:output file (LHCO):_files' && ret=0

return ret
