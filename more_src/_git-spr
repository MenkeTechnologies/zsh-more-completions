#compdef git-spr spr
# _git-spr — Stacked Pull Requests on GitHub (ejoffe/spr)
# upstream: https://github.com/ejoffe/spr
# Subcommands & flags from cmd/spr/main.go (urfave/cli v2).

_git-spr() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--detail[show detailed status bits output]' \
        '--profile[show runtime profiling info]' \
        '(-v --verbose)'{-v,--verbose}'[show verbose logging]' \
        '--debug[show runtime debug info]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'status:show status of open pull requests'
                's:alias for status'
                'st:alias for status'
                'sync:synchronize local stack with remote'
                'update:update & create PRs for updated commits'
                'u:alias for update'
                'up:alias for update'
                'fetch:enable fetch (overrides noFetch config)'
                'f:alias for fetch'
                'no-fetch:disable fetch'
                'nf:alias for no-fetch'
                'merge:merge all mergeable PRs'
                'amend:amend a commit in the stack'
                'a:alias for amend'
                'edit:edit a commit in the stack'
                'e:alias for edit'
                'check:run preflight checks'
                'version:show version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                status|s|st) _arguments '(-t --text)'{-t,--text}'[plain text output]' ;;
                update|u|up)
                    _arguments \
                        '(-r --reviewer)*'{-r+,--reviewer=}'[reviewer to add]:user:' \
                        '(-c --count)'{-c+,--count=}'[update N PRs from bottom]:n:' \
                        '(--nr --no-rebase)'{--nr,--no-rebase}'[disable rebasing]'
                    ;;
                merge) _arguments '(-c --count)'{-c+,--count=}'[merge N PRs from bottom]:n:' ;;
                amend|a) _arguments '(-u --update)'{-u,--update}'[run update after amend]' ;;
                edit|e)
                    _arguments \
                        '(-d --done)'{-d,--done}'[finish editing, restore stack]' \
                        '(-u --update)'{-u,--update}'[run update after edit]' \
                        '--abort[abort current edit session]'
                    ;;
            esac
            ;;
    esac
}

_git-spr "$@"
