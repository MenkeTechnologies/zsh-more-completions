#compdef vc-scheduler volcano-scheduler
# _vc-scheduler — Volcano batch scheduler (volcano-sh/volcano)
# upstream: https://github.com/volcano-sh/volcano
# Flags from cmd/scheduler/app/options/options.go on tip.

_vc-scheduler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--master=[apiserver URL override]:url:_urls' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--ca-cert-file=[CA cert file for HTTPS]:file:_files' \
        '--tls-cert-file=[TLS server cert]:file:_files' \
        '--tls-private-key-file=[TLS server key]:file:_files' \
        '*--scheduler-name=[handled scheduler names]:name:' \
        '--scheduler-conf=[scheduler configuration file]:file:_files' \
        '--schedule-period=[scheduling cycle period]:dur:' \
        '--resync-period=[informer resync period]:dur:' \
        '--default-queue=[default queue name]:name:' \
        '--listen-address=[HTTP server bind host\:port]:host\:port:' \
        '--healthz-address=[health-check bind host\:port]:host\:port:' \
        '--priority-class=[enable PriorityClass support]:bool:(true false)' \
        '--kube-api-qps=[Kubernetes API QPS]:f:' \
        '--kube-api-burst=[Kubernetes API burst]:n:' \
        '--minimum-feasible-nodes=[minimum feasible nodes to score]:n:' \
        '--minimum-percentage-nodes-to-find=[minimum % nodes to score]:n:' \
        '--percentage-nodes-to-find=[% nodes to score (<=0 auto)]:n:' \
        '--plugins-dir=[directory containing custom plugins]:dir:_files -/' \
        '--csi-storage[enable CSI storage support]' \
        '--enable-healthz=[enable health check]:bool:(true false)' \
        '--enable-metrics=[enable metrics endpoint]:bool:(true false)' \
        '--enable-pprof=[enable pprof endpoint]:bool:(true false)' \
        '*--node-selector=[label selector for managed nodes (key:value)]:sel:' \
        '--cache-dumper=[enable cache dumper]:bool:(true false)' \
        '--cache-dump-dir=[cache dump JSON directory]:dir:_files -/' \
        '--node-worker-threads=[node-sync worker threads]:n:' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '--leader-elect-resource-namespace=[leader election namespace]:ns:' \
        '-v[klog verbosity level]:n:'
}

_vc-scheduler "$@"
