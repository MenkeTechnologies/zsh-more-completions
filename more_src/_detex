#compdef detex
# Documentation: detex usage (opendetex)
# Source: strip (La)TeX commands from input, leaving plain text.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-v[show program version]' \
    '-c[echo LaTeX \\cite, \\ref, \\pageref values]' \
    '-e+[LaTeX environments to ignore]:env-list:' \
    '(-t)-l[force latex mode]' \
    '-n[do not follow \\input, \\include, \\subfile]' \
    '-r[replace math with noun-verbs-noun for grammar]' \
    '-s[replace control sequences with space]' \
    '(-l)-t[force tex mode]' \
    '-w[word-only output]' \
    '-1[prefix each line with filename and line number]' \
    '*:tex file:_files -g "*.(tex|ltx|sty|cls)"' \
    && ret=0

return ret
