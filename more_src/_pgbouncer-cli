#compdef pgbouncer

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '(-q --quiet)'{-q,--quiet}'[quiet, no log to stdout]' \
  '(-R --reboot)'{-R,--reboot}'[restart with shared sockets]' \
  '(-u --user)'{-u+,--user=}'[run as user]:user:_users' \
  '(-v --verbose)*'{-v,--verbose}'[verbose log]' \
  '(--regservice)--regservice[register Windows service]' \
  '(--unregservice)--unregservice[unregister service]' \
  '*: :_files -g "*.ini"' && ret=0

return ret
