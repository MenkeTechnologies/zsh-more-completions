#compdef dscl

local -a subcommands

subcommands=(
    'read:Read a property from a record'
    'readall:Read all properties from all records'
    'readpl:Read a property list value'
    'list:List records or properties'
    'search:Search for records'
    'create:Create a record or property'
    'append:Append value(s) to a property'
    'merge:Merge value(s) into a property'
    'change:Change a value in a property'
    'delete:Delete a record, property, or value'
    'diff:Compare two records'
    'passwd:Change a password'
    'auth:Authenticate'
    'authonly:Authenticate without changing directory'
    'mcxread:Read MCX settings'
    'mcxset:Set MCX settings'
    'mcxdelete:Delete MCX settings'
)

_arguments -s -S \
    '-p[Prompt for password]' \
    '-u[Authenticate as user]:username' \
    '-P[Authenticate with password]:password' \
    '-f[Target a file path]:file path:_files' \
    '-url[Interpret datasource as URL]' \
    '-q[Quiet mode, no interactive prompt]' \
    '-raw[Don'\''t strip DSLocal default values]' \
    '-plist[Output in plist format]' \
    '1:datasource:(localhost /Search /Local/Default /BSD/local /LDAPv3/127.0.0.1)' \
    '2:subcommand:->subcmd' \
    '*:: :->args' && return

case $state in
    subcmd)
        _describe 'dscl subcommand' subcommands
        ;;
    args)
        case $words[1] in
            read|readall|list|delete|create|append|merge|change|search)
                _arguments \
                    '1:path:(/Users /Groups /Computers /Contacts /Mounts /Networks /Machines /Config)' \
                    '*:property or value'
                ;;
            passwd)
                _arguments \
                    '1:user path' \
                    '2:new password'
                ;;
        esac
        ;;
esac
