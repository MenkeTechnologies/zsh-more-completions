#compdef orte-ps
# Documentation: https://linux.die.net/man/1/orte-ps
# Reference accessed: 2026-05-16
# Verified: Open MPI orte-ps(1) manpage. NOTE: removed in Open MPI 5.x
# (replaced by PRRTE `prte` tools); historical flag set only.
# Removed from prior file: bogus man.archlinux.org search URL.

# orte-ps: Open MPI ORTE process status (legacy)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-j --jobid)'{-j+,--jobid=}'[show state of specific job]:jobid:' \
  '(-n --nodes)'{-n,--nodes}'[display all allocated nodes and states]' \
  '*--gmca[GMCA parameter]:key value:' \
  '*--mca[MCA parameter]:key value:' \
  '--daemon-uri=[ORTE daemon URI]:uri:' && ret=0
return ret
