#compdef zpool-clear
# _zpool-clear — OpenZFS zpool clear (reset the error counters on a pool and optionally on specific devices; -F initiates extreme rewind to a previous transaction group, -n dry-run for -F, -X may roll back further losing recent writes; positional pool then optional devices)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_clear) on tip.

_zpool-clear() {
    _arguments \
        '-F[extreme rewind]' \
        '-n[dry run with -F]' \
        '-X[broader rewind (may lose data)]' \
        '1:pool:' \
        '*:device:'
}

_zpool-clear "$@"
