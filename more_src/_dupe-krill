#compdef dupe-krill
# Documentation: https://github.com/kornelski/dupe-krill
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for dupe-krill (kornelski/dupe-krill, getopts in src/bin.rs).

_arguments -s -S \
  '(- *)'{-h,--help}'[show usage]' \
  '(-d --dry-run)'{-d,--dry-run}'[report duplicates without changing disk]' \
  '(-s --small)'{-s,--small}'[dedupe files smaller than a block]' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress output]' \
  '(-C --reflink)'{-C,--reflink}'[require reflinks only]' \
  '(-c --reflink-or-hardlink)'{-c,--reflink-or-hardlink}'[reflink with hardlink fallback]' \
  '--json[JSON progress/output]' \
  '*-e[exclude filename (exact match, repeatable)]:filename:' \
  '*:path:_files -/'
