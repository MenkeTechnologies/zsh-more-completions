#compdef pgflag
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/pgflag.html
# Display waterfall plots of uv data and allow flagging

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'line=[line keyword]:line:' \
  'select=[select keyword]:select:' \
  'stokes=[stokes keyword]:stokes:' \
  'device=[device keyword]:device:' \
  'device2=[device2 keyword]:device2:' \
  'device3=[device3 keyword]:device3:' \
  'mode=[mode keyword]:mode:' \
  'flagpar=[flagpar keyword]:flagpar:' \
  'patch=[patch keyword]:patch:' \
  'log=[log keyword]:log:' \
  'command=[command keyword]:command:' \
  'options=[options keyword]:options:' \
  '*:visibility dataset:_files' && ret=0

return ret
