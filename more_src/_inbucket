#compdef inbucket
# Documentation: https://github.com/inbucket/inbucket
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# inbucket is primarily configured via environment variables; the binary
# accepts an optional config file argument and -help/-version flags.

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '*:config file:_files'
