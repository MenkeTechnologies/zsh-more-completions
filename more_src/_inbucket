#compdef inbucket
# Documentation: https://man.archlinux.org/search?q=inbucket
# Reference accessed: 2026-05-16

_arguments -s \
  '-pidfile=[pid file]:file:_files' \
  '-logfile=[log file]:file:_files' \
  '-logjson[JSON logs]' \
  '-netdebug[dump SMTP/POP3 traffic]' \
  '(- *)-help[show help]' \
  '(- *)-version[show version]'
