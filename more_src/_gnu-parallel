#compdef gnu-parallel

# Zsh completion for GNU parallel

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:number' \
  '(-k --keep-order)'{-k,--keep-order}'[keep sequence of output same as input]' \
  '--dry-run[print command but do not run]' \
  '(-v --verbose)'{-v,--verbose}'[print the job before running]' \
  '--progress[show progress]' \
  '--bar[show progress bar]' \
  '--eta[show estimated time of arrival]' \
  '(-n --max-args)'{-n,--max-args}'[use at most N arguments per command line]:max args' \
  '(-N)'-N'[use at most N arguments per command line from each input source]:max args' \
  '(-L --max-lines)'{-L,--max-lines}'[use at most N lines per command line]:max lines' \
  '-0[use NUL as delimiter]' \
  '(-d --delimiter)'{-d,--delimiter}'[input items terminated by delim]:delimiter' \
  '-E[set eof string]:eof string' \
  '(-i --replace)'{-i,--replace}'[replace {} with input line]:replace string' \
  '(-I)'-I'[replace string]:replace string' \
  '--colsep[column separator for input]:separator' \
  '--header[use first line as header]:header' \
  '(-a --arg-file)'{-a,--arg-file}'[use file as input source]:file:_files' \
  '(-S --sshlogin)'{-S,--sshlogin}'[distribute to remote computers]:sshlogin' \
  '--sshloginfile[file with sshlogins]:file:_files' \
  '--slf[same as --sshloginfile]:file:_files' \
  '--trc[transfer, return, cleanup]:file:_files' \
  '--transfer[transfer files to remote]' \
  '--return[return files from remote]:file:_files' \
  '--cleanup[remove transferred files on remote]' \
  '--retries[number of retries]:retries' \
  '--timeout[set timeout per job]:duration' \
  '--memfree[minimum free memory]:size' \
  '--load[max load before starting new job]:load' \
  '--noswap[do not start job if swap is in use]' \
  '--halt[when to halt]:when:(now soon 1 2)' \
  '--resume[resume from last unfinished job]' \
  '--resume-failed[retry failed jobs and resume]' \
  '--joblog[logfile for completed jobs]:file:_files' \
  '--results[save output in files]:dir:_files -/' \
  '--tmpdir[directory for temporary files]:dir:_files -/' \
  '--files[save output to files]' \
  '--pipe[pipe stdin to commands]' \
  '--pipepart[pipe parts of physical file]' \
  '--block[block size for --pipe]:size' \
  '--recstart[record start string]:string' \
  '--recend[record end string]:string' \
  '--group[group output]' \
  '--ungroup[output ungrouped]' \
  '--linebuffer[line buffer output]' \
  '--tag[tag lines with input]' \
  '--tagstring[tag with string]:string' \
  '--onall[run on all sshlogins]' \
  '--nonall[run on all sshlogins with no arguments]' \
  '--workdir[set working directory]:dir:_files -/' \
  '--nice[set niceness]:niceness' \
  '--semaphore[work as a counting semaphore]' \
  '--semaphorename[name of semaphore]:name' \
  '--semaphoretimeout[timeout for semaphore]:seconds' \
  '--bg[run in background]' \
  '--wait[wait for semaphore]' \
  '--xargs[multiple arguments with context replace]' \
  '*::command:_command_names'
