#compdef intellij idea
# _intellij — JetBrains IntelliJ IDEA CLI entrypoint (JetBrains, Java/Kotlin); custom argparse
# upstream: https://github.com/JetBrains/intellij-community

_intellij() {
    local -a sub=(
        'diff:open diff viewer'
        'merge:open merge viewer'
        'format:run code style formatter'
        'inspect:run code inspection'
        'install:install plugin'
        'installPlugins:install plugins'
        'cwm-host:code with me host'
        'cwm-guest:code with me guest'
        'remoteDevHost:remote dev host'
        'remoteDevStatus:remote dev status'
        'invalidateCaches:invalidate caches'
        'qodana:run qodana inspection'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--wait[wait until window closes]' \
        '-w[wait until window closes]' \
        '--line=+[goto line]:n:' \
        '-l+[goto line]:n:' \
        '--column=+[goto column]:n:' \
        '-c+[goto column]:n:' \
        '--new-window[force new window]' \
        '-n[force new window]' \
        '1:subcommand-or-file:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'intellij subcommand' sub
            _files ;;
        args)
            case $words[1] in
                diff|merge) _arguments '*:file:_files' ;;
                format) _arguments \
                    '--settings=+[code style settings file]:file:_files -g "*.xml"' \
                    '-s+[code style settings file]:file:_files -g "*.xml"' \
                    '--mask=+[file mask]:str:' \
                    '-m+[file mask]:str:' \
                    '--recursive[recursive]' \
                    '-r[recursive]' \
                    '--charset=+[charset]:charset:' \
                    '-c+[charset]:charset:' \
                    '--dry[dry run]' \
                    '-d[dry run]' \
                    '*:file:_files' ;;
                inspect) _arguments \
                    '1:project:_files -/' \
                    '2:profile:_files -g "*.xml"' \
                    '3:output-dir:_files -/' \
                    '--verbosity=+[verbosity]:v:(0 1 2 3)' \
                    '-v+[verbosity]:v:(0 1 2 3)' \
                    '--changes[only changed]' \
                    '-changes[only changed]' \
                    '--scope=+[scope]:str:' \
                    '-scope+[scope]:str:' ;;
                install|installPlugins) _arguments '*:plugin-id:' ;;
                qodana) _arguments \
                    '1:project:_files -/' \
                    '2:output:_files -/' ;;
                remoteDevHost|remoteDevStatus|cwm-host|cwm-guest) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_intellij "$@"
