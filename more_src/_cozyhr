#compdef cozyhr
# Documentation: https://man.archlinux.org/search?q=cozyhr
# Reference accessed: 2026-05-16

# cozystack/cozyhr — main.go cobra (v1.6.x)

local curcontext="$curcontext" state line ret=1
local -a pub

pub=(
  '(- *)'{-h,--help}'[help]'
  '--version[print version]'
  '--kubeconfig=[kubeconfig path]:file:_files'
  '--context=[kubectl context name]:context:'
  '(-n)'{-n+,--namespace=}'[namespace override]:namespace:'
  '(-C)'{-C+,--working-directory=}'[Helm chart directory]:directory:_files -/'
)

_arguments -C -s -S \
  $pub \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a sub=(
      'show:render manifests like helm template'
      'apply:upgrade/install release and sync Flux status'
      'diff:diff live vs desired manifests'
      'suspend:suspend Flux HelmRelease'
      'resume:resume Flux HelmRelease'
      'delete:uninstall Helm release'
      'list:list HelmReleases'
      'ls:list HelmReleases'
      'get:describe HelmReleases'
      'completion:emit shell completion script'
      'reconcile:annotate for Flux reconciliation'
      'version:print version string'
    )
    _describe -t commands 'cozyhr command' sub && ret=0
    ;;
  (args)
    local -a extra
    case $line[1] in
      (show)
        extra=(
          --plain'[render without querying HelmRelease values]'
          '*'{-s+,--show-only=}'[template glob like helm --show-only]:glob:'
          '*'{-f+,--values=}'[extra values YAML]:file:_files'
        )
        _arguments -s -S $pub $extra '1:Helm release:' && ret=0
        ;;
      (apply)
        extra=(
          --plain'[install without querying HelmRelease values]'
          --resume'[clear spec.suspend after success]'
          --take-ownership'[adopt existing resources]'
          '*'{-f+,--values=}'[extra values YAML]:file:_files'
        )
        _arguments -s -S $pub $extra '1:Helm release:' && ret=0
        ;;
      (diff)
        extra=(
          --plain'[render without querying HelmRelease]'
          '*'{-f+,--values=}'[extra values YAML]:file:_files'
        )
        _arguments -s -S $pub $extra '1:Helm release:' && ret=0
        ;;
      (suspend|resume|delete)
        _arguments -s -S $pub '1:Helm release:' && ret=0
        ;;
      (reconcile)
        extra=(
          --with-source'[reconcile chart source before HelmRelease]'
          --force'[force one-off upgrade via Flux]'
        )
        _arguments -s -S $pub $extra '1:Helm release:' && ret=0
        ;;
      (list|ls|get)
        extra=(
          '(-A)'{-A,--all-namespaces}'[all namespaces]'
          '(-o)'{-o+,--output=}'[table columns/json/yaml/...]:output:'
        )
        _arguments -s -S $pub $extra '*:Helm release:' && ret=0
        ;;
      (completion)
        _arguments -s -S $pub '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (version)
        _arguments -s -S $pub && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
