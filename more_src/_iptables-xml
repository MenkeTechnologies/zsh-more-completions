#compdef iptables-xml
# _iptables-xml — netfilter iptables-xml (convert iptables-save output into a structured XML representation suitable for diffing or programmatic edits; -c include counters, -v verbose, --version; positional argument is the iptables-save file (default stdin))
# upstream: https://git.netfilter.org/iptables
# Flags from netfilter/iptables iptables/iptables-xml.c on tip.

_iptables-xml() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c[include counters]' \
        '-v[verbose]' \
        '*:input file:_files'
}

_iptables-xml "$@"
