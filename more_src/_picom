#compdef picom

# Zsh completion for picom - X compositor (fork of compton)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--config=[read configuration from file]:file:_files' \
  '(-d --display)'{-d,--display}'[display to be managed]:display' \
  '(-r --shadow-radius)'{-r,--shadow-radius}'[blur radius for shadows]:radius' \
  '(-o --shadow-opacity)'{-o,--shadow-opacity}'[opacity of shadows]:opacity (0.0-1.0)' \
  '(-l --shadow-offset-x)'{-l,--shadow-offset-x}'[left offset for shadows]:pixels' \
  '(-t --shadow-offset-y)'{-t,--shadow-offset-y}'[top offset for shadows]:pixels' \
  '--shadow-red=[red color value of shadow]:value (0.0-1.0)' \
  '--shadow-green=[green color value of shadow]:value (0.0-1.0)' \
  '--shadow-blue=[blue color value of shadow]:value (0.0-1.0)' \
  '--shadow-color=[color of shadow]:color (#RRGGBB)' \
  '--shadow-exclude=[exclude conditions for shadows]:condition' \
  '(-c --shadow)'{-c,--shadow}'[enable client-side shadows on windows]' \
  '(-C --no-dock-shadow)'{-C,--no-dock-shadow}'[do not draw shadows on dock/panel windows]' \
  '(-G --no-dnd-shadow)'{-G,--no-dnd-shadow}'[do not draw shadows on DND windows]' \
  '(-m --menu-opacity)'{-m,--menu-opacity}'[opacity of dropdown menus and popup menus]:opacity (0.0-1.0)' \
  '(-f --fading)'{-f,--fading}'[fade windows during opacity changes]' \
  '(-F)'-F'[fade windows during open/close]' \
  '(-i --inactive-opacity)'{-i,--inactive-opacity}'[opacity of inactive windows]:opacity (0.0-1.0)' \
  '(-e --frame-opacity)'{-e,--frame-opacity}'[opacity of window titlebars and borders]:opacity (0.0-1.0)' \
  '--inactive-opacity-override[let inactive opacity set by -i override _NET_WM_WINDOW_OPACITY]' \
  '--active-opacity=[opacity of active windows]:opacity (0.0-1.0)' \
  '--inactive-dim=[dim inactive windows]:value (0.0-1.0)' \
  '--corner-radius=[sets the radius of rounded window corners]:radius' \
  '--rounded-corners-exclude=[exclude conditions for rounded corners]:condition' \
  '--mark-wmwin-focused[try to detect WM windows and mark them as focused]' \
  '--mark-ovredir-focused[mark override-redirect windows as focused]' \
  '--no-fading-openclose[do not fade on window open/close]' \
  '--no-fading-destroyed-argb[do not fade destroyed ARGB windows]' \
  '--fade-in-step=[opacity change between steps while fading in]:value (0.01-1.0)' \
  '--fade-out-step=[opacity change between steps while fading out]:value (0.01-1.0)' \
  '(-D --fade-delta)'{-D,--fade-delta}'[time between steps in fading]:milliseconds' \
  '--fade-exclude=[exclude conditions for fading]:condition' \
  '--opacity-rule=[set opacity for windows matching condition]:opacity\:condition' \
  '(-I --fade-in-step)'{-I,--fade-in-step}'[opacity change between steps while fading in]:value' \
  '(-O --fade-out-step)'{-O,--fade-out-step}'[opacity change between steps while fading out]:value' \
  '(-S --shadow-offset)'-S'[set shadow offset]' \
  '--detect-rounded-corners[detect rounded corners]' \
  '--detect-client-opacity[detect _NET_WM_WINDOW_OPACITY on client windows]' \
  '--vsync[enable VSync]' \
  '--use-ewmh-active-win[use EWMH _NET_ACTIVE_WINDOW to determine active window]' \
  '--unredir-if-possible[unredirect all windows if a full-screen opaque window is detected]' \
  '--unredir-if-possible-delay=[delay before unredirecting]:milliseconds' \
  '--unredir-if-possible-exclude=[conditions to not unredirect]:condition' \
  '--focus-exclude=[conditions for always-focused windows]:condition' \
  '--detect-transient[use WM_TRANSIENT_FOR to group windows]' \
  '--detect-client-leader[use WM_CLIENT_LEADER to group windows]' \
  '--blur-method=[blur method]:method:(none gaussian box kernel dual_kawase)' \
  '--blur-size=[blur radius]:size' \
  '--blur-deviation=[standard deviation for Gaussian blur]:deviation' \
  '--blur-strength=[blur strength for dual_kawase]:strength (1-20)' \
  '--blur-kern=[specify blur convolution kernel]:kernel' \
  '--blur-background[blur background of semi-transparent windows]' \
  '--blur-background-frame[blur background of windows when frame is not opaque]' \
  '--blur-background-fixed[use fixed blur strength]' \
  '--blur-background-exclude=[exclude conditions for background blur]:condition' \
  '--daemon[daemonize process (fork to background)]' \
  '--dbus[enable D-Bus support]' \
  '--no-ewmh-fullscreen[do not use EWMH to detect fullscreen windows]' \
  '--max-brightness=[dim windows brighter than this]:value (0.0-1.0)' \
  '--transparent-clipping[make transparent parts of windows clip other windows]' \
  '--log-level=[set log level]:level:(trace debug info warn error)' \
  '--log-file=[set log file]:file:_files' \
  '--show-all-xerrors[show all X errors for debugging]' \
  '--no-stacking[disable stacking]' \
  '--benchmark=[benchmark mode - render specified number of frames]:frames' \
  '--benchmark-wid=[specify window id for benchmark]:window id' \
  '--backend=[choose backend]:backend:(xrender glx egl)' \
  '--force-win-blend[force all windows to be painted with blending]' \
  '--no-use-damage[disable damage information to render full screen every time]' \
  '--xrender-sync-fence[use X Sync fence after each draw call]' \
  '--glx-no-stencil[do not use stencil buffer (GLX)]' \
  '--glx-no-rebind-pixmap[do not rebind pixmap on window damage (GLX)]' \
  '--window-shader-fg=[GLSL fragment shader for rendering windows]:file:_files' \
  '--write-pid-path=[write process ID to file]:file:_files' \
  '--version[show version number]' \
  '(-h --help)'{-h,--help}'[show this help]' && ret=0

return ret
