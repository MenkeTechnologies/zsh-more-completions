#compdef a2jmidi-bridge
# Documentation: https://man.archlinux.org/search?q=a2jmidi-bridge
# Reference accessed: 2026-05-16

# a2jmidi-bridge: bridge ALSA MIDI to a single JACK MIDI port (legacy)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-n[client name]:name:' \
  '--name=[client name]:name:' \
  '*::a2jmidi-bridge args:_files' && ret=0
return ret
