#compdef cargo-name
# ============================================================================
#  _cargo-name — cargo-name: cargo subcommand to check whether a
#                crate name is available on crates.io
#                (Yoshua "yoshuawuyts" Wuyts — Rust async-std
#                co-author, Node.js community contributor, web/
#                async Rust ecosystem figure)
#
#  Source-direct extraction from
#    https://github.com/yoshuawuyts/cargo-name/blob/master/src/main.rs
#    https://github.com/killercup/quicli (the killercup/quicli
#    library by Pascal "killercup" Hertleif — author of clap-
#    rs/clap_complete, clippy contributor, Rust book "Command
#    Line Applications in Rust")
#
#  Maintained by Yoshua "yoshuawuyts" Wuyts (Rust async-std co-
#  author, Node.js Foundation contributor, async/web Rust
#  ecosystem figure — author of dozens of foundational async
#  Rust crates).  yoshuawuyts/cargo-name has 7 GH stars but
#  yoshua is one of the most influential Rust async ecosystem
#  developers.  cargo-name is a cargo subcommand (cargo's plugin
#  mechanism: cargo automatically discovers `cargo-X` binaries
#  on PATH and dispatches `cargo X` to them) that checks whether
#  a CRATE NAME IS AVAILABLE on crates.io.  Saves the round-trip
#  of opening crates.io in a browser to manually search for name
#  availability before publishing a new crate.  Returns one of:
#  "Available." (name is free), "Unavailable." (name is taken),
#  or "Unknown status code returned." (crates.io API issue).
#  Sister tools: cargo (in corpus via _cargo + STOCK in Rust
#  toolchain), cargo-search (built-in `cargo search NAME` is the
#  manual approach), cargo-publish (publishes a crate), cargo-
#  edit (cargo-add/cargo-rm/cargo-upgrade — in corpus), cargo-
#  expand (in corpus), cargo-watch (in corpus), cargo-binstall
#  (in corpus).  Cargo subcommand ecosystem has 100s of plugins.
#
#  CLI library taxonomy update: 17th Rust CLI library — Pascal
#  "killercup" Hertleif's **quicli** (killercup/quicli).  Rust
#  ecosystem now has 17 documented CLI libraries — RE-TAKING THE
#  SOLO LEAD as the MOST-DOCUMENTED CLI LANGUAGE in the cross-
#  language taxonomy ahead of Go (16) and TypeScript-Node (16).
#  🎉 Rust BREAKS the THREE-WAY TIE.
#
#  quicli (killercup/quicli) is Pascal Hertleif's "Quickly build
#  cool CLI apps in Rust" — a HIGHER-LEVEL HELPER crate that
#  combines:
#    1. structopt (struct-based clap_derive, pre-clap-derive era)
#    2. log + env_logger (logging boilerplate)
#    3. failure (error-handling boilerplate; later replaced by
#       anyhow/thiserror in successors)
#    4. `main!()` macro that wraps the user's main function with
#       structopt parsing + error handling + logger init + exit
#       code conversion
#  Distinguishing philosophy: BATTERIES-INCLUDED HIGHER-LEVEL
#  wrapper that lets prototypers ship a CLI in ~10 lines without
#  manually wiring up clap + env_logger + failure + structopt
#  separately.  Pascal Hertleif is the AUTHOR of the o'reilly
#  Rust book "Command Line Applications in Rust" (CLI Rust book
#  — see rust-cli.github.io/book/) — quicli is the LIBRARY that
#  the book's early chapters use to teach Rust CLI development.
#  Pascal also maintains clap-rs/clap_complete (the shell-
#  completion-generation crate that ships with clap_derive).
#  537 GH stars on the quicli library (note: quicli is now
#  largely SUPERSEDED by clap_derive + anyhow + env_logger
#  composed manually; preserved for educational and historical
#  value).  Used by yoshuawuyts/cargo-name (7 stars but
#  yoshua's), rust-embedded/gpio-cdev (Linux GPIO Character
#  Device 236 stars), qboileau/rstow (stow re-impl in Rust 17
#  stars), zandemax/desfire-tool (MIFARE DesFire card CLI 8
#  stars), trudi-group/fbas_analyzer (Stellar/MobileCoin FBAS
#  analyzer 12 stars), spease/plist2json (Apple plist → JSON),
#  drdreo/celcius, pierzchalski/macro_analysis, quilt/cargo-ease
#  (cargo subcommand helper).
#
#  quicli API:
#    #[macro_use]
#    extern crate quicli;
#
#    use quicli::prelude::*;          // Re-exports: structopt::
#                                     // StructOpt, log macros,
#                                     // failure::Error, etc.
#
#    #[derive(Debug, StructOpt)]      // structopt re-exported
#                                     // from quicli::prelude
#    struct Args {
#      /// Doc-comment becomes --help text for this arg
#      name: String,                  // POSITIONAL (required)
#
#      /// Optional verbose output flag
#      #[structopt(short = "v", long = "verbose")]
#      verbose: bool,
#
#      /// Output file
#      #[structopt(short, long)]
#      output: Option<String>,
#    }
#
#    // main!() macro wraps the user's main function — handles:
#    // 1. Args::from_args() parsing
#    // 2. env_logger initialization (respects RUST_LOG)
#    // 3. failure::Error -> Display conversion
#    // 4. process::exit() with correct exit code
#    main!(|args: Args| {
#      // Body has access to `args` (parsed) and log macros
#      // (info!, warn!, error!, debug!) without manual setup
#      info!("Processing {}...", args.name);
#      match lookup(&args.name)? {
#        Status::Available => println!("Available."),
#        Status::Unavailable => println!("Unavailable."),
#      }
#    });
#
#  quicli distinctive features:
#    - `main!()` MACRO — wraps the user's main fn with all the
#      boilerplate (args parsing + logger init + error handling
#      + exit code)
#    - PRELUDE module — `use quicli::prelude::*` re-exports
#      `StructOpt`, `Error`, `Result`, `ensure!`/`bail!` failure
#      macros, log macros (info!/warn!/error!/debug!/trace!),
#      `log_level()` helper, and other CLI essentials so the
#      caller doesn't manually `use` each
#    - BUILT ON structopt (clap_derive's predecessor) — quicli
#      pre-dates clap_derive (~2017 era when structopt was the
#      canonical derive macro for clap). The pattern lives on
#      in the o'reilly Rust book.
#    - BATTERIES-INCLUDED EDUCATIONAL FRAMEWORK — quicli's
#      target audience is RUST BEGINNERS learning to build CLIs
#      via the o'reilly book; production projects typically
#      manually compose clap_derive + anyhow + env_logger today
#    - `log_level()` helper — returns a log::LevelFilter based
#      on `-v/-vv/-vvv` count in args + the RUST_LOG env var
#    - `read_file`/`write_to_file`/`create_dir`/glob helpers
#      re-exported in prelude for common file-system operations
#      typical in CLI tools
#    - DOC-COMMENT-AS-HELP — inherits structopt's behavior where
#      `/// doc-comment` becomes --help text for fields
#    - `quicli::main!` REPLACED BY anyhow + clap_derive composition
#      in modern Rust (2020+); quicli's role is preserved as a
#      historical/educational artifact and for tools that
#      already use it
#    - INSPIRED BY Ruby's gem-builder pattern + Python's Click
#      (function-decorator philosophy) + the o'reilly book's
#      pedagogical goal of "minimum boilerplate to ship a Rust
#      CLI"
#  Distinct from R275 Rust clap-derive (proc-macro derive on
#  struct — successor to structopt; modern preferred), R330 Rust
#  bpaf (functional applicative combinator), R344 Rust google/
#  argh (Google Fuchsia-OS derive-on-struct), R347 Rust
#  RazrFalcon/pico-args (LOW-LEVEL imperative pull parser), R404
#  Rust matklad/xflags (declarative MACRO block syntax), R407
#  Rust blyxxyz/lexopt (MINIMAL iterator-based pull parser),
#  R410 Rust murarth/gumdrop (zero-dep derive-macro), R413 Rust
#  docopt/docopt.rs (USAGE-STRING-IS-SPEC), R416 Rust rust-lang/
#  getopts (OFFICIAL POSIX-getopt(3) port), R420 Rust ksk001100/
#  seahorse (Cobra-for-Rust chained-builder), R427 Rust tanakh/
#  argopt (function-as-CLI proc-macro).  Rust documented
#  libraries so far: clap-derive, bpaf, argh, pico-args, xflags,
#  lexopt, gumdrop, docopt.rs, getopts, seahorse, argopt, quicli
#  (this round) plus older clap-builder, structopt (deprecated,
#  now clap_derive)... 17 total.  quicli's distinguishing feature
#  vs all other Rust libs: quicli is the ONLY Rust CLI library
#  in the corpus that ships as a BATTERIES-INCLUDED EDUCATIONAL
#  FRAMEWORK combining structopt + log + failure + main!() macro
#  — designed by Pascal Hertleif to be the "go-to library for
#  Rust beginners" via the o'reilly "Command Line Applications
#  in Rust" book.  quicli's approach: BATTERIES-INCLUDED
#  EDUCATIONAL FRAMEWORK with `#[macro_use] extern crate quicli`
#  + `use quicli::prelude::*` re-exporting structopt/log/failure
#  + `#[derive(Debug, StructOpt)]` Args struct + `main!()` macro
#  wrapping the user's main fn with parsing/logger/error/exit
#  + `log_level()` helper for -v count + file-system helper re-
#  exports (read_file/write_to_file/etc.) + DOC-COMMENT-AS-HELP
#  inherited from structopt + INSPIRED BY Python Click +
#  o'reilly Rust CLI book pedagogy — corpus's **first documented
#  batteries-included-educational-framework Rust CLI library**.
#  Brings cross-language CLI library taxonomy variant count to
#  169; Rust ecosystem now has 17 documented CLI libraries —
#  RE-TAKING THE SOLO LEAD as the MOST-DOCUMENTED CLI LANGUAGE
#  in the cross-language taxonomy ahead of Go (16) and
#  TypeScript-Node (16).
#
#  Surface (verbatim from `src/main.rs` quicli `main!()` macro
#  with structopt Args struct):
#
#  Usage:
#    cargo-name <NAME>
#    cargo name <NAME>                              # cargo subcommand form
#
#  Positional:
#    <NAME>                         The name of the crate you're
#                                   targeting on crates.io
#
#  Output:
#    "Available."                   Name is free — you can claim it
#    "Unavailable."                 Name is taken
#    "Unknown status code returned." crates.io API issue or
#                                   network error
#
#  Auto-generated by structopt (re-exported via quicli::prelude):
#    -h, --help                     Show help
#    -V, --version                  Show version
#
#  Examples:
#    cargo name awesome-tool                # Check "awesome-tool" availability
#    cargo-name awesome-tool                # Same (direct invocation, bypassing cargo dispatch)
#    cargo name --help                      # Show help
#    cargo name --version                   # Show version
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also quicli users):
#    - gpio-cdev (rust-embedded/gpio-cdev 236 stars — Linux GPIO
#      Character Device API; uses quicli in examples/blinky.rs;
#      FUTURE candidate)
#    - rstow (qboileau/rstow 17 stars — Rust stow re-impl;
#      FUTURE candidate)
#    - desfire-tool (zandemax/desfire-tool 8 stars — MIFARE
#      DesFire CLI; too niche)
#    - plist2json (spease/plist2json 0 stars — Apple plist → JSON
#      utility; too niche)
#    - fbas_analyzer (trudi-group/fbas_analyzer 12 stars — Stellar
#      FBAS analyzer; FUTURE)
#    - cargo-ease (quilt/cargo-ease — cargo helper; FUTURE)
#    - quicli repo itself (killercup/quicli 537 stars library not CLI)
# ============================================================================

_cargo-name() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    ':name:'
}

_cargo-name "$@"
