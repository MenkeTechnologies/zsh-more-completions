#compdef mii-tool
# _miitool — net-tools mii-tool (read/write MII PHY status of an Ethernet device: link speed, duplex, autoneg, advertised modes; -r restart neg, -w watch link, -F force mode, -A advertise modes)
# upstream: https://github.com/ecki/net-tools
# Flags from net-tools mii-tool.c on tip.

_mii-tool() {
    _arguments \
        '-v[verbose]' \
        '-V[show version]' \
        '-R[reset PHY]' \
        '-r[restart autonegotiation]' \
        '-w[watch link state]' \
        '-l[log to syslog]' \
        '-F+[force mode]:mode:(100baseTx-FD 100baseTx-HD 10baseT-FD 10baseT-HD)' \
        '-A+[advertise modes (comma-sep)]:modes:(100baseT4 100baseTx-FD 100baseTx-HD 10baseT-FD 10baseT-HD)' \
        '*:interface:_net_interfaces'
}

_mii-tool "$@"
