#compdef darwin-rebuild

# Zsh completion for darwin-rebuild - nix-darwin system rebuild tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'switch:build and activate the new configuration'
  'activate:activate the configuration'
  'build:build the new configuration'
  'changelog:show the nix-darwin changelog'
  'check:build and run the checks for the new configuration'
  'edit:edit the configuration'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--flake[use the specified flake]:flake:' \
  '(-I)-I+[add path to nix expression search path]:path:_files -/' \
  '--arg[pass argument to the nix-darwin expression]:name value:' \
  '--argstr[pass string argument]:name value:' \
  '--option[set a nix configuration option]:name value:' \
  '--show-trace[print a stack trace upon error]' \
  '--impure[allow access to mutable paths and repositories]' \
  '--no-link[do not create symlinks to the build results]' \
  '--keep-going[keep going in case of failed builds]' \
  '--keep-failed[keep temporary directories of failed builds]' \
  '--fallback[fall back on building from source if binary substitution fails]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'darwin-rebuild command' commands && ret=0
    ;;
esac

return ret
