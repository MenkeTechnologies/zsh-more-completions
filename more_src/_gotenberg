#compdef gotenberg
# Documentation: https://gotenberg.dev/docs/configuration
# Gotenberg - API for converting documents to PDF

local ret=1

_arguments -s -S \
  '--api-port=[server port]:port' \
  '--api-port-from-env=[read port from env var]:env' \
  '--api-bind-ip=[bind IP address]:ip' \
  '--api-tls-cert-file=[TLS certificate file]:file:_files' \
  '--api-tls-key-file=[TLS key file]:file:_files' \
  '--api-start-timeout=[server start timeout]:duration' \
  '--api-timeout=[request timeout]:duration' \
  '--api-body-limit=[request body size limit]:limit' \
  '--api-root-path=[base path for routes]:path' \
  '--api-correlation-id-header=[correlation id header name]:header' \
  '--api-enable-basic-auth[enable basic authentication]' \
  '--api-download-from-allow-list=[allowed download URL regex]:regex' \
  '--api-download-from-deny-list=[denied download URL regex]:regex' \
  '--api-download-from-deny-private-ips[deny downloads from private IPs]' \
  '--api-download-from-deny-public-ips[deny downloads from public IPs]' \
  '--api-download-from-max-retry=[max download retries]:n' \
  '--api-disable-download-from[disable download-from feature]' \
  '--api-disable-health-check-route-telemetry[disable health route telemetry]' \
  '--api-disable-root-route-telemetry[disable root route telemetry]' \
  '--api-disable-debug-route-telemetry[disable debug route telemetry]' \
  '--api-disable-version-route-telemetry[disable version route telemetry]' \
  '--api-enable-debug-route[enable debug route]' \
  '--chromium-restart-after=[restart after N conversions]:n' \
  '--chromium-max-queue-size=[max queue size]:n' \
  '--chromium-max-concurrency=[max concurrent conversions]:n' \
  '--chromium-auto-start[start Chromium on startup]' \
  '--chromium-start-timeout=[Chromium start timeout]:duration' \
  '--chromium-idle-shutdown-timeout=[idle shutdown timeout]:duration' \
  '--chromium-allow-file-access-from-files[allow file access from files]' \
  '--chromium-allow-insecure-localhost[allow insecure localhost]' \
  '--chromium-allow-list=[allowed URL regex]:regex' \
  '--chromium-deny-list=[denied URL regex]:regex' \
  '--chromium-deny-private-ips[deny private IPs]' \
  '--chromium-deny-public-ips[deny public IPs]' \
  '--chromium-ignore-certificate-errors[ignore certificate errors]' \
  '--chromium-disable-web-security[disable web security]' \
  '--chromium-host-resolver-rules=[host resolver rules]:rules' \
  '--chromium-proxy-server=[proxy server]:server' \
  '--chromium-clear-cache[clear cache before conversion]' \
  '--chromium-clear-cookies[clear cookies before conversion]' \
  '--chromium-disable-javascript[disable JavaScript]' \
  '--chromium-disable-routes[disable Chromium routes]' \
  '--log-std-format=[log output format]:format:(text json)' \
  '--log-level=[log level]:level:(error warn info debug)' \
  '--log-fields-prefix=[prefix for log fields]:prefix' \
  '--log-std-enable-gcp-fields[enable GCP log fields]' \
  '--log-std-level-case=[log level case]:case:(upper lower)' \
  '--gotenberg-graceful-shutdown-duration=[graceful shutdown duration]:duration' \
  '--gotenberg-hide-banner[hide startup banner]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
