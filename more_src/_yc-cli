#compdef yc
# _yc-cli — Yandex Cloud CLI (Yandex Cloud, Go); manage Yandex Cloud resources from the terminal
# upstream: https://github.com/yandex-cloud/yc

_yc-cli() {
    local -a sub=(
        'application-load-balancer:L7 ALB'
        'audit-trails:Audit Trails'
        'billing:billing'
        'cdn:Content Delivery Network'
        'certificate-manager:Certificate Manager'
        'compute:Compute Cloud'
        'config:configure CLI'
        'container:Container Registry / Serverless Containers'
        'cdn-resource:CDN resources'
        'cloud-router:Cloud Router'
        'completion:print shell completion'
        'data-proc:Data Proc'
        'dataproc:alias for data-proc'
        'datasphere:DataSphere'
        'dataspheres:alias for datasphere'
        'datatransfer:Data Transfer'
        'dlqs:Message Queue'
        'dns:Cloud DNS'
        'dataspheres:DataSphere'
        'dataspheres:DataSphere'
        'function:Cloud Functions'
        'helm-chart:Helm chart in container registry'
        'help:show help'
        'iam:IAM commands'
        'init:initialize CLI'
        'iot:IoT Core'
        'kms:Key Management Service'
        'kubernetes:Managed Kubernetes'
        'load-balancer:Network LB'
        'load-testing:Load Testing'
        'lockbox:Lockbox'
        'logging:Cloud Logging'
        'managed-clickhouse:Managed ClickHouse'
        'managed-greenplum:Managed Greenplum'
        'managed-kafka:Managed Kafka'
        'managed-mongodb:Managed MongoDB'
        'managed-mysql:Managed MySQL'
        'managed-postgresql:Managed PostgreSQL'
        'managed-redis:Managed Redis'
        'managed-sqlserver:Managed SQL Server'
        'message-queue:Message Queue'
        'monitoring:Monitoring'
        'object-storage:Object Storage'
        'oraganization-manager:Organization Manager'
        'organization-manager:Organization Manager'
        'resource-manager:Resource Manager'
        'serverless:Serverless'
        'serverless-containers:Serverless Containers'
        'speech-sense:SpeechSense'
        'storage:Object Storage'
        'sws:Smart Web Security'
        'sws-firewall:SWS Firewall'
        'sws-firewall-rule:SWS Firewall Rule'
        'tax-keeper:TaxKeeper'
        'token:token mgmt'
        'translate:Translate'
        'vision:Vision OCR'
        'video:Video'
        'vpc:VPC'
        'wiki:wiki'
        'video:Video'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--cloud-id+[cloud id]:str:' \
        '--folder-id+[folder id]:str:' \
        '--folder-name+[folder name]:str:' \
        '-folder-name+[folder name]:str:' \
        '--format+[output format]:fmt:(text json json-rest yaml)' \
        '--no-user-output[no user output]' \
        '--profile+[profile]:profile:' \
        '--retry+[retries]:n:' \
        '--token+[OAuth token]:str:' \
        '--endpoint+[endpoint]:host:_hosts' \
        '--debug[debug]' \
        '--debug-grpc[debug grpc]' \
        '--impersonate-service-account-id+[impersonate SA id]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yc subcommand' sub ;;
        args)
            case $words[1] in
                compute) _arguments '1:compute cmd:(disk disk-placement-group disk-type filesystem gpu-cluster host-group host-type image instance instance-group placement-group snapshot snapshot-schedule)' '*:args:' ;;
                kubernetes) _arguments '1:k8s cmd:(cluster node-group version)' '*:args:' ;;
                iam) _arguments '1:iam cmd:(access-binding access-key api-key create-token key role service-account user-account)' '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_yc-cli "$@"
