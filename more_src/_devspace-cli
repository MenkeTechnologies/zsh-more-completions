#compdef devspace
# _devspace-cli — DevSpace developer-first k8s dev CLI (Loft Labs, Go); deploy + sync code into running k8s containers
# upstream: https://github.com/devspace-sh/devspace

_devspace-cli() {
    local -a sub=(
        'add:add modules'
        'analyze:analyze a deployment'
        'attach:attach to container'
        'build:build images'
        'cleanup:cleanup commands'
        'completion:print shell completion'
        'deploy:deploy app'
        'dev:start dev session'
        'enter:open a shell in a container'
        'help:show help'
        'init:initialize a devspace.yaml'
        'list:list contexts/profiles/etc'
        'logs:print container logs'
        'open:open application in browser'
        'print:print resolved devspace.yaml'
        'purge:purge devspace deploy'
        'render:render devspace.yaml'
        'reset:reset commands'
        'restart:restart container'
        'run:run pipeline'
        'set:set commands'
        'sync:sync local + remote'
        'ui:open DevSpace UI'
        'update:update commands'
        'upgrade:upgrade devspace'
        'use:switch context/profile/etc'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--config+[config file]:file:_files' \
        '--debug[debug]' \
        '--inactivity-timeout+[inactivity timeout]:duration:' \
        '--kube-context+[kube context]:context:' \
        '--no-warn[no warnings]' \
        '-n+[namespace]:ns:' \
        '--namespace+[namespace]:ns:' \
        '--profile+[profile]:profile:' \
        '-p+[profile]:profile:' \
        '--profile-refresh[refresh profile]' \
        '--silent[silent]' \
        '-s[silent]' \
        '--switch-context[switch kube context]' \
        '--var+[set var]:KEY=VAL:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'devspace subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_devspace-cli "$@"
