#compdef sirius
# Documentation: https://boecker-lab.github.io/docs.sirius.github.io/cli/
# SIRIUS CLI: molecular formula, fingerprint, structure and compound class ID

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'+[input files or project-space directory]:input:_files' \
  '(-o --output --project)'{-o,--output,--project}'+[output project-space directory]:project:_files -/' \
  '(-c)-c+[maximum number of formula candidates to store]:count' \
  '-z+[parent/precursor mass]:mass' \
  '--adduct=[ionization adduct (e.g. [M+H]+)]:adduct' \
  '(-p)-p+[instrument profile]:profile:(qtof orbitrap)' \
  '--ppm-max=[maximum allowed MS1 mass deviation in ppm]:ppm' \
  '--ppm-max-ms2=[maximum allowed MS2 mass deviation in ppm]:ppm' \
  '--databases=[structure/formula database(s) to search]:db' \
  '--database=[structure/formula database(s) to search]:db' \
  '--formulas=[restrict to known molecular formula(s)]:formula' \
  '--recompute[force recomputation of existing results]' \
  '1:command:(login logout config formula sirius fingerprint fingerid structure canopus zodiac passatutto write-summaries custom-db similarity decomp mgf-export ftree-export project-space)' \
  '*::args:_files' && ret=0

return ret
