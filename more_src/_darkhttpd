#compdef darkhttpd

# Zsh completion for darkhttpd (simple static HTTP server)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:document root:_files -/' \
  '--port=[Port to listen on]:port' \
  '--addr=[Address to bind to]:address' \
  '--maxconn=[Maximum number of simultaneous connections]:number' \
  '--log=[Log file path]:file:_files' \
  '--chroot[Chroot into the document root]' \
  '--daemon[Daemonize (run in background)]' \
  '--no-listing[Disable directory listing]' \
  '--no-server-id[Do not send Server header]' \
  '--forward=[Forward a URL path to another host]:host spec' \
  '--forward-all=[Forward all requests to another host]:host' \
  '--auth=[Enable basic authentication]:username:password' \
  '--header=[Add a custom header to all responses]:header' \
  '--timeout=[Connection timeout in seconds]:seconds' \
  '--ipv6[Listen on IPv6 as well]' \
  '--mimetypes=[Load MIME types from a file]:file:_files' \
  '--uid=[Change UID after binding]:uid' \
  '--gid=[Change GID after binding]:gid' \
  '--pidfile=[Write PID to file]:file:_files' \
  '--no-keepalive[Disable HTTP Keep-Alive]' \
  '--forward-https[Enable forwarding to HTTPS]' && ret=0

return ret
