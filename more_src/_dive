#compdef dive

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--ci[run in CI mode]' \
  '--ci-config[CI config file]:file:_files' \
  '--highestUserWastedPercent[highest allowable percentage of wasted space]:percent' \
  '--highestWastedBytes[highest allowable bytes wasted]:bytes' \
  '--lowestEfficiency[lowest allowable image efficiency]:percent' \
  '-j[output JSON results]:file:_files' \
  '--json[output JSON results]:file:_files' \
  '--source[container engine source]:source:(docker podman docker-archive)' \
  '--ignore-errors[ignore image parsing errors]' \
  '1:docker image:->images' && ret=0

case "$state" in
  images)
    if command -v docker &>/dev/null; then
      local -a images
      images=(${(f)"$(docker images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null)"})
      _describe -t images 'docker image' images && ret=0
    else
      _message 'docker image'
    fi
    ;;
esac

return ret
