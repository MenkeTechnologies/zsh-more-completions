#compdef gnome-terminal-server

# gnome-terminal-server: background D-Bus service for gnome-terminal
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--help-all[show all options inc GTK]' \
  '--help-gtk[show GTK options]' \
  '--version[show version]' \
  '--app-id=[D-Bus app id]:id:' \
  '--no-fork[do not fork]' \
  '--debug[debug mode]' \
  '--display=[X display]:display:' \
  '*::gnome-terminal-server args:_files' && ret=0
return ret
