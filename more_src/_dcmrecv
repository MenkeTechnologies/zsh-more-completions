#compdef dcmrecv
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmrecv.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmnet/apps/dcmrecv.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmnet/apps/dcmrecv.cc OFCommandLine setup + dcmnet/docs/dcmrecv.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+v --verbose-pc)'{+v,--verbose-pc}'[show presentation contexts in verbose mode]' \
  '(-i4 --ipv4 -i6 --ipv6 -i0 --ip-auto)'{-i4,--ipv4}'[use IPv4 only (default)]' \
  '(-i4 --ipv4 -i6 --ipv6 -i0 --ip-auto)'{-i6,--ipv6}'[use IPv6 only]' \
  '(-i4 --ipv4 -i6 --ipv6 -i0 --ip-auto)'{-i0,--ip-auto}'[use IPv6/IPv4 dual stack]' \
  '(-xf --config-file)'{-xf+,--config-file=}'[load association profile from config file]:file:_files:profile:' \
  '(-uca --use-called-aetitle -aet --aetitle)'{-uca,--use-called-aetitle}'[always respond with called AE title (default)]' \
  '(-uca --use-called-aetitle -aet --aetitle)'{-aet+,--aetitle=}'[set AE title and check called AE title]:aetitle:' \
  '(-ta --acse-timeout)'{-ta+,--acse-timeout=}'[timeout for ACSE messages]:seconds:' \
  '(-td --dimse-timeout)'{-td+,--dimse-timeout=}'[timeout for DIMSE messages]:seconds:' \
  '(-pdu --max-pdu)'{-pdu+,--max-pdu=}'[set max receive PDU (4096..131072, default: 16384)]:bytes:' \
  '(-dhl --disable-host-lookup)'{-dhl,--disable-host-lookup}'[disable hostname lookup]' \
  '(-tls --disable-tls +tls --enable-tls)'{-tls,--disable-tls}'[use normal TCP/IP connection (default)]' \
  '(-tls --disable-tls +tls --enable-tls)'{+tls,--enable-tls}'[use authenticated secure TLS connection]:private key:_files:certificate:_files' \
  '(+ps --std-passwd +pw --use-passwd -pw --null-passwd)'{+ps,--std-passwd}'[prompt user for password on stdin (default)]' \
  '(+ps --std-passwd +pw --use-passwd -pw --null-passwd)'{+pw+,--use-passwd=}'[use specified password]:password:' \
  '(+ps --std-passwd +pw --use-passwd -pw --null-passwd)'{-pw,--null-passwd}'[use empty string as password]' \
  '(-pem --pem-keys -der --der-keys)'{-pem,--pem-keys}'[read keys and certificates as PEM file (default)]' \
  '(-pem --pem-keys -der --der-keys)'{-der,--der-keys}'[read keys and certificates as DER file]' \
  '*'{+cf+,--add-cert-file=}'[add certificate file to list of certificates]:file:_files' \
  '*'{+cd+,--add-cert-dir=}'[add certificates in directory to list]:directory:_files -/' \
  '*'{+crl+,--add-crl-file=}'[add certificate revocation list file]:file:_files' \
  '(+crv --enable-crl-vfy)'{+crv,--enable-crl-vfy}'[enable leaf CRL verification]' \
  '(+cra --enable-crl-all)'{+cra,--enable-crl-all}'[enable full chain CRL verification]' \
  '(+ph --list-profiles)'{+ph,--list-profiles}'[list supported TLS profiles and exit]' \
  '(+pg --profile-8996)'{+pg,--profile-8996}'[BCP 195 RFC 8996 TLS Profile (default)]' \
  '(+pm --profile-8996-mod)'{+pm,--profile-8996-mod}'[Modified BCP 195 RFC 8996 TLS Profile]' \
  '(+py --profile-bcp195-nd)'{+py,--profile-bcp195-nd}'[Non-downgrading BCP 195 TLS Profile (retired)]' \
  '(+px --profile-bcp195)'{+px,--profile-bcp195}'[BCP 195 TLS Profile (retired)]' \
  '(+pz --profile-bcp195-ex)'{+pz,--profile-bcp195-ex}'[Extended BCP 195 TLS Profile (retired)]' \
  '(+pb --profile-basic)'{+pb,--profile-basic}'[Basic TLS Secure Transport Connection Profile (retired)]' \
  '(+pa --profile-aes)'{+pa,--profile-aes}'[AES TLS Secure Transport Connection Profile (retired)]' \
  '(+pn --profile-null)'{+pn,--profile-null}'[Authenticated unencrypted communication (retired)]' \
  '(+cc --list-ciphers)'{+cc,--list-ciphers}'[list supported TLS ciphersuites and exit]' \
  '*'{+cs+,--cipher=}'[add ciphersuite to list of negotiated suites]:ciphersuite:' \
  '(+dp --dhparam)'{+dp+,--dhparam=}'[read DH parameters for DH/DSS ciphersuites]:file:_files' \
  '--no-sni[do not use SNI (default)]' \
  '--expect-sni=[expect requests for server name]:server name:' \
  '(+rs --seed)'{+rs+,--seed=}'[seed random generator with file contents]:file:_files' \
  '(+ws --write-seed)'{+ws,--write-seed}'[write back modified seed]' \
  '(+wf --write-seed-file)'{+wf+,--write-seed-file=}'[write modified seed to file]:file:_files' \
  '(-rc --require-peer-cert -vc --verify-peer-cert -ic --ignore-peer-cert)'{-rc,--require-peer-cert}'[verify peer certificate, fail if absent (default)]' \
  '(-rc --require-peer-cert -vc --verify-peer-cert -ic --ignore-peer-cert)'{-vc,--verify-peer-cert}'[verify peer certificate if present]' \
  '(-rc --require-peer-cert -vc --verify-peer-cert -ic --ignore-peer-cert)'{-ic,--ignore-peer-cert}'[do not verify peer certificate]' \
  '(-od --output-directory)'{-od+,--output-directory=}'[write received objects to directory (default: ".")]:directory:_files -/' \
  '(-s --no-subdir +ssd --series-date-subdir)'{-s,--no-subdir}'[do not generate any subdirectories (default)]' \
  '(-s --no-subdir +ssd --series-date-subdir)'{+ssd,--series-date-subdir}'[generate subdirectories from series date]' \
  '(+fd --default-filenames +fu --unique-filenames +fsu --short-unique-names +fst --system-time-names)'{+fd,--default-filenames}'[generate filename from instance UID (default)]' \
  '(+fd --default-filenames +fu --unique-filenames +fsu --short-unique-names +fst --system-time-names)'{+fu,--unique-filenames}'[generate unique filename based on new UID]' \
  '(+fd --default-filenames +fu --unique-filenames +fsu --short-unique-names +fst --system-time-names)'{+fsu,--short-unique-names}'[generate short pseudo-random unique filename]' \
  '(+fd --default-filenames +fu --unique-filenames +fsu --short-unique-names +fst --system-time-names)'{+fst,--system-time-names}'[generate filename from current system time]' \
  '(-fe --filename-extension)'{-fe+,--filename-extension=}'[append extension to generated filenames]:extension:' \
  '(-B --normal +B --bit-preserving --ignore)'{-B,--normal}'[allow implicit format conversions (default)]' \
  '(-B --normal +B --bit-preserving --ignore)'{+B,--bit-preserving}'[write dataset exactly as received]' \
  '(-B --normal +B --bit-preserving --ignore)--ignore[receive but do not store dataset]' \
  ':port:'
