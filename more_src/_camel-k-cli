#compdef camel-k-cli kamel
# _camel-k-cli — Apache Camel K kamel CLI command-line frontend wrapping the Apache Camel K Kubernetes-native serverless integration platform building running Camel DSL integrations on Kubernetes deploying Java Groovy Yaml XML JavaScript Kotlin Camel routes integration kit catalog binding kameletbinding (Apache Camel team, Go); cobra
# upstream: https://camel.apache.org/camel-k/

_camel-k-cli() {
    local -a sub=(
        'install:install Camel K Operator'
        'uninstall:uninstall Camel K Operator'
        'run:run an integration'
        'get:get integration status'
        'log:fetch integration logs'
        'delete:delete an integration'
        'rebuild:rebuild integration kits'
        'reset:reset Camel K cluster'
        'kit:integration kit operations'
        'build:integration build operations'
        'binding:KameletBinding operations'
        'kamelet:Kamelet management'
        'promote:promote integration to another env'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--operator-id=+[id]:str:' \
        '--all-namespaces[all namespaces]' \
        '--name=+[name]:str:' \
        '-d+[dependency]:str:' \
        '--dependency=+[dep]:str:' \
        '-p+[property]:str:' \
        '--property=+[k=v]:str:' \
        '--config=+[name]:str:' \
        '--resource=+[file]:file:_files' \
        '--profile=+[name]:str:' \
        '--trait=+[name=value]:str:' \
        '-t+[trait]:str:' \
        '--env=+[k=v]:str:' \
        '--label=+[k=v]:str:' \
        '--annotation=+[k=v]:str:' \
        '--source=+[name]:str:' \
        '--output=+[fmt]:f:(yaml json)' \
        '-o+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'camel-k-cli subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments '*:source file:_files -g "*.java *.kts *.groovy *.yaml *.yml *.xml *.js"' ;;
                get|log|delete|rebuild) _arguments '*:integration name:' ;;
                kit|build|binding|kamelet) _arguments '1:op:(list get create update delete)' '*:name:' ;;
            esac
            ;;
    esac
}

_camel-k-cli "$@"
