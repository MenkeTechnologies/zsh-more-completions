#compdef hugin_executor
# Documentation: https://man.archlinux.org/search?q=hugin_executor
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --assistant)'{-a,--assistant}'[run assistant]' \
  '(-s --stitching)'{-s,--stitching}'[run stitching]' \
  '(-d --dry-run)'{-d,--dry-run}'[dry run]' \
  '(-t --threads)'{-t,--threads}'+[number of threads]:n:' \
  '(-u --user-defined-output)'{-u,--user-defined-output}'+[user-defined output script]:script:_files' \
  '(-p --prefix)'{-p,--prefix}'+[output prefix]:prefix:' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
