#compdef pbrt
# Documentation: https://pbrt.org/users-guide-v4
# pbrt-v4 physically based ray tracer

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--nthreads=[number of CPU threads to use]:n' \
  '--outfile=[output image file path]:file:_files' \
  '--spp=[samples per pixel]:n' \
  '--seed=[random seed]:n' \
  '--cropwindow=[crop window x0,x1,y0,y1]:bounds' \
  '--pixel=[render single pixel x,y]:xy' \
  '--pixelbounds=[render image region x0,x1,y0,y1]:bounds' \
  '--pixelmaterial=[print material info for pixel x,y]:xy' \
  '--pixelstats[record per-pixel statistics]' \
  '--display-server=[send image to tev display server]:addr:port' \
  '--render-coord-sys=[rendering coordinate system]:name' \
  '--debugstart=[trace specific ray path]:index' \
  '--displacement-edge-scale=[displacement edge scale]:n' \
  '--gpu-device=[GPU device index]:index' \
  '--log-file=[write log to file]:file:_files' \
  '--log-level=[log verbosity level]:level' \
  '--mse-reference-image=[reference image for MSE computation]:file:_files' \
  '--mse-reference-out=[write MSE results to file]:file:_files' \
  '--gpu[use GPU rendering path]' \
  '--wavefront[use wavefront integrator]' \
  '--interactive[interactive rendering mode with live display]' \
  '--fullscreen[run interactive mode fullscreen]' \
  '--quick[render quickly with reduced quality]' \
  '--quiet[suppress non-essential output]' \
  '--stats[display rendering statistics]' \
  '--log-utilization[log core utilization]' \
  '--nan-stats[track NaN/Inf statistics]' \
  '--force-diffuse[convert specular materials to diffuse]' \
  '--disable-image-textures[disable image texture lookups]' \
  '--disable-pixel-jitter[disable pixel sample jittering]' \
  '--disable-texture-filtering[disable texture filtering]' \
  '--disable-wavelength-jitter[disable wavelength jittering]' \
  '--write-partial-images[write images periodically during rendering]' \
  '--toply[convert triangle meshes to binary PLY]' \
  '--upgrade[convert pbrt-v3 scene files to pbrt-v4]' \
  '--format[reformat scene file]' \
  '*:scene:_files' && ret=0

return ret
