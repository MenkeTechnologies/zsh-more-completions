#compdef pegasus-plan
# Documentation: https://pegasus.isi.edu/documentation/manpages/pegasus-plan.html
# pegasus-plan - run Pegasus to generate the executable workflow

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display all options]' \
  '(-V --version)'{-V,--version}'[display Pegasus version number]' \
  '*-D[override properties influencing program execution]:property=value' \
  '(-b --basename)'{-b,--basename}'=[prefix for workflow-specific files like .dag files]:prefix' \
  '(-c --cache)'{-c,--cache}'=[comma-separated replica cache file paths]:files:_files' \
  '(-C --cluster)'{-C,--cluster}'=[clustering styles]:style:(horizontal label whole)' \
  '--cleanup=[cleanup strategy]:strategy:(none leaf inplace constraint)' \
  '--conf=[path to properties file]:file:_files' \
  '--dir=[base directory for planner output]:dir:_files -/' \
  '(-f --force)'{-f,--force}'[bypass the reduction phase]' \
  '--force-replan[replan DAX jobs on failure instead of using rescue DAG]' \
  '(-g --group)'{-g,--group}'=[VO group membership]:group' \
  '--inherited-rc-files=[comma-separated replica file paths for hierarchical workflows]:files:_files' \
  '(-I --input-dir)'{-I,--input-dir}'=[input directories on submit host]:dir:_files -/' \
  '(-j --job-prefix)'{-j,--job-prefix}'=[prefix for job submit filenames]:prefix' \
  '(-J --json)'{-J,--json}'[output logs to stderr, write JSON braindump to stdout]' \
  '(-n --nocleanup)'{-n,--nocleanup}'[disable cleanup (deprecated)]' \
  '(-o --output-sites)'{-o,--output-sites}'=[comma-separated output site list]:sites' \
  '(-O --output-dir)'{-O,--output-dir}'=[output directory for DAX files]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[decrease logging level]' \
  '(-r --randomdir)'{-r,--randomdir}'[create random directories on staging sites]' \
  '--relative-dir=[relative execution directory]:dir' \
  '--relative-submit-dir=[relative submit directory]:dir' \
  '(-R --rescue)'{-R,--rescue}'=[previous submit directories for data reuse]:dir:_files -/' \
  '(-s --sites)'{-s,--sites}'=[comma-separated execution site list]:sites' \
  '--staging-site=[key=value pairs mapping execution to staging sites]:mapping' \
  '--submit[submit the generated workflow using pegasus-run]' \
  '*-v[increase verbosity (stackable)]' \
  '--verbose[increase verbosity]' \
  '*:abstract workflow:_files' && ret=0

return ret
