#compdef pnpm-dlx

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--package=[packages to install]:packages' \
  '-p+[packages to install]:packages' \
  '-c[execute shell command]' \
  '--shell-mode[execute as shell command]' \
  '*::command:_command_names -e' && ret=0

return ret
