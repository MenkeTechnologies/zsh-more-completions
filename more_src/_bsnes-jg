#compdef bsnes-jg
# Documentation: https://gitlab.com/jgemu/bsnes
# Reference accessed: 2026-05-16
# Verified: bsnes-jg is a Jolly Good Framework module, not a standalone CLI
# binary. It is loaded by the jgrf launcher; the module itself has no
# command-line interface. Tool kept per "do not delete files" directive with
# conservative stub showing only jgrf-pass-through file argument.

# bsnes-jg: Jolly Good Framework module of bsnes (load via jgrf)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:SNES ROM:_files -g "*.(sfc|smc|fig|swc|bs|st|zip|7z)"' && ret=0
return ret
