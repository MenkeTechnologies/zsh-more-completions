#compdef flanneld

# Zsh completion for flanneld - Flannel networking daemon

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--etcd-endpoints=[etcd endpoints]:endpoints' \
  '--etcd-prefix=[etcd prefix]:prefix' \
  '--etcd-keyfile=[etcd TLS key file]:file:_files' \
  '--etcd-certfile=[etcd TLS certificate file]:file:_files' \
  '--etcd-cafile=[etcd TLS CA file]:file:_files' \
  '*--iface=[interface to use]:interface:_net_interfaces' \
  '*--iface-regex=[regex to match interface]:regex' \
  '--subnet-file=[path to subnet file]:file:_files' \
  '--subnet-lease-renew-margin=[subnet lease renewal margin in minutes]:minutes' \
  '--ip-masq[setup IP masquerade for traffic from the pod network]' \
  '--kube-subnet-mgr[use Kubernetes subnet manager]' \
  '--kube-api-url=[Kubernetes API server URL]:url' \
  '--kubeconfig-file=[path to kubeconfig file]:file:_files' \
  '--public-ip=[public IP to use for inter-host communication]:ip' \
  '--public-ipv6=[public IPv6 to use for inter-host communication]:ipv6' \
  '--healthz-ip=[IP address for healthz server]:ip' \
  '--healthz-port=[port for healthz server]:port' \
  '-v=[log verbosity level]:level' \
  && ret=0

return ret
