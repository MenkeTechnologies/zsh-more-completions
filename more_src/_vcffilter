#compdef vcffilter
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcffilter.md
# Filter VCF records using genotype and INFO field criteria

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-f,--info-filter}'[apply filters to INFO fields, removing alleles that do not pass]:specification' \
  '*'{-g,--genotype-filter}'[apply filters to genotype fields of records]:specification' \
  '(-k --keep-info)'{-k,--keep-info}'[used with -g, retain variant info while removing genotype data]' \
  '(-s --filter-sites)'{-s,--filter-sites}'[filter entire records instead of just alleles]' \
  '(-t --tag-pass)'{-t,--tag-pass}'[tag passing records with this tag, print all records]:tag' \
  '(-F --tag-fail)'{-F,--tag-fail}'[tag failing records with this tag, print all records]:tag' \
  '(-A --append-filter)'{-A,--append-filter}'[append to existing filter tag rather than replacing it]' \
  '(-a --allele-tag)'{-a,--allele-tag}'[apply tagging per-allele, setting corresponding INFO field tag]:tag' \
  '(-v --invert)'{-v,--invert}'[invert filter logic (like grep -v)]' \
  '(-o --or)'{-o,--or}'[combine multiple filters using logical OR instead of AND]' \
  '*'{-r,--region}'[target filtering to specific region (requires tabix-indexed file)]:region' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
