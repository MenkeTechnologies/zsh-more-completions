#compdef qovery
# _qovery-cli — Qovery DevOps platform CLI (Qovery, Go); deploy apps to AWS/GCP/Azure/Scaleway via Qovery
# upstream: https://github.com/Qovery/qovery-cli

_qovery-cli() {
    local -a sub=(
        'application:application commands'
        'auth:authenticate'
        'cluster:cluster commands'
        'completion:print shell completion'
        'config:config commands'
        'console:open Qovery console'
        'container:container commands'
        'context:context commands'
        'cronjob:cronjob commands'
        'database:database commands'
        'deploy:deploy stack'
        'demo:demo commands'
        'environment:environment commands'
        'help:show help'
        'lifecycle:lifecycle commands'
        'log:fetch service logs'
        'login:login'
        'logout:logout'
        'org:org commands'
        'preview:preview env commands'
        'project:project commands'
        'service:service commands'
        'shell:open shell'
        'status:show status'
        'token:token commands'
        'upgrade:upgrade qovery cli'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--token+[Qovery token]:str:' \
        '--config+[config file]:file:_files' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qovery subcommand' sub ;;
    esac
}

_qovery-cli "$@"
