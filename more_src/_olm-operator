#compdef olm-operator olm
# _olm-operator — OLMv0 main lifecycle operator (operator-framework/operator-lifecycle-manager)
# upstream: https://github.com/operator-framework/operator-lifecycle-manager
# Flags from cmd/olm/main.go on tip.

_olm-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print OLM version and exit]' \
        '--interval=[wake-up interval]:dur:' \
        '--watchedNamespaces=[comma-separated watched namespaces]:list:' \
        '--writeStatusName=[ClusterOperator name to write status to ("" disables)]:name:' \
        '--writePackageServerStatusName=[packageserver ClusterOperator name ("" disables)]:name:' \
        '--debug[enable debug log level]' \
        '--tls-key=[TLS private key file (requires --tls-cert)]:file:_files' \
        '--tls-cert=[TLS certificate file (requires --tls-key)]:file:_files' \
        '--client-ca=[watch path for client-CA bundle]:file:_files' \
        '--protectedCopiedCSVNamespaces=[comma-sep namespaces whose copied CSVs are protected]:list:' \
        '--namespace=[operator namespace]:ns:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr[log to stderr instead of files]' \
        '--stderrthreshold=[stderr klog severity threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_olm-operator "$@"
