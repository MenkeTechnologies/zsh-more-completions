#compdef tinker
# Documentation: https://man.archlinux.org/search?q=tinker
# Reference accessed: 2026-05-16

# Tinker: software for molecular modeling. Provides many sub-programs;
# the wrapper invokes them by name.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'dynamic:run MD simulation'
  'minimize:energy minimization'
  'newton:Newton-Raphson minimization'
  'analyze:analyze a structure'
  'archive:archive trajectory files'
  'bar:Bennett acceptance ratio free energy'
  'gda:gibbs analysis'
  'pdbxyz:convert PDB to xyz'
  'xyzpdb:convert xyz to PDB'
  'monte:Monte Carlo'
  'optimize:optimize geometry'
  'polarize:polarization analysis'
  'protein:build protein from sequence'
  'sniffer:scan for new structures'
)

_arguments -C \
  '1: :->cmd' \
  '*::tinker args and key file:->args' && ret=0

case $state in
  cmd) _describe -t commands 'tinker command' commands && ret=0 ;;
esac
return ret
