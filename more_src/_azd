#compdef azd

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-C+[set working directory]:directory:_directories' \
  '--cwd=[set working directory]:directory:_directories' \
  '--debug[enable debug logging]' \
  '--no-prompt[do not prompt for user input]' \
  '-e+[name of the environment]:environment name:' \
  '--environment=[name of the environment]:environment name:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize a new application'
      'up:provision Azure resources and deploy'
      'provision:provision Azure resources'
      'deploy:deploy application code to Azure'
      'down:delete Azure resources'
      'restore:restore application dependencies'
      'package:package application code'
      'monitor:monitor a deployed application'
      'pipeline:manage and configure deployment pipelines'
      'env:manage environments'
      'config:manage azd configurations'
      'auth:authenticate with Azure'
      'template:find and view templates'
      'hooks:manage hooks'
      'show:display information about your app and its resources'
      'version:print version number'
    )
    _describe -t commands 'azd command' commands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-t+[template to use]:template:' \
          '--template=[template to use]:template:' \
          '-l+[Azure location]:location:' \
          '--location=[Azure location]:location:' \
          '-s+[Azure subscription]:subscription:' \
          '--subscription=[Azure subscription]:subscription:' \
          '-b+[branch to use]:branch:' \
          '--branch=[branch to use]:branch:' \
          '--from-code[initialize from existing code]' && ret=0
        ;;
      up|provision|deploy|down|restore|package)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--all[apply to all services]' \
          '--service=[target specific service]:service:' \
          '--platform=[target platform]:platform:(docker appservice containerapp)' && ret=0
        ;;
      env)
        local -a env_commands=(
          'list:list environments'
          'new:create a new environment'
          'select:set the default environment'
          'refresh:refresh environment settings'
          'get-values:get all environment values'
          'set:set a value in the environment'
        )
        _describe -t commands 'env command' env_commands && ret=0
        ;;
      auth)
        local -a auth_commands=(
          'login:log in to Azure'
          'logout:log out of Azure'
          'token:get an access token'
        )
        _describe -t commands 'auth command' auth_commands && ret=0
        ;;
      config)
        local -a config_commands=(
          'list:list all configuration values'
          'get:get a configuration value'
          'set:set a configuration value'
          'unset:unset a configuration value'
          'reset:reset configuration to defaults'
          'show:show configuration'
        )
        _describe -t commands 'config command' config_commands && ret=0
        ;;
      pipeline)
        local -a pipeline_commands=(
          'config:configure deployment pipeline'
        )
        _describe -t commands 'pipeline command' pipeline_commands && ret=0
        ;;
      monitor)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--live[open live metrics dashboard]' \
          '--logs[open log stream]' \
          '--overview[open overview dashboard]' && ret=0
        ;;
      template)
        local -a template_commands=(
          'list:list templates'
          'show:show template details'
          'source:manage template sources'
        )
        _describe -t commands 'template command' template_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
