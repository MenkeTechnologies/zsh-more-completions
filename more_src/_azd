#compdef azd
# Documentation: https://github.com/Azure/azure-dev/tree/main/cli/azd/cmd
# Reference accessed: 2026-05-27
# Verified: upstream cli/azd/cmd/{root,cobra_builder,auth,env,infra,pipeline,
# templates,config,hooks,monitor,down,init,package,up,deploy,provision,show,
# restore,version}.go subcommand and flag registrations. Coverage: every
# top-level subcommand registered in root.go; per-subcommand flags captured
# for the high-traffic commands (auth, env, init, deploy, up, down, monitor,
# package, provision, infra, pipeline, template, config, hooks, restore,
# show, version). Less-common subcommands (add, build, copilot, exec,
# extension, mcp, publish, telemetry, tool, update, vs-server) fall back to
# global-flags + file completion.

# azd — Azure Developer CLI (Cobra-based Go binary).

local curcontext="$curcontext" state line ret=1

local -a _azd_subcommands
_azd_subcommands=(
  'add:add a component to the project'
  'auth:authenticate with Azure'
  'build:build the application'
  'config:manage azd configuration'
  'copilot:Copilot integration features'
  'deploy:deploy the application to Azure'
  'down:delete the Azure resources for an environment'
  'env:manage environments'
  'exec:execute a command inside the project context'
  'extension:manage azd extensions'
  'hooks:manage and run project lifecycle hooks'
  'infra:manage Infrastructure as Code (IaC)'
  'init:initialize a new application'
  'mcp:Model Context Protocol integration'
  'monitor:open Application Insights for the project'
  'package:package the application for deployment'
  'pipeline:configure a CI/CD pipeline'
  'provision:provision the Azure resources for the application'
  'publish:publish the application'
  'restore:restore application dependencies'
  'show:display information about the project and its resources'
  'telemetry:manage telemetry settings'
  'template:manage azd templates'
  'tool:manage tools (alpha)'
  'up:provision Azure resources and deploy (init + provision + deploy)'
  'update:update the azd CLI to the latest version'
  'version:print the azd version'
  'vs-server:run the Visual Studio integration server'
)

local -a _azd_auth_subs
_azd_auth_subs=(
  'login:log in to Azure'
  'logout:remove stored Azure credentials'
  'status:show current authentication status'
  'token:print an access token for Azure'
)

local -a _azd_env_subs
_azd_env_subs=(
  'config:manage environment configuration'
  'get-value:print a single environment value'
  'get-values:print all environment values'
  'list:list environments'
  'new:create a new environment and make it the default'
  'refresh:refresh environment values from the last provision'
  'remove:remove an environment'
  'select:set the default environment'
  'set:set one or more environment values'
  'set-secret:set a name as a reference to a Key Vault secret'
)

local -a _azd_infra_subs
_azd_infra_subs=(
  'create:provision Azure resources (alias for provision)'
  'delete:delete Azure resources (alias for down)'
  'generate:generate IaC files from the project'
  'synth:synthesize infrastructure templates'
)

local -a _azd_config_subs
_azd_config_subs=(
  'show:show all configuration values'
  'list:list all configuration values (deprecated, use show)'
  'get:get a configuration value'
  'set:set a configuration value'
  'unset:remove a configuration value'
  'reset:reset configuration to defaults'
  'list-alpha:list available alpha-stage features'
  'options:list all available configuration settings'
)

local -a _azd_template_subs
_azd_template_subs=(
  'list:list available azd templates'
  'show:show details for a template'
  'source:view and manage template sources'
)

local -a _azd_pipeline_subs
_azd_pipeline_subs=(
  'config:configure the CI/CD pipeline to connect to Azure'
)

local -a _azd_hooks_subs
_azd_hooks_subs=(
  'run:run a named project hook'
)

# Global / persistent flags shared by every azd command (cobra_builder.go,
# root.go, internal/global_command_options.go).
local -a _azd_global_opts
_azd_global_opts=(
  '(-h --help)'{-h,--help}'[show help for the command]'
  '--cwd=[run azd in the given working directory]:directory:_files -/'
  '-C+[run azd in the given working directory]:directory:_files -/'
  '--debug[enable verbose debug logging]'
  '--no-prompt[fail instead of prompting when information is missing]'
  '--docs[open the online docs for this command]'
)

_arguments -C \
  $_azd_global_opts \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'azd subcommand' _azd_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        _arguments -C \
          $_azd_global_opts \
          '1: :->authcmd' \
          '*:: :->authargs' && ret=0
        case $state in
          authcmd) _describe -t commands 'azd auth subcommand' _azd_auth_subs && ret=0 ;;
          authargs)
            case $line[1] in
              login)
                _arguments \
                  $_azd_global_opts \
                  '--check-status[check authentication status without logging in]' \
                  '--use-device-code[use device-code flow for sign-in]' \
                  '--tenant-id=[Azure AD tenant ID to authenticate against]:tenant id:' \
                  '--client-id=[client ID for service-principal sign-in]:client id:' \
                  '--client-secret=[client secret for service-principal sign-in]:secret:' \
                  '--client-certificate=[path to PEM client certificate]:file:_files' \
                  '--federated-credential-provider=[federated credential provider]:provider:(github azure-pipelines)' \
                  '--redirect-port=[port for the local redirect listener]:port:' && ret=0
                ;;
              token)
                _arguments \
                  $_azd_global_opts \
                  '*--scope=[OAuth scope to request]:scope:' \
                  '--tenant-id=[Azure AD tenant ID]:tenant id:' \
                  '--output=[output format]:format:(json none)' && ret=0
                ;;
              *) _arguments $_azd_global_opts && ret=0 ;;
            esac
            ;;
        esac
        ;;
      env)
        _arguments -C \
          $_azd_global_opts \
          '1: :->envcmd' \
          '*:: :->envargs' && ret=0
        case $state in
          envcmd) _describe -t commands 'azd env subcommand' _azd_env_subs && ret=0 ;;
          envargs)
            case $line[1] in
              new)
                _arguments \
                  $_azd_global_opts \
                  '(-l --location)'{-l+,--location=}'[Azure location for the new environment]:location:' \
                  '(-s --subscription)'{-s+,--subscription=}'[Azure subscription ID]:subscription:' && ret=0
                ;;
              set|get-value)
                _arguments \
                  $_azd_global_opts \
                  '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' \
                  '1:key:' '2:value:' && ret=0
                ;;
              get-values|list|refresh|select|remove)
                _arguments \
                  $_azd_global_opts \
                  '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' \
                  '--output=[output format]:format:(json table)' && ret=0
                ;;
              *) _arguments $_azd_global_opts && ret=0 ;;
            esac
            ;;
        esac
        ;;
      infra)
        _arguments -C \
          $_azd_global_opts \
          '1: :->infracmd' \
          '*:: :->infraargs' && ret=0
        case $state in
          infracmd) _describe -t commands 'azd infra subcommand' _azd_infra_subs && ret=0 ;;
          infraargs) _arguments $_azd_global_opts && ret=0 ;;
        esac
        ;;
      config)
        _arguments -C \
          $_azd_global_opts \
          '1: :->cfgcmd' \
          '*:: :->cfgargs' && ret=0
        case $state in
          cfgcmd) _describe -t commands 'azd config subcommand' _azd_config_subs && ret=0 ;;
          cfgargs) _arguments $_azd_global_opts '*:key:' && ret=0 ;;
        esac
        ;;
      template)
        _arguments -C \
          $_azd_global_opts \
          '1: :->tplcmd' \
          '*:: :->tplargs' && ret=0
        case $state in
          tplcmd) _describe -t commands 'azd template subcommand' _azd_template_subs && ret=0 ;;
          tplargs)
            case $line[1] in
              list)
                _arguments \
                  $_azd_global_opts \
                  '(-f --filter)'{-f+,--filter=}'[filter results by tags]:tag:' \
                  '(-s --source)'{-s+,--source=}'[template source key]:source:' \
                  '--output=[output format]:format:(json table)' && ret=0
                ;;
              show)
                _arguments $_azd_global_opts '1:template:' && ret=0
                ;;
              *) _arguments $_azd_global_opts && ret=0 ;;
            esac
            ;;
        esac
        ;;
      pipeline)
        _arguments -C \
          $_azd_global_opts \
          '1: :->pipecmd' \
          '*:: :->pipeargs' && ret=0
        case $state in
          pipecmd) _describe -t commands 'azd pipeline subcommand' _azd_pipeline_subs && ret=0 ;;
          pipeargs)
            case $line[1] in
              config)
                _arguments \
                  $_azd_global_opts \
                  '--principal-name=[name of the service principal to create]:name:' \
                  '--principal-role=[role to assign to the service principal]:role:' \
                  '--remote-name=[git remote name to use]:remote:' \
                  '--auth-type=[authentication type]:auth:(federated client-credentials)' \
                  '--provider=[pipeline provider]:provider:(github azdo)' \
                  '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' && ret=0
                ;;
              *) _arguments $_azd_global_opts && ret=0 ;;
            esac
            ;;
        esac
        ;;
      hooks)
        _arguments -C \
          $_azd_global_opts \
          '1: :->hookcmd' \
          '*:: :->hookargs' && ret=0
        case $state in
          hookcmd) _describe -t commands 'azd hooks subcommand' _azd_hooks_subs && ret=0 ;;
          hookargs)
            case $line[1] in
              run)
                _arguments \
                  $_azd_global_opts \
                  '--platform=[platform for the hook]:platform:' \
                  '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' \
                  '1:hook name:' && ret=0
                ;;
              *) _arguments $_azd_global_opts && ret=0 ;;
            esac
            ;;
        esac
        ;;
      init)
        _arguments \
          $_azd_global_opts \
          '(-t --template)'{-t+,--template=}'[initialize from a template (URI, owner/repo, name, or local path)]:template:' \
          '(-b --branch)'{-b+,--branch=}'[template branch (requires --template)]:branch:' \
          '(-f --filter)'{-f+,--filter=}'[tag filter for template results]:tag:' \
          '(-s --subscription)'{-s+,--subscription=}'[Azure subscription ID]:subscription:' \
          '(-l --location)'{-l+,--location=}'[Azure location]:location:' \
          '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' \
          '--from-code[initialize from existing code in the current directory]' \
          '(-m --minimal)'{-m,--minimal}'[create a minimal project]' \
          '--up[provision and deploy after initializing]' && ret=0
        ;;
      up)
        _arguments \
          $_azd_global_opts \
          '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' \
          '--subscription=[Azure subscription ID]:subscription:' \
          '(-l --location)'{-l+,--location=}'[Azure location]:location:' && ret=0
        ;;
      down)
        _arguments \
          $_azd_global_opts \
          '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' \
          '--force[delete resources without confirmation]' \
          '--purge[permanently delete soft-deleted resources]' && ret=0
        ;;
      deploy)
        _arguments \
          $_azd_global_opts \
          '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' \
          '--all[deploy all services listed in azure.yaml]' \
          '--from-package=[deploy from a previously built package]:path:_files' \
          '1:service:' && ret=0
        ;;
      provision)
        _arguments \
          $_azd_global_opts \
          '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' \
          '--no-state[do not use cached deployment state]' \
          '--preview[preview the changes without applying them]' && ret=0
        ;;
      package)
        _arguments \
          $_azd_global_opts \
          '--all[package every service listed in azure.yaml]' \
          '--output-path=[file or folder path to write the package to]:path:_files' \
          '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' \
          '1:service:' && ret=0
        ;;
      monitor)
        _arguments \
          $_azd_global_opts \
          '--live[open Application Insights Live Metrics]' \
          '--logs[open Application Insights Logs]' \
          '--overview[open the Application Insights overview dashboard]' \
          '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' && ret=0
        ;;
      show)
        _arguments \
          $_azd_global_opts \
          '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' \
          '--output=[output format]:format:(json table)' && ret=0
        ;;
      restore)
        _arguments \
          $_azd_global_opts \
          '--all[restore all services listed in azure.yaml]' \
          '(-e --environment)'{-e+,--environment=}'[environment name]:environment:' \
          '1:service:' && ret=0
        ;;
      version)
        _arguments \
          $_azd_global_opts \
          '--output=[output format]:format:(json none)' && ret=0
        ;;
      *)
        _arguments $_azd_global_opts '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
