#compdef datafusion-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --data-path)'{-p,--data-path}'[path to data directory]:path:_directories' \
  '(-c --batch-size)'{-c,--batch-size}'[batch size]:size:' \
  '(-f --file)'{-f,--file}'[SQL file to execute]:file:_files' \
  '--format[output format]:format:(csv tsv table json nd-json automatic)' \
  '(-m --memory-limit)'{-m,--memory-limit}'[memory limit]:limit:' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '--color[enable colored output]' \
  '(-r --rc)'{-r,--rc}'[path to init file]:file:_files' \
  && ret=0

return ret
