#compdef synapse_port_db
# _synapse_port_db — port Synapse SQLite database to PostgreSQL (element-hq/synapse)
# upstream: https://github.com/element-hq/synapse
# Flags from synapse/_scripts/synapse_port_db.py (argparse).

_synapse_port_db() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-v[verbose logging]' \
        '--sqlite-database=[source SQLite database file]:file:_files -g "*.{db,sqlite,sqlite3}"' \
        '--postgres-config=[PostgreSQL Synapse config YAML]:file:_files -g "*.{yml,yaml}"' \
        '--curses[curses-based progress UI]' \
        '--batch-size=[port batch size]:n:'
}

_synapse_port_db "$@"
