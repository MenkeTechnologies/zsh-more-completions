#compdef wxt

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dev:start development mode'
  'build:build extension for production'
  'zip:create zip of built extension'
  'prepare:prepare TypeScript types'
  'init:create a new WXT project'
  'submit:submit extension to stores'
  'submit:init:setup submission credentials'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'wxt command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (dev)
        _arguments \
          '--browser=[target browser]:browser:(chrome firefox edge safari opera)' \
          '-b+[target browser]:browser:(chrome firefox edge safari opera)' \
          '--mv2[use Manifest V2]' \
          '--mv3[use Manifest V3]' \
          '--port=[dev server port]:port' \
          '--open[open browser on startup]' && ret=0
        ;;
      (build)
        _arguments \
          '--browser=[target browser]:browser:(chrome firefox edge safari opera)' \
          '-b+[target browser]:browser:(chrome firefox edge safari opera)' \
          '--mv2[use Manifest V2]' \
          '--mv3[use Manifest V3]' \
          '--analyze[analyze bundle]' \
          '--sourcemap[generate source maps]' && ret=0
        ;;
      (zip)
        _arguments \
          '--browser=[target browser]:browser:(chrome firefox edge safari opera)' \
          '-b+[target browser]:browser:(chrome firefox edge safari opera)' \
          '--mv2[use Manifest V2]' \
          '--mv3[use Manifest V3]' && ret=0
        ;;
      (init)
        _arguments \
          '--template=[project template]:template' \
          '--pm=[package manager]:pm:(npm yarn pnpm bun)' \
          '1:project name' && ret=0
        ;;
    esac
    ;;
esac

return ret
