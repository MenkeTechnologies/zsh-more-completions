#compdef src

# Zsh completion for Sourcegraph CLI (src)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'search:search for code'
      'api:make Sourcegraph API requests'
      'batch:manage batch changes'
      'repos:manage repositories'
      'users:manage users'
      'orgs:manage organizations'
      'extensions:manage extensions'
      'lsif:manage LSIF data'
      'code-intel:manage code intelligence'
      'login:authenticate with Sourcegraph'
      'version:show version information'
      'serve-git:serve git repositories'
      'validate:validate Sourcegraph installation'
      'snapshot:manage snapshots'
    )
    _describe -t commands 'src command' commands && ret=0
    ;;
  args)
    case $line[1] in
      search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-json[output as JSON]' \
          '-less[pipe output through less]' \
          '-display=[max results to display]:count' \
          '-stream[stream results]' \
          '1:search query' && ret=0
        ;;
      api)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-query=[GraphQL query]:query' \
          '-vars=[query variables as JSON]:vars' \
          '-get[use HTTP GET instead of POST]' && ret=0
        ;;
      batch)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->batch_cmds' \
          '*::arg:->batch_args' && ret=0
        case $state in
          batch_cmds)
            local -a batch_commands=(
              'preview:preview a batch change'
              'apply:apply a batch change'
              'validate:validate a batch spec'
              'new:create a new batch spec'
              'repos:list repos in a batch spec'
              'exec:execute batch change steps locally'
            )
            _describe -t commands 'batch subcommand' batch_commands && ret=0
            ;;
          batch_args)
            case $line[1] in
              preview|apply)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '-f=[batch spec file]:spec file:_files -g "*.yaml"' \
                  '-namespace=[namespace]:namespace' \
                  '-n=[namespace]:namespace' && ret=0
                ;;
              validate|new)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '-f=[batch spec file]:spec file:_files -g "*.yaml"' && ret=0
                ;;
              exec)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '-f=[batch spec file]:spec file:_files -g "*.yaml"' \
                  '-timeout=[step timeout]:timeout' \
                  '-keep-logs[keep logs after execution]' \
                  '-cache=[cache directory]:cache dir:_directories' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      repos)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->repos_cmds' && ret=0
        case $state in
          repos_cmds)
            local -a repos_commands=(
              'list:list repositories'
              'get:get a repository'
              'delete:delete a repository'
            )
            _describe -t commands 'repos subcommand' repos_commands && ret=0
            ;;
        esac
        ;;
      users)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->users_cmds' && ret=0
        case $state in
          users_cmds)
            local -a users_commands=(
              'list:list users'
              'get:get a user'
              'create:create a user'
              'delete:delete a user'
            )
            _describe -t commands 'users subcommand' users_commands && ret=0
            ;;
        esac
        ;;
      orgs)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->orgs_cmds' && ret=0
        case $state in
          orgs_cmds)
            local -a orgs_commands=(
              'list:list organizations'
              'get:get an organization'
              'create:create an organization'
              'delete:delete an organization'
              'members:manage organization members'
            )
            _describe -t commands 'orgs subcommand' orgs_commands && ret=0
            ;;
        esac
        ;;
      extensions)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->ext_cmds' && ret=0
        case $state in
          ext_cmds)
            local -a ext_commands=(
              'list:list extensions'
              'get:get an extension'
              'create:create an extension'
              'update:update an extension'
              'delete:delete an extension'
              'publish:publish an extension'
              'copy:copy an extension'
            )
            _describe -t commands 'extensions subcommand' ext_commands && ret=0
            ;;
        esac
        ;;
      lsif)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->lsif_cmds' && ret=0
        case $state in
          lsif_cmds)
            local -a lsif_commands=(
              'upload:upload LSIF data'
            )
            _describe -t commands 'lsif subcommand' lsif_commands && ret=0
            ;;
        esac
        ;;
      login)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:Sourcegraph URL' && ret=0
        ;;
    esac
    ;;
esac

return ret
