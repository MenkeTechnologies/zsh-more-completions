#compdef avifenc
# Documentation: avifenc --help (libavif 1.4.2)
# Source: AVIF (AV1) image encoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-q --qcolor)'{-q+,--qcolor=}'[color quality 0..100]:q:' \
    '--qalpha=[alpha quality 0..100]:q:' \
    '(-s --speed)'{-s+,--speed=}'[encoder speed 0..10 or default]:speed:' \
    '(-j --jobs)'{-j+,--jobs=}'[worker threads or all]:jobs:' \
    '--no-overwrite[never overwrite existing output]' \
    '(-o --output)'{-o+,--output=}'[output filename]:file:_files -g "*.avif"' \
    '(-l --lossless)'{-l,--lossless}'[lossless defaults]' \
    '(-d --depth)'{-d+,--depth=}'[output bit depth (8/10/12 or D,Dext)]:depth:' \
    '(-y --yuv)'{-y+,--yuv=}'[YUV format]:format:(auto 444 422 420 400)' \
    '(-p --premultiply)'{-p,--premultiply}'[premultiply color by alpha]' \
    '--sharpyuv[sharp RGB->YUV420 conversion]' \
    '--stdin[read input from stdin]' \
    '--input-format=[input file format]:format:(jpeg png y4m auto)' \
    '--cicp=[CICP values P/T/M]:p/t/m:' \
    '--nclx=[CICP values P/T/M]:p/t/m:' \
    '(-r --range)'{-r+,--range=}'[YUV range]:range:(limited l full f)' \
    '--target-size=[target file size in bytes]:bytes:' \
    '--progressive[encode progressive layered image]' \
    '--layered[encode layered AVIF (max 4 layers)]' \
    '(-g --grid)'{-g+,--grid=}'[encode MxN grid]:MxN:' \
    '(-c --codec)'{-c+,--codec=}'[codec name]:codec:(aom rav1e svt)' \
    '--exif=[Exif metadata file]:file:_files' \
    '--xmp=[XMP metadata file]:file:_files' \
    '--icc=[ICC profile file]:file:_files' \
    '--timescale=[timescale for image sequences]:n:' \
    '--fps=[frames per second for image sequences]:n:' \
    '--creation-time=[creation time (unix epoch)]:seconds:' \
    '--modification-time=[modification time (unix epoch)]:seconds:' \
    '(-k --keyframe)'{-k+,--keyframe=}'[max keyframe interval]:interval:' \
    '--ignore-exif[ignore embedded Exif]' \
    '--ignore-xmp[ignore embedded XMP]' \
    '(--ignore-profile --ignore-icc)--ignore-profile[ignore embedded color profile]' \
    '(--ignore-profile --ignore-icc)--ignore-icc[ignore embedded color profile]' \
    '--pasp=[aspect ratio H,V]:h,v:' \
    '--crop=[crop X,Y,W,H]:crop:' \
    '1:input image:_files -g "*.(jpg|jpeg|png|y4m)"' \
    '2:output avif:_files -g "*.avif"' \
    && ret=0

return ret
