#compdef ceph-monstore-tool
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-monstore-tool/
# Inspect and manipulate a Ceph monitor's store database.

local ret=1

_arguments -s -S \
  '--version=[map version to operate on]:ver:' \
  '--out=[output file]:file:_files' \
  '*::command:->cmd' && ret=0

case $state in
  (cmd)
    _values 'command' \
      'store-copy[copy the store to PATH]' \
      'get[get monmap/osdmap/mdsmap/mgr/crushmap]' \
      'get-key[get key to file]' \
      'remove-key[remove key]' \
      'dump-keys[dump store keys]' \
      'dump-paxos[dump Paxos transactions]' \
      'dump-trace[dump contents of a trace file]' \
      'replay-trace[replay trace from a file]' \
      'random-gen[add randomly generated ops to the store]' \
      'rewrite-crush[add a rewrite commit to the store]' \
      'rebuild[rebuild the store]' && ret=0
    ;;
esac

return ret
