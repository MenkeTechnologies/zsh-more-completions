#compdef lutris

# Zsh completion for lutris - open gaming platform

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-d --debug)'{-d,--debug}'[show debug messages]' \
  '(-i --install)'{-i,--install}'[install a game from a YAML file]:file:_files -g "*.y(a|)ml"' \
  '(-b --output-script)'{-b,--output-script}'[output the install script]:file:_files' \
  '(-e --exec)'{-e,--exec}'[execute a program with the Lutris runtime]:command:_command_names -e' \
  '(-l --list-games)'{-l,--list-games}'[list all games in the library]' \
  '(-o --installed)'{-o,--installed}'[only list installed games]' \
  '(-s --list-steam-games)'{-s,--list-steam-games}'[list Steam games]' \
  '--list-steam-folders[list Steam library folders]' \
  '(-j --json)'{-j,--json}'[display output in JSON format]' \
  '--reinstall[reinstall game]' \
  '-r+[remove a game]:game slug' \
  '--remove[remove a game]:game slug' \
  '--export[export game]:game slug' \
  '--import[import a game]:file:_files' \
  '--dest[set install destination]:directory:_directories' \
  '*:URI or game slug:' && ret=0

return ret
