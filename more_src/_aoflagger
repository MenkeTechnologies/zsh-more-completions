#compdef aoflagger
# Documentation: https://aoflagger.readthedocs.io/en/latest/using_aoflagger.html
# Reference accessed: 2026-05-29
# RFI (Radio Frequency Interference) flagger for radio astronomy (Andre Offringa).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-direct-read -reorder -memory-read -auto-read-mode)-direct-read[read data on-demand (slow, repeated scans)]' \
  '(-direct-read -reorder -memory-read -auto-read-mode)-reorder[reorder measurement set to disk (formerly indirect mode)]' \
  '(-direct-read -reorder -memory-read -auto-read-mode)-memory-read[fastest mode; only for MS that fits in RAM]' \
  '(-direct-read -reorder -memory-read -auto-read-mode)-auto-read-mode[choose reorder or memory based on RAM (default)]' \
  '-v[verbose: display progress information]' \
  '-strategy[use specified Lua strategy file]:file:_files -g "*.lua"' \
  '-column[data column to flag]:column:' \
  '-bands[bands to flag (comma-separated)]:bands:' \
  '-fields[fields to flag (comma-separated)]:fields:' \
  '-threshold-timestep-rfi[per-timestep RFI threshold]:value:' \
  '-threshold-channel-rfi[per-channel RFI threshold]:value:' \
  '-statistics[output flagging statistics]' \
  '-combine-spws[combine spectral windows]' \
  '-uvw[show baseline information]' \
  '-skip-flagged[skip already-flagged data]' \
  '*:measurement set:_files -/' && ret=0

return ret
