#compdef gromacs
# Documentation: https://man.archlinux.org/search?q=gromacs
# Reference accessed: 2026-05-16

# GROMACS: wrapper that invokes gmx (or its named subcommands)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-version[show version]' \
  '*::gmx command and args:_files' && ret=0
return ret
