# GROMACS gmx wrapper-level flags (recognized for any subcommand)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-help[show help]' \
  '-hidden[show developer-only options (with -h)]' \
  '-quiet[suppress standard output]' \
  '-nocopyright[omit copyright notice]' \
  '-version[show version]' \
  '-nice[set process priority]:nice:' \
  '*::gmx command and args:_files' && ret=0
return ret
