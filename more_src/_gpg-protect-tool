#compdef gpg-protect-tool
# Documentation: https://www.gnupg.org/documentation/manuals/gnupg/
# GnuPG: secret key maintenance tool

local ret=1

_arguments -s -S \
  '(-p --protect)'{-p,--protect}'[protect a private key]' \
  '(-u --unprotect)'{-u,--unprotect}'[unprotect a private key]' \
  '--shadow[create a shadow entry for a public key]' \
  '--show-shadow-info[return the shadow info]' \
  '--show-keygrip[show the keygrip]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-a --armor)'{-a,--armor}'[write output in advanced format]' \
  '--canonical[write output in canonical format]' \
  '(-P --passphrase)'{-P,--passphrase}'=[use passphrase STRING]:passphrase' \
  '--have-cert[certificate to export provided on STDIN]' \
  '--store[store the created key in the appropriate place]' \
  '--force[force overwriting]' \
  '--prompt=[use ESCSTRING as prompt in pinentry]:escstring' \
  '--version[print version information]' \
  '--help[show help]' \
  '*:arg:_default' && ret=0

return ret
