#compdef pushprox-client
# Documentation: https://github.com/prometheus-community/PushProx
# PushProx client that registers with the proxy and serves scrapes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--fqdn=[FQDN to register with]:fqdn' \
  '--proxy-url=[push proxy to talk to]:url' \
  '--tls.cacert=[CA certificate to verify peer against]:file:_files' \
  '--tls.cert=[client certificate file]:file:_files' \
  '--tls.key=[private key file]:file:_files' \
  '--metrics-addr=[serve Prometheus metrics at this address]:addr' \
  '--proxy.retry.initial-wait=[time to wait after proxy failure]:dur' \
  '--proxy.retry.max-wait=[max time to wait between proxy poll retries]:dur' && ret=0

return ret
