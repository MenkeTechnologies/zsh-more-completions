#compdef avahi-browse-cli
# _avahi-browse-cli — Avahi avahi-browse mDNS/DNS-SD service browser CLI alias (avahi team, C); custom argparse
# upstream: https://github.com/avahi/avahi

_avahi-browse-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-D[browse for domains]' \
        '--browse-domains[browse for domains]' \
        '-a[browse for all services]' \
        '--all[browse for all services]' \
        '-d+[domain]:str:' \
        '--domain=+[domain]:str:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-t[terminate after dumping cache]' \
        '--terminate[terminate after dumping cache]' \
        '-c[terminate after dumping cache]' \
        '--cache[terminate after dumping cache]' \
        '-l[ignore local services]' \
        '--ignore-local[ignore local services]' \
        '-r[resolve services]' \
        '--resolve[resolve services]' \
        '-f[fail if daemon not running]' \
        '--fail[fail if daemon not running]' \
        '-p[parsable output]' \
        '--parsable[parsable output]' \
        '-k[do not connect to daemon, do not subscribe]' \
        '--no-db-lookup[do not connect to daemon, do not subscribe]' \
        '*:service-type:'
}

_avahi-browse-cli "$@"
