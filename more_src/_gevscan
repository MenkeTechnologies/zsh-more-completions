#compdef gevscan
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/Apps/gEvScan.cxx
# gevscan - GENIE utility to scan event samples for problematic events

local ret=1

_arguments -s -S \
  '-f[input GHEP event file]:file:_files' \
  '-o[output error log filename]:outfile:_files' \
  '-n[event range: single event or nev1[,nev2]]:nrange:' \
  '--add-event-printout-in-error-log[include event details in error log output]' \
  '--max-num-of-errors-shown[maximum number of errors to display]:num:' \
  '--event-record-print-level[verbosity for event record output]:level:' \
  '--check-energy-momentum-conservation[verify energy and momentum are conserved]' \
  '--check-charge-conservation[verify electric charge is conserved]' \
  '--check-for-pseudoparticles-in-final-state[detect pseudo-particles in final state]' \
  '--check-for-off-mass-shell-particles-in-final-state[detect off-shell particles in final state]' \
  '--check-for-num-of-final-state-nucleons-inconsistent-with-target[verify nucleon counts match target]' \
  '--check-vertex-distribution[analyze intra-nuclear vertex positions]' \
  '--check-decayer-consistency[verify particle decay consistency across events]' \
  '--all[execute all available checks]' \
  '*: :_files' && ret=0

return ret
