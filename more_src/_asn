#compdef asn

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-n[disable colorized output]' \
  '-d[enable debug mode]' \
  '-j[JSON output]' \
  '-J[prettified JSON output]' \
  '-c[compact output]' \
  '-o+[open ASN/IP info in browser]:target:' \
  '-s+[server for WHOIS lookups]:server:' \
  '-i[display info for an IP address or CIDR]' \
  '-t[perform traceroute with ASN lookup]' \
  '-u[perform MTR with ASN lookup]' \
  '-g[display IP geolocation info]' \
  '-l[lookup AS name for ASN]' \
  '-p[display AS peers]' \
  '-a[display AS announced prefixes]' \
  '-x[display IX presence]' \
  '-r[display reverse DNS]' \
  '-f[display firewall rules for an AS]' \
  '-m+[specify MTU for traceroute]:MTU:' \
  '-w+[timeout for queries]:seconds:' \
  '*:IP address, ASN, or hostname:_hosts' && ret=0

return ret
