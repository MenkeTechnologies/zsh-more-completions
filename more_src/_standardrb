#compdef standardrb standard

# Zsh completion for standardrb (Standard Ruby style linter/formatter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--fix[auto-fix violations]' \
  '--no-fix[do not auto-fix violations]' \
  '--format=[output format]:format:(progress simple clang json offenses worst tap junit html github markdown quiet emacs files pacman fuubar)' \
  '--only=[run only specified cop]:cop' \
  '--except=[exclude specified cop]:cop' \
  '--fix-unsafely[apply unsafe auto-corrections]' \
  '--stdin=[read source from stdin, using FILE for path]:file:_files' \
  '--generate-todo[generate a .standard_todo.yml file]' \
  '--todo[load .standard_todo.yml if it exists]' \
  '--no-cache[do not use cache]' \
  '--cache[use cache]' \
  '*:files:_files -g "*.rb"' && ret=0

return ret
