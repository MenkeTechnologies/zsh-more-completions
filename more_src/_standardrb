#compdef standardrb standard
# Documentation: https://github.com/standardrb/standard
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Standard Ruby style linter/formatter. Forwards most CLI args to RuboCop.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show Standard version]' \
  '(- *)'{-V,--verbose-version}'[show Standard and dependency versions]' \
  '--fix[apply auto-fixes that should not break code]' \
  '--no-fix[disable automatic fixing]' \
  '--fix-unsafely[apply auto-fixes that may change code behavior]' \
  '--format=[output formatter (any RuboCop formatter)]:format:(progress simple clang json offenses worst tap junit html github markdown quiet emacs files pacman fuubar)' \
  '--generate-todo[create .standard_todo.yml listing files with errors]' \
  '--lsp[start a Language Server Protocol server on STDIN]' \
  '*:files:_files -g "*.rb"' && ret=0

return ret
