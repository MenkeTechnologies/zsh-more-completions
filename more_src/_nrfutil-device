#compdef nrfutil-device
# Documentation: https://docs.nordicsemi.com/bundle/nrfutil/page/nrfutil-device/nrfutil-device_2.13.0.html
# nrfutil device - list, program, erase, reset and recover Nordic devices

local ret=1
local context state line
typeset -A opt_args

_nrfutil_device_cmds() {
  local -a cmds
  cmds=(
    'list:list connected devices'
    'program:program firmware onto a device'
    'reset:reset a device'
    'recover:erase all user-available flash and unlock the device'
    'erase:erase the device flash'
    'fw-read:read firmware from a device'
  )
  _describe -t commands 'nrfutil device command' cmds
}

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--serial-number=[target device by serial number]:serial:' \
  '--traits=[select devices by traits]:traits:' \
  '--core=[target a specific core]:core:' \
  '--log-level=[log level]:level:(off error warn info debug trace)' \
  '--json[output in JSON format]' \
  '1: :_nrfutil_device_cmds' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $line[1] in
      program)
        _arguments -s -S \
          '--firmware=[firmware file to program]:file:_files' \
          '--options=[programming options]:options:' \
          '--verify=[verification method]:verify:' \
          '--reset-kind=[reset to perform after programming]:kind:' \
          '--serial-number=[target device serial number]:serial:' \
          '--core=[target core]:core:' && ret=0
        ;;
      reset)
        _arguments -s -S \
          '--reset-kind=[kind of reset to perform]:kind:' \
          '--serial-number=[target device serial number]:serial:' && ret=0
        ;;
      *)
        _arguments -s -S \
          '--serial-number=[target device serial number]:serial:' \
          '--json[output in JSON format]' && ret=0
        ;;
    esac
    ;;
esac

return ret
