#compdef chronos
# Documentation: https://mesos.github.io/chronos/docs/configuration.html
# Chronos: fault-tolerant job scheduler for Apache Mesos

local ret=1

_arguments -s \
  '--http_port=[port to listen on for HTTP requests]:port:' \
  '--https_port=[port to listen on for HTTPS requests]:port:' \
  '--master=[URL of the Mesos master]:url:' \
  '--zk_hosts=[list of ZooKeeper servers for storing state]:hosts:' \
  '--zk_path=[path in ZooKeeper for storing state]:path:' \
  '--hostname=[advertised hostname for this Chronos instance]:hostname:_hosts' \
  '--mail_from=[mail from field]:address:' \
  '--mail_server=[mailserver in server:port format]:server:' \
  '--mail_user=[mail user for auth]:user:' \
  '--mail_password=[mail password for auth]:password:' \
  '--mail_ssl[use SSL for mail]' \
  '--user=[the chronos user to run processes under]:user:_users' \
  '--failover_timeout=[failover timeout in seconds for Mesos]:seconds:' \
  '--leader_max_idle_time=[look-ahead time for scheduling tasks (ms)]:ms:' \
  '--task_epsilon=[default epsilon value for tasks (seconds)]:seconds:' \
  '--cluster_name=[name of the cluster where Chronos runs]:name:' \
  '--slack_url=[webhook URL for posting to Slack]:url:' \
  '--ssl_keystore_path=[path to SSL keystore (enables HTTPS)]:file:_files' \
  '--ssl_keystore_password=[password for the SSL keystore]:password:' \
  '--mesos_task_cpu=[CPUs to request from Mesos per task]:cpus:' \
  '--mesos_task_mem=[memory to request from Mesos per task (MB)]:mb:' \
  '--mesos_task_disk=[disk to request from Mesos per task (MB)]:mb:' \
  '--mesos_authentication_principal=[Mesos authentication principal]:principal:' \
  '--disable_after_failures=[disable a job after this many failures]:count:' \
  '--decline_offer_duration=[duration to decline offers by default (ms)]:ms:' && ret=0

return ret
