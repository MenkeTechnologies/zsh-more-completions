#compdef litecli

# Zsh completion for litecli - a user-friendly SQLite CLI with autocompletion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-e --execute)'{-e,--execute}'[execute command and quit]:command:' \
  '(-D --database)'{-D,--database}'[database to open]:database file:_files -g "*.db"' \
  '--liteclirc=[set config file path]:config file:_files' \
  '(-t --table)'{-t,--table}'[display output in table format]' \
  '--csv[display output in CSV format]' \
  '(-l --line)'{-l,--line}'[display output in line format]' \
  '--prompt=[set custom prompt]:prompt:' \
  '--logfile=[set log file path]:file:_files' \
  '--auto-vertical-output[auto switch to vertical output for wide results]' \
  '--login-path=[set login path]:path:' \
  '*:database file:_files -g "*.(db|sqlite|sqlite3)"' && ret=0

return ret
