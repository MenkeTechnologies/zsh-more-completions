#compdef t1dotlessj
# Documentation: t1dotlessj --help (lcdf-typetools)
# Source: lcdf-typetools t1dotlessj — derive a dotlessj Type 1 font from a j-containing font.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a --pfa -b --pfb)'{-a,--pfa}'[output PFA font]' \
    '(-a --pfa -b --pfb)'{-b,--pfb}'[output PFB font (default)]' \
    '(-o --output)'{-o,--output=}'[output file]:file:_files' \
    '(-n --name)'{-n,--name=}'[output PostScript name]:name:' \
    '(- *)'{-h,--help}'[show help]' \
    '(-q --quiet)'{-q,--quiet}'[no errors to stderr]' \
    '(- *)--version[show version]' \
    '1:Type 1 font (PFA / PFB):_files -g "*.{pfa,pfb}"' \
    '2:output dotlessj font:_files' \
    && ret=0

return ret
