#compdef httprobe

# Zsh completion for httprobe - take a list of domains and probe for HTTP/HTTPS

_arguments -s -S \
  '-c+[set the concurrency level (default 50)]:count:' \
  '-p+[add additional probe (scheme:port)]:probe:' \
  '-s[skip the default probes (http:80 and https:443)]' \
  '-t+[timeout for the HTTP requests (milliseconds)]:timeout:' \
  '--prefer-https[only try plain HTTP if HTTPS fails]'
