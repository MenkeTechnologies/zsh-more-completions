#compdef ambmask
# Documentation: https://ambermd.org/doc12/AmberTools13.pdf
# Test and validate Amber atom-mask expressions (AmberTools)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-p[prmtop topology file]:prmtop:_files' \
  '-c[coordinate/restart (inpcrd) file]:coords:_files' \
  '-out[output format: short pdb amber elem]:format:(short pdb amber elem)' \
  '-find[atom-mask expression to evaluate]:mask' \
  '-prnlev[print/verbosity level]:level' \
  '-v[verbose output]' && ret=0

return ret
