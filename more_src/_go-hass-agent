#compdef go-hass-agent
# Documentation: https://github.com/joshuar/go-hass-agent
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# go-hass-agent: Home Assistant device agent (joshuar/go-hass-agent).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'register:register the agent with Home Assistant'
  'config:configure agent settings'
  'run:run the agent'
  'version:show version'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'go-hass-agent command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (register)
        _arguments \
          '--token=[registration token]:token:' \
          '--server=[Home Assistant server URL]:url:' \
          '--force[force re-registration]' && ret=0 ;;
      (config)
        _arguments \
          '--mqtt-server=[MQTT server URL]:url:' \
          '--mqtt-user=[MQTT username]:user:' \
          '--mqtt-password=[MQTT password]:password:' \
          '--no-mqtt-enabled[disable MQTT]' \
          '--server-hostname=[web server hostname]:host:' \
          '--server-port=[web server port]:port:' \
          '--server-https-cert=[TLS certificate]:file:_files' \
          '--server-https-key=[TLS private key]:file:_files' && ret=0 ;;
    esac ;;
esac

return ret
