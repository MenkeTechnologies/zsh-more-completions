#compdef tidb-benchraw
# _tidb-benchraw — TiDB raw KV benchmark (rawkv with optional mTLS)
# upstream: https://github.com/pingcap/tidb
# Flags from cmd/benchraw/main.go on tip.

_tidb-benchraw() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-N=[data row count]:n:' \
        '-C=[concurrent workers]:n:' \
        '-pd=[PD address]:host\:port:' \
        '-V=[value byte size]:n:' \
        '-cacert=[trusted CA cert file (PEM)]:file:_files' \
        '-cert=[client X509 cert file (PEM)]:file:_files' \
        '-key=[client X509 key file (PEM)]:file:_files'
}

_tidb-benchraw "$@"
