#compdef vcfgeno2haplo
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfgeno2haplo.md
# Convert genotype-based records to haplotype alleles within a window

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-r --reference)'{-r,--reference}'[FASTA reference file]:FASTA file:_files' \
  '(-w --window-size)'{-w,--window-size}'[merge variants at most this many bp apart (default 30)]:bp' \
  '(-o --only-variants)'{-o,--only-variants}'[concatenate REF/ALT strings instead of the whole haplotype]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
