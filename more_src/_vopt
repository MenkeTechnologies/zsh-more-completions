#compdef vopt
# _vopt — Mentor Siemens EDA ModelSim/Questa vopt CLI performing global optimization on compiled Verilog/VHDL design units flattening hierarchy preserving signals annotating SDF generating optimized snapshot for high-performance vsim runs (Siemens team, C++); custom argparse
# upstream: https://eda.sw.siemens.com/en-US/ic/questa/simulation/advanced-simulator/

_vopt() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-modelsimini=+[ini file]:file:_files -g "*.ini"' \
        '-o+[output design]:str:' \
        '-L+[library]:str:' \
        '-Lf+[library]:str:' \
        '-work=+[lib]:str:' \
        '-quiet[quiet]' \
        '-verbose[verbose]' \
        '-stats=+[s]:s:(none all time perf)' \
        '+acc[full signal access]' \
        '+acc=+[level]:l:(a b c d e f h i l m n p r s t u v w)' \
        '+nocover[no coverage]' \
        '+cover[enable coverage]' \
        '+cover=+[t]:t:(bcestf)' \
        '+notimingchecks[disable timing checks]' \
        '-novopt[disable vopt]' \
        '-optimize[force optimize]' \
        '-debugdb=+[file]:file:_files' \
        '-fsmverbose[fsm verbose]' \
        '-c[command line]' \
        '-do=+[script]:file:_files' \
        '-suppress=+[msg ids]:str:' \
        '-error=+[msg ids]:str:' \
        '-warning=+[msg ids]:str:' \
        '-permit_unmatched_virtual_intf[permit unmatched virtual intf]' \
        '-debugMode[debug mode]' \
        '-floatgenerics+[name]:str:' \
        '-pdufile=+[file]:file:_files' \
        '-mfcu[merge file compilation unit]' \
        '*:design unit:'
}

_vopt "$@"
