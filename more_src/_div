#compdef div
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss38.html
# KAPPA: divide one NDF data structure by another

local ret=1

_arguments -s \
  'IN1=[first NDF, to be divided]:NDF:_files' \
  'IN2=[second NDF, divided into the first]:NDF:_files' \
  'OUT=[output ratio NDF]:NDF:_files' \
  'TITLE=[title for the output NDF]:title' \
  '*:NDF:_files' && ret=0

return ret
