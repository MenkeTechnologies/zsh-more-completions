#compdef nbdsh
# Documentation: https://libguestfs.org/nbdsh.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '--base-allocation[request base:allocation meta context]' \
  '*'{-c,--command=}'[execute command]:cmd:' \
  '-n[do not create implicit handle]' \
  '--opt-mode[enable option mode]' \
  '(-u --uri)'{-u,--uri=}'[NBD URI]:uri:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(- *)'{-V,--version}'[show version]'
