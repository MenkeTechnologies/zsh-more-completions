#compdef cgmanager-proxy
# Documentation: https://man.archlinux.org/search?q=cgmanager-proxy
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-s --syslog)'{-s,--syslog}'[log to syslog]' && ret=0

return ret
