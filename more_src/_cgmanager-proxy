#compdef cgmanager-proxy
# Documentation: https://github.com/lxc/cgmanager
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (project archived/deprecated 2020).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-s --syslog)'{-s,--syslog}'[log to syslog]' && ret=0

return ret
