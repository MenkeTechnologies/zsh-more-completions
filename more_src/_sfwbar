#compdef sfwbar
# Documentation: https://man.archlinux.org/search?q=sfwbar
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'-h'[show help]' \
  '(- *)'-v'[show version]' \
  '-f[specify config file]:config file:_files' \
  '-c[specify CSS file]:CSS file:_files' \
  '-m[specify monitor name]:monitor name' \
  '-d[set debug level]:debug level'
