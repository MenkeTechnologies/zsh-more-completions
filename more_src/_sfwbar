#compdef sfwbar
# Documentation: https://github.com/LBCrion/sfwbar
# Reference accessed: 2026-05-21
# Verified: upstream src/sfwbar.c GOptionEntry table.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --config)'{-f+,--config=}'[specify config file]:config file:_files' \
  '(-c --css)'{-c+,--css=}'[specify CSS file]:CSS file:_files' \
  '(-s --socket)'{-s+,--socket=}'[specify compositor IPC socket file]:socket:_files' \
  '(-d --debug)'{-d,--debug}'[display debug info]' \
  '(-g --debug-filter)'{-g+,--debug-filter=}'[filter debug output for a pattern]:pattern:' \
  '(-m --monitor)'{-m+,--monitor=}'[monitor to display the panel on]:monitor:' \
  '(-b --bar_id)'{-b+,--bar_id=}'[default sway bar_id to listen on for sway events]:bar id:'
