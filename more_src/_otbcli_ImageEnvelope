#compdef otbcli_ImageEnvelope
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ImageEnvelope.html
# Orfeo ToolBox: compute a vector data envelope of an image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image filename]:image:_files' \
  '-out[output vector data envelope]:output:_files' \
  '-sr[sampling rate for image edges in pixels]:value:' \
  '-elev.dem[directory containing DEM files]:dir:_files -/' \
  '-elev.geoid[geoid grid file]:file:_files' \
  '-elev.default[default height above ellipsoid]:value:' \
  '-proj[projection for envelope computation]:proj:' \
  '*::arg:_files' && ret=0

return ret
