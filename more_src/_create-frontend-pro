#compdef create-frontend-pro
# Documentation: https://www.npmjs.com/package/create-frontend-pro
# Reference accessed: 2026-05-23
# Verified: npm view create-frontend-pro bin; npm readme Command Line Options section.

# Zsh completion for create-frontend-pro - Next.js and Vite React frontend scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--framework=[frontend framework]:framework:(next react-vite)' \
  '--name=[project name]:name:' \
  '--pm=[package manager]:manager:(npm pnpm yarn bun)' \
  '--typescript[generate TypeScript project]' \
  '--state=[state management]:state:(redux zustand none)' \
  '--ui=[UI library]:ui:(shadcn chakra mui antd headless)' \
  '--data=[data fetching layer]:data:(tanstack-query axios none)' \
  '--storybook[add Storybook configuration]' \
  '--vitest[add Vitest testing setup]' \
  '--husky[add Husky git hooks]' \
  '--install[auto-install dependencies after scaffold]' \
  ':project name:' && ret=0

return ret
