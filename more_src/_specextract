#compdef specextract
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/specextract.html
# Create source and optional background spectra for Chandra imaging-mode data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[the source event file(s)]:file:_files' \
  'outroot=[root for the output filenames]:root:' \
  'bkgfile=[the background event file(s)]:file:_files' \
  'asp=[aspect solution or aspect histogram file(s)]:file:_files' \
  'dtffile=[the dead time factor file(s)]:file:_files' \
  'mskfile=[the detector mask file(s)]:file:_files' \
  'rmffile=[CALDB directive for RMF calibration]:rmffile:' \
  'badpixfile=[the bad pixel file(s)]:file:_files' \
  'dafile=[ACIS dead area coefficients file]:dafile:' \
  'bkgresp=[whether to write background responses]:bkgresp:(yes no)' \
  'weight=[generate weighted or unweighted ARFs]:weight:(yes no)' \
  'weight_rmf=[generate weighted or unweighted RMF files]:weight_rmf:(yes no)' \
  'resp_pos=[method to refine the unweighted response position]:resp_pos:' \
  'refcoord=[reference coordinates of unweighted response files]:refcoord:' \
  'correctpsf=[apply a point-source aperture correction]:correctpsf:(yes no)' \
  'combine=[combine output spectra and responses]:combine:(yes no)' \
  'readout_streakspec=[readout streak effective exposure time]:readout_streakspec:(yes no)' \
  'grouptype=[source spectrum grouping type]:grouptype:' \
  'binspec=[source spectrum grouping specification]:binspec:' \
  'bkg_grouptype=[background spectrum grouping type]:bkg_grouptype:' \
  'bkg_binspec=[background spectrum grouping specification]:bkg_binspec:' \
  'energy=[energy grid in keV]:energy:' \
  'channel=[RMF binning specification in pixels]:channel:' \
  'energy_wmap=[energy range for WMAPs]:energy_wmap:' \
  'binarfcorr=[detector pixel bin size for arfcorr PSF correction]:binarfcorr:' \
  'binwmap=[binning factor for RMF WMAPs]:binwmap:' \
  'binarfwmap=[binning factor for ARF WMAPs]:binarfwmap:' \
  'parallel=[run processes in parallel]:parallel:(yes no)' \
  'nproc=[number of processors to use]:nproc:' \
  'tmpdir=[directory for temporary files]:dir:_files -/' \
  'clobber=[overwrite existing output file]:clobber:(yes no)' \
  'verbose=[level of verbosity]:verbose:(0 1 2 3 4 5)' && ret=0

return ret
