#compdef ship-js

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'prepare:prepare a release'
  'trigger:trigger a release from CI'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ship-js command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (prepare)
        _arguments \
          '-d+[base directory]:directory:_directories' \
          '--dir=[base directory]:directory:_directories' \
          '-y[skip confirmation prompts]' \
          '--yes[skip confirmation prompts]' \
          '--no-browse[do not open browser]' \
          '--dry-run[dry run without making changes]' \
          '--first-release[first release (no changelog diff)]' && ret=0
        ;;
      (trigger)
        _arguments \
          '-d+[base directory]:directory:_directories' \
          '--dir=[base directory]:directory:_directories' \
          '--dry-run[dry run without making changes]' && ret=0
        ;;
    esac
    ;;
esac

return ret
