#compdef xpkgdiff
# Documentation: https://man.voidlinux.org/xtools.1
# compare a package in the repositories to the locally-built version (xtools)

local ret=1

_arguments -s -S \
  '-S[do not strip files before comparing]' \
  '-f[force comparison]' \
  '-r[use given repository]:repository:' \
  '-x[use given diff command]:command:' \
  '-t[keep temporary files]' \
  '-a[compare all subpackages]' \
  '-R[use remote repositories]' \
  '-c[colorize output]' \
  '-p[use given pager]:pager:' \
  '*:package:' && ret=0

return ret
