#compdef exoscale-cli
# Documentation: https://github.com/exoscale/cli
# Reference accessed: 2026-05-27
# Verified: upstream cmd/root.go, cmd/subcommands/init.go, and cmd/*.go top-level command files (exoscale/cli)
# Note: the upstream binary is `exo`. Existing _exo and _exoscale completions cover the canonical names;
#       this file targets the alternate package/distribution name `exoscale-cli` only.

local curcontext="$curcontext" state line ret=1
local -a _exo_subcommands

_exo_subcommands=(
  'compute:compute services management (instances, SKS, load balancers, networking, SSH keys)'
  'dbaas:managed database services (MySQL, PostgreSQL, Kafka, OpenSearch, Grafana, Valkey, Thanos)'
  'dns:DNS domain and record management'
  'iam:identity and access management (API keys, roles, organization policy)'
  'storage:object storage operations (S3-compatible buckets and objects)'
  'aiservices:AI services management'
  'config:manage CLI configuration accounts'
  'integrations:external tooling integrations (fig, etc.)'
  'limits:show current account limits'
  'output:show output format reference'
  'status:show Exoscale status page information'
  'version:print the version of exo'
  'x:experimental raw API access (alias: api)'
  'zone:list all available zones'
)

_arguments -C \
  '(-C --config)'{-C+,--config=}'[specify an alternate config file]:file:_files' \
  '(-A --use-account)'{-A+,--use-account=}'[account to use in config file]:account:' \
  '(-O --output-format)'{-O+,--output-format=}'[output format]:format:(table json text)' \
  '--output-template=[template to use when output-format is text]:template:' \
  '(-Q --quiet)'{-Q,--quiet}'[quiet mode, disable non-essential output]' \
  '--timeout=[per-zone timeout for list operations, e.g. 15s; -1s disables]:duration:' \
  '(-h --help)'{-h,--help}'[help for exo]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'exo subcommand' _exo_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      compute)
        local -a _compute_sub
        _compute_sub=(
          'anti-affinity-group:manage anti-affinity groups'
          'block-storage:manage block storage volumes'
          'deploy-target:manage deploy targets'
          'elastic-ip:manage elastic IP addresses'
          'instance:manage compute instances'
          'instance-pool:manage instance pools'
          'instance-template:manage instance templates'
          'instance-type:list compute instance types'
          'load-balancer:manage network load balancers'
          'private-network:manage private networks'
          'security-group:manage security groups and rules'
          'sks:manage Scalable Kubernetes Service clusters'
          'ssh-key:manage SSH keys'
        )
        _describe -t commands 'compute subcommand' _compute_sub && ret=0
        ;;
      dbaas)
        local -a _dbaas_sub
        _dbaas_sub=(
          'create:create a managed database service'
          'delete:delete a managed database service'
          'list:list managed database services'
          'show:show database service details'
          'update:update a managed database service'
          'logs:show service logs'
          'metrics:show service metrics'
          'migration:manage database migrations'
          'database:manage logical databases on a service'
          'external-endpoint:manage external endpoints for service integrations'
          'ca-certificate:fetch database service CA certificate'
          'type:show supported database service types'
          'user:manage database service users'
          'task:show database service tasks'
        )
        _describe -t commands 'dbaas subcommand' _dbaas_sub && ret=0
        ;;
      dns)
        local -a _dns_sub
        _dns_sub=(
          'add:add a DNS record to a domain'
          'create:create a new DNS domain'
          'delete:delete a DNS domain'
          'list:list DNS domains or records'
          'remove:remove a DNS record from a domain'
          'show:show DNS domain or record details'
          'update:update a DNS record'
        )
        _describe -t commands 'dns subcommand' _dns_sub && ret=0
        ;;
      iam)
        local -a _iam_sub
        _iam_sub=(
          'api-key:manage IAM API keys'
          'org-policy:manage organization-wide IAM policy'
          'role:manage IAM roles'
        )
        _describe -t commands 'iam subcommand' _iam_sub && ret=0
        ;;
      storage)
        local -a _storage_sub
        _storage_sub=(
          'bucket:manage object storage buckets'
          'cors:manage bucket CORS configuration'
          'delete:delete an object'
          'download:download an object from a bucket'
          'headers:manage object headers'
          'list:list objects in a bucket'
          'mb:make a new bucket'
          'metadata:manage object metadata'
          'presign:generate a presigned URL for an object'
          'purge:purge all objects from a bucket'
          'rb:remove a bucket'
          'setacl:set the ACL of a bucket or object'
          'show:show bucket or object details'
          'upload:upload a file as an object'
        )
        _describe -t commands 'storage subcommand' _storage_sub && ret=0
        ;;
      config)
        local -a _config_sub
        _config_sub=(
          'add:add a new account to the configuration'
          'delete:delete an account from the configuration'
          'list:list configured accounts'
          'set:set the active account'
          'show:show the active account configuration'
        )
        _describe -t commands 'config subcommand' _config_sub && ret=0
        ;;
      aiservices)
        local -a _ai_sub
        _ai_sub=(
          'deployment:manage AI service deployments'
          'model:manage available AI models'
        )
        _describe -t commands 'aiservices subcommand' _ai_sub && ret=0
        ;;
      *)
        _arguments '*:argument:' && ret=0
        ;;
    esac
    ;;
esac

return ret
