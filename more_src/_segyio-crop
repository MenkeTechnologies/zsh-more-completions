#compdef segyio-crop
# Documentation: https://github.com/equinor/segyio/blob/main/applications/segyio-crop.c
# segyio: copy a sub cube from SRC to DST

local ret=1

_arguments -s -S \
  '(-i --iline-begin --inline-begin)'{-i,--iline-begin=,--inline-begin=}'[inline to copy from]:line' \
  '(-I --iline-end --inline-end)'{-I,--iline-end=,--inline-end=}'[inline to copy to (inclusive)]:line' \
  '(-x --xline-begin --crossline-begin)'{-x,--xline-begin=,--crossline-begin=}'[crossline to copy from]:line' \
  '(-X --xline-end --crossline-end)'{-X,--xline-end=,--crossline-end=}'[crossline to copy to (inclusive)]:line' \
  '(-s --sample-begin)'{-s,--sample-begin=}'[measurement to copy from]:time' \
  '(-S --sample-end)'{-S,--sample-end=}'[measurement to copy to (inclusive)]:time' \
  '(-f --format)'{-f,--format=}'[override sample format]:format:(ibm ieee short long char)' \
  '(-b --il)'{-b,--il=}'[inline header word byte offset]:offset' \
  '(-B --xl)'{-B,--xl=}'[crossline header word byte offset]:offset' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--version[output version information and exit]' \
  '--help[display this help and exit]' \
  '*:SEG-Y file:_files' && ret=0

return ret
