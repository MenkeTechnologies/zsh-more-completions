#compdef annotateBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/annotate.html
# annotate coverage of features from multiple files (bedtools annotate)

local ret=1

_arguments -s -S \
  '-i[input file to be annotated]:file:_files' \
  '*-files[annotation files for overlap detection]:file:_files' \
  '*-names[names to describe each file]:name' \
  '-counts[report count of overlapping features per file]' \
  '-both[report count followed by percent coverage]' \
  '-s[force strandedness (same strand)]' \
  '-S[require opposite strandedness]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
