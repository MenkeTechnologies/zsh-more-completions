#compdef egctl

# envoyproxy/gateway cmd/egctl (cobra); Homebrew: Formula/e/egctl.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(*)'--kubeconfig='[kubeconfig path]:kubeconfig:_files' \
  '--kube-context=[kubectl context]:context:' \
  '(*)'--namespace='[namespace]:namespace:' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'egctl command' compadd -- experimental translate xinstall dashboard infrastructure proxy ratelimit env stats shutdown upgrade apply delete get install create wait version
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
