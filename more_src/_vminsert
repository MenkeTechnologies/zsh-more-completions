#compdef vminsert

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '*-storageNode=[storage node addr]:addr:' \
  '-httpListenAddr=[HTTP listen addr]:addr:' \
  '-clusternativeListenAddr=[cluster-native listen addr]:addr:' \
  '-disableReroutingOnUnavailable[disable rerouting on unavailable]' \
  '-relabelConfig=[relabel config file]:file:_files' \
  '-tls[enable TLS]' \
  '-tlsCertFile=[TLS cert]:file:_files' \
  '-tlsKeyFile=[TLS key]:file:_files' \
  '-mtls[enable mTLS]' \
  '-mtlsCAFile=[mTLS CA file]:file:_files' \
  '-cluster.tls[enable cluster TLS]' \
  '-cluster.tlsCertFile=[cluster TLS cert]:file:_files' \
  '-cluster.tlsKeyFile=[cluster TLS key]:file:_files' \
  '-cluster.tlsCAFile=[cluster TLS CA]:file:_files' \
  '-storageNode.discoveryInterval=[storage node discovery interval]:duration:' \
  '-storageNode.filter=[storage node filter]:filter:' \
  '-loggerLevel=[log level]:level:(INFO WARN ERROR FATAL PANIC)' \
  '-loggerFormat=[log format]:format:(default json)'
