#compdef clearml clearml-session clearml-serving
# Documentation: https://github.com/allegroai/clearml
# Reference accessed: 2026-05-27
# Verified: upstream clearml/cli/{config,data,task,hpo,debug}/__main__.py,
# allegroai/clearml-agent clearml_agent/interface/{__init__,worker}.py,
# allegroai/clearml-session clearml_session/__main__.py,
# allegroai/clearml-serving clearml_serving/__main__.py.

# Zsh completion for ClearML / Allegro AI package CLIs.
# Dispatches on $service so a single file covers every clearml-* entry point.

local curcontext="$curcontext" state line ret=1

# Top-level "clearml" itself has no subcommands - it's a no-op metapackage in
# CLI form. The real work happens in the clearml-* binaries below.
case $service in
  clearml)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' && ret=0
    return ret
    ;;
  clearml-init)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show clearml-init version]' \
      '(-F --file)'{-F+,--file=}'[target configuration file path]:file:_files' && ret=0
    return ret
    ;;
  clearml-task)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--version[display the clearml-task utility version]' \
      '--project=[project name for the task]:project:' \
      '--name=[name for the remote task]:name:' \
      '*--tags=[tags to add to the new Task]:tag:' \
      '--repo=[remote repository URL]:url:' \
      '--branch=[repository branch or tag]:branch:' \
      '--commit=[specific commit id]:commit:' \
      '--folder=[local folder to execute remotely]:dir:_directories' \
      '--script=[entry point script]:file:_files' \
      '--binary=[binary used to launch entry point]:binary:' \
      '--module=[python module to execute]:module:' \
      '--cwd=[working directory]:dir:_directories' \
      '*--args=[args as key=value]:arg:' \
      '--queue=[queue to enqueue the Task on]:queue:' \
      '--requirements=[requirements.txt file]:file:_files -g "*.txt"' \
      '*--packages=[required packages list]:package:' \
      '--docker=[docker image to use]:image:' \
      '--docker_args=[docker run arguments]:args:' \
      '--docker_bash_setup_script=[docker bash setup script]:file:_files' \
      '--output-uri=[Task output_uri]:uri:' \
      '--task-type=[task type]:type:(training testing inference data_processing application monitor optimizer service qc custom)' \
      '--skip-task-init[do not auto-inject Task.init()]' \
      '--base-task-id=[clone existing task id]:id:' \
      '--import-offline-session=[offline session path]:path:_files' \
      '--force-no-requirements[do not install any requirements]' \
      '--skip-repo-detection[skip repo detection]' \
      '--skip-python-env-install[skip python env install]' && ret=0
    return ret
    ;;
  clearml-data)
    local -a _data_cmds
    _data_cmds=(
      'create:create a new dataset'
      'add:add files or links to the dataset'
      'set-description:set dataset description'
      'sync:sync a local folder with the dataset'
      'remove:remove files/links from the dataset'
      'upload:upload local dataset changes'
      'close:finalize and close the dataset'
      'publish:publish dataset task'
      'delete:delete a dataset'
      'rename:rename a dataset'
      'move:move a dataset to another project'
      'compare:compare two datasets'
      'search:search datasets'
      'verify:verify local dataset content'
      'list:list dataset content'
      'get:get a local copy of a dataset'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '1: :->dcmd' \
      '*:: :->dargs' && ret=0
    case $state in
      dcmd) _describe -t commands 'clearml-data command' _data_cmds && ret=0 ;;
      dargs)
        case $line[1] in
          create)
            _arguments -s -S \
              '*--parents=[parent dataset IDs]:id:' \
              '--project=[dataset project name]:project:' \
              '--name=[dataset name]:name:' \
              '--version=[dataset version]:version:' \
              '--output-uri=[output URI (deprecated)]:uri:' \
              '--storage=[remote storage URI]:uri:' \
              '*--tags=[user tags]:tag:' && ret=0
            ;;
          add)
            _arguments -s -S \
              '--id=[dataset id]:id:' \
              '--dataset-folder=[dataset folder]:dir:' \
              '*--files=[files or folders to add]:file:_files' \
              '*--wildcard=[wildcard patterns]:pattern:' \
              '*--links=[remote links to add]:link:' \
              '--non-recursive[disable recursive scan]' \
              '--verbose[verbose reporting]' \
              '--max-workers=[thread count]:n:' && ret=0
            ;;
          sync)
            _arguments -s -S \
              '--id=[dataset id]:id:' \
              '--dataset-folder=[dataset folder]:dir:' \
              '--folder=[local folder to sync]:dir:_directories' \
              '--storage=[remote storage URI]:uri:' \
              '*--parents=[parent dataset IDs]:id:' \
              '--project=[dataset project name]:project:' \
              '--name=[dataset name]:name:' \
              '*--tags=[user tags]:tag:' \
              '--skip-close[do not close after sync]' \
              '--chunk-size=[chunk size in MB]:mb:' \
              '--verbose[verbose reporting]' && ret=0
            ;;
          remove)
            _arguments -s -S \
              '--id=[dataset id]:id:' \
              '*--files=[files to remove]:file:' \
              '--non-recursive[disable recursive scan]' \
              '--verbose[verbose reporting]' && ret=0
            ;;
          upload|close|publish)
            _arguments -s -S \
              '--id=[dataset id]:id:' \
              '--storage=[remote storage URI]:uri:' \
              '--chunk-size=[chunk size in MB]:mb:' \
              '--verbose[verbose reporting]' && ret=0
            ;;
          delete)
            _arguments -s -S \
              '--id=[dataset id]:id:' \
              '--project=[dataset project name]:project:' \
              '--name=[dataset name]:name:' \
              '--version=[dataset version]:version:' \
              '--force[force delete]' \
              '--entire-dataset[delete entire dataset and versions]' && ret=0
            ;;
          rename|move)
            _arguments -s -S \
              '--project=[dataset project name]:project:' \
              '--name=[dataset name]:name:' \
              '--new-name=[new name]:name:' \
              '--new-project=[new project]:project:' && ret=0
            ;;
          compare)
            _arguments -s -S \
              '--source=[source dataset id]:id:' \
              '--target=[target dataset id]:id:' \
              '--verbose[verbose reporting]' && ret=0
            ;;
          search)
            _arguments -s -S \
              '*--ids=[dataset IDs]:id:' \
              '--project=[project name]:project:' \
              '--name=[dataset name]:name:' \
              '*--tags=[tags]:tag:' && ret=0
            ;;
          verify)
            _arguments -s -S \
              '--id=[dataset id]:id:' \
              '--folder=[dataset folder]:dir:_directories' \
              '--filesize[verify file size]' \
              '--verbose[verbose reporting]' && ret=0
            ;;
          list)
            _arguments -s -S \
              '--id=[dataset id]:id:' \
              '--project=[project name]:project:' \
              '--name=[dataset name]:name:' \
              '--version=[dataset version]:version:' \
              '--filter=[name filter]:filter:' \
              '--modified[show modified only]' && ret=0
            ;;
          get)
            _arguments -s -S \
              '--id=[dataset id]:id:' \
              '--copy=[copy dataset to a writable folder]:dir:_directories' \
              '--link=[link dataset into folder]:dir:_directories' \
              '--part=[dataset part index]:n:' \
              '--num-parts=[number of dataset parts]:n:' \
              '--overwrite[overwrite existing target]' \
              '--verbose[verbose reporting]' && ret=0
            ;;
        esac
        ;;
    esac
    return ret
    ;;
  clearml-agent)
    local -a _agent_cmds
    _agent_cmds=(
      'init:configure clearml-agent and connect to ClearML server'
      'daemon:run as a persistent worker servicing a queue'
      'execute:build and execute a single task'
      'build:build a task environment (no execution)'
      'list:list available workers'
      'config:show or edit clearml-agent config'
      'config-utils:helpers for editing clearml.conf'
      'completion:generate shell completion'
      'help:show help'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '--config-file=[clearml.conf path]:file:_files -g "*.conf"' \
      '--debug[debug logging]' \
      '1: :->acmd' \
      '*:: :->aargs' && ret=0
    case $state in
      acmd) _describe -t commands 'clearml-agent command' _agent_cmds && ret=0 ;;
      aargs)
        case $line[1] in
          daemon)
            _arguments -s -S \
              '--foreground[stay in foreground]' \
              '--detached[run detached in background]' \
              '--stop[stop a running daemon]' \
              '*--queue=[queue(s) to service]:queue:' \
              '--order-fairness[fair queue order]' \
              '--standalone-mode[do not pull task code]' \
              '--services-mode=[number of services]:n:' \
              '--gpus=[GPU spec]:gpus:' \
              '--cpu-only[run on CPU only]' \
              '--docker=[Docker image to use]:image:' \
              '--force-current-version[use installed agent version inside docker]' \
              '--create-queue[create queue if missing]' \
              '--dynamic-gpus[support per-task GPU allocation]' \
              '--uptime=[uptime schedule]:schedule:' \
              '--downtime=[downtime schedule]:schedule:' \
              '--child-report-tags=[tags for child reports]:tags:' \
              '--use-owner-token[use task owner token]' && ret=0
            ;;
          execute|build)
            _arguments -s -S \
              '--id=[task id]:id:' \
              '--standalone-mode[do not pull task code]' \
              '--docker=[Docker image]:image:' \
              '--target=[target directory]:dir:_directories' \
              '--gpus=[GPU spec]:gpus:' \
              '--cpu-only[run on CPU only]' \
              '--log-level=[log level]:level:(DEBUG INFO WARN ERROR)' \
              '--disable-monitoring[disable resource monitoring]' \
              '--require-queue[require enqueued task]' && ret=0
            ;;
          init)
            _arguments -s -S '--detail[verbose init]' && ret=0 ;;
          list)
            _arguments -s -S '--detail[verbose listing]' && ret=0 ;;
          config)
            _arguments '*::sub:(edit get set unset show)' && ret=0 ;;
          completion)
            _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
        esac
        ;;
    esac
    return ret
    ;;
  clearml-session)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '--attach=[attach to a previously started session]:session_id:' \
      '(-S --shutdown)'{-S+,--shutdown=}'[shutdown a running session]:session_id:' \
      '--shell[start shell session]' \
      '--debugging-session=[debug an existing task id]:task_id:' \
      '--queue=[queue to launch in]:queue:' \
      '--router-enabled=[enable router]:value:(true false)' \
      '--docker=[docker image]:image:' \
      '--docker-args=[docker arguments]:args:' \
      '--public-ip=[obtain public ip]:value:(true false)' \
      '--remote-ssh-port=[remote SSH port]:port:' \
      '--vscode-server=[start VSCode server]:value:(true false)' \
      '--vscode-version=[VSCode version]:version:' \
      '--vscode-extensions=[VSCode extensions]:extensions:' \
      '--jupyter-lab=[start JupyterLab]:value:(true false)' \
      '--upload-files=[upload files]:files:_files' \
      '--continue-session=[continue a session]:session_id:' \
      '--store-workspace=[store workspace folder]:dir:_directories' \
      '--git-credentials=[forward git credentials]:value:(true false)' \
      '--user-folder=[user folder on remote]:dir:' \
      '*--packages=[required packages]:package:' \
      '--requirements=[requirements file]:file:_files -g "*.txt"' \
      '--init-script=[init script]:file:_files' \
      '--config-file=[session config file]:file:_files' \
      '--remote-gateway=[remote gateway]:gateway:' \
      '--base-task-id=[base task id]:id:' \
      '--project=[project name]:project:' \
      '--session-name=[session display name]:name:' \
      '*--session-tags=[session tags]:tag:' \
      '--disable-session-cleanup=[disable cleanup]:value:(true false)' \
      '--keepalive=[keepalive]:value:(true false)' \
      '*--queue-excluded-tag=[exclude tag from queue]:tag:' \
      '*--queue-include-tag=[include tag in queue]:tag:' \
      '--skip-docker-network=[skip docker network]:value:(true false)' \
      '--docker-network=[docker network mode]:mode:(host port)' \
      '--password=[session password]:password:' \
      '*--randomize=[randomize values]:value:' \
      '--username=[username]:user:' \
      '--force-dropbear=[force dropbear ssh]:value:(true false)' \
      '--disable-storage-packages=[disable storage packages]:value:(true false)' \
      '--disable-store-defaults[do not store new defaults]' \
      '--disable-fingerprint-check[disable SSH fingerprint check]' \
      '--verbose[verbose output]' \
      '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
      '1::action:(list info shutdown)' && ret=0
    return ret
    ;;
  clearml-serving)
    local -a _serving_cmds
    _serving_cmds=(
      'list:list running Serving Services'
      'create:create a new Serving Service'
      'config:configure a new Serving Service'
      'metrics:configure inference metrics service'
      'model:configure model endpoints for a running service'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--id=[serving service Task id]:id:' \
      '--verbose[verbose output]' \
      '*'{-y,--yes}'[answer yes to all prompts]' \
      '1: :->scmd' \
      '*:: :->sargs' && ret=0
    case $state in
      scmd) _describe -t commands 'clearml-serving command' _serving_cmds && ret=0 ;;
      sargs)
        case $line[1] in
          create)
            _arguments -s -S \
              '--name=[serving service name]:name:' \
              '--project=[project name]:project:' \
              '--tags=[tags]:tag:' && ret=0
            ;;
          metrics)
            _arguments '1::sub:(add remove list)' '*:: :_files' && ret=0 ;;
          model)
            _arguments '1::sub:(list remove upload canary auto-update add)' '*:: :_files' && ret=0 ;;
          config|list)
            _files
            ;;
        esac
        ;;
    esac
    return ret
    ;;
  clearml-param-search)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--project-name=[project name]:project:' \
      '--task-name=[optimization task name]:name:' \
      '--base-task-id=[base task id to optimize]:id:' \
      '--queue=[queue to enqueue optimization jobs on]:queue:' \
      '*--params-search=[hyper-parameter search spec JSON]:spec:' \
      '*--params-override=[parameter override JSON]:spec:' \
      '--objective-metric-title=[objective metric title]:title:' \
      '--objective-metric-series=[objective metric series]:series:' \
      '--objective-metric-sign=[objective metric sign]:sign:(min max min_global max_global)' \
      '--optimizer-class=[optimizer class]:class:' \
      '--optimization-time-limit=[optimization time limit in minutes]:minutes:' \
      '--compute-time-limit=[compute time limit in minutes]:minutes:' \
      '--pool-period-min=[pool period in minutes]:minutes:' \
      '--total-max-jobs=[total maximum jobs]:n:' \
      '--min-iteration-per-job=[minimum iterations per job]:n:' \
      '--max-iteration-per-job=[maximum iterations per job]:n:' \
      '--max-number-of-concurrent-tasks=[max concurrent tasks]:n:' \
      '--save-top-k-tasks-only=[keep top K tasks only]:n:' \
      '--time-limit-per-job=[time limit per job in minutes]:minutes:' \
      '--local-port=[local port for UI server]:port:' && ret=0
    return ret
    ;;
  clearml-debug)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '--task-id=[task id to debug]:id:' \
      '--folder=[output folder for debug data]:dir:_directories' \
      '--verbose[verbose output]' && ret=0
    return ret
    ;;
  *)
    _files
    ;;
esac

return ret
