#compdef borgmatic
# Documentation: https://man.archlinux.org/search?q=borgmatic
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'rcreate:create a new repository'
  'rdelete:delete a repository'
  'transfer:transfer archives between repos'
  'prune:prune old archives'
  'compact:compact unused data'
  'create:create a new archive'
  'check:check repository consistency'
  'extract:extract files from an archive'
  'config:configure'
  'export-tar:export archive as tar'
  'mount:mount archive'
  'umount:unmount archive'
  'restore:restore database dumps'
  'rlist:list archives'
  'list:list archive contents'
  'rinfo:show repo info'
  'info:show archive info'
  'break-lock:break repo lock'
  'borg:run a borg command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*-c+[config file]:file:_files -g "*.yaml *.yml"' \
  '*--config=[config file]:file:_files -g "*.yaml *.yml"' \
  '*-n[dry run]' \
  '*--dry-run[dry run]' \
  '*--no-color[no color]' \
  '*-v+[verbosity]:n:(-1 0 1 2)' \
  '*--verbosity=[verbosity]:n:' \
  '*--syslog-verbosity=[syslog verbosity]:n:' \
  '*--log-file=[log file]:file:_files' \
  '*--log-file-verbosity=[log file verbosity]:n:' \
  '*--log-file-format=[log format]:f:' \
  '*--monitoring-verbosity=[monitoring verbosity]:n:' \
  '*--override=[k=v override]:v:' \
  '*--bash-completion[bash completion]' \
  '*--zsh-completion[zsh completion]' \
  '1: :->action' \
  '*::arg:->args' && ret=0

case $state in
  (action) _describe -t actions 'borgmatic action' actions && ret=0 ;;
  (args) _files ;;
esac

return ret
