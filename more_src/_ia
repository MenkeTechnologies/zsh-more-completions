#compdef ia
# Documentation: https://man.archlinux.org/search?q=ia
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'account:manage archive.org account'
  'ac:account (alias)'
  'configure:set credentials'
  'co:configure (alias)'
  'copy:copy files between items'
  'cp:copy (alias)'
  'delete:delete files from items'
  'rm:delete (alias)'
  'download:download files'
  'do:download (alias)'
  'flag:manage flags'
  'fl:flag (alias)'
  'list:list files in items'
  'ls:list (alias)'
  'metadata:read/modify item metadata'
  'md:metadata (alias)'
  'move:move/rename files'
  'mv:move (alias)'
  'reviews:submit/modify reviews'
  're:reviews (alias)'
  'search:search items'
  'se:search (alias)'
  'simplelists:manage simplelists'
  'sl:simplelists (alias)'
  'tasks:query catalog tasks'
  'ta:tasks (alias)'
  'upload:upload files'
  'up:upload (alias)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config-file)'{-c,--config-file=}'[config file]:file:_files' \
  '(-l --log)'{-l,--log}'[log requests]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-i --insecure)'{-i,--insecure}'[insecure mode]' \
  '(-H --host)'{-H,--host=}'[host]:host:_hosts' \
  '--user-agent-suffix=[user-agent suffix]:suffix:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ia subcommand' subcommands && ret=0
    ;;
esac

return ret
