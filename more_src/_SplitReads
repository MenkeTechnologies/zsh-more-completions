#compdef SplitReads
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/SplitReads.java
# Outputs reads from a SAM/BAM/CRAM by read group, sample and library name

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'=[directory to output SAM/BAM/CRAM files]:dir:_files -/' \
  '(--split-sample -SM)'{--split-sample,-SM}'[split file by sample]' \
  '(--split-read-group -RG)'{--split-read-group,-RG}'[split file by read group]' \
  '(--split-library-name -LB)'{--split-library-name,-LB}'[split file by library]' \
  '*:argument:_files' && ret=0

return ret
