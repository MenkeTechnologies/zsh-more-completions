#compdef evidence
# _evidence — Evidence.dev open-source code-based business intelligence with markdown+SQL+component layer (evidence-dev team, JavaScript/SvelteKit); custom argparse
# upstream: https://github.com/evidence-dev/evidence

_evidence() {
    local -a sub=(
        'create:scaffold a new project'
        'dev:run local development server'
        'build:build for production'
        'sources:run source queries'
        'preview:preview production build'
        'docs:open docs'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug[debug logging]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'evidence subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--template=+[template]:t:(default minimal blog docs)' \
                    '--package-manager=+[pkg manager]:m:(npm pnpm yarn bun)' \
                    '--example-project=+[bool]:b:(true false)' \
                    '*:name:_files -/' ;;
                dev) _arguments \
                    '--port=+[port]:port:_ports' \
                    '-p+[port]:port:_ports' \
                    '--host=+[host]:host:_hosts' \
                    '--strict-port[fail if port used]' \
                    '--open[open browser]' \
                    '--debug[debug logs]' ;;
                build) _arguments \
                    '--strict[strict mode]' \
                    '--debug[debug logs]' ;;
                sources) _arguments \
                    '--source=+[source name]:str:' \
                    '--changed[only changed]' \
                    '--queries=+[queries glob]:str:' \
                    '--strict[strict mode]' ;;
                preview) _arguments \
                    '--port=+[port]:port:_ports' \
                    '-p+[port]:port:_ports' \
                    '--host=+[host]:host:_hosts' ;;
            esac
            ;;
    esac
}

_evidence "$@"
