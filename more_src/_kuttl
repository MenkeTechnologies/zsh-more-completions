#compdef kuttl kubectl-kuttl

# Zsh completion for kuttl - KUbernetes Test TooL

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'test:run tests'
  'assert:assert resources match expected state'
  'errors:assert resources do not exist or have specific status'
  'version:show version'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'kuttl command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (test)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--config=[path to kuttl configuration file]:file:_files -g "*.yaml *.yml"' \
          '--artifacts-dir=[directory to store test artifacts]:directory:_files -/' \
          '--crd-dir=[directory with CRDs to apply]:directory:_files -/' \
          '--manifest-dir=[directory with manifests to apply]:directory:_files -/' \
          '--start-kind[start a KinD cluster]' \
          '--kind-config=[KinD cluster config]:file:_files -g "*.yaml *.yml"' \
          '--kind-context=[KinD context to use]:context' \
          '--skip-cluster-delete[do not delete KinD cluster after tests]' \
          '--skip-delete[do not delete test resources]' \
          '--namespace=[test namespace]:namespace' \
          '--timeout=[timeout for operations in seconds]:seconds' \
          '--parallel=[number of parallel tests]:count' \
          '--test=[run only matching test]:test name' \
          '--test-regex=[run tests matching regex]:regex' \
          '--suppress-log=[suppress log output]:type:(events)' \
          '--report=[generate report]:format:(JSON XML)' \
          '--report-name=[report file name]:name' \
          '*:test directories:_files -/' && ret=0
        ;;
      (assert)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--namespace=[target namespace]:namespace' \
          '--timeout=[assertion timeout in seconds]:seconds' \
          '*:resource files:_files -g "*.yaml *.yml"' && ret=0
        ;;
      (errors)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--namespace=[target namespace]:namespace' \
          '--timeout=[assertion timeout in seconds]:seconds' \
          '*:resource files:_files -g "*.yaml *.yml"' && ret=0
        ;;
      (version)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
