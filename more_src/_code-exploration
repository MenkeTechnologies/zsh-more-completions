#compdef code-exploration
# Documentation: https://code.visualstudio.com/docs/configure/command-line
# VS Code Exploration build command-line interface

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[print usage]' \
  '(-v --version)'{-v,--version}'[print version, commit and architecture]' \
  '(-n --new-window)'{-n,--new-window}'[open a new window]' \
  '(-r --reuse-window)'{-r,--reuse-window}'[open file/folder in the last active window]' \
  '(-g --goto)'{-g,--goto}'+[open file at line and character position]:file\:line\:char:_files' \
  '(-d --diff)'{-d,--diff}'[open a file diff editor (two paths)]:file:_files:file:_files' \
  '(-m --merge)'{-m,--merge}'[perform a three-way merge]:path:_files' \
  '(-w --wait)'{-w,--wait}'[wait for files to be closed before returning]' \
  '--locale=[set display language]:locale:' \
  '--add[add folder(s) to the last active window]:dir:_files -/' \
  '--install-extension=[install or update an extension]:extension:' \
  '--uninstall-extension=[uninstall an extension]:extension:' \
  '--list-extensions[list installed extensions]' \
  '--show-versions[show extension versions with --list-extensions]' \
  '--enable-proposed-api=[enable proposed API for an extension]:extension:' \
  '--disable-extensions[disable all installed extensions]' \
  '--update-extensions[update installed extensions and exit]' \
  '--extensions-dir=[root path for extensions]:dir:_files -/' \
  '--user-data-dir=[directory for user data]:dir:_files -/' \
  '--profile=[open with a specific profile]:profile:' \
  '(-s --status)'{-s,--status}'[print process usage and diagnostics]' \
  '(-p --performance)'{-p,--performance}'[start with startup performance diagnostics]' \
  '--disable-gpu[disable GPU hardware acceleration]' \
  '--verbose[print verbose output]' \
  '*:file:_files' && ret=0

return ret
