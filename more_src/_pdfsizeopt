#compdef pdfsizeopt
# Documentation: https://man.archlinux.org/search?q=pdfsizeopt
# Reference accessed: 2026-05-16

_arguments -s \
  '--use-pngout=[use pngout]:bool:(yes no)' \
  '--use-jbig2=[use JBIG2]:bool:(yes no)' \
  '--use-sam2p-pr=[use sam2p PR]:bool:(yes no)' \
  '--use-multivalent=[use Multivalent]:bool:(yes no)' \
  '--use-image-optimizer=[image optimizers]:list:' \
  '--do-optimize-images=[optimize images]:bool:(yes no)' \
  '--do-optimize-fonts=[optimize fonts]:bool:(yes no)' \
  '--do-optimize-streams=[optimize streams]:bool:(yes no)' \
  '--do-optimize-objs=[optimize objects]:bool:(yes no)' \
  '--do-optimize-obj-heads=[optimize object heads]:bool:(yes no)' \
  '--do-fast-bilevel-images=[fast bilevel images]:bool:(yes no)' \
  '--do-require-image-optimizers=[require optimizers]:bool:(yes no)' \
  '--do-debug-image-optimizers=[debug optimizers]:bool:(yes no)' \
  '--do-unify-fonts=[unify fonts]:bool:(yes no)' \
  '--do-keep-font-optionals=[keep font optionals]:bool:(yes no)' \
  '--do-regenerate-all-fonts=[regenerate all fonts]:bool:(yes no)' \
  '--do-double-check-type1c-output=[double check type1c]:bool:(yes no)' \
  '--do-double-check-missing-glyphs=[double check missing glyphs]:bool:(yes no)' \
  '--do-ignore-generation-numbers=[ignore generation numbers]:bool:(yes no)' \
  '--do-remove-generational-objs=[remove generational objs]:bool:(yes no)' \
  '--do-unify-pages=[unify pages]:bool:(yes no)' \
  '--do-generate-xref-stream=[generate xref stream]:bool:(yes no)' \
  '--do-generate-object-stream=[generate object stream]:bool:(yes no)' \
  '--do-decompress-flate=[decompress flate]:bool:(yes no)' \
  '--do-decompress-most-streams=[decompress most streams]:bool:(yes no)' \
  '--do-compress-uncompressed-streams=[compress uncompressed streams]:bool:(yes no)' \
  '--do-escape-images-from-multivalent=[escape images from Multivalent]:bool:(yes no)' \
  '--do-debug-gs=[debug GS]:bool:(yes no)' \
  '--tmp-dir=[tmp dir]:dir:_files -/' \
  '*:pdf file:_files -g "*.pdf"'
