#compdef cdk-notifier
# Documentation: https://github.com/karlderkaefer/cdk-notifier
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '(-l --log-level)'{-l,--log-level}'=[Log level]:level:(debug info warn error)' \
  '*::args: _default'
