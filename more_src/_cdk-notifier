#compdef cdk-notifier
# Documentation: https://man.archlinux.org/search?q=cdk-notifier
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '(-l --log-level)'{-l,--log-level}'=[Log level]:level:(debug info warn error)' \
  '*::args: _default'
