#compdef knative-eventing-keda-controller
# _knative-eventing-keda-controller — Knative Eventing KEDA autoscaler controller (sharedmain)
# upstream: https://github.com/knative-extensions/eventing-autoscaler-keda
# Flags from cmd/controller/main.go + knative.dev/pkg sharedmain on tip.

_knative-eventing-keda-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_knative-eventing-keda-controller "$@"
