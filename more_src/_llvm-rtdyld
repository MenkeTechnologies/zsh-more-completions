#compdef llvm-rtdyld
# _llvm-rtdyld — LLVM runtime dynamic loader test (LLVM project, C++); load/relocate object files in-process for JIT testing
# upstream: https://github.com/llvm/llvm-project

_llvm-rtdyld() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-action=+[action]:action:(execute printobjline printobjlinerel printcheckgotandstubs printline verify)' \
        '-entry=+[entry symbol]:sym:' \
        '-target-addr-start=+[target address start]:addr:' \
        '-triple=+[triple]:triple:' \
        '-mcpu=+[cpu]:cpu:' \
        '-mattr=+[mattr]:str:' \
        '-dummy-extern=+[dummy extern]:sym:' \
        '-preallocate-slabs=+[preallocate slabs]:n:' \
        '-slab-allocate=+[slab allocate]:str:' \
        '-slab-address=+[slab address]:addr:' \
        '-slab-page-size=+[slab page size]:n:' \
        '-target-addr-end=+[target address end]:addr:' \
        '-check=+[check file]:file:_files' \
        '-checkname=+[check name]:str:' \
        '-section-addr=+[section addr]:str:' \
        '-print-alloc-requests[print alloc requests]' \
        '-verbose[verbose]' \
        '*:file:_files'
}

_llvm-rtdyld "$@"
