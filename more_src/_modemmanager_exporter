#compdef modemmanager_exporter
# Documentation: https://github.com/mdlayher/modemmanager_exporter
# Prometheus exporter for ModemManager modem signal metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-addr=[address for ModemManager exporter]:address' \
  '-rate=[how frequently ModemManager polls each modem for extended signal strength data]:duration' \
  '*:arg:_default' && ret=0

return ret
