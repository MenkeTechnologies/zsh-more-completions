#compdef scil_fodf_ssst
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_fodf_ssst.html
# Scilpy: compute single-shell single-tissue fODF via CSD

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--sh_order=[SH order for CSD]:order' \
  '--mask=[binary mask]:mask:_files' \
  '--b0_threshold=[b0 threshold]:thr' \
  '--skip_b0_check[skip b0 existence validation]' \
  '--sh_basis=[SH basis]:basis:(descoteaux07 tournier07 descoteaux07_legacy tournier07_legacy)' \
  '--processes=[number of sub-processes]:nbr' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_dwi:_files' \
  '2:in_bval:_files' \
  '3:in_bvec:_files' \
  '4:frf_file:_files' \
  '5:out_fODF:_files' && ret=0

return ret
