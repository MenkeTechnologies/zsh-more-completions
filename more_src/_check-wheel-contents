#compdef check-wheel-contents
# Documentation: https://github.com/jwodder/check-wheel-contents
# Reference accessed: 2026-06-04

# Zsh completion for check-wheel-contents (check Python wheel contents)
local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)'{-V,--version}'[show version and exit]'
  '--config[path to configuration file]:config file:_files'
  '(-p --package)'{-p,--package}'[directory of the package source]:directory:_directories'
  '--src-dir[directory containing package source]:directory:_directories'
  '*--toplevel[expected top-level entries in the wheel]:names:'
  '*--package-omit[glob patterns for files to ignore in package]:pattern:'
  '(-W --select)'{-W,--select}'[select specific checks to run]:check codes:'
  '*--ignore[ignore specific checks]:check codes:'
  '*:wheel file:_files -g "*.whl"'
)

_arguments -s -S $arguments
