#compdef aerospike-cli
# Documentation: https://github.com/reugn/aerospike-cli
# Reference accessed: 2026-05-27
# Verified: upstream reugn/aerospike-cli README flag list (JDBC SQL CLI for Aerospike)

# aerospike-cli: command line utility to query the Aerospike database using SQL
# (wraps the Aerospike JDBC driver).
local curcontext="$curcontext" ret=1
_arguments -s \
  '(--host -host)'{--host,-host}'[Aerospike cluster hostname]:host:_hosts' \
  '(--port -port)'{--port,-port}'[Aerospike cluster port (default 3000)]:port:' \
  '(--namespace -ns)'{--namespace,-ns}'[Aerospike namespace]:namespace:' \
  '(--options -opts)'{--options,-opts}'[JDBC driver configuration options as a URL query string]:options:' \
  '(--version -v)'{--version,-v}'[show application version and exit]' \
  '(--help -h)'{--help,-h}'[show usage info]' && ret=0
return ret
