local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-h --help -w --watch)'{-h,--help}'[print help and exit]' \
    '(-h --help -w --watch)'{-w,--watch}'[watch files in ./src and rebuild on change (uses chokidar)]' \
    && ret=0

return ret
