#compdef volume-manager cstor-volume-mgmt
# _volume-manager — OpenEBS cStor per-volume manager (CStorVolume watcher + gRPC server for snapshot operations inside the target pod)
# upstream: https://github.com/openebs/cstor-operators
# Subcommands + flags from cmd/volume-manager/app/{commands,start}.go on tip (cobra).

_volume-manager() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '-v[klog verbosity level]:n:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                start:'start the CStorVolume watcher + gRPC server'
            )
            _describe -t commands 'volume-manager subcommand' subs
            ;;
        args)
            case $line[1] in
                start)
                    _arguments \
                        '--kubeconfig=[kubeconfig (out-of-cluster only)]:file:_files' \
                        '(-p --port)'{-p,--port}'=[gRPC server listen port]:port:'
                    ;;
            esac
            ;;
    esac
}

_volume-manager "$@"
