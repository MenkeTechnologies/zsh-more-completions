#compdef autocast
# Documentation: https://github.com/k9withabone/autocast
# autocast - automate terminal demos, generate asciicast files from YAML

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--width=[terminal width]:width' \
  '--height=[terminal height]:height' \
  '(-t --title)'{-t,--title}'=[title of the asciicast]:title' \
  '--shell=[shell to use for running commands]:shell:(bash python)' \
  '*'{-e,--environment}'=[environment variables to use in the shell]:NAME=VALUE' \
  '*--environment-capture=[environment variables to capture]:env var' \
  '(-d --type-speed --delay)'{-d,--type-speed,--delay}'=[default time between key presses]:type speed' \
  '--prompt=[shell prompt to use in asciicast output]:prompt' \
  '--secondary-prompt=[secondary shell prompt for asciicast output]:secondary prompt' \
  '--timeout=[maximum time to let a shell command run]:timeout' \
  '--overwrite[overwrite output file if it already exists]' \
  '1:input file:_files' \
  '2:output asciicast file:_files' && ret=0

return ret
