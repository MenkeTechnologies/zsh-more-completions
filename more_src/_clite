#compdef clite
# Documentation: https://github.com/cline/cline
# Reference accessed: 2026-05-23
# Verified: @cline/cli --help and subcommand help (npm bin clite).

# Zsh completion for clite - Cline AI coding agent terminal CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --plan)'{-p,--plan}'[run in plan mode]' \
  '--json[JSON message output]' \
  '--auto-approve[tool auto-approval]:boolean:(true false)' \
  '(-c --cwd)'{-c+,--cwd=}'[working directory]:directory:_files -/' \
  '--thinking[reasoning effort]:level:(none low medium high xhigh)' \
  '(-i --tui)'{-i,--tui}'[interactive TUI]' \
  '--id[resume session by ID]:session:' \
  '(-P --provider)'{-P+,--provider=}'[provider id]:provider:' \
  '(-k --key)'{-k+,--key=}'[API key override]:key:' \
  '(-m --model)'{-m+,--model=}'[model id]:model:' \
  '(-s --system)'{-s+,--system=}'[system prompt override]:prompt:' \
  '-z[background hub session]' \
  '--retries[max consecutive mistakes]:n:' \
  '(-t --timeout)'{-t+,--timeout=}'[timeout seconds]:seconds:' \
  '--acp[Agent Client Protocol mode]' \
  '--config[config directory]:directory:_files -/' \
  '--data-dir[isolated state directory]:directory:_files -/' \
  '--hooks-dir[extra hooks directory]:directory:_files -/' \
  '--update[check for updates]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'clite command' \
      'auth[authenticate provider and model]' \
      'config[show configuration]' \
      'connect[connect external channel]' \
      'mcp[manage MCP servers]' \
      'doctor[diagnose configuration]' \
      'history[list or manage sessions]' \
      'h[alias for history]' \
      'hook[handle hook payload from stdin]' \
      'schedule[manage scheduled tasks]' \
      'hub[manage local hub daemon]' \
      'update[check for CLI updates]' \
      'version[show version]' \
      'kanban[launch kanban app]' && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        _arguments -C \
          '(-p --provider)'{-p+,--provider=}'[provider id]:provider:' \
          '(-k --apikey)'{-k+,--apikey=}'[API key]:key:' \
          '(-m --modelid)'{-m+,--modelid=}'[model id]:model:' \
          '(-b --baseurl)'{-b+,--baseurl=}'[base URL]:url:' \
          '--config[configuration directory]:directory:_files -/' \
          '(-c --cwd)'{-c+,--cwd=}'[working directory]:directory:_files -/' \
          '--data-dir[isolated state directory]:directory:_files -/' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '1:provider:provider:' && ret=0
        ;;
      connect)
        _arguments -C \
          '--stop[kill channel connections]' \
          '1:channel:channel:' && ret=0
        ;;
      history|h)
        _arguments '*::history options:' && ret=0
        ;;
    esac
    ;;
esac

return ret
