#compdef vhost-user-blk
# Documentation: https://github.com/qemu/qemu/blob/master/contrib/vhost-user-blk/vhost-user-blk.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (QEMU contrib vhost-user-blk daemon).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(-c --print-capabilities)'{-c,--print-capabilities}'[print capabilities in JSON]' \
  '(-f --fd)'{-f+,--fd=}'[inherited file descriptor number for the socket]:fd:' \
  '(-s --socket-path)'{-s+,--socket-path=}'[UNIX socket path]:file:_files' \
  '(-b --blk-file)'{-b+,--blk-file=}'[block device or file path]:file:_files' \
  '(-r --read-only)'{-r,--read-only}'[enable read-only mode]' && ret=0
return ret
