#compdef vhost-user-blk
# Documentation: https://man.archlinux.org/search?q=vhost-user-blk
# Reference accessed: 2026-05-16

# vhost-user-blk: vhost-user block device backend
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-s[unix socket path]:file:_files' \
  '--socket-path=[unix socket path]:file:_files' \
  '--fd=[connected fd]:fd:' \
  '-d[disk/device backend]:device:' \
  '--blk-file=[block device file]:file:_files' \
  '--read-only[read-only mode]' \
  '-r[read-only mode]' \
  '--print-capabilities[print capabilities]' \
  '*::vhost-user-blk args:_files' && ret=0
return ret
