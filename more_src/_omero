#compdef omero
# Documentation: https://omero.readthedocs.io/en/stable/users/cli/index.html
# OMERO command-line client for managing images and data objects

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'omero command' \
      'login[create a connection to the server]' \
      'logout[terminate the current session]' \
      'sessions[manage stored sessions]' \
      'import[import images into OMERO]' \
      'export[export images from OMERO]' \
      'download[download data from the server]' \
      'upload[upload files to the server]' \
      'obj[work with OMERO data objects]' \
      'ls[list objects and containers]' \
      'tag[manage tags on objects]' \
      'delete[delete objects from OMERO]' \
      'chgrp[move objects between groups]' \
      'chown[change ownership of objects]' \
      'fs[filesystem-related operations]' \
      'admin[administrative operations]' && ret=0
    ;;
  args)
    case $line[1] in
      login)
        _arguments -s \
          '(-s --server)'{-s,--server}'=[server hostname]:server' \
          '(-u --user)'{-u,--user}'=[username]:user' \
          '(-p --port)'{-p,--port}'=[server port]:port' \
          '(-g --group)'{-g,--group}'=[group for the connection]:group' \
          '(-k --key)'{-k,--key}'=[session key to join an existing connection]:key' \
          '(-w --password)'{-w,--password}'=[password]:password' \
          '--sudo=[connect as another user]:adminuser' \
          '1:connection string' && ret=0
        ;;
      sessions)
        _values 'sessions subcommand' \
          'login[create a connection]' \
          'list[list stored sessions]' \
          'file[print current session file location]' \
          'group[switch group membership of current session]' \
          'keepalive[keep the current session alive]' \
          'clear[remove stored sessions]' \
          'logout[terminate the current session]' && ret=0
        ;;
      import)
        _arguments -s \
          '(-s)-s+[server hostname]:server' \
          '(-p)-p+[server port]:port' \
          '(-u)-u+[username]:user' \
          '(-g)-g+[group name]:group' \
          '-d+[import images into dataset]:dataset id' \
          '-r+[import plate into screen]:screen id' \
          '(-T --target)'{-T,--target}'=[import target]:target' \
          '(-n --name)'{-n,--name}'=[image or plate name]:name' \
          '(-x --description)'{-x,--description}'=[image or plate description]:desc' \
          '-f[list files to be imported then exit]' \
          '--depth=[directory scan depth]:depth' \
          '*--skip=[skip optional import steps]:step:(checksum minmax thumbnails upgrade all)' \
          '--parallel-fileset=[filesets to import simultaneously]:n' \
          '--parallel-upload=[file upload threads]:n' \
          '--file=[store process standard output]:file:_files' \
          '--errs=[store process standard error]:file:_files' \
          '--logprefix=[directory prefix for output files]:dir:_files -/' \
          '--output=[alternative output style]:type:(yaml)' \
          '--debug=[set debug level]:level' \
          '--bulk=[import from bulk YAML config]:file:_files' \
          '--report[report errors to the OME team]' \
          '--upload[upload broken files and logs with report]' \
          '--logs[upload log file with report]' \
          '--email=[contact email for error reports]:email' \
          '--java-help[show Java options help]' \
          '--advanced-help[show advanced options help]' \
          '*:path:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
