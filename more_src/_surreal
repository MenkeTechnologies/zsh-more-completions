#compdef surreal

# Zsh completion for SurrealDB CLI

local curcontext="$curcontext" state line ret=1

local -a surreal_commands
surreal_commands=(
  'backup:backup a running SurrealDB server'
  'export:export a SurrealDB database'
  'fix:fix SurrealDB data files'
  'help:print help information'
  'import:import a SurrealQL file'
  'isready:check if the SurrealDB server is ready'
  'ml:manage SurrealML models'
  'sql:start an interactive SQL shell'
  'start:start the SurrealDB server'
  'upgrade:upgrade to the latest version'
  'validate:validate a SurrealQL file'
  'version:output the version'
)

local -a surreal_global_flags
surreal_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '-V[show version]'
  '--version[show version]'
)

_arguments -s -S \
  $surreal_global_flags \
  '1:command:_describe -t commands command surreal_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      start)
        _arguments -s -S \
          $surreal_global_flags \
          '-b=[listen address]:address:' \
          '--bind=[listen address]:address:' \
          '--log=[log level]:level:(none full error warn info debug trace)' \
          '-l=[log level]:level:(none full error warn info debug trace)' \
          '--no-banner[hide the startup banner]' \
          '--strict[enable strict mode]' \
          '--unauthenticated[allow unauthenticated access]' \
          '-u=[initial root username]:username:' \
          '--username=[initial root username]:username:' \
          '-p=[initial root password]:password:' \
          '--password=[initial root password]:password:' \
          '--auth[enable authentication]' \
          '--no-identification-headers[disable identification headers]' \
          '--allow-all[allow all capabilities]' \
          '--allow-funcs=[allow specific functions]:functions:' \
          '--allow-guests[allow guest access]' \
          '--allow-net=[allow specific network targets]:targets:' \
          '--allow-scripting[allow scripting]' \
          '--deny-all[deny all capabilities]' \
          '--deny-funcs=[deny specific functions]:functions:' \
          '--deny-guests[deny guest access]' \
          '--deny-net=[deny specific network targets]:targets:' \
          '--deny-scripting[deny scripting]' \
          '--key=[encryption key]:key:' \
          '--kvs-ca=[KV store CA file]:file:_files' \
          '--kvs-cert=[KV store cert file]:file:_files' \
          '--kvs-key=[KV store key file]:file:_files' \
          '--temporary-directory=[temporary directory]:directory:_directories' \
          '--tick-interval=[tick interval]:duration:' \
          '--web-crt=[web TLS certificate]:file:_files' \
          '--web-key=[web TLS private key]:file:_files' \
          '--client-ip=[method for detecting client IP]:method:(none socket-addr x-forwarded-for x-real-ip cf-connecting-ip true-client-ip)' \
          '--query-timeout=[max query execution time]:duration:' \
          '--transaction-timeout=[max transaction execution time]:duration:' \
          '1:path:(memory file\:// rocksdb\:// tikv\:// fdb\:// surrealkv\://)' && ret=0
        ;;
      sql)
        _arguments -s -S \
          $surreal_global_flags \
          '--conn=[remote database server URL]:url:' \
          '-e=[remote database server URL]:url:' \
          '--endpoint=[remote database server URL]:url:' \
          '--db=[database to use]:database:' \
          '--ns=[namespace to use]:namespace:' \
          '-u=[database username]:username:' \
          '--username=[database username]:username:' \
          '-p=[database password]:password:' \
          '--password=[database password]:password:' \
          '--auth-level=[authentication scope]:level:(root namespace database)' \
          '--token=[authentication token]:token:' \
          '--pretty[pretty-print output]' \
          '--json[output results as JSON]' \
          '--multi[enable multi-line mode]' \
          '--hide-welcome[hide welcome message]' && ret=0
        ;;
      export)
        _arguments -s -S \
          $surreal_global_flags \
          '--conn=[remote database server URL]:url:' \
          '-e=[remote database server URL]:url:' \
          '--endpoint=[remote database server URL]:url:' \
          '--db=[database to export]:database:' \
          '--ns=[namespace to export]:namespace:' \
          '-u=[database username]:username:' \
          '--username=[database username]:username:' \
          '-p=[database password]:password:' \
          '--password=[database password]:password:' \
          '--auth-level=[authentication scope]:level:(root namespace database)' \
          '--token=[authentication token]:token:' \
          '1:output file:_files' && ret=0
        ;;
      import)
        _arguments -s -S \
          $surreal_global_flags \
          '--conn=[remote database server URL]:url:' \
          '-e=[remote database server URL]:url:' \
          '--endpoint=[remote database server URL]:url:' \
          '--db=[database to import into]:database:' \
          '--ns=[namespace to import into]:namespace:' \
          '-u=[database username]:username:' \
          '--username=[database username]:username:' \
          '-p=[database password]:password:' \
          '--password=[database password]:password:' \
          '--auth-level=[authentication scope]:level:(root namespace database)' \
          '--token=[authentication token]:token:' \
          '1:input file:_files' && ret=0
        ;;
      backup)
        _arguments -s -S \
          $surreal_global_flags \
          '--conn=[remote database server URL]:url:' \
          '-e=[remote database server URL]:url:' \
          '--endpoint=[remote database server URL]:url:' \
          '-u=[database username]:username:' \
          '--username=[database username]:username:' \
          '-p=[database password]:password:' \
          '--password=[database password]:password:' \
          '--auth-level=[authentication scope]:level:(root namespace database)' \
          '--token=[authentication token]:token:' \
          '--db=[database to backup]:database:' \
          '--ns=[namespace to backup]:namespace:' \
          '1:destination (file or connection string):_files' && ret=0
        ;;
      isready)
        _arguments -s -S \
          $surreal_global_flags \
          '--conn=[remote database server URL]:url:' \
          '-e=[remote database server URL]:url:' \
          '--endpoint=[remote database server URL]:url:' && ret=0
        ;;
      validate)
        _arguments -s -S \
          $surreal_global_flags \
          '*:file:_files' && ret=0
        ;;
      fix)
        _arguments -s -S \
          $surreal_global_flags \
          '1:path:_files' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          $surreal_global_flags \
          '--nightly[upgrade to the latest nightly version]' \
          '--alpha[upgrade to the latest alpha version]' \
          '--beta[upgrade to the latest beta version]' \
          '--version=[upgrade to a specific version]:version:' \
          '--dry-run[do not actually upgrade]' && ret=0
        ;;
      ml)
        local -a ml_commands
        ml_commands=(
          'export:export a SurrealML model'
          'import:import a SurrealML model'
        )
        _arguments -s -S \
          $surreal_global_flags \
          '1:ml command:_describe -t commands command ml_commands' \
          '*::ml args:' && ret=0
        ;;
      *)
        _arguments -s -S $surreal_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
