#compdef github-subdomains
# Documentation: https://github.com/gwen001/github-subdomains
# find subdomains on GitHub by scraping code search results

local ret=1

_arguments -s -S \
  '-d[domain you are looking for (required)]:domain' \
  '-e[extended mode, also look for <dummy>example.<tld>]' \
  '-k[exit the program when all tokens have been disabled]' \
  '-o[output file (default: <domain>.txt)]:output file:_files' \
  '-raw[raw output]' \
  '-t[GitHub token(s): single, comma-separated, or .tokens file]:tokens' \
  '*::arg:_files' && ret=0

return ret
