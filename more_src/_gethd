#compdef gethd
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/gethd.html
# MIRIAD gethd - print the value of a header item

local ret=1

_arguments -s -S \
  'in=[dataset item to query dataset/item]:in:_files' \
  'format=[default/time/pol/arcsec/arcmin/degrees/hours/hms/dms]:format:(default time pol arcsec arcmin degrees hours hms dms)' \
  'log=[output log file]:log:_files' \
  '*:dataset:_files' && ret=0

return ret
