#compdef decompyle3
# Documentation: https://github.com/rocky/python-decompile3
# decompyle3 - Python bytecode decompiler (newer Python versions)

local ret=1

_arguments -s -S \
  '(-o --output)'{-o,--output}'=[write decompiled output to path]:output:_files' \
  '(-r --recurse)'{-r,--recurse}'[process directories recursively]' \
  '(-a --asm)'{-a,--asm}'[show assembler output]' \
  '(-A --asm++)'{-A,--asm++}'[show xdis and tokenized assembler output]' \
  '(-g --grammar)'{-g,--grammar}'[show grammar information]' \
  '(-t --tree)'{-t,--tree}'[show parse tree]' \
  '(-T --tree++)'{-T,--tree++}'[show parse tree and AST]' \
  '--linemaps[show bytecode-to-source line correspondences]' \
  '--verify=[verification method]:method:(run syntax)' \
  '--start-offset=[start decompilation at offset]:offset' \
  '--stop-offset=[stop decompilation at offset]:offset' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files' && ret=0

return ret
