# Documentation: https://github.com/pioneerspacesim/pioneer/blob/master/src/main.cpp
# Reference accessed: 2026-05-16
# Verified: src/main.cpp main() lines 29-230. Pioneer uses a mode-prefix
# argv parser; first arg is the mode flag (single dash or slash), followed
# by mode-specific positionals or key=value config overrides.

# Pioneer: open-source space adventure game
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show usage]' \
  '(- *)-h[show usage]' \
  '(- *)-?[show usage]' \
  '(- *)-version[show version info]' \
  '(- *)-v[show version info]' \
  '(- *)-game[launch the game (default)]' \
  '(- *)-g[launch the game (default)]' \
  '(- *)-galaxydump[dump galaxy data to file]' \
  '(- *)-gd[dump galaxy data to file]' \
  '-startat=[start at system path (e.g. 0,0,0,0,18)]:path:' \
  '-sa=[start at system path]:path:' \
  '*:filename / key=value:_files' && ret=0
return ret
