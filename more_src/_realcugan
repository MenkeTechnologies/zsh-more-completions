#compdef realcugan realcugan-ncnn-vulkan
# _realcugan — bilibili Real-CUGAN ncnn Vulkan anime super-resolution CLI alias (nihui / bilibili, C++); custom argparse
# upstream: https://github.com/nihui/realcugan-ncnn-vulkan

_realcugan() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-i+[input file or dir]:file:_files' \
        '-o+[output file or dir]:file:_files' \
        '-s+[upscale ratio]:n:(2 3 4)' \
        '-n+[denoise level]:n:(-1 0 1 2 3)' \
        '-t+[tile size]:n:' \
        '-c+[syncgap mode]:n:(0 1 2 3)' \
        '-m+[model path]:dir:_files -/' \
        '-g+[gpu id]:n:' \
        '-j+[thread count load:proc:save]:str:' \
        '-x[enable tta mode]' \
        '-f+[output format]:fmt:(png webp jpg)' \
        '-v[verbose]' \
        '*:arg:'
}

_realcugan "$@"
