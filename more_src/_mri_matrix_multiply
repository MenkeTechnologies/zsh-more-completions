#compdef mri_matrix_multiply
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_matrix_multiply
# Multiply registration matrices together

local ret=1

_arguments -s -S \
  '*-im[input matrix file]:file:_files' \
  '*-iim[input matrix file (invert before applying)]:file:_files' \
  '-om[output matrix file]:file:_files' \
  '-v[verbose mode]' && ret=0

return ret
