#compdef snap

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:install a snap'
  'remove:remove a snap'
  'refresh:refresh snaps'
  'list:list installed snaps'
  'find:search the store'
  'info:show snap details'
  'run:run an app from a snap'
  'login:authenticate to the store'
  'logout:log out of the store'
  'whoami:show authenticated user'
  'set:set configuration values'
  'get:show configuration values'
  'unset:unset configuration values'
  'services:list services'
  'start:start one or more services'
  'stop:stop one or more services'
  'restart:restart services'
  'enable:enable a service or snap'
  'disable:disable a service or snap'
  'logs:tail service logs'
  'switch:switch tracked channel'
  'revert:revert to previous revision'
  'alias:create an alias'
  'unalias:remove an alias'
  'aliases:list aliases'
  'prefer:resolve alias conflicts in favor of a snap'
  'connect:connect a plug to a slot'
  'disconnect:disconnect a plug from a slot'
  'connections:list connections'
  'interface:show interface details'
  'interfaces:list interfaces (legacy)'
  'changes:list system changes'
  'change:show details of a change'
  'tasks:show tasks of a change'
  'abort:abort a change'
  'watch:watch a change'
  'ack:add an assertion'
  'known:list known assertions'
  'sign-build:sign a snap build'
  'save:create a snapshot'
  'saved:list snapshots'
  'restore:restore a snapshot'
  'forget:forget a snapshot'
  'check-snapshot:check a snapshot'
  'export-snapshot:export a snapshot to a file'
  'import-snapshot:import a snapshot from a file'
  'warnings:show warnings'
  'okay:acknowledge all warnings'
  'version:show version'
  'wait:wait for a value to change'
  'debug:debug operations'
  'download:download a snap'
  'pack:pack a snap source directory'
  'try:try a snap from a directory'
  'prepare-image:prepare an image build'
  'validate:manage validation sets'
  'recovery:show recovery system info'
  'reboot:reboot to a recovery system'
  'remodel:apply a new model assertion'
  'model:show the model assertion'
  'create-cohort:create cohort keys for a snap'
  'help:show help'
  'completion:emit shell completion script'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'snap subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '--channel=[track/risk/branch]:channel:' \
          '--classic[classic confinement]' \
          '--dangerous[install local snap without assertion check]' \
          '--devmode[developer mode]' \
          '--jailmode[force strict confinement]' \
          '--revision=[revision]:rev:' \
          '(--beta --candidate --edge --stable)--beta[shortcut for --channel=beta]' \
          '(--beta --candidate --edge --stable)--candidate[shortcut for --channel=candidate]' \
          '(--beta --candidate --edge --stable)--edge[shortcut for --channel=edge]' \
          '(--beta --candidate --edge --stable)--stable[shortcut for --channel=stable]' \
          '--cohort=[cohort key]:key:' \
          '--transaction=[transaction]:mode:(all-snaps per-snap)' \
          '--name=[instance name]:name:' \
          '--unaliased[do not enable automatic aliases]' \
          '--no-wait[do not wait for completion]' \
          '--quota-group=[quota group]:group:' \
          '*:snap:_files' && ret=0
        ;;
      (remove)
        _arguments \
          '--revision=[revision]:rev:' \
          '--purge[do not save snapshot]' \
          '--terminate[terminate running processes]' \
          '--no-wait[do not wait]' \
          '*:snap:' && ret=0
        ;;
      (refresh)
        _arguments \
          '--list[list snaps that would be refreshed]' \
          '--time[show schedule]' \
          '--hold=[hold duration]:duration:' \
          '--unhold[remove hold]' \
          '--amend[replace local snap with store version]' \
          '--channel=[channel]:channel:' \
          '(--beta --candidate --edge --stable)--beta[shortcut]' \
          '(--beta --candidate --edge --stable)--candidate[shortcut]' \
          '(--beta --candidate --edge --stable)--edge[shortcut]' \
          '(--beta --candidate --edge --stable)--stable[shortcut]' \
          '--classic[classic confinement]' \
          '--devmode[developer mode]' \
          '--jailmode[strict confinement]' \
          '--revision=[revision]:rev:' \
          '--cohort=[cohort key]:key:' \
          '--leave-cohort[leave cohort]' \
          '--transaction=[transaction]:mode:(all-snaps per-snap)' \
          '--ignore-validation[ignore validation]' \
          '--ignore-running[ignore running app]' \
          '--no-wait[do not wait]' \
          '*:snap:' && ret=0
        ;;
      (find)
        _arguments \
          '--private[search private snaps]' \
          '--narrow[only stable channel]' \
          '--section=[category]:category:' \
          '--color=[color mode]:mode:(auto never always)' \
          '--unicode=[unicode mode]:mode:(auto never always)' \
          ':query:' && ret=0
        ;;
      (info)
        _arguments \
          '--verbose[show extra info]' \
          '--abs-time[absolute timestamps]' \
          '*:snap:' && ret=0
        ;;
      (list)
        _arguments \
          '--all[show all revisions]' \
          '--color=[color mode]:mode:(auto never always)' \
          '--unicode=[unicode mode]:mode:(auto never always)' \
          '*:snap:' && ret=0
        ;;
      (run)
        _arguments \
          '--shell[start shell instead of app]' \
          '--gdb[run under gdb]' \
          '--gdbserver=[run under gdbserver]:address:' \
          '--strace=[strace args]:args:' \
          '--trace-exec[trace exec]' \
          '--timer=[run as timer]:timer:' \
          ':app:' && ret=0
        ;;
      (switch)
        _arguments \
          '--channel=[channel]:channel:' \
          '--beta[shortcut]' \
          '--candidate[shortcut]' \
          '--edge[shortcut]' \
          '--stable[shortcut]' \
          '--cohort=[cohort key]:key:' \
          '--leave-cohort[leave cohort]' \
          ':snap:' && ret=0
        ;;
      (logs)
        _arguments \
          '(-f --follow)'{-f,--follow}'[follow logs]' \
          '-n=[number of lines]:n:' \
          '*:service:' && ret=0
        ;;
      (download)
        _arguments \
          '--channel=[channel]:channel:' \
          '--beta[shortcut]' \
          '--candidate[shortcut]' \
          '--edge[shortcut]' \
          '--stable[shortcut]' \
          '--revision=[revision]:rev:' \
          '--basename=[output basename]:name:' \
          '--target-directory=[target directory]:dir:_files -/' \
          '--cohort=[cohort key]:key:' \
          ':snap:' && ret=0
        ;;
      (debug)
        _values 'debug subcommand' \
          'state' 'sandbox-features' 'connectivity' 'aspects' 'paths' \
          'last-change' 'change' 'last-task' 'task' 'changes' 'tasks' \
          'ensure-state' 'gadget' 'gadget-snap' 'gadget-mount' 'gadget-volumes' \
          'help-warnings' 'self-test' 'service-control' 'translate-service' && ret=0
        ;;
      (validate)
        _arguments \
          '--monitor[monitor mode]' \
          '--enforce[enforce mode]' \
          '--forget[forget mode]' \
          '--refresh[refresh validation]' \
          '*:set:' && ret=0
        ;;
      (set)
        _arguments \
          '-t[values are typed JSON]' \
          '-s[values are strings]' \
          ':snap:' \
          '*:key=value:' && ret=0
        ;;
      (reboot)
        _arguments \
          '--run[reboot to run mode]' \
          '--recover[reboot to recover mode]' \
          '--install[reboot to install mode]' \
          '--factory-reset[factory reset]' \
          ':label:' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' && ret=0
        ;;
    esac
    ;;
esac

return ret
