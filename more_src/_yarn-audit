#compdef yarn-audit
# _yarn-audit — Yarn yarn-audit CLI security audit subcommand of yarn classic + yarn berry reporting vulnerabilities in dependency graph from the GitHub Advisory Database with severity-low-moderate-high-critical detail per-package recursive top-down output JSON text recursive groups (Yarn team, JS); custom argparse
# upstream: https://classic.yarnpkg.com/en/docs/cli/audit

_yarn-audit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--json[json output]' \
        '--recursive[recursive]' \
        '--no-recursive[no recursive]' \
        '--all[include all deps]' \
        '--groups=+[group]:g:(dependencies devDependencies optionalDependencies)' \
        '--level=+[l]:l:(info low moderate high critical)' \
        '--severity=+[s]:s:(info low moderate high critical)' \
        '--summary[summary only]' \
        '--no-summary[no summary]' \
        '--no-progress[no progress bar]' \
        '--ignore=+[advisory ids]:str:' \
        '--exclude=+[packages]:str:' \
        '*::'
}

_yarn-audit "$@"
