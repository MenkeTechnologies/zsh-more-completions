#compdef nextpnr-gowin nextpnr-himbaechel
# _nextpnr-gowin — YosysHQ nextpnr-gowin CLI place-and-route portable open-source FPGA P&R tool targeting Gowin LittleBee GW1N GW2A family chips packed JSON netlist from Yosys producing FS bitstream for gowin_pack (David Shah team, C++); custom argparse
# upstream: https://github.com/YosysHQ/nextpnr

_nextpnr-gowin() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--log=+[log file]:file:_files' \
        '--json=+[json netlist]:file:_files -g "*.json"' \
        '--cst=+[cst constraints]:file:_files -g "*.cst"' \
        '--write=+[json output]:file:_files -g "*.json"' \
        '--vopt=+[option=value]:str:' \
        '--device=+[d]:d:(GW1N-LV1QN48C6\\/I5 GW1N-LV1QN48 GW1N-1 GW1N-9C GW1N-9 GW1N-4 GW1NS-2 GW1NSR-4C GW2A-18 GW2A-18C GW2AR-18 GW2A-55C GW1NZ-1 GW1NR-9C)' \
        '--family=+[f]:f:(GW1N-1 GW1N-4 GW1N-9 GW1NR-9 GW1NS-2 GW2A-18 GW1NZ-1 GW1NR-9C)' \
        '--freq=+[MHz]:n:' \
        '--seed=+[seed]:n:' \
        '--placer=+[p]:p:(heap sa)' \
        '--router=+[r]:r:(router1 router2)' \
        '--no-route[skip routing]' \
        '--no-place[skip placement]' \
        '--no-pack[skip packing]' \
        '--placer-heap-alpha=+[alpha]:n:' \
        '--placer-heap-beta=+[beta]:n:' \
        '--threads=+[N]:n:' \
        '--gui[gui mode]' \
        '--report=+[file]:file:_files -g "*.json"' \
        '--detailed-timing-report[detailed timing report]' \
        '--no-tmdriv[disable timing-driven]' \
        '--ignore-loops[ignore combinational loops]' \
        '--randomize-seed[randomize seed]' \
        '*:json file:_files -g "*.json"'
}

_nextpnr-gowin "$@"
