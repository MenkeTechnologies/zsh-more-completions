#compdef virt-p2v
# Documentation: https://man.archlinux.org/search?q=virt-p2v
# Reference accessed: 2026-05-16

# virt-p2v: physical-to-virtual conversion client (boots from CD/USB)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-x[trace]' \
  '--trace[trace]' \
  '--cmdline=[append to kernel cmdline]:cmdline:' \
  '--config=[config file]:file:_files' \
  '--colors[colorize output]' \
  '*::virt-p2v args:_files' && ret=0
return ret
