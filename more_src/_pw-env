        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_pw-env_commands" \
"*::: :->pw-env" \
&& ret=0
    case $state in
    (pw-env)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pw-env-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate hook for\: bash, zsh, fish, or powershell:_default' \
&& ret=0
;;
(exec)
_arguments "${_arguments_options[@]}" : \
'--dir=[Directory to look for .env file in (defaults to current directory)]:DIR:_files' \
'--warn-missing[Print a warning to stderr for each .env entry that could not be resolved]' \
'-h[Print help]' \
'--help[Print help]' \
'*::command -- Command to execute with transient environment variables:_default' \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
'--shell=[Shell syntax to use\: bash, zsh, fish, or powershell]:SHELL:_default' \
'--warn-missing[Print a warning to stderr for each .env entry that could not be resolved]' \
'-h[Print help]' \
