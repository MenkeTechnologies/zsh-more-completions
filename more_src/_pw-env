(( $+functions[_pw-env_commands] )) ||
_pw-env_commands() {
    local commands; commands=(
'init:Generate shell hook code for automatic .env loading on cd' \
'exec:Execute a command with resolved environment variables only in the child process' \
'export:Export resolved environment variables (for shell eval)' \
'load:Load and display resolved environment variables (human-readable)' \
'add:Store a secret in the configured backend and add an empty .env entry for it' \
'migrate:Migrate plaintext secrets from .env into the password manager' \
'check:Check availability of password manager backends' \
'approvals:Manage approval state for project-local overrides and secret fetching' \
'cache:Manage local cache state' \
'update:Download and replace the current binary with a released build' \
'config-template:Print the default configuration file template' \
'config-wizard:Open an interactive TUI that builds and saves the global config file' \
'completions:Generate shell completion script' \
'hook:' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'pw-env commands' commands "$@"
}
