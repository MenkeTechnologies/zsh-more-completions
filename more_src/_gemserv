#compdef gemserv

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'=[path to configuration file]:config file:_files -g "*.toml"' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-V --version)'{-V,--version}'[show version]' \
  && ret=0

return ret
