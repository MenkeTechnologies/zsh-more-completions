#compdef nc-config nf-config ncxx4-config
# _nc-config — Unidata NetCDF nc-config and nf-config show install information for the netCDF C/Fortran/C++ libraries (Unidata team, C); custom argparse
# upstream: https://github.com/Unidata/netcdf-c

_nc-config() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--all[print all flags]' \
        '--version[show version]' \
        '--prefix[show install prefix]' \
        '--includedir[show include dir]' \
        '--libdir[show library dir]' \
        '--cflags[show compile flags]' \
        '--cppflags[show preprocessor flags]' \
        '--libs[show link flags]' \
        '--static[show static libs]' \
        '--has-c++[has C++ bindings]' \
        '--cxx4flags[show C++4 flags]' \
        '--cxx4libs[show C++4 libs]' \
        '--cxx[has older C++ bindings]' \
        '--has-fortran[has Fortran bindings]' \
        '--has-f77[has Fortran 77 bindings]' \
        '--has-f90[has Fortran 90 bindings]' \
        '--has-szlib[has SZLIB compression]' \
        '--has-hdf5[has HDF5 support]' \
        '--has-hdf4[has HDF4 support]' \
        '--has-pnetcdf[has parallel-netCDF support]' \
        '--has-parallel[has parallel I/O support]' \
        '--has-dap[has DAP client]' \
        '--has-dap2[has DAP2 client]' \
        '--has-dap4[has DAP4 client]' \
        '--has-nczarr[has NCZarr]' \
        '--has-nc2[has netCDF2 API]' \
        '--has-nc4[has netCDF4 API]' \
        '--has-byterange[has byterange support]' \
        '--has-jna[has JNA bindings]' \
        '--has-logging[has logging]' \
        '--has-tests[has tests]'
}

_nc-config "$@"
