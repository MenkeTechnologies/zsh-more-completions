#compdef pj
# Documentation: https://github.com/projen/projen/blob/main/src/cli/index.ts
# projen (pj) - define and maintain project configuration through code

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version number]' \
  '--post[run post-synthesis steps such as installing dependencies (--no-post to skip)]' \
  '(-w --watch)'{-w,--watch}'[keep running and resynthesize when projenrc changes]' \
  '--debug[debug logs]' \
  '*::task:->tasks' && ret=0

case $state in
  tasks)
    _values 'task' \
      'new[create a new project from a project type]' && ret=0
    ;;
esac

return ret
