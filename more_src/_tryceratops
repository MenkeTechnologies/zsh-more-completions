#compdef tryceratops
# Documentation: https://github.com/guilatrova/tryceratops
# tryceratops - a linter for catching Python exception anti-patterns

local ret=1

_arguments -s -S \
  '--experimental[enable experimental analyzers]' \
  '*--ignore=[ignore specific violation code]:code:' \
  '*--exclude=[exclude directory path]:dir:_files -/' \
  '--autofix[autofix some violations]' \
  '*:path:_files' && ret=0

return ret
