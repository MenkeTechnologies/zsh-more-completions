#compdef plotHeatmap
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/plotHeatmap.html
# deepTools: create a heatmap for scores associated with genomic regions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --matrixFile)'{-m,--matrixFile}'[matrix file from computeMatrix]:file:_files' \
  '(-o -out --outFileName)'{-o,-out,--outFileName}'[output image file]:file:_files' \
  '--outFileSortedRegions[save sorted regions to file]:file:_files' \
  '--outFileNameMatrix[save underlying matrix values]:file:_files' \
  '--interpolationMethod[image interpolation method]:method:(auto nearest bilinear bicubic gaussian)' \
  '--dpi[image resolution]:dpi:' \
  '--kmeans[number of k-means clusters]:n:' \
  '--hclust[number of hierarchical clusters]:n:' \
  '--silhouette[compute silhouette scores]' \
  '--version[show version]' \
  '--plotType[plot type]:type:(lines fill se std)' \
  '--sortRegions[sort mode]:mode:(descend ascend no keep)' \
  '--sortUsing[sort metric]:metric:(mean median max min sum region_length)' \
  '--sortUsingSamples[sample numbers for sorting]:samples:' \
  '--clusterUsingSamples[samples for clustering]:samples:' \
  '--linesAtTickMarks[draw dashed lines at tick marks]' \
  '--averageTypeSummaryPlot[summary plot statistic]:type:(mean median min max std sum)' \
  '--missingDataColor[color for missing data]:color:' \
  '--colorMap[colormap]:cmap:' \
  '--colorList[custom color sequence]:colors:' \
  '--colorNumber[number of color transitions]:n:' \
  '--alpha[transparency (0-1)]:alpha:' \
  '(-min --zMin)'{-min,--zMin}'[minimum intensity value]:n:' \
  '(-max --zMax)'{-max,--zMax}'[maximum intensity value]:n:' \
  '--heatmapHeight[height in cm]:cm:' \
  '--heatmapWidth[width in cm]:cm:' \
  '--whatToShow[components to show]:what:("plot, heatmap and colorbar" "plot and heatmap" "heatmap only" "heatmap and colorbar")' \
  '--boxAroundHeatmaps[toggle box around heatmaps]:yn:(yes no)' \
  '(-x --xAxisLabel)'{-x,--xAxisLabel}'[x-axis label]:label:' \
  '--startLabel[region start label]:label:' \
  '--endLabel[region end label]:label:' \
  '--refPointLabel[reference point label]:label:' \
  '--labelRotation[x-axis label rotation degrees]:deg:' \
  '(-z --regionsLabel)'{-z,--regionsLabel}'[region labels]:labels:' \
  '--samplesLabel[sample labels]:labels:' \
  '(-T --plotTitle)'{-T,--plotTitle}'[plot title]:title:' \
  '(-y --yAxisLabel)'{-y,--yAxisLabel}'[y-axis label]:label:' \
  '--yMin[y-axis minimum]:n:' \
  '--yMax[y-axis maximum]:n:' \
  '--legendLocation[legend location]:loc:(best upper-right upper-left upper-center lower-left lower-right lower-center center center-left center-right none)' \
  '--perGroup[plot samples by group]' \
  '--plotFileFormat[output file format]:format:(png pdf svg eps plotly)' \
  '--verbose[verbose output]' && ret=0

return ret
