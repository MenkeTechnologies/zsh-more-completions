#compdef uairctl
# Documentation: https://man.archlinux.org/search?q=uairctl
# Reference accessed: 2026-05-16

# https://github.com/metent/uair — src/lib.rs Command (argh)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show uairctl help]' \
  {-s+}'[unix socket path]:socket:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a _uairctl_cmds
    _uairctl_cmds=(
      pause:'pause timer'
      resume:'resume timer'
      toggle:'toggle timer state'
      next:'next session'
      prev:'previous session'
      finish:'finish current session'
      jump:'jump to session id'
      reload:'reload config'
      fetch:'print timer state (format string)'
      listen:'stream timer updates'
    )
    _describe -t commands 'uairctl command' _uairctl_cmds && ret=0
    ;;
  (args)
    case $line[1] in
      (jump)
        _arguments ':session id:' && ret=0 ;;
      (fetch)
        _arguments ':output format string:' && ret=0 ;;
      (listen)
        _arguments \
          {-o+,--override=}'[timer override]:override:' \
          {-e,--exit}'[print once and exit]' && ret=0 ;;
    esac ;;
esac

return ret
