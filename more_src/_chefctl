#compdef chefctl

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '(-l --lock-file)'{-l,--lock-file}'+[lock file]:file:_files' \
  '(-L --log-dir)'{-L,--log-dir}'+[log directory]:dir:_files -/' \
  '(-p --pidfile)'{-p,--pidfile}'+[PID file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-i --immediate)'{-i,--immediate}'[run immediately, no random splay]' \
  '(-s --splay)'{-s,--splay}'+[splay seconds]:sec:' \
  '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
  '(-W --whyrun)'{-W,--whyrun}'[why-run mode]' \
  '(-x --debug)'{-x,--debug}'[debug mode]' \
  '(--once)--once[run chef-client once]' \
  '(--no-lock)--no-lock[do not acquire lock]' \
  '(-H --human)'{-H,--human}'[human-readable output]' \
  '(--periodic)--periodic[periodic run]' \
  '(--report-options)--report-options=+[report options]:opts:' \
  '*:chef-client-args:' && ret=0

return ret
