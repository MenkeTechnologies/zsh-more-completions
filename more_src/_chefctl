#compdef chefctl
# Documentation: https://github.com/facebook/chef-utils/blob/main/chefctl/src/chefctl.rb
# Reference accessed: 2026-05-17
# Verified: upstream source at the URL above (Facebook chef-utils chefctl.rb option parsing).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-C --config)'{-C,--config}'+[chefctl config file]:file:_files' \
  '(-p --plugin-path)'{-p,--plugin-path}'+[chefctl plugin file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-c --color)'{-c,--color}'[enable colored output]' \
  '(-d --debug)'{-d,--debug}'[activate chef debug mode]' \
  '(-H --human)'{-H,--human}'[use human-readable report handlers]' \
  '(-n --why-run)'{-n,--why-run}'[why-run / dry-run mode]' \
  '(-i --immediate)'{-i,--immediate}'[run immediately, no splay, stop queued]' \
  '(-l --lock-timeout)'{-l,--lock-timeout}'+[lock acquisition timeout]:time:' \
  '(-L --lock-file)'{-L,--lock-file}'+[lock file location]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress terminal output]' \
  '(-s --splay)'{-s,--splay}'+[maximum random splay seconds]:sec:' \
  '(-t --trace)'{-t,--trace}'[detailed trace logging]' \
  '(-w --wait-for-chef)'{-w,--wait-for-chef}'[only wait for chef step]' \
  '--program=+[chefctl process name]:name:' \
  '--clowntown-disable-locking-mechanism[disable locking (single-run scenarios)]' \
  '--priority=+[process priority]:priority:' \
  '*:chef-client-args:' && ret=0

return ret
