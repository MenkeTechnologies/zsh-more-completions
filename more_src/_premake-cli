#compdef premake-cli
# _premake-cli — Premake project file generator CLI alias (Jess Perkins / Premake team, Lua/C); custom argparse
# upstream: https://github.com/premake/premake-core

_premake-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--cc=+[C compiler set]:c:(gcc clang msc)' \
        '--debugger=+[debugger]:str:' \
        '--dotnet=+[.NET framework]:n:(mono msnet pnet)' \
        '--file=+[script file]:file:_files -g "premake5.lua *.lua"' \
        '-f+[script file]:file:_files -g "premake5.lua *.lua"' \
        '--fatal[fatal warnings]' \
        '--insecure[insecure connections]' \
        '--interactive[run interactive mode]' \
        '--no-overwrite[no overwrite]' \
        '--os=+[target OS]:os:(linux macosx windows bsd haiku solaris ios tvos android)' \
        '--platform=+[platform]:list:' \
        '--scripts=+[script search path]:list:_files -/' \
        '--systemscript=+[system script]:file:_files' \
        '--verbose[verbose]' \
        '--version[show version]' \
        '--debug[debug]' \
        '*:action:(gmake gmake2 vs2005 vs2008 vs2010 vs2012 vs2013 vs2015 vs2017 vs2019 vs2022 xcode4 codeblocks codelite clean test self-test embed package)'
}

_premake-cli "$@"
