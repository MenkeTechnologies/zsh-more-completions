#compdef popularity-contest
# Debian package usage statistics reporter (popcon)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--su[run submission as root]' \
  '--crunch[produce machine-readable output]' \
  '--cachedir[cache directory]:dir:_files -/' \
  '--submission[generate and submit report]' \
  && return 0
