#compdef Gctf
# Documentation: https://hpc.nih.gov/apps/Gctf.html
# Gctf - GPU real-time CTF determination and correction (Kai Zhang)

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--apix[pixel size in Angstrom]:apix' \
  '--dstep[detector step / pixel size in micrometer]:dstep' \
  '--kV[acceleration voltage in kV]:kv' \
  '--cs[spherical aberration in mm]:cs' \
  '--ac[amplitude contrast (0.04-0.1)]:ac' \
  '--boxsize[box size in pixels for FFT (512 or 1024)]:n' \
  '--resL[lowest resolution for search, Angstrom]:res' \
  '--resH[highest resolution for search, Angstrom]:res' \
  '--defL[lowest defocus to search, Angstrom]:def' \
  '--defH[highest defocus to search, Angstrom]:def' \
  '--defS[defocus search step, Angstrom]:step' \
  '--astm[estimated astigmatism in Angstrom]:astm' \
  '--bfac[B-factor to suppress high-resolution amplitude]:bfac' \
  '--overlap[overlapping factor for grid box sampling]:val' \
  '--convsize[box size for background smoothing]:n' \
  '--smooth_resL[resolution for low-frequency background smoothing]:res' \
  '--phase_shift_L[lowest phase shift to search, degrees]:ps' \
  '--phase_shift_H[highest phase shift to search, degrees]:ps' \
  '--phase_shift_S[phase shift search step, degrees]:step' \
  '--phase_shift_T[phase shift target: 1 CCC, 2 resolution limit]:t' \
  '--only_search_ps[only search phase shift]:val' \
  '--cosearch_refine_ps[refine during phase shift search]:val' \
  '--do_EPA[do equiphase average (0/1)]:val' \
  '--EPA_oversmp[EPA oversampling]:n' \
  '--do_Hres_ref[do high-resolution refinement]:val' \
  '--Href_resL[lowest resolution for high-res refinement]:res' \
  '--Href_resH[highest resolution for high-res refinement]:res' \
  '--Href_bfac[B-factor for high-res refinement]:bfac' \
  '--estimate_B[estimate B-factor]:val' \
  '--B_resL[lowest resolution for B-factor estimation]:res' \
  '--B_resH[highest resolution for B-factor estimation]:res' \
  '--do_validation[validate CTF determination]:val' \
  '--do_local_refine[refine local defocus (0/1)]:val' \
  '--local_radius[radius for local refinement]:r' \
  '--local_boxsize[box size for local refinement]:n' \
  '--local_overlap[overlap factor for local grid boxes]:val' \
  '--local_avetype[local average type: 0 equal, 1 single weight]:t' \
  '--refine_local_astm[refine local astigmatism]:val' \
  '--do_phase_flip[phase flip and write a new micrograph]:val' \
  '--ctfout_resL[lowest resolution for CTF diagnosis file]:res' \
  '--ctfout_resH[highest resolution for CTF diagnosis file]:res' \
  '--ctfout_bfac[B-factor for CTF diagnosis file]:bfac' \
  '--write_local_ctf[write local CTF star]:val' \
  '--plot_res_ring[plot resolution ring on diagnosis power spectrum]:val' \
  '--ctfstar[output CTF star file]:file:_files' \
  '--boxsuffix[suffix of box files for local refinement]:suffix' \
  '--do_unfinished[only process unfinished micrographs]:val' \
  '--skip_check_mrc[skip MRC format check]:val' \
  '--gid[GPU device id]:gid' \
  '*:micrograph:_files' && ret=0

return ret
