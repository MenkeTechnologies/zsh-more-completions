#   tungstenite    = "0.11"              (livereload websocket)
#   elasticlunr-rs = "2.3"               (client-side search index)
#   clap           = "2.33.3"            (old App/SubCommand API)
#
# === AXIS 151 OPENER — filesystem-watcher ecosystem ===
# Axis position: Rust=206 OPENS Axis 151 at slot 1/0/0.
# Canonical Rust fs watcher is `notify` by Félix Saparelli (passcod) — a
# cross-platform abstraction over inotify (Linux), FSEvents (macOS), and
# ReadDirectoryChangesW (Windows).  doctave uses notify to power live-reload
# in `doctave serve`, watching markdown source files and broadcasting reload
# events to the browser via a tungstenite websocket.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=206   ← THIS FILE              (axis 151 OPENS, slot 1/0/0)
#   Go=206     ← next round              (axis 151 continues, slot 2/0/0)
#   TS-Node=206 ← round after            (axis 151 CLOSES at triple-206, slot 1/1/1)
# ---------------------------------------------------------------------------

_doctave() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'init:Initialize a new project (start here!)'
        'build:Builds your site from the project'\''s Markdown files'
        'serve:Starts a live reloading development server to serve your documentation site'
        'help:Prints help information'
    )

    _arguments -C \
        '--no-color[disable terminal color output]' \
        '(- *)'{-h,--help}'[prints help information]' \
        '(- *)'{-V,--version}'[prints version information]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'doctave command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                init)  _doctave_init  && ret=0 ;;
                build) _doctave_build && ret=0 ;;
                serve) _doctave_serve && ret=0 ;;
                help)
                    _describe -t commands 'doctave command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

# `doctave init` — bootstrap a new project skeleton with docs/ + doctave.yaml
_doctave_init() {
    _arguments \
        '--docs-dir=[optional custom root directory for your documentation (default: docs/)]:directory:_files -/' \
        '--no-color[disable terminal color output]' \
        '(-h --help)'{-h,--help}'[prints help information]' \
        '(-V --version)'{-V,--version}'[prints version information]'
}

# `doctave build` — generate static site (HTML+search index) from Markdown
_doctave_build() {
    _arguments \
        '--release[build the site in release mode]' \
        '--allow-failed-checks[do not return an error if there are failed checks]' \
        '--no-color[disable terminal color output]' \
        '(-h --help)'{-h,--help}'[prints help information]' \
        '(-V --version)'{-V,--version}'[prints version information]'
}

# `doctave serve` — live-reload dev server (notify-driven file watcher + ws)
_doctave_serve() {
    _arguments \
        '(-p --port)'{-p,--port=}'[port used to serve the documentation site (positive integer)]:port:_ports' \
        '--no-color[disable terminal color output]' \
        '(-h --help)'{-h,--help}'[prints help information]' \
        '(-V --version)'{-V,--version}'[prints version information]'
}

_doctave "$@"
