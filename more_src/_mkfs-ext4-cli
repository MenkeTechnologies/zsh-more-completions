#compdef mkfs-ext4-cli mkfs.ext4-cli mkfs-ext3-cli mkfs-ext2-cli
# _mkfs-ext4-cli — e2fsprogs mkfs.ext4 ext4 filesystem creator CLI alias (e2fsprogs team, C); custom argparse
# upstream: https://github.com/tytso/e2fsprogs

_mkfs-ext4-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-V[show version]' \
        '-c[check for bad blocks first]' \
        '-cc[check for bad blocks with rw test]' \
        '-d+[source dir to copy]:dir:_files -/' \
        '-D[direct IO]' \
        '-E+[extended options]:str:' \
        '-F[force]' \
        '-i+[bytes per inode]:n:' \
        '-I+[inode size bytes]:n:' \
        '-j[create journal]' \
        '-J+[journal options]:str:' \
        '-l+[bad blocks file]:file:_files' \
        '-L+[volume label]:str:' \
        '-m+[reserved blocks pct]:n:' \
        '-M+[last mounted dir]:dir:_files -/' \
        '-n[no action]' \
        '-N+[number of inodes]:n:' \
        '-o+[creator os]:str:' \
        '-O+[features]:str:' \
        '-q[quiet]' \
        '-r+[fs revision]:n:' \
        '-S[write only superblock]' \
        '-T+[usage type]:str:' \
        '-t+[fs type]:t:(ext2 ext3 ext4)' \
        '-U+[uuid]:str:' \
        '-v[verbose]' \
        '-z+[undo file]:file:_files' \
        '-G+[flex bg size]:n:' \
        '-g+[blocks per group]:n:' \
        '-C+[cluster size]:n:' \
        '-b+[block size]:n:' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper}*"'
}

_mkfs-ext4-cli "$@"
