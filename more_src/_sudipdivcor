#compdef sudipdivcor
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/amplitudes/sudipdivcor.c
# Dip-dependent divergence (spreading) correction

local ret=1

_arguments -s -S \
  'dxcdp=[distance between successive cdps in meters]:dxcdp' \
  'np=[number of slopes]:np' \
  'tmig=[times corresponding to rms velocities in vmig]:tmig' \
  'vmig=[rms velocities corresponding to times in tmig]:vmig' \
  'vfile=[binary file containing velocities vmig(t)]:vfile:_files' \
  'conv=[=1 to apply the conventional divergence correction]:conv:(0 1)' \
  'trans=[=1 to include transmission factors]:trans:(0 1)' \
  'verbose=[=1 for diagnostic print]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
