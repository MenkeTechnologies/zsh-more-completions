#compdef datezone
# Documentation: https://man.archlinux.org/man/datezone.1.en
# dateutils: inspect date/time values across timezones

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help and exit]' \
  '(-V --version)'{-V,--version}'[output version information and exit]' \
  '(-q --quiet)'{-q,--quiet}'[suppress parser error and fix-up messages]' \
  '(-b --base)'{-b+,--base=}'[fallback DT to fill in missing fields]:datetime:' \
  '*'{-i+,--input-format=}'[input format string]:format:' \
  '--from-locale=[interpret input dates as coming from LOCALE]:locale:' \
  '--from-zone=[interpret input dates as coming from ZONE]:zone:' \
  '--next[show next transition from/to DST]' \
  '--prev[show previous transition from/to DST]' \
  '*:zone:' && ret=0

return ret
