#compdef alass-cli alass
# Documentation: https://github.com/kaegi/alass
# alass-cli — automatic language-agnostic subtitle synchronization

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-V --version)'{-V,--version}'[show version number]' \
  '(-p --split-penalty)'{-p,--split-penalty}'[how eager the algorithm is to avoid splitting subtitles]:value' \
  '(-i --interval)'{-i,--interval}'[smallest recognized time interval in ms]:ms' \
  '(-n --allow-negative-timestamps)'{-n,--allow-negative-timestamps}'[permit negative timestamps in output]' \
  '--sub-fps-ref=[fps for accompanying video of MicroDVD .sub reference]:fps' \
  '--sub-fps-inc=[fps for accompanying video of MicroDVD .sub incorrect]:fps' \
  '--encoding-ref=[charset encoding of the reference subtitle file]:encoding' \
  '--encoding-inc=[charset encoding of the incorrect subtitle file]:encoding' \
  '(-O --speed-optimization)'{-O,--speed-optimization}'[speed up synchronization by sacrificing accuracy]:value' \
  '(-t --statistics-required-tag)'{-t,--statistics-required-tag}'[filter statistics output by tag]:tag' \
  '(-l --no-split)'{-l,--no-split}'[synchronize without looking for splits/breaks]' \
  '(-g --disable-fps-guessing)'{-g,--disable-fps-guessing}'[disable framerate difference detection]' \
  '--index=[audio index in the reference video file]:index' \
  '1:reference file:_files' \
  '2:incorrect subtitle:_files' \
  '3:output file:_files' && ret=0

return ret
