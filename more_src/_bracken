#compdef bracken bracken-build est_abundance.py kmer2read_distr generate_kmer_distribution
# _bracken — Jennifer Lu Bayesian Reestimation of Abundance with KrakEN species abundance estimator companion to Kraken2 (jenniferlu717 team, Python/C++); getopt
# upstream: https://github.com/jenniferlu717/Bracken

_bracken() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-d+[Kraken database dir]:dir:_files -/' \
        '--db=+[Kraken database dir]:dir:_files -/' \
        '-i+[input Kraken report]:file:_files -g "*.report *.kreport *.kreport2"' \
        '--input=+[input Kraken report]:file:_files -g "*.report *.kreport *.kreport2"' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-w+[output report]:file:_files' \
        '--out-report=+[output report]:file:_files' \
        '-r+[read length]:n:' \
        '--read_length=+[read length]:n:' \
        '-l+[level]:l:(K P C O F G S S1 D)' \
        '--level=+[level]:l:(K P C O F G S S1 D)' \
        '-t+[threshold]:n:' \
        '--threshold=+[threshold]:n:' \
        '-k+[kmer length]:n:' \
        '--kmer_len=+[kmer length]:n:' \
        '-x+[kmer distribution file]:file:_files' \
        '--kmer_distr=+[kmer distribution file]:file:_files' \
        '-y+[type]:t:(kraken kraken2)' \
        '--type=+[type]:t:(kraken kraken2)' \
        '*:input kreport:_files -g "*.report *.kreport *.kreport2"'
}

_bracken "$@"
