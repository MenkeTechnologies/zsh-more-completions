#compdef packit
# Documentation: https://man.archlinux.org/search?q=packit
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

local -a modes
modes=(
  'inject:inject custom packets'
  'capture:capture and decode packets'
  'replay:replay captured packets'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-m --mode)'{-m+,--mode=}'[run mode]:mode:(inject capture replay)' \
  '(-i --interface)'{-i+,--interface=}'[interface]:if:_net_interfaces' \
  '(-c --count)'{-c+,--count=}'[packet count]:n:' \
  '(-p --payload)'{-p+,--payload=}'[payload]:p:' \
  '(-w --wait)'{-w+,--wait=}'[wait between]:s:' \
  '(-T --type)'{-T+,--type=}'[packet type]:t:(IPv4 IPv6 ICMP ICMPv6 TCP UDP ARP)' \
  '(-s --source)'{-s+,--source=}'[source IP]:ip:' \
  '(-d --destination)'{-d+,--destination=}'[dest IP]:ip:' \
  '(-S --srcport)'{-S+,--srcport=}'[source port]:port:' \
  '(-D --dstport)'{-D+,--dstport=}'[dest port]:port:' \
  '(-f --filter)'{-f+,--filter=}'[bpf filter]:filter:' \
  '(-F --flags)'{-F+,--flags=}'[TCP flags]:flags:' \
  '(-W --window)'{-W+,--window=}'[TCP window size]:n:' \
  '(-q --seqnum)'{-q+,--seqnum=}'[seq number]:n:' \
  '(-a --acknum)'{-a+,--acknum=}'[ack number]:n:' \
  '(-e --hwsource)'{-e+,--hwsource=}'[source MAC]:mac:' \
  '(-E --hwdest)'{-E+,--hwdest=}'[dest MAC]:mac:' \
  '(-t --ttl)'{-t+,--ttl=}'[TTL]:n:' \
  '(-Z --tos)'{-Z+,--tos=}'[ToS]:n:' \
  '(-r --read)'{-r+,--read=}'[read pcap]:file:_files -g "*.pcap"' \
  '(-o --output)'{-o+,--output=}'[output pcap]:file:_files' \
  '(-n --nonum)'{-n,--nonum}'[no numeric]' \
  '(-x --xdump)'{-x,--xdump}'[hex dump]' \
  '(-X --noxdump)'{-X,--noxdump}'[no hex dump]' \
  '(-v --verbose)*'{-v,--verbose}'[verbose]' \
  '(-Q --quiet)'{-Q,--quiet}'[quiet]' \
  '*: :' && ret=0

return ret
