_bsky() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '-a+[profile name]:profile:' \
        '-V[verbose mode]' \
        '1: :_bsky_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                show-profile|follows|followers)
                    _arguments \
                        '(-H --handle)'{-H,--handle}'=[user handle]:handle:' \
                        '--json[output JSON]' && ret=0 ;;
                update-profile)
                    _arguments \
                        '--avatar=[avatar image]:file:_files' \
                        '--banner=[banner image]:file:_files' \
                        '*::display-name + description:' && ret=0 ;;
                show-session|blocks|mutes|notification|votes|reposts)
                    _arguments '--json[output JSON]' && ret=0 ;;
                timeline|tl|thread)
                    _arguments \
                        '(-H --handle)'{-H,--handle}'=[user handle]:handle:' \
                        '-n+[number of items (default 30)]:n:' \
                        '--json[output JSON]' && ret=0 ;;
                stream)
                    _arguments \
                        '--cursor=[cursor]:cursor:' \
                        '(-H --handle)'{-H,--handle}'=[user handle]:handle:' \
                        '--pattern=[content pattern regex]:regex:' \
                        '--reply=[filter replies of event ID]:id:' \
                        '--json[output JSON]' && ret=0 ;;
                post)
                    _arguments \
                        '-r+[reply to URL or post id]:reply:' \
                        '-q+[quote-repost URL or post id]:quote:' \
                        '--stdin[read content from stdin]' \
                        '*'{-i,--image}'=[attach an image (repeatable)]:image:_files' \
                        '*--ia=[alt text for image (repeatable)]:alt:' \
                        '*--image-alt=[alt text for image (repeatable)]:alt:' \
                        '(-v --video)'{-v,--video}'=[attach a video]:video:_files' \
                        '--va=[alt text for video]:alt:' \
                        '--video-alt=[alt text for video]:alt:' \
                        '*::post text:' && ret=0 ;;
                vote)
                    _arguments \
                        '--down[cast a down-vote (legacy)]' \
                        '1:URL or post id:' && ret=0 ;;
                follow|unfollow|block|unblock|mute|unmute)
                    _arguments '1:handle:' && ret=0 ;;
                repost|delete|report)
                    _arguments '1:URL or post id:' && ret=0 ;;
                search|search-actors)
                    _arguments '1:query:' && ret=0 ;;
                add-app-password|revoke-app-password)
                    _arguments '1:app password name:' && ret=0 ;;
                login|list|lists|moderation-list|list-app-passwords|invite-codes|chat|mcp)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_bsky_commands] )) ||
_bsky_commands() {
    local -a commands
    commands=(
        'login:authenticate against a PDS and persist the session'
        'show-profile:show a profile'
        'update-profile:update your profile'
        'show-session:show the current session'
        'timeline:show your home timeline'
        'tl:show your home timeline (alias for timeline)'
        'stream:stream the firehose'
        'thread:show a thread'
        'search:search posts'
        'search-actors:search actors'
        'notification:show notifications'
        'post:publish a post'
        'delete:delete a post / record'
        'vote:like a post'
        'votes:list likes for a post'
        'repost:repost a post'
        'reposts:list reposts for a post'
        'follow:follow an account'
        'unfollow:unfollow an account'
        'follows:list who you follow'
        'followers:list who follows you'
        'block:block an account'
        'unblock:unblock an account'
        'blocks:list blocked accounts'
        'mute:mute an account'
        'unmute:unmute an account'
        'mutes:list muted accounts'
        'list:list lists / show members of a list'
        'lists:list all lists you own'
        'moderation-list:manage moderation lists'
        'report:submit a moderation report'
        'add-app-password:generate a new app password'
        'list-app-passwords:list your app passwords'
        'revoke-app-password:revoke an app password'
        'invite-codes:list invite codes'
        'chat:open an interactive chat REPL'
        'mcp:run as an MCP server for AI agents'
    )
    _describe -t commands 'bsky command' commands
}

_bsky "$@"
