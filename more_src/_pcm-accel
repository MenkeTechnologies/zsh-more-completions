#compdef pcm-accel
# Documentation: https://raw.githubusercontent.com/intel/pcm/master/src/pcm-accel.cpp
# Intel PCM accelerator monitor (IAA / DSA / QAT)

local ret=1

_arguments -s -S \
  '(-h --help /h)'{-h,--help,/h}'[show help]' \
  '-silent[suppress informational output]' \
  '-iaa[display IAA accelerator measurements]' \
  '-dsa[display DSA accelerator measurements]' \
  '-qat[display QAT accelerator measurements]' \
  '-numa[show accelerator device NUMA node mapping]' \
  '-evt=[custom event configuration file]:file:_files' \
  '-csv[output CSV to screen]' \
  '-csv=[output CSV to file]:file:_files' \
  '-csv-delimiter=[set CSV delimiter character]:delimiter' \
  '-human-readable[human-readable CSV formatting]' \
  '(-i /i)'{-i=,/i=}'[number of iterations]:count' \
  '*::interval:_normal' && ret=0

return ret
