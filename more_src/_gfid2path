#compdef gfid2path glusterfind-gfid2path
# Documentation: https://man.archlinux.org/search?q=gfid2path
# Reference accessed: 2026-05-16

# gfid2path: resolve GFID to file path (Gluster)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '*:gfid:_files' && ret=0
return ret
