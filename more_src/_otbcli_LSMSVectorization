#compdef otbcli_LSMSVectorization
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_LSMSVectorization.html
# Orfeo ToolBox: final step of LSMS, vectorize a label image to GIS polygons

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image of spectral signatures]:image:_files' \
  '-inseg[segmented label image]:image:_files' \
  '-out[output GIS vector file]:output:_files' \
  '-tilesizex[size of tiles along X-axis]:value:' \
  '-tilesizey[size of tiles along Y-axis]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
