#compdef gmailctl
# Documentation: https://man.archlinux.org/search?q=gmailctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'init:write starter config'
      'diff:diff live Gmail filters vs config'
      'export:export current filters to stdout'
      'apply:apply config to Gmail'
      'download:download filters JSON from Gmail'
      'edit:edit config with $EDITOR'
    )
    _describe -t commands 'gmailctl command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-c --config)'{-c,--config}'=[config file]:file:_files' \
      '(-y --yes)'{-y,--yes}'[non-interactive]' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
