#compdef claude-code claude
# Documentation: https://man.archlinux.org/search?q=claude-code
# Reference accessed: 2026-05-16

_claude-code() {
    local line state
    local -a commands
    commands=(
        'doctor:Diagnose installation or configuration issues'
        '--version:Check installed version'
    )

    _arguments -C \
        '(-c --continue)'{-c,--continue}'[Continue most recent conversation]' \
        '(-p --print)'{-p,--print}'[Execute prompt and exit]' \
        '(-r --resume)'{-r,--resume}'[Resume a specific session]:session-id:' \
        '1: :->command' \
        '*: :_files'

    case $state in
        command)
            _describe -t commands 'claude command' commands
            ;;
    esac
}

_claude-code "$@"
