#compdef httpry
# Documentation: https://man.archlinux.org/search?q=httpry
# Reference accessed: 2026-05-16

# Zsh completion for httpry HTTP log sniffer

_arguments -s -S \
  '(-h --help)'{-h,--help}'[usage]' \
  '(-i --interface)'{-i,--interface}'[capture interface]:iface' \
  '(-o --output)'{-o,--output}'[pcap-output file]:file:_files' \
  '(-r --read-file)'{-r,--read-file}'[read packets from file]:file:_files' \
  '*:BPF filter expression:_message "tcpdump filter"' && ret=0

return ret
