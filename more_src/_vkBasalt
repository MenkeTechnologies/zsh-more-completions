#compdef vkBasalt

# Zsh completion for vkBasalt - Vulkan post-processing layer
# vkBasalt is typically used as an environment variable (ENABLE_VKBASALT=1)
# but also provides a configuration-oriented CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config=[path to config file]:config file:_files -g "*.conf"' \
  '*:command and arguments: _normal' && ret=0

return ret
