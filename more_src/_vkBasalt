#compdef vkBasalt
# Documentation: https://github.com/DadSchoorse/vkBasalt
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: vkBasalt has no CLI binary; it operates as a Vulkan layer
# enabled via ENABLE_VKBASALT=1 and configured via env vars
# (VKBASALT_CONFIG_FILE, VKBASALT_LOG_LEVEL, VKBASALT_LOG_FILE).

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:file:_files' && ret=0
return ret
