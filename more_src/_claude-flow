#compdef claude-flow
# Documentation: https://www.npmjs.com/package/claude-flow
# Reference accessed: 2026-05-23
# Verified: npx claude-flow --help.

# Zsh completion for claude-flow - RuFlo AI agent orchestration CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize RuFlo in the current directory'
  'start:start the RuFlo orchestration system'
  'status:show system status'
  'agent:agent management commands'
  'swarm:swarm coordination commands'
  'memory:memory management commands'
  'task:task management commands'
  'session:session management commands'
  'mcp:MCP server management'
  'hooks:self-learning hooks system'
  'neural:neural pattern training and learning'
  'security:security scanning and threat modeling'
  'performance:performance profiling and benchmarking'
  'embeddings:vector embeddings and semantic search'
  'hive-mind:consensus-based multi-agent coordination'
  'ruvector:RuVector PostgreSQL bridge management'
  'guidance:guidance control plane commands'
  'autopilot:persistent swarm completion'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'claude-flow command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '(-f --force)'{-f,--force}'[overwrite existing configuration]' \
          '(-m --minimal)'{-m,--minimal}'[create minimal configuration]' \
          '--full[create full configuration with all components]' \
          '--skip-claude[skip .claude/ directory creation]' \
          '--only-claude[only create .claude/ directory]' \
          '--start-all[auto-start daemon, memory, and swarm after init]' \
          '--start-daemon[auto-start daemon after init]' \
          '--with-embeddings[initialize ONNX embedding subsystem]' \
          '--embedding-model=[ONNX embedding model]:model:(all-MiniLM-L6-v2 all-mpnet-base-v2)' \
          '--codex[initialize for OpenAI Codex CLI]' && ret=0 ;;
      (start|status|agent|swarm|memory|task|session|mcp|hooks|neural|security|performance|embeddings|hive-mind|ruvector|guidance|autopilot|help)
        _arguments '*::args:' && ret=0 ;;
    esac ;;
esac

return ret
