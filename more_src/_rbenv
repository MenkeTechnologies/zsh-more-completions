#compdef rbenv

# Zsh completion for rbenv - Simple Ruby Version Management

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'commands:List all available rbenv commands'
  'exec:Run an executable with the selected Ruby version'
  'global:Set or show the global Ruby version'
  'help:Display help for a command'
  'hooks:List hook scripts for a given rbenv command'
  'init:Configure the shell environment for rbenv'
  'install:Install a Ruby version using ruby-build'
  'local:Set or show the local application-specific Ruby version'
  'prefix:Display prefixes for Ruby versions'
  'rehash:Rehash rbenv shims (run after installing executables)'
  'root:Display the root directory where versions and shims are kept'
  'shell:Set or show the shell-specific Ruby version'
  'shims:List existing rbenv shims'
  'uninstall:Uninstall a specific Ruby version'
  'version:Show the current Ruby version and its origin'
  'version-file:Detect the file that sets the current rbenv version'
  'version-name:Show the current Ruby version'
  'version-origin:Explain how the current Ruby version is set'
  'versions:List all Ruby versions available to rbenv'
  'whence:List all Ruby versions that contain the given executable'
  'which:Display the full path to an executable'
)

_arguments -s -S \
  '--version[display the version of rbenv]' \
  '-h[display help]' \
  '--help[display help]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments \
          '(-l --list)'{-l,--list}'[list latest stable versions]' \
          '(-L --list-all)'{-L,--list-all}'[list all local versions]' \
          '-f[install even if the version appears to be installed already]' \
          '--force[install even if the version appears to be installed already]' \
          '-s[skip if the version appears to be installed already]' \
          '--skip-existing[skip if the version appears to be installed already]' \
          '-v[verbose: print compilation status to stdout]' \
          '--verbose[verbose: print compilation status to stdout]' \
          ':version:' && ret=0
        ;;
      uninstall)
        _arguments \
          '-f[attempt to remove the specified version without prompting]' \
          '--force[attempt to remove without prompting]' \
          ':version:($(rbenv versions --bare 2>/dev/null))' && ret=0
        ;;
      global|local|shell)
        _arguments ':version:(system $(rbenv versions --bare 2>/dev/null))' && ret=0
        ;;
    esac
    ;;
esac

return ret
