#compdef opencv_createsamples
# Documentation: https://docs.opencv.org/4.x/dc/d88/tutorial_traincascade.html
# opencv_createsamples — generate positive samples for cascade training

local ret=1

_arguments -s -S \
  '-vec[output file containing the positive samples]:file:_files' \
  '-img[source object image]:file:_files' \
  '-bg[background description file]:file:_files' \
  '-num[number of positive samples to generate]:num' \
  '-bgcolor[background color (grayscale)]:color' \
  '-bgthresh[background color threshold]:thresh' \
  '-inv[invert colors]' \
  '-randinv[invert colors randomly]' \
  '-maxidev[maximal intensity deviation of foreground pixels]:dev' \
  '-maxxangle[maximal rotation angle towards x-axis (radians)]:angle' \
  '-maxyangle[maximal rotation angle towards y-axis (radians)]:angle' \
  '-maxzangle[maximal rotation angle towards z-axis (radians)]:angle' \
  '-show[show each generated sample]' \
  '-w[width of output samples in pixels]:width' \
  '-h[height of output samples in pixels]:height' \
  '-info[description file of marked up images collection]:file:_files' && ret=0

return ret
