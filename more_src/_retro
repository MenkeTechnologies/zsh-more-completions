#compdef retro
# _retro — Charles Childers RETRO modern personal concatenative Forth-like dialect with literate sources (crcx team, C); custom argparse
# upstream: http://retroforth.org

_retro() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i[interactive listener]' \
        '--interactive[interactive listener]' \
        '-c[skip the listener]' \
        '-u+[use image]:file:_files' \
        '--use=+[use image]:file:_files' \
        '-f+[run file]:file:_files -g "*.retro *.forth *.txt *.muri"' \
        '--file=+[run file]:file:_files -g "*.retro *.forth *.txt *.muri"' \
        '-t+[run a token]:str:' \
        '--run=+[run a token]:str:' \
        '-s[ignore stdin until EOF]' \
        '--silent[silent mode]' \
        '-q[quiet mode]' \
        '--quiet[quiet mode]' \
        '*:retro source:_files -g "*.retro *.forth *.txt *.muri"'
}

_retro "$@"
