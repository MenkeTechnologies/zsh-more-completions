#compdef fregot
# Documentation: https://github.com/fugue/fregot/blob/main/README.md
# fregot - Fugue Rego Toolkit, an alternative REPL and toolset for OPA Rego

local ret=1
local -a commands

commands=(
  'repl:start an interactive read-eval-print loop'
  'eval:evaluate a Rego expression'
  'test:run rules prefixed with test_'
  'bundle:compile Rego files into a single bundle'
  'capabilities:print supported built-in functions with types'
)

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--dump=[dump debug information]:tag' \
  '--format=[error message format]:format:(text json)' \
  '(-v --verbosity)'{-v,--verbosity}'=[set output verbosity]:level:(0 1)' \
  '(-i --input)'{-i,--input}'=[input file path]:file:_files' \
  '(-o --output)'{-o,--output}'=[output bundle file path]:file:_files' \
  '--watch[enable file watching]' \
  '-O[enable optimizations while debugging]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'fregot command' commands && ret=0
    ;;
  args)
    _files -g '*.rego' && ret=0
    ;;
esac

return ret
