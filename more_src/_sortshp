#compdef sortshp
# Documentation: https://mapserver.org/utilities/sortshp.html
# Sort an Esri shapefile on a single column in ascending or descending order

local ret=1

_arguments -s \
  '1:input shapefile:_files -g "*.shp"' \
  '2:output shapefile:_files' \
  '3:item (column name):' \
  '4:order:(ascending descending)' && ret=0

return ret
