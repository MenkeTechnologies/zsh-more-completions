#compdef mri_mask
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_mask
# FreeSurfer apply a mask volume to an input volume

local ret=1

_arguments -s -S \
  '-xform[apply LTA transform to align mask to input]:xform:_files' \
  '-invert[reversely apply -xform]' \
  '-lta_src[source volume for -xform]:src:_files' \
  '-lta_dst[target volume for -xform]:dst:_files' \
  '-T[threshold mask volume at value]:thresh:' \
  '-bb[extract bounding box around mask, pad npad voxels]:npad:' \
  '-abs[take abs() before applying threshold]' \
  '-transfer[transfer only voxel value from mask to out]:value:' \
  '-keep_mask_deletion_edits[transfer voxel-deletion edits from mask to out]' \
  '*:volume:_files' && ret=0

return ret
