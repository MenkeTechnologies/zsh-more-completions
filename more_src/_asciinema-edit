#compdef asciinema-edit
# Documentation: https://github.com/cirocosta/asciinema-edit
# asciinema-edit - asciinema casts post-production tools

local ret=1
local curcontext="$curcontext" state line

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print the version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'asciinema-edit command' \
      'quantize[update cast delays following quantization ranges]' \
      'cut[remove a certain range of time frames]' \
      'speed[update the cast speed by a certain factor]' && ret=0
    ;;
  args)
    case $line[1] in
      quantize)
        _arguments -s \
          '--range=[quantization ranges (comma delimited)]:ranges' \
          '--out=[file to write the modified contents to]:file:_files' \
          '1:cast file:_files' && ret=0
        ;;
      cut)
        _arguments -s \
          '--start=[initial frame timestamp]:start' \
          '--end=[final frame timestamp]:end' \
          '--out=[file to write the modified contents to]:file:_files' \
          '1:cast file:_files' && ret=0
        ;;
      speed)
        _arguments -s \
          '--factor=[number by which delays are multiplied]:factor' \
          '--start=[initial frame timestamp]:start' \
          '--end=[final frame timestamp]:end' \
          '--out=[file to write the modified contents to]:file:_files' \
          '1:cast file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
