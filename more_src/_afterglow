#compdef afterglow afterglow.pl
# _afterglow — Raffael Marty afterglow (Perl tool turning network logs into a graphviz / GDF graph for visualization with Gephi or GraphViz; -c color config, -e edge config, -m max nodes, -t input is tcpdump output, -o output format (dot|gdf|gml|csv), -f input file, -p print stats, -k filter regex, -d skip duplicates, -g group/cluster mode)
# upstream: https://github.com/zrlram/afterglow
# Flags from afterglow src/perl/afterglow.pl on tip.

_afterglow() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-c+[color config]:file:_files -g "*.properties"' \
        '-e+[edge config]:file:_files' \
        '-m+[max nodes]:n:' \
        '-t[tcpdump input]' \
        '-o+[output format]:format:(dot gdf gml csv)' \
        '-f+[input file]:file:_files' \
        '-p[print stats]' \
        '-k+[filter regex]:regex:' \
        '-d[skip duplicate edges]' \
        '-g[group/cluster mode]' \
        '-x+[exclude regex]:regex:'
}

_afterglow "$@"
