#compdef tsduck tsversion tsconfig
# _tsduck — Thierry Lelegard TSDuck MPEG-2 transport-stream toolkit version and config helpers reporting build features supported plugins SRT/RIST/Dektec/HiDes capabilities (tsduck team, C++); custom argparse
# upstream: https://github.com/tsduck/tsduck

_tsduck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--version[show version]' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-c[output as code]' \
        '--integer[integer version]' \
        '--all[show all info]' \
        '--bin[bin directory]' \
        '--config[config directory]' \
        '--dvb-table-encoding[DVB table encoding]' \
        '--input-directory[input directory]' \
        '--install-prefix[install prefix]' \
        '--lib[lib directory]' \
        '--module[module directory]' \
        '--output-directory[output directory]' \
        '--plugin[plugin directory]' \
        '--python[Python path]' \
        '--java[Java path]' \
        '--vatek[VATek support]' \
        '--dektec[Dektec support]' \
        '--hides[HiDes support]' \
        '--srt[SRT support]' \
        '--rist[RIST support]' \
        '--brief[brief output]' \
        '--list-plugins[list plugins]' \
        '--list-formats[list formats]' \
        '--list-charsets[list charsets]' \
        '--list-tables[list tables]' \
        '--list-descriptors[list descriptors]'
}

_tsduck "$@"
