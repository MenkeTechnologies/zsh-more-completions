#compdef sublist3r-cli sublist3r
# _sublist3r-cli — Ahmed Aboul-Ela sublist3r-cli CLI command-line frontend wrapping the Sublist3r open-source Python tool designed to enumerate subdomains of websites using OSINT search engines Google Yahoo Bing Baidu Ask plus Netcraft VirusTotal ThreatCrowd DNSdumpster ReverseDNS PassiveDNS SSL-CT-logs SubBrute SOA bruteforce concurrent-thread wordlist verbose-mode (Ahmed Aboul-Ela team, Python); argparse
# upstream: https://github.com/aboul3la/Sublist3r

_sublist3r-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d+[domain]:str:' \
        '--domain=+[name]:str:' \
        '-b+[bruteforce]:str:' \
        '--bruteforce[bruteforce]' \
        '-p+[port]:str:' \
        '--ports=+[ports]:str:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-e+[engines]:e:(baidu yahoo google bing ask netcraft virustotal threatcrowd ssl passivedns dnsdumpster all)' \
        '--engines=+[e]:e:(baidu yahoo google bing ask netcraft virustotal threatcrowd ssl passivedns dnsdumpster all)' \
        '-o+[output file]:file:_files -g "*.txt *.json"' \
        '--output=+[file]:file:_files -g "*.txt *.json"' \
        '-n[no color]' \
        '*:args:'
}

_sublist3r-cli "$@"
