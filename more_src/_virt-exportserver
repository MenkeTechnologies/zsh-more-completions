#compdef virt-exportserver
# _virt-exportserver — KubeVirt VirtualMachineExport server pod (streams VM disks over HTTPS)
# upstream: https://github.com/kubevirt/kubevirt
# Flags from cmd/virt-exportserver/virt-exportserver.go on tip; runtime config primarily via env vars (CERT_FILE, KEY_FILE, TOKEN_FILE, EXPORT_NAME, DEADLINE, VM_INFO, VOLUME_INFO).

_virt-exportserver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[log to stderr and files]' \
        '--stderrthreshold=[stderr threshold level]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:' \
        '--log-file=[log file destination]:file:_files'
}

_virt-exportserver "$@"
