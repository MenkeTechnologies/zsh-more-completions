#compdef octosql

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config[path to config file]:config file:_files' \
  '(-o --output)'{-o,--output}'[output format]:format:(live_table batch_table json csv stream_native)' \
  '(-d --describe)'{-d,--describe}'[describe the schema of a data source]:source:' \
  '*:SQL query:' \
  && ret=0

return ret
