#compdef dipy_align_affine
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_align_affine.html
# DIPY: affine image registration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--transform=[transformation type]:type:(com trans rigid rigid_isoscaling rigid_scaling affine)' \
  '--nbins=[number of bins for PDF discretization]:n' \
  '--sampling_prop=[percentage of voxels for PDF calculation]:pct' \
  '--metric=[similarity metric for mutual information]:metric' \
  '--level_iters=[iterations per scale]:iters' \
  '--sigmas=[smoothing parameters for scale space]:sigmas' \
  '--factors=[scale factors for scale space]:factors' \
  '--progressive=[enable/disable progressive registration]:bool:(True False)' \
  '--save_metric=[save quality assessment metrics]:bool:(True False)' \
  '--static_vol_idx=[indices for 4D static volumes]:idx' \
  '--moving_vol_idx=[indices for 4D moving volumes]:idx' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_moved=[filename for transformed image]:file:_files' \
  '--out_affine=[filename for affine matrix]:file:_files' \
  '--out_quality=[filename for quality metric file]:file:_files' \
  '*:image (static moving):_files' && ret=0

return ret
