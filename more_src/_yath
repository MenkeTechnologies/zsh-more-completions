#compdef yath
# Documentation: https://metacpan.org/pod/App::Yath
# yath - Yet Another Test Harness (Test2::Harness) CLI

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-j --jobs --job-count)'{-j,--jobs,--job-count}'+[set number of concurrent jobs]:jobs' \
  '(-x --slots-per-job)'{-x,--slots-per-job}'+[slots per job]:slots' \
  '(-r --retry)'{-r,--retry}'+[retry failed jobs N times]:count' \
  '--retry-isolated[retry failed jobs in isolation]' \
  '--rerun-failed[rerun previously failed tests]' \
  '--color[enable color output]' \
  '--no-color[disable color output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--progress[show progress]' \
  '--no-progress[disable progress]' \
  '(-T --show-times)'{-T,--show-times}'[show per-test timing data]' \
  '--notify-slack=[send slack notification]:target' \
  '--notify-slack-fail=[slack notification on failure]:target' \
  '--notify-email=[send email notification]:email' \
  '--notify-text=[notification message]:text' \
  '--exclude-file=[exclude file]:file:_files' \
  '--exclude-pattern=[exclude matching pattern]:regex' \
  '*'{-I,--include}'+[add directory to @INC]:dir:_files -/' \
  '--search=[search path for tests]:path:_files' \
  '*'{-m,--load}'+[load module]:module' \
  '*'{-M,--load-import}'+[load and import module]:module' \
  '*'{-P,--preload}'+[preload module]:module' \
  '(-l --lib)'{-l,--lib}'[add lib to @INC]' \
  '(-b --blib)'{-b,--blib}'[add blib to @INC]' \
  '--tlib[add t/lib to @INC]' \
  '(-L --log)'{-L,--log}'[write event log]' \
  '-B[compress log with bzip2]' \
  '-G[compress log with gzip]' \
  '1:command:(test run start stop watch replay init which help)' \
  '*::arg:_files' && ret=0

return ret
