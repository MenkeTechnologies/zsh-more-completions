#compdef chplcheck

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-c+,--config=}'[config file path]:file:_files' \
  '*--file=[add file to lint]:file:_files -g "*.chpl"' \
  '*--disable-rule=[disable a lint rule by name]:rule:' \
  '*--enable-rule=[enable a lint rule by name]:rule:' \
  '--skip-unstable[skip unstable code when linting]' \
  '--skip-bundled-modules[skip bundled modules]' \
  '--no-skip-bundled-modules[do not skip bundled modules]' \
  '*--skip=[skip a file when linting]:file:_files' \
  '*--internal-prefix=[internal prefix to skip]:prefix:' \
  '--check-internal-prefix[check internal prefix]' \
  '*--add-rules=[add rules]:rules:' \
  '*--setting=[rule setting]:setting:' \
  '--lsp[run as language server]' \
  '--list-rules[list available rules]' \
  '--list-active-rules[list active rules]' \
  '--fixit[apply automatic fixes]' \
  '--fixit-suffix=[suffix for fixit output files]:suffix:' \
  '--interactive[interactive mode]' \
  '*:file:_files -g "*.chpl"' && ret=0

return ret
