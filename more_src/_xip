#compdef xip
# Documentation: https://man.archlinux.org/search?q=xip
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '--sign[Sign archive with identity]:signing identity'
    '--keychain[Keychain to search for identity]:keychain:_files'
    '--timestamp[Include a trusted timestamp]'
    '--no-timestamp[Do not include a timestamp]'
    '--expand[Expand a signed archive]'
    '*:file:_files -g "*.xip"'
)

_arguments -s -S $arguments
