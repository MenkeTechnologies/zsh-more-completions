#compdef GatherBQSRReports
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/bqsr/GatherBQSRReports.java
# Gathers scattered BQSR recalibration reports into a single file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-I,--input}'=[scattered BQSR report file]:report:_files' \
  '(-O --output)'{-O,--output}'=[file to output the gathered report to]:output:_files' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:report:_files' && ret=0

return ret
