#compdef rdf gmx-rdf
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-rdf.html
# gmx rdf: calculate radial distribution functions

local ret=1

_arguments -s \
  '-f[input trajectory or single configuration]:file:_files' \
  '-s[input structure]:file:_files' \
  '-n[extra index groups]:file:_files' \
  '-o[computed RDFs]:file:_files' \
  '-cn[cumulative RDFs]:file:_files' \
  '-b[first frame (ps) to read]:time:' \
  '-e[last frame (ps) to read]:time:' \
  '-dt[only use frame if t MOD dt == first time (ps)]:time:' \
  '-tu[unit for time values]:unit:(fs ps ns us ms s)' \
  '-fgroup[atoms stored in the trajectory file]:selection:' \
  '-rmpbc[make molecules whole for each frame]' \
  '-pbc[use periodic boundary conditions for distances]' \
  '-xvg[plot formatting options]:format:(xmgrace xmgr none)' \
  '-sf[provide selections from files]:file:_files' \
  '-selrpos[selection reference positions]:enum:' \
  '-seltype[default selection output positions]:enum:' \
  '-ref[reference selection for RDF computation]:selection:' \
  '-sel[selections to compute RDFs for]:selection:' \
  '-bin[bin width (nm)]:real:' \
  '-rmax[largest distance (nm) to calculate]:real:' \
  '-norm[normalization method]:enum:' \
  '-xy[use only x and y components of distance]' \
  '-excl[use exclusions from topology]' \
  '-cut[shortest distance (nm) to be considered]:real:' \
  '-surf[RDF with respect to surface of reference]:enum:' && ret=0

return ret
