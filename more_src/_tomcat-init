#compdef tomcat-init

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start tomcat'
  'stop:stop tomcat'
  'restart:restart tomcat'
  'reload:reload configuration'
  'status:show status'
  'condrestart:restart only if running'
  'try-restart:restart only if running'
  'force-reload:force reload'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tomcat-init command' commands && ret=0 ;;
esac

return ret
