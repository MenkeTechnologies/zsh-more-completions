#compdef xplr

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files -g "*.lua"' \
  '--vroot[set virtual root]:directory:_directories' \
  '--read-only[open in read-only mode]' \
  '--on-load[send messages when xplr loads]:messages' \
  '--force-focus[force focus on start]' \
  '--print-pwd-as-result[print pwd as result]' \
  '*'{-C,--extra-config}'[extra config file to load]:config file:_files -g "*.lua"' \
  '*:path:_files' \
  && ret=0

return ret
