#compdef xplr
# Documentation: https://github.com/sayanarijit/xplr/blob/main/src/cli.rs
# Reference accessed: 2026-05-21
# Verified: upstream source at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  '(-c --config)'{-c,--config}'+[config file]:config file:_files -g "*.lua"' \
  '--vroot+[set virtual root]:directory:_directories' \
  '--read-only[open in read-only mode]' \
  '--read0[read null-delimited input]' \
  '--write0[write null-delimited output]' \
  '(-0 --null)'{-0,--null}'[null-delimited input and output]' \
  '--on-load+[messages to send on load]:messages:' \
  '--force-focus[force focus on start]' \
  '--print-pwd-as-result[print pwd as result]' \
  '*'{-C,--extra-config}'+[extra config file to load]:config file:_files -g "*.lua"' \
  '(-m --pipe-msg-in)'{-m,--pipe-msg-in}'+[pipe message input]:format:' \
  '(-M --print-msg-in)'{-M,--print-msg-in}'+[print message input]:format:' \
  '*:path:_files' \
  && ret=0

return ret
