#compdef 1dRplot
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dRplot.html
# Plot a 1D file

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help message]' \
  '-addavg[add line at average of column]' \
  '-col.color[colors for each column in input]:colors' \
  '-col.grp[integer labels defining column grouping]:grp' \
  '-col.line.type[line type for each column]:type' \
  '-col.name[name of each column in input]:name' \
  '-col.name.show[show names of columns in input]' \
  '-col.nozeros[do not plot all zeros columns]' \
  '-col.plot.char[symbols for each column in input]:char' \
  '-col.plot.type[column plot type (l, p, or b)]:type:(l p b)' \
  '-col.text.lym[text placed at left Y margin]:text' \
  '-col.text.rym[text placed at right Y margin]:text' \
  '-col.ystack[scale and offset each column based on index]' \
  '-grid.show[show grid]' \
  '-grp.label[labels assigned to each group]:label' \
  '(-i -input)'{-i,-input}'[file to plot]:file:_files' \
  '-input_delta[file containing value for error bars]:file:_files' \
  '-input_type[type of data in 1D file]:type' \
  '-leg.fontsize[font size for legend text]:size' \
  '-leg.line.color[color for legend items]:color' \
  '-leg.line.type[line type for legend items]:type' \
  '-leg.names[names for legend items]:names' \
  '-leg.ncol[number of columns in legend]:ncol' \
  '-leg.plot.char[plot characters for legend items]:char' \
  '-leg.position[legend position]:pos' \
  '-leg.show[show legend]' \
  '-load.Rdat[load data list from file for reproducing plot]:file:_files' \
  '(-mat -matplot)'{-mat,-matplot}'[display as matrix]' \
  '-msg.trace[output trace information with errors]' \
  '(-multi -multiplot)'{-multi,-multiplot}'[put columns in separate graphs]' \
  '-nozeros[do not plot all zeros time series]' \
  '(-one -oneplot)'{-one,-oneplot}'[put all columns on one graph]' \
  '-prefix[output prefix]:prefix' \
  '-row.name[name of each row in input]:name' \
  '-rowcol.name[names of rows and columns]:name' \
  '-run_examples[run all examples]' \
  '-save[save plot and quit]' \
  '-save.Rdat[save data list for reproducing plot in R]:file:_files' \
  '-save.size[save figure size in pixels]:size' \
  '-show_allowed_options[list of allowed options]' \
  '-title[graph title]:title' \
  '-TR[sampling period in seconds]:tr' \
  '-verb[verbosity level]:level' \
  '-x[X axis input]:x' \
  '-xax.label[label of X axis]:label' \
  '-xax.lim[range of X axis]:lim' \
  '-xax.tic.text[X tics text]:text' \
  '-yax.label[label of Y axis]:label' \
  '-yax.lim[range of Y axis]:lim' \
  '-yax.tic.text[Y tics text]:text' \
  '-zeros[do plot all zeros time series]' \
  '*:file:_files' && ret=0

return ret
