#compdef clevis-luks-unbind
# Documentation: https://github.com/latchset/clevis/blob/master/src/luks/clevis-luks-unbind.in
# Reference accessed: 2026-05-16
# Verified: upstream src/luks/clevis-luks-unbind.in getopts ":d:s:f".

# clevis-luks-unbind: unbind a clevis-bound LUKS slot
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[LUKS device]:device:_files -g "/dev/*"' \
  '-s[slot number]:slot:' \
  '-f[force (quiet)]' && ret=0
return ret
