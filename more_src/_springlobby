#compdef springlobby
# Documentation: https://manpages.debian.org/bookworm/springlobby/springlobby.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm springlobby(6) manpage.
# Removed from prior file: bogus man.archlinux.org search URL.

# springlobby: wxWidgets lobby client for Spring RTS engine
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-nc --no-crash-handler)'{-nc,--no-crash-handler}'[disable crash handler (debugging)]' \
  '(-cl --console-logging)'{-cl,--console-logging}'[show log on console]' \
  '(-gl --gui-logging)'{-gl,--gui-logging}'[enable log window]' \
  '(-l --log-verbosity)'{-l+,--log-verbosity=}'[log verbosity 0-5]:level:(0 1 2 3 4 5)' && ret=0
return ret
