#compdef intersectBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/intersect.html
# intersect overlaps between two sets of genomic features (bedtools intersect)

local ret=1

_arguments -s -S \
  '-a[query file (BAM/BED/GFF/VCF)]:file:_files' \
  '*-b[database file(s)]:file:_files' \
  '-abam[file A is BAM format (deprecated)]:file:_files' \
  '-ubam[write uncompressed BAM output]' \
  '-bed[convert BAM input output to BED format]' \
  '-wa[report the complete original A feature]' \
  '-wb[report the complete original B feature]' \
  '-loj[left outer join; report all A features with B or NULL]' \
  '-wo[report A and B plus overlap base pair count]' \
  '-wao[like -wo but include A features with zero overlap]' \
  '-u[report each A feature only once if any B overlap]' \
  '-c[count overlapping B features per A feature]' \
  '-C[separate count for each database file]' \
  '-v[report only A features with no overlap in B]' \
  '-f[minimum overlap as fraction of A]:fraction' \
  '-F[minimum overlap as fraction of B]:fraction' \
  '-r[require reciprocal overlap fraction]' \
  '-e[satisfy minimum fraction for A OR B]' \
  '-s[enforce same strand]' \
  '-S[enforce opposite strand]' \
  '-split[treat spliced BAM or BED12 entries as distinct intervals]' \
  '-sorted[memory-efficient algorithm for sorted inputs]' \
  '-g[genome file defining chromosome order]:file:_files' \
  '-header[print A file header before results]' \
  '*-names[aliases for database files in output]:name' \
  '-filenames[show complete filenames instead of file IDs]' \
  '-sortout[sort output database hits]' \
  '-nobuf[disable output buffering]' \
  '-iobuf[set read buffer size (K/M/G suffix)]:size' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
