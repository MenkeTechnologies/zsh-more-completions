#compdef msiecfinfo msiecfexport
# _libmsiecf — libyal MS Internet Explorer Cache File (index.dat) parser; walks URL / REDR / LEAK records and extracts cached objects
# upstream: https://github.com/libyal/libmsiecf

_libmsiecf() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-c+[codepage]:codepage:(ascii windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)' \
        '-m+[mode]:mode:(all recovered)' \
        '-t+[target dir]:dir:_files -/' \
        '-X[exclusive]' \
        '*:index.dat:_files'
}

_libmsiecf "$@"
