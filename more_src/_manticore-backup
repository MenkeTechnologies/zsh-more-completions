#compdef manticore-backup
# Documentation: https://manual.manticoresearch.com/Securing_and_compacting_a_table/Backup_and_restore
# Create and restore backups of Manticore Search tables

local ret=1

_arguments -s -S \
  '--help[show help documentation]' \
  '--version[display the current tool version]' \
  '--backup-dir=[path to the backup directory where the backup will be stored]:dir:_files -/' \
  '--restore=[restore from a backup directory; empty lists available backups]::backup:' \
  '--config=[Manticore configuration file location]:config:_files' \
  '--tables=[comma-separated list of tables to back up]:tables:' \
  '--compress[enable file compression using zstd]' \
  '--force[skip versions check on restore and gracefully restore the backup]' \
  '--unlock[unlock tables if they remain locked after failed operations]' \
  '--disable-telemetry[disable sending anonymized metrics to Manticore]' && ret=0

return ret
