#compdef getlist
# Documentation: man getlist(1)
# Source: InterNetNews/inn frontends/getlist.c — get list from NNTP server (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[send AUTHINFO credentials]' \
    '-h+[NNTP server]:host:_hosts' \
    '-p+[NNTP port]:port:_default' \
    '-R[force MODE READER]' \
    '1::list type:(active active.times counts distrib.pats distributions extensions headers moderators motd newsgroups overview.fmt subscriptions)' \
    '2::pattern:_default' \
    '3::types:_default' \
    && ret=0

return ret
