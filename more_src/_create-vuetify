#compdef create-vuetify
# Documentation: https://www.npmjs.com/package/create-vuetify
# Reference accessed: 2026-05-24
# Verified: npm view create-vuetify bin; npx create-vuetify --help output.

# Zsh completion for create-vuetify - Vuetify project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--name=[project name]:name:'   '--platform=[framework]:platform:(vue nuxt)'   '--features=[comma-separated features]:features:(pinia eslint i18n mcp)'   '--router=[router type]:router:(router file-router none)'   '--css=[CSS framework]:css:(unocss unocss-wind4 unocss-vuetify tailwindcss none)'   '--packageManager=[package manager]:manager:'   '--install[install dependencies after creation]'   '--typescript[use TypeScript instead of JavaScript]'   '--no-typescript[use JavaScript instead of TypeScript]'   '--force[force overwrite existing files]'   '--interactive[use interactive mode]'   '--debug[show debug logs]'   '--dir=[target directory]:directory:_directories'   '--preset=[preset key or path]:preset:'   '--cwd=[working directory]:directory:_directories'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' presets upgrade complete && ret=0
    ;;
  args)
    _arguments -C '*:arguments:' && ret=0
    ;;
esac

return ret
