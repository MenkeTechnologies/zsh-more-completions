#compdef sutf-benchmark
# Documentation: https://github.com/simdutf/simdutf/blob/master/benchmarks/src/cmdline.cpp
# Reference accessed: 2026-05-21
# Verified: upstream argparse in benchmarks/src/cmdline.cpp.
# Note: the upstream simdutf benchmark binary is named `benchmark` (built from
# benchmarks/benchmark.cpp); `sutf-benchmark` is the packaged/aliased name.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--show-procedures[list procedures in human-readable format]' \
  '-l[list procedures in machine-friendly format]' \
  '--json[list procedures in JSON format]' \
  '*'{-F+,--input-file=}'[dataset path (repeatable)]:file:_files' \
  '*'{-P+,--procedure=}'[procedure to test (repeatable, substring match)]:name:' \
  {-I+,--iterations=}'[number of iterations (default 30000)]:n:' \
  '--random-utf8=[use random UTF-8 of given size]:size:' && ret=0

return ret
