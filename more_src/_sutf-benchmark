#compdef sutf-benchmark

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*'{-F+,--input-file=}'[dataset path (may repeat)]:file:_files' \
  '*'{-P+,--procedure=}'[procedure to test]:name:' \
  {-I+,--iterations=}'[number of iterations]:n:' \
  '--random-utf8=[use random UTF-8 of given size]:size:' && ret=0

return ret
