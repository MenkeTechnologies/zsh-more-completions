#compdef leanify
# Documentation: https://github.com/JayXon/Leanify
# lightweight lossless file minifier/optimizer

local ret=1

_arguments -s -S \
  '(-i --iteration)'{-i,--iteration}'+[number of iterations for optimization (default 15)]:iterations:' \
  '(-d --max_depth)'{-d,--max_depth}'+[limit recursive processing depth (1 disables recursive minifying)]:depth:' \
  '(-f --fastmode)'{-f,--fastmode}'[fast mode, skip recompression step]' \
  '(-q --quiet)'{-q,--quiet}'[suppress standard output]' \
  '(-v --verbose)'{-v,--verbose}'[detailed output messages]' \
  '(-p --parallel)'{-p,--parallel}'[distribute tasks across all CPU cores]' \
  '--keep-exif[preserve Exif metadata]' \
  '*:path:_files' && ret=0

return ret
