#compdef spotipy spotipy-cli
# _spotipy — Paul Lamere spotipy lightweight Python Spotify Web API client with CLI subcommands (spotipy team, Python); argparse
# upstream: https://github.com/spotipy-dev/spotipy

_spotipy() {
    local -a sub=(
        'auth:authenticate to Spotify'
        'tracks:track subcommands'
        'albums:album subcommands'
        'artists:artist subcommands'
        'playlists:playlist subcommands'
        'me:show current user'
        'devices:list user devices'
        'currently-playing:show currently playing'
        'search:search Spotify catalog'
        'audio-features:audio features for tracks'
        'audio-analysis:audio analysis for a track'
        'recommendations:get recommendations'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--client-id=+[client id]:str:' \
        '--client-secret=+[client secret]:str:' \
        '--redirect-uri=+[redirect URI]:url:_urls' \
        '--scope=+[scope csv]:str:' \
        '--cache-path=+[cache file]:file:_files' \
        '--username=+[user]:user:_users' \
        '--no-cache[no cache]' \
        '--open-browser[open browser]' \
        '--no-open-browser[no open browser]' \
        '--retries=+[N]:n:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spotipy subcommand' sub ;;
        args)
            case $words[1] in
                tracks|albums|artists|playlists) _arguments \
                    '1:cmd:(get list audio-features audio-analysis recommendations top)' \
                    '*:id or name:' ;;
                search) _arguments \
                    '--type=+[type]:t:(track album artist playlist show episode)' \
                    '--limit=+[N]:n:' \
                    '--market=+[market]:str:' \
                    '*:query:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_spotipy "$@"
