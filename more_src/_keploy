#compdef keploy

_keploy_commands() {
  local -a commands=(
    'record:Record API calls and generate test cases'
    'test:Run recorded test cases'
    'serve:Start the Keploy server'
    'generate:Generate test cases from OpenAPI spec'
    'config:Manage configuration'
    'normalize:Normalize test data'
    'rerecord:Re-record test cases'
    'update:Update Keploy'
    'version:Print version'
    'help:Show help'
    'completion:Generate shell completion'
  )
  _describe -t commands 'keploy command' commands
}

_keploy() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --version)'{-v,--version}'[Print version]' \
    '--debug[Enable debug mode]' \
    '1:command:_keploy_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        record)
          _arguments \
            '(-c --command)'{-c,--command}'[Command to run]:command:' \
            '--path[Path to store test cases]:path:_directories' \
            '--delay[Delay before recording in seconds]:seconds:' \
            '--passThroughPorts[Ports to pass through]:ports:' \
            '--containerName[Container name]:container:' \
            '--networkName[Network name]:network:' \
            '--buildDelay[Build delay]:seconds:' \
            '--config-path[Config file path]:file:_files' \
            '--proxyPort[Proxy port]:port:' \
            '--dnsPort[DNS port]:port:'
          ;;
        test)
          _arguments \
            '(-c --command)'{-c,--command}'[Command to run]:command:' \
            '--path[Path to test cases]:path:_directories' \
            '--delay[Delay before testing in seconds]:seconds:' \
            '--apiTimeout[API timeout in seconds]:seconds:' \
            '--passThroughPorts[Ports to pass through]:ports:' \
            '--containerName[Container name]:container:' \
            '--networkName[Network name]:network:' \
            '--testsets[Test sets to run]:testsets:' \
            '--config-path[Config file path]:file:_files' \
            '--proxyPort[Proxy port]:port:' \
            '--dnsPort[DNS port]:port:' \
            '--coverage[Enable coverage]' \
            '--goCoverage[Go coverage output]:file:_files' \
            '--generateGithubActions[Generate GitHub Actions YAML]'
          ;;
        generate)
          _arguments \
            '--sourceFilePath[OpenAPI spec file]:file:_files' \
            '--testCasePath[Output path]:path:_directories'
          ;;
        config)
          local -a subcommands=(
            'generate:Generate config file'
          )
          _describe -t subcommands 'config subcommand' subcommands
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_keploy "$@"
