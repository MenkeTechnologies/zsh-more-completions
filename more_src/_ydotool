#compdef ydotool
# Documentation: https://github.com/ReimuNotMoe/ydotool
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'type:type text'
  'key:press keys (CODE:STATE format)'
  'mousemove:move mouse'
  'click:click mouse button'
  'debug:diagnostic output'
  'stdin:keyboard emulation from stdin'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'ydotool command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      type)
        _arguments \
          '*:text' && ret=0
        ;;
      key)
        _arguments \
          '*:keycode (CODE:STATE)' && ret=0
        ;;
      mousemove)
        _arguments \
          '--absolute[use absolute positioning]' \
          '-x+[x coordinate]:x' \
          '-y+[y coordinate]:y' && ret=0
        ;;
      click)
        _arguments \
          '--repeat=[repeat N times]:count' \
          '--next-delay=[delay between repeats in ms]:ms' \
          '1:button code' && ret=0
        ;;
    esac
    ;;
esac

return ret
