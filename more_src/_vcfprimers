#compdef vcfprimers
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfprimers.md
# vcflib: extract flanking sequences around variants as FASTA for primer design

local ret=1

_arguments -s -S \
  '(-f --fasta-reference)'{-f,--fasta-reference}'[FASTA reference file to obtain primer sequences]:reference:_files' \
  '(-l --primer-length)'{-l,--primer-length}'[length of primer sequences on each side of the variant]:length' \
  '*:vcf file:_files' && ret=0

return ret
