#compdef 3dttest++
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dttest++.html
# AFNI two-sample / paired / one-sample t-tests at each voxel

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '*-setA[first dataset collection]:spec' \
  '*-setB[second dataset collection]:spec' \
  '-labelA[label for set A]:label' \
  '-labelB[label for set B]:label' \
  '-setweightA[weights for set A datasets]:spec' \
  '-setweightB[weights for set B datasets]:spec' \
  '-singletonA[test single dataset against a group]:spec' \
  '-paired[perform paired-sample t-test]' \
  '-unpooled[variances separately for each set]' \
  '-covariates[include covariate data from file]:file:_files' \
  '-center[control covariate mean removal]:mode:(NONE DIFF SAME)' \
  '-cmeth[centering method]:method:(MEAN MEDIAN)' \
  '-toz[convert t-statistics to z-scores]' \
  '-zskip[exclude zero voxel values]' \
  '-rankize[apply rank transformation]' \
  '-no1sam[omit one-sample test results]' \
  '-nomeans[exclude mean sub-bricks]' \
  '-notests[exclude test statistic sub-bricks]' \
  '-BminusA[reverse subtraction order to B minus A]' \
  '-AminusB[A minus B (standard)]' \
  '-prefix[output dataset filename]:prefix' \
  '-mask[restrict to voxels within a mask]:dataset:_files' \
  '-resid[output residual values to dataset]:prefix' \
  '-ACF[compute autocorrelation function parameters]' \
  '-exblur[additional Gaussian smoothing]:fwhm' \
  '-brickwise[process datasets sub-brick by sub-brick]' \
  '-nocov[suppress covariate results]' \
  '-dupe_ok[allow duplicate dataset labels]' \
  '-Clustsim[cluster-level threshold tables via randomization]' \
  '-ETAC[Equitable Thresholding And Clustering]' \
  '-ETAC_blur[multiple blur levels with ETAC]:blurs' \
  '-ETAC_opt[configure ETAC parameters]:opts' \
  '-ETAC_mem[display memory requirement estimate]' \
  '-prefix_clustsim[prefix for simulation files]:prefix' \
  '-no5percent[suppress FPR threshold file]' \
  '-tempdir[temporary file storage location]:dir:_files -/' \
  '-seed[random number seed]:seed' \
  '-randomsign[randomize dataset signs for null sims]' \
  '-permute[enable inter-set permutation testing]' \
  '-nopermute[disable automatic permutation]' \
  '-debug[display detailed analysis information]' \
  '*:dataset:_files' && ret=0

return ret
