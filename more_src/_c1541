#compdef c1541
# Documentation: https://github.com/VICE-Team/svn-mirror/blob/main/vice/src/c1541.c
# Reference accessed: 2026-05-16
# Verified: vice/src/c1541.c command_list[] (line 277) - 47 commands enumerated.
# Removed from prior file: cp (not real), ls (not real), lock (not real),
# show (not real), unlock (not real). Added missing: bfill, bpeek, bpoke,
# disable-libdebug-output, entry, exit, geosdelete, geosdir, geosextract,
# geoslist, p00save, unlynx, unzip, version, x.

# c1541: VICE Commodore disk image manipulation utility
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  '?:explain command or list available'
  '@:execute CBM DOS command'
  'attach:attach disk image to unit'
  'bam:show BAM of disk image'
  'bcopy:copy block to another block'
  'bfill:fill a block with a single value'
  'block:show specified disk block in hex'
  'bpeek:show block data from offset to end'
  'bpoke:poke data into block'
  'bread:read block data to host file'
  'bwrite:write block data from host file'
  'cd:change current host directory'
  'chain:follow and print block chain'
  'copy:copy files in image'
  'delete:delete files in image'
  'dir:list files matching pattern'
  'disable-libdebug-output:disable lib.c debug output'
  'entry:show detailed directory entry'
  'exit:exit (same as quit)'
  'extract:extract files to host filesystem'
  'format:format disk image'
  'geosdelete:delete a GEOS file'
  'geosdir:list GEOS directory'
  'geosextract:extract GEOS files to host'
  'geoslist:list GEOS files'
  'geosread:read a GEOS file'
  'geoswrite:write a GEOS file'
  'help:list available commands or explain one'
  'info:show image info'
  'list:list directory entries'
  'name:set image name'
  'p00save:save in P00 format'
  'pwd:print working host directory'
  'quit:exit c1541'
  'read:read file from image'
  'rename:rename file in image'
  'silent:set silent mode'
  'tape:attach tape image'
  'unit:set current unit'
  'unlynx:expand lynx-archived image'
  'unzip:expand zipped image'
  'validate:validate disk image'
  'verbose:set verbose mode'
  'version:show version'
  'write:write file to image'
  'x:exit (alias)'
  'zcreate:create zoom-coded image'
)
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'c1541 command' commands && ret=0 ;;
esac
return ret
