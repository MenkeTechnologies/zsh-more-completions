#compdef c1541
# Documentation: https://vice-emu.sourceforge.io/vice_15.html
# Reference accessed: 2026-05-16

# c1541: VICE Commodore disk image manipulation utility
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  '?:help'
  'attach:attach a disk image'
  'block:show disk block'
  'bcopy:copy block'
  'bam:show BAM'
  'bread:read block'
  'bwrite:write block'
  'cd:change cwd'
  'chain:list chain'
  'copy:copy file in image'
  'cp:copy file in image'
  'delete:delete file in image'
  'dir:list image directory'
  'ls:list image directory'
  'extract:extract files to host'
  'format:format image'
  'geosread:read GEOS file'
  'geoswrite:write GEOS file'
  'help:help'
  'info:show image info'
  'list:list directory'
  'lock:set file locked'
  'name:set image name'
  'pwd:print working dir'
  'quit:exit'
  'read:read file from image'
  'rename:rename file in image'
  'show:show partition contents'
  'silent:silent mode'
  'tape:attach tape'
  'unit:set current unit'
  'unlock:clear locked'
  'validate:validate image'
  'verbose:verbose mode'
  'write:write file to image'
  'zcreate:create zoom-coded image'
)
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-?[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'c1541 command' commands && ret=0 ;;
esac
return ret
