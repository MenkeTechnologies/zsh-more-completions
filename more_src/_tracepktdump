#compdef tracepktdump
# Documentation: https://manpages.debian.org/testing/libtrace-tools/tracepktdump.1.en.html
# output libtrace packets in human readable format

local ret=1

_arguments -s -S \
  '(-f --filter)'{-f+,--filter=}'[output only packets that match the bpf-filter expression]:bpf filter' \
  '(-c --count)'{-c+,--count=}'[stop after displaying num packets]:num' \
  '*:uri:_files' && ret=0

return ret
