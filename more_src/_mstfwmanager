#compdef mstfwmanager mlxfwmanager
# Documentation: https://www.mankier.com/1/mstfwmanager
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mstfwmanager (a.k.a. mlxfwmanager): firmware update/query tool for Mellanox cards.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --dev)'{-d,--dev}'[device]:dev:' \
  '(-i --image-file)'{-i,--image-file}'[firmware image file]:file:_files' \
  '(-D --image-dir)'{-D,--image-dir}'[firmware image directory]:dir:_directories' \
  '(-y --yes)'{-y,--yes}'[answer yes to prompts]' \
  '(-u --update)'{-u,--update}'[update firmware]' \
  '(-f --force)'{-f,--force}'[force update]' \
  '--query[query firmware only]' \
  '--online[update from online source]' \
  '--no-progress[suppress progress bar]' \
  '*::mstfwmanager args:_files' && ret=0
return ret
