#compdef cmix
# Documentation: https://github.com/byronknoll/cmix
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

# cmix usage (from README and source):
#   cmix -c [dictionary] input output      # compress
#   cmix -d [dictionary] input output      # decompress
#   cmix -n [dictionary] input output      # store mode (no compression)
#   cmix -s [dictionary] input output      # preprocess only
#   cmix -t [dictionary] input output      # test/verify
# The optional dictionary file is given as a positional argument.
_arguments -C \
  '(- *)-h[show help]' \
  '-c[compress]' \
  '-d[decompress]' \
  '-n[store mode (no compression)]' \
  '-s[preprocessing only]' \
  '-t[test/verify]' \
  '*:file:_files' && ret=0

return ret
