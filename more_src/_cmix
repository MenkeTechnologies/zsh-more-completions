#compdef cmix
# Documentation: https://man.archlinux.org/search?q=cmix
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c[compress]' \
  '-d[decompress]' \
  '-n[default mode]' \
  '-s+[dictionary file]:file:_files' \
  '-t+[test file]:file:_files' \
  '-b+[blocksize]:n:' \
  '*:file:_files' && ret=0

return ret
