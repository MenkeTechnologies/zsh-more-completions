#compdef scheduler-plugins-controller
# _scheduler-plugins-controller — sigs.k8s.io/scheduler-plugins controller manager
# upstream: https://github.com/kubernetes-sigs/scheduler-plugins
# Flags from cmd/controller/app/options.go on tip.

_scheduler-plugins-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metricsAddr=[metrics server bind host\:port]:host\:port:' \
        '--probeAddr=[probe endpoint bind host\:port]:host\:port:' \
        '--qps=[QPS for apiserver queries]:n:' \
        '--burst=[burst for apiserver queries]:n:' \
        '--workers=[scheduler-plugin-controllers worker count]:n:' \
        '--enableLeaderElection=[enable leader election]:bool:(true false)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_scheduler-plugins-controller "$@"
