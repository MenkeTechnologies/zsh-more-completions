#compdef git-up
# _git-up — aanand/git-up (pull --rebase across every local branch tracking a remote, then stash-pop; --no-fetch skips the fetch step, --no-stash skips the auto-stash, --tags also fetches tags)
# upstream: https://github.com/aanand/git-up
# Flags from git-up git_up/cli.py on tip.

_git-up() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--no-fetch[skip git fetch]' \
        '--no-stash[skip stash before rebase]' \
        '--tags[also fetch tags]' \
        '--quiet[quiet]'
}

_git-up "$@"
