#compdef rtx
# Documentation: https://mise.jdx.dev/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: rtx was renamed to mise (github.com/jdx/mise). Defer to the _mise
# completion if present; otherwise complete files for backward compatibility.

local curcontext="$curcontext" state line ret=1

if (( $+functions[_mise] )); then
  _mise "$@"
  return
fi

_arguments -s -S '*:arg:_files' && ret=0
return ret
