#compdef CollectAlignmentSummaryMetrics
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/analysis/CollectAlignmentSummaryMetrics.java
# Picard: collect high-level alignment quality metrics from a SAM/BAM/CRAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM/CRAM file]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output metrics file]:file:_files' \
  '(-H --HISTOGRAM_FILE)'{-H,--HISTOGRAM_FILE}'=[read-length chart pdf output]:file:_files' \
  '--MAX_INSERT_SIZE=[chimeric pair insert-size threshold]:n:' \
  '*--EXPECTED_PAIR_ORIENTATIONS=[expected paired-end orientation]:o:(FR RF TANDEM)' \
  '*--ADAPTER_SEQUENCE=[adapter sequence]:seq:' \
  '(-LEVEL --METRIC_ACCUMULATION_LEVEL)'{-LEVEL,--METRIC_ACCUMULATION_LEVEL}'=[metric accumulation level]:lvl:(ALL_READS SAMPLE LIBRARY READ_GROUP)' \
  '(-BS --IS_BISULFITE_SEQUENCED)'{-BS,--IS_BISULFITE_SEQUENCED}'=[reads are bisulfite sequenced]:b:(true false)' \
  '--COLLECT_ALIGNMENT_INFORMATION=[collect alignment data beyond counts]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
