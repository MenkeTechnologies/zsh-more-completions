#compdef groebner
# Documentation: https://4ti2.github.io/groebner.html
# 4ti2: compute a Groebner basis of a toric ideal or lattice

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display this help and exit]' \
  '(-p --precision)'{-p,--precision=}'[integer arithmetic precision]:precision:(64 32 arbitrary)' \
  '(-a --algorithm)'{-a,--algorithm=}'[Groebner basis completion procedure]:alg:(fifo weighted unbounded)' \
  '(-g --generation)'{-g,--generation=}'[generating set procedure]:alg:(hybrid project-and-lift max-min saturation)' \
  '(-t --truncation)'{-t,--truncation=}'[truncation method]:trunc:(ip lp weight none)' \
  '(-m --minimal)'{-m,--minimal=}'[compute a minimal Markov basis]:state:(yes no)' \
  '(-r --auto-reduce-freq)'{-r,--auto-reduce-freq=}'[frequency of auto reduction]:n:' \
  '(-f --output-freq)'{-f,--output-freq=}'[frequency of output]:n:' \
  '(-q --quiet)'{-q,--quiet}'[do not output anything to the screen]' \
  '*:project:_files' && ret=0

return ret
