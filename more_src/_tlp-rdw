#compdef tlp-rdw
# Documentation: https://linrunner.de/tlp/usage/tlp-rdw.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--version[show version]' \
  '1:command:->commands' && ret=0

case $state in
  commands)
    _values 'tlp-rdw command' \
      'enable[activate automatic event-based actions on radio devices]' \
      'disable[deactivate automatic event-based actions on radio devices]'
    ;;
esac

return ret
