#compdef exhaustruct
# Documentation: https://github.com/GaijinEntertainment/go-exhaustruct
# checks if all struct fields are initialized in struct literals

local ret=1

_arguments -s -S \
  '*-allow-empty-rx=[regex pattern for types allowed to be empty]:regexp:' \
  '-allow-empty[allow all empty struct literals globally]' \
  '-allow-empty-declarations[allow empty literals in var and := declarations]' \
  '-allow-empty-returns[allow empty literals in return statements]' \
  '*-enforce-rx=[regex pattern for types/fields to check]:regexp:' \
  '-explicit[enable explicit (opt-in) checking mode]' \
  '*-ignore-rx=[regex pattern for types to skip]:regexp:' \
  '*-optional-rx=[regex pattern for types/fields to mark optional]:regexp:' \
  '-report-full-type-path[show full package path in errors]' \
  '-fix[apply all suggested fixes]' \
  '-V[print version and exit]' \
  '-c=[display offending line with this many lines of context]:n:' \
  '-cpuprofile=[write CPU profile to file]:file:_files' \
  '-debug=[debug flags, any subset of fpstv]:flags:' \
  '-flags[print analyzer flags in JSON]' \
  '-json[emit JSON output]' \
  '-memprofile=[write memory profile to file]:file:_files' \
  '-trace=[write trace log to file]:file:_files' \
  '*:packages:_files' && ret=0

return ret
