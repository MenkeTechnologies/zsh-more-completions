#compdef task

# Zsh completion for taskwarrior - Task management

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--version[show version]' \
  '*::arg:->args' && ret=0

case $state in
  (args)
    local -a commands=(
      'add:add a new task'
      'annotate:add an annotation to a task'
      'append:append text to a task description'
      'calc:calculator'
      'colors:display all supported colors'
      'columns:list supported columns'
      'commands:list all commands'
      'completed:list completed tasks'
      'config:modify configuration'
      'context:manage contexts'
      'count:count matching tasks'
      'delete:delete a task'
      'denotate:remove an annotation from a task'
      'diagnostics:show diagnostic information'
      'done:mark a task as done'
      'duplicate:duplicate a task'
      'edit:edit a task with an editor'
      'export:export tasks in JSON'
      'help:show help'
      'history:display task history'
      'ids:show matching task IDs'
      'import:import tasks from JSON'
      'info:show task details'
      'list:list tasks'
      'log:add an already-completed task'
      'logo:display the Taskwarrior logo'
      'modify:modify a task'
      'next:list most urgent tasks'
      'prepend:prepend text to a task description'
      'projects:list projects'
      'purge:permanently remove deleted tasks'
      'ready:list ready tasks'
      'reports:list available reports'
      'show:show configuration variables'
      'start:mark a task as started'
      'stats:show statistics'
      'stop:remove start from a task'
      'summary:show project summary'
      'sync:synchronize tasks'
      'tags:list tags'
      'undo:undo the last change'
      'version:show version'
      'waiting:list waiting tasks'
    )

    # Check if first word is a number (task ID) or filter
    if [[ $words[1] =~ '^[0-9]' ]]; then
      # After task ID, show task-specific commands
      local -a task_commands=(
        'annotate:add annotation'
        'append:append text'
        'delete:delete task'
        'denotate:remove annotation'
        'done:mark as done'
        'duplicate:duplicate task'
        'edit:edit task'
        'info:show details'
        'modify:modify task'
        'prepend:prepend text'
        'start:start task'
        'stop:stop task'
      )
      _describe -t commands 'task command' task_commands && ret=0
    else
      _describe -t commands 'task command' commands && ret=0
    fi
    ;;
esac

return ret
