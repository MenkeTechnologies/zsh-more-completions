#compdef argocd-app
# Documentation: https://argo-cd.readthedocs.io/en/stable/user-guide/commands/argocd_app/
# Argo CD app: manage applications

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--auth-token=[authentication token]:token:' \
  '--server=[Argo CD server address]:server:' \
  '--insecure[skip server certificate and domain verification]' \
  '--grpc-web[enable gRPC-web protocol]' \
  '--config=[path to Argo CD config]:file:_files' \
  '--plaintext[disable TLS]' \
  '--port-forward[connect to a random argocd-server port using port forwarding]' \
  '--port-forward-namespace=[namespace name used for port forwarding]:namespace:' \
  '--core[CLI talks directly to Kubernetes instead of the Argo CD API server]' \
  '--client-crt=[client certificate file]:file:_files' \
  '--client-crt-key=[client certificate key file]:file:_files' \
  '*::subcommand:(actions add-source confirm-deletion create delete delete-resource diff edit get get-resource history list logs manifests patch patch-resource remove-source resources rollback set sync terminate-op unset wait)' && ret=0

return ret
