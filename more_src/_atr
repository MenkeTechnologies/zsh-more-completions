#compdef atr
# ============================================================================
# _atr — zsh completion for atscan/atr, the AT Protocol IPLD-CAR
#        Repository toolkit (Go, indigo-backed)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/atscan/atr
#   Maintainer : atscan  (Bluesky / atproto-ecosystem researcher)
#   License    : MIT
#   Language   : Go
#   Module     : github.com/atscan/atr
#   Binary     : atr  (built from root atr.go calling cmd.Execute)
#   Last push  : 2025-10-25
#
# WHAT IT IS
#   atr is "an AT Protocol IPLD-CAR Repository toolkit (CLI)" — a
#   focused inspection / extraction tool for Bluesky / atproto user
#   repositories serialized as IPLD CAR (Content-Addressable Archive)
#   files.  The AT Protocol stores each user's full data repository
#   (posts, likes, follows, profile, lists, …) as a Merkle Search
#   Tree (MST) of IPLD blocks, exportable as a `.car` file by the
#   user's PDS.  atr walks one or more `.car` files (or stdin), and
#   prints summary statistics (size, block / commit / object counts,
#   per-collection counts, profile fields, recent commit chain) for
#   `atr inspect`, a streamable per-record dump with optional `jq` /
#   JMESPath query and color-pretty syntax-highlighted output for
#   `atr show`, or a commit-history walk for `atr log`.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/{root,atr-inspect,atr-show,
#                       atr-log}.go spf13/cobra Command tree)
#   atr [GLOBAL_FLAGS] <SUBCOMMAND> [args...]
#
#   Global persistent flag (inherited by every subcommand):
#     -C, --working-dir <DIR>    Working directory for resolving
#                                relative CAR file paths
#                                [default: `.`]
#
#   Subcommands:
#     version                    Print version
#     inspect | i [CAR_FILES...] Inspect repo(s) — summary
#                                statistics, profile, collections,
#                                last commits (reads stdin if pipe)
#     show    | s [CAR_FILES...] Show repo(s) documents
#       -r, --root <CID>             Use specific root
#       -b, --back <N>               Go back N commits
#       -t, --type <REGEX>           Filter by item type
#       -q, --query <JQ>             Query results (jq via gojq)
#       -x, --query-jmes <JMES>      Query results (JMESPath)
#           --raw                    Do not use colors (faster)
#     log     | l [CAR_FILES...] Show commit history (path)
#           --raw                    Do not use colors (faster)
#
#   Standard cobra auto-flags:
#     -h, --help                 Show help
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/bluesky-social/indigo
#   v0.0.0-20230718161430-1e5d9abdee8f` declared in go.mod — the
#   canonical Go AT Protocol bindings maintained by Bluesky PBC
#   (bluesky-social/indigo).  indigo is the authoritative Go
#   implementation of the AT Protocol: typed lexicon-generated
#   bindings for every public AT Protocol Lexicon
#   (com.atproto.* / app.bsky.* namespaces), MST + IPLD CAR
#   serialization helpers, repo-format readers/writers, identity
#   resolution (DID PLC + DID Web), Bluesky firehose consumers,
#   and the canonical relay / PDS / appview server implementations
#   (see indigo/cmd/{rainbow,relay,palomar,hepa,sonar,…}).  atr's
#   `repo/` package uses indigo's `repo` and `mst` modules to
#   deserialize CAR files into a typed `RepoSnapshot` and walk
#   the MST tree.  Verified via:
#     gh api repos/atscan/atr/contents/go.mod
#       → github.com/bluesky-social/indigo v0.0.0-2023…
#       → github.com/spf13/cobra v1.7.0
#   This entry is the Go=128 leader bump that continues Axis 73
#   (AT Protocol / Bluesky SDK) opened at R881 with Rust=
#   atrium-rs/bsky-sdk + atrium-api (atrium-rs/atrium bsky-cli).
#
#   No completion for `atr` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
#   The adjacent `_atril` / `_atrm` / `_atrun` in this corpus target
#   unrelated tools (MATE document viewer / at-job removal /
#   at-job runner);  `atr` is a distinct binary.
# ============================================================================

_atr() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-C --working-dir)'{-C+,--working-dir=}'[working directory (default .)]:dir:_files -/' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_atr_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                inspect|i)
                    _arguments \
                        '*:CAR file:_files -g "*.car"' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                show|s)
                    _arguments \
                        '(-r --root)'{-r+,--root=}'[use specific root CID]:CID:' \
                        '(-b --back)'{-b+,--back=}'[go back N commits]:N:' \
                        '(-t --type)'{-t+,--type=}'[filter by item type (regex)]:type:' \
                        '(-q --query)'{-q+,--query=}'[query results (jq via gojq)]:jq query:' \
                        '(-x --query-jmes)'{-x+,--query-jmes=}'[query results (JMESPath)]:jmespath query:' \
                        '--raw[do not use colors (faster)]' \
                        '*:CAR file:_files -g "*.car"' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                log|l)
                    _arguments \
                        '--raw[do not use colors (faster)]' \
                        '*:CAR file:_files -g "*.car"' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                version)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_atr_commands] )) ||
_atr_commands() {
    local -a commands
    commands=(
        'inspect:inspect repo(s) - summary statistics and profile'
        'i:inspect repo(s) (alias for inspect)'
        'show:show repo(s) documents with optional jq/JMESPath query'
        's:show repo(s) documents (alias for show)'
        'log:show commit history (path)'
        'l:show commit history (alias for log)'
        'version:print version'
    )
    _describe -t commands 'atr command' commands
}

_atr "$@"
