#compdef airmon-ng
# _airmon-ng — Aircrack-ng airmon-ng (enable / disable monitor mode on a wireless adapter; subcommands: check (list interferences), start IFACE [CHAN], stop IFACE, version, help; --verbose verbose; positional argument is the action followed by the interface and optional channel)
# upstream: https://github.com/aircrack-ng/aircrack-ng
# Flags from aircrack-ng scripts/airmon-ng on tip.

_airmon-ng() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '1::action:(check start stop verify version)' \
        '2::interface:_net_interfaces' \
        '3::channel:'
}

_airmon-ng "$@"
