#compdef virt-index-validate
# Documentation: https://libguestfs.org/virt-index-validate.1.html
# validate the index file of a virt-builder repository

local ret=1

_arguments -s -S \
  '--help[display help information]' \
  '(-V --version)'{-V,--version}'[display the program version number and exit]' \
  '--compat-1.24.0[check for compatibility with virt-builder 1.24.0]' \
  '--compat-1.24.1[check for compatibility with virt-builder >= 1.24.1]' \
  '*:index file:_files' && ret=0

return ret
