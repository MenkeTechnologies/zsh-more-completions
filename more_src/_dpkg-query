#compdef dpkg-query

_arguments -s \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-l --list)'{-l,--list}'[list packages matching pattern]' \
  '(-W --show)'{-W,--show}'[show package info]' \
  '(-s --status)'{-s,--status}'[show package status details]' \
  '(-L --listfiles)'{-L,--listfiles}'[list files belonging to package]' \
  '(-S --search)'{-S,--search}'[search for files in installed packages]' \
  '(-p --print-avail)'{-p,--print-avail}'[show available package details]' \
  '(-c --control-show)'{-c,--control-show=}'[show control file]:file:' \
  '--control-list[list control files]' \
  '--control-path=[show path of control file]:file:' \
  '(-f --showformat)'{-f,--showformat=}'[output format]:format:' \
  '--no-pager[disable pager]' \
  '--load-avail[load available file]' \
  '--admindir=[admin directory]:dir:_files -/' \
  '--root=[root directory]:dir:_files -/' \
  '*:package:'
