#compdef pip-review
# Documentation: https://man.archlinux.org/search?q=pip-review
# Reference accessed: 2026-05-16

_arguments -s \
  '--auto[install all updates without prompting]' \
  '--interactive[prompt per package]' \
  '--preview[show outdated table before action]' \
  '--preview-only[show update table only]' \
  '--local[only local packages]' \
  '--user[user site only]' \
  '--continue-on-fail[continue on failure]' \
  '--raw[raw output]' \
  '--debug[debug output]' \
  '--verbose[verbose output]' \
  '--no-recursive[do not recurse]' \
  '(- *)-h[show help]'
