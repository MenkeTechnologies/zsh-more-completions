#compdef rga-preproc

# Zsh completion for rga-preproc (ripgrep-all preprocessor)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--rga-no-cache[disable cache]' \
  '--rga-accurate[use more accurate but slower adapters]' \
  '--rga-adapters=[list of adapters to use]:adapters' \
  '--rga-cache-max-blob-len=[max blob length for caching]:size' \
  '--rga-cache-path=[path to cache]:cache dir:_directories' \
  '--rga-max-archive-recursion=[max archive recursion depth]:depth' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:file:_files' && ret=0

return ret
