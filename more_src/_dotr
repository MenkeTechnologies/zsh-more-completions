#compdef dotr
# Documentation: https://dotty.epfl.ch/3.0.0/docs/usage/getting-started.html
# Scala 3 (Dotty) runner

local ret=1

_arguments -s -S \
  '(-help -h)'{-help,-h}'[show help]' \
  '-version[show runner version]' \
  '-repl[run the REPL]' \
  '-run[run a main class]' \
  '-classpath+[specify where to find user class files]:classpath:_files' \
  '-J-[pass an option directly to the JVM]:jvm option:' \
  '*::main class and args:_files' && ret=0

return ret
