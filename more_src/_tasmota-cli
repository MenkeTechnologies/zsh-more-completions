#compdef tasmota-cli
# Documentation: https://github.com/gorootde/tasmota-cli
# CLI utility to manage Tasmota devices over the network

local ret=1

_arguments -s \
  '-u[username for authentication]:username' \
  '-p[password for authentication]:password' \
  '-la[enable legacy authentication mode]' \
  '-v[verbose mode]' \
  '1:command' \
  '*:ip address:_hosts' && ret=0

return ret
