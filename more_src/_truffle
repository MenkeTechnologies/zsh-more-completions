#compdef truffle

# Zsh completion for truffle - Truffle Ethereum development framework

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:execute build pipeline'
  'compile:compile contract source files'
  'config:set user-level configuration options'
  'console:run a console with contracts instantiated'
  'create:create a new contract, migration, or test'
  'dashboard:start Truffle Dashboard'
  'db:database commands for Truffle DB'
  'debug:interactively debug a transaction'
  'deploy:alias for migrate'
  'develop:open a console with a local development blockchain'
  'exec:execute a JS module within the Truffle environment'
  'help:list all commands or provide information about a specific command'
  'init:initialize a new Truffle project'
  'install:install a package from the Ethereum Package Registry'
  'migrate:run migrations to deploy contracts'
  'networks:show deployed addresses for contracts on each network'
  'obtain:fetch and cache a specified compiler'
  'opcode:print the compiled opcodes for a contract'
  'preserve:save data to a decentralized storage system'
  'publish:publish a package to the Ethereum Package Registry'
  'run:run a third-party plugin command'
  'test:run JavaScript and Solidity tests'
  'unbox:download a Truffle Box'
  'version:show version number and exit'
  'watch:watch filesystem for changes and rebuild'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version number]' \
  '--config=[specify configuration file]:config file:_files' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'truffle command' commands && ret=0
    ;;
  args)
    case $words[1] in
      compile)
        _arguments \
          '--all[compile all contracts]' \
          '--list[list compiler versions]:type:(releases prereleases)' \
          '--contracts-directory=[contracts directory]:directory:_directories' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      console|develop)
        _arguments \
          '--network=[specify the network to use]:network:' \
          '--verbose-rpc[log communication between Truffle and the Ethereum client]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      create)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:type:(contract migration test)' \
          '2:name:' && ret=0
        ;;
      debug)
        _arguments \
          '--network=[specify the network to use]:network:' \
          '--fetch-external[allow debugging external contracts]' \
          '--compile-tests[compile test files]' \
          '--compile-all[compile all contracts]' \
          '--compile-none[skip compilation]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:transaction hash:' && ret=0
        ;;
      deploy|migrate)
        _arguments \
          '--reset[run all migrations from the beginning]' \
          '--f=[run migrations from a specific migration number]:number:' \
          '--to=[run migrations to a specific migration number]:number:' \
          '--network=[specify the network to use]:network:' \
          '--compile-all[compile all contracts]' \
          '--compile-none[skip compilation]' \
          '--verbose-rpc[log communication between Truffle and the Ethereum client]' \
          '--dry-run[fork the network and simulate migration]' \
          '--skip-dry-run[skip the dry-run before migrations]' \
          '--interactive[prompt to confirm transactions]' \
          '--describe-json[add extra descriptions for migrations in JSON format]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      exec)
        _arguments \
          '--network=[specify the network to use]:network:' \
          '--compile[compile before execution]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:script file:_files -g "*.js"' && ret=0
        ;;
      init)
        _arguments \
          '--force[initialize regardless of current state]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      obtain)
        _arguments \
          '--solc=[download specified solc version]:version:' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      test)
        _arguments \
          '--compile-all[compile all contracts]' \
          '--compile-none[skip compilation]' \
          '--network=[specify the network to use]:network:' \
          '--verbose-rpc[log communication between Truffle and the Ethereum client]' \
          '--show-events[show all contract events]' \
          '--debug[enable in-test debugging]' \
          '--debug-global=[specify global debug function name]:name:' \
          '--bail[bail after first test failure]' \
          '--stacktrace[enable in-test stack traces]' \
          '--stacktrace-extra[produce stack traces with more info]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:test files:_files -g "*.{js,ts,sol}"' && ret=0
        ;;
      unbox)
        _arguments \
          '--force[unbox regardless of current state]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:box name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
