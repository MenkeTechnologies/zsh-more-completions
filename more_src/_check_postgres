#compdef check_postgres check_postgres.pl
# _check_postgres — Nagios checks against PostgreSQL (bucardo/check_postgres)
# upstream: https://github.com/bucardo/check_postgres
# Flags from check_postgres.pl GetOptions; actions from sub check_* names.

_check_postgres() {
    local -a actions=(
        archive_ready autovac_freeze backends bloat checkpoint cluster_id
        commitratio connection custom_query database_size dbstats disabled_triggers
        disk_space fsm_pages fsm_relations hitratio hot_standby_delay last_analyze
        last_vacuum last_vacuum_analyze listener locks lockwait logfile
        new_version_bc new_version_box new_version_cp new_version_pg new_version_tnm
        partman_premake pgagent_jobs pgb_pool pgbouncer_backends pgbouncer_checksum
        pgbouncer_maxwait prepared_txns query_runtime query_time relation_size
        replicate_row replication_slots same_schema sequence settings_checksum
        slony_status timesync txn_idle txn_time txn_wraparound version wal_files
    )

    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(- *)--man[show full manual]' \
        '*'{-v,--verbose}'[verbose (repeatable)]' \
        '--vv[extra-verbose]' \
        '(-q --quiet)'{-q,--quiet}'[quiet output]' \
        '--output=[output format]:fmt:(nagios cacti mrtg simple json)' \
        '--simple[short output]' \
        '--showperf=[enable Nagios perfdata]:n:(0 1)' \
        '--perflimit=[limit perfdata items]:n:' \
        '--showtime=[show query time]:n:(0 1)' \
        '(-t --timeout)'{-t+,--timeout=}'[seconds before timeout]:secs:' \
        '--test[test connection only]' \
        '--symlinks[create symlinks for each action]' \
        '--debugoutput=[debug output mode]:mode:' \
        '--no-check_postgresrc[skip ~/.check_postgresrc]' \
        '--assume-standby-mode[assume hot standby]' \
        '--assume-prod[assume production]' \
        '--assume-async[assume async replication]' \
        "--action=[check to run]:action:($actions)" \
        '--warning=[warning threshold]:thr:' \
        '--critical=[critical threshold]:thr:' \
        '*--include=[only include matching items]:pat:' \
        '*--exclude=[exclude matching items]:pat:' \
        '--alldb[query every database]' \
        '*--includedb=[only check listed DBs]:db:' \
        '*--excludedb=[exclude listed DBs]:db:' \
        '*--includeuser=[only include users]:user:_users' \
        '*--excludeuser=[exclude users]:user:_users' \
        '*'{-H+,--host=,--dbhost=}'[Postgres host]:host:_hosts' \
        '*'{-p+,--port=,--dbport=}'[Postgres port]:port:' \
        '*'{--db=,--dbname=}'[database name]:db:' \
        '*'{-u+,--dbuser=}'[database user]:user:_users' \
        '*--dbpass=[database password]:pass:' \
        '*--dbservice=[service name]:svc:' \
        '--role=[set role]:role:' \
        '--PGBINDIR=[directory with psql binary]:dir:_files -/' \
        '--PSQL=[psql binary path]:file:_files' \
        '--tempdir=[temporary directory]:dir:_files -/' \
        '--get_method=[URL fetch method]:method:(GET wget curl fetch lynx links)' \
        '--language=[output language]:lang:' \
        '--mrtg=[MRTG-only argument]:arg:' \
        '--logfile=[log file path]:file:_files' \
        '--queryname=[query name]:name:' \
        '--query=[SQL query]:sql:' \
        '--valtype=[custom_query value type]:type:(string integer number time)' \
        '--reverse[reverse threshold semantics]' \
        '--repinfo=[replicate_row spec]:spec:' \
        '--noidle[ignore idle backends]' \
        '--datadir=[Postgres data directory]:dir:_files -/' \
        '*--schema=[schema (slony_status)]:sch:' \
        '*--filter=[same_schema filter]:filt:' \
        '--suffix=[same_schema suffix]:suf:' \
        '--replace[same_schema replace]' \
        '--skipsequencevals[skip sequence values]' \
        '--lsfunc=[ls function name]:fn:' \
        '*--object=[include object type]:type:' \
        '*--skipobject=[skip object type]:type:' \
        '--skipcycled[skip cycled sequences]'
}

_check_postgres "$@"
