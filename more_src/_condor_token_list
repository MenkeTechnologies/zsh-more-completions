#compdef condor_token_list
# _condor_token_list — HTCondor condor_token_list (enumerate IDTOKENs in the per-user $HOME/.condor/tokens.d directory (or alternate -dir); prints subject, identity, issued, expiration and authz list for each; -verbose adds raw JWT, -file lists one specific token, -h help)
# upstream: https://github.com/htcondor/htcondor
# Flags from HTCondor src/condor_tools/token_list on tip.

_condor_token_list() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-version[show version]' \
        '-verbose[show raw JWT]' \
        '-dir+[token dir]:dir:_files -/' \
        '-file+[single token file]:file:_files'
}

_condor_token_list "$@"
