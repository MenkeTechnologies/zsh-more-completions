#compdef cf-secret
# Documentation: https://docs.cfengine.com/docs/master/reference-components-cf-secret.html
# Source: cfengine/core cf-secret/cf-secret.c — CFEngine per-host secret encryption tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-M --manpage)'{-M,--manpage}'[print man page]' \
    '(-d --debug)'{-d,--debug}'[enable debugging output]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-g --log-level)'{-g+,--log-level=}'[log level]:level:(error warning notice info verbose debug)' \
    '(-I --inform)'{-I,--inform}'[enable basic information output]' \
    '(-k --key)'{-k+,--key=}'[key files (comma-separated)]:files:_default' \
    '(-H --host)'{-H+,--host=}'[hosts to encrypt/decrypt for (default localhost)]:hosts:_default' \
    '(-o --output)'{-o+,--output=}'[output file (required for encrypt/decrypt)]:file:_files' \
    '1:subcommand:(encrypt decrypt print-headers)' \
    '*::args:_files' \
    && ret=0

return ret
