#compdef sbomdiff
# Documentation: https://pypi.org/project/sbomdiff/
# show the difference between two SBOM files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--sbom=[SBOM type]:type:(auto spdx cyclonedx)' \
  '--exclude-license[suppress license difference reporting]' \
  '--checksum=[checksum algorithm for comparison]:algo:(MD5 SHA1 SHA256 SHA384 SHA512 SHA3-256 SHA3-384 SHA3-512 BLAKE2b-256 BLAKE2b-384 BLAKE2b-512 BLAKE3)' \
  '-d[display debug information]' \
  '(-o --output-file)'{-o,--output-file}'=[write output to a file]:file:_files' \
  '(-f --format)'{-f,--format}'=[output format]:format:(text json yaml)' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:first SBOM file:_files' \
  '2:second SBOM file:_files' && ret=0

return ret
