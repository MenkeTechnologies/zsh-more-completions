#compdef directus

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize a new Directus project'
      'bootstrap:initialize or update the database'
      'start:start the Directus server'
      'database:database management commands'
      'schema:schema management commands'
      'roles:role management commands'
      'users:user management commands'
      'count:count items in a collection'
      'help:show help'
    )
    _describe -t commands 'directus command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      database)
        if (( CURRENT == 2 )); then
          local -a db_cmds=(
            'install:install the database'
            'migrate\:latest:migrate to latest version'
            'migrate\:up:migrate one version up'
            'migrate\:down:migrate one version down'
          )
          _describe -t commands 'database command' db_cmds && ret=0
        fi
        ;;
      schema)
        if (( CURRENT == 2 )); then
          local -a schema_cmds=(
            'snapshot:create a schema snapshot'
            'apply:apply a schema snapshot'
            'diff:show schema differences'
          )
          _describe -t commands 'schema command' schema_cmds && ret=0
        else
          case ${words[2]} in
            snapshot)
              _arguments -s -S \
                '--format=[output format]:format:(json yaml)' \
                '--yes[skip confirmation]' \
                '--collection=[specific collection]:collection' \
                '*:file:_files' && ret=0
              ;;
            apply)
              _arguments -s -S \
                '--yes[skip confirmation]' \
                '--dry-run[preview changes without applying]' \
                '*:snapshot file:_files' && ret=0
              ;;
          esac
        fi
        ;;
      roles)
        if (( CURRENT == 2 )); then
          local -a role_cmds=(
            'create:create a new role'
          )
          _describe -t commands 'roles command' role_cmds && ret=0
        fi
        ;;
      users)
        if (( CURRENT == 2 )); then
          local -a user_cmds=(
            'create:create a new user'
            'passwd:change user password'
          )
          _describe -t commands 'users command' user_cmds && ret=0
        else
          case ${words[2]} in
            create)
              _arguments -s -S \
                '--email=[user email]:email' \
                '--password=[user password]:password' \
                '--role=[role UUID]:role' && ret=0
              ;;
          esac
        fi
        ;;
    esac
    ;;
esac

return ret
