#compdef condor_token_request_auto_approve
# _condor_token_request_auto_approve — HTCondor condor_token_request_auto_approve (administrative shortcut: tell the daemon to auto-approve incoming IDTOKEN requests for the given netblock for a set lifetime; --netblock CIDR, --lifetime seconds, -name target daemon, -pool collector address)
# upstream: https://github.com/htcondor/htcondor
# Flags from HTCondor src/condor_tools/token_request_auto_approve on tip.

_condor_token_request_auto_approve() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-version[show version]' \
        '--netblock+[CIDR]:cidr:' \
        '--lifetime+[seconds]:seconds:' \
        '-name+[daemon name]:name:' \
        '-pool+[collector]:host:_hosts'
}

_condor_token_request_auto_approve "$@"
