#compdef ecli
# _ecli — Eunomia eBPF program loader / OCI client (eunomia-bpf/eunomia-bpf)
# upstream: https://github.com/eunomia-bpf/eunomia-bpf
# Subcommands + flags from ecli/client/src/main.rs (clap).

_ecli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_ecli_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                run)
                    _arguments \
                        '(-j --json)'{-j,--json}'[print logs in JSON (JSON programs only)]' \
                        '(-p --prog-type)'{-p+,--prog-type=}'[program type]:type:(json wasm tar)' \
                        '*:command line (program URL/path + args):'
                    ;;
                push)
                    _arguments \
                        '(-m --module)'{-m+,--module=}'[wasm module path]:file:_files -g "*.wasm"' \
                        '(-i --prompt)'{-i,--prompt}'[prompt for registry credentials]' \
                        '(-u --username)'{-u+,--username=}'[registry username]:user:' \
                        '(-p --password)'{-p+,--password=}'[registry password]:password:' \
                        '*--annotation=[OCI manifest annotation (key=value)]:annotation:' \
                        '1:image reference:'
                    ;;
                pull)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[output file path]:file:_files' \
                        '(-i --prompt)'{-i,--prompt}'[prompt for registry credentials]' \
                        '(-u --username)'{-u+,--username=}'[registry username]:user:' \
                        '(-p --password)'{-p+,--password=}'[registry password]:password:' \
                        '1:image reference:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ecli_commands] )) ||
_ecli_commands() {
    local -a commands
    commands=(
        'run:load + run a Eunomia eBPF program (URL / path / -)'
        'push:push a wasm-packaged eBPF program to an OCI registry'
        'pull:pull an eBPF program image from an OCI registry'
    )
    _describe -t commands 'ecli command' commands
}

_ecli "$@"
