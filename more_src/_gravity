#compdef gravity

# Zsh completion for Gravity language VM (marcobambini/gravity)

local ret=1

_arguments -s -S \
  '--help[show usage]' \
  '--version[show version]' \
  '-c+[compile source .gravity to bytecode file]:file:_files -g "*.gravity"' \
  '-o+[bytecode output path (with -c)]:file:_files' \
  '-x+[execute bytecode JSON]:file:_files' \
  '-i+[evaluate inline source string]:source' \
  '-q[quiet execution]' \
  '-t+[run unit tests under folder]:directory:_directories' \
  '*:.gravity source or bytecode:_files' && ret=0

return ret
