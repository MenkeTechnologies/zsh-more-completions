#compdef bower-cli
# _bower-cli — Twitter Bower web frontend package manager CLI alias (bower team, JavaScript); custom argparse
# upstream: https://github.com/bower/bower

_bower-cli() {
    local -a sub=(
        'cache:cache commands'
        'cache list:list cache'
        'cache clean:clean cache'
        'help:show help'
        'home:open homepage of package'
        'info:show package info'
        'init:init new bower.json'
        'install:install packages'
        'link:create symlink'
        'list:list installed packages'
        'lookup:show package URL'
        'prune:remove uninstalled packages'
        'register:register new package'
        'search:search packages'
        'uninstall:uninstall packages'
        'unregister:unregister package'
        'update:update packages'
        'version:bump version'
        'login:login'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--allow-root[allow run as root]' \
        '-f[force operations]' \
        '--force[force operations]' \
        '-j[json output]' \
        '--json[json output]' \
        '-l+[log level]:l:(error conflict warn action info debug)' \
        '--loglevel=+[log level]:l:(error conflict warn action info debug)' \
        '-o[disable interactivity]' \
        '--offline[disable interactivity]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-s[silent]' \
        '--silent[silent]' \
        '-V[verbose]' \
        '--verbose[verbose]' \
        '--no-color[no color]' \
        '--no-proxy[disable proxy]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bower subcommand' sub ;;
        args)
            case $words[1] in
                install|uninstall|update|info|home|lookup|search) _arguments \
                    '-F[force the latest version]' \
                    '--force-latest[force the latest version]' \
                    '-p[save to bower.json]' \
                    '--save[save to bower.json]' \
                    '-D[save as dev dependency]' \
                    '--save-dev[save as dev dependency]' \
                    '-S[save exact version]' \
                    '--save-exact[save exact version]' \
                    '-E[expand mode]' \
                    '*:package:' ;;
                init) ;;
                version) _arguments '1:version:' '-m+[message]:str:' '--message=+[message]:str:' ;;
                cache) _arguments '1:cmd:(list clean)' '*:args:' ;;
            esac
            ;;
    esac
}

_bower-cli "$@"
