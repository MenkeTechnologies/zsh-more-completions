#compdef dpkg-buildpackage
# Documentation: https://manpages.debian.org/dpkg-buildpackage
# Source: guillemj/dpkg scripts/dpkg-buildpackage.pl — Debian source-package builder (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '--admindir=-[dpkg admin directory]:dir:_files -/' \
    '--as-root[run binary target as root]' \
    '--build=-[build type]:type:(source binary any all full)' \
    '-a+[debian architecture (--host-arch)]:arch:_default' \
    '-A[binary-arch only (=-b -B)]' \
    '-b[binary-only build]' \
    '-B[binary-only, no architecture-independent files]' \
    '-C+[changelog file]:file:_files' \
    '-e+[maintainer (Changed-By)]:maintainer:_default' \
    '--target-arch=-[target architecture]:arch:_default' \
    '--target-type=-[target type]:type:_default' \
    '-F[full build (default)]' \
    '-g[source build (=-S -g)]' \
    '-G[source build, no diff]' \
    '-m+[maintainer]:maintainer:_default' \
    '-O[old-style source]' \
    '-P+[build profiles (comma-separated)]:profile:_default' \
    '-R+[rules file]:file:_files -g "debian/rules"' \
    '-s+[signing mode]:mode:(s a k m)' \
    '-S[source-only build]' \
    '-t+[GNU system type]:type:_default' \
    '-v+[version to include in changelog]:version:_default' \
    '--buildinfo-file=-[buildinfo file]:file:_files' \
    '*--buildinfo-option=-[option for dpkg-genbuildinfo]:opt:_default' \
    '--changes-file=-[changes file]:file:_files' \
    '*--changes-option=-[option for dpkg-genchanges]:opt:_default' \
    '--check-command=-[QA command]:cmd:_command_names' \
    '*--check-option=-[option for QA check command]:opt:_default' \
    '--no-sign[do not sign result]' \
    '--force-sign[force signing even if upload candidate]' \
    '--sign-backend=-[signing backend]:backend:(gpg gpg2)' \
    '--sign-keyfile=-[signing key file]:file:_files' \
    '--jobs=-[parallel jobs]:n:_default' \
    '--jobs-force=-[force parallel jobs]:n:_default' \
    '*--hook-=-[run command at hook]:cmd:_default' \
    '--ignore-builtin-builddeps[skip built-in build-deps check]' \
    '--no-post-clean[no post-build clean]' \
    '--pre-clean[clean before build (default)]' \
    '--rules-requires-root=-[rules requires root]:value:(no binary-targets yes)' \
    '--sanitize-env[run with sanitised env]' \
    '*--source-option=-[option for dpkg-source]:opt:_default' \
    '1::source dir:_files -/' \
    && ret=0

return ret
