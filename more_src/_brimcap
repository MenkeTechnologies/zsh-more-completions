#compdef brimcap
# Documentation: https://github.com/brimdata/brimcap (cmd/brimcap/ charm-spec CLI — NOT cobra)
# Reference accessed: 2026-05-30
# brimcap — search, analyze and inspect pcap files. Drives Zeek + Suricata analyzers to emit ZNG/ZSON/NDJSON.
# Uses Brim's charm-spec CLI framework (single-dash long opts).

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'analyze:analyze a pcap and emit a stream of ZNG values'
  'config:print the brimcap config (and analyzer registrations)'
  'cut:extract a pcap slice by indexed flow id (input/output)'
  'index:index a pcap file for fast flow extraction'
  'info:print pcap metadata (no flags; takes <pcap> positional)'
  'search:extract flows from indexed pcap files (requires -root)'
  'slice:cut a pcap by time range and 5-tuple flow'
  'ts:print first/last timestamps of a pcap'
)

# Shared root-only config flags (added via SetRootOnlyFlags).
local -a _root_only
_root_only=(
  '-config[brimcap config file path (env BRIMCAP_CONFIG)]:file:_files'
  '-root[brimcap root directory (env BRIMCAP_ROOT)]:dir:_directories'
)

_arguments -C \
  '-json[encode stderr output in JSON (defaults to true when stderr is not a TTY)]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'brimcap subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      analyze)
        _arguments \
          $_root_only \
          '-nostats[suppress statistics output to stderr]' \
          '-z[write output as ZSON values]' \
          '1:pcap file:_files -g "*.(pcap|pcapng|cap)"' && ret=0
        ;;
      config)
        _arguments $_root_only && ret=0
        ;;
      cut)
        _arguments \
          '-r[input file to read from (default stdin "-")]:file:_files' \
          '-w[output file to create (default stdout "-")]:file:_files' && ret=0
        ;;
      index)
        _arguments \
          '-r[input file to read from (default stdin "-")]:file:_files -g "*.(pcap|pcapng|cap)"' \
          '-x[output file for the index (default stdout "-")]:file:_files' \
          '-n[index size limit (default 10000)]:N:' \
          '-root[write the pcap index to a common directory for parallel search]:dir:_directories' && ret=0
        ;;
      info)
        _arguments '1:pcap file:_files -g "*.(pcap|pcapng|cap)"' && ret=0
        ;;
      search)
        _arguments \
          $_root_only \
          '-w[output destination (default stdout "-")]:file:_files' \
          '-ts[REQUIRED: flow start timestamp]:timestamp:' \
          '-duration[search window duration (default 1ns)]:duration:' \
          '-proto[REQUIRED: transport protocol]:proto:(tcp udp icmp)' \
          '-src.ip[REQUIRED: source IP]:ip:' \
          '-src.port[source port]:port:' \
          '-dst.ip[REQUIRED: destination IP]:ip:' \
          '-dst.port[destination port]:port:' && ret=0
        ;;
      slice)
        _arguments \
          '-r[input file to read from (default stdin "-")]:file:_files -g "*.(pcap|pcapng|cap)"' \
          '-w[output file to create (default stdout "-")]:file:_files' \
          '-x[index file]:file:_files' \
          '-from[beginning of time range]:timestamp:' \
          '-to[end of time range]:timestamp:' \
          '-p[transport protocol (default tcp)]:proto:(tcp udp icmp)' && ret=0
        ;;
      ts)
        _arguments \
          '-r[input file to read from (default stdin "-")]:file:_files -g "*.(pcap|pcapng|cap)"' \
          '-w[output file (default stdout "-")]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
