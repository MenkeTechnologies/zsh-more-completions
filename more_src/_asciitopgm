#compdef asciitopgm
# Documentation: man asciitopgm (Netpbm)
# Source: turn a text-art (ASCII grey-shading) file into a PGM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-divisor=[scale divisor]:integer:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:image height:' \
    '2:image width:' \
    '3:ascii file:_files' \
    && ret=0

return ret
