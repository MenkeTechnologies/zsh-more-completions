#compdef voltron
# Documentation: https://github.com/snare/voltron/wiki/Views
# voltron — debugger UI toolkit; attach utility views to GDB/LLDB/VDB/WinDbg

local ret=1

_arguments -s -S -C \
  '(-d --debug)'{-d,--debug}'[print debug logging]' \
  '*-o[override config variable]:override:' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'voltron command' \
      'view[display a view]' \
      'v[display a view (alias)]' && ret=0
    ;;
  args)
    case $line[1] in
      view|v)
        _values 'view type' \
          'registers[CPU register values with change highlighting]' \
          'disasm[disassembly from the instruction pointer]' \
          'memory[memory contents with scrolling]' \
          'stack[stack memory view]' \
          'command[run debugger command and display output]' \
          'breakpoints[list breakpoints with addresses and hit counts]' && ret=0
        ;;
    esac
    ;;
esac

return ret
