#compdef bluej
# _bluej — BlueJ educational Java IDE (Kölling/Rosenberg, University of Kent); object-first Java teaching IDE
# upstream: https://github.com/k-pet-group/BlueJ-Greenfoot

_bluej() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-bluej.javaTools.java=+[path to java]:path:_files' \
        '-bluej.javaTools.javac=+[path to javac]:path:_files' \
        '-bluej.useClassesDir=+[classes dir]:dir:_files -/' \
        '*:project:_files -/'
}

_bluej "$@"
