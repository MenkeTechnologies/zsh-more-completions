#compdef marfrmf
# Multiplies or divides a detector redistribution matrix by an ancillary response

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'rmfil=[input RMF file with redistribution matrix]:rmf file:_files' \
  'ebfil=[file containing EBOUNDS dataset]:ebounds file:_files' \
  'arfil=[ARF file with ancillary response, or NONE]:arf file:_files' \
  'outfil=[output RMF file to create]:output file:_files' \
  'rmfversn=[OGIP FITS format version for output]:version:' \
  'qoverride=[override mission/instrument deconvolution]:flag:(yes no)' \
  'telescop=[telescope name]:telescope:' \
  'instrume=[instrument name]:instrument:' \
  'filter=[moveable filter name, or NONE]:filter:' \
  'detnam=[sub-instrument name, or NONE]:detector:' \
  'chatter=[verbosity level 1-9]:level:' \
  'clobber=[overwrite pre-existing output file]:flag:(yes no)' \
  'scalar=[scalar value for matrix operation]:value:' \
  'qdivide=[divide (yes) or multiply (no)]:flag:(yes no)' \
  'arfcol=[column name for ARF data]:column:' \
  '*:file:_files' && ret=0

return ret
