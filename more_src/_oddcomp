#compdef oddcomp
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/oddcomp.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS oddcomp: find protein/DNA regions with unusual composition
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-infile=[composition data file]:file:_files' \
  '-window=[window size for scan]:size:' \
  '-fullwindow[use full overlap window]' \
  '-outfile=[report output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
