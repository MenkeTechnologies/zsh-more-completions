#compdef tidb-server

_arguments -s \
  '(- *)-V[show version]' \
  '--advertise-address=[address advertised to clients]:addr:' \
  '--host=[listen host]:host:_hosts' \
  '-P=[MySQL protocol port]:port:' \
  '--socket=[unix socket file path]:file:_files' \
  '--status=[status report port]:port:' \
  '--status-host=[status service host]:host:_hosts' \
  '--path=[storage data dir or PD addresses]:path:' \
  '--store=[storage engine]:engine:(unistore tikv mocktikv)' \
  '--temp-dir=[temp directory]:dir:_files -/' \
  '--config=[config file path]:file:_files' \
  '--config-check[validate config file and exit]' \
  '--config-strict[enforce strict config file validity]' \
  '-L=[log level]:level:(debug info warn error fatal)' \
  '--log-file=[log file path]:file:_files' \
  '--log-general=[general log filename]:file:_files' \
  '--log-slow-query=[slow query log directory]:dir:_files -/' \
  '--initialize-insecure[bootstrap insecurely]' \
  '--initialize-secure[create root with socket auth]' \
  '--initialize-sql-file=[SQL script run on first start]:file:_files' \
  '--metrics-addr=[Prometheus pushgateway address]:addr:' \
  '--metrics-interval=[push interval]:duration:' \
  '--report-status[enable status/pprof reporting]' \
  '--cors=[CORS Access-Control-Allow-Origin]:origin:' \
  '--proxy-protocol-fallbackable[allow non-PROXY connections]' \
  '--proxy-protocol-networks=[PROXY-allowed networks]:networks:' \
  '--lease=[schema lease]:duration:' \
  '--token-limit=[concurrent session limit]:n:' \
  '--run-ddl=[enable DDL]:flag:(true false)' \
  '--affinity-cpus=[CPU affinity]:cpus:' \
  '--plugin-dir=[plugin directory]:dir:_files -/' \
  '--plugin-load=[plugin names to load]:plugins:' \
  '--tidb-service-scope=[initial service scope]:scope:' \
  '--redact[desensitize log files]' \
  '--repair-mode[enable repair mode]' \
  '--repair-list=[tables to repair]:tables:'
