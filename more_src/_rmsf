#compdef rmsf gmx-rmsf
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-rmsf.html
# Calculate root mean square fluctuation (RMSF) of atomic positions

local ret=1

_arguments -s -S \
  '-f+[trajectory input]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-s+[structure+mass database]:structure:_files -g "*.(tpr|gro|g96|pdb|brk|ent)"' \
  '-n+[index file]:index file:_files -g "*.ndx"' \
  '-q+[PDB file for coordinates]:pdb file:_files -g "*.pdb"' \
  '-oq+[output PDB with B-factor values]:pdb file:_files -g "*.pdb"' \
  '-ox+[output PDB with average coordinates]:pdb file:_files -g "*.pdb"' \
  '-o+[xvg output for RMSF data]:xvg file:_files -g "*.xvg"' \
  '-od+[xvg output for RMSD values]:xvg file:_files -g "*.xvg"' \
  '-oc+[xvg output for correlation data]:xvg file:_files -g "*.xvg"' \
  '-dir+[log file for diagonalized MSF matrix]:log file:_files -g "*.log"' \
  '-b+[start time ps]:time:' \
  '-e+[end time ps]:time:' \
  '-dt+[frame sampling interval ps]:time:' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-w[view output files]' \
  '-res[calculate per-residue averages]' \
  '-aniso[compute anisotropic temperature factors]' \
  '-fit[perform least-squares superposition]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
