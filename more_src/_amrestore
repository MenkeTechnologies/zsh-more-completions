#compdef amrestore
# _amrestore — Zmanda Amanda amrestore CLI for restoring data from Amanda backup tapes file format directly to disk or stdout supporting label hostname diskname date filter compressed decompressed dumps with pipe (zmanda team, C); getopt
# upstream: https://github.com/zmanda/amanda

_amrestore() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-p[output to stdout pipe]' \
        '--pipe[output to stdout pipe]' \
        '-c[compress with gzip]' \
        '--compress[compress with gzip]' \
        '-C[compress with compress]' \
        '--compress-best[compress with bzip2 -9]' \
        '-r[raw output]' \
        '--raw[raw output]' \
        '-b+[blocksize]:n:' \
        '--blocksize=+[blocksize]:n:' \
        '-f+[fileno]:n:' \
        '--fileno=+[fileno]:n:' \
        '-l+[label]:str:' \
        '--label=+[label]:str:' \
        '-h[also restore header]' \
        '-o+[option]:str:' \
        '*:device hostname diskname date level:_files'
}

_amrestore "$@"
