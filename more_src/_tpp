#compdef tpp

# Zsh completion for tpp (text presentation program)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-s[start at specified slide number]:slide number' \
  '-n[no splash screen]' \
  '-l[convert to LaTeX]:output file:_files -g "*.tex(N)"' \
  '-o[output file for conversion]:output file:_files' \
  '--help[show help]' \
  '--version[show version]' \
  '1:presentation file:_files -g "*.tpp(N)"' && ret=0

return ret
