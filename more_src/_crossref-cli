#compdef crossref-cli crossref
# _crossref-cli — Crossref crossref-cli CLI client to the Crossref REST API resolving DOIs querying journal-article-book-monograph metadata title author year ISSN ORCID funder filtering by works members journals funders types prefixes searching members affiliations licenses (Crossref team, Python); custom argparse
# upstream: https://api.crossref.org/

_crossref-cli() {
    local -a sub=(
        'works:query works metadata'
        'doi:fetch DOI metadata'
        'journals:query journals'
        'funders:query funders'
        'members:query members'
        'types:query content types'
        'prefixes:query DOI prefixes'
        'agency:query DOI registration agency'
        'random:fetch random sample of works'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--mailto=+[email]:str:' \
        '--ua=+[user agent]:str:' \
        '--rows=+[N]:n:' \
        '--offset=+[N]:n:' \
        '--sort=+[s]:s:(score relevance updated deposited indexed published-print published-online published is-referenced-by-count references-count)' \
        '--order=+[o]:o:(asc desc)' \
        '--filter=+[k=v]:str:' \
        '-q+[query]:str:' \
        '--query=+[query]:str:' \
        '--query-author=+[author]:str:' \
        '--query-title=+[title]:str:' \
        '--query-container-title=+[title]:str:' \
        '--query-affiliation=+[org]:str:' \
        '--query-editor=+[editor]:str:' \
        '--query-funder=+[funder]:str:' \
        '--query-publisher-name=+[name]:str:' \
        '--from-pub-date=+[YYYY-MM-DD]:str:' \
        '--until-pub-date=+[YYYY-MM-DD]:str:' \
        '--from-update-date=+[YYYY-MM-DD]:str:' \
        '--until-update-date=+[YYYY-MM-DD]:str:' \
        '--type=+[t]:t:(journal-article book-chapter book monograph proceedings-article posted-content report)' \
        '--format=+[f]:f:(json bibtex ris csv yaml citeproc-json table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'crossref-cli subcommand' sub ;;
        args)
            case $words[1] in
                doi) _arguments '*:doi:' ;;
                journals|funders|members) _arguments '*:identifier:' ;;
                works) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_crossref-cli "$@"
