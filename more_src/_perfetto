#compdef perfetto
# Documentation: https://perfetto.dev/docs/reference/perfetto-cli
# perfetto - on-device system tracing command-line interface

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-o --out)'{-o,--out}'=[output trace file (- for stdout)]:file:_files' \
  '(-c --config)'{-c,--config}'=[trace config file]:file:_files' \
  '--txt[parse config as pbtxt format]' \
  '(-t --time)'{-t,--time}'=[trace duration]:duration:' \
  '(-b --buffer)'{-b,--buffer}'=[ring buffer size]:size:' \
  '(-s --size)'{-s,--size}'=[maximum file size]:size:' \
  '(-a --app)'{-a,--app}'=[enable atrace for Android app]:app:' \
  '(-d --background)'{-d,--background}'[record trace in background]' \
  '(-D --background-wait)'{-D,--background-wait}'[background and wait for data sources]' \
  '--notify-fd=[write status byte to file descriptor]:fd:' \
  '--no-clobber[do not overwrite existing output files]' \
  '--clone=[clone an existing tracing session by id]:tsid:' \
  '--clone-by-name=[clone an existing tracing session by name]:name:' \
  '--clone-for-bugreport[disable trace filtering on cloned sessions]' \
  '--add-note=[add user note to trace config]:note:' \
  '--upload[upload trace to Android reporting paths]' \
  '--save-for-bugreport[save eligible bugreport traces to file]' \
  '--save-all-for-bugreport[clone all eligible bugreport sessions]' \
  '--query[query the service state as text]' \
  '--query-raw[query the service state as raw proto]' \
  '--detach=[detach from tracing session]:key:' \
  '--attach=[re-attach to detached session]:key:' \
  '--stop[stop tracing after re-attaching]' \
  '--is_detached=[check if session can be re-attached]:key:' && ret=0

return ret
