#compdef zoekt-repo-index
# _zoekt-repo-index — Zoekt Android-style "repo" manifest indexer
# upstream: https://github.com/sourcegraph/zoekt
# Flags from cmd/zoekt-repo-index/main.go on tip.

_zoekt-repo-index() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-file_limit=[max file size (bytes)]:bytes:' \
        '-shard_limit=[max corpus size per shard (bytes)]:bytes:' \
        '-parallelism=[max parallel indexing processes]:n:' \
        '-rev_prefix=[reference prefix for branches]:prefix:' \
        '-base_url=[base URL for repository names]:url:_urls' \
        '-repo_cache=[root for repository cache]:dir:_files -/' \
        '-index=[index directory for *.zoekt files]:dir:_files -/' \
        '-manifest_repo_url=[manifest git repo URL]:url:_urls' \
        '-manifest_rev_prefix=[prefix for manifest repo branches]:prefix:' \
        '-name=[repository name]:name:' \
        '-url=[repository URL]:url:_urls' \
        '-max_sub_projects=[trim number of projects in manifest (debug)]:n:' \
        '-incremental=[only index if repo has changed]:bool:(true false)' \
        '*: :_files'
}

_zoekt-repo-index "$@"
