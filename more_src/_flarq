#compdef flarq
# Documentation: https://man.archlinux.org/search?q=flarq
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config-dir=+[config dir]:dir:_files -/' \
  '--arq-server-address=+[ARQ address]:addr:' \
  '--arq-server-port=+[ARQ port]:port:' \
  '--debug-level=+[debug level]:lvl:(0 1 2 3 4 5)' && ret=0

return ret
