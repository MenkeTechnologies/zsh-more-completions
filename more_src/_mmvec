#compdef mmvec
# Documentation: https://github.com/biocore/mmvec/blob/master/scripts/mmvec
# mmvec neural networks for microbe-metabolite interaction analysis

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--microbe-file=[input microbial abundances]:file:_files' \
  '--metabolite-file=[input metabolite abundances]:file:_files' \
  '--metadata-file=[input sample metadata file]:file:_files' \
  '--training-column=[metadata column specifying training/testing samples]:column' \
  '--num-testing-examples=[number of samples to randomly select for testing]:n' \
  '--min-feature-count=[minimum samples a microbe must appear in]:n' \
  '--epochs=[number of epochs to train]:n' \
  '--batch-size=[size of mini-batch]:n' \
  '--latent-dim=[dimensionality of shared latent space]:n' \
  '--input-prior=[width of normal prior for input embedding]:n' \
  '--output-prior=[width of normal prior for output embedding]:n' \
  '--arm-the-gpu[enable GPU support]' \
  '--learning-rate=[gradient descent decay rate]:rate' \
  '--beta1=[gradient decay rate for first Adam momentum]:n' \
  '--beta2=[gradient decay rate for second Adam momentum]:n' \
  '--clipnorm=[gradient clipping size]:n' \
  '--checkpoint-interval=[seconds before storing a checkpoint]:n' \
  '--summary-interval=[seconds before storing a summary]:n' \
  '--summary-dir=[summary directory for results]:dir:_files -/' \
  '--embeddings-file=[path to save learned embeddings]:file:_files' \
  '--ranks-file=[path to save learned ranks]:file:_files' \
  '--ordination-file=[path to save learned ordination]:file:_files' \
  '--equalize-biplot[equalize norms of singular vectors]' \
  '*:command:(paired-omics)' && ret=0

return ret
