#compdef bareos-bsmtp
# Documentation: https://docs.bareos.org/Appendix/BareosPrograms.html
# Reference accessed: 2026-05-16
# Verified: Bareos docs Appendix - bsmtp program reference. Note: in
# bsmtp, -h is --mailhost, NOT help. Help is -? only.
# Removed from prior file: fabricated -h as help and -V as version flags.

# bareos-bsmtp: simple SMTP client used by Bareos for notification mail
local curcontext="$curcontext" ret=1
_arguments -C \
  '-\?[show help]' \
  '--help[show help]' \
  '(-4 --ipv4-protocol)'{-4,--ipv4-protocol}'[force IPv4]' \
  '(-6 --ipv6-protocol)'{-6,--ipv6-protocol}'[force IPv6]' \
  '(-a --any-protocol)'{-a,--any-protocol}'[any IP protocol]' \
  '(-8 --utf8)'{-8,--utf8}'[set charset to UTF-8]' \
  '(-c --copy-to)'{-c+,--copy-to=}'[Cc\: header]:cc:' \
  '(-d --debug-level)'{-d+,--debug-level=}'[debug level]:level:' \
  '(--dt --debug-timestamps)'{--dt,--debug-timestamps}'[print timestamps in debug output]' \
  '(-f --from)'{-f+,--from=}'[From header (required)]:from:' \
  '(-s --subject)'{-s+,--subject=}'[Subject header (required)]:subject:' \
  '(-r --reply-to)'{-r+,--reply-to=}'[Reply-To header]:address:' \
  '(-h --mailhost)'{-h+,--mailhost=}'[SMTP server host\:port (NOT help)]:host\:port:' \
  '(-l --max-lines)'{-l+,--max-lines=}'[max lines to send]:n:' \
  '*:recipient:' && ret=0
return ret
