#compdef alsactl
# Documentation: https://manpages.debian.org/alsactl.1
# Source: alsa-utils — mixer/control-state save/restore + init + daemon.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(- *)'{-h,--help}'[show flags and commands]' \
    '(-d --debug)'{-d,--debug}'[more verbose]' \
    '(- *)'{-v,--version}'[print version]' \
    '(-f --file)'{-f+,--file=}'[configuration file]:file:_files' \
    '(-a --config-dir)'{-a+,--config-dir=}'[boot/hotplug ALSA config dir]:dir:_directories' \
    '(-l --lock -L --no-lock)'{-l,--lock}'[use file locking]' \
    '(-l --lock -L --no-lock)'{-L,--no-lock}'[do not use file locking]' \
    '(-O --lock-state-file)'{-O+,--lock-state-file=}'[state lock file path]:file:_files' \
    '(-F --force)'{-F,--force}'[restore matching control elements best-effort]' \
    '(-g --ignore)'{-g,--ignore}'[silence "No soundcards found" and exit 0]' \
    '(-P --pedantic)'{-P,--pedantic}'[do not restore mismatching control elements]' \
    '(-I --no-init-fallback)'{-I,--no-init-fallback}'[do not initialize cards on restore failure]' \
    '(-r --runstate)'{-r+,--runstate=}'[runstate file path]:file:_files' \
    '(-R --remove)'{-R,--remove}'[remove runstate file first]' \
    '*'{-E,--env=}'[set environment variable]:var=value:' \
    '(-i --initfile)'{-i+,--initfile=}'[init configuration file]:file:_files' \
    '(-p --period)'{-p+,--period=}'[daemon store period in seconds]:seconds:' \
    '(-e --pid-file)'{-e+,--pid-file=}'[PID file path]:file:_files' \
    '(-b --background)'{-b,--background}'[run task in background]' \
    '(-s --syslog)'{-s,--syslog}'[use syslog for messages]' \
    '(-n --nice)'{-n+,--nice=}'[process priority (nice value)]:nice:' \
    '(-c --sched-idle)'{-c,--sched-idle}'[scheduling policy idle]' \
    '(-D --ucm-defaults)'{-D,--ucm-defaults}'[execute defaults section from UCM config]' \
    '(-U --no-ucm)'{-U,--no-ucm}'[skip UCM init even if available]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'store:save current controls to state file'
            'restore:load controls from state file'
            'nrestore:non-blocking restore (signal daemon)'
            'init:initialize controls from init configuration'
            'daemon:run in background, periodically saving state'
            'rdaemon:like daemon but restart on signal'
            'kill:signal the running daemon'
            'monitor:print control events'
            'info:print info about a soundcard'
            'clean:remove unused control state'
            'dump-state:dump current state in alsactl format'
            'dump-cfg:dump current init config'
        )
        _describe -t subcmds 'alsactl command' subcmds && ret=0
        ;;
    args)
        _default
        ;;
esac

return ret
