#compdef posting

_posting_commands() {
  local -a commands=(
    'run:Start the TUI application'
    'import:Import from other formats'
    'export:Export to other formats'
    'locate:Show config/data file locations'
    'help:Show help'
  )
  _describe 'command' commands
}

_posting() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--collection=[collection directory]:directory:_directories' \
    '--env=[environment file]:file:_files' \
    '--theme=[color theme]:theme' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '1:command:_posting_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        import)
          _arguments \
            '--format=[import format]:format:(curl openapi insomnia postman)' \
            '(-o --output)'{-o,--output}'=[output directory]:directory:_directories' \
            '(-h --help)'{-h,--help}'[help for import]' \
            '1:file:_files'
          ;;
        export)
          _arguments \
            '--format=[export format]:format:(curl)' \
            '(-o --output)'{-o,--output}'=[output file]:file:_files' \
            '(-h --help)'{-h,--help}'[help for export]' \
            '1:request'
          ;;
        run)
          _arguments \
            '--collection=[collection directory]:directory:_directories' \
            '--env=[environment file]:file:_files' \
            '--theme=[color theme]:theme' \
            '(-h --help)'{-h,--help}'[help for run]'
          ;;
        locate)
          _arguments \
            '(-h --help)'{-h,--help}'[help for locate]'
          ;;
      esac
      ;;
  esac
}

_posting "$@"
