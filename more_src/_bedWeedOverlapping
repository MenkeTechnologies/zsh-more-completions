#compdef bedWeedOverlapping
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# Filter out beds that overlap a weed.bed file

local ret=1

_arguments -s -S \
  '-maxOverlap=[maximum overlapping ratio, default 0]:ratio:' \
  '-invert[keep overlapping items instead]' \
  '*:weeds.bed input.bed output.bed:_files' && ret=0

return ret
