#compdef traefikee
# Documentation: https://doc.traefik.io/traefik-enterprise/references/cli/traefikee/
# Traefik Enterprise node binary (controller / proxy)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'controller:start a new controller and join it to a cluster'
  'proxy:start a new proxy and join it to a cluster'
  'tokens:get tokens from the cluster'
  'version:print version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'traefikee command' commands && ret=0
    ;;
  args)
    _arguments -s -S \
      '--advertise=[address to advertise to peers]:address:' \
      '--api.addr=[address to listen on for the API]:address:' \
      '--api.autocerts[generate required mTLS certificates for the cluster API]' \
      '--api.bundle=[certificate bundle to access the cluster API with teectl]:file:_files' \
      '--bind=[address to listen for peers on]:address:' \
      '--discovery.static.peers=[comma separated list of peers to connect to]:peers:' \
      '--name=[name of the node]:name:' \
      '--statedir=[path to the state directory]:dir:_files -/' \
      '--log.format=[log format]:format:(json common)' \
      '--log.level=[log level]:level:' \
      '--jointoken.value=[value of the join token]:token:' \
      '(-h --help)'{-h,--help}'[show help]' && ret=0
    ;;
esac

return ret
