#compdef diving
# Documentation: https://github.com/vicanso/diving-rs
# Source: vicanso/diving-rs — Rust Docker-image layer explorer.
# Reference accessed: 2026-06-01
# Image sources: registry, docker:// local Docker, file:// tar.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--output-file=[export JSON or Markdown to file or stdout]:file:_files' \
    '--no-skip-base[include base image layers in Markdown reports]' \
    '--ai-api-key=[OpenAI-compatible API key]:key:_default' \
    '--ai-base-url=[custom API endpoint (default OpenAI)]:url:_default' \
    '--ai-model=[model name (default gpt-4o)]:model:_default' \
    '--ai-system-prompt=[override built-in system prompt]:prompt:_default' \
    '--lang=[output language]:lang:(en zh)' \
    '--no-ai-history[skip regression comparison]' \
    '--wecom-webhook=[push results to a WeCom group chat]:url:_default' \
    '--listen=[web mode address (default 127.0.0.1:7001)]:addr:_default' \
    '--mode=[run mode]:mode:(web)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:image (registry / docker:// / file://):_default' \
    && ret=0

return ret
