#compdef osrm-datastore
# Documentation: https://github.com/Project-OSRM/osrm-backend
# Load an OSRM dataset into shared memory for use by osrm-routed.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--list-inputs[list required and optional input file extensions]' \
  '(-l --verbosity)'{-l+,--verbosity=}'[log verbosity level]:level:(NONE ERROR WARNING INFO DEBUG)' \
  '(-r --remove-locks)'{-r,--remove-locks}'[remove shared memory locks]' \
  '(-s --spring-clean)'{-s,--spring-clean}'[clean all shared memory regions]' \
  '--max-wait=[max seconds to wait on running update before forcing lock]:seconds:_default' \
  '--dataset-name=[name of dataset to load (enables concurrent datasets)]:name:_default' \
  '--disable-feature-dataset=[disable a feature dataset from loading]:dataset:(ROUTE_STEPS ROUTE_GEOMETRY)' \
  '--list[list all OSRM datasets currently in memory]' \
  '--list-blocks[list datasets and their data blocks in memory]' \
  '--only-metric[reload only metric data (traffic update optimization)]' \
  '(-b --base)'{-b+,--base=}'[base path to .osrm file]:file:_files -g "*.osrm(-.)"' \
  '*:base path:_files -g "*.osrm(-.)"' && ret=0

return ret
