#compdef mpichversion
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/mpichversion.1.html
# Report on the MPICH version

local ret=1

_arguments -s \
  '(-v --version)'{-v,--version}'[show the version of MPICH]' \
  '(-D --date)'{-D,--date}'[show the release date of this version]' \
  '-patches[show the identifiers for any applied patches]' \
  '(-c --configure)'{-c,--configure}'[show the configure arguments used to build MPICH]' \
  '(-d --device)'{-d,--device}'[show the device for which MPICH was configured]' && ret=0

return ret
