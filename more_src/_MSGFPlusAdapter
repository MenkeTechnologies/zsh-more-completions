#compdef MSGFPlusAdapter
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: adapter for the MS-GF+ peptide identification engine

local ret=1

_arguments -s -S \
  '-in[input MS data file]:input file:_files' \
  '-out[output file (idXML)]:output file:_files' \
  '-mzid_out[mzIdentML output file]:file:_files' \
  '-executable[path to MSGFPlus jar]:jar:_files' \
  '-database[protein sequence database (FASTA)]:fasta:_files' \
  '-precursor_mass_tolerance[precursor mass tolerance]:value:' \
  '-precursor_error_units[tolerance units]:unit:(Da ppm)' \
  '-isotope_error_range[allowed isotope peak error range]:range:' \
  '-fragment_method[fragmentation method]:method:(from_spectrum CID ETD HCD)' \
  '-instrument[instrument type]:type:(low_res high_res TOF Q_Exactive)' \
  '-enzyme[protease used]:enzyme:' \
  '-protocol[labeling protocol]:protocol:(automatic phospho iTRAQ TMT none)' \
  '-tryptic[cleavage specificity]:spec:(non semi fully)' \
  '-min_peptide_length[minimum peptide length]:n:' \
  '-max_peptide_length[maximum peptide length]:n:' \
  '-min_precursor_charge[minimum charge state]:n:' \
  '-max_precursor_charge[maximum charge state]:n:' \
  '-max_mods[maximum modifications per peptide]:n:' \
  '-max_missed_cleavages[allowed missed cleavages]:n:' \
  '-matches_per_spec[results per spectrum]:n:' \
  '-min_peaks[minimum spectrum peaks required]:n:' \
  '-fixed_modifications[fixed modifications (Unimod)]:mods:' \
  '-variable_modifications[variable modifications (Unimod)]:mods:' \
  '-add_features[output additional features for Percolator]:bool:' \
  '-allow_dense_centroided_peaks[search dense centroided spectra]' \
  '-conf[MS-GF+ configuration file]:file:_files' \
  '-tasks[override task count]:n:' \
  '-java_executable[path to Java executable]:exe:_files' \
  '-java_memory[maximum Java heap size (MB)]:mb:' \
  '-reindex[recalculate peptide-protein associations]:bool:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
