#compdef plank
# Documentation: https://man.archlinux.org/search?q=plank
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--help-all[show all help options]' \
  '--help-gtk[GTK options]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-n --name)'{-n+,--name=}'[dock name]:name:' \
  '(-p --preferences)'{-p,--preferences}'[show preferences]' \
  '--display=[X display]:display:' && ret=0

return ret
