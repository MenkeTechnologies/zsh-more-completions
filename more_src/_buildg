#compdef buildg

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-f --file)'{-f,--file}'[Dockerfile path]:file:_files -g "(Dockerfile*|*.dockerfile)"' \
  '--target[target build stage]:stage' \
  '*--build-arg[set build argument]:arg=value' \
  '*--cache-from[external cache source]:cache' \
  '*--cache-to[cache export destination]:cache' \
  '--progress[progress output type]:type:(auto plain tty)' \
  '*--secret[secret to expose to the build]:secret' \
  '*--ssh[SSH agent socket or keys]:ssh' \
  '--image[image to use for debugging]:image' \
  '*:build context:_files -/' && ret=0

return ret
