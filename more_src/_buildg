#compdef buildg
# Documentation: https://github.com/ktock/buildg
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'debug:interactively debug a Dockerfile'
  'du:show disk usage'
  'prune:prune build cache'
  'dap:start the DAP server'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug output]' \
  '--root[buildg root dir]:dir:_directories' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'buildg command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (debug)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'[Dockerfile path]:file:_files -g "(Dockerfile*|*.dockerfile)"' \
          '--target=[target build stage]:stage' \
          '*--build-arg=[set build argument]:arg=value' \
          '*--cache-from=[external cache source]:cache' \
          '*--cache-to=[cache export destination]:cache' \
          '--progress=[progress output type]:type:(auto plain tty)' \
          '*--secret=[secret to expose to the build]:secret' \
          '*--ssh=[SSH agent socket or keys]:ssh' \
          '--image=[image to use for debugging]:image' \
          '*:build context:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
