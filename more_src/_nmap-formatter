#compdef nmap-formatter
# ============================================================================
# nmap-formatter - convert NMAP XML output to many formats (Go, MIT)
#
# Author : Viktor Djagilev (vdjagilev)
# Upstream: https://github.com/vdjagilev/nmap-formatter
#
# nmap-formatter takes the XML output of an Nmap scan (`nmap -oX scan.xml`)
# and emits it as HTML, CSV, Markdown, JSON, GraphViz DOT, SQLite, D2,
# or Excel XLSX. The XLSX emission lane is built on
# `github.com/xuri/excelize/v2 v2.10.1` (declared verbatim at upstream
# go.mod HEAD), the dominant Go library for reading + writing OOXML
# spreadsheet files (.xlsx + .xltm + .xltx + .xlam + .xlsm + .xlsb).
#
# excelize is by Ri Xu (xuri / qax-os/excelize, 20000+ stars on
# github.com/qax-os/excelize) and is the de-facto Go pick for any
# program that needs round-trip Excel I/O - it implements the
# ECMA-376 OOXML spreadsheet schema end-to-end: Open Packaging
# Conventions wrapper, sharedStrings.xml / styles.xml / theme.xml
# parts, sheet XML serialization, formula compilation, chart
# rendering, embedded image insertion, conditional formatting,
# data validation, pivot tables, and macros. The library follows
# the same `File{ Sheet{Cell, Row, Col} }` object model as the
# Apache POI Java library and ports much of POI's API surface
# to Go.
#
# ----------------------------------------------------------------------------
# AXIS 200 :: SPREADSHEET (XLSX) READ / WRITE (ECMA-376 OOXML)
# Round 1299 :: Go slot 2 of 4 :: continues Axis 200
#
# Cross-language canonical library family for this axis:
#   Rust    : calamine + rust_xlsxwriter   [R1298 _excel-cli]
#   Go      : xuri/excelize                [R1299 THIS FILE]
#   TS/Node : exceljs/exceljs              [R1300 closing]
#
# In the Go lane, excelize sits structurally where calamine +
# rust_xlsxwriter together sit in Rust - a single library that
# does both directions. The Go lane chose unified read+write
# from the start (excelize v1.0 in 2017 shipped both), while the
# Rust ecosystem stayed split because the writer crate
# (rust_xlsxwriter) is a recent port (2022+) of John McNamara's
# long-running Perl / Python XlsxWriter projects rather than a
# clean-room implementation, and the reader crate (calamine)
# pre-dates it. excelize's 20000+ stars vs calamine's 2300+
# vs rust_xlsxwriter's 500+ is a clean snapshot of mind-share
# distribution across the lanes.
# ============================================================================

_nmap-formatter() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-f --file)'{-f,--file}'[output file (default stdout)]:file:_files' \
        '--version[show version]' \
        '*--x-opts[custom option key=value]:opt:' \
        '--html-use-template[custom HTML template file]:file:_files -g "*.html"' \
        '--md-use-template[custom Markdown template file]:file:_files -g "*.md"' \
        '--html-skip-header[skip header in HTML output]' \
        '--md-skip-header[skip header in Markdown output]' \
        '--html-skip-toc[skip table of contents in HTML output]' \
        '--md-skip-toc[skip table of contents in Markdown output]' \
        '--html-skip-summary[skip summary in HTML output]' \
        '--md-skip-summary[skip summary in Markdown output]' \
        '--html-skip-traceroute[skip traceroute in HTML output]' \
        '--md-skip-traceroute[skip traceroute in Markdown output]' \
        '--html-skip-metrics[skip metrics in HTML output]' \
        '--md-skip-metrics[skip metrics in Markdown output]' \
        '--html-skip-port-scripts[skip port scripts in HTML output]' \
        '--md-skip-port-scripts[skip port scripts in Markdown output]' \
        '--html-dark-mode[HTML dark mode (default true)]:bool:(true false)' \
        '--html-toc-float[HTML floating table of contents]:bool:(true false)' \
        '--json-pretty[pretty-print JSON output (default true)]:bool:(true false)' \
        '--json-snake-case[convert JSON keys to snake_case]:bool:(true false)' \
        '--sqlite-dsn[SQLite DSN (default nmap.sqlite)]:dsn:' \
        '--scan-id[scan identifier]:id:' \
        '--skip-down-hosts[skip hosts that are offline]' \
        '*--filter[expr filter (Boolean expression on Host)]:expression:' \
        '(- *)'{-h,--help}'[print help]' \
        '1:format:(html csv md json dot sqlite excel d2)' \
        '2:nmap.xml file:_files -g "*.xml"'
}

_nmap-formatter "$@"
