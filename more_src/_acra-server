#compdef acra-server
# ============================================================================
# _acra-server — zsh completion for Cossack Labs' AcraServer, the database
#                 proxy daemon at the heart of the Acra database security
#                 suite (Go=144 leader bump continuing Axis 89 AWS SDK /
#                 aws-sdk-rust)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/cossacklabs/acra
#   Maintainer : Cossack Labs
#   License    : Apache-2.0
#   Stars      : 1480
#   Language   : Go
#   Module     : github.com/cossacklabs/acra
#   Binary     : acra-server  (cmd/acra-server/acra-server.go,
#                               part of the multi-binary Acra suite:
#                               acra-server, acra-keys, acra-keymaker,
#                               acra-translator, acra-tokens,
#                               acra-rollback, acra-rotate,
#                               acra-poisonrecordmaker, acra-backup)
#   Last push  : 2026-04-23
#
# WHAT IT IS
#   Acra is "a database security suite — database proxy with field-
#   level encryption, search through encrypted data, SQL injection
#   prevention, intrusion detection, audit logging".  AcraServer is
#   the transparent SQL proxy that sits between the application
#   and PostgreSQL / MySQL:  it intercepts SQL traffic, parses each
#   query via AcraCensor (SQL firewall), transparently encrypts /
#   decrypts AcraStruct- and AcraBlock-marked fields, generates
#   and validates poison records for intrusion detection, signs
#   audit log entries with monotonic chained-hash sequences,
#   tokenizes data through the integrated AcraTokens engine, and
#   exposes a Prometheus-scrapable metrics endpoint.  Keys are
#   loaded from a configurable keystore that can use the local
#   filesystem, Redis, HashiCorp Vault, or AWS KMS via aws-sdk-go-
#   v2.  TLS termination supports per-service certs and a
#   per-cert client-id extractor for end-to-end mutual TLS.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/acra-server/acra-
#                       server.go `registerFlags(flagSet)` —
#                       Acra uses Go's stdlib `flag` package, not
#                       cobra or urfave/cli)
#   acra-server [OPTIONS]
#
#   Logging / output:
#     --logging_format <FMT>         plaintext|json|CEF
#                                    [default: plaintext]
#     --v                            Log INFO/WARN/ERROR to stderr
#     --d                            Log everything to stderr
#     --log_to_console               Log to stderr [default: true]
#     --log_to_file <PATH>           Log to file
#
#   Database connection:
#     --db_host <HOST>               Host to db
#     --db_port <PORT>               Port to db  [default: 5432]
#     --postgresql_enable            Handle PostgreSQL connections
#                                    [default: true]
#     --mysql_enable                 Handle MySQL connections
#
#   AcraServer listeners:
#     --incoming_connection_host <HOST>
#                                    Host for AcraServer
#     --incoming_connection_port <PORT>
#                                    Port for AcraServer
#     --incoming_connection_api_port <PORT>
#                                    Port for AcraServer HTTP API
#     --incoming_connection_string <URL>
#                                    Connection string
#                                    (tcp://x.x.x.x:yyyy or
#                                     unix:///path/to/socket)
#     --incoming_connection_api_string <URL>
#                                    API connection string
#     --incoming_connection_close_timeout <SECS>
#                                    Wait time on restart before
#                                    closing all connections
#     --incoming_connection_prometheus_metrics_string <URL>
#                                    Prometheus metrics URL
#                                    (tcp://host:port; metrics at
#                                     <URL>/metrics)
#
#   Keystore:
#     --keys_dir <DIR>               Keystore directory
#     --keystore_cache_on_start_enable
#                                    Load all keys to cache on
#                                    start  [default: true]
#     --keystore_cache_size <N>      Max keys in in-memory LRU
#                                    cache (0=unlimited, -1=off)
#     --client_id <ID>               Static ClientID for data
#                                    protection
#
#   HTTP API:
#     --http_api_enable              Enable HTTP API
#     --http_api_tls_transport_enable
#                                    Enable HTTPS for the API
#                                    (default true in 0.96.0+)
#
#   TLS / mTLS:
#     --tls_client_id_from_cert      Extract ClientID from TLS
#                                    cert  [default: true]
#     --tls_identifier_extractor_type <T>
#                                    TLS cert field as ClientID
#                                    (distinguished_name|serial_
#                                    number|empty)
#     (plus the full TLS arg set registered by network.Register
#     TLSBaseArgs / network.RegisterTLSArgsForService — server,
#     client, database side, see `--tls_*_*` family in upstream
#     docs)
#
#   Poison records / intrusion detection:
#     --poison_detect_enable         Turn on poison record
#                                    detection
#     --poison_shutdown_enable       Stop+shutdown on poison
#     --poison_run_script_file <PATH>
#                                    Execute script on poison
#
#   SQL safety:
#     --sql_parse_on_error_exit_enable
#                                    Stop on SQL parse error
#     --acracensor_config_file <PATH>
#                                    Path to AcraCensor config
#     --token_db <PATH>              Path to BoltDB token store
#
#   Encryptor config:
#     --encryptor_config_storage_type <T>
#                                    filesystem|s3 (see acra docs)
#
#   Audit log:
#     --audit_log_enable             Enable audit log
#                                    functionality
#
#   Debug / dev:
#     --ds                           Turn on HTTP debug server
#     --pgsql_hex_bytea              [DEPRECATED] ignored
#     --pgsql_escape_bytea           [DEPRECATED] ignored
#     --acrastruct_wholecell_enable  [DEPRECATED] ignored
#     --acrastruct_injectedcell_enable
#                                    [DEPRECATED] ignored
#
#   Plus full Redis (keystore+token), KMS keyloader, tracing
#   (--tracing_log_enable, --tracing_jaeger_enable), and Jaeger
#   parameter trees registered by `cmd.Register*Parameters()`
#   helpers.
#
#   Standard Go flag package conventions:
#     -h, --help                     Show help
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/aws/aws-sdk-go-v2 v1.16.6`,
#   `github.com/aws/aws-sdk-go-v2/config v1.15.12`,
#   `github.com/aws/aws-sdk-go-v2/credentials v1.12.7`, and
#   `github.com/aws/aws-sdk-go-v2/service/kms v1.17.4` declared in
#   go.mod — `aws-sdk-go-v2` is THE canonical Go AWS SDK
#   maintained by AWS (aws/aws-sdk-go-v2, 2.7K+ stars,
#   the Smithy-codegen replacement for the legacy aws-sdk-go
#   v1).  aws-sdk-go-v2 ships per-service client packages
#   (`s3.Client`, `kms.Client`, `ec2.Client`, `iam.Client`,
#   `dynamodb.Client`, `sqs.Client`, ...), typed input/output
#   structs (`kms.EncryptInput`, `kms.DecryptOutput`), paginators
#   (`s3.NewListObjectsV2Paginator`), waiters
#   (`s3.NewBucketExistsWaiter`), the unified
#   `aws.Config` + `config.LoadDefaultConfig` credential chain
#   (IMDSv2 / env / shared / SSO / process / IAM Identity
#   Center), `aws.Credentials`, retryers, and the
#   `aws/middleware` stack composed via `smithy-go`.  Acra's
#   `keystore/v2/keystore/aws_kms` package constructs a
#   `kms.NewFromConfig(awsConfig)` client to encrypt and decrypt
#   master keystore-wrapping keys against an AWS KMS Customer
#   Master Key, enabling KMS-backed key rotation for the field-
#   level encryption pipeline.  Verified via:
#     gh api repos/cossacklabs/acra/contents/go.mod
#       → github.com/aws/aws-sdk-go-v2 v1.16.6
#       → github.com/aws/aws-sdk-go-v2/config v1.15.12
#       → github.com/aws/aws-sdk-go-v2/credentials v1.12.7
#       → github.com/aws/aws-sdk-go-v2/service/kms v1.17.4
#       → module github.com/cossacklabs/acra
#     gh api repos/cossacklabs/acra/contents/cmd/acra-server/
#         acra-server.go
#       → func registerFlags(flagSet *flag.FlagSet) { ... }
#         (40+ flagSet.String/Int/Bool registrations)
#   This entry is the Go=144 leader bump that continues Axis 89
#   (AWS SDK / aws-sdk-rust) opened at R945 with Rust=aws-sdk-
#   iam via awslabs/iam-policy-autopilot.
#
#   No completion for `acra-server` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_acra-server() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '--logging_format=[log format]:format:(plaintext json CEF)' \
        '--v[log INFO/WARN/ERROR to stderr]' \
        '--d[log everything to stderr]' \
        '--log_to_console[log to stderr]' \
        '--log_to_file=[log to file path]:file:_files' \
        '--db_host=[database host]:host:' \
        '--db_port=[database port (default 5432)]:port:' \
        '--postgresql_enable[handle PostgreSQL connections]' \
        '--mysql_enable[handle MySQL connections]' \
        '--incoming_connection_host=[AcraServer host]:host:' \
        '--incoming_connection_port=[AcraServer port]:port:' \
        '--incoming_connection_api_port=[AcraServer HTTP API port]:port:' \
        '--incoming_connection_string=[connection string (tcp\://host\:port or unix\:///path)]:url:' \
        '--incoming_connection_api_string=[API connection string]:url:' \
        '--incoming_connection_close_timeout=[restart close timeout in seconds]:secs:' \
        '--incoming_connection_prometheus_metrics_string=[Prometheus metrics URL]:url:' \
        '--keys_dir=[keystore directory]:dir:_files -/' \
        '--keystore_cache_on_start_enable[load all keys to cache on start]' \
        '--keystore_cache_size=[in-memory LRU key cache size]:n:' \
        '--client_id=[static ClientID]:id:' \
        '--http_api_enable[enable HTTP API]' \
        '--http_api_tls_transport_enable[enable HTTPS for the API]' \
        '--tls_client_id_from_cert[extract ClientID from TLS cert]' \
        '--tls_identifier_extractor_type=[TLS cert field as ClientID]:type:(distinguished_name serial_number empty)' \
        '--poison_detect_enable[turn on poison record detection]' \
        '--poison_shutdown_enable[stop+shutdown on poison]' \
        '--poison_run_script_file=[execute script on poison]:path:_files' \
        '--sql_parse_on_error_exit_enable[stop on SQL parse error]' \
        '--acracensor_config_file=[AcraCensor configuration file]:path:_files -g "*.yaml"' \
        '--token_db=[BoltDB token store path]:path:_files' \
        '--encryptor_config_storage_type=[encryptor config storage type]:type:(filesystem s3)' \
        '--audit_log_enable[enable audit log]' \
        '--ds[turn on HTTP debug server]'
}

_acra-server "$@"
