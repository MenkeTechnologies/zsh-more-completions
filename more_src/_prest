#compdef prest

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'migrate:run database migrations'
  'version:print version information'
)

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' \
  '--url=[database URL]:database URL:' \
  '--conf=[path to configuration file]:config file:_files' \
  '--debug[enable debug mode]' \
  '--migrations=[path to migrations directory]:migrations dir:_files -/' \
  '(-p --port)'{-p,--port}'=[HTTP port]:port number:' \
  '--ssl-mode=[SSL mode]:ssl mode:(disable require verify-ca verify-full)' \
  '--ssl-cert=[path to SSL certificate]:cert file:_files' \
  '--ssl-key=[path to SSL private key]:key file:_files' \
  '--ssl-rootcert=[path to SSL root certificate]:root cert file:_files' \
  '--http-port=[HTTP port]:port:' \
  '--pg-host=[PostgreSQL host]:host:_hosts' \
  '--pg-port=[PostgreSQL port]:port:' \
  '--pg-user=[PostgreSQL user]:user:' \
  '--pg-pass=[PostgreSQL password]:password:' \
  '--pg-database=[PostgreSQL database]:database:' \
  '--jwt-key=[JWT secret key]:key:' \
  '--jwt-algo=[JWT algorithm]:algorithm:(HS256 HS384 HS512)' \
  '--cors-allowed-origins=[CORS allowed origins]:origins:' \
  '--cors-allowed-headers=[CORS allowed headers]:headers:' \
  '--cache[enable cache]' \
  '--cache-time=[cache TTL in minutes]:minutes:' \
  '--single[run as single tenant]' \
  '--qsprefix=[query string prefix]:prefix:' \
  '--expose-conf[expose configuration endpoint]' \
  '--auth-enabled[enable authentication]' \
  '--auth-schema=[schema for auth]:schema:' \
  '--auth-table=[table for auth]:table:' \
  '--auth-username=[username field]:field:' \
  '--auth-password=[password field]:field:' \
  '--auth-encrypt=[password encryption method]:method:(MD5 SHA1)' \
  '--adapter=[database adapter]:adapter:(postgres)' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-v --version)'{-v,--version}'[show version]' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'prest command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (migrate)
        _arguments \
          '1:action:(up down next goto reset version force)' \
          '--path=[migrations directory]:dir:_files -/' \
          '--url=[database URL]:URL:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
