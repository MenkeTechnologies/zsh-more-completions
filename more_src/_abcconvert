#compdef abcconvert
# Documentation: https://github.com/alembic/alembic/blob/master/bin/AbcConvert/AbcConvert.cpp
# Alembic: convert between HDF5 and Ogawa archive formats

local ret=1

_arguments -s -S \
  '(-help --help)'{-help,--help}'[show help]' \
  '-toHDF[convert to HDF]' \
  '-toOgawa[convert to Ogawa]' \
  '-force[force conversion even if input is already the target type]' \
  '*-in+[input files (multi-file mode)]:file:_files -g "*.abc"' \
  '-out+[output file (multi-file mode)]:file:_files -g "*.abc"' \
  '*:alembic archive:_files -g "*.abc"' && ret=0

return ret
