#compdef srhtctl
# _srhtctl — sourcehut API CLI (xenrox/srhtctl)
# upstream: https://git.xenrox.net/~xenrox/srhtctl
# Subcommands from cmd/*.go (cobra).

_srhtctl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--config=[path to config.ini]:file:_files -g "*.ini"' \
        '(-u --user)'{-u+,--user=}'[sourcehut username]:user:' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_srhtctl_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                builds)
                    _arguments '1:builds subcommand:(deploy resubmit info)'
                    ;;
                lists)
                    _arguments '1:lists subcommand:(patch list)'
                    ;;
                meta)
                    _arguments '1:meta subcommand:(profile logs)'
                    ;;
                paste)
                    _arguments '1:paste subcommand:(create delete cleanup)'
                    ;;
                todo)
                    _arguments '1:todo subcommand:(ticket list)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_srhtctl_commands] )) ||
_srhtctl_commands() {
    local -a commands
    commands=(
        'builds:builds.sr.ht jobs (deploy / resubmit / info)'
        'git:git.sr.ht repos'
        'lists:lists.sr.ht (patch / list)'
        'meta:meta.sr.ht profile / logs'
        'paste:paste.sr.ht (create / delete / cleanup)'
        'todo:todo.sr.ht tickets (ticket / list)'
        'completion:print shell completion script'
    )
    _describe -t commands 'srhtctl command' commands
}

_srhtctl "$@"
