(( $+functions[_decompose_commands] )) ||
_decompose_commands() {
    local commands; commands=(
'up:Start the environment' \
'down:Stop the environment daemon and its managed processes' \
'ps:Show process status' \
'attach:Reattach to a running environment'\''s logs' \
'tui:Open an interactive TUI attached to a running environment. Services keep running after the TUI exits; use \`decompose down\` (or press \`Q\` in the TUI) to stop them' \
'logs:View process logs' \
'start:Start one or more previously-stopped services. With no args, starts all' \
'stop:Stop one or more services. With no args, stops all' \
'restart:Restart one or more services. With no args, restarts all' \
'config:Validate and print the resolved configuration' \
'kill:Send a signal to one or more services. With no args, targets all' \
'ls:List running decompose environments' \
'run:Run a one-off command in a service'\''s environment (env vars, working dir, env_file) without attaching to a running replica. Does not require a running daemon. Fire-and-forget\: the command is not added to the supervised process list' \
'exec:Execute a one-off command in the environment of a currently-running service. Requires the daemon to be running and at least one replica of SERVICE to be in the Running state. Otherwise behaves like \`run\`' \
'completion:Generate a shell completion script for the given shell' \
'daemon:' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'decompose commands' commands "$@"
}
