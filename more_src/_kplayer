#compdef kplayer
# Documentation: https://github.com/KDE/kplayer/blob/master/src/main.cpp
# Reference accessed: 2026-05-16
# Verified: src/main.cpp lines 90-101. KDE4-era app using KCmdLineArgs.

# KPlayer: KDE multimedia player (MPlayer frontend)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-qt[show Qt help]' \
  '(- *)--help-kde[show KDE help]' \
  '(- *)--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--play[play files immediately (default)]' \
  '--queue[queue files for playing]' \
  '--play-next[play after current file finishes]' \
  '--queue-next[queue after current file]' \
  '--add-to-new-playlist[add to new playlist]' \
  '--add-to-playlists[add to list of playlists]' \
  '--add-to-collection[add to multimedia collection]' \
  '*:file/dir/URL:_files' && ret=0
return ret
