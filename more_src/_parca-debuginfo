#compdef parca-debuginfo
# Documentation: https://www.parca.dev/docs/debuginfo-cli/
# Parca command line utility to handle debug information tasks

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--log-level=[log level]:level:(error warn info debug)' \
  '1:command:(upload extract buildid)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      upload)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--log-level=[log level]:level:(error warn info debug)' \
          '--store-address=[gRPC address to send symbols to]:address:' \
          '--bearer-token=[bearer token to authenticate with store]:token:' \
          '--bearer-token-file=[file to read bearer token from]:file:_files' \
          '--insecure[send gRPC requests via plaintext instead of TLS]' \
          '--insecure-skip-verify[skip TLS certificate verification]' \
          '*:path:_files' && ret=0
        ;;
      extract)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--log-level=[log level]:level:(error warn info debug)' \
          '--output-dir=[output directory path for extracted debug information files]:dir:_files -/' \
          '*:path:_files' && ret=0
        ;;
      buildid)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--log-level=[log level]:level:(error warn info debug)' \
          '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
