#compdef veneur
# Documentation: https://github.com/stripe/veneur
# Stripe distributed StatsD/SSF metrics aggregation pipeline

local ret=1

_arguments -s -S \
  '-f[path to the configuration file]:file:_files -g "*.(yaml|yml)"' \
  '-validate-config[validate config file is valid YAML with correct datatypes]' \
  '-validate-config-strict[validate config and reject unknown fields]' && ret=0

return ret
