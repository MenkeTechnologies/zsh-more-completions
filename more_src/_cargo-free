#compdef cargo-free
# Documentation: https://crates.io/crates/cargo-free
# check if a given crate name is available on crates.io

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-j --json)'{-j,--json}'[output result as json object]' \
  '*:crate name:' && ret=0

return ret
