#compdef cbbackupmgr

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'backup:back up data from a Couchbase cluster into a repository'
  'collect-logs:collect diagnostic logs about the backup archive'
  'compact:compact an existing backup to reclaim space'
  'config:create a new backup repository in an archive'
  'examine:examine specific keys in a backup'
  'info:display info about backups in an archive'
  'list:list contents of a backup archive'
  'merge:merge multiple backups in a repository together'
  'remove:delete a backup repository'
  'restore:restore a backup from the archive into a cluster'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'cbbackupmgr subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (backup|restore|merge|info|compact|remove|examine|list)
        _arguments \
          '(-a --archive)'{-a,--archive=}'[backup archive directory]:dir:_files -/' \
          '(-r --repo)'{-r,--repo=}'[repository name]:name:' \
          '(-c --cluster)'{-c,--cluster=}'[cluster hostname]:host:' \
          '(-u --username)'{-u,--username=}'[cluster username]:user:_users' \
          '(-p --password)'{-p,--password=}'[cluster password]:password:' \
          '(-t --threads)'{-t,--threads=}'[concurrent worker threads]:n:' \
          '--no-progress-bar[disable progress indicator]' \
          '--cacert=[CA certificate]:file:_files' \
          '--no-ssl-verify[skip TLS verification]' \
          '--client-cert=[client cert (mTLS)]:file:_files' \
          '--client-key=[client key (mTLS)]:file:_files' && ret=0
        ;;
      (config)
        _arguments \
          '(-a --archive)'{-a,--archive=}'[backup archive directory]:dir:_files -/' \
          '(-r --repo)'{-r,--repo=}'[repository name]:name:' \
          '--include-buckets=[comma-separated bucket include list]:buckets:' \
          '--exclude-buckets=[comma-separated bucket exclude list]:buckets:' \
          '--disable-bucket-config[disable bucket config backup]' \
          '--disable-views[disable views backup]' \
          '--disable-gsi-indexes[disable GSI indexes backup]' \
          '--disable-ft-indexes[disable FTS indexes backup]' \
          '--disable-data[disable data backup]' \
          '--disable-analytics[disable analytics backup]' \
          '--disable-eventing[disable eventing backup]' && ret=0
        ;;
    esac
    ;;
esac

return ret
