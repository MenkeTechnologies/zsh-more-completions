#compdef retdec-cli retdec-decompiler
# _retdec-cli — Avast RetDec retargetable machine-code decompiler CLI alias (avast team, C++); custom argparse
# upstream: https://github.com/avast/retdec

_retdec-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--print-after-all[print after all]' \
        '--print-before-all[print before all]' \
        '--target-language=+[lang]:l:(c py)' \
        '-l+[lang]:l:(c py)' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--mode=+[mode]:m:(raw bin ll)' \
        '-m+[mode]:m:(raw bin ll)' \
        '--arch=+[arch]:a:(arm thumb x86 mips powerpc)' \
        '-a+[arch]:a:(arm thumb x86 mips powerpc)' \
        '--endian=+[endian]:e:(little big)' \
        '-e+[endian]:e:(little big)' \
        '--bitsize=+[bits]:n:' \
        '-b+[bits]:n:' \
        '--silent[silent]' \
        '--cleanup[cleanup]' \
        '--color-for-ida[color for IDA]' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--no-config[no config]' \
        '--stop-after=+[phase]:str:' \
        '--keep-unreachable-funcs[keep unreachable funcs]' \
        '--select-decode-only[select decode only]' \
        '--select-functions=+[functions csv]:str:' \
        '--select-ranges=+[ranges csv]:str:' \
        '--max-memory=+[bytes]:n:' \
        '--max-memory-half-ram[max memory half RAM]' \
        '--no-memory-limit[no memory limit]' \
        '--backend-disabled-opts=+[opts]:str:' \
        '--backend-call-info-obtainer=+[obtainer]:str:' \
        '--backend-var-renamer=+[renamer]:r:(address hungarian readable simple unified)' \
        '--backend-var-name-gen=+[gen]:str:' \
        '--backend-var-name-gen-prefix=+[prefix]:str:' \
        '--backend-no-debug-comments[no debug comments]' \
        '--backend-no-symbolic-names[no symbolic names]' \
        '--backend-keep-all-brackets[keep all brackets]' \
        '--backend-keep-library-funcs[keep library funcs]' \
        '--backend-no-time-varying-info[no time varying info]' \
        '--backend-no-var-renaming[no var renaming]' \
        '--backend-no-compound-operators[no compound operators]' \
        '--backend-emit-cg[emit call graph]' \
        '--backend-emit-cfg[emit cfg]' \
        '--backend-cg-conversion=+[mode]:m:(auto manual)' \
        '--backend-cfg-conversion=+[mode]:m:(auto manual)' \
        '--backend-aggressive-opts[aggressive opts]' \
        '--ar-name=+[name]:str:' \
        '--ar-index=+[index]:n:' \
        '--static-code-archive=+[archive]:str:' \
        '--static-code-sigfile=+[sigfile]:file:_files' \
        '--pdb=+[pdb file]:file:_files' \
        '--raw-section-vma=+[address]:str:' \
        '--raw-entry-point=+[address]:str:' \
        '--detect-static-code[detect static code]' \
        '--unpack=+[file]:file:_files' \
        '*:file:_files'
}

_retdec-cli "$@"
