#compdef scil_volume_resample
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_volume_resample.html
# Scilpy: resample a volume to a new resolution

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--ref --volume_size --voxel_size --iso_min)--ref=[reference volume]:ref:_files' \
  '(--ref --volume_size --voxel_size --iso_min)--volume_size=[target volume dimensions]:size' \
  '(--ref --volume_size --voxel_size --iso_min)--voxel_size=[target voxel size]:size' \
  '(--ref --volume_size --voxel_size --iso_min)--iso_min[resample to smallest isotropic voxel]' \
  '--interp=[interpolation method]:interp:(nn lin quad cubic)' \
  '--enforce_voxel_size[enforce exact voxel size]' \
  '--enforce_dimensions[enforce dimensions]' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_image:_files' \
  '2:out_image:_files' && ret=0

return ret
