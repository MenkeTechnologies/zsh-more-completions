#compdef iproxy
# _iproxy — forward TCP ports to a connected iOS device (libimobiledevice/libusbmuxd)
# upstream: https://github.com/libimobiledevice/libusbmuxd
# Flags from tools/iproxy.c.

_iproxy() {
    local -a args
    args=(
        '(-u --udid)'{-u+,--udid=}'[target the specific device by UDID]:udid:'
        '(-n --network)'{-n,--network}'[connect to a network-attached device]'
        '(-l --local)'{-l,--local}'[connect to a USB-attached device (default)]'
        '(-s --source)'{-s+,--source=}'[source address for the listening socket (default 127.0.0.1)]:address:'
        '(-d --debug)'{-d,--debug}'[increase debug level (repeatable)]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '*:local:device port spec (LOCAL_PORT:DEVICE_PORT):'
    )
    _arguments -s -S $args
}

_iproxy "$@"
