#compdef armada-eventingester eventingester
# _armada-eventingester — Armada event ingester (Pulsar → Redis pipeline that feeds the public job-event API)
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/eventingester/main.go on tip; runtime config is YAML-driven (./config/eventingester/config.yaml + --config overrides) with viper ARMADA_* env binding.

_armada-eventingester() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[YAML config file (repeat or comma-separate for multiple)]:file:_files'
}

_armada-eventingester "$@"
