#compdef goname
# Documentation: https://man.archlinux.org/search?q=goname
# Reference accessed: 2026-05-16

# EMBOSS goname: find GO ontology terms by name
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-outfile=[output file]:file:_files' \
  '-namespace=[GO namespace]:namespace:(biological_process molecular_function cellular_component)' \
  '-sensitive[also search definitions and comments]' \
  '-subclasses[include subclasses]' \
  '-obsoletes[include obsolete terms]' \
  '-outformat=[output format]:format:(obo edam excel html nametable text xml tagseq listfile)' \
  '*:GO name query:' && ret=0
return ret
