#compdef provider-kubernetes crossplane-provider-kubernetes
# _provider-kubernetes — Crossplane Kubernetes provider (manages arbitrary Kubernetes Object CRs against remote clusters)
# upstream: https://github.com/crossplane-contrib/provider-kubernetes
# Flags from cmd/provider/main.go on tip (alecthomas/kingpin/v2 + DefaultEnvars).

_provider-kubernetes() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '(-d --debug)'{-d,--debug}'[run with debug logging]' \
        '(-s --sync)'{-s,--sync}'=[controller-manager sync period (e.g. 300ms, 1.5h, 2h45m)]:duration:' \
        '--poll=[per-resource drift-check poll interval]:duration:' \
        '--poll-state-metric=[state-metric recording interval]:duration:' \
        '--poll-jitter-percentage=[jitter percentage applied to the poll interval (0-100)]:pct:' \
        '(-l --leader-election)'{-l,--leader-election}'[enable leader election (LEADER_ELECTION env var)]' \
        '--max-reconcile-rate=[max concurrent reconciliations]:n:' \
        '--sanitize-secrets=[redact Secret data from Object status (SANITIZE_SECRETS env var)]:bool:(true false)' \
        '--health-probe-bind-addr=[health/readiness probe bind address (HEALTH_PROBE_BIND_ADDRESS env var)]:addr:' \
        '--enable-management-policies=[enable Management Policies (ENABLE_MANAGEMENT_POLICIES env var)]:bool:(true false)' \
        '--enable-watches=[enable resource watches (ENABLE_WATCHES env var)]:bool:(true false)' \
        '--enable-server-side-apply=[use SSA to sync Object manifests (ENABLE_SERVER_SIDE_APPLY env var)]:bool:(true false)' \
        '--enable-changelogs=[capture change logs during reconciliation (ENABLE_CHANGE_LOGS env var)]:bool:(true false)' \
        '*--legacy-csa-field-managers=[additional legacy CSA field-manager names]:name:'
}

_provider-kubernetes "$@"
