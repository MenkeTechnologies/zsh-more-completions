#compdef bismark2bedGraph
# Documentation: https://github.com/FelixKrueger/Bismark/blob/master/bismark2bedGraph
# bismark2bedGraph: sort Bismark methylation extractor output into bedGraph/coverage files

local ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--man[show full manual]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o+,--output=}'[name of the output file]:filename:' \
  '--dir[output directory]:dir:_files -/' \
  '--cutoff[min times a methylation state must be seen to report a position]:n:' \
  '--remove_spaces[replace whitespace in sequence IDs with underscores]' \
  '(--CX --CX_context)'{--CX,--CX_context}'[generate output for all cytosines regardless of context]' \
  '--buffer_size[memory to allocate for sorting]:size:' \
  '(--scaffolds --gazillion)'{--scaffolds,--gazillion}'[handle genomes with many scaffolds by merging files]' \
  '--ample_memory[sort with arrays instead of UNIX sort]' \
  '--zero_based[write additional coverage file with 0-based start coordinates]' \
  '--ucsc[write additional bedGraph file compatible with the UCSC browser]' \
  '*:methylation extractor input:_files' && ret=0

return ret
