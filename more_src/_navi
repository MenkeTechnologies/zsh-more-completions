#compdef navi

# Zsh completion for navi - Interactive cheatsheet tool

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--path[colon-separated list of paths to look for cheatsheets]:paths:_dir_list' \
  '--fzf-overrides[fzf overrides]:overrides:' \
  '--fzf-overrides-var[fzf overrides for variable selection]:overrides:' \
  '--finder[which finder to use]:finder:(fzf skim)' \
  '--tag-rules[rules for tag filtering]:rules:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'fn:perform functions'
      'info:show cheatsheet information'
      'repo:manage cheatsheet repositories'
      'widget:print the widget for shell integration'
      'help:show help for a subcommand'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (fn)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '1:function:(url welcome homescreen widget)' \
          && ret=0
        ;;
      (info)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '1:info:(cheats-path config-path)' \
          && ret=0
        ;;
      (repo)
        _arguments -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->repo_cmd' && ret=0
        case $state in
          (repo_cmd)
            local -a repo_commands=(
              'add:add a cheatsheet repository'
              'browse:browse for cheatsheet repositories'
            )
            _describe -t commands 'repo command' repo_commands && ret=0
            ;;
        esac
        ;;
      (widget)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash fish zsh)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
