#compdef gdcmraw
# Documentation: https://gdcm.sourceforge.net
# Source: malaterre/GDCM Applications/Cxx/gdcmraw.cxx — extract DICOM Data Element value field (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input)'{-i+,--input=}'[input DICOM file]:file:_files -g "*.{dcm,DCM,dicom}"' \
    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
    '(-t --tag)'{-t+,--tag=}'[tag to extract (e.g. 7fe0,0010)]:tag:_default' \
    '(-S --split-frags)'{-S,--split-frags}'[split fragments into multiple files]' \
    '(-p --pattern)'{-p+,--pattern=}'[trailing file pattern (see --split-frags)]:pattern:_default' \
    '(-P --pixel-data)'{-P,--pixel-data}'[pixel data trailing 0]' \
    '(-V --verbose)'{-V,--verbose}'[verbose]' \
    '(-W --warning)'{-W,--warning}'[print warnings]' \
    '(-D --debug)'{-D,--debug}'[print debug info]' \
    '(-E --error)'{-E,--error}'[print errors]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version]' \
    '*:DICOM file:_files -g "*.{dcm,DCM,dicom}"' \
    && ret=0

return ret
