#compdef clipnotify
# Documentation: https://github.com/cdown/clipnotify
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-l[loop instead of exiting after first clipboard change]' \
  '-s+[X11 selection to monitor]:selection:(clipboard primary secondary)' && ret=0

return ret
