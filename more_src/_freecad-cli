#compdef freecad-cli

# freecad-cli: CLI invocation of FreeCAD (no GUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --console)'{-c,--console}'[console mode (default for cli)]' \
  '(-t --run-test)'{-t,--run-test=}'[run unit test]:test:' \
  '(-l --log-file)'{-l,--log-file=}'[log file]:file:_files' \
  '(-u --user-cfg)'{-u,--user-cfg=}'[user config]:file:_files' \
  '(-s --system-cfg)'{-s,--system-cfg=}'[system config]:file:_files' \
  '(-M --module-path)'{-M,--module-path=}'[module path]:dir:_files -/' \
  '(-P --python-path)'{-P,--python-path=}'[Python path]:dir:_files -/' \
  '(-p --pass)'{-p,--pass}'[pass args to script]' \
  '*:FreeCAD file or Python script:_files' && ret=0
return ret
