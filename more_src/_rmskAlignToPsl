#compdef rmskAlignToPsl
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: convert repeatmasker alignments to PSLs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-bigRmsk[input is text version of bigRmskAlignBed files]' \
  '-repSizes=[two column tab file of repeat name and size]:file:_files' \
  '-dump[print alignments to stdout for debugging]' \
  ':rmsk align tab:_files' \
  ':rmsk psl file:_files' && ret=0

return ret
