#compdef xmlquery
# Documentation: https://esmci.github.io/cime/versions/cesm2.2/html/Tools_user/xmlquery.html
# CIME: query variables from a case env_*.xml file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-d --debug)'{-d,--debug}'[print debug information to file]' \
  '(-v --verbose)'{-v,--verbose}'[add additional context to log messages]' \
  '(-s --silent)'{-s,--silent}'[print only warnings and error messages]' \
  {--caseroot,-caseroot}'[case directory to reference (default current directory)]:dir:_files -/' \
  {--listall,-listall}'[list all variables and their values]' \
  {--file,-file}'[the file to query]:file:_files' \
  {--subgroup,-subgroup}'[apply to this subgroup only]:subgroup' \
  '(-p --partial-match)'{-p,--partial-match}'[allow partial matches, treat args as regex]' \
  {--no-resolve,-no-resolve}'[do not resolve variable values]' \
  '--full[print a full listing for each variable]' \
  {--fileonly,-fileonly}'[only print the filename each variable is defined in]' \
  {--value,-value}'[only print one value without newline]' \
  '--raw[print the complete raw record for each variable]' \
  '--description[print the description for each variable]' \
  '--get-group[print the group for each variable]' \
  '--type[print the data type for each variable]' \
  '--valid-values[print the valid values for each variable, if defined]' \
  '*:variable name(s):' && ret=0

return ret
