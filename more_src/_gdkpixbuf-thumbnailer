#compdef gdk-pixbuf-thumbnailer gdkpixbuf-thumbnailer
# Documentation: https://man.archlinux.org/search?q=gdk-pixbuf-thumbnailer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-s+[size]:px:' \
  '*:source destination:_files' && ret=0

return ret
