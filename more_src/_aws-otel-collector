#compdef aws-otel-collector
# Documentation: https://man.archlinux.org/search?q=aws-otel-collector
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-c --config)'{-c,--config}'=[Collector config YAML]:file:_files' \
  '--set=[Config override key=value]:value:' \
  '*::args: _default'
