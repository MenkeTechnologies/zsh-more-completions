#compdef pfsclamp
# Documentation: http://pfstools.sourceforge.net/man1/pfsclamp.1.html
# pfstools: clamp luminance values in a pfs stream

local ret=1

_arguments -s -S \
  '--min=[lower bound for clamping (default 0.0001)]:val' \
  '--max=[upper bound for clamping (default 1e8)]:val' \
  '(-p --percentile)'{-p,--percentile}'[treat min and max as a percentile]' \
  '(-z --zero)'{-z,--zero}'[set out-of-range values to zero]' \
  '--rgb[perform clamping in RGB space]' \
  '--help[print list of command line options]' && ret=0

return ret
