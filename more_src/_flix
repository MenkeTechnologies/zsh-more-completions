#compdef flix

# Zsh completion for flix (functional language with algebraic effects)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build the current project'
  'build-jar:build a jar file'
  'build-pkg:build a fpkg package'
  'check:type-check the current project'
  'doc:generate documentation'
  'init:initialize a new project'
  'repl:start interactive REPL'
  'run:build and run the current project'
  'test:run project tests'
  'benchmark:run project benchmarks'
  'lsp:start the language server'
  'release:build a release package'
)

_arguments -s -S \
  '1:command:->command' \
  '--entrypoint[set program entry point]:function name' \
  '--explain[explain error codes]:error code' \
  '--threads[number of threads]:count' \
  '--json[output errors as JSON]' \
  '--no-install[do not install dependencies]' \
  '--listen[LSP port]:port' \
  '--help[show help]' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'flix command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (run|build|check|test|benchmark)
        _arguments \
          '--entrypoint[program entry point]:function name' \
          '--threads[number of threads]:count' \
          '--json[output errors as JSON]' \
          '--no-install[skip dependency installation]' \
          '*:source file:_files -g "*.flix(N)"' && ret=0
        ;;
      (build-jar)
        _arguments \
          '--entrypoint[program entry point]:function name' \
          '*:source file:_files -g "*.flix(N)"' && ret=0
        ;;
      (doc)
        _arguments \
          '(-o --output)'{-o,--output}'[output directory]:directory:_files -/' && ret=0
        ;;
      (init)
        _arguments '1:project name' && ret=0
        ;;
      (repl)
        _arguments '*:source file:_files -g "*.flix(N)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
