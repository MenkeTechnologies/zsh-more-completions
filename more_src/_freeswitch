#compdef freeswitch fs_cli

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-nc[do not connect to console]' \
  '-nf[no fork (run in foreground)]' \
  '-c[console mode]' \
  '-conf+[config dir]:dir:_files -/' \
  '-log+[log dir]:dir:_files -/' \
  '-base+[base dir]:dir:_files -/' \
  '-storage+[storage dir]:dir:_files -/' \
  '-recordings+[recordings dir]:dir:_files -/' \
  '-grammar+[grammar dir]:dir:_files -/' \
  '-fonts+[fonts dir]:dir:_files -/' \
  '-images+[images dir]:dir:_files -/' \
  '-htdocs+[htdocs dir]:dir:_files -/' \
  '-temp+[temp dir]:dir:_files -/' \
  '-db+[database dir]:dir:_files -/' \
  '-mod+[modules dir]:dir:_files -/' \
  '-scripts+[scripts dir]:dir:_files -/' \
  '-cfgname+[config filename]:file:_files' \
  '-pid+[PID file]:file:_files' \
  '-stop[stop FreeSWITCH]' \
  '-reload[reload modules]' \
  '-restart[restart FreeSWITCH]' \
  '-status[check status]' \
  '-rp[run as low priority]' \
  '-lp[run as low priority]' \
  '-np[run with normal priority]' \
  '-hp[run with high priority]' \
  '-vg[run under valgrind]' \
  '-vrg[run under valgrind in regression mode]' \
  '-rcrash[record crashes via systemd-coredump]' \
  '-core[dump core on crash]' \
  '-r+[run script and exit]:script:_files' \
  '-x+[execute command and exit]:cmd:' \
  '*::passthrough:' && ret=0

return ret
