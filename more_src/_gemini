#compdef gemini

# Zsh completion for gemini - Google Gemini CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-m --model)'{-m,--model}'[model to use]:model:(gemini-2.5-pro gemini-2.5-flash gemini-1.5-pro gemini-1.5-flash)' \
  '(-p --prompt)'{-p,--prompt}'[prompt to send]:prompt' \
  '(-i --prompt-interactive)'{-i,--prompt-interactive}'[prompt then enter interactive mode]:prompt' \
  '(-s --sandbox)'{-s,--sandbox}'[run in sandbox]' \
  '--sandbox-image[sandbox image to use]:image' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-a --all-files)'{-a,--all-files}'[include all files in context]' \
  '--show-memory-usage[show memory usage]' \
  '(-y --yolo)'{-y,--yolo}'[auto-approve all actions]' \
  '(-c --checkpointing)'{-c,--checkpointing}'[enable checkpointing]' \
  '(-t --telemetry)'{-t,--telemetry}'[enable telemetry]' \
  '--telemetry-target[telemetry target]:target:(local gcp)' \
  '--telemetry-otlp-endpoint[telemetry OTLP endpoint]:endpoint' \
  '--telemetry-log-prompts[log prompts to telemetry]' \
  '(-e --extensions)'{-e,--extensions}'[extensions to load]:extensions' \
  '--list-extensions[list available extensions]' \
  '--proxy[HTTP proxy URL]:url' && ret=0

return ret
