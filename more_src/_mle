#compdef mle
# Documentation: https://github.com/adsr/mle/blob/master/mle.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-a+[enable/disable tab to space conversion]:1|0:(0 1)' \
  '-b+[enable/disable bracket pair highlighting]:1|0:(0 1)' \
  '-c+[set color column position]:column' \
  '-e+[enable/disable mouse support]:1|0:(0 1)' \
  '-H+[enable/disable headless mode]:1|0:(0 1)' \
  '-i+[enable/disable auto indent]:1|0:(0 1)' \
  '-K+[create keymap definition]:kdef' \
  '-k+[add key binding to current keymap]:kbind' \
  '-l+[set line number type]:ltype' \
  '-M+[define a macro]:macro' \
  '-m+[set macro toggle key]:key' \
  '-N[skip reading rc file]' \
  '-n+[set initial keymap]:kmap' \
  '-p+[set startup macro]:macro' \
  '-S+[create syntax definition]:syndef' \
  '-s+[add syntax rule to current definition]:synrule' \
  '-t+[set tab size]:size' \
  '-u+[enable/disable undo/redo]:1|0:(0 1)' \
  '-w+[enable/disable soft word wrap]:1|0:(0 1)' \
  '-x+[run Lua user script]:uscript:_files' \
  '-y+[set override syntax]:syntax' \
  '-z+[enable/disable trimmed paste]:1|0:(0 1)' \
  '*:file:_files' && return 0
