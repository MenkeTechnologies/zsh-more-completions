#compdef mle
# Documentation: https://man.archlinux.org/search?q=mle
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-a+[set tab width]:width' \
  '-c+[set cursor style]:style:(block line underline)' \
  '-H+[set headroom (lines above cursor)]:lines' \
  '-i+[set tab-to-spaces mode]:mode:(0 1)' \
  '-K+[set syntax file]:syntax:_files' \
  '-k+[set key binding]:key binding' \
  '-l[show line numbers]' \
  '-M+[set mouse mode]:mode:(0 1)' \
  '-n+[set line number width]:width' \
  '-p+[set macro]:macro' \
  '-S[disable syntax highlighting]' \
  '-t+[set tab width]:width' \
  '-w[set soft wrap]' \
  '-y+[set syntax]:syntax' \
  '*:file:_files' && return 0
