#compdef gitingest

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--max-file-size=[Skip files larger than this size]:size:' \
  '--include-patterns=[Glob patterns to force include]:patterns:' \
  '--exclude-patterns=[Glob patterns to skip]:patterns:' \
  '--branch=[Git branch to ingest]:branch:' \
  '1:repository URL or path:_default' \
  '*::arguments: _default'
