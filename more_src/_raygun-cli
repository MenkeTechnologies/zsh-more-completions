#compdef raygun-cli raygun
# _raygun-cli — Raygun raygun-cli CLI command-line frontend wrapping the Raygun application performance monitoring real user monitoring crash reporting error tracking platform CLI providing login deploy notify symbols-upload source-map mapping-file ProGuard-mapping debug-information-files dSYM Android-NDK Apple-iOS-tvOS-watchOS-macOS Unity Unreal Windows-PDB application application-version (Raygun team, Go); cobra
# upstream: https://raygun.com/

_raygun-cli() {
    local -a sub=(
        'login:authenticate'
        'whoami:show identity'
        'deploy:report a deployment'
        'notify:notify a release'
        'application:application operations'
        'symbols-upload:upload debug symbols'
        'source-map:source map operations'
        'proguard-mapping:ProGuard mapping operations'
        'dsym:dSYM operations'
        'pdb:PDB upload'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--external-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--application-name=+[name]:str:' \
        '-a+[app]:str:' \
        '--application-id=+[id]:str:' \
        '--version=+[v]:str:' \
        '-V+[version]:str:' \
        '--owner-name=+[name]:str:' \
        '--scm-identifier=+[id]:str:' \
        '--scm-type=+[t]:t:(GitHub GitLab Bitbucket Azure CodeCommit)' \
        '--release-notes=+[text]:str:' \
        '--release-notes-file=+[file]:file:_files' \
        '--emails-to-notify=+[emails]:str:' \
        '--notify-using-emails=+[v]:v:(true false)' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'raygun subcommand' sub ;;
        args)
            case $words[1] in
                symbols-upload|source-map|proguard-mapping|dsym|pdb) _arguments '*:file:_files' ;;
                application) _arguments '1:op:(list get create)' '*:name:' ;;
            esac
            ;;
    esac
}

_raygun-cli "$@"
