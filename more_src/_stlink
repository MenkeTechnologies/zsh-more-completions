#compdef stlink stlink-tools
# _stlink — Texane stlink-tools CLI helper for the open-source library and command-line utilities for ST-Link V2 V3 V2-1 supporting STM32 flash erase write verify read traffic SWD JTAG access via libusb (stlink-org team, C); getopt
# upstream: https://github.com/stlink-org/stlink

_stlink() {
    local -a sub=(
        'flash:read/write/erase flash'
        'info:display STM32 chip info'
        'trace:capture SWO trace'
        'util:run GDB server'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--serial=+[serial]:str:' \
        '--connect-under-reset[connect under reset]' \
        '--debug[debug]' \
        '--reset[reset target]' \
        '--hot-plug[hot plug]' \
        '--freq=+[Hz]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'stlink subcommand' sub ;;
        args)
            case $words[1] in
                flash) _arguments \
                    '1:action:(read write erase)' \
                    '--format=+[fmt]:f:(binary ihex)' \
                    '--reset[reset]' \
                    '--connect-under-reset[connect under reset]' \
                    '*:file address size:_files' ;;
                util) _arguments \
                    '--port=+[port]:n:' \
                    '-p+[port]:n:' \
                    '--persist[persistent]' \
                    '--no-reset[no reset]' \
                    '--multi[multi]' \
                    '--semihosting[semihosting]' ;;
                trace) _arguments \
                    '--cpu-freq=+[Hz]:n:' \
                    '--trace-freq=+[Hz]:n:' \
                    '--save=+[file]:file:_files -g "*.bin *.log"' ;;
            esac
            ;;
    esac
}

_stlink "$@"
