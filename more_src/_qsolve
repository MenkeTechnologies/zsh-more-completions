#compdef qsolve
# Documentation: https://4ti2.github.io/qsolve.html
# 4ti2: compute the generating set of a cone (rational solutions)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display this help and exit]' \
  '(-p --precision)'{-p,--precision=}'[integer arithmetic precision]:precision:(64 32 arbitrary)' \
  '(-m --mat -s --support)'{-m,--mat}'[use the Matrix algorithm]' \
  '(-s --support -m --mat)'{-s,--support}'[use the Support algorithm]' \
  '(-o --order)'{-o,--order=}'[column choice ordering]:ordering:(maxinter minindex maxcutoff mincutoff)' \
  '(-f --output-freq)'{-f,--output-freq=}'[frequency of output]:n:' \
  '(-q --quiet)'{-q,--quiet}'[do not output anything to the screen]' \
  '*:project:_files' && ret=0

return ret
