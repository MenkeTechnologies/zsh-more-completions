#compdef pfsview
# Documentation: http://pfstools.sourceforge.net/man1/pfsview.1.html
# pfstools: Qt viewer for high dynamic range pfs frames

local ret=1

_arguments -s -S \
  '--window_min=[lower bound to display, log_10 units]:log_lum' \
  '--window_max=[upper bound to display, log_10 units]:log_lum' && ret=0

return ret
