#compdef complexity
# GNU tool for measuring C source code complexity

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-t --threshold)'{-t,--threshold}'[minimum complexity to report]:threshold:' \
  '(-c --horrid-threshold)'{-c,--horrid-threshold}'[complexity threshold for horrid]:threshold:' \
  '(-n --nesting)'{-n,--nesting}'[nesting penalty weight]:weight:' \
  '(-s --scores)'{-s,--scores}'[show all scores]' \
  '(-u --unifdef)'{-u,--unifdef}'[pass through unifdef first]:opts:' \
  '--histogram[display score histogram]' \
  '--no-header[suppress header output]' \
  '*:source file:_files -g "*.c"' \
  && return 0
