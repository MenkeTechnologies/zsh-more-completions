#compdef storage_controller
# _storage_controller — Neon storage controller (tenant + shard placement orchestrator that drives pageservers and safekeepers via JWT-auth HTTP API)
# upstream: https://github.com/neondatabase/neon
# Flags from storage_controller/src/main.rs on tip (clap-derive); at least one of --listen / --listen-https is required.

_storage_controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '(-l --listen)'{-l+,--listen=}'[HTTP listen address (host:port)]:hostport:' \
        '--listen-https=[HTTPS listen address (host:port)]:hostport:' \
        '--public-key=[JWT public key for client auth]:pem:' \
        '--jwt-token=[token to authenticate to pageservers]:token:' \
        '--safekeeper-jwt-token=[token to authenticate to safekeepers]:token:' \
        '--control-plane-jwt-token=[token for the control-plane compute-notification endpoint]:token:' \
        '--peer-jwt-token=[token to authenticate to peer storcons]:token:' \
        '--control-plane-url=[control-plane storage API base URL]:url:_urls' \
        '--database-url=[Postgres URL (postgresql://...)]:url:_urls' \
        '--dev[allow running without auth]' \
        '--max-offline-interval=[grace period before marking pageserver offline]:dur:' \
        '--max-warming-up-interval=[grace period around pageserver restart]:dur:' \
        '--split-threshold=[size threshold for autosplit shards]:bytes:' \
        '--max-split-shards=[max shards during autosplit (0=off)]:n:' \
        '--initial-split-threshold=[size threshold for initial shard split]:bytes:' \
        '--initial-split-shards=[target shards for initial split]:n:' \
        '--reconciler-concurrency=[max normal-priority reconcilers]:n:' \
        '--priority-reconciler-concurrency=[max high-priority reconcilers]:n:' \
        '--safekeeper-reconciler-concurrency=[max safekeeper reconcilers per node]:n:' \
        '--tenant-rate-limit=[tenant API requests/sec]:n:' \
        '--db-connect-timeout=[initial DB connect timeout]:dur:' \
        '--start-as-candidate[start as leader-election candidate]' \
        '--address-for-peers=[address peers should reach this controller on]:url:_urls' \
        '--chaos-interval=[chaos: migrate tenants every interval]:dur:' \
        '--chaos-exit-crontab=[chaos: exit on this cron schedule]:cron:' \
        '--max-secondary-lag-bytes=[max lag on secondary during drain]:bytes:' \
        '--heartbeat-interval=[heartbeat send interval]:dur:' \
        '--long-reconcile-threshold=[long-reconcile alert threshold]:dur:'
}

_storage_controller "$@"
