#compdef unbuild
# Documentation: https://github.com/unjs/unbuild
# Reference accessed: 2026-05-21
# Verified: upstream src/cli.ts at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--config=[config file relative to cwd]:file:_files' \
  '--watch[watch src dir and rebuild on change (experimental)]' \
  '--stub[stub package for JIT compilation]' \
  '--minify[minify build]' \
  '--sourcemap[generate sourcemaps (experimental)]' \
  '--parallel[run different build types simultaneously]' \
  '1:dir:_files -/' \
  '*:dir:_files -/' && ret=0

return ret
