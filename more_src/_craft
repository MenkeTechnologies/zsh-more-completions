#
# THE craft CLI — yargs + prompts + simple-git + multi-target publishing
#
# craft's CLI is in src/index.ts.  Uses yargs with 6 subcommands.
#
# Global flags (apply to all subcommands):
#   --no-input               suppress all user prompts (default
#                            true in CI; sets prompts to use
#                            initial values)
#   --dry-run                no file writes, commits, pushes, or
#                            API mutations
#   --log-level LEVEL        Debug | Info | Warn | Error
#                            (default Info)
#   -v, --version            show version
#   -h, --help               show help
#
# All flags also configurable via CRAFT_* environment variables
# (e.g., CRAFT_DRY_RUN=1, CRAFT_LOG_LEVEL=Debug, CRAFT_NO_INPUT=1).
#
# Subcommands (6):
#   prepare [NEW-VERSION]    bump version + update changelog +
#                            create release branch + push
#     Options:
#       --rev REV              git revision to base release on
#       --no-push              do not push to remote
#       --no-git-checks        skip git working-tree checks
#       --no-changelog         skip changelog update
#       --publish              also publish after prepare
#       --remote NAME          git remote name (default origin)
#       --config-from PATH     load .craft.yml from PATH
#       --calver-offset N      CalVer offset value
#   publish NEW-VERSION      build + publish artifacts to all
#                            configured targets
#     Options:
#       --target NAME          publish only to specific target(s)
#                              (repeatable)
#       --rev REV              git revision to publish
#       --merge-target NAME    branch to merge release into
#       --remote NAME          git remote (default origin)
#       --no-merge             skip merge step
#       --keep-branch          keep release branch after merge
#       --keep-downloads       keep downloaded artifacts
#       --no-status-check      skip release status check
#       --no-git-checks        skip git working-tree checks
#   targets                  list configured release targets
#                            (from .craft.yml)
#   config                   show resolved craft config
#   artifacts <subcommand>   manage release-artifact store
#     Subcommands: list, get, remove
#   changelog                generate / validate CHANGELOG.md
#
# prompts is used in src/commands/prepare.ts (and others) for
# interactive version-bump-type selection when NEW-VERSION not
# provided; respects --no-input for CI mode.
#
# Five-axis distinctness from dialoguer (R661) + go-prompt (R662):
#
#   1. SINGLE-FUNCTION API — prompts([{...}, {...}, ...]) vs
#      dialoguer's per-prompt struct vs go-prompt's REPL framework.
#
#   2. 11 PROMPT TYPES — text/password/invisible/number/
#      confirm/list/toggle/select/multiselect/autocomplete/
#      autocompleteMultiselect/date.
#
#   3. ZERO RUNTIME DEPENDENCIES — minimalist bundle size.
#
#   4. CONDITIONAL PROMPTS — `type: prev => ... | null`
#      dynamic prompt skipping based on previous answers.
#
#   5. TERKEL-GJERVIG / SOLO-MAINTAINED PROVENANCE —
#      distinct from Inquirer.js (SBoudrias / Mojo Lingo
#      community), Enquirer (Jon Schlinkert / breakdance),
#      Armin Ronacher (console-rs / dialoguer), Masashi
#      Shibata (c-bata / go-prompt).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/getsentry/craft/blob/master/src/index.ts
# https://github.com/getsentry/craft/blob/master/src/commands/prepare.ts
# https://github.com/getsentry/craft/blob/master/src/commands/publish.ts
# yargs .command() + .option() definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _craft_cmds _craft_log_levels _craft_artifacts
_craft_cmds=(
    'prepare:bump version + changelog + create release branch'
    'publish:build + publish artifacts to all configured targets'
    'targets:list configured release targets'
    'config:show resolved craft config'
    'artifacts:manage release-artifact store'
    'changelog:generate / validate CHANGELOG.md'
    'help:show help for a subcommand'
)
_craft_log_levels=(
    'Debug:debug-level logging'
    'Info:info-level logging (default)'
    'Warn:warn-level logging'
    'Error:error-level logging'
)
_craft_artifacts=('list:list stored artifacts' 'get:get an artifact' 'remove:remove an artifact')

local global_flags
global_flags=(
    '--no-input[suppress all user prompts (default true in CI)]'
    '--dry-run[dry-run mode: no file writes, commits, pushes, or API mutations]'
    '--log-level=[logging level]:level:->log_level'
    '(- *)'{-h,--help}'[show help]'
    '(- *)'{-v,--version}'[show version]'
)

_arguments -C \
    $global_flags \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    log_level)
        _describe -t levels 'log level' _craft_log_levels && ret=0
        ;;
    cmd)
        _describe -t commands 'craft subcommand' _craft_cmds && ret=0
        ;;
    args)
        case $words[1] in
            prepare)
                _arguments \
                    '--rev=[git revision to base release on]:revision:_default' \
                    '--no-push[do not push to remote]' \
                    '--no-git-checks[skip git working-tree checks]' \
                    '--no-changelog[skip changelog update]' \
                    '--publish[also publish after prepare]' \
                    '--remote=[git remote name]:remote:_default' \
                    '--config-from=[load .craft.yml from path]:path:_files' \
                    '--calver-offset=[CalVer offset value]:offset:_default' \
                    '1:NEW-VERSION:_default' \
                    && ret=0
                ;;
            publish)
                _arguments \
                    '*--target=[publish only to specific target(s)]:target:_default' \
                    '--rev=[git revision to publish]:revision:_default' \
                    '--merge-target=[branch to merge release into]:branch:_default' \
                    '--remote=[git remote]:remote:_default' \
                    '--no-merge[skip merge step]' \
                    '--keep-branch[keep release branch after merge]' \
                    '--keep-downloads[keep downloaded artifacts]' \
                    '--no-status-check[skip release status check]' \
                    '--no-git-checks[skip git working-tree checks]' \
                    '1:NEW-VERSION:_default' \
                    && ret=0
                ;;
            artifacts)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'artifacts subcommand' _craft_artifacts && ret=0
                fi
                ;;
            help)
                _describe -t commands 'subcommand' _craft_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
