#compdef impacket-machine_role

# Impacket machine_role.py: query a target host'\''s machine role over RPC
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-target-ip[target IP]:ip:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos auth]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '*:user[:password]@host:' && ret=0
return ret
