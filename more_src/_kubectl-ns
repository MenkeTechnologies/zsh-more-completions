#compdef kubectl-ns
# Documentation: https://github.com/ahmetb/kubectx
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl ns (kubens from kubectx). Usage: kubens [-f] [<namespace>|-]
# `-` switches to previous namespace; `-f` allows non-existent namespace.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-f[allow setting non-existent namespace]' \
  '*:namespace name:_default'
