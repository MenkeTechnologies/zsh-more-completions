#compdef sumpha
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/sumpha.html
# Sum multiple PHA spectral files into a single combined spectrum

local ret=1

_arguments -s -S \
  'filelist=[PHA files to add, or @filename list]:filelist:_files' \
  'outfile=[output combined spectrum file]:outfile:_files' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:file:_files' && ret=0

return ret
