#compdef dos gmx-dos
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-dos.html
# gmx dos: analyze density of states and properties based on that

local ret=1

_arguments -s \
  '-f[full precision trajectory file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-n[index file]:file:_files' \
  '-vacf[velocity autocorrelation function output]:file:_files' \
  '-mvacf[mass-weighted velocity autocorrelation output]:file:_files' \
  '-dos[density of states output]:file:_files' \
  '-g[log file output]:file:_files' \
  '-b[starting frame time]:time:' \
  '-e[ending frame time]:time:' \
  '-dt[frame sampling interval]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-v[verbose output mode]' \
  '-recip[use cm-1 on x-axis instead of 1/ps]' \
  '-abs[use absolute Fourier transform value]' \
  '-normdos[normalize DoS to sum to 3N]' \
  '-T[simulation temperature]:real:' \
  '-acflen[ACF length]:int:' \
  '-normalize[normalize ACF]' \
  '-P[order of Legendre polynomial]:order:(0 1 2 3)' \
  '-fitfn[fit function type]:fn:(none exp aexp exp_exp exp5 exp7 exp9)' \
  '-beginfit[exponential fit start time]:real:' \
  '-endfit[exponential fit end time]:real:' && ret=0

return ret
