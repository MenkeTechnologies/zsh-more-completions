#compdef questdb-cli questdb2
# _questdb-cli — QuestDB questdb-cli CLI command-line frontend wrapping the QuestDB open-source time-series database providing start stop status install uninstall console http-interface postgres-wire-protocol ILP-influx-line-protocol REST telemetry hot-backup snapshot restore TLS auth-jwk-jwt copy-from-csv-parquet retention-policy partition-detach (QuestDB team, Java/C); custom argparse
# upstream: https://questdb.io/

_questdb-cli() {
    local -a sub=(
        'start:start QuestDB server'
        'stop:stop QuestDB server'
        'status:check server status'
        'install:install service'
        'uninstall:uninstall service'
        'restart:restart server'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[root directory]:dir:_files -/' \
        '-f[force overwrite]' \
        '-n[disable monitoring]' \
        '-t+[tag]:str:' \
        '-conf+[file]:file:_files -g "server.conf log.conf"' \
        '--http.bind.to=+[host:port]:_hosts' \
        '--pg.net.bind.to=+[host:port]:_hosts' \
        '--line.tcp.net.bind.to=+[host:port]:_hosts' \
        '--line.udp.bind.to=+[host:port]:_hosts' \
        '--shared.worker.count=+[N]:n:' \
        '--telemetry.enabled[telemetry]' \
        '--cairo.commit.lag=+[ms]:n:' \
        '--cairo.commit.mode=+[m]:m:(nosync sync async)' \
        '--cairo.max.uncommitted.rows=+[N]:n:' \
        '--cairo.sql.copy.formats.file=+[file]:file:_files' \
        '--cairo.sql.parquet.partition.scan.enabled[parquet scan]' \
        '--http.security.readonly[read only]' \
        '--http.user=+[user]:_users' \
        '--http.password=+[password]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'questdb subcommand' sub ;;
        args) _arguments '*:arg:' ;;
    esac
}

_questdb-cli "$@"
