#compdef turbiniactl turbinia-client
# Documentation: https://turbinia.readthedocs.io/en/latest/user/turbinia-client.html
# Turbinia DFIR processing client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config_instance)'{-c,--config_instance}'=[Turbinia instance config name]:instance' \
  '(-p --config_path)'{-p,--config_path}'=[path to .turbinia_api_config.json]:file:_files' \
  '-j[return JSON responses]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'turbinia command' \
      'config[get Turbinia configuration]' \
      'evidence[get or upload evidence]' \
      'jobs[list enabled jobs]' \
      'result[get request or task results]' \
      'status[get request or task status]' \
      'submit[submit new requests]' && ret=0
    ;;
esac

return ret
