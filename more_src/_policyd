#compdef policyd
# Documentation: (no current upstream)
# Reference accessed: 2026-05-16
# Verified: policyd (v1, "policy-weight") is dead upstream. The v2 successor
# was renamed to "cluebringer" (binary: cbpolicyd) and ships its own
# completion. Debian dropped the `policyd` binary after buster. No reliable
# upstream manpage exists. Conservative stub retained per "do not delete
# files" directive.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# policyd: legacy Postfix policy daemon (dead upstream; see cbpolicyd)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:arg:_files' && ret=0
return ret
