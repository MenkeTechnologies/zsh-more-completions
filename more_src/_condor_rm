#compdef condor_rm
# Documentation: https://man.archlinux.org/search?q=condor_rm
# Reference accessed: 2026-05-16

# condor_rm: remove Condor jobs
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-name[schedd]:name:' \
  '-pool[pool]:pool:' \
  '-addr[address]:sinful:' \
  '-forcex[forcefully remove X (no peaceful)]' \
  '-fast[fast remove]' \
  '-reason[reason text]:reason:' \
  '-all[remove all jobs of user]' \
  '-constraint[constraint expression]:expr:' \
  '*:jobid:' && ret=0
return ret
