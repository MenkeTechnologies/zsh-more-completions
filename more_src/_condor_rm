#compdef condor_rm
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_rm.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_rm: remove HTCondor jobs from the queue.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-long[display result ClassAd]' \
  '-totals[display success/failure totals]' \
  '-debug[debug]' \
  '-name[schedd name]:name:' \
  '-pool[pool]:pool:' \
  '-addr[address (sinful)]:sinful:' \
  '-forcex[force immediate local removal of jobs in X state]' \
  '-transfer[request output file transfer before removal]' \
  '-reason[reason text]:reason:' \
  '-all[remove all jobs of user]' \
  '-constraint[constraint expression]:expr:' \
  '*:jobid:' && ret=0
return ret
