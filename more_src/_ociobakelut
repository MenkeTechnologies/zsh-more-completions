#compdef ociobakelut
# Documentation: https://opencolorio.readthedocs.io/
# bake a new LUT or ICC profile from an OCIO config or LUT file(s)

local ret=1

_arguments -s -S \
  '--help[display summary of available options]' \
  '--v[verbose output]' \
  '--inputspace=[input OCIO ColorSpace (or Role)]:colorspace:' \
  '--outputspace=[output OCIO ColorSpace (or Role)]:colorspace:' \
  '--shaperspace=[the OCIO ColorSpace or Role, for the shaper]:colorspace:' \
  '--looks=[the OCIO looks to apply]:looks:' \
  '--iconfig=[input .ocio configuration file (default: $OCIO)]:config:_files -g "*.ocio"' \
  '--lut=[specify a LUT (forward direction)]:lut:_files' \
  '--invlut=[specify a LUT (inverse direction)]:lut:_files' \
  '--slope[slope (float x y z)]:x: :y: :z:' \
  '--offset[offset (float x y z)]:x: :y: :z:' \
  '--offset10[offset (10-bit x y z)]:x: :y: :z:' \
  '--power[power (float x y z)]:x: :y: :z:' \
  '--sat=[saturation (ASC-CDL luma coefficients)]:saturation:' \
  '--format=[output LUT format]:format:(houdini flame lustre iridas_itx iridas_cube iridas_btx spi1d spi3d spimtx cinespace truelight icc)' \
  '--shapersize=[size of the shaper (default: format specific)]:size:' \
  '--cubesize=[size of the cube (default: format specific)]:size:' \
  '--stdout[write to stdout (rather than file)]' \
  '--whitepoint=[whitepoint for the profile (default: 6505)]:whitepoint:' \
  '--displayicc=[an icc profile which matches the OCIO profiles target display]:profile:_files' \
  '--description=[meaningful description displayed in applications]:description:' \
  '--copyright=[copyright field information]:copyright:' \
  '*:output file:_files' && ret=0

return ret
