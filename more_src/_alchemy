#compdef alchemy
# Documentation: https://alchemy.run/concepts/cli/
# alchemy - TypeScript-native Infrastructure-as-Code CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--app=[application name]:app' \
  '--stage=[deployment stage]:stage' \
  '(-p --profile)'{-p,--profile}'=[credential profile]:profile' \
  '--env-file=[environment file]:file:_files' \
  '--cwd=[working directory]:dir:_files -/' \
  '--quiet[suppress output]' \
  '--watch[watch for changes]' \
  '--force[force operation]' \
  '--adopt[adopt existing resources]' \
  '--erase-secrets[erase secrets]' \
  '--template=[project template]:template' \
  '--framework=[framework]:framework' \
  '--yes[skip prompts]' \
  '--overwrite[overwrite existing files]' \
  '--install[install dependencies]' \
  '--pm=[package manager]:pm:(npm pnpm yarn bun)' \
  '--vibe-rules[add vibe rules]' \
  '--god-token[create god-mode token]' \
  '1:command:(deploy destroy dev run create init configure login logout util)' \
  '*::arg:_files' && ret=0

return ret
