#compdef jaeger-esmapping-generator
# _jaeger-esmapping-generator — print Jaeger Elasticsearch index templates (jaegertracing/jaeger)
# upstream: https://github.com/jaegertracing/jaeger
# Flags from internal/storage/v1/elasticsearch/mappings/flags.go on tip.

_jaeger-esmapping-generator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--mapping=[index template to render (required)]:mapping:(jaeger-span jaeger-service jaeger-dependencies jaeger-sampling)' \
        '--es-version=[major Elasticsearch version]:n:(6 7 8)' \
        '--shards=[shards per index]:n:' \
        '--replicas=[replicas per index]:n:' \
        '--index-prefix=[index name prefix]:prefix:' \
        '--use-ilm=[use ILM to manage index lifecycle]:bool:(true false)' \
        '--ilm-policy-name=[ILM policy name when --use-ilm=true]:name:'
}

_jaeger-esmapping-generator "$@"
