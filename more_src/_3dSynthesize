#compdef 3dSynthesize
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dSynthesize.html
# AFNI: synthesize an output dataset from 3dDeconvolve coefficients

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-cbucket[coefficient bucket dataset]:dataset:_files' \
  '-matrix[matrix file from 3dDeconvolve]:matrix:_files' \
  '-select[selection criteria for matrix columns]:select:' \
  '-dry[dry run; print info and stop]' \
  '-TR[set TR for output dataset]:tr:' \
  '-prefix[output dataset prefix]:prefix:_files' \
  '-cenfill[fill method for censored points (zero/nbhr/none)]:method:(zero nbhr none)' \
  '*:dataset:_files' && ret=0

return ret
