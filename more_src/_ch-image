#compdef ch-image

# ch-image: Charliecloud image management
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'build:build an image from a Dockerfile'
  'build-cache:manage build cache'
  'delete:delete an image'
  'gestalt:diagnostic info'
  'import:import an image directory'
  'list:list local images'
  'pull:pull an image from a registry'
  'push:push an image to a registry'
  'reset:reset image storage'
  'undelete:undelete a deleted image'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-v[verbose (repeatable)]' \
  '--verbose[verbose (repeatable)]' \
  '--auth[require auth on registry actions]' \
  '--cache=[cache mode]:mode:(disabled enabled rebuild)' \
  '--debug[debug logging]' \
  '--bucache=[build cache mode]:mode:(disabled enabled rebuild)' \
  '--storage=[storage directory]:dir:_files -/' \
  '--rootless=[rootless mode]:bool:(auto force never)' \
  '--no-cache[disable build cache]' \
  '--no-lock[disable locking]' \
  '--password-many[ask for password each time]' \
  '--tls-no-verify[no TLS verification]' \
  '--always-download[always download images]' \
  '--arch=[target architecture]:arch:(amd64 arm64 ppc64le s390x host yolo)' \
  '--profile[enable profiling]' \
  '--quiet[quiet]' \
  '--no-xattrs[skip xattrs]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ch-image command' commands && ret=0 ;;
esac
return ret
