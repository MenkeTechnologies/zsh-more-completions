#compdef pt-config-diff

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--charset=[connection charset]:charset:' \
  '--config=[config file]:file:_files' \
  '--databases=[only these databases]:dbs:' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--host=[MySQL host]:host:_hosts' \
  '--ignore-variables=[ignore these vars]:list:' \
  '--password=[MySQL password]:pw:' \
  '--port=[MySQL port]:port:' \
  '--report[print report]' \
  '--report-width=[report width]:cols:' \
  '--socket=[MySQL socket]:file:_files' \
  '--ssl-ca=[SSL CA]:file:_files' \
  '--ssl-cert=[SSL cert]:file:_files' \
  '--ssl-key=[SSL key]:file:_files' \
  '--user=[MySQL user]:user:' \
  '*:DSN_or_config:' && ret=0

return ret
