#compdef cellranger-arc
# Documentation: https://www.10xgenomics.com/support/software/cell-ranger-arc/2.0/analysis/command-line-arguments
# cellranger-arc - Single Cell Multiome ATAC + Gene Expression analysis

local ret=1
local -a subcmds

subcmds=(
  'count:count ATAC and gene expression reads from a single library'
  'mkfastq:run bcl2fastq on Multiome ATAC + GEX data'
  'mkref:create a cellranger-arc-compatible reference'
  'aggr:aggregate multiple count runs'
  'reanalyze:re-run secondary analysis on a completed run'
  'mkgtf:filter a GTF file for compatibility'
  'testrun:run a tiny pipeline to verify install'
  'upload:upload analysis logs to 10x support'
  'sitecheck:collect system configuration'
)

local -a common
common=(
  '--id=[unique run id and output folder name]:id:'
  '--description=[sample description for output]:text:'
  '--jobmode=[job manager]:mode:(local sge lsf slurm)'
  '--localcores=[max cores for local jobs]:n:'
  '--localmem=[max GB memory for local jobs]:gb:'
  '--localvmem=[max virtual address space GB]:gb:'
  '--mempercore=[memory per core for cluster jobs]:gb:'
  '--maxjobs=[max concurrent cluster submissions]:n:'
  '--jobinterval=[delay between submissions ms]:ms:'
  '--overrides=[JSON file for resource customization]:file:_files'
  '--uiport=[serve web UI at port]:port:'
  '--disable-ui[disable web interface]'
  '--noexit[keep UI running after completion]'
  '--nopreflight[skip preflight checks]'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- :)--version[print version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'cellranger-arc command' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      count)
        _arguments -s -S $common \
          '--reference=[path to reference folder]:dir:_files -/' \
          '--libraries=[3-column CSV of ATAC/GEX FASTQ paths]:csv:_files' \
          '--min-atac-count=[minimum ATAC transposition events]:n:' \
          '--min-gex-count=[minimum GEX UMI counts]:n:' \
          '--peaks=[custom peaks BED file]:bed:_files' \
          '--gex-exclude-introns[count only exonic reads]' \
          '--no-bam[skip BAM file generation]' \
          '--dry[generate invocation without running]' && ret=0
        ;;
      mkfastq)
        _arguments -s -S $common \
          '--run=[Illumina BCL run folder]:dir:_files -/' \
          '--csv=[sample sheet CSV]:csv:_files' \
          '--samplesheet=[sample sheet]:csv:_files' \
          '--force-single-index[use i7 index when dual specified]' \
          '--filter-single-index[demultiplex only single-indexed]' \
          '--filter-dual-index[demultiplex only dual-indexed]' \
          '--rc-i2-override=[reverse complement I2 reads]:bool:(true false)' \
          '--lanes=[comma-delimited lane numbers]:lanes:' \
          '--use-bases-mask=[override read lengths]:mask:' \
          '--delete-undetermined[remove unmatched FASTQs]' \
          '--output-dir=[custom output location]:dir:_files -/' \
          '--project=[custom project name]:name:' && ret=0
        ;;
      mkref)
        _arguments -s -S \
          '--config=[configuration file]:file:_files' \
          '--nthreads=[threads for STAR indexing]:n:' \
          '--memgb=[max memory GB]:gb:' \
          '--ref-version=[version string]:str:' && ret=0
        ;;
      aggr)
        _arguments -s -S $common \
          '--reference=[path to reference folder]:dir:_files -/' \
          '--csv=[enumeration of count outputs]:csv:_files' \
          '--peaks=[custom peaks BED file]:bed:_files' \
          '--normalize=[depth normalization mode]:mode:(none depth)' \
          '--nosecondary[skip secondary analysis]' && ret=0
        ;;
      reanalyze)
        _arguments -s -S $common \
          '--reference=[path to reference folder]:dir:_files -/' \
          '--matrix=[feature barcode matrix H5]:h5:_files' \
          '--atac-fragments=[ATAC fragments TSV.GZ]:file:_files' \
          '--params=[analysis parameters CSV]:csv:_files' \
          '--barcodes=[subset barcodes CSV]:csv:_files' \
          '--agg=[aggregation CSV]:csv:_files' && ret=0
        ;;
      mkgtf)
        _arguments -s -S \
          '--attribute=[attribute key:value to retain]:attr:' \
          '*:gtf file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
