#compdef sqlpackage SqlPackage
# Documentation: https://learn.microsoft.com/en-us/sql/tools/sqlpackage/sqlpackage-cli-reference
# SqlPackage - DacFx command-line tool for SQL database publish/extract/export/import

local ret=1

_arguments -s \
  '/Action\:[action to perform]:action:(Extract Publish Export Import DeployReport DriftReport Script)' \
  '/AccessToken\:[Microsoft Entra access token]:token' \
  '/at\:[Microsoft Entra access token]:token' \
  '/ClientId\:[client id for Entra auth]:client id' \
  '/Diagnostics\:[enable diagnostic logging]:bool:(True False)' \
  '/DiagnosticsFile\:[diagnostics log file]:file:_files' \
  '/MaxParallelism\:[degree of parallelism for operations]:n' \
  '/OverwriteFiles\:[overwrite existing files]:bool:(True False)' \
  '/Profile\:[publish profile path]:profile:_files' \
  '*/Properties\:[set a deployment property]:property' \
  '*/p\:[set a deployment property]:property' \
  '/Quiet\:[suppress detailed feedback]:bool:(True False)' \
  '/Secret\:[client secret for Entra auth]:secret' \
  '/SourceConnectionString\:[source connection string]:conn' \
  '/SourceDatabaseName\:[source database name]:database' \
  '/SourceEncryptConnection\:[encrypt source connection]:bool:(True False)' \
  '/SourceFile\:[source dacpac/bacpac file]:file:_files' \
  '/SourcePassword\:[source password]:password' \
  '/SourceServerName\:[source server name]:server' \
  '/SourceTimeout\:[source connection timeout]:seconds' \
  '/SourceTrustServerCertificate\:[trust source server cert]:bool:(True False)' \
  '/SourceUser\:[source user]:user' \
  '/TargetConnectionString\:[target connection string]:conn' \
  '/TargetDatabaseName\:[target database name]:database' \
  '/TargetEncryptConnection\:[encrypt target connection]:bool:(True False)' \
  '/TargetFile\:[target dacpac/bacpac file]:file:_files' \
  '/TargetPassword\:[target password]:password' \
  '/TargetServerName\:[target server name]:server' \
  '/TargetTimeout\:[target connection timeout]:seconds' \
  '/TargetTrustServerCertificate\:[trust target server cert]:bool:(True False)' \
  '/TargetUser\:[target user]:user' \
  '/TenantId\:[Entra tenant id]:tenant' \
  '/UniversalAuthentication\:[use universal (MFA) authentication]:bool:(True False)' \
  '*/Variables\:[set a SQLCMD variable]:variable' \
  '/Version[display version]' && ret=0

return ret
