#compdef pgmigrate
# Documentation: https://github.com/peterldowns/pgmigrate/blob/main/README.md
# pgmigrate modern Postgres migrations CLI

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --database)'{-d,--database}'=[database connection string]:connstring' \
  '(-m --migrations)'{-m,--migrations}'=[path to migrations directory]:dir:_files -/' \
  '--table-name=[table name for storing migration records]:table' \
  '--configfile=[path to configuration file]:file:_files' \
  '--log-format=[output format]:format:(text json)' \
  '1:command:(applied migrate plan verify ops version config dump new help)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      ops)
        _arguments -s \
          '--mark-applied[mark migrations as applied]' \
          '--mark-unapplied[mark migrations as unapplied]' \
          '--all[apply operation to all migrations]' && ret=0
        ;;
      dump)
        _arguments -s \
          '--out=[output file path for the dump]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
