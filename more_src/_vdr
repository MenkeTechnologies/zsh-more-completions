#compdef vdr
# Documentation: https://manpages.debian.org/bookworm/vdr/vdr.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm vdr(1) manpage.
# Removed from prior file: bogus man.archlinux.org search URL.

# vdr: Video Disk Recorder (DVB television recorder)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --audio)'{-a+,--audio=}'[audio output command]:cmd:' \
  '--cachedir=[cache directory]:dir:_files -/' \
  '--chartab=[character translation table]:table:' \
  '(-c --config)'{-c+,--config=}'[config directory]:dir:_files -/' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '(-D --device)'{-D+,--device=}'[device number]:num:' \
  '--dirnames=[recording path layout]:path:' \
  '--edit=[edit a recording]:rec:' \
  '(-E --epgfile)'{-E+,--epgfile=}'[EPG data file]:file:_files' \
  '--filesize=[max VDR file size MB]:mb:' \
  '--genindex=[generate index for recording]:rec:' \
  '(-g --grab)'{-g+,--grab=}'[grab images to directory]:dir:_files -/' \
  '(-i --instance)'{-i+,--instance=}'[instance id]:id:' \
  '(-l --log)'{-l+,--log=}'[log level]:level:' \
  '(-L --lib)'{-L+,--lib=}'[plugin library directory]:dir:_files -/' \
  '--lirc=-[LIRC socket path]:path:' \
  '--localedir=[locale directory]:dir:_files -/' \
  '(-m --mute)'{-m,--mute}'[start muted]' \
  '--no-kbd[disable keyboard input]' \
  '(-p --port)'{-p+,--port=}'[SVDRP port]:port:' \
  '(-P --plugin)'{-P+,--plugin=}'[load plugin with options]:plugin:' \
  '(-r --record)'{-r+,--record=}'[record command]:cmd:' \
  '--resdir=[resource directory]:dir:_files -/' \
  '--showargs=-[show plugin args]:dir:_files -/' \
  '(-s --shutdown)'{-s+,--shutdown=}'[shutdown command]:cmd:' \
  '--split[split recordings on track changes]' \
  '(-t --terminal)'{-t+,--terminal=}'[controlling terminal]:tty:' \
  '(-u --user)'{-u+,--user=}'[run as user]:user:_users' \
  '--updindex=[update index for recording]:rec:' \
  '--userdump[allow generating user dumps]' \
  '--vfat[encode names for VFAT]' \
  '(-v --video)'{-v+,--video=}'[video directory]:dir:_files -/' \
  '(-w --watchdog)'{-w+,--watchdog=}'[watchdog timeout seconds]:sec:' && ret=0
return ret
