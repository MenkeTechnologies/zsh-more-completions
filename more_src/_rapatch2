#compdef rapatch2
# radare2 binary patcher applying radiff2/unified patch files to target binaries

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-p+[patch level, skip N leading directories]:level' \
  '-R[reverse patch]' \
  '-s[sandbox mode, disable scripts and r2 command execution]' \
  '-q[be quiet]' \
  '-v[show version]' \
  '1:patch file:_files' \
  '2:target file:_files' && ret=0

return ret
