#compdef libguestfs libguestfs-test-tool guestmount guestunmount virt-cat virt-copy-in virt-copy-out virt-diff virt-edit virt-filesystems virt-format virt-get-kernel virt-inspector virt-list-filesystems virt-list-partitions virt-log virt-ls virt-tar virt-tar-in virt-tar-out
# _libguestfs — Red Hat libguestfs CLI suite virt-cat virt-copy-in virt-copy-out virt-diff virt-edit virt-filesystems virt-inspector virt-ls virt-log virt-tar guestmount for inspecting and modifying disk images (libguestfs team, C); getopt
# upstream: https://github.com/libguestfs/libguestfs

_libguestfs() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-a+[add disk]:file:_files -g "*.img *.qcow2 *.raw *.vmdk *.vdi *.vhd *.vhdx *.iso *.tar *.gz *.bz2 *.xz"' \
        '--add=+[add disk]:file:_files -g "*.img *.qcow2 *.raw *.vmdk *.vdi *.vhd *.vhdx *.iso *.tar *.gz *.bz2 *.xz"' \
        '-c+[connect URI]:str:' \
        '--connect=+[connect URI]:str:' \
        '-d+[domain]:str:' \
        '--domain=+[domain]:str:' \
        '-m+[mount spec]:str:' \
        '--mount=+[mount spec]:str:' \
        '-i[inspect]' \
        '--inspector[inspect]' \
        '--ro[read only]' \
        '--rw[read write]' \
        '--all[show all]' \
        '--csv[csv output]' \
        '--format=+[fmt]:f:(raw qcow2 vmdk vdi vhd vhdx iso tar gz bz2 xz)' \
        '--key=+[id:type:value]:str:' \
        '-N+[type]:t:(disk part fs lv vg ufs ntfs ext2 ext3 ext4 vfat xfs btrfs jfs reiserfs)' \
        '--new=+[type]:t:(disk part fs lv vg ufs ntfs ext2 ext3 ext4 vfat xfs btrfs jfs reiserfs)' \
        '--no-applicate[no app]' \
        '--debug-overlays[debug overlays]' \
        '--xpath=+[expr]:str:' \
        '--echo-keys[echo keys]' \
        '--keys-from-stdin[keys from stdin]' \
        '*:disk image or path:_files'
}

_libguestfs "$@"
