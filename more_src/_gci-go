#compdef gci
# _gci-go — Go imports section ordering tool (Daixiang Cai, Go); split/sort imports into custom sections
# upstream: https://github.com/daixiang0/gci

_gci-go() {
    local -a sub=(
        'list:list files whose ordering differs'
        'diff:show diff'
        'write:rewrite files'
        'print:print rewritten files'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-s+[section]:section:(standard default custom blank dot localmodule)' \
        '-section+[section]:section:' \
        '-skip-generated[skip generated files]' \
        '-skip-vendor[skip vendor]' \
        '-custom-order[use custom order]' \
        '-no-inline-comments[disable inline comments handling]' \
        '-no-prefix-comments[disable prefix comments handling]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gci subcommand' sub ;;
        args)
            _arguments '*:file or dir:_files'
            ;;
    esac
}

_gci-go "$@"
