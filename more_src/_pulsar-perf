#compdef pulsar-perf

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'produce:run a producer performance test'
  'consume:run a consumer performance test'
  'transaction:run a transaction performance test'
  'read:run a reader performance test'
  'monitor-brokers:monitor broker health'
  'managed-ledger:run a managed ledger performance test'
  'simulation-client:run simulation client'
  'simulation-controller:run simulation controller'
  'websocket-producer:run a WebSocket producer'
  'help:show help'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pulsar-perf subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (produce|consume|read|transaction)
        _arguments \
          '-h[show help]' \
          '--help[show help]' \
          '-u+[service URL]:url:' \
          '--service-url=[service URL]:url:' \
          '--auth-plugin=[auth plugin class]:class:' \
          '--auth-params=[auth params]:params:' \
          '--listener-name=[listener name]:name:' \
          '-conf-file+[config file]:file:_files' \
          '-r+[messages per second]:rate:' \
          '-s+[message size in bytes]:n:' \
          '-n+[number of messages]:n:' \
          '-time+[total test duration in seconds]:secs:' \
          '-threads+[number of threads]:n:' \
          '-stats-interval-seconds+[stats output interval]:secs:' \
          '-trust-cert-file+[CA cert file]:file:_files' \
          '-tls-allow-insecure+[allow insecure TLS]:flag:(true false)' \
          '-tls-enable-hostname-verification+[verify hostname]:flag:(true false)' \
          '-c+[max concurrent calls]:n:' \
          '-p+[producer configuration name=value]:name=value:' \
          '-payload-file+[payload file]:file:_files' \
          '-payload-delimiter+[payload delimiter]:char:' \
          '-batch-time-window+[batch time window in ms]:ms:' \
          '-batch-max-bytes+[max batch size]:bytes:' \
          '-batch-max-messages+[max messages per batch]:n:' \
          '-z+[compression]:codec:(NONE LZ4 ZLIB ZSTD SNAPPY)' \
          '--compression=[compression]:codec:(NONE LZ4 ZLIB ZSTD SNAPPY)' \
          '-bm+[block if message queue full]:flag:(true false)' \
          '-mbb+[max bytes for message buffer]:bytes:' \
          '-mp+[max pending messages]:n:' \
          '-mpa+[max across partitions]:n:' \
          '-tto+[topic timeout]:secs:' \
          '-numTopic+[number of topics]:n:' \
          '-nmp+[messages produced per transaction]:n:' \
          '-nmc+[messages consumed per transaction]:n:' \
          '-ntxn+[number of transactions]:n:' \
          '-txn-timeout+[transaction timeout]:ms:' \
          '-abort[abort transactions]' \
          '-txn-enable+[enable transactions]:flag:(true false)' \
          '-ss+[subscription name]:name:' \
          '-st+[subscription type]:type:(Exclusive Shared Failover Key_Shared)' \
          '-sn+[subscription names list]:names:' \
          '-q+[queue size]:n:' \
          '--topics-c=[consumer topics]:topics:' \
          '--topics-p=[producer topics]:topics:' \
          '*:topic:' && ret=0
        ;;
      (managed-ledger)
        _arguments \
          '-h[show help]' \
          '-zk+[ZooKeeper servers]:zk:' \
          '-md+[max delay between batches]:ms:' \
          '-c+[number of cursors]:n:' \
          '-mb+[managed ledger backlog]:bytes:' \
          '-msz+[message size]:bytes:' \
          '-rate+[messages per second]:rate:' && ret=0
        ;;
    esac
    ;;
esac

return ret
