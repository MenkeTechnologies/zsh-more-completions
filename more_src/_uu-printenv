#compdef uu-printenv
# Documentation: https://man.archlinux.org/search?q=uu-printenv
# Reference accessed: 2026-05-16
# Source: Homebrew bottle
# Formula: uutils-coreutils
# Type: maintainer-shipped (Homebrew)
# Harvested: 2026-05-15

autoload -U is-at-least

_uu-printenv() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-0[end each output line with 0 byte rather than newline]' \
'--null[end each output line with 0 byte rather than newline]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'*::variables:_default' \
&& ret=0
}

(( $+functions[_uu-printenv_commands] )) ||
_uu-printenv_commands() {
    local commands; commands=()
    _describe -t commands 'uu-printenv commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-printenv" ]; then
    _uu-printenv "$@"
else
    compdef _uu-printenv uu-printenv
fi
