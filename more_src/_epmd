#compdef epmd
# Documentation: epmd -help
# Source: Erlang/OTP epmd — Erlang Port Mapper Daemon.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d -debug)'{-d,-debug}'[enable debugging (repeat for more)]' \
    '-address+[listen IP addresses (comma-separated)]:list:' \
    '-port+[listen port (default 4369)]:port:_ports' \
    '-daemon[start detached as a daemon]' \
    '-relaxed_command_check[allow kill/stop with registered nodes]' \
    '(- *)-names[list registered nodes]' \
    '(- *)-kill[kill epmd]' \
    '(- *)-stop+[forced unregister of NODE]:node:' \
    '-packet_timeout+[seconds before idle connection timeout (default 60)]:seconds:' \
    '-delay_accept+[insert delay before accept]:seconds:' \
    '-delay_write+[insert delay before write]:seconds:' \
    && ret=0

return ret
