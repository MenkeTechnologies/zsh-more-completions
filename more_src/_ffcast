#compdef ffcast
# Documentation: https://github.com/lolilolicon/FFcast/blob/master/doc/ffcast.1.pod
# Reference accessed: 2026-05-16
# Verified: upstream doc/ffcast.1.pod.

# ffcast: ffmpeg-friendly screen region selector
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'png:capture to PNG'
  'rec:record screen'
  'pad:pad selection'
  'trim:trim selection'
  'each:run command on each selection'
  'source:source ffcast bash library'
  'help:show command help'
)
_arguments -C \
  '-h[show help]' \
  '-#-[select window by ID]:id:' \
  '-b[include borders]' \
  '-f[include WM frame]' \
  '-g[selection geospec]:geospec:' \
  '-i[combine selections by intersection]' \
  '-q[less verbose]' \
  '-s[drag rectangular selection]' \
  '*-v[more verbose]' \
  '-w[click to select window]' \
  '-x-[Xinerama head ID]:n:' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'ffcast subcommand' commands && ret=0 ;;
esac
return ret
