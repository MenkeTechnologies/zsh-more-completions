#compdef st-trace
# Documentation: https://man.archlinux.org/search?q=st-trace
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'+[verbose level]:n:' \
  '(-c --clock)'{-c,--clock}'+[clock in MHz]:mhz:' \
  '(-s --serial)'{-s,--serial}'+[serial]:serial:' \
  '(-n --no-reset)'{-n,--no-reset}'[do not reset]' \
  '(-f --force)'{-f,--force}'[force overwrite]' \
  '(-x --stlinkv1)'{-x,--stlinkv1}'[use stlinkv1 protocol]' \
  '(-2 --stlinkv2)'{-2,--stlinkv2}'[use stlinkv2 protocol]' \
  '(-3 --stlinkv3)'{-3,--stlinkv3}'[use stlinkv3 protocol]' && ret=0

return ret
