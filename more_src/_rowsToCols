#compdef rowsToCols
# UCSC kent: convert rows to columns and vice versa in a text file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-varCol[rows may have various numbers of columns]' \
  '-tab[fields are separated by tab]' \
  '-fs=[fields are separated by given character]:char:' \
  '-fixed[fields are of fixed width with space padding]' \
  '-offsets=[fields are of fixed width at given comma-separated offsets]:offsets:' \
  ':in txt:_files' \
  ':out txt:_files' && ret=0

return ret
