#compdef civo
# Documentation: https://man.archlinux.org/search?q=civo
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'apikey:API key management'
  'applications:marketplace apps'
  'completion:print shell completion'
  'database:managed databases'
  'diagnostic:CLI diagnostics'
  'domain:DNS domain'
  'firewall:cloud firewalls'
  'help:show help'
  'instance:instance commands'
  'ip:reserved IPs'
  'ip-address:reserved IPs'
  'kfcluster:KF clusters'
  'kubernetes:kubernetes (k3s) clusters'
  'loadbalancer:load balancers'
  'monitoring:monitoring'
  'network:network commands'
  'objectstore:object storage'
  'organisation:organisation'
  'permission:permission management'
  'quota:account quotas'
  'region:regions'
  'role:RBAC roles'
  'size:instance sizes'
  'snapshot:snapshots'
  'sshkey:SSH keys'
  'team:team mgmt'
  'teammember:team member mgmt'
  'update:update CLI'
  'user:user mgmt'
  'volume:volumes'
  'webhook:webhooks'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--config=[config file]:file:_files' \
  '*--region=[region]:r:' \
  '*--apikey=[API key name]:k:' \
  '*--debug[debug HTTP]' \
  '*--fields=[output fields csv]:list:' \
  '*-o+[output format]:f:(json human custom yaml)' \
  '*--output=[output format]:f:(json human custom yaml)' \
  '*--pretty[pretty JSON]' \
  '*--quiet[quiet]' \
  '*--showheader[show header]' \
  '*--write-config-from-env[write env to config]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'civo command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (kubernetes)
        _arguments \
          '1:subcommand:(applications create credentials delete list rename scale show update)' \
          '*: :' && ret=0 ;;
      (instance)
        _arguments \
          '1:subcommand:(create delete firewall hard-reboot list move-ip password public-ip reboot rebuild remove-firewall restore retag setfirewall show shutdown soft-reboot stop tags update upgrade)' \
          '*: :' && ret=0 ;;
      (volume)
        _arguments \
          '1:subcommand:(attach create delete detach list resize show update)' \
          '*: :' && ret=0 ;;
      (network)
        _arguments \
          '1:subcommand:(create delete list rename show update)' \
          '*: :' && ret=0 ;;
      (firewall)
        _arguments \
          '1:subcommand:(create delete list new rename rule show)' \
          '*: :' && ret=0 ;;
      (loadbalancer)
        _arguments \
          '1:subcommand:(create delete list rename show update)' \
          '*: :' && ret=0 ;;
      (database)
        _arguments \
          '1:subcommand:(backup create credential delete list rename show update versions)' \
          '*: :' && ret=0 ;;
      (objectstore)
        _arguments \
          '1:subcommand:(create credential delete list show update)' \
          '*: :' && ret=0 ;;
      (apikey)
        _arguments \
          '1:subcommand:(add current ls remove rename save)' \
          '*: :' && ret=0 ;;
      (sshkey)
        _arguments \
          '1:subcommand:(create delete list rename show)' \
          '*: :' && ret=0 ;;
      (snapshot)
        _arguments \
          '1:subcommand:(create delete list show)' \
          '*: :' && ret=0 ;;
      (domain)
        _arguments \
          '1:subcommand:(create delete list record show)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
