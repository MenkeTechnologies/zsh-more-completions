#compdef uvspec
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvspec.html
# MIRIAD uvspec - plot averaged spectra of visibility data

local ret=1

_arguments -s -S \
  'vis=[input uv dataset names]:vis:_files' \
  'select=[uv selection commands]:select' \
  'line=[uv line type line,nchan,start,width,step]:line' \
  'stokes=[polarization types to plot]:stokes' \
  'interval=[time averaging interval in minutes]:interval' \
  'hann=[Hanning smoothing width (odd)]:hann' \
  'offset=[offset in arcsec to shift the data]:offset' \
  'axis=[x-axis,y-axis (channel,frequency,velocity / amplitude,phase,...)]:axis' \
  'xrange=[x-axis range]:xrange' \
  'yrange=[y-axis range]:yrange' \
  'device=[PGPLOT plot device/type]:device' \
  'nxy=[number of plots in X and Y]:nxy' \
  'log=[log file for spectrum output]:log:_files' \
  'options=[nocal,nopass,nopol,ampscalar,rms,mnoise,sdo,nobase,avall,dots,flagged,all,hdr,timelog]:options' \
  '*:visibility data:_files' && ret=0

return ret
