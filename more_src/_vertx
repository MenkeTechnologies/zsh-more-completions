#compdef vertx

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run a verticle'
  'start:start a Vert.x application in the background'
  'stop:stop a running Vert.x application'
  'list:list running Vert.x applications'
  'bare:start a bare Vert.x instance'
  'version:show version'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'vertx subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '-conf=[config file or JSON]:file:_files' \
          '(-cp -classpath)'{-cp=,-classpath=}'[classpath]:cp:' \
          '-instances=[number of instances]:n:' \
          '(-w -worker)'{-w,-worker}'[run as worker verticle]' \
          '-ha[enable high availability]' \
          '-options=[Vertx options file or JSON]:file:_files' \
          '--launcher-class=[launcher class]:class:' \
          '--cluster[enable clustering]' \
          '--cluster-host=[cluster host]:host:_hosts' \
          '--cluster-port=[cluster port]:port:' \
          '--cluster-public-host=[cluster public host]:host:_hosts' \
          '--cluster-public-port=[cluster public port]:port:' \
          '--redeploy=[redeploy pattern]:pattern:' \
          '--on-redeploy=[redeploy command]:cmd:' \
          '--redeploy-grace-period=[redeploy grace period ms]:ms:' \
          '--redeploy-scan-period=[redeploy scan period ms]:ms:' \
          '--redeploy-termination-period=[redeploy termination period ms]:ms:' \
          '--workspace=[workspace dir]:dir:_files -/' \
          ':verticle:' && ret=0
        ;;
      (start)
        _arguments \
          '-id=[application id]:id:' \
          '--launcher-class=[launcher class]:class:' && ret=0
        ;;
      (stop)
        _arguments \
          ':id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
