#compdef agent-protocol
# Documentation: https://github.com/AI-Engineer-Foundation/agent-protocol
# Reference accessed: 2026-05-23
# Verified: agent-protocol test --help (Click CLI).

# Zsh completion for agent-protocol - Agent Protocol API compliance checker

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'agent-protocol command' \
      'test[check Agent API Agent Protocol compliance]' && ret=0
    ;;
  args)
    case $line[1] in
      test)
        _arguments -C \
          '(-u --url)'{-u+,--url=}'[URL of the Agent API]:url:' \
          '*:pytest args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
