#compdef bufr_get
# Documentation: https://confluence.ecmwf.int/display/ECC/bufr_get
# Source: ecmwf/eccodes tools/bufr_get.cc — read key values from BUFR messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[force, do not fail on error]' \
    '-p+[keys to print (key[:s/d/i],...)]:keys:_default' \
    '-F+[C-style float format (default %g)]:format:_default' \
    '-P+[append keys to default print list]:keys:_default' \
    '-w+[where clause filter]:filter:_default' \
    '-n+[print all keys in namespace]:namespace:_default' \
    '-s+[key=value pairs to set]:kvs:_default' \
    '(- *)-V[show version]' \
    '-W+[minimum column width (default 8)]:n:_default' \
    '-m[print MARS keys]' \
    '-g[copy GTS header]' \
    '-T+[message type]:type:(T B M A)' \
    '-7[do not fail on wrong message length]' \
    '*:bufr file:_files' \
    && ret=0

return ret
