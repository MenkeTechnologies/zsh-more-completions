#compdef virtstoraged virtsecretd virtnodedevd virtnwfilterd virtinterfaced virtproxyd
# _virtstoraged — libvirt per-resource daemons (virtstoraged/virtsecretd/virtnodedevd/virtnwfilterd/virtinterfaced/virtproxyd handle storage / secret / node-device / nwfilter / iface / RPC-proxy subsystems in the split-daemon model; shared flags: -d daemonize, -f config file, -p pidfile, -t timeout seconds, -v verbose)
# upstream: https://gitlab.com/libvirt/libvirt
# Flags from libvirt src/remote/remote_daemon.c on tip.

_virtstoraged() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-d[daemonize]' \
        '-f+[config file]:file:_files' \
        '-p+[pidfile]:file:_files' \
        '-t+[timeout seconds]:seconds:'
}

_virtstoraged "$@"
