#compdef dockeye

# dockeye — Docker/compose TUI (https://github.com/toewsengineering/dockeye). Run `dockeye --help` for pane shortcuts; CLI exposes global flags only.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[path to config.toml]:file:_files' \
  '--log-level=[tracing filter]:level:(error warn info debug trace)' && ret=0

return ret
