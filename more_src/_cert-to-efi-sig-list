#compdef cert-to-efi-sig-list
# Documentation: man cert-to-efi-sig-list(1)
# Source: mjg59/efitools cert-to-efi-sig-list.c (master) — X.509 to EFI sig list converter (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--version[show version]' \
    '--help[show help]' \
    '-g+[owner GUID]:guid:_default' \
    '1:certificate file (PEM):_files -g "*.{pem,crt,cer}"' \
    '2:EFI sig list output file:_files -g "*.esl"' \
    && ret=0

return ret
