#compdef zdns
# Documentation: https://github.com/zmap/zdns
# Reference accessed: 2026-05-17
# Verified: zmap/zdns upstream flag surface and DNS record type
# subcommand list.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  A AAAA AFSDB ANY ATMA AVC AXFR BINDVERSION CAA CDNSKEY CDS CERT CNAME CSYNC
  DHCID DMARC DNSKEY DS EID EUI48 EUI64 GID GPOS HINFO HIP HTTPS ISDN
  KEY KX L32 L64 LOC LP MB MD MF MG MR MX NAPTR NID NINFO NS NSAPPTR
  NSEC NSEC3 NSEC3PARAM NULL NXT OPENPGPKEY PTR PX RP RRSIG RT SMIMEA
  SOA SPF SRV SSHFP SVCB TALINK TKEY TLSA TXT UID UINFO UNSPEC URI
  alookup mxlookup nslookup MULTIPLE
)

_arguments -C \
  '--all-nameservers[query all nameservers]' \
  '--cache-size=[cache size]:n:' \
  '--go-processes=[GOMAXPROCS]:n:' \
  '--iteration-timeout=[per-iteration timeout]:duration:' \
  '--iterative[iterative resolution]' \
  '--max-depth=[max recursion depth]:n:' \
  '--name-server-mode=[NS mode]:mode:' \
  '*--name-servers=[name server]:ns:' \
  '--nanoseconds[timestamps in nanoseconds]' \
  '--network-timeout=[network timeout]:duration:' \
  '--no-follow-cnames[do not follow CNAMEs]' \
  '--retries=[retries]:n:' \
  '(-t --threads)'{-t,--threads}'=[threads]:n:' \
  '--timeout=[total timeout]:duration:' \
  '(- *)'{-v,--version}'[show version]' \
  '--checking-disabled[CD bit]' \
  '--class=[query class]:class:(IN CH HS ANY)' \
  '--client-subnet=[EDNS client subnet]:subnet:' \
  '--dnssec[request DNSSEC]' \
  '--validate-dnssec[validate DNSSEC]' \
  '--nsid[NSID option]' \
  '-4[IPv4 only]' \
  '-6[IPv6 only]' \
  '--https[DNS over HTTPS]' \
  '--local-addr=[local address]:addr:' \
  '--local-interface=[local interface]:iface:_net_interfaces' \
  '--no-recycle-sockets[do not recycle sockets]' \
  '--prefer-ipv4-iteration[prefer IPv4 iteration]' \
  '--prefer-ipv6-iteration[prefer IPv6 iteration]' \
  '--root-cas-file=[root CAs file]:file:_files' \
  '--tcp-only[TCP only]' \
  '--tls[DNS over TLS]' \
  '--udp-only[UDP only]' \
  '--verify-server-cert[verify TLS cert]' \
  '--alexa[input is Alexa CSV]' \
  '--blacklist-file=[blacklist file]:file:_files' \
  '--conf-file=[config file]:file:_files' \
  '(-c --multi-config-file)'{-c,--multi-config-file}'=[multi config file]:file:_files' \
  '--include-fields=[include fields]:fields:' \
  '(-f --input-file)'{-f,--input-file}'=[input file]:file:_files' \
  '--log-file=[log file]:file:_files' \
  '--metadata-file=[metadata file]:file:_files' \
  '--metadata-passthrough[passthrough metadata]' \
  '(-o --output-file)'{-o,--output-file}'=[output file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--override-name=[override name]:name:' \
  '--prefix=[output prefix]:prefix:' \
  '--result-verbosity=[verbosity]:level:(short normal long trace)' \
  '(-u --status-updates-file)'{-u,--status-updates-file}'=[status updates]:file:_files' \
  '--verbosity=[log verbosity]:level:' \
  '--zone-file=[zone file]:file:_files' \
  '--zone-file-include-targets[include targets from zone file]' \
  '1: :->rrtype' && ret=0

case $state in
  (rrtype)
    _describe -t subcommands 'DNS record type' subcommands && ret=0
    ;;
esac

return ret
