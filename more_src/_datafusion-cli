#compdef datafusion-cli

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --data-path)'{-p,--data-path=}'[data path]:dir:_files -/' \
  '(-b --batch-size)'{-b,--batch-size=}'[query batch size]:n:' \
  '*'{-c,--command=}'[execute given SQL command then exit]:sql:' \
  '(-m --memory-limit)'{-m,--memory-limit=}'[memory pool limit, e.g. 10g]:size:' \
  '*'{-f,--file=}'[execute commands from file then exit]:file:_files' \
  '*'{-r,--rc=}'[run files on startup instead of ~/.datafusionrc]:file:_files' \
  '--format=[output format]:format:(csv tsv table json nd-json automatic)' \
  '(-q --quiet)'{-q,--quiet}'[reduce non-result output]' \
  '--mem-pool-type=[memory pool type]:type:(greedy fair)' \
  '--top-memory-consumers=[top consumers shown on memory exhaustion]:n:' \
  '--maxrows=[max rows for table format]:n:' \
  '--color[enable console syntax highlighting]' \
  '(-d --disk-limit)'{-d,--disk-limit=}'[disk space for spilling, e.g. 10g]:size:' \
  '--object-store-profiling=[object store profiling level]:level:(disabled summary trace)'
