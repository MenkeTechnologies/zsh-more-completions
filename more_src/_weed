#compdef weed

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'master:start a master server'
  'volume:start a volume server'
  'filer:start a filer server'
  's3:start an S3 gateway'
  'iam:start an IAM server'
  'mount:mount as a FUSE filesystem'
  'export:export data from volume servers'
  'upload:upload files'
  'download:download files'
  'shell:start an interactive shell'
  'benchmark:run benchmarks'
  'compact:compact volumes'
  'fix:fix volumes'
  'server:start master, volume, and filer combined'
  'scaffold:generate scaffold files'
  'filer.backup:backup filer metadata'
  'filer.cat:stream file content'
  'filer.copy:copy files between filers'
  'filer.meta.backup:backup filer metadata'
  'filer.meta.tail:tail filer metadata changes'
  'filer.remote.sync:sync with remote storage'
  'filer.replicate:replicate filer data'
  'filer.sync:sync filer data'
  'version:display version'
)

_arguments -s -S \
  '(-v)-v=[set log verbosity]:level:(0 1 2 3 4)' \
  '--logdir=[directory to store log files]:directory:_files -/' \
  '--alsologtostderr[log to standard error as well as files]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      master)
        _arguments \
          '-port=[HTTP listen port]:port' \
          '-port.grpc=[gRPC listen port]:port' \
          '-ip=[IP address to bind to]:IP' \
          '-ip.bind=[IP address to bind to]:IP' \
          '-mdir=[directory to store metadata]:directory:_files -/' \
          '-volumeSizeLimitMB=[volume size limit in MB]:MB' \
          '-volumePreallocate[preallocate volume disk space]' \
          '-defaultReplication=[default replication strategy]:strategy' \
          '-garbageThreshold=[threshold to trigger vacuum]:threshold' \
          '-peers=[other master nodes]:peers' \
          '-raftHashicorp[use Hashicorp Raft]' \
          '-metricsPort=[Prometheus metrics port]:port' && ret=0
        ;;
      volume)
        _arguments \
          '-port=[HTTP listen port]:port' \
          '-port.grpc=[gRPC listen port]:port' \
          '-ip=[IP address to bind to]:IP' \
          '-ip.bind=[IP address to bind to]:IP' \
          '-dir=[directories to store data]:directories:_dir_list' \
          '-max=[maximum number of volumes]:count' \
          '-mserver=[master server location]:address' \
          '-dataCenter=[data center name]:name' \
          '-rack=[rack name]:name' \
          '-compactionMBps=[compaction speed limit in MB/s]:MBps' \
          '-metricsPort=[Prometheus metrics port]:port' && ret=0
        ;;
      filer)
        _arguments \
          '-port=[HTTP listen port]:port' \
          '-port.grpc=[gRPC listen port]:port' \
          '-ip=[IP address to bind to]:IP' \
          '-ip.bind=[IP address to bind to]:IP' \
          '-master=[master server address]:address' \
          '-collection=[default collection]:collection' \
          '-defaultReplicaPlacement=[default replication]:strategy' \
          '-maxMB=[split files larger than this in MB]:MB' \
          '-dirListLimit=[directory listing limit]:count' \
          '-dataCenter=[data center name]:name' \
          '-rack=[rack name]:name' \
          '-disableHttp[disable HTTP filer]' \
          '-metricsPort=[Prometheus metrics port]:port' && ret=0
        ;;
      s3)
        _arguments \
          '-port=[S3 listen port]:port' \
          '-ip=[IP address to bind to]:IP' \
          '-filer=[filer server address]:address' \
          '-config=[config file]:config file:_files' \
          '-domainName=[domain name for virtual hosted style]:domain' \
          '-tlsPrivateKey=[TLS private key]:key file:_files' \
          '-tlsCertificate=[TLS certificate]:cert file:_files' && ret=0
        ;;
      mount)
        _arguments \
          '-filer=[filer server address]:address' \
          '-dir=[mount point]:mount point:_files -/' \
          '-collection=[collection to mount]:collection' \
          '-replication=[replication strategy]:strategy' \
          '-cacheDir=[local cache directory]:directory:_files -/' \
          '-cacheSizeMB=[cache size in MB]:MB' \
          '-allowOthers[allow other users to access mount]' \
          '-umask=[umask for files]:umask' \
          '-readOnly[mount read-only]' && ret=0
        ;;
      server)
        _arguments \
          '-master.port=[master HTTP port]:port' \
          '-volume.port=[volume HTTP port]:port' \
          '-filer.port=[filer HTTP port]:port' \
          '-s3.port=[S3 port]:port' \
          '-dir=[data directory]:directory:_files -/' \
          '-ip=[IP address]:IP' && ret=0
        ;;
      upload)
        _arguments \
          '-master=[master server]:address' \
          '-dir=[upload directory]:directory' \
          '-include=[include pattern]:pattern' \
          '-replication=[replication]:strategy' \
          '-collection=[collection]:collection' \
          '-ttl=[time to live]:TTL' \
          '-maxMB=[max file size in MB]:MB' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
