#compdef duckdb

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c[run command and exit]:command' \
  '-cmd[run command before reading stdin]:command' \
  '-csv[set output mode to CSV]' \
  '-json[set output mode to JSON]' \
  '-line[set output mode to line]' \
  '-column[set output mode to column]' \
  '-markdown[set output mode to markdown]' \
  '-table[set output mode to table]' \
  '-box[set output mode to box]' \
  '-latex[set output mode to LaTeX]' \
  '-html[set output mode to HTML]' \
  '-ascii[set output mode to ASCII]' \
  '-tabs[set output mode to tab-separated]' \
  '-separator[set output separator]:separator' \
  '-newline[set output newline]:newline' \
  '-nullvalue[set NULL display value]:value' \
  '-header[enable headers]' \
  '-noheader[disable headers]' \
  '-echo[echo commands]' \
  '-init[read/process named file]:file:_files' \
  '-bail[stop on error]' \
  '-batch[force batch I/O]' \
  '-interactive[force interactive I/O]' \
  '-readonly[open database in read-only mode]' \
  '-s[run command and exit]:command' \
  '-unsigned[allow unsigned extensions]' \
  '-no-stdin[exit after processing init file]' \
  '-list[set output mode to list]' \
  '-stats[print memory stats before each finalize]' \
  '-threads[number of threads]:threads' \
  '-unredacted[do not redact secrets in errors]' \
  '1:database file:_files -g "*.{db,duckdb,parquet,csv,json}"' && ret=0

return ret
