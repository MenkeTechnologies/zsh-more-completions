#compdef clusterlint
# Documentation: https://github.com/digitalocean/clusterlint
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list available checks'
  'run:execute all or specific checks'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--in-cluster[access Kubernetes API from within a Pod]' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--plugins=[load custom plugin checks from file path]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'clusterlint command' commands && ret=0 ;;
  args)
    case $line[1] in
      run)
        _arguments \
          '-g+[run only checks belonging to a group]:group:' \
          '-G+[exclude checks belonging to a group]:group:' \
          '-c+[run a single named check]:check:' \
          '-C+[exclude a specific check]:check:' && ret=0 ;;
    esac ;;
esac

return ret
