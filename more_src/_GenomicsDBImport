#compdef GenomicsDBImport
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/genomicsdb/GenomicsDBImport.java
# GATK4: import single-sample gVCFs into a GenomicsDB before joint genotyping

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--genomicsdb-workspace-path[workspace for a new GenomicsDB]:dir:_files -/' \
  '--genomicsdb-update-workspace-path[existing workspace to update]:dir:_files -/' \
  '*'{-V,--variant}'[input gVCF file]:file:_files -g "*.(g.vcf|g.vcf.gz|vcf|vcf.gz)"' \
  '--sample-name-map[tab-delimited file mapping sample name to file uri]:file:_files' \
  '(-L --intervals)'{-L,--intervals}'[genomic intervals to import]:intervals:_files' \
  '--batch-size[number of samples to read in at once]:n:' \
  '--reader-threads[threads to use when opening VCFs in batches]:n:' \
  '--overwrite-existing-genomicsdb-workspace[overwrite the workspace if it exists]' \
  '*:options:_files' && ret=0

return ret
