#compdef kube-score

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'score:score Kubernetes objects'
      'list:list available checks'
      'version:print version'
      'completion:generate shell completion'
    )
    _describe -t commands 'kube-score command' commands && ret=0
    ;;
  args)
    case $words[1] in
      score)
        _arguments -s -S \
          {-o,--output-format}'=[output format]:format:(human json ci sarif)' \
          '--output-version=[output version]:version' \
          '*--ignore-test=[test to ignore]:test' \
          '*--enable-optional-test=[optional test to enable]:test' \
          '--ignore-container-cpu-limit[ignore container CPU limit]' \
          '--ignore-container-memory-limit[ignore container memory limit]' \
          '--kubernetes-version=[Kubernetes version]:version' \
          '*:file:_files' \
          && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
