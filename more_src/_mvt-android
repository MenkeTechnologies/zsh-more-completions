#compdef mvt-android

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'version:show version'
  'check-bugreport:scan bugreport for IOCs'
  'check-backup:scan backup for IOCs'
  'check-androidqf:scan androidqf data'
  'check-iocs:check IOC files'
  'download-iocs:download IOC indicators'
)

_arguments -C \
  '--disable-update-check[disable version check]' \
  '--disable-indicator-update-check[disable indicator update check]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'mvt-android subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (check-bugreport)
        _arguments -s \
          '*'{-i,--iocs}'=[IOCs file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output path]:dir:_files -/' \
          '(-l --list-modules)'{-l,--list-modules}'[list modules]' \
          '(-m --module)'{-m,--module}'=[module name]:module:' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '*:bugreport path:_files' && ret=0 ;;
      (check-backup)
        _arguments -s \
          '*'{-i,--iocs}'=[IOCs file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output path]:dir:_files -/' \
          '(-l --list-modules)'{-l,--list-modules}'[list modules]' \
          '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive]' \
          '(-p --backup-password)'{-p,--backup-password}'=[backup password]:pw:' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '*:backup path:_files -/' && ret=0 ;;
      (check-androidqf)
        _arguments -s \
          '*'{-i,--iocs}'=[IOCs file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output path]:dir:_files -/' \
          '(-l --list-modules)'{-l,--list-modules}'[list modules]' \
          '(-m --module)'{-m,--module}'=[module name]:module:' \
          '(-H --hashes)'{-H,--hashes}'[generate hashes]' \
          '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive]' \
          '(-p --backup-password)'{-p,--backup-password}'=[backup password]:pw:' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '*:androidqf path:_files -/' && ret=0 ;;
      (check-iocs)
        _arguments -s \
          '*'{-i,--iocs}'=[IOCs file]:file:_files' \
          '(-l --list-modules)'{-l,--list-modules}'[list modules]' \
          '(-m --module)'{-m,--module}'=[module name]:module:' \
          '*:folder:_files -/' && ret=0 ;;
    esac
    ;;
esac

return ret
