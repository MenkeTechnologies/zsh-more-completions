#compdef syz-execprog
# _syz-execprog — execute syzkaller programs and trace results (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-execprog/execprog.go (flag).

_syz-execprog() {
    _arguments \
        '-os=[target OS]:os:(linux freebsd netbsd openbsd darwin windows fuchsia trusty test)' \
        '-arch=[target architecture]:arch:(amd64 386 arm64 arm mips64le ppc64le riscv64 s390x)' \
        '-type=[target VM type]:type:' \
        '-coverfile=[write coverage to file]:file:_files' \
        '-repeat=[repeat execution N times (0=infinite)]:n:' \
        '-procs=[number of parallel processes]:n:' \
        '-output[write programs and results to stdout]' \
        '-hints[do a hints-generation run]' \
        '-enable=[enable only listed additional features]:list:' \
        '-disable=[enable all features except listed]:list:' \
        '-executor=[path to syz-executor binary]:file:_files' \
        '-threaded=[use threaded mode in executor]:val:(true false)' \
        '-cover[collect feedback signals (coverage)]' \
        '-sandbox=[sandbox for fuzzing]:sandbox:(none setuid namespace android)' \
        '-sandbox_arg=[sandbox runner argument]:n:' \
        '-debug[debug output from executor]' \
        '-slowdown=[execution slowdown for emulation/instrumentation]:n:' \
        '-unsafe[unsafe program deserialization mode]' \
        '-glob=[run glob expansion request]:pattern:' \
        '-stress[enable stress mode (local fuzzer)]' \
        '-syscalls=[comma-separated enabled syscalls for stress mode]:list:' \
        '-gdb[start executor under gdb]' \
        '*:program file:_files'
}

_syz-execprog "$@"
