#compdef jobber
# Documentation: https://dshearer.github.io/jobber/doc/v1.4/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Corrected from prior file: subcommands take an optional -a flag
# (operate on all users, requires root) per upstream docs; removed
# the global --user option (not documented at top level).
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'list:list the jobs for a particular user'
      'log:print the run log of previous runs'
      'test:immediately run a job and show its output'
      'reload:load or reload a user jobfile'
      'pause:temporarily stop Jobber from running a job'
      'resume:resume a paused job'
      'init:make a do-nothing jobfile in the home directory'
      'cat:print a job command (the shell script it executes)'
    )
    _describe -t commands 'jobber command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      list|reload)
        _arguments '-a[apply to all users (requires root)]' && ret=0
        ;;
      test|pause|resume|cat)
        _arguments \
          '-a[apply to all users (requires root)]' \
          ':job name' && ret=0
        ;;
      log)
        _arguments ':job name' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
