#compdef jobber

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--user[specify user]:user:_users' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'list:list jobs'
      'log:show job run log'
      'test:test a job'
      'reload:reload jobber configuration'
      'pause:pause a job'
      'resume:resume a paused job'
      'init:create initial jobber config'
      'cat:show job file contents'
    )
    _describe -t commands 'jobber command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      test|pause|resume)
        _arguments ':job name' && ret=0
        ;;
      log)
        _arguments \
          ':job name' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
