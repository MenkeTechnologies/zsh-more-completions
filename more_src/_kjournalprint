#compdef kjournalprint

_arguments -s \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-C --confdb)'{-C,--confdb=}'[config DB directory]:dir:_files -/' \
  '(-D --dir)'{-D,--dir=}'[journal DB path]:dir:_files -/' \
  '(-z --zone-list)'{-z,--zone-list}'[list zones in DB]' \
  '(-l --limit)'{-l,--limit=}'[limit changes]:n:' \
  '(-s --serial)'{-s,--serial=}'[start at SOA serial]:serial:' \
  '(-M --merge)'{-M,--merge}'[merge changesets]' \
  '(-H --check)'{-H,--check}'[extra semantic checks]' \
  '(-d --debug)'{-d,--debug}'[brief debug format]' \
  '(-x --mono)'{-x,--mono}'[disable color]' \
  '(-X --color)'{-X,--color}'[force color]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  ':zone name:'
