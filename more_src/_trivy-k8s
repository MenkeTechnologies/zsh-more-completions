#compdef trivy-k8s
# _trivy-k8s — Aqua Security trivy-k8s CLI Kubernetes cluster vulnerability misconfiguration scanner subcommand of trivy scanning installed-image-tag-image-pull-secret manifest namespaces nodes-pods-deployments-cronjob-clusterrole-rolebinding-PSP-PSA admission-controller-policy with KSPM CIS compliance benchmark reports SBOM-output (Aqua Security team, Go); pflag
# upstream: https://aquasecurity.github.io/trivy/

_trivy-k8s() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--kubeconfig=+[file]:file:_files' \
        '--cluster-context=+[name]:str:' \
        '--components=+[list]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--include-namespaces=+[list]:str:' \
        '--exclude-namespaces=+[list]:str:' \
        '--exclude-nodes=+[list]:str:' \
        '--exclude-owned[exclude owned resources]' \
        '--all-namespaces[all namespaces]' \
        '-A[all namespaces]' \
        '--scanners=+[list]:str:' \
        '--security-checks=+[list]:str:' \
        '--severity=+[list]:str:' \
        '--vuln-type=+[types]:str:' \
        '--report=+[r]:r:(summary all)' \
        '--format=+[f]:f:(table json sarif github cosign-vuln cyclonedx spdx-json spdx html)' \
        '--ignorefile=+[file]:file:_files' \
        '--ignore-policy=+[file]:file:_files' \
        '--policy=+[paths]:str:' \
        '--data=+[paths]:str:' \
        '--compliance=+[c]:c:(k8s-cis k8s-nsa k8s-pss-baseline k8s-pss-restricted aks-cis-1.2.0 docker-cis-1.6.0 eks-cis-1.4 rke2-cis-1.24)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--exit-code=+[N]:n:' \
        '--exit-on-eol=+[N]:n:' \
        '--timeout=+[duration]:str:' \
        '--node-collector-imageref=+[image]:str:' \
        '--node-collector-namespace=+[name]:str:' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--clear-cache[clear cache]' \
        '--reset[reset]' \
        '--download-db-only[download db only]' \
        '--skip-db-update[skip db update]' \
        '*::'
}

_trivy-k8s "$@"
