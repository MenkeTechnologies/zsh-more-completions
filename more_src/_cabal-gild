#compdef cabal-gild
# Documentation: https://github.com/tfausak/cabal-gild
# Format .cabal files (formatter and checker)

local ret=1

_arguments -s -S \
  '--help[print the help message then exit]' \
  '--version[print the version number then exit]' \
  '--crlf=[CRLF line-ending leniency]:leniency:(lenient strict)' \
  '--mode=[operational mode]:mode:(format check)' \
  '--stdin=[when reading from STDIN, use FILE as the effective input file]:file:_files' \
  '--input=[input file (deprecated, use positional args)]:file:_files' \
  '--output=[output file (deprecated, use piping)]:file:_files' \
  '--io=[set both input and output files (deprecated)]:file:_files' \
  '*:file:_files' && ret=0

return ret
