#compdef tunneld
# Documentation: https://github.com/mmatczuk/go-http-tunnel
# tunneld - go-http-tunnel server for publicly available hosts

local ret=1

_arguments -s \
  '-h[show help]' \
  '-tlsCrt[path to server TLS certificate]:file:_files' \
  '-tlsKey[path to server TLS certificate key]:file:_files' && ret=0

return ret
