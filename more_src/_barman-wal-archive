#compdef barman-wal-archive
# Documentation: https://manpages.ubuntu.com/manpages/questing/man1/barman-wal-archive.1.html
# archive_command based on Barman's put-wal

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-U --user)'{-U,--user}'=[user for the ssh connection to the Barman server]:user' \
  '--port=[port of the Barman server SSH server]:port' \
  '(-c --config)'{-c,--config}'=[configuration file on the Barman server]:file:_files' \
  '(-t --test)'{-t,--test}'[test the connection and configuration]' \
  '(-z --gzip)'{-z,--gzip}'[gzip-compress the WAL before sending]' \
  '(-j --bzip2)'{-j,--bzip2}'[bzip2-compress the WAL before sending]' \
  '--xz[xz-compress the WAL before sending]' \
  '--snappy[snappy-compress the WAL before sending]' \
  '--zstd[zstd-compress the WAL before sending]' \
  '--lz4[lz4-compress the WAL before sending]' \
  '--compression-level=[compression level]:level' \
  '--md5[send the MD5 checksum of the WAL file]' \
  '1:barman host:_hosts' \
  '2:server name:' \
  '3:wal path:_files' && ret=0

return ret
