#compdef litra
# Documentation: https://man.archlinux.org/search?q=litra
# Reference accessed: 2026-05-16

# https://github.com/timrogers/litra-rs — clap (src/main.rs Commands enum)
local -a _litra_dev
_litra_dev=(
  '(-s --serial-number)'{-s,--serial-number}'=-[target device serial]:serial:'
  '(-p --device-path)'{-p,--device-path}'=-[(USB) device path]:path:_files'
  '(-t --device-type)'{-t,--device-type}'=-[device family]:type:(glow beam beam_lx)'
)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[help]' \
  '-V[version]' \
  '--version[version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a c
    c=(
      'on:power on' 'off:power off' 'toggle:toggle power'
      'brightness:set brightness (lumens or percent)'
      'brightness-up:raise brightness' 'brightness-down:lower brightness'
      'temperature:set color temperature (Kelvin)'
      'temperature-up:warmer' 'temperature-down:cooler'
      'devices:list USB lights' 'back-color:rear accent color'
      'back-brightness:rear LED brightness' 'back-off:rear LED off'
      'back-on:rear LED on' 'back-toggle:rear LED toggle'
      'back-brightness-up' 'back-brightness-down'
      'mcp:Model Context Protocol server'
    )
    _describe -t commands 'litra command' c && ret=0
    ;;
  args)
    case $line[1] in
      brightness)
        _arguments -s -S "$_litra_dev[@]" \
          '(-v --value)'{-v,--value}'=-[brightness lumens]:lm:' \
          '(-b --percentage)'{-b,--percentage}'=-[brightness percent]:pct:' && ret=0
        ;;
      brightness-up|brightness-down|temperature-up|temperature-down|back-brightness-up|back-brightness-down)
        _arguments -s -S "$_litra_dev[@]" \
          '(-v --value)'{-v,--value}'=-[delta]:n:' && ret=0
        ;;
      temperature|back-color)
        _arguments -s -S "$_litra_dev[@]" \
          '--value=-[Kelvin or color value]:value:' \
          '(-n --named-color)'{-n,--named-color}'=-[preset]:color:(red green blue yellow orange purple pink cyan white magenta)' && ret=0
        ;;
      devices)
        _arguments '--json[machine-readable JSON]' && ret=0
        ;;
      on|off|toggle|back-off|back-on|back-toggle)
        _arguments -s -S "$_litra_dev[@]" && ret=0
        ;;
      back-brightness)
        _arguments -s -S "$_litra_dev[@]" \
          '(-v --value)'{-v,--value}'=-[lumens]:lm:' \
          '(-b --percentage)'{-b,--percentage}'=-[percent]:pct:' && ret=0
        ;;
      *) _default && ret=0 ;;
    esac
    ;;
esac

return ret
