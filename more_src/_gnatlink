#compdef gnatlink
# Documentation: https://man.archlinux.org/search?q=gnatlink
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-A[ASCII mode]' \
  '-b+[binder option]:opt:' \
  '-B+[gcc option]:opt:' \
  '-f[force regeneration]' \
  '-g[debug info]' \
  '-h[help]' \
  '-M[generate map file]' \
  '-Mmap[generate named map]:name:' \
  '-n[do not call binder/gcc]' \
  '-o+[output executable]:file:_files' \
  '-P+[pre-link command]:cmd:' \
  '-R[remove ALI dependency]' \
  '-v[verbose]' \
  '-W+[wide character handling]:enc:' \
  '--GCC=[GCC executable]:cmd:_command_names' \
  '--LINK=[linker]:cmd:_command_names' \
  '*:object_or_lib:_files' && ret=0

return ret
