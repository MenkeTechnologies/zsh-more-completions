#compdef hugectl
# Run command with hugepage controls

local ret=1

_arguments -s -S \
  '--heap[back heap with hugepages]' \
  '--heap=[specify heap hugepage size]:size:' \
  '--shm[back shared memory with hugepages]' \
  '--text[back text/data with hugepages]' \
  '--no-preload[disable LD_PRELOAD of libhugetlbfs]' \
  '--force-preload[force LD_PRELOAD]' \
  '--verbose[verbose output]' \
  '-v[verbose output]' \
  '--help[show help]' \
  '*:command:_command_names -e' && ret=0

return ret
