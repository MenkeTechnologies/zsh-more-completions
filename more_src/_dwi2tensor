#compdef dwi2tensor
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwi2tensor.html
# Source: MRtrix3/mrtrix3 cmd/dwi2tensor.cpp — diffusion-tensor estimation from DWI (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-ols[initial fit with ordinary least-squares]' \
    '-mask+[restrict computation to mask]:file:_files -g "*.{nii,nii.gz,mif}"' \
    '-b0+[output b=0 image]:file:_files' \
    '-dkt+[output diffusion-kurtosis tensor]:file:_files' \
    '-iter+[IWLS iterations (0-10)]:n:_default' \
    '-predicted_signal+[output predicted DWI]:file:_files' \
    '-grad+[MRtrix gradient file]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '1:dwi (input):_files -g "*.{nii,nii.gz,mif}"' \
    '2:dt (output):_files' \
    && ret=0

return ret
