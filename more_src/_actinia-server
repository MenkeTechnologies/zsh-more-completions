#compdef actinia-server
# Documentation: https://man.archlinux.org/search?q=actinia-server
# Reference accessed: 2026-05-16

# actinia-server — pyproject [project.scripts] → actinia_core.cli.actinia_server:main
# (https://github.com/actinia-org/actinia-core). argparse: --host --port --debug.

local ret=1

_arguments -s -S \
  '--host=[bind address]:host:(0.0.0.0 localhost)' \
  '--port=[listen port]:port' \
  '--debug=[enable debug mode]:bool:(True False)' && ret=0

return ret
