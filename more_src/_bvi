#compdef bvi
# Documentation: https://bvi.sourceforge.net/man_bvi.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bvi — display-oriented editor for binary files (hex editor based on vi).

_arguments -s -S \
  '-R[read-only mode]' \
  '-c+[execute ex command after first file loaded]:cmd:' \
  '-f+[load script file of ex commands]:script:_files' \
  '-s+[skip N bytes from start (supports 0x hex / 0 octal / b k m suffix)]:skip:' \
  '-e+[load file up to specified end address]:end:' \
  '-n+[load only N bytes]:length:' \
  '*:file:_files'
