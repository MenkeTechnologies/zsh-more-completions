#compdef airflow
# _airflow-cli — Apache Airflow CLI (Python orchestration DAG runner; subcommands: dags, tasks, db, users, roles, connections, variables, pools, providers, jobs, plugins, info, config, kerberos, rotate-fernet-key, version, celery, scheduler, webserver, standalone, triggerer, dag-processor, cheat-sheet, sync-perm, info; --verbose, --output, --json)
# upstream: https://github.com/apache/airflow
# Subcommands from Apache Airflow airflow/cli on tip.

_airflow-cli() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-o+[output format]:format:(table json yaml plain)' \
        '--output+[output format]:format:(table json yaml plain)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'airflow command' '(dags tasks db users roles connections variables pools providers jobs plugins info config kerberos rotate-fernet-key version celery scheduler webserver standalone triggerer dag-processor cheat-sheet sync-perm internal-api)' ;;
        args)
            case $line[1] in
                dags) _describe -t commands 'dags subcommand' '(backfill delete deserialize-json export-yaml-summary list list-import-errors list-jobs list-runs next-execution pause reserialize show show-dependencies state test trigger unpause)' ;;
                tasks) _describe -t commands 'tasks subcommand' '(clear failed-deps list render run state states-for-dag-run test)' ;;
                db) _describe -t commands 'db subcommand' '(check check-migrations clean downgrade init reset shell upgrade migrate revision)' ;;
                users) _describe -t commands 'users subcommand' '(add-role create delete export import list remove-role reset-password)' ;;
                roles) _describe -t commands 'roles subcommand' '(add-perms create del-perms delete export import list)' ;;
                connections) _describe -t commands 'connections subcommand' '(add delete export get import list test create-default-connections)' ;;
                variables) _describe -t commands 'variables subcommand' '(delete export get import list set)' ;;
                providers) _describe -t commands 'providers subcommand' '(get hooks lazy-loaded links list logging widgets connection-form configs)' ;;
                jobs) _describe -t commands 'jobs subcommand' '(check)' ;;
                config) _describe -t commands 'config subcommand' '(get-value list update-defaults)' ;;
            esac
            ;;
    esac
}

_airflow-cli "$@"
