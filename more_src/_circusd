#compdef circusd

# Completion for circusd - Circus process and socket manager daemon

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--log-level=[log level]:level:(debug info warning error critical)' \
  '--log-output=[log output file]:log file:_files' \
  '--daemon[daemonize circusd]' \
  '--pidfile=[PID file]:pid file:_files' \
  '--httpd[enable HTTP admin interface]' \
  '--httpd-host=[HTTP admin host]:host' \
  '--httpd-port=[HTTP admin port]:port' \
  '--endpoint=[ZMQ endpoint]:endpoint' \
  '--pubsub-endpoint=[ZMQ pubsub endpoint]:endpoint' \
  '--stats-endpoint=[ZMQ stats endpoint]:endpoint' \
  '1:config file:_files -g "*.{ini,conf}"' && ret=0

return ret
