#compdef circusd
# Documentation: https://circus.readthedocs.io/en/latest/man/circusd/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# circusd: Circus process and socket manager daemon
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--log-level=[log level]:level:(debug info warning error critical)' \
  '--log-output=[log output file ("-" for stdout)]:log file:_files' \
  '--logger-config=[Python logger config (INI/JSON/YAML)]:file:_files' \
  '--daemon[run in background]' \
  '--pidfile=[PID file]:pid file:_files' \
  '1:config file:_files -g "*.{ini,conf}"' && ret=0

return ret
