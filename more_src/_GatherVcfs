#compdef GatherVcfs
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#GatherVcfs
# Picard: concatenate VCF files of the same set of samples in genomic order

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  '*'{-I=,--INPUT=}'[input VCF file(s) in genomic order]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  {-O=,--OUTPUT=}'[output VCF file]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '--QUIET=[suppress job-summary info on stderr]:bool:(true false)' \
  '--CREATE_INDEX=[create a BAM/VCF index when writing]:bool:(true false)' \
  '--CREATE_MD5_FILE=[create an MD5 digest for output]:bool:(true false)' \
  '*:vcf file:_files -g "*.(vcf|vcf.gz|bcf)"' && ret=0

return ret
