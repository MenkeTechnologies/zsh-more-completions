#compdef masscan
# _masscan — Robert David Graham's masscan (asynchronous Internet-scale TCP port scanner; raw-socket sender capable of millions of pps with PF_RING)
# upstream: https://github.com/robertdavidgraham/masscan
# Flags from doc/masscan.8.markdown on tip; nmap-compatible aliases are documented under `--nmap`.

_masscan() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '*--range=[IP/range/CIDR to scan]:target:' \
        '(-p --ports)'{-p+,--ports=}'[ports to scan (comma/range, U:N for UDP)]:ports:' \
        '--rate=[packets per second to transmit]:n:' \
        '(-c --conf)'{-c+,--conf=}'[configuration file]:file:_files' \
        '--resume=[resume a previously paused scan]:file:_files' \
        '--echo[dump current config and exit]' \
        '(-e --adapter)'{-e+,--adapter=}'[network interface to use]:iface:_net_interfaces' \
        '--adapter-ip=[source IP (single or power-of-2 range)]:ip:' \
        '--source-ip=[source IP (alias for --adapter-ip)]:ip:' \
        '--adapter-port=[source port (single or power-of-2 range)]:port:' \
        '--adapter-mac=[source MAC address]:mac:' \
        '--adapter-vlan=[802.1q VLAN ID]:vlanid:' \
        '--router-mac=[gateway destination MAC]:mac:' \
        '--ping[also send ICMP echo requests]' \
        '*--exclude=[blacklist IP/range/CIDR]:target:' \
        '--excludefile=[file of exclude ranges]:file:_files' \
        '(-iL --includefile)'{-iL+,--includefile=}'[file of target ranges]:file:_files' \
        '--append-output[append to output file instead of overwriting]' \
        '--iflist[list adapters and exit]' \
        '--retries=[retries per port (1s interval)]:n:' \
        '--nmap[print nmap-compatible option aliases]' \
        '--pcap-payloads=[libpcap UDP payloads for matching dest ports]:file:_files' \
        '--nmap-payloads=[nmap-payloads file]:file:_files' \
        '--http-cookie=[set HTTP Cookie header]:val:' \
        '--http-field=[set arbitrary HTTP header (NAME: value)]:hdr:' \
        '--http-host=[set HTTP Host header]:host:' \
        '--http-method=[HTTP method]:method:' \
        '--http-url=[HTTP request URL]:url:' \
        '--http-user-agent=[User-Agent header]:ua:' \
        '--http-version=[HTTP version string]:ver:' \
        '--hello-string=[client hello string for banner grab]:str:' \
        '--hello-file=[client hello file for banner grab]:file:_files' \
        '--banners[grab banners after TCP connect]' \
        '--banner[alias for --banners]' \
        '--interactive[show found IPs live as they come in]' \
        '--offline[do not send packets (test mode)]' \
        '--pcap-payloads[same as --pcap-payloads]' \
        '--packet-trace[print every packet sent/received (debug)]' \
        '--pfring[use PF_RING zero-copy interface]' \
        '--readscan=[parse a saved binary scan result]:file:_files' \
        '--regress[run internal regression tests and exit]' \
        '--shard=[node ID in a shard]:n:' \
        '--shards=[total shards in this scan]:n:' \
        '--wait=[seconds to wait after sending all packets]:sec:' \
        '--output-filename=[output file]:file:_files' \
        '--output-format=[output format]:fmt:(xml binary grepable list json ndjson hostonly unicornscan)' \
        '-oB+[binary output file (alias for --output-format binary)]:file:_files' \
        '-oX+[XML output file]:file:_files' \
        '-oL+[list output file]:file:_files' \
        '-oG+[grepable output file]:file:_files' \
        '-oJ+[json output file]:file:_files' \
        '-oD+[ndjson output file]:file:_files' \
        '-oU+[unicornscan output file]:file:_files' \
        '*:target:'
}

_masscan "$@"
