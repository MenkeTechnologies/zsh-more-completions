#compdef cdda2ogg cdda2mp3
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/cdda2ogg.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cdda2ogg/cdda2mp3 are shell wrappers around icedax/cdda2wav. They take a
# single optional positional argument (FILEPREFIX) and are configured via
# environment variables (CDDA_DEVICE, LIST, CDDA2WAV, CDDA2WAV_OPTS,
# MP_CODER, MP_OPTIONS, FILEPREFIX). No CLI flags are documented.

_arguments \
  '1:file prefix:'

