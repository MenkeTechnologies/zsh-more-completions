#compdef watchman-diag

local -a arguments

arguments=(
    '--help[Show help message]'
    '-h[Show help message]'
    '--sockname=[Specify socket name]:socket path:_files'
    '-U[Specify socket name]:socket path:_files'
    '--logfile=[Specify log file]:log file:_files'
    '--log-level=[Set log level]:level:(off error warn info debug)'
    '--statefile=[Specify state file]:state file:_files'
    '--no-pretty[Disable pretty printing of JSON]'
    '--json-command[Accept commands in JSON format]'
    '--server-encoding=[Set server encoding]:encoding:(bser json)'
    '--output-encoding=[Set output encoding]:encoding:(bser json)'
    '--persistent[Persistent connection]'
    '-p[Persistent connection]'
    '--no-spawn[Do not spawn the service]'
    '--no-local[Do not use local transport]'
)

_arguments -s -S $arguments
