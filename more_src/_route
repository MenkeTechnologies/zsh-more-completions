#compdef route
# _route — OpenBSD route (view + manipulate IPv4/IPv6 kernel routing tables; only the superuser may modify; routing-domain selectable via -T)
# upstream: https://github.com/openbsd/src (sbin/route)
# Flags + commands from sbin/route/route.8 on tip.

_route() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-d[dry run (no kernel updates)]' \
        '-n[numeric output]' \
        '-q[quiet (suppress feedback)]' \
        '-t[skip changing kernel; print messages]' \
        '-v[verbose]' \
        '-T+[routing table id]:rtable:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'route command' \
                '(add:add a route delete:delete a route change:change route flags/gateway exec:run command in a routing domain flush:flush routes get:look up a route monitor:print routing socket messages nameserver:set nameservers for rdomain show:show routing table sourceaddr:set a source address for a rdomain)'
            ;;
    esac
}

_route "$@"
