#compdef autoflake

# Zsh completion for autoflake - removes unused imports and variables from Python code

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--check[return error code if changes are needed]' \
  '--diff[print diff for fixed files]' \
  '(-i --in-place)'{-i,--in-place}'[make changes in-place]' \
  '(-r --recursive)'{-r,--recursive}'[drill down directories recursively]' \
  '*--exclude=[exclude files/directories matching glob pattern]:glob pattern:' \
  '*--imports=[only remove specified unused imports]:module list:' \
  '--expand-star-imports[expand wildcard star imports]' \
  '--remove-all-unused-imports[remove all unused imports]' \
  '--ignore-init-module-imports[exclude __init__.py when removing imports]' \
  '--remove-duplicate-keys[remove duplicate keys in objects]' \
  '--remove-unused-variables[remove unused variables]' \
  '--ignore-pass-statements[ignore pass statements]' \
  '--ignore-pass-after-docstring[ignore pass statements after docstrings]' \
  '--quiet[suppress output]' \
  '*:files:_files -g "*.py"'
