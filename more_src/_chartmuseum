#compdef chartmuseum
# Documentation: https://chartmuseum.com/docs/
# Source: upstream README + chartmuseum/chartmuseum repo
# Reference accessed: 2026-05-30
# chartmuseum — Helm chart-repository server. Single Go binary, run as a
# server. Wide flag set: 60+ knobs covering 12+ storage backends, auth,
# TLS, multitenancy, caching, and Prometheus metrics. Every flag has an
# equivalent UPPERCASE env var; this completion covers the flag side only.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[print version]' \
  '--config=[ChartMuseum config file]:file:_files -g "*.(yaml|yml|json|toml)"' \
  '--debug[enable debug messages]' \
  '--log-json[output structured JSON logs]' \
  '--log-health[log inbound /health requests]' \
  '--log-latency-integer[log latency as nanosecond integer instead of string]' \
  '--port=[port to listen on]:port:' \
  '--listen-host=[host to listen on]:host:_hosts' \
  '--read-timeout=[read socket timeout (seconds)]:seconds:' \
  '--write-timeout=[write socket timeout (seconds)]:seconds:' \
  '--basic-auth-user=[basic-auth username]:user:' \
  '--basic-auth-pass=[basic-auth password]:pass:' \
  '--auth-anonymous-get[allow anonymous GET even with auth]' \
  '--bearer-auth[enable bearer-token auth]' \
  '--auth-realm=[bearer authorization-server URL]:url:' \
  '--auth-service=[bearer authorization-server service name]:service:' \
  '--auth-cert-path=[authorization-server PEM cert]:file:_files -g "*.(pem|crt)"' \
  '--auth-actions-search-path=[JMESPath for allowed actions in JWT]:jmespath:' \
  '--tls-cert=[TLS cert chain file]:file:_files -g "*.(pem|crt)"' \
  '--tls-key=[TLS key file]:file:_files -g "*.(pem|key)"' \
  '--tls-ca-cert=[TLS CA cert file]:file:_files -g "*.(pem|crt)"' \
  '--cors-allow-origin=[Access-Control-Allow-Origin value]:origin:' \
  '--storage=[storage backend]:backend:(local amazon google microsoft oracle alibaba baidu tencent openstack etcd)' \
  '--storage-local-rootdir=[local storage root directory]:dir:_files -/' \
  '--storage-amazon-bucket=[S3 bucket name]:bucket:' \
  '--storage-amazon-prefix=[S3 key prefix]:prefix:' \
  '--storage-amazon-region=[AWS region]:region:(us-east-1 us-east-2 us-west-1 us-west-2 ca-central-1 eu-west-1 eu-west-2 eu-west-3 eu-central-1 eu-north-1 ap-south-1 ap-southeast-1 ap-southeast-2 ap-northeast-1 ap-northeast-2 ap-northeast-3 sa-east-1)' \
  '--storage-amazon-endpoint=[alternative S3 endpoint URL]:url:' \
  '--storage-amazon-sse=[S3 server-side encryption (e.g. AES256, aws:kms)]:algo:(AES256 aws:kms)' \
  '--storage-google-bucket=[GCS bucket name]:bucket:' \
  '--storage-google-prefix=[GCS object prefix]:prefix:' \
  '--storage-microsoft-container=[Azure blob container]:container:' \
  '--storage-microsoft-prefix=[Azure blob prefix]:prefix:' \
  '--storage-oracle-bucket=[Oracle bucket]:bucket:' \
  '--storage-oracle-prefix=[Oracle key prefix]:prefix:' \
  '--storage-oracle-region=[Oracle Cloud region]:region:' \
  '--storage-oracle-compartmentid=[Oracle compartment OCID]:ocid:' \
  '--storage-alibaba-bucket=[Alibaba OSS bucket]:bucket:' \
  '--storage-alibaba-prefix=[Alibaba OSS prefix]:prefix:' \
  '--storage-alibaba-endpoint=[Alibaba OSS endpoint]:url:' \
  '--storage-alibaba-sse=[Alibaba OSS encryption]:algo:(AES256 KMS)' \
  '--storage-baidu-bucket=[Baidu BOS bucket]:bucket:' \
  '--storage-baidu-prefix=[Baidu BOS prefix]:prefix:' \
  '--storage-baidu-endpoint=[Baidu BOS endpoint]:url:' \
  '--storage-tencent-bucket=[Tencent COS bucket]:bucket:' \
  '--storage-tencent-prefix=[Tencent COS prefix]:prefix:' \
  '--storage-tencent-endpoint=[Tencent COS endpoint]:url:' \
  '--storage-openstack-container=[OpenStack container]:container:' \
  '--storage-openstack-prefix=[OpenStack prefix]:prefix:' \
  '--storage-openstack-region=[OpenStack region]:region:' \
  '--storage-openstack-auth=[OpenStack auth version]:v:(v1 auto)' \
  '--storage-openstack-cacert=[OpenStack CA cert file]:file:_files -g "*.(pem|crt)"' \
  '--storage-etcd-endpoint=[etcd endpoint]:url:' \
  '--storage-etcd-prefix=[etcd key prefix]:prefix:' \
  '--storage-etcd-cafile=[etcd CA file]:file:_files -g "*.(pem|crt)"' \
  '--storage-etcd-certfile=[etcd cert file]:file:_files -g "*.(pem|crt)"' \
  '--storage-etcd-keyfile=[etcd key file]:file:_files -g "*.(pem|key)"' \
  '--storage-timestamp-tolerance=[timestamp-drift tolerance]:duration:' \
  '--chart-url=[absolute URL for .tgz files in index.yaml]:url:' \
  '--chart-post-form-field-name=[form field for chart file]:name:' \
  '--prov-post-form-field-name=[form field for prov file]:name:' \
  '--max-upload-size=[max POST body size (bytes, default 20971520)]:bytes:' \
  '--max-storage-objects=[max objects per tenant]:N:' \
  '--allow-overwrite[allow chart re-upload without ?force]' \
  '--disable-force-overwrite[disallow re-upload even with ?force]' \
  '--disable-delete[disable DELETE route]' \
  '--disable-api[disable all /api routes (read-only mode)]' \
  '--gen-index[generate index.yaml, print to stdout, exit]' \
  '--disable-statefiles[disable index-cache.yaml usage]' \
  '--index-limit=[parallel scan limit for repo indexer]:N:' \
  '--cache=[cache store]:store:(redis)' \
  '--cache-interval=[delta cache update interval]:duration:' \
  '--cache-redis-addr=[redis address (host\:port)]:host:port:' \
  '--cache-redis-db=[redis database number]:N:' \
  '--cache-redis-password=[redis password]:pass:' \
  '--depth=[nested-repo depth for multitenancy]:N:' \
  '--depth-dynamic[allow dynamic depth levels]' \
  '--context-path=[base context path]:path:' \
  '--enable-metrics[enable Prometheus /metrics endpoint]' \
  && ret=0

return ret
