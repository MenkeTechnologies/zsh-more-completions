#compdef diffsitter

# Zsh completion for diffsitter (AST-based diff tool)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--color=[colorize output]:when:(auto on off)' \
  '--no-color[disable color output]' \
  '-l+[language to use for parsing]:language:(bash c c-sharp cpp css go html java javascript json kotlin lua php python ruby rust scala swift toml typescript yaml)' \
  '--language=[language to use for parsing]:language:(bash c c-sharp cpp css go html java javascript json kotlin lua php python ruby rust scala swift toml typescript yaml)' \
  '--config=[path to config file]:file:_files' \
  '--exclude-kinds=[node kinds to exclude]:kinds' \
  '--sort[sort nodes before diffing]' \
  '--no-sort[do not sort nodes before diffing]' \
  '-d[use double-column output]' \
  '--double-column[use double-column output]' \
  '-W+[width for double column output]:width' \
  '--width=[width for double column output]:width' \
  '--dump-config[dump default config]' \
  '--list-languages[list supported languages]' \
  '--generate-completion=[generate shell completion]:shell:(bash fish zsh powershell elvish)' \
  '1:old file:_files' \
  '2:new file:_files'
