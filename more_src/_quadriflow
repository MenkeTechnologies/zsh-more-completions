#compdef quadriflow
# Documentation: https://github.com/hjwdzh/QuadriFlow
# QuadriFlow: scalable and robust quadrangulation of triangle meshes

local ret=1

_arguments -s -S \
  '-i[input triangle mesh (OBJ)]:input:_files -g "*.obj"' \
  '-o[output quad mesh (OBJ)]:output:_files -g "*.obj"' \
  '-f[desired number of faces in output quad mesh]:faces:' \
  '-mcf[use adaptive network simplex minimum-cost flow solver]' \
  '-sharp[detect and preserve sharp edges]' \
  '-sat[use SAT solver for flip removal (Unix only; needs minisat, timeout)]' && ret=0

return ret
