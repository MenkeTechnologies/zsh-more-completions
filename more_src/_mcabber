#compdef mcabber
# Documentation: https://man.archlinux.org/search?q=mcabber
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --config-file)'{-f,--config-file}'+[use config file]:config:_files' && ret=0

return ret
