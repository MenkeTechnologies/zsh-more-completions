#compdef mcabber
# Documentation: https://mcabber.com/files/mcabber.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-h[quick help usage message]' \
  '-V[display version and compile-time definitions]' \
  '-f+[use configuration file]:configfile:_files' && ret=0

return ret
