#compdef below
# Documentation: https://github.com/facebookincubator/below
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for below - system monitor from Meta

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'live:view live system data'
      'record:record system data'
      'replay:replay historical system data'
      'dump:report script-friendly information (JSON, CSV, OpenMetrics, etc.)'
      'snapshot:create a replayable snapshot file of historical data'
    )
    _describe -t commands 'below command' commands && ret=0
    ;;
  args)
    case $line[1] in
      live)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--host=[remote host]:host' \
          '--port=[remote port]:port' \
          && ret=0
        ;;
      record)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--retain-for-s=[retention time in seconds]:seconds' \
          '--store-dir=[data store directory]:directory:_directories' \
          '--compress[compress stored data]' \
          '--skew-detection-threshold=[clock skew threshold]:threshold' \
          '--collect-io-stat[collect I/O stats]' \
          '--debug[enable debug logging]' \
          && ret=0
        ;;
      replay)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--host=[remote host]:host' \
          '--port=[remote port]:port' \
          '(-t --time)'{-t,--time}'=[replay from this time]:time' \
          && ret=0
        ;;
      dump)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--time=[time to dump]:time' \
          '--host=[remote host]:host' \
          '--port=[remote port]:port' \
          '--everything[dump all data]' \
          '--output=[output format]:format:(json csv openmetrics)' \
          && ret=0
        ;;
      snapshot)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
