#compdef python3.13 python3.14 python3.15
# _python3.13 — CPython 3.13 (newer minor versions installed as a separate stem; same flags as python3.x: -V version, -c expr, -m module, -O optimize, -OO, -B no .pyc, -E ignore PYTHON*, -I isolated, -X opt=value, -W warning filter, -t/-tt tab checks dropped in 3.13)
# upstream: https://github.com/python/cpython
# Flags from python3 cpython Modules/main.c on tip.

_python3.13() {
    _arguments \
        '-V[show version]' \
        '--version[show version]' \
        '-h[show help]' \
        '-c+[execute expression]:expr:' \
        '-m+[run module]:module:' \
        '-O[basic optimizations]' \
        '-OO[strip docstrings + asserts]' \
        '-B[do not write .pyc]' \
        '-E[ignore PYTHON* env vars]' \
        '-I[isolated]' \
        '-q[quiet]' \
        '-s[no user site]' \
        '-S[no site init]' \
        '-u[unbuffered stdio]' \
        '*-v[verbose]' \
        '*-W+[warning filter]:filter:(default error always module once ignore)' \
        '*-X+[implementation option]:option:(dev faulthandler frozen_modules importtime no_debug_ranges pycache_prefix showrefcount tracemalloc utf8 warn_default_encoding gil int_max_str_digits perf perf_jit cpu_count int_max_str_digits)' \
        '-d[debug parser]' \
        '*-P[no script directory in sys.path]' \
        '*:script:_files -g "*.py"'
}

_python3.13 "$@"
