#compdef 1panel 1pctl
# _1panel — modern open-source VPS control panel (1Panel-dev/1Panel)
# upstream: https://github.com/1Panel-dev/1Panel
# Subcommands from core/cmd/server/cmd/*.go (cobra).

_1panel() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-l --language)'{-l+,--language=}'[CLI language]:lang:(en zh)' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_1panel_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                app)
                    _arguments \
                        '1: :(init)' && ret=0 ;;
                reset)
                    _arguments \
                        '1: :(mfa https ips entrance domain passkey)' && ret=0 ;;
                update)
                    _arguments \
                        '1: :(username password port)' \
                        '*:value:' && ret=0 ;;
                listen-ip)
                    _arguments \
                        '1: :(ipv4 ipv6)' && ret=0 ;;
                restore)
                    _arguments '1:backup file:_files -g "*.(tar|tar.gz|zip)"' && ret=0 ;;
                user-info|user-list|version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_1panel_commands] )) ||
_1panel_commands() {
    local -a commands
    commands=(
        'app:application related operations (init)'
        'reset:reset mfa / https / ips / entrance / domain / passkey'
        'update:update username / password / port'
        'listen-ip:toggle IPv4 / IPv6 listener'
        'restore:restore panel from a backup file'
        'user-info:show login credentials of the current admin'
        'user-list:list all 1Panel users'
        'version:print 1Panel version'
    )
    _describe -t commands '1panel command' commands
}

_1panel "$@"
