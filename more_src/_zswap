#compdef zswap
# _zswap — zswap kernel compressed cache control via sysfs; helper wrapper writes to /sys/module/zswap/parameters/*
# upstream: kernel.org Documentation/admin-guide/mm/zswap.rst

_zswap() {
    local -a sub=(
        'enable:turn zswap on'
        'disable:turn zswap off'
        'status:print enabled state'
        'compressor:get/set compressor'
        'zpool:get/set zpool backend'
        'max_pool_percent:get/set max pool percent'
        'shrinker_enabled:get/set shrinker enabled'
        'accept_threshold_percent:get/set accept threshold percent'
        'same_filled_pages_enabled:get/set same-filled pages enabled'
        'non_same_filled_pages_enabled:get/set non-same-filled pages enabled'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zswap subcommand' sub ;;
        args)
            case $words[1] in
                compressor) _arguments '1:algorithm:(lzo lz4 lz4hc zstd 842 deflate lzo-rle)' ;;
                zpool) _arguments '1:backend:(zsmalloc zbud z3fold)' ;;
                max_pool_percent|accept_threshold_percent) _arguments '1:percent:' ;;
                shrinker_enabled|same_filled_pages_enabled|non_same_filled_pages_enabled) _arguments '1:bool:(Y N)' ;;
            esac
            ;;
    esac
}

_zswap "$@"
