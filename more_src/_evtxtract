#compdef evtxtract
# Documentation: https://github.com/williballenthin/EVTXtract/blob/master/evtxtract/main.py
# recover and reconstruct EVTX log records from raw binary data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable debug logging]' \
  '(-q --quiet)'{-q,--quiet}'[disable all output but errors]' \
  '(-s --split)'{-s,--split}'[split each event into its own file]' \
  '(-o --out)'{-o,--out}'=[output directory to store split files]:dir:_files -/' \
  '1:input:_files' && ret=0

return ret
