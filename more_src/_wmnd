#compdef wmnd

# wmnd: Window Maker network monitor dockapp
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-display[X display]:display:' \
  '-i[interface]:iface:' \
  '-d[switch with mouse]' \
  '-bw[broadcast window size]:n:' \
  '-W[show interface name]' \
  '-icon[icon file]:file:_files' \
  '-r[refresh rate (ms)]:ms:' \
  '-pen[pen color]:color:' \
  '-warn[warn color]:color:' \
  '-light[light color]:color:' \
  '-bg[bg color]:color:' \
  '-fg[fg color]:color:' \
  '-T[traffic display type]:type:(rate counter)' \
  '-d[scale]:scale:' \
  '-x[interface label]:label:' \
  '*::wmnd args:_files' && ret=0
return ret
