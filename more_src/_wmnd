#compdef wmnd
# Documentation: https://manpages.debian.org/bookworm/wmnd/wmnd.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian bookworm wmnd(1) man page OPTIONS list.

# wmnd: Window Maker network monitor dockapp
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show options summary]' \
  '(- *)-v[show version]' \
  '-i+[select starting interface]:interface' \
  '-I+[interfaces to monitor]:interfaces' \
  '-D+[select driver]:driver' \
  '-l[start with long device names]' \
  '-m[hide maximal values at startup]' \
  '-t[hide ppp connection time]' \
  '-M[use maximal values from entire history]' \
  '-w+[display mode]:mode' \
  '-r+[refresh rate in microseconds]:rate' \
  '-s+[scroll rate in tenths of seconds]:rate' \
  '-S+[scroll steps before updating speed indicator]:steps' \
  '-b[use base-2 scaling instead of base-10]' \
  '-c+[transmission color]:color' \
  '-C+[reception color]:color' \
  '-L+[middle line color]:color' \
  '-d+[X11 display]:display' \
  '-f+[alternate config file]:file:_files' \
  '-F[do not parse ~/.wmndrc]' \
  '-q[quiet (errors only)]' \
  '-Q[show informational messages]' \
  '-o+[smoothing factor (0 to 1)]:factor' \
  '-a+[fixed scale for byte modes]:bytes' \
  '-n+[class/title name]:name' && ret=0
return ret
