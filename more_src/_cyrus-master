#compdef cyrus-master
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/master.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org master(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-master: Cyrus master process controller
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-M[alternate cyrus.conf]:file:_files' \
  '-l[listen queue backlog (default 32)]:n:' \
  '-j[janitor sweep frequency per second]:hz:' \
  '-p[alternate pidfile]:file:_files' \
  '-r[alternate ready file]:file:_files' \
  '(-D)-d[start in daemon mode]' \
  '(-d)-D[do not close stdin/stdout/stderr (debug)]' \
  '-L[redirect stdout/stderr to logfile]:file:_files' && ret=0
return ret
