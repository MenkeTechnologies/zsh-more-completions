#compdef lvrename
# _lvrename — rename a logical volume (LVM2)
# upstream: https://gitlab.com/lvmteam/lvm2

_lvrename() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-A --autobackup)'{-A,--autobackup}'+[autobackup]:bool:(y n)' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-t --test)'{-t,--test}'[dry run]' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '1:vg or old name:' \
        '2:new name:' \
        '3:third arg:'
}

_lvrename "$@"
