#compdef zeditor
# Documentation: https://zed.dev/docs/reference/cli
# Zed editor command-line interface (Linux binary name)

local ret=1

_arguments -s \
  '(-w --wait)'{-w,--wait}'[wait for opened files to be closed before exiting]' \
  '(-n --new)'{-n,--new}'[open paths in a new workspace window]' \
  '(-a --add)'{-a,--add}'[add paths to the focused workspace]' \
  '(-r --reuse)'{-r,--reuse}'[reuse an existing window, replacing its workspace]' \
  '*--diff[open a diff view comparing two files]:old:_files:new:_files' \
  '--foreground[run Zed in the foreground, keeping terminal attached]' \
  '--user-data-dir=[custom directory for user data]:dir:_files -/' \
  '(-v --version)'{-v,--version}'[print version and exit]' \
  '--uninstall[uninstall Zed and remove related files]' \
  '--zed=[custom path to the Zed application or binary]:path:_files' \
  '*:file:_files' && ret=0

return ret
