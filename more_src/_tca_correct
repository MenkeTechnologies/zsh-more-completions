#compdef tca_correct
# Documentation: https://man.archlinux.org/man/tca_correct.1.en
# tca_correct: calculate transverse chromatic aberration correction

local ret=1

_arguments -s \
  '-h[display help]' \
  '-l[input file is a PTO file instead of an image]' \
  '-m+[optimization method (0 normal, 1 newfit)]:method:(0 1)' \
  '-o+[string of variables to optimize (abcvde)]:optvars:' \
  '-r[reset values (zero a,b,c,d,e and set v to 10)]' \
  '-s+[scale for corner detection]:scale:' \
  '-n+[number of points per grid cell (default 10)]:number:' \
  '-g+[divide image in NxN grid cells (default 10)]:number:' \
  '-t+[remove control points with error higher than num pixels]:num:' \
  '-v[verbose]' \
  '--save-into-database[save tca data into Hugin lens database]' \
  '-w+[write PTO file]:file:_files -g "*.pto"' \
  '-R+[use this file as red channel]:file:_files' \
  '-G+[use this file as green channel]:file:_files' \
  '-B+[use this file as blue channel]:file:_files' \
  '*:image:_files' && ret=0

return ret
