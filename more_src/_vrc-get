#compdef vrc-get

# Zsh completion for vrc-get (anatawa12/vrc-get, clap 4 CLI).

local curcontext="$curcontext" state line ret=1
local -a vcmds repocmds upkgs infocmds migcmds cachecmds vcccmds projcmds unitycmds

vrc_get_env=(
  '--offline[use local caches only; disables network]'
  '--no-update[do not refresh local repository metadata]'
)

vcmds=(
  'install:add or resolve packages in a Unity project'
  'i:alias for install'
  'resolve:(re)install locked packages to satisfy the lockfile'
  'remove:remove packages from the project'
  'rm:alias for remove'
  'reinstall:reinstall named packages'
  'update:refresh cached repository metadata'
  'outdated:list newer package versions than the lockfile'
  'upgrade:upgrade some or all locked dependencies'
  'downgrade:pin a package to an older version'
  'search:search packages by substring in metadata fields'
  'repo:manage curated package repositories'
  'user-package:manage local user packages'
  'info:inspect a project or package index entry'
  'migrate:migrate a Unity or legacy VRCSDK project'
  'cache:manage downloaded package caches'
  'vcc:experimental VRChat Creator Companion integration'
  'completion:emit shell completion scripts'
)

repocmds=(
  'list:list configured repositories'
  'add:add a local path or remote URL as a repository'
  'remove:remove repositories by id, URL, name, or path'
  'cleanup:delete stray repo JSON files under the Repos directory'
  'packages:list packages available from a repository'
  'import:merge repositories listed in a repositories file'
  'export:print the repositories file format to stdout'
)

upkgs=(
  'list:list registered user packages'
  'add:register a folder as a user package'
  'remove:unregister a user package path'
)

infocmds=(
  'project:print human-readable or JSON project information'
  'package:print versions and metadata for a package name'
)

migcmds=(
  'unity2022:migrate the project manifest for Unity 2022'
  'vpm:convert a legacy unitypackage SDK layout to VPM'
)

cachecmds=(
  'clear:delete downloaded package archives from the cache'
)

vcccmds=(
  'project:list, add, or remove tracked Unity projects'
  'unity:list, add, remove, or refresh Unity Hub installations'
)

projcmds=(
  'list:list projects tracked in the VCC database'
  'add:register an existing Unity project directory'
  'remove:drop a project path from the VCC database'
)

unitycmds=(
  'list:list Unity editor paths registered for VCC'
  'add:register a Unity.exe installation path'
  'remove:remove an installation from the VCC list'
  'update:rescan installs using Unity Hub metadata'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->top' \
  '*::arg:->args' && ret=0

case $state in
  (top) _describe -t commands 'vrc-get command' vcmds && ret=0 ;;
  (args)
    case $line[1] in
      (install|i)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-n --name)'{-n,--name}'[match display names instead of package IDs]' \
          '--prerelease[allow prerelease package versions]' \
          '(-p --project)'{-p,--project=}'[Unity project directory]:project directory:_files -/' \
          '(-y --yes)'{-y,--yes}'[skip interactive confirmation prompts]' \
          "${(@)vrc_get_env}" \
          '::package ID:_default' \
          '::version:_default' && ret=0 ;;
      (resolve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --project)'{-p,--project=}'[Unity project directory]:project directory:_files -/' \
          "${(@)vrc_get_env}" && ret=0 ;;
      (remove|rm)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --project)'{-p,--project=}'[Unity project directory]:project directory:_files -/' \
          '(-y --yes)'{-y,--yes}'[skip interactive confirmation prompts]' \
          "${(@)vrc_get_env}" \
          '*:package names to remove:_default' && ret=0 ;;
      (reinstall)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --project)'{-p,--project=}'[Unity project directory]:project directory:_files -/' \
          '(-y --yes)'{-y,--yes}'[skip interactive confirmation prompts]' \
          "${(@)vrc_get_env}" \
          '*:package names to reinstall:_default' && ret=0 ;;
      (update) _arguments -s -S '(- *)'{-h,--help}'[show help]' && ret=0 ;;
      (outdated)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--prerelease[include prereleases when determining newer versions]' \
          '--json-format=[machine-readable output schema version]:version:' \
          '(-p --project)'{-p,--project=}'[Unity project directory]:project directory:_files -/' \
          "${(@)vrc_get_env}" && ret=0 ;;
      (upgrade)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--prerelease[allow prerelease targets]' \
          '(-p --project)'{-p,--project=}'[Unity project directory]:project directory:_files -/' \
          '(-y --yes)'{-y,--yes}'[skip interactive confirmation prompts]' \
          "${(@)vrc_get_env}" \
          '::package name:_default' \
          '::target version:_default' && ret=0 ;;
      (downgrade)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--prerelease[allow prerelease targets]' \
          '(-p --project)'{-p,--project=}'[Unity project directory]:project directory:_files -/' \
          '(-y --yes)'{-y,--yes}'[skip interactive confirmation prompts]' \
          "${(@)vrc_get_env}" \
          '1:package name:_default' \
          '2:target version:_default' && ret=0 ;;
      (search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          "${(@)vrc_get_env}" \
          '*:search tokens (all must match):_default' && ret=0 ;;
      (repo)
        if (( CURRENT == 3 )); then
          _describe -t commands 'repo command' repocmds && ret=0
        else
          case $words[3] in
            (list|cleanup|export)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                "${(@)vrc_get_env}" && ret=0 ;;
            (add)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '(-H --header)'{-H+,--header=}'[extra HTTP header NAME\:VALUE]:header:' \
                "${(@)vrc_get_env}" \
                '1:repository URL or filesystem path:_files' \
                '::friendly repository name:_default' && ret=0 ;;
            (remove)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '--id[match repository ID fields only]' \
                '--url[match repository remote URLs only]' \
                '--name[match configured display names only]' \
                '--path[match local checkout paths only]' \
                "${(@)vrc_get_env}" \
                '1:repository id URL name or path string:_default' && ret=0 ;;
            (packages)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                "${(@)vrc_get_env}" \
                '1:configured repo name or remote URL:_default' && ret=0 ;;
            (import)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '(-y --yes)'{-y,--yes}'[skip confirmation before adding remotes]' \
                "${(@)vrc_get_env}" \
                '1:repositories.txt compatible file:_files' && ret=0 ;;
          esac
        fi ;;
      (user-package)
        if (( CURRENT == 3 )); then
          _describe -t commands 'user-package command' upkgs && ret=0
        else
          case $words[3] in
            (list) _arguments -s -S '(- *)'{-h,--help}'[show help]' && ret=0 ;;
            (add|remove)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '1:package directory:_files -/' && ret=0 ;;
          esac
        fi ;;
      (info)
        if (( CURRENT == 3 )); then
          _describe -t commands 'info command' infocmds && ret=0
        else
          case $words[3] in
            (project)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '(-p --project)'{-p,--project=}'[Unity project directory]:project directory:_files -/' \
                '--json-format=[structured output schema version]:version:' && ret=0 ;;
            (package)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '--json-format=[structured output schema version]:version:' \
                "${(@)vrc_get_env}" \
                '1:package name:_default' && ret=0 ;;
          esac
        fi ;;
      (migrate)
        if (( CURRENT == 3 )); then
          _describe -t commands 'migrate command' migcmds && ret=0
        else
          case $words[3] in
            (unity2022)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '(-p --project)'{-p,--project=}'[Unity project directory]:project directory:_files -/' \
                '--unity=[Unity 2022 editor executable]:file:_files' \
                "${(@)vrc_get_env}" && ret=0 ;;
            (vpm)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '(-p --project)'{-p,--project=}'[Unity project directory]:project directory:_files -/' \
                "${(@)vrc_get_env}" && ret=0 ;;
          esac
        fi ;;
      (cache)
        if (( CURRENT == 3 )); then
          _describe -t commands 'cache command' cachecmds && ret=0
        else
          case $words[3] in
            (clear)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                "${(@)vrc_get_env}" && ret=0 ;;
          esac
        fi ;;
      (vcc)
        if (( CURRENT == 3 )); then
          _describe -t commands 'vcc command' vcccmds && ret=0
        elif (( CURRENT == 4 )); then
          case $words[3] in
            (project) _describe -t commands 'vcc project command' projcmds && ret=0 ;;
            (unity) _describe -t commands 'vcc unity command' unitycmds && ret=0 ;;
          esac
        else
          case $words[3] in
            (project)
              case $words[4] in
                (list)
                  _arguments -s -S \
                    '(- *)'{-h,--help}'[show help]' \
                    "${(@)vrc_get_env}" && ret=0 ;;
                (add|remove)
                  _arguments -s -S \
                    '(- *)'{-h,--help}'[show help]' \
                    "${(@)vrc_get_env}" \
                    '1:Unity project directory:_files -/' && ret=0 ;;
              esac ;;
            (unity)
              case $words[4] in
                (list)
                  _arguments -s -S \
                    '(- *)'{-h,--help}'[show help]' \
                    "${(@)vrc_get_env}" && ret=0 ;;
                (add|remove)
                  _arguments -s -S \
                    '(- *)'{-h,--help}'[show help]' \
                    "${(@)vrc_get_env}" \
                    '1:Unity editor path:_files' && ret=0 ;;
                (update)
                  _arguments -s -S \
                    '(- *)'{-h,--help}'[show help]' \
                    '--method=[how to query Unity Hub]:method:(read-config call-hub)' \
                    "${(@)vrc_get_env}" && ret=0 ;;
              esac ;;
          esac
        fi ;;
      (completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '::shell:(bash elvish fish powershell zsh)' && ret=0 ;;
    esac ;;
esac

return ret
