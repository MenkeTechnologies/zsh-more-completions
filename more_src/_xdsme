#compdef xdsme
# Documentation: https://github.com/legrandp/xdsme
# XDSME - XDS Made Easier, automated XDS data-processing pipeline

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-1[jump directly to processing step 1]' \
  '-2[jump directly to processing step 2]' \
  '-3[jump directly to processing step 3]' \
  '-4[jump directly to processing step 4]' \
  '-5[jump directly to processing step 5]' \
  '(-a --anomal)'{-a,--anomal}'[distinguish Friedel pairs for scaling and statistics]' \
  '(-A --Anomal)'{-A,--Anomal}'[like -a plus strict absorption correction]' \
  '(-b --beam-center-optimize-i)'{-b,--beam-center-optimize-i}'[optimize beam center using i-score ranking]' \
  '(-B --beam-center-optimize-z)'{-B,--beam-center-optimize-z}'[optimize beam center using z-score ranking]' \
  '(-c --cell)'{-c,--cell}'[set the expected cell]:cell:' \
  '(-d --distance)'{-d,--distance}'[set detector-to-crystal distance]:distance:' \
  '(-E --exec)'{-E,--exec}'[path to directory containing executables]:directory:_files -/' \
  '(-f --reference)'{-f,--reference}'[reference data set for XPLAN and CORRECT]:reference:_files' \
  '(-F --first-frame)'{-F,--first-frame}'[first frame for DATA_RANGE]:frame:' \
  '(-i --xds-input)'{-i,--xds-input}'[direct XDS keyword input]:keywords:' \
  '(-I --ice)'{-I,--ice}'[exclude resolution ranges with ice rings]' \
  '(-L --last-frame)'{-L,--last-frame}'[last frame for DATA_RANGE]:frame:' \
  '(-M --orientation-matrix)'{-M,--orientation-matrix}'[input crystal orientation matrix]:matrix file:_files' \
  '(-n --nthreads)'{-n,--nthreads}'[maximum number of processing threads]:threads:' \
  '(-O --oscillation)'{-O,--oscillation}'[frame oscillation range in degrees]:degrees:' \
  '(-p --project)'{-p,--project}'[project name for working directory]:project:' \
  '(-r --high-resolution)'{-r,--high-resolution}'[high resolution cutoff]:resolution:' \
  '(-R --low-resolution)'{-R,--low-resolution}'[low resolution cutoff (default 50)]:resolution:' \
  '(-s --spg)'{-s,--spg}'[expected space group by number or string]:space group:' \
  '(-S --strategy)'{-S,--strategy}'[calculate strategy then stop]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-w --wavelength)'{-w,--wavelength}'[set x-ray wavelength]:wavelength:' \
  '(-W --beam-center-swap)'{-W,--beam-center-swap}'[test beam-center permutations using z-score]' \
  '(-x --beam-x)'{-x,--beam-x}'[set ORGX detector origin X]:orgx:' \
  '(-y --beam-y)'{-y,--beam-y}'[set ORGY detector origin Y]:orgy:' \
  '(-X --xml)'{-X,--xml}'[generate XML output with scaling statistics]' \
  '--slow[set parameters for more accurate processing]' \
  '--weak[set parameters for indexing weak spots]' \
  '--brute[attempt hard indexing for resistant cases]' \
  '--invert[invert rotation axis]' \
  '--optimize[optimize profiles and re-run from step 4]' \
  '*:image files:_files' && ret=0

return ret
