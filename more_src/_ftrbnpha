#compdef ftrbnpha
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftrbnpha.html
# Compress a FITS PHA dataset to a given number of channels

local ret=1

_arguments -s -S \
  'infile=[input FITS PHA file to compress]:infile:_files' \
  'outfile=[output compressed PHA file]:outfile:_files' \
  'binfile=[text file of binning ranges and factors]:binfile:_files' \
  'phafile=[PHA file whose grouping defines binning]:phafile:_files' \
  'finchan=[number of channels in output]:finchan:' \
  'cmpmode=[compression method]:cmpmode:(LINEAR BRIGHT2LINEAR FAINT2BRIGHT)' \
  'properr=[combine channel errors in quadrature]:properr:(yes no)' \
  'error=[error calculation method]:error:(GAUSS POISS-0 POISS-1 POISS-2 POISS-3)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:file:_files' && ret=0

return ret
