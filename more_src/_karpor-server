#compdef karpor-server karpor-apiserver
# _karpor-server — KusionStack Karpor aggregated API server (multi-cluster Kubernetes search + insights with optional AI assistance)
# upstream: https://github.com/KusionStack/karpor
# Flags from cmd/karpor/app/server.go + cmd/karpor/app/options/{core_options,search_storage,ai,recommended}.go on tip.

_karpor-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '--enable-rbac[turn on RBAC authorization]' \
        '--read-only-mode[turn on read-only mode]' \
        '--github-badge[display the GitHub badge in the UI]' \
        '--search-storage-type=[search storage backend type]:type:(elasticsearch)' \
        '*--elastic-search-addresses=[Elasticsearch addresses]:url:_urls' \
        '--elastic-search-username=[Elasticsearch username]:user:' \
        '--elastic-search-password=[Elasticsearch password]:password:' \
        '--ai-backend=[AI backend]:backend:(openai azureopenai dashscope)' \
        '--ai-auth-token=[AI provider auth token]:token:' \
        '--ai-base-url=[AI provider base URL]:url:_urls' \
        '--ai-model=[AI model name]:model:' \
        '--ai-temperature=[AI generation temperature]:f:' \
        '--ai-top-p=[AI top-p]:f:' \
        '--ai-proxy-enabled[route AI traffic through a proxy]' \
        '--ai-http-proxy=[HTTP proxy for AI traffic]:url:' \
        '--ai-https-proxy=[HTTPS proxy for AI traffic]:url:' \
        '--ai-no-proxy=[csv of hosts excluded from AI proxy]:csv:' \
        '--service-account-signing-key-file=[SA token signing key file]:file:_files' \
        '--secure-port=[HTTPS port]:port:' \
        '--bind-address=[secure server bind address]:addr:' \
        '--tls-cert-file=[TLS certificate file]:file:_files' \
        '--tls-private-key-file=[TLS private key file]:file:_files' \
        '--client-ca-file=[client CA bundle]:file:_files' \
        '--feature-gates=[csv of feature gates]:gates:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr]:bool:(true false)'
}

_karpor-server "$@"
