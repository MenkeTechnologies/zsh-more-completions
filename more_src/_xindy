#compdef xindy
# _xindy — TeX Live xindy (multilingual replacement for makeindex; -L picks a language module, -C codepage, -M loads index style modules, -I input encoding (latin|utf8), -o output index, -t log, -g/--no-merge-rules special-cases)
# upstream: https://github.com/ku-tex/xindy
# Flags from xindy xindy.pl on tip.

_xindy() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-q[quiet]' \
        '-d[debug]' \
        '-L+[language module]:lang:(english german german-din5007 french spanish italian polish norwegian danish swedish finnish portuguese hungarian czech slovak russian ukrainian greek)' \
        '-C+[codepage]:codepage:(utf8 latin1 latin2 cp850 cp1250 cp1252 cp1257)' \
        '*-M+[style module]:module:' \
        '-I+[input encoding]:enc:(latin xindy utf8)' \
        '-o+[output index]:file:_files -g "*.ind"' \
        '-t+[log file]:file:_files -g "*.ilg"' \
        '-g[merge rules off]' \
        '--no-merge-rules[disable merge rules]' \
        '--filenameenc+[encoding for filenames]:enc:' \
        '*:idx file:_files -g "*.idx"'
}

_xindy "$@"
