#compdef cobaya-grid-copy
# Documentation: https://cobaya.readthedocs.io/en/latest/grids.html
# cobaya: copy or zip a grid of chains

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--dist[include getdist outputs]' \
  '--chains[include chain files]' \
  '--sym_link[just make symbolic links to source directories]' \
  '--no_config[do not copy grid config info]' \
  '--remove_burn_fraction=[fraction at start of chain to remove as burn in]:fraction' \
  '*--file_extensions=[extensions to include]:extension' \
  '*--skip_extensions=[extensions to skip]:extension' \
  '--max_age_days=[only include files with date stamp at most this old]:days' \
  '--dryrun[show what would be done without doing it]' \
  '--verbose[verbose output]' \
  '--zip[make a zip file]' \
  '1:grid directory:_files -/' \
  '2:target directory or zip:_files' && ret=0

return ret
