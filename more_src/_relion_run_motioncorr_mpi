#compdef relion_run_motioncorr_mpi
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: MPI beam-induced motion correction of movies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[STAR file or wildcard with input movies]:file:_files' \
  '--o=[name for the output directory]:dir:_files -/' \
  '--skip_logfile[skip generation of tracks-part of the logfile.pdf]' \
  '--j=[number of threads per movie (= process)]:value' \
  '--max_io_threads=[limit the number of IO threads]:value' \
  '--only_do_unfinished[only run for micrographs without output yet]' \
  '--do_at_most=[only process at most this many micrographs]:value' \
  '--grouping_for_ps=[group this many frames for power spectrum (-1=none)]:value' \
  '--ps_size=[output size of power spectrum]:value' \
  '--first_frame_sum=[first movie frame used in output sum]:value' \
  '--last_frame_sum=[last movie frame used in output sum (0=all)]:value' \
  '--eer_grouping=[EER grouping]:value' \
  '--eer_upsampling=[EER upsampling (1=physical, 2=2x super-resolution)]:value' \
  '--use_motioncor2[use Shawn Zheng MOTIONCOR2]' \
  '--motioncor2_exe=[location of MOTIONCOR2 executable]:file:_files' \
  '--bin_factor=[binning factor (can be non-integer)]:value' \
  '--bfactor=[B-factor (pix^2) used inside MOTIONCOR2]:value' \
  '--gainref=[location of MRC file with the gain reference]:file:_files' \
  '--gain_rot=[rotate gain reference times 90 degrees (0-3)]:value:(0 1 2 3)' \
  '--gain_flip=[flip gain reference (0, 1 or 2)]:value:(0 1 2)' \
  '--patch_x=[patching in X-direction for MOTIONCOR2]:value' \
  '--patch_y=[patching in Y-direction for MOTIONCOR2]:value' \
  '--group_frames=[average this many frames before beam-induced shifts]:value' \
  '--defect_file=[location of a defect file or defect map]:file:_files' \
  '--archive=[directory for archiving movies in 4-byte MRC]:dir:_files -/' \
  '--even_odd_split[generate odd/even summed images for denoising]' \
  '--other_motioncor2_args=[additional arguments to MOTIONCOR2]:args' \
  '--gpu[device ids for each MPI-thread, e.g 0:1:2:3]::device ids' \
  '--dose_weighting[use dose-weighting scheme]' \
  '--angpix=[pixel size (A)]:value' \
  '--voltage=[voltage (kV) for dose-weighting]:value' \
  '--dose_per_frame=[electron dose (e/A2/frame) for dose-weighting]:value' \
  '--preexposure=[pre-exposure (e/A2) for dose-weighting]:value' \
  '--use_own[use our own implementation of motion correction]' \
  '--float16[write in half-precision 16 bit floating point]' \
  '--skip_defect[skip hot pixel detection]' \
  '--save_noDW[save aligned but non dose weighted micrograph]' \
  '--max_iter=[maximum number of iterations for alignment]:value' \
  '--dose_motionstats_cutoff=[dose (e/A2) splitting early/late motion stats]:value' \
  '*:file:_files' && ret=0

return ret
