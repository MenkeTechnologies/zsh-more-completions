#compdef swift-account-server
# Documentation: https://manpages.debian.org/testing/swift-account/swift-account-server.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# OpenStack Swift account server daemon

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:swift config file:_files -g "*.conf"' && ret=0
return ret
