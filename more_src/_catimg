#compdef catimg
# Documentation: catimg --help (posva/catimg)
# Source: cat-image — render an image in the terminal using Unicode + ANSI colors.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(-w -H)-w+[terminal width / columns]:width:' \
    '(-w -H)-H+[terminal height / rows]:height:' \
    '-l+[GIF loops (negative = infinite)]:n:' \
    '-r+[resolution (1 or 2)]:n:(1 2)' \
    '-c[restricted color palette]' \
    '-t[disable 24-bit truecolor (fall back to 256)]' \
    '1:image file:_files -g "*.(png|jpg|jpeg|gif|bmp|tiff)"' \
    && ret=0

return ret
