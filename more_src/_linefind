#compdef linefind

# linefind: Hugin tool to detect straight lines for lens distortion correction
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-i[input pto]:file:_files -g "*.pto"' \
  '-o[output pto]:file:_files -g "*.pto"' \
  '-l[max number of lines per image]:n:' \
  '--lines=[max number of lines per image]:n:' \
  '*:project file:_files -g "*.pto"' && ret=0
return ret
