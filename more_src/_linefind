#compdef linefind

# linefind: Hugin tool to add vertical/horizontal line control points
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-o[output project file]:file:_files -g "*.pto"' \
  '-l[search for lines of length >= N]:length:' \
  '-i[image index to scan]:n:' \
  '*:hugin project file:_files -g "*.pto"' && ret=0
return ret
