#compdef linefind
# Documentation: https://manpages.debian.org/experimental/hugin-tools/linefind.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# linefind: Hugin tool to add vertical/horizontal line control points
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output project file]:file:_files -g "*.pto"' \
  '(-l --lines)'{-l+,--lines=}'[max number of lines detected per image]:num:' \
  '*'{-i+,--image=}'[image index to scan (repeatable)]:n:' \
  '*:hugin project file:_files -g "*.pto"' && ret=0
return ret
