#compdef frescobaldi
# Documentation: https://manpages.debian.org/testing/frescobaldi/frescobaldi.1.en.html
# LilyPond sheet music text editor

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help about options and exit]' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '(-e --encoding)'{-e,--encoding=}'[encoding to use]:encoding:' \
  '(-l --line)'{-l,--line=}'[line number to go to, starting at 1]:line:' \
  '(-c --column)'{-c,--column=}'[column to go to, starting at 0]:column:' \
  '--start=[session to start (none for empty session)]:session:' \
  '(-n --new)'{-n,--new}'[always start a new instance]' \
  '*:LilyPond file:_files -g "*.ly"' && ret=0

return ret
