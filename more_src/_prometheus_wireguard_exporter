#compdef prometheus_wireguard_exporter
# Documentation: https://github.com/MindFlavor/prometheus_wireguard_exporter
# Prometheus exporter for WireGuard peer and interface metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-v[enable verbose mode]:bool:(true false)' \
  '-a[prepend sudo to wg commands]:bool:(true false)' \
  '-l[service address]:addr' \
  '-p[service port]:port' \
  '*-n[add friendly_name/friendly_json attributes from config files]:file:_files' \
  '-s[enable allowed IP and subnet split mode]:bool:(true false)' \
  '-r[export peer remote IP and port as labels]:bool:(true false)' \
  '*-i[interface(s) to monitor]:iface' \
  '-d[add handshake delay metric]:bool:(true false)' && ret=0

return ret
