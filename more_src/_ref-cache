#compdef ref-cache
# Documentation: https://www.htslib.org/doc/ref-cache.html
# CRAM reference caching proxy

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-b[run in the background as a System V-style daemon]' \
  '-d+[directory where cached files will be stored]:dir:_files -/' \
  '-l+[directory for log files]:dir:_files -/' \
  '-L[do not log]' \
  '*-m+[reply to connections from the listed networks]:networks' \
  '-n+[number of server processes to run]:count' \
  '-p+[port number to listen on]:port' \
  '-r+[number of request log files to keep]:count' \
  '-R+[maximum size of a request log file in MiB]:size' \
  '-s[run as a systemd-style socket service]' \
  '-u+[URL of the upstream server]:url' \
  '-U[do not attempt to get files from an upstream server]' \
  '-v[turn on debugging output]' && ret=0

return ret
