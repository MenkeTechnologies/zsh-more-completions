#compdef bowtie-build bowtie-build-s bowtie-build-l
# _bowtie-build — Ben Langmead bowtie-build CLI Burrows-Wheeler index builder for Bowtie 1 ultrafast short-read aligner indexing reference FASTA producing .ebwt suffix index files for downstream alignment small-genome large-genome 32-bit 64-bit index variants colored DNA RNA reference genome (Ben Langmead team, C++); custom argparse
# upstream: https://bowtie-bio.sourceforge.net/

_bowtie-build() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-f[FASTA input]' \
        '-c[reference sequences given on command line]' \
        '-C[colorspace]' \
        '--color[colorspace]' \
        '-a[no automatic A bit count]' \
        '--noauto[no automatic A]' \
        '--packed[packed memory layout]' \
        '--bmax=+[N]:n:' \
        '--bmaxdivn=+[N]:n:' \
        '--dcv=+[N]:n:' \
        '--nodc[no difference cover]' \
        '-r[do not build reverse index]' \
        '--noref[do not build reverse index]' \
        '-3[3 indexes]' \
        '--justref[only build .3.ebwt .4.ebwt]' \
        '-o+[offrate]:n:' \
        '--offrate=+[N]:n:' \
        '-t+[ftabchars]:n:' \
        '--ftabchars=+[N]:n:' \
        '--ntoa[convert N to A]' \
        '--big-little-endian[big or little endian]' \
        '--seed=+[seed]:n:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--threads=+[N]:n:' \
        '-V[verbose]' \
        '--verbose[verbose]' \
        '*:fasta and basename:_files -g "*.fa *.fasta *.fna"'
}

_bowtie-build "$@"
