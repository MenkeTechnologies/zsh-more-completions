#compdef midori

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '--help-all[all help options]' \
  '--help-gtk[GTK help options]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --app)'{-a+,--app=}'[run URL as web application]:url:' \
  '(-c --config)'{-c+,--config=}'[config folder]:folder:_files -/' \
  '(-p --private)'{-p,--private}'[private browsing mode]' \
  '--plain[plain GTK+ window with WebKit]' \
  '(-d --diagnostic-dialog)'{-d,--diagnostic-dialog}'[show diagnostic dialog]' \
  '(-g --debug)'{-g,--debug}'[run in gdb and save backtrace]' \
  '(-r --run)'{-r+,--run=}'[execute file as JavaScript]:file:_files' \
  '(-s --snapshot)'{-s+,--snapshot=}'[capture snapshot of URI]:uri:' \
  '(-e --execute)'{-e+,--execute=}'[run command]:command:' \
  '--help-execute[list --execute commands]' \
  '(-b --block-uris)'{-b+,--block-uris=}'[block URIs matching regex]:pattern:' \
  '(-i --inactivity-reset)'{-i+,--inactivity-reset=}'[seconds of inactivity to reset]:seconds:' \
  '--display=[X display]:display:' \
  '*:URL or file:_files' && ret=0

return ret
