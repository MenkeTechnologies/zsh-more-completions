#compdef gosec
# _gosec-bin — Go security checker (Secure Go community + CCC); inspects Go source for security issues
# upstream: https://github.com/securego/gosec

_gosec-bin() {
    _arguments \
        '-conf+[config file]:file:_files' \
        '-exclude+[exclude rules]:rules:' \
        '-include+[include rules]:rules:' \
        '-exclude-dir+[exclude dir glob]:dir:_files -/' \
        '-exclude-generated[exclude generated files]' \
        '-fmt+[output format]:fmt:(json yaml csv junit-xml html text sonarqube tap sarif)' \
        '-log+[log file]:file:_files' \
        '-no-fail[do not return error on issues]' \
        '-nosec[do not honor #nosec annotations]' \
        '-out+[output file]:file:_files' \
        '-quiet[only report issues]' \
        '-severity+[severity threshold]:level:(low medium high)' \
        '-confidence+[confidence threshold]:level:(low medium high)' \
        '-sort+[sort by]:by:(rules)' \
        '-tags+[build tags]:tags:' \
        '-track-suppressions[track suppression]' \
        '-stdout[print to stdout]' \
        '-color[colored output]' \
        '-tests[include tests]' \
        '-verbose+[verbose level]:lvl:' \
        '-version[show version]' \
        '-help[show help]' \
        '*:packages:'
}

_gosec-bin "$@"
