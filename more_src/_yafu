#compdef yafu
# Documentation: https://github.com/bbuhrow/yafu/blob/master/docfile.txt
# yafu - Yet Another Factorization Utility

local ret=1

_arguments -s -S \
  '-p[run yafu at idle priority]' \
  '-v[increase verbosity of output (repeatable)]' \
  '-silent[no output except to log file]' \
  '-threads[number of sieving threads in SIQS and ECM]:num' \
  '-lathreads[threads for linear algebra only]:num' \
  '-session[use name instead of the default session.log]:name' \
  '-logfile[name of the logfile to use]:name:_files' \
  '-batchfile[name of batchfile to use in command line job]:name:_files' \
  '-seed[seed RNG with highseed,lowseed]:seed' \
  '-B1ecm[B1 bound in the ECM method]:num' \
  '-B2ecm[B2 bound in the ECM method]:num' \
  '-B1pm1[B1 bound in the pm1 method]:num' \
  '-B2pm1[B2 bound in the pm1 method]:num' \
  '-B1pp1[B1 bound in the pp1 method]:num' \
  '-B2pp1[B2 bound in the pp1 method]:num' \
  '-rhomax[max iterations in the rho method]:num' \
  '-fmtmax[max iterations for the fermat method]:num' \
  '-sigma[input to ECM sigma parameter]:num' \
  '-qssave[name of the siqs savefile]:name:_files' \
  '-siqsR[stop after finding num relations in siqs]:num' \
  '-siqsT[stop after num seconds in siqs]:num' \
  '-forceDLP[force SIQS to use double large primes]' \
  '-noopt[force siqs to not optimize small tf bound]' \
  '-noecm[skip all ECM stages, proceed to QS/NFS]' \
  '-one[stop factoring after finding one factor]' \
  '-pretest[ECM pretesting of the input number]:num' \
  '-pretest_ratio[fraction for plan=custom pretest depth]:num' \
  '-plan[pretesting plan]:plan:(none noecm light normal deep custom)' \
  '-work[assert input has received t-level pretesting]:num' \
  '-xover[digit size beyond which nfs replaces qs]:num' \
  '-snfs_xover[digit size beyond which snfs replaces qs]:num' \
  '-ecm_path[full path to ecm binary]:path:_files' \
  '-ggnfs_dir[path to ggnfs binaries]:path:_files -/' \
  '-ext_ecm[B1 beyond which to use external ecm]:num' \
  '-nprp[number of witnesses for Rabin-Miller test]:num' \
  '-aprcl_p[upper digit limit for APR-CL proof]:num' \
  '-aprcl_d[upper digit limit for silent APR-CL proof]:num' \
  '-op[output primes and prps to file]:name:_files' \
  '-of[output input number and factors to file]:name:_files' \
  '-ou[output unfactored composites to file]:name:_files' \
  '-no_expr[do not print expression form when outputting]' \
  '-np[perform poly search step within nfs]' \
  '-ns[perform sieving step within nfs]' \
  '-nc[postprocessing step starting with filtering]' \
  '-nc2[postprocessing step starting with linear algebra]' \
  '-nc3[postprocessing step starting with sqrt]' \
  '-a[use special Q on the algebraic side in nfs]' \
  '-r[use special Q on the rational side in nfs]' \
  '-R[restart when a previous savefile exists]' \
  '-job[name of input job file in nfs]:name:_files' \
  '-o[name of output file in nfs]:name:_files' \
  '-ggnfsT[timeout for nfs command in seconds]:num' \
  '-psearch[parallel poly selection method]:method:(fast wide deep min avg good)' \
  '-pbatch[block size of leading coefficients to distribute]:num' \
  '-siever[ggnfs siever version to use]:num' \
  '-nt[trial sieve listed job files then exit]:files' \
  '-testsieve[digits beyond which to test sieve top polys]:num' \
  '-inmem[digit limit below which to skip savefile]:num' \
  '-pfile[output primes to primes.txt]' \
  '-pscreen[output primes to the screen]' \
  '-vproc[increase verbosity of processor detection]' \
  '*:expression:_files' && ret=0

return ret
