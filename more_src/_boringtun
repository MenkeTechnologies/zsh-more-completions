#compdef boringtun boringtun-cli
# Documentation: https://github.com/cloudflare/boringtun
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  {-f,--foreground}'[run in the foreground]'
  '(-t --threads)'{-t+,--threads=}'[number of OS threads]:n:'
  '(-v --verbosity)'{-v+,--verbosity=}'[verbosity level]:level:(silent info debug trace)'
  '--uapi-fd=[file descriptor for UAPI]:fd:'
  '--log=[log file path]:file:_files'
  '--disable-drop-privileges[do not drop privileges after setup]'
  '--disable-connected-udp[disable connected UDP sockets]'
  '1:interface name:'
)

_arguments -s -S $arguments
