#compdef edstats
# Documentation: https://www.ccp4.ac.uk/html/edstats.html
# CCP4 EDSTATS - real-space electron density fit statistics

local ret=1

_arguments -s -S \
  'XYZIN[input coordinate file (PDB)]:file:_files' \
  'MAPIN1[2mFo-DFc electron density map]:file:_files' \
  'MAPIN2[2(mFo-DFc) difference map]:file:_files' \
  'HISOUT[histogram of map values]:file:_files' \
  'PPDOUT[P-P difference plot data]:file:_files' \
  'QQDOUT[Q-Q difference plot data]:file:_files' \
  'MAPOUT1[rescaled normalized observed map]:file:_files' \
  'MAPOUT2[rescaled normalized difference map]:file:_files' \
  'OUT[per-residue metrics table]:file:_files' \
  'XYZOUT[PDB with per-atom Z-difference metrics]:file:_files' \
  '*:keyword:(RESLO RESHI MAIN SIDE MOLE RESC THR1 THR2 TEST USEFO)' && ret=0

return ret
