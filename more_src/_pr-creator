#compdef pr-creator
# _pr-creator — open a GitHub pull request from CI (kubernetes/test-infra)
# upstream: https://github.com/kubernetes/test-infra
# Flags from robots/pr-creator/main.go (flag).

_pr-creator() {
    _arguments \
        '-org=[GitHub org]:org:' \
        '-repo=[GitHub repo]:repo:' \
        '-branch=[repo branch to merge into]:branch:' \
        '-source=[user:branch to merge from]:source:' \
        '-allow-mods=[allow maintainers to modify the PR]:val:(true false)' \
        '-confirm[mutate GitHub instead of dry run]' \
        '-local[allow source to be a local branch]' \
        '-title=[PR title]:title:' \
        '-head-branch=[reuse any self-authored open PR from this branch]:branch:' \
        '-match-title=[reuse any self-authored open PR matching this title]:title:' \
        '-body=[PR body]:text:' \
        '-labels=[labels to attach to PR]:labels:' \
        '-github-token-path=[GitHub token file]:file:_files' \
        '-github-endpoint=[GitHub API endpoint]:url:_urls'
}

_pr-creator "$@"
