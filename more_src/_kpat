#compdef kpat

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--start[start new game]' \
  '--game=+[game name]:game:' \
  '--solvable[only solvable games]' \
  '--solver-quick[quick solver]' \
  '--solver=+[solver type]:type:' \
  '--solverstats[show solver stats]' \
  '--display=+[X display]:disp:' && ret=0

return ret
