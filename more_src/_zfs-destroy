#compdef zfs-destroy
# _zfs-destroy — OpenZFS zfs destroy destroy datasets/snapshots/bookmarks CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-destroy() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-d[defer destroy]' \
        '-f[force unmount]' \
        '-n[no act]' \
        '-p[parsable]' \
        '-r[recursive destroy]' \
        '-R[recursive destroy with all clones]' \
        '-v[verbose]' \
        '*:dataset:'
}

_zfs-destroy "$@"
