#compdef lsarchive
# Documentation: https://man.archlinux.org/search?q=lsarchive
# Reference accessed: 2026-05-16
# Source: https://github.com/sorin-ionescu/prezto/blob/cff2d01871425b1b80710f8ec6a475c5a53145b4/modules/archive/functions/_lsarchive
# Repository: sorin-ionescu/prezto (modules/archive/functions/_lsarchive)
#autoload

#
# Completes lsarchive.
#
# Authors:
#   Sorin Ionescu <sorin.ionescu@gmail.com>
#

_arguments \
  '(-v --verbose)'{-v,--remove}'[verbose archive listing]' \
  "*::archive file:_files -g '(#i)*.(tar|tgz|tbz|tbz2|txz|tlz|gz|bz2|xz|lzma|Z|zip|zst|jar|rar|7z)(-.)'" && return 0
