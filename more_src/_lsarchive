#compdef lsarchive
# Documentation: https://github.com/sorin-ionescu/prezto/blob/master/modules/archive/functions/lsarchive
# Reference accessed: 2026-05-19
# Verified: upstream prezto archive function source.
# Removed from prior file: bogus man.archlinux.org search URL;
# typo where -v was paired with --remove (real long form is --verbose).
#autoload

#
# Completes lsarchive.
#
# Authors:
#   Sorin Ionescu <sorin.ionescu@gmail.com>
#

_arguments \
  '(-v --verbose)'{-v,--verbose}'[verbose archive listing]' \
  "*::archive file:_files -g '(#i)*.(tar|tgz|tbz|tbz2|txz|tlz|gz|bz2|xz|lzma|Z|zip|zst|jar|rar|7z)(-.)'" && return 0
