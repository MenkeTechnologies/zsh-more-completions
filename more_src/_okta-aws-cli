#compdef okta-aws-cli

# Zsh completion for okta-aws-cli - AWS authentication via Okta OIDC

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--profile=[AWS profile]:profile' \
  '--org-domain=[Okta org domain]:domain' \
  '--oidc-client-id=[OIDC client ID]:client-id' \
  '--aws-acct-fed-app-id=[AWS account federation app ID]:app-id' \
  '--aws-iam-idp=[AWS IAM identity provider ARN]:idp-arn' \
  '--aws-iam-role=[AWS IAM role ARN]:role-arn' \
  '--session-duration=[session duration in seconds]:seconds' \
  '--format=[output format]:format:(env-var aws-credentials process-credentials noop)' \
  '--debug[enable debug output]' \
  '--cache-access-token[cache the access token]' \
  '--write-aws-credentials[write credentials to AWS credentials file]' \
  '--open-browser[open browser for authentication]' \
  '--all-profiles[fetch credentials for all profiles]' \
  '--exec=[execute a command with credentials]:command' \
  '--key-ring=[use system keyring for caching]:keyring' \
  '--legacy-aws-variables[use legacy AWS variable names]' \
  && ret=0

return ret
