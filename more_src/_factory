#compdef factory
# Documentation: https://factory.mintlify.app/reference/cli-reference
# Reference accessed: 2026-05-23
# Verified: @factory/cli installs droid; see _droid.

# Zsh completion for factory - Factory package CLI name (binary droid)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --file)'{-f,--file}'[read prompt from file]:file:_files' \
  '(-m --model)'{-m,--model}'[model ID]:model:' \
  '(-s --session-id)'{-s,--session-id}'[continue session]:session:' \
  '(-r --resume)'{-r,--resume}'[resume previous session]' \
  '(-w --worktree)'{-w,--worktree}'[git worktree]:name:' \
  '--cwd[working directory]:directory:_directories' \
  '--fork[fork session]:session:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'factory command' \
      'exec[non-interactive execution]' \
      'mcp[manage MCP servers]' \
      'plugin[manage plugins]' \
      'daemon[run Factory daemon]' \
      'search[search local sessions]' \
      'find[alias for search]' \
      'computer[manage relay computers]' \
      'update[check for updates]' && ret=0
    ;;
  args)
    case $line[1] in
      exec)
        _arguments '*:prompt:' && ret=0
        ;;
      search|find)
        _arguments '*:query:' && ret=0
        ;;
    esac
    ;;
esac

return ret
