#compdef mlxreg

# mlxreg: read/write Mellanox device registers
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-d[device]:dev:' \
  '--device=[device]:dev:' \
  '--reg_name=[register name]:reg:' \
  '--reg_id=[register id]:hex:' \
  '--reg_len=[register length]:n:' \
  '--get[query]' \
  '--set=[set fields key=value,...]:kv:' \
  '--indexes=[register indexes]:list:' \
  '--show_fields[show register fields]' \
  '--show_all_regs[list available register names]' \
  '--show_reg=[show given register]:reg:' \
  '--yes[answer yes]' \
  '*::mlxreg args:_files' && ret=0
return ret
