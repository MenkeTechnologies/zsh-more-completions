#compdef ide-helper-cli
# _ide-helper-cli — Barry vd. Heuvel Laravel IDE Helper CLI alias (barryvdh team, PHP); artisan-based
# upstream: https://github.com/barryvdh/laravel-ide-helper

_ide-helper-cli() {
    local -a sub=(
        'ide-helper:generate:generate _ide_helper.php'
        'ide-helper:meta:generate phpstorm meta file'
        'ide-helper:models:generate model docblocks'
        'ide-helper:eloquent:enable eloquent migration helper'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ide-helper subcommand' sub ;;
        args)
            case $words[1] in
                ide-helper:generate) _arguments \
                    '1:filename:_files' \
                    '--memory[use database to associate values with classes]' \
                    '-M[use database to associate values with classes]' \
                    '--sublime[use sublime text format]' \
                    '-S[use sublime text format]' \
                    '--helpers[include helper files]' \
                    '-H[include helper files]' \
                    '--no-helpers[do not include helper files]' \
                    '--write-mixin[write mixin file]' \
                    '--phpstorm-noinspections[include phpstorm noinspect]' \
                    '--prefix=+[prefix]:str:' ;;
                ide-helper:models) _arguments \
                    '*:model:' \
                    '--filename=+[filename]:file:_files' \
                    '-F+[filename]:file:_files' \
                    '--dir=+[dir]:dir:_files -/' \
                    '-D+[dir]:dir:_files -/' \
                    '--write[write directly to model files]' \
                    '-W[write directly to model files]' \
                    '--write-mixin[write to mixin file]' \
                    '-M[write to mixin file]' \
                    '--nowrite[do not write]' \
                    '-N[do not write]' \
                    '--reset[reset existing docblocks]' \
                    '-R[reset existing docblocks]' \
                    '--smart-reset[smart reset]' \
                    '-S[smart reset]' \
                    '--phpstorm-noinspections[include phpstorm noinspect]' \
                    '-p[include phpstorm noinspect]' \
                    '--ignore=+[ignore models]:str:' \
                    '-I+[ignore models]:str:' ;;
                ide-helper:meta) _arguments \
                    '--filename=+[filename]:file:_files' ;;
            esac
            ;;
    esac
}

_ide-helper-cli "$@"
