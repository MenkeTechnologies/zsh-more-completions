#compdef bwameth bwameth.py
# _bwameth — Brent Pedersen bwameth CLI fast bisulfite-treated DNA alignment wrapper around BWA-MEM mapping reads in C-to-T converted space to a likewise-converted reference for whole-genome bisulfite-sequencing WGBS reduced-representation RRBS methylation calling on output BAM (Brent Pedersen team, Python); argparse
# upstream: https://github.com/brentp/bwa-meth

_bwameth() {
    local -a sub=(
        'index:create methylation-aware bwa index'
        'index-mem2:create bwa-mem2 index'
        'tabulate:tabulate methylation per cytosine'
        'c2t:perform in-silico C-to-T conversion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-r+[reference fasta]:file:_files -g "*.fa *.fasta *.fna"' \
        '--reference=+[file]:file:_files -g "*.fa *.fasta *.fna"' \
        '--read-group=+[read group]:str:' \
        '-p+[prefix]:str:' \
        '--prefix=+[prefix]:str:' \
        '--set-as-failed=+[strand]:s:(f r)' \
        '--CT2GA[do GA conversion instead of CT]' \
        '--do-not-penalize-chimeras[no chimera penalty]' \
        '--map-mem-mb=+[MB]:n:' \
        '--no-sort[do not sort output]' \
        '--no-sambamba[do not use sambamba]' \
        '--no-bam-output[do not output bam]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bwameth subcommand' sub ;;
        args)
            _arguments '*:fastq files:_files -g "*.fq *.fastq *.gz"'
            ;;
    esac
}

_bwameth "$@"
