#compdef astfits
# astfits — report and manipulate FITS metadata

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress extra information]' \
  '--log[store program activity in a log file]' \
  '(-N --numthreads)'{-N,--numthreads}'[number of CPU threads]:number' \
  '--minmapsize[minimum bytes to use memory-mapped files]:size' \
  '--quietmmap[do not report memory-mapped file creation]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[output data type]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--tableformat[output table format]:format:(txt fits-ascii fits-binary)' \
  '(-h --hdu)'{-h,--hdu}'[extension name or number of input]:HDU' \
  '(-I --ignorecase)'{-I,--ignorecase}'[ignore case in matching column names]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and exit]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for current directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for current user]' \
  '--cite[show BibTeX citation for this program]' \
  '--config[configuration file to use]:file:_files' \
  '--checkconfig[print all config files and variables]' \
  '--onlyversion[only run if program version matches]:version' \
  '--searchin[search column metadata]:where:(name unit comment)' \
  '(-n --numhdus)'{-n,--numhdus}'[print number of HDUs in the FITS file]' \
  '--datasum[calculate and print datasum of the HDU]' \
  '--datasum-encoded[16-char string encoding of datasum]' \
  '--pixelscale[return pixel scale of the HDU WCS]' \
  '--pixelareaarcsec2[pixel area in arc-seconds squared]' \
  '--skycoverage[image coverage in WCS coordinates]' \
  '--hastablehdu[check if file has at least one table HDU]' \
  '--hasimagehdu[check if file has at least one image HDU]' \
  '--listtablehdus[list all table HDUs within the file]' \
  '--listimagehdus[list all image HDUs within the file]' \
  '--listallhdus[list all HDUs within the file]' \
  '(-R --remove)'{-R,--remove}'[remove extension from input file]:HDU' \
  '(-C --copy)'{-C,--copy}'[copy extension to output file]:HDU' \
  '(-k --cut)'{-k,--cut}'[copy extension to output and remove from input]:HDU' \
  '--primaryimghdu[copy/cut image HDUs to primary HDU]' \
  '(-p --printallkeys)'{-p,--printallkeys}'[print all keywords in the selected HDU]' \
  '--printkeynames[print all keyword names]' \
  '(-a --asis)'{-a,--asis}'[write value as-is (may corrupt FITS)]:record' \
  '*'{-l,--keyvalue}'[print value of requested keyword]:keyword' \
  '*'{-d,--delete}'[delete a keyword from the header]:keyword' \
  '*'{-r,--rename}'[rename keyword keeping value and comments]:old,new' \
  '*'{-u,--update}'[update a keyword value or comment]:key,value' \
  '*'{-w,--write}'[write a keyword with value and comments]:record' \
  '*'{-c,--comment}'[add COMMENT keyword]:comment' \
  '*'{-H,--history}'[add HISTORY keyword]:history' \
  '(-t --date)'{-t,--date}'[set DATE keyword to current time]' \
  '(-v --verify)'{-v,--verify}'[verify CHECKSUM and DATASUM keywords]' \
  '--copykeys[range or names of keywords to copy]:range' \
  '--outhdu[HDU in output for --copykeys]:HDU' \
  '(-O --colinfoinstdout)'{-O,--colinfoinstdout}'[column info/metadata when printing to stdout]' \
  '(-Q --quitonerror)'{-Q,--quitonerror}'[quit if there is an error on any action]' \
  '(-s --datetosec)'{-s,--datetosec}'[FITS date to seconds from epoch]:date string' \
  '--wcsdistortion[convert WCS distortion to another type]:type' \
  '--wcscoordsys[convert WCS coordinate system]:system' \
  '--pixelareaonwcs[image where pixels show their area in sky]' \
  '--edgesampling[number of extra samplings in pixel sides]:number' \
  '--arguments[plain-text file with command-line arguments]:file:_files' \
  '*:input FITS files:_files -g "*.fits(|.gz|.fz)(N)"'
