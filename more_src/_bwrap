#compdef bwrap

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--bind=[bind mount source to dest]:source:_files:dest' \
  '--dev-bind=[bind mount dev source to dest]:source:_files:dest' \
  '--ro-bind=[read-only bind mount]:source:_files:dest' \
  '--bind-try=[bind mount, ignoring failures]:source:_files:dest' \
  '--dev-bind-try=[dev bind mount, ignoring failures]:source:_files:dest' \
  '--ro-bind-try=[read-only bind, ignoring failures]:source:_files:dest' \
  '--remount-ro=[remount as read-only]:dest' \
  '--proc=[mount procfs]:dest' \
  '--dev=[mount devtmpfs]:dest' \
  '--tmpfs=[mount tmpfs]:dest' \
  '--mqueue=[mount mqueue]:dest' \
  '--dir=[create directory]:dest' \
  '--file=[copy file descriptor content]:fd:dest' \
  '--bind-data=[bind mount fd as file]:fd:dest' \
  '--ro-bind-data=[read-only bind mount fd]:fd:dest' \
  '--symlink=[create symlink]:source:dest' \
  '--lock-file=[take a lock on file]:file:_files' \
  '--sync-fd=[keep fd open while sandbox is running]:fd' \
  '--exec-label=[set SELinux label]:label' \
  '--file-label=[set SELinux label for temp files]:label' \
  '--block-fd=[block on fd]:fd' \
  '--userns-block-fd=[block on fd for user namespace]:fd' \
  '--info-fd=[write info to fd]:fd' \
  '--json-status-fd=[write JSON status to fd]:fd' \
  '--seccomp=[load seccomp from fd]:fd' \
  '--add-seccomp-fd=[add seccomp from fd]:fd' \
  '--unshare-cgroup[create new cgroup namespace]' \
  '--unshare-cgroup-try[try to create new cgroup namespace]' \
  '--unshare-ipc[create new IPC namespace]' \
  '--unshare-net[create new network namespace]' \
  '--unshare-pid[create new PID namespace]' \
  '--unshare-user[create new user namespace]' \
  '--unshare-user-try[try to create new user namespace]' \
  '--unshare-uts[create new UTS namespace]' \
  '--unshare-all[unshare all possible namespaces]' \
  '--share-net[retain the network namespace]' \
  '--uid=[user ID in sandbox]:uid' \
  '--gid=[group ID in sandbox]:gid' \
  '--hostname=[hostname in sandbox]:hostname' \
  '--chdir=[change directory]:directory:_directories' \
  '--setenv=[set environment variable]:name:value' \
  '--unsetenv=[unset environment variable]:name' \
  '--clearenv[unset all environment variables]' \
  '--new-session[create new session]' \
  '--die-with-parent[kill child when parent dies]' \
  '--as-pid-1[do not install pid 1 handler]' \
  '--cap-add=[add capability]:capability' \
  '--cap-drop=[drop capability]:capability' \
  '--perms=[set permissions for next operation]:permissions' \
  '--size=[set size for next tmpfs]:size' \
  '--chmod=[set permissions]:permissions:path' \
  '*:command:_command_names -e' && ret=0

return ret
