#compdef foot-cli footclient
# _foot-cli — Daniel Eklöf foot Wayland terminal emulator client CLI alias (Daniel Eklöf / dnkl, C); custom argparse
# upstream: https://codeberg.org/dnkl/foot

_foot-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--app-id=+[Wayland app id]:str:' \
        '-a+[Wayland app id]:str:' \
        '--config=+[config file]:file:_files -g "*.ini"' \
        '-c+[config file]:file:_files -g "*.ini"' \
        '--check-config[check config and exit]' \
        '--server=+[server socket]:file:_files' \
        '-s+[server socket]:file:_files' \
        '--server-socket=+[server socket]:file:_files' \
        '--working-directory=+[working dir]:dir:_files -/' \
        '-D+[working dir]:dir:_files -/' \
        '--title=+[window title]:str:' \
        '-T+[window title]:str:' \
        '--maximized[start maximized]' \
        '-m[start maximized]' \
        '--fullscreen[start fullscreen]' \
        '-F[start fullscreen]' \
        '--hold[hold terminal after process exit]' \
        '-H[hold terminal after process exit]' \
        '--login-shell[run as login shell]' \
        '-l[run as login shell]' \
        '--log-colorize=+[colorize log]:b:(never always auto)' \
        '--log-no-syslog[no syslog]' \
        '--log-level=+[log level]:level:(none error warning info debug)' \
        '-d+[log level]:level:(none error warning info debug)' \
        '--print-pid=+[pid file]:file:_files' \
        '-p+[pid file]:file:_files' \
        '--override=+[override config option]:str:' \
        '-o+[override config option]:str:' \
        '--window-size-pixels=+[window size WxH]:str:' \
        '-W+[window size WxH]:str:' \
        '--window-size-chars=+[window size in chars]:str:' \
        '-w+[window size in chars]:str:' \
        '--term=+[TERM value]:str:' \
        '-t+[TERM value]:str:' \
        '--font=+[font]:str:' \
        '-f+[font]:str:' \
        '*:cmd-and-args:_command_names -e'
}

_foot-cli "$@"
