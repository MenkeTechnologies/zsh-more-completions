#compdef godef
# Documentation: https://pkg.go.dev/github.com/rogpeppe/godef
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '-t[print the type of the expression]' \
  '-a[print all public members and their locations]' \
  '-A[print private members in addition to public ones]' \
  '-o[byte offset within file]:offset:' \
  '-i[read source from stdin]' \
  '-f[source file to evaluate expression in]:file:_files -g "*.go"' \
  '-acme[read offset, file name, contents from current acme window]' \
  '*:expr:' && ret=0
return ret
