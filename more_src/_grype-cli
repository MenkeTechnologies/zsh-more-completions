#compdef grype
# Documentation: https://oss.anchore.com/docs/reference/grype/cli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'completion:generate completion'
  'config:show config'
  'db:vulnerability DB commands'
  'explain:explain a vulnerability'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)*'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '*-c+[config]:file:_files' \
  '*--config=[config]:file:_files' \
  '*--add-cpes-if-none[add CPEs if none]' \
  '*--by-cve[match by CVE]' \
  '*--distro=[override distro]:d:' \
  '*--exclude=[exclude pattern]:p:' \
  '*-f+[fail on severity]:s:(negligible low medium high critical)' \
  '*--fail-on=[fail on severity]:s:(negligible low medium high critical)' \
  '*--file=[output file]:file:_files' \
  '*--name=[name override]:n:' \
  '*-o+[output format]:f:(table cyclonedx cyclonedx-json json sarif template)' \
  '*--output=[output format]:f:(table cyclonedx cyclonedx-json json sarif template)' \
  '*--platform=[platform]:p:' \
  '*-s+[scope]:s:(squashed all-layers)' \
  '*--scope=[scope]:s:(squashed all-layers)' \
  '*--show-suppressed[show suppressed]' \
  '*-t+[template path]:file:_files' \
  '*--template=[template path]:file:_files' \
  '*--only-fixed[only fixed]' \
  '*--only-notfixed[only not fixed]' \
  '*--vex=[VEX file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _alternative \
      'commands:command:_describe -t cmds "grype command" commands' \
      'sources:source:( )' && ret=0 ;;
  (args)
    case $line[1] in
      (db)
        _arguments \
          '1:subcommand:(check delete diff import list status update)' \
          '*: :_files' && ret=0 ;;
      (explain)
        _arguments \
          '*--id=[CVE ID]:id:' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
