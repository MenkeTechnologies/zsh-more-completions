#compdef hothasktags
# Documentation: https://hackage.haskell.org/package/hothasktags
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-c+[ghc options file]:file:_files' \
  '-X+[language extension]:ext:' \
  '*:haskell file:_files -g "*.hs"' && ret=0

return ret
