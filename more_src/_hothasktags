#compdef hothasktags
# Documentation: https://man.archlinux.org/search?q=hothasktags
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-c+[ghc options file]:file:_files' \
  '-X+[language extension]:ext:' \
  '*:haskell file:_files -g "*.hs"' && ret=0

return ret
