#compdef xcowsay xcowfortune xcowthink
# Documentation: https://man.archlinux.org/search?q=xcowsay
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-t --time)'{-t,--time}'+[time on screen sec]:sec:' \
  '(-r --reading-speed)'{-r,--reading-speed}'+[reading speed cps]:cps:' \
  '(-f --font)'{-f,--font}'+[font name]:font:' \
  '(-l --left)'{-l,--left}'[align text left]' \
  '(--image)--image=+[cow image]:file:_files -g "*.{png,jpg,jpeg,gif,svg}"' \
  '(--cow-size)--cow-size=+[cow size]:size:(small med large)' \
  '(--at)--at=+[position x,y]:xy:' \
  '(--display)--display=+[X display]:display:' \
  '(--monitor)--monitor=+[monitor index]:n:' \
  '(--release-time)--release-time=+[release sec]:sec:' \
  '(--debug)--debug[debug mode]' \
  '(--dream)--dream[think bubble]' \
  '(--config)--config=+[config file]:file:_files' \
  '(--bubble-color)--bubble-color=+[bubble color]:color:' \
  '(--text-color)--text-color=+[text color]:color:' \
  '(--no-wrap)--no-wrap[do not wrap text]' \
  '*:message:' && ret=0

return ret
