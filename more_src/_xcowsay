#compdef xcowsay xcowfortune xcowthink
# Documentation: https://github.com/nickg/xcowsay/blob/master/xcowsay.6
# Reference accessed: 2026-05-21
# Verified: upstream xcowsay.6 man page.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-t --time)'{-t,--time=}'+[seconds to display the cow]:sec:' \
  '(-r --reading-speed)'{-r,--reading-speed=}'+[milliseconds per word]:ms:' \
  '(-f --font)'{-f,--font=}'+[Pango font string]:font:' \
  '(-d --dream)'{-d,--dream=}'+[display image instead of text]:file:_files -g "*.(png|jpg|jpeg|gif|svg)"' \
  '--think[display a thought bubble instead of speech bubble]' \
  '--daemon[run in daemon mode (DBus)]' \
  '--cow-size=+[cow size]:size:(small med large)' \
  '--image=+[alternate image instead of cow]:file:_files -g "*.(png|jpg|jpeg|gif|svg)"' \
  '--monitor=+[monitor index]:n:' \
  '--at=+[screen position X,Y]:xy:' \
  '--bubble-at=+[bubble position offset X,Y]:xy:' \
  '--no-wrap[disable word wrapping]' \
  '(-l --left)'{-l,--left}'[bubble on left of cow]' \
  '--debug[print debug messages]' \
  '--release[close on button release instead of press]' \
  '--config=+[config file to load after personal config]:file:_files' \
  '*:message:' && ret=0

return ret
