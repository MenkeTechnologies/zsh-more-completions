#compdef create-tessera
# Documentation: https://www.npmjs.com/package/create-tessera
# Reference accessed: 2026-05-23
# Verified: npm view create-tessera bin; npm readme Flags and upgrade sections.

# Zsh completion for create-tessera - Tessera SCORM course project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--template=[course template]:template:(default bare)'   '--dry-run[preview upgrade changes without writing files]'   '(-h --help)'{-h,--help}'[print usage and exit]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' upgrade && ret=0
    ;;
  args)
    case $line[1] in
      upgrade)
        _arguments -C           '--dry-run[preview upgrade without writing files]'           '(-h --help)'{-h,--help}'[print usage and exit]' && ret=0
        ;;
      *)
        _arguments -C           '--template=[course template]:template:(default bare)'           '(-h --help)'{-h,--help}'[print usage and exit]'           ':course name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
