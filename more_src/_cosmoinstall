#compdef cosmoinstall
# Documentation: https://github.com/jart/cosmopolitan/blob/master/tool/cosmocc/bin/cosmoinstall
# Reference accessed: 2026-05-27
# Verified: upstream tool/cosmocc/bin/cosmoinstall shell script

# Zsh completion for cosmoinstall.
# Wraps GNU coreutils `install` while filtering out the -s (strip) flag,
# which would corrupt an Actually Portable Executable. When installing
# .a archives it also mirrors the aarch64 variant into a parallel
# .aarch64/ directory.

local arguments

arguments=(
  '(-b --backup)'{-b,--backup=-}'[make a backup of each existing destination file]::control:(none off numbered t existing nil simple never)'
  '(-c)-c[(ignored, kept for compatibility)]'
  '(-C --compare)'{-C,--compare}'[compare each pair of source and destination files]'
  '(-d --directory)'{-d,--directory}'[treat all arguments as directory names; create all parent directories]'
  '(-D)-D[create all leading components of DEST except the last]'
  '(-g --group)'{-g+,--group=}'[set group ownership instead of process current group]:group:_groups'
  '(-m --mode)'{-m+,--mode=}'[set permission mode (as in chmod)]:mode:'
  '(-o --owner)'{-o+,--owner=}'[set ownership (super-user only)]:user:_users'
  '(-p --preserve-timestamps)'{-p,--preserve-timestamps}'[preserve modification and access times of SOURCE files]'
  '(-S --suffix)'{-S+,--suffix=}'[override the usual backup suffix]:suffix:'
  '(-t --target-directory)'{-t+,--target-directory=}'[copy all SOURCE arguments into DIRECTORY]:directory:_files -/'
  '(-T --no-target-directory)'{-T,--no-target-directory}'[treat DEST as a normal file]'
  '(-v --verbose)'{-v,--verbose}'[print the name of each created directory or copied file]'
  '--preserve-context[preserve SELinux security context]'
  '(-Z)-Z[set SELinux security context of destination to default type]'
  '--context=[set SELinux/SMACK security context]:context:'
  '--help[display help and exit]'
  '--version[print version information]'
  '*:file:_files'
)

_arguments -s $arguments
