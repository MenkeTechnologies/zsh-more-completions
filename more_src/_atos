#compdef atos
# Documentation: https://www.unix.com/man-page/osx/1/atos/
# Source: Apple macOS — symbolicate addresses in a Mach-O binary or a running process.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-o -p)-o[binary image file to look up symbols in]:file:_files' \
    '(-o -p)-p[process ID or partial executable name]:pid or name:' \
    '-arch[architecture of binary image]:arch:(x86_64 arm64 arm64e i386 ppc)' \
    '-l[load address of binary image]:address:' \
    '-s[slide value of binary image]:slide:' \
    '-printHeader[print "Looking up symbols in process ..." header]' \
    '-f[file containing whitespace-separated addresses to convert]:file:_files' \
    '*:address:' \
    && ret=0

return ret
