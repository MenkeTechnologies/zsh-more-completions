#compdef genePredFilter
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: filter a genePred file, dropping invalid entries

local ret=1

_arguments -s -S \
  '-db=[database used to get chromosome sizes]:db' \
  '-chromSizes=[use chrom sizes from tab separated file (name,size)]:file:_files' \
  '-verbose=[verbosity level; >=2 prints errors for each problem]:level' \
  '1:input genePred:_files' \
  '2:output genePred:_files' && ret=0

return ret
