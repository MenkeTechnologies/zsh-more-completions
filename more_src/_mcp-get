#compdef mcp-get
# Documentation: https://github.com/michaellatman/mcp-get
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mcp-get: npm CLI for MCP servers (deprecated; superseded by Smithery)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:add an MCP server package'
  'list:display available packages'
  'uninstall:remove an installed MCP server'
  'update:upgrade the mcp-get tool itself'
)

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'mcp-get command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac

return ret
