#compdef envio

_envio_commands() {
  local -a commands=(
    'create:Create a new environment profile'
    'add:Add environment variables to a profile'
    'remove:Remove environment variables from a profile'
    'list:List all environment profiles'
    'load:Load an environment profile'
    'unload:Unload an environment profile'
    'launch:Launch a program with an environment profile'
    'export:Export a profile to a file'
    'import:Import a profile from a file'
    'update:Update environment variables in a profile'
    'version:Print version information'
    'help:Print help information'
  )
  _describe -t commands 'envio command' commands
}

_envio() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Print help information]' \
    '(-V --version)'{-V,--version}'[Print version information]' \
    '1:command:_envio_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        create)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:profile-name:' \
            '*:key=value pairs:'
          ;;
        add|update)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:profile-name:' \
            '*:key=value pairs:'
          ;;
        remove)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:profile-name:' \
            '*:variable names:'
          ;;
        load|unload)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:profile-name:'
          ;;
        launch)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:profile-name:' \
            '2:command:_command_names'
          ;;
        export)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:profile-name:' \
            '2:output file:_files'
          ;;
        import)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:input file:_files'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]'
          ;;
      esac
      ;;
  esac
}

_envio "$@"
