#compdef suricata-cli suricatasc
# _suricata-cli — OISF Suricata high-perf IDS/IPS/NSM CLI alias (OISF team, C); custom argparse
# upstream: https://github.com/OISF/suricata

_suricata-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "suricata.{yaml,yml}"' \
        '-T[test config]' \
        '-i+[interface]:_net_interfaces' \
        '-r+[pcap file]:file:_files -g "*.pcap*"' \
        '-q+[nfqueue id]:n:' \
        '-s+[signature file]:file:_files -g "*.rules"' \
        '-S+[exclusive signature file]:file:_files -g "*.rules"' \
        '-l+[log directory]:dir:_files -/' \
        '-D[daemon mode]' \
        '-k+[checksum validation]:m:(all none)' \
        '-F+[bpf filter file]:file:_files' \
        '--af-packet=+[interface]:_net_interfaces' \
        '--af-xdp=+[interface]:_net_interfaces' \
        '--netmap=+[interface]:_net_interfaces' \
        '--pcap=+[interface]:_net_interfaces' \
        '--pcap-buffer-size=+[bytes]:n:' \
        '--simulate-applayer-error-at-offset-ts=+[offset]:n:' \
        '--simulate-applayer-error-at-offset-tc=+[offset]:n:' \
        '--simulate-packet-loss=+[pct]:n:' \
        '--simulate-packet-tcp-reassembly-memcap=+[hits]:n:' \
        '--engine-analysis[engine analysis]' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--set=+[name=value]:str:' \
        '--build-info[show build info]' \
        '--list-app-layer-protos[list app layer protos]' \
        '--list-keywords[list keywords]' \
        '--list-runmodes[list runmodes]' \
        '--list-unittests[list unittests]' \
        '--runmode=+[mode]:m:(workers single autofp)' \
        '--unix-socket=+[socket file]:file:_files' \
        '--user=+[user]:_users' \
        '--group=+[group]:_groups' \
        '--pidfile=+[pid file]:file:_files' \
        '--init-errors-fatal[init errors fatal]' \
        '--disable-detection[disable detection]' \
        '--dump-config[dump config]' \
        '--dump-features[dump features]' \
        '--strict-rule-keywords=+[keywords]:str:' \
        '--enable-rule-keyword=+[keyword]:str:' \
        '--disable-rule-keyword=+[keyword]:str:' \
        '-v[verbose]' \
        '*:arg:'
}

_suricata-cli "$@"
