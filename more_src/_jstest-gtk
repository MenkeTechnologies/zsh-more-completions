#compdef jstest-gtk
# Documentation: https://manpages.debian.org/bookworm/jstest-gtk/jstest-gtk.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm jstest-gtk(1) OPTIONS section documents only
# -h/--help and -v/--version (lowercase -v, not uppercase -V).
# Removed from prior file: -V (real version flag is -v lowercase).

# jstest-gtk: GTK joystick test/calibration tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '*:joystick device:_files -g "/dev/input/js*"' && ret=0
return ret
