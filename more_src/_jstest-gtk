#compdef jstest-gtk
# Documentation: https://jstest-gtk.gitlab.io/
# Reference accessed: 2026-05-16

# jstest-gtk: GTK joystick test/calibration tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:joystick device:_files -g "/dev/input/js*"' && ret=0
return ret
