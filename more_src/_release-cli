#compdef release-cli
# Documentation: https://docs.gitlab.com/user/project/releases/release_cli/
# Reference accessed: 2026-05-17
# Verified: GitLab release-cli docs. NOTE: deprecated in GitLab 18.0,
# slated for removal in 20.0 — users directed to `glab`.
# Removed from prior file: bogus man.archlinux.org search URL;
# missing the `create` subcommand and its flags.

# release-cli: GitLab release automation (deprecated, use glab)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'create:create a release'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'release-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '--name=[release name]:name:' \
          '--tag-name=[tag name]:tag:' \
          '--description=[description (file or string)]:desc:' \
          '--ref=[ref]:ref:' \
          '--released-at=[released-at timestamp]:ts:' \
          '*--milestone=[milestone (repeatable)]:milestone:' \
          '*--assets-link=[asset link JSON (repeatable)]:json:' && ret=0
        ;;
    esac
    ;;
esac
return ret
