#compdef tasknc
# Documentation: https://github.com/lharding/tasknc/blob/master/doc/manual.pod
# tasknc - ncurses task manager wrapper around Taskwarrior

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug=}'[debug mode]:mode:(all eval_string task_count trim search set_var)' \
  '(-f --filter)'{-f,--filter=}'[set initial filter string]:filter' \
  '(-l --loglevel)'{-l,--loglevel=}'[set log level]:level' && ret=0

return ret
