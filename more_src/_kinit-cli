#compdef kinit-cli
# _kinit-cli — MIT Kerberos kinit obtain and cache Kerberos ticket-granting ticket CLI alias (krb5 team, C); custom argparse
# upstream: https://github.com/krb5/krb5

_kinit-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-l+[lifetime]:str:' \
        '-r+[renewable lifetime]:str:' \
        '-f[forwardable]' \
        '-F[not forwardable]' \
        '-p[proxiable]' \
        '-P[not proxiable]' \
        '-a[anonymous]' \
        '-A[no addresses]' \
        '-C[canonicalize]' \
        '-E[enterprise principal]' \
        '-s+[start time]:str:' \
        '-S+[service]:str:' \
        '-T+[armor ticket cache]:file:_files' \
        '-X+[attribute[=value]]:str:' \
        '-c+[cache name]:file:_files' \
        '-k[use keytab]' \
        '-i[use default client keytab]' \
        '-t+[keytab file]:file:_files' \
        '-n[anonymous principal]' \
        '-R[renew]' \
        '-v[validate]' \
        '*:principal:'
}

_kinit-cli "$@"
