#compdef slaacd
# _slaacd — OpenBSD slaacd (IPv6 SLAAC client daemon; watches interfaces with AUTOCONF6, sends router solicitations, and configures interface addresses from received RAs; controlled by slaacctl(8))
# upstream: https://github.com/openbsd/src (sbin/slaacd)
# Flags from sbin/slaacd/slaacd.8 on tip.

_slaacd() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-v[verbose]' \
        '-s+[control socket (default /dev/slaacd.sock)]:file:_files'
}

_slaacd "$@"
