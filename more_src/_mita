#compdef mita
# Documentation: https://github.com/enfein/mieru/blob/main/docs/operation.md
# mita - mieru proxy server software

local ret=1
local context curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'mita command' \
      'start[start the server proxy]' \
      'run[run the server in foreground]' \
      'stop[stop the server proxy]' \
      'reload[reload server configuration]' \
      'status[show server status]' \
      'apply[apply configuration]' \
      'describe[describe configuration]' \
      'get[read connections, metrics, users or quotas]' \
      'profile[manage profiling]' \
      'version[show version]' \
      'help[show help]' && ret=0
    ;;
  args)
    case $line[1] in
      apply|describe)
        _values 'subcommand' 'config[configuration]' && ret=0 ;;
      get)
        _values 'subcommand' \
          'connections[active connections]' \
          'metrics[runtime metrics]' \
          'users[registered users]' \
          'quotas[user quotas]' && ret=0 ;;
    esac
    ;;
esac

return ret
