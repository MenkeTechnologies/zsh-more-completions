#compdef kdump-config
# Manage kernel crash dump configuration

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'show:show current kdump status'
  'load:load kdump kernel'
  'unload:unload kdump kernel'
  'status:show kdump status'
  'start:start kdump service'
  'stop:stop kdump service'
  'restart:restart kdump service'
  'propagate:propagate SSH keys for remote dump'
  'test:test kdump configuration'
)

_arguments -s -S \
  '1:command:->command' && ret=0

case $state in
  (command)
    _describe -t commands 'kdump-config command' commands && ret=0
    ;;
esac

return ret
