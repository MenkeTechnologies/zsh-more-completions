#compdef ys-0 ys-0.1.90 ys-sh-0.1.90

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--run[run a YAMLScript program file (default)]' \
  {-l,--load}'[output JSON of YAMLScript evaluation]' \
  '*'{-e+,--eval=}'[evaluate a YAMLScript expression]:expr:' \
  {-c,--compile}'[compile YAMLScript to Clojure]' \
  {-b,--binary}'[compile to native binary]' \
  {-p,--print}'[print the result of --run]' \
  {-o+,--output=}'[output file]:file:_files' \
  {-s,--stream}'[output all results from a multi-document stream]' \
  {-T+,--to=}'[output format for --load]:format:(json yaml edn)' \
  {-J,--json}'[output pretty JSON for --load]' \
  {-Y,--yaml}'[output YAML for --load]' \
  {-E,--edn}'[output EDN for --load]' \
  {-U,--unordered}'[mappings do not preserve key order]' \
  {-m+,--mode=}'[mode tag]:mode:(code data bare)' \
  {-C,--clojure}'[treat input as Clojure code]' \
  '-d[debug all compilation stages]' \
  '*'{-D+,--debug-stage=}'[debug specific compilation stage]:stage:(parse compose resolve build transform construct print)' \
  {-S,--stack-trace}'[print full stack trace for errors]' \
  {-x,--xtrace}'[print each expression before evaluation]' \
  '--install[install libyamlscript]' \
  '--upgrade[upgrade ys and libyamlscript]' \
  '*:YAMLScript file:_files -g "*.(ys|yaml|yml)"' && ret=0

return ret
