#compdef ai
# Documentation: https://github.com/BuilderIO/ai-shell
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for ai-shell (ai CLI) - natural language to shell commands

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-s --silent)'{-s,--silent}'[skip explanations and run in silent mode]' \
  '--version[show version information]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'ai-shell command' \
      'chat[start an interactive AI conversation]' \
      'config[access configuration settings]' \
      'update[update to the latest version]' && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _values 'config command' \
          'set[set configuration key=value]' && ret=0
        ;;
    esac
    ;;
esac

return ret
