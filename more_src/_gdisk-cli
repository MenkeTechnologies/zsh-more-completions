#compdef gdisk-cli
# _gdisk-cli — Rod Smith gdisk interactive GUID partition table editor CLI alias (gdisk team, C++); custom argparse
# upstream: https://sourceforge.net/projects/gptfdisk/

_gdisk-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-v[show version]' \
        '-V[show version]' \
        '-l+[list partitions]:device:_files' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper}*"'
}

_gdisk-cli "$@"
