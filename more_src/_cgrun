#compdef cgrun

# cgrun: run a process inside a control group
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-g[cgroup spec]:spec:' \
  '--group=[cgroup spec]:spec:' \
  '-s[sticky (stay in cgroup)]' \
  '--sticky[sticky (stay in cgroup)]' \
  '*:cmd:_command_names' && ret=0
return ret
