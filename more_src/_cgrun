#compdef cgrun
# Documentation: https://github.com/kawamuray/cgrun
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--parent=[parent cgroup hierarchy to inherit]:path:' \
  '-u+[user (uid) for executing the program]:user:_users' \
  '-p+[target existing process by PID]:pid:_pids' \
  '--tree[with -p: apply to the entire process tree]' \
  '*::cgroup params and command:_default' && ret=0

return ret
