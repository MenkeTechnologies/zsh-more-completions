#compdef kafka-avro-console-consumer
# Documentation: https://docs.confluent.io/platform/current/schema-registry/fundamentals/serdes-develop/serdes-avro.html
# kafka-avro-console-consumer - read Avro data from a Kafka topic as JSON

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--bootstrap-server[Kafka broker to connect to]:broker:' \
  '--topic[topic to consume from]:topic:' \
  '--from-beginning[read from the beginning of the topic]' \
  '--group[consumer group id]:group:' \
  '*--property[set a formatter property (e.g. schema.registry.url, print.key, key.separator)]:property:' \
  '--consumer.config[consumer config properties file]:file:_files' \
  '--timeout-ms[exit if no message received within timeout]:ms:' \
  '*:arg:' && ret=0

return ret
