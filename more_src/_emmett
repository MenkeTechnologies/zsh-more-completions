#compdef emmett
# Documentation: https://emmett.sh/docs/2.0.x/cli
# Emmett - full-stack async Python web framework

local ret=1

local -a cmds
cmds=(
  'develop:Run a development server with reloader'
  'serve:Run a production server'
  'shell:Start an interactive shell with app context'
  'routes:List the application routes'
)

_arguments -s -C \
  '(-a --app)'{-a,--app}'=[application import path or file]:app' \
  '--help[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds) _describe -t commands 'emmett command' cmds && ret=0 ;;
  args)
    case $words[1] in
      develop)
        _arguments -s \
          '(-h --host)'{-h,--host}'=[bind host]:host' \
          '(-p --port)'{-p,--port}'=[bind port]:port' \
          '--interface=[server interface]:interface:(rsgi asgi)' \
          '--loop=[event loop]:loop:(auto asyncio rloop uvloop)' \
          '--task-impl=[task implementation]:impl:(asyncio rust)' \
          '--ssl-certfile=[SSL certificate file]:file:_files' \
          '--ssl-keyfile=[SSL key file]:file:_files' \
          '(--reloader --no-reloader)--reloader[enable the reloader]' \
          '(--reloader --no-reloader)--no-reloader[disable the reloader]' && ret=0
        ;;
      serve)
        _arguments -s \
          '(-h --host)'{-h,--host}'=[bind host]:host' \
          '(-p --port)'{-p,--port}'=[bind port]:port' \
          '(-w --workers)'{-w,--workers}'=[number of workers]:workers' \
          '--threads=[number of threads]:threads' \
          '--blocking-threads=[number of blocking threads]:threads' \
          '--runtime-mode=[runtime mode]:mode:(st mt)' \
          '--interface=[server interface]:interface:(rsgi asgi)' \
          '--http=[HTTP protocol]:http:(auto 1 2)' \
          '--http-read-timeout=[HTTP read timeout in ms]:ms' \
          '(--ws --no-ws)--ws[enable websockets]' \
          '(--ws --no-ws)--no-ws[disable websockets]' \
          '--loop=[event loop]:loop:(auto asyncio rloop uvloop)' \
          '--task-impl=[task implementation]:impl:(asyncio rust)' \
          '--log-level=[log level]:level:(critical error warning info debug)' \
          '(--access-log --no-access-log)--access-log[enable access log]' \
          '(--access-log --no-access-log)--no-access-log[disable access log]' \
          '--backlog=[socket backlog]:backlog' \
          '--backpressure=[backpressure limit]:limit' \
          '--ssl-certfile=[SSL certificate file]:file:_files' \
          '--ssl-keyfile=[SSL key file]:file:_files' && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
