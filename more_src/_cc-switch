#compdef cc-switch
# Documentation: https://github.com/SaladDay/cc-switch-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Note: the desktop app cc-switch (farion1231/cc-switch) is a Tauri GUI; this
# completion targets the cc-switch CLI fork (SaladDay/cc-switch-cli) which
# ships subcommands matching this layout.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'provider:manage API providers'
  'mcp:manage MCP servers'
  'prompts:manage system prompt presets'
  'skills:manage skill directories'
  'config:show/edit configuration'
  'proxy:manage proxy'
  'env:check environment variables and tools'
  'completions:manage shell completions'
  'update:update to latest release'
)

_arguments -s -S \
  '--app=[target application]:app:(claude codex gemini opencode openclaw)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cc-switch command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (provider)
        _arguments -s -S \
          '1:subcommand:(list current switch add edit duplicate delete export speedtest stream-check fetch-models)' && ret=0
        ;;
      (mcp)
        _arguments -s -S \
          '1:subcommand:(list add edit delete enable disable validate sync import)' && ret=0
        ;;
      (prompts)
        _arguments -s -S \
          '1:subcommand:(list current activate deactivate create rename edit show delete)' && ret=0
        ;;
      (skills)
        _arguments -s -S \
          '1:subcommand:(list discover install uninstall enable disable info sync sync-method scan-unmanaged import-from-apps repos)' && ret=0
        ;;
      (config)
        _arguments -s -S \
          '1:subcommand:(show path validate common backup restore export import webdav reset)' && ret=0
        ;;
      (proxy)
        _arguments -s -S \
          '1:subcommand:(show enable disable serve)' && ret=0
        ;;
      (env)
        _arguments -s -S '1:subcommand:(check list tools)' && ret=0
        ;;
      (completions)
        _arguments -s -S '1:subcommand:(install status uninstall)' && ret=0
        ;;
    esac
    ;;
esac

return ret
