#compdef cc-switch
# Documentation: https://man.archlinux.org/search?q=cc-switch
# Reference accessed: 2026-05-16

# Zsh completion for CC-Switch CLI
# https://github.com/lbjlaq/CC-Switch

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'provider:Manage API providers'
  'use:Switch active configuration'
  'mcp:Manage MCP servers'
  'prompts:Manage system prompts'
  'skill:Manage skill directories'
  'env:Check environment variables'
  'init:Interactive setup'
  'web:Launch web UI'
)

_arguments -s -S \
  '--app=[target application]:app:(claude codex gemini opencode openclaw)' \
  '--config-dir=[override config directory]:path:_directories' \
  '(-f --force)'{-f,--force}'[force action]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cc-switch command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (provider)
        _arguments -s -S '1:subcommand:(list show health)' && ret=0
        ;;
      (use)
        _arguments -s -S \
          '(-l --launch)'{-l,--launch}'[launch target CLI after switching]' \
          '(-p --previous)'{-p,--previous}'[switch to last configuration]' \
          '(-e --empty)'{-e,--empty}'[clear configuration]' \
          '1:provider name:' && ret=0
        ;;
      (mcp)
        _arguments -s -S \
          '1:subcommand:(list add enable disable sync)' \
          '--type=[transport type]:type:(stdio http sse)' && ret=0
        ;;
      (prompts)
        _arguments -s -S '1:subcommand:(list use)' && ret=0
        ;;
      (skill)
        _arguments -s -S '1:subcommand:(sync)' && ret=0
        ;;
      (env)
        _arguments -s -S '1:subcommand:(check list)' && ret=0
        ;;
    esac
    ;;
esac

return ret
