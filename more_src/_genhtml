#compdef genhtml

# Zsh completion for genhtml (lcov HTML report generator)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-o --output-directory)'{-o,--output-directory}'[output directory]:directory:_files -/' \
  '(-t --title)'{-t,--title}'[report title]:title' \
  '(-d --description-file)'{-d,--description-file}'[test description file]:file:_files' \
  '(-k --keep-descriptions)'{-k,--keep-descriptions}'[do not remove test descriptions]' \
  '(-b --baseline-file)'{-b,--baseline-file}'[baseline coverage data]:file:_files' \
  '(-p --prefix)'{-p,--prefix}'[remove prefix from filenames]:prefix' \
  '--no-prefix[do not remove prefix]' \
  '(-s --show-details)'{-s,--show-details}'[show detailed test case info]' \
  '(-f --frames)'{-f,--frames}'[use HTML frames]' \
  '--highlight[highlight lines with converted coverage]' \
  '--legend[include legend in output]' \
  '--html-prolog[HTML prolog file]:file:_files' \
  '--html-epilog[HTML epilog file]:file:_files' \
  '--html-extension[file extension]:extension' \
  '--html-gzip[compress HTML files with gzip]' \
  '--sort[sort file list]' \
  '--no-sort[do not sort file list]' \
  '--function-coverage[include function coverage]' \
  '--no-function-coverage[exclude function coverage]' \
  '--branch-coverage[include branch coverage]' \
  '--no-branch-coverage[exclude branch coverage]' \
  '--num-spaces[number of spaces per tab]:spaces' \
  '--css-file[external CSS file]:file:_files -g "*.css"' \
  '--precision[coverage rate decimal precision]:precision' \
  '--missed[show missed counts instead of hit counts]' \
  '--dark-mode[use dark color scheme]' \
  '--flat[use flat directory structure]' \
  '--demangle-cpp[demangle C++ function names]' \
  '--ignore-errors[ignore errors]:errors' \
  '--rc[override config option]:key=value' \
  '--config-file[config file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:coverage data file:_files -g "*.info"' && ret=0

return ret
