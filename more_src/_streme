#compdef streme
# Documentation: https://meme-suite.org/meme/doc/streme.html
# MEME Suite: discover ungapped motifs enriched in sequences

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--o=[output directory (default streme_out), fail if exists]:dir:_files -/' \
  '--oc=[output directory (default streme_out), overwrite if exists]:dir:_files -/' \
  '--p=[primary sequence file]:file:_files' \
  '--n=[control sequence file]:file:_files' \
  '--text[output text only to stdout]' \
  '--objfun=[objective function]:objfun:(de cd)' \
  '--notrim[do not trim sequences to a common length]' \
  '--order=[order of the Markov background model]:m:' \
  '--bfile=[background model file]:file:_files' \
  '--kmer=[preserve k-mer frequencies (deprecated)]:k:' \
  '--hofract=[fraction of sequences held out for testing]:hofract:' \
  '--totallength=[maximum total sequence length]:len:' \
  '--seed=[random number seed]:seed:' \
  '--thresh=[stop when motif significance exceeds this]:thresh:' \
  '--evalue[use E-value rather than p-value threshold]' \
  '--patience=[stop after this many non-improving motifs]:patience:' \
  '--nmotifs=[stop after finding this many motifs]:nmotifs:' \
  '--time=[stop after this many seconds]:secs:' \
  '--minw=[minimum motif width]:minw:' \
  '--maxw=[maximum motif width]:maxw:' \
  '--w=[exact motif width]:w:' \
  '--neval=[number of seed words to evaluate]:neval:' \
  '--nref=[number of seeds to refine]:nref:' \
  '--niter=[number of refinement iterations]:niter:' \
  '--align=[alignment of sequences for the site histogram]:align:(left center right)' \
  '--verbosity=[verbosity level]:level:(1 2 3 4 5)' \
  '*:sequence file:_files' && ret=0

return ret
