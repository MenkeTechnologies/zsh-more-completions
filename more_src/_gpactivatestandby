#compdef gpactivatestandby
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gpactivatestandby.html
# Activate a standby coordinator host as the active Greenplum coordinator

local ret=1

_arguments -s -S \
  '(-h -? --help)'{-h,-\?,--help}'[display online help]' \
  '-a[do not prompt for confirmation]' \
  '-d[absolute path to the data directory for the coordinator being activated]:dir:_files -/' \
  '-f[force activation of the backup coordinator]' \
  '-l[directory to write log output]:dir:_files -/' \
  '-q[operate in quiet mode]' \
  '-v[display version, status, last updated date, and checksum]' && ret=0

return ret
