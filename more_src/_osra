#compdef osra
# Documentation: https://github.com/metamolecular/osra/blob/master/README
# Optical Structure Recognition - convert images of molecules to SMILES/SDF

local ret=1

_arguments -s -S \
  '(-r --resolution)'{-r,--resolution}'=[DPI for image processing]:dpi:' \
  '(-t --threshold)'{-t,--threshold}'=[gray level threshold]:value:' \
  '(-n --negate)'{-n,--negate}'[invert colors for white-on-black images]' \
  '(-o --output)'{-o,--output}'=[prefix for writing recognized structures to files]:prefix:' \
  '(-s --size)'{-s,--size}'=[resize output images]:size:' \
  '(-g --guess)'{-g,--guess}'[display resolution estimate]' \
  '(-p --print)'{-p,--print}'[output confidence function estimate]' \
  '(-f --format)'{-f,--format}'=[output format]:format:(smi sdf rxn rsmi cmlr)' \
  '(-d --debug)'{-d,--debug}'[print debugging info on spelling corrections]' \
  '(-a --superatom)'{-a,--superatom}'=[superatom label mapping file]:file:_files' \
  '(-l --spelling)'{-l,--spelling}'=[spelling correction dictionary file]:file:_files' \
  '(-u --unpaper)'{-u,--unpaper}'=[pre-process with unpaper rounds]:rounds:' \
  '(-w --write)'{-w,--write}'=[write output to file instead of stdout]:file:_files' \
  '(-b --bond)'{-b,--bond}'[show average bond length in pixels]' \
  '(-j --jaggy)'{-j,--jaggy}'[additional thinning for low-quality documents]' \
  '(-i --adaptive)'{-i,--adaptive}'[adaptive thresholding for low-contrast images]' \
  '(-c --coordinates)'{-c,--coordinates}'[display bounding box coordinates]' \
  '--embedded-format=[embed InChI or SMILES as molecular property in SDF]:format:' \
  '*:image file:_files' && ret=0

return ret
