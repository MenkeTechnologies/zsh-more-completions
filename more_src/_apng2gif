#compdef apng2gif
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/apng2gif.1.html
# convert APNG animated images to GIF files

local ret=1

_arguments -s \
  '-t+[transparency threshold level (alpha below becomes transparent)]:tlevel' \
  '-b+[background colour for partially transparent pixels (composes over it)]:bcolor' \
  '-l+[loop count (0 = infinite, orig = keep original)]:loops' \
  '1:input apng:_files -g "*.(png|apng|PNG)"' \
  '2:output gif:_files -g "*.(gif|GIF)"' && ret=0

return ret
