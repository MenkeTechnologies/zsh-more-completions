#compdef chirpc experttune
# Documentation: source-direct extraction from upstream
# kk7ds/chirp setup.py `entry_points.console_scripts`
# (3 entries: `chirp=chirp.wxui:chirpmain`,
# `chirpc=chirp.cli.main:main`, `experttune=chirp.cli.experttune:main`)
# + chirp/cli/main.py argparse declarations +
# chirp/cli/experttune.py argparse declarations. `chirp` itself
# is a wxPython GUI launcher (chirp.wxui:chirpmain) intentionally
# omitted from this #compdef line since it has minimal CLI
# surface.
# Reference accessed: 2026-05-30 via gh api.
# kk7ds CHIRP R154b — 2-stem multi-binary harvest of the 2 CLI
# binaries from the CHIRP ham-radio programming toolkit not
# previously covered. Sister to the heavily-covered ham radio
# family (fldigi/flrig/wsjtx/direwolf/gpredict/rigctl from R154a's
# upstream).

case $service in

  chirpc)
    # CHIRP CLI for programming memory channels into a connected
    # ham radio via serial (or MMAP file image).
    _arguments -s -S \
      '(-s --serial)'{-s+,--serial=}'[serial port to use (or "mmap" for file image)]:port:_files -g "/dev/tty*"' \
      '(-r --radio)--radio=[radio model name]:model:' \
      '(-i --id)'{-i,--id}'[query and print radio ident]' \
      '--mmap=[MMAP image file]:file:_files -g "*.img"' \
      '--download-mmap=[download radio memory into MMAP image]:file:_files -g "*.img"' \
      '--upload-mmap=[upload MMAP image into radio memory]:file:_files -g "*.img"' \
      '--list-radios[list supported radio models and exit]' \
      '--list-settings[list available radio settings]' \
      '--list-mem[list all memory locations]' \
      '--list-special-mem[list special memory locations (e.g. scan-edge, CALL channels)]' \
      '--raw[dump the raw bytes of a memory location]' \
      '--get-mem[get and print one memory location]' \
      '--copy-mem[copy a memory location to another slot]' \
      '--clear-mem[clear a memory location]' \
      '--set-mem-name=[set memory name]:name:' \
      '--set-mem-freq=[set RX frequency (MHz)]:mhz:' \
      '--set-mem-mode=[set memory mode]:mode:(FM AM NFM WFM USB LSB CW DV DN)' \
      '--set-mem-offset=[set TX offset (MHz)]:mhz:' \
      '--set-mem-dup=[set duplex direction]:dup:(\\\+ \\\- off split)' \
      '--set-mem-tenc=[set transmit tone encoder type]:type:(Tone DTCS Cross)' \
      '--set-mem-tencoff[disable transmit tone encoder]' \
      '--set-mem-tencon[enable transmit tone encoder]' \
      '--set-mem-tsql=[set receive tone-squelch frequency]:hz:' \
      '--set-mem-tsqloff[disable tone-squelch RX]' \
      '--set-mem-tsqlon[enable tone-squelch RX]' \
      '--set-mem-dtcs=[set DTCS code]:code:' \
      '--set-mem-dtcsoff[disable DTCS]' \
      '--set-mem-dtcson[enable DTCS]' \
      '--set-mem-dtcspol=[set DTCS polarity TX:RX (NN/NR/RN/RR)]:pol:(NN NR RN RR)' \
      '*:memory location number(s):'
    ;;

  experttune)
    # Auto-tune an SPE Expert linear amplifier via CAT control.
    # Reads BANDS table from chirp.cli.experttune for the bands
    # enum below (160/80/40/30/20/17/15/12/10/6 meter US ham bands
    # within band-edge limits).
    _arguments -s -S \
      '--bands=[comma-separated list of bands to tune]:bands (e.g. 40\,20\,15):' \
      '--call=[callsign for CW ID after each step]:callsign:' \
      '--next=[next-step strategy]:strategy:(interactive auto)' \
      '--debug[enable verbose debugging]' \
      '1:radio model:' \
      '2:CAT serial port:_files -g "/dev/tty*"'
    ;;

esac
