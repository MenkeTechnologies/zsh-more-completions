#compdef qltool
# Documentation: https://docs.qiling.io/en/latest/qltool/
# Qiling Framework command-line emulation tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --filename)'{-f,--filename}'[binary filename to emulate]:file:_files' \
  '--rootfs[emulation root directory for libraries]:dir:_files -/' \
  '--args[program command line arguments]:args' \
  '(-i --input)'{-i,--input}'[input hex string]:hex' \
  '--format[file/input format]:format:(asm hex bin)' \
  '--arch[target architecture]:arch:(x86 x8664 arm arm_thumb arm64 mips a8086 evm)' \
  '--endian[target endianness]:endian:(little big)' \
  '--os[target operating system]:os:(linux freebsd macos windows uefi dos evm)' \
  '(-v --verbose)'{-v,--verbose}'[logging verbosity]:level:(off default debug disasm dump)' \
  '--env[environment dictionary file or python string]:env' \
  '(-g --gdb)'{-g,--gdb}'[enable gdb server with optional address:port]:addr' \
  '--qdb[attach debugger (MIPS/ARM thumb only)]' \
  '--rr[enable record/replay feature]' \
  '--profile[specify profile file]:file:_files' \
  '--no-console[suppress program output]' \
  '(-e --filter)'{-e,--filter}'[regexp filtering on logs]:regexp' \
  '--log-file[output logs to file]:file:_files' \
  '--log-plain[disable colored log output]' \
  '--root[enable sudo-required mode]' \
  '--debug-stop[halt on first error]' \
  '(-m --multithread)'{-m,--multithread}'[multithread execution]' \
  '--timeout[emulation timeout in microseconds]:usec' \
  '(-c --coverage-file)'{-c,--coverage-file}'[code coverage output]:file:_files' \
  '--coverage-format[coverage format]:format:(drcov drcov_exact)' \
  '--json[emit JSON report]' \
  '1:command:(run code qltui examples)' \
  '*:arg:_files' && ret=0

return ret
