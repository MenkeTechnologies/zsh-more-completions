#compdef csvjoin
# Documentation: https://csvkit.readthedocs.io/en/latest/scripts/csvjoin.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[print full tracebacks on errors]' \
  '-d+[delimiting character]:delimiter' \
  '--delimiter=[delimiting character]:delimiter' \
  '-t[specify that input is tab-delimited]' \
  '--tabs[specify that input is tab-delimited]' \
  '-q+[quoting character]:character' \
  '--quotechar=[quoting character]:character' \
  '-u+[quoting style]:style:(0 1 2 3)' \
  '--quoting=[quoting style]:style:(0 1 2 3)' \
  '-b[do not interpret double-quote as escape]' \
  '--no-doublequote[do not interpret double-quote as escape]' \
  '-p+[escape character]:character' \
  '--escapechar=[escape character]:character' \
  '-z+[maximum field length]:size' \
  '--maxfieldsize=[maximum field length]:size' \
  '-e+[encoding]:encoding' \
  '--encoding=[encoding]:encoding' \
  '-L+[locale for parsing formatted numbers]:locale' \
  '--locale=[locale for parsing formatted numbers]:locale' \
  '-S[ignore whitespace after delimiter]' \
  '--skipinitialspace[ignore whitespace after delimiter]' \
  '--blanks[do not convert empty cells to NULL]' \
  '--null-value=[treat string as NULL]:value' \
  '--date-format=[strptime date format]:format' \
  '--datetime-format=[strptime datetime format]:format' \
  '-H[no header row]' \
  '--no-header-row[no header row]' \
  '-K+[skip lines before header]:number' \
  '--skip-lines=[skip lines before header]:number' \
  '-c+[columns to join on]:columns' \
  '--columns=[columns to join on]:columns' \
  '--outer[perform a full outer join]' \
  '--left[perform a left outer join]' \
  '--right[perform a right outer join]' \
  '-y+[sniff limit (bytes)]:limit' \
  '--snifflimit=[sniff limit (bytes)]:limit' \
  '-I[disable type inference]' \
  '--no-inference[disable type inference]' \
  '*:CSV file:_files -g "*.{csv,tsv,txt}"' && ret=0

return ret
