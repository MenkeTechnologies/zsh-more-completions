#compdef codemie
# Documentation: https://github.com/codemie-ai/codemie-code
# Reference accessed: 2026-05-22
# Verified: src/cli/index.ts Commander program.addCommand registrations.

# Zsh completion for codemie - AI/Run CodeMie multi-agent CLI wrapper

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--task[run built-in agent task and exit]:task:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'codemie command' \
      'setup[interactive configuration]' \
      'profile[manage profiles]' \
      'assistants[manage assistants]' \
      'list[list agents]' \
      'install[install agent]' \
      'uninstall[uninstall agent]' \
      'update[update agent]' \
      'self-update[update CodeMie CLI]' \
      'doctor[diagnose setup]' \
      'version[show version]' \
      'workflow[workflow commands]' \
      'analytics[analytics]' \
      'log[logs]' \
      'hook[hooks]' \
      'sound[sound settings]' \
      'skill[skill command]' \
      'skills[skills management]' \
      'plugin[plugin management]' \
      'opencode-metrics[OpenCode metrics]' \
      'test-metrics[test metrics]' \
      'models[models]' \
      'sdk[SDK commands]' \
      'mcp[MCP commands]' \
      'mcp-proxy[MCP proxy]' \
      'proxy[proxy daemon]' \
      'codebase[codebase memory]' && ret=0
    ;;
  args)
    case $line[1] in
      proxy)
        _values 'proxy command' connect inspect stop && ret=0
        ;;
      codebase)
        _values 'codebase command' ui && ret=0
        ;;
      *)
        _arguments '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
