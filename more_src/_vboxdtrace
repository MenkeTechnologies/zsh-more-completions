#compdef vboxdtrace VBoxDTrace
# Documentation: https://man.archlinux.org/search?q=vboxdtrace
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-32[32-bit mode]' \
  '-64[64-bit mode]' \
  '-aACeEFGhHilLnPqsSvVwxXZ[various dtrace options]' \
  '-b+[bufsize]:size:' \
  '-c+[command to trace]:cmd:_command_names' \
  '-D+[macro define]:def:' \
  '-I+[include path]:dir:_files -/' \
  '-L+[library path]:dir:_files -/' \
  '-o+[output file]:file:_files' \
  '-p+[trace pid]:pid:_pids' \
  '-s+[script file]:file:_files -g "*.d"' \
  '-U+[undef macro]:macro:' \
  '*:probe:' && ret=0

return ret
