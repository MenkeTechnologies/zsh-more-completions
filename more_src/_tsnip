#compdef tsnip
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tsnip.cpp
# tsnip - analyze a DVB Native IP (DVB-NIP) capture file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:pcap file:_files -g "*.pcap *.pcapng"' && ret=0

return ret
