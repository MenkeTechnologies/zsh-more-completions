#compdef cargo-bench-cmp critcmp
# Documentation: https://man.archlinux.org/search?q=cargo-bench-cmp
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (cargo-bench-cmp|critcmp)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-b --baseline)*'{-b+,--baseline=}'[baseline name]:name:' \
      '(-f --filter)'{-f+,--filter=}'[filter regex]:re:' \
      '(-g --group)'{-g+,--group=}'[group regex]:re:' \
      '(-l --list)'{-l,--list}'[list baselines]' \
      '(--export)*--export=[export name]:name:' \
      '(-t --threshold)'{-t+,--threshold=}'[threshold pct]:n:' \
      '(--target-dir)--target-dir=[target dir]:dir:_files -/' \
      '*:: :_normal' && ret=0 ;;
esac

return ret
