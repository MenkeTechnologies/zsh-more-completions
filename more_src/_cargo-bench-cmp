#compdef cargo-bench-cmp
# Documentation: https://github.com/BurntSushi/cargo-benchcmp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Note: canonical binary is `cargo-benchcmp` (no dash). This filename is an
# alias preserved for historical install paths; forwards to cargo-benchcmp.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--include-missing[print benchmarks missing from either side]' \
  '--threshold=[only show changes above percent threshold]:percent:' \
  '--variance[include timing variance columns]' \
  '--improvements[only improvements]' \
  '--regressions[only regressions]' \
  '--color=[row coloring]:when:(never always auto)' \
  '*:input:_files' && return 0
