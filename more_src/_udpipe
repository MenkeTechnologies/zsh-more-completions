#compdef udpipe
# Documentation: https://ufal.mff.cuni.cz/udpipe/1/users-manual
# UDPipe tokenizer, tagger, lemmatizer and dependency parser

local ret=1

_arguments -s -S \
  '--help[display help message]' \
  '--version[display version information]' \
  '--tokenize[perform tokenization]' \
  '--tag[perform tagging]' \
  '--parse[perform parsing]' \
  '--immediate[process sentences immediately during loading]' \
  '--input=[input format]:format:(conllu generic_tokenizer horizontal vertical)' \
  '--output=[output format]:format:(conllu matxin horizontal plaintext vertical)' \
  '--outfile=[save output to file with optional {} substitution]:template' \
  '--tokenizer=[configure tokenizer (implies --tokenize)]:opts' \
  '--tagger=[configure tagger (implies --tag)]:opts' \
  '--parser=[configure parser (implies --parse)]:opts' \
  '--accuracy[measure accuracy only]' \
  '--train[train a new model]' \
  '--method=[training method]:method:(morphodita_parsito)' \
  '--heldout=[heldout validation data]:file:_files' \
  '--detokenize[generate SpaceAfter features from plain text]' \
  '*:file:_files' && ret=0

return ret
