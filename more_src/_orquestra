#compdef orquestra orq orquestra-cli
# _orquestra — Zapata Computing Orquestra orq CLI for declarative quantum workflow execution on backends (zapatacomputing team, Python); click
# upstream: https://github.com/zapatacomputing/orquestra-sdk

_orquestra() {
    local -a sub=(
        'login:login to Orquestra'
        'logout:logout'
        'submit:submit a workflow'
        'workflow:workflow subcommands'
        'wf:workflow alias'
        'task:task subcommands'
        'config:config subcommands'
        'logs:fetch workflow logs'
        'down:tear down resources'
        'up:start runtime'
        'restart:restart runtime'
        'status:show status'
        'tools:tools subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config=+[config name]:str:' \
        '-c+[config name]:str:' \
        '--config-file=+[config file]:file:_files -g "*.json *.yaml *.yml"' \
        '--runtime-name=+[runtime]:r:(ray_local in_process ce qe ce_compute_engine)' \
        '--workspace-id=+[workspace]:str:' \
        '--project-id=+[project]:str:' \
        '--api-uri=+[api URL]:url:_urls' \
        '--token=+[auth token]:str:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'orquestra subcommand' sub ;;
        args)
            case $words[1] in
                submit) _arguments \
                    '--config=+[config name]:str:' \
                    '--workspace-id=+[workspace]:str:' \
                    '--project-id=+[project]:str:' \
                    '--force[force submit]' \
                    '*:workflow file:_files -g "*.py *.yaml *.yml"' ;;
                workflow|wf) _arguments '1:workflow cmd:(list submit view stop graph status logs results download summary)' ;;
                task) _arguments '1:task cmd:(list view results logs)' ;;
                config) _arguments '1:config cmd:(list set get remove)' ;;
                login) _arguments \
                    '--server=+[server URL]:url:_urls' \
                    '--passport-file=+[passport file]:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_orquestra "$@"
