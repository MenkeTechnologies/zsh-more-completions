#compdef sreport
# _sreport — SchedMD Slurm sreport (accounting database reporting tool; subcommands: cluster (AccountUtilizationByUser|UserUtilizationByAccount|Utilization|WCKeyUtilizationByUser), job (SizesByAccount|SizesByWcKey), reservation (Utilization), user (TopUsage); -t time format, -P parsable, -n no headers, -M clusters, -T elapsed cutoff, -a all clusters, --tres types)
# upstream: https://github.com/SchedMD/slurm
# Flags from SchedMD/slurm src/sreport/sreport.c on tip.

_sreport() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a[all clusters]' \
        '-n[no headers]' \
        '-P[parsable]' \
        '-Q[quiet]' \
        '-v[verbose]' \
        '-t+[time format]:fmt:(SecPer MinPer HourPer Hours Minutes Seconds Percent)' \
        '-T+[elapsed cutoff]:time:' \
        '-M+[clusters]:clusters:' \
        '--tres+[tres types]:tres:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'sreport report' '(cluster job reservation user)' ;;
        args)
            case $line[1] in
                cluster) _describe -t commands 'cluster report' '(AccountUtilizationByUser UserUtilizationByAccount Utilization WCKeyUtilizationByUser)' ;;
                job) _describe -t commands 'job report' '(SizesByAccount SizesByWcKey)' ;;
                reservation) _describe -t commands 'reservation report' '(Utilization)' ;;
                user) _describe -t commands 'user report' '(TopUsage)' ;;
            esac
            ;;
    esac
}

_sreport "$@"
