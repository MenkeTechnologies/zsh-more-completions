#compdef scil_NODDI_maps
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_NODDI_maps.html
# Scilpy: compute NODDI microstructure maps from a DWI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--mask=[brain mask]:mask:_files' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--replace_bad_voxels=[value to replace NaNs/infs]:value' \
  '--tolerance=[tolerated gap between b-values]:tol' \
  '--para_diff=[axial diffusivity]:value' \
  '--iso_diff=[mean diffusivity]:value' \
  '--lambda1=[first regularization parameter]:value' \
  '--lambda2=[second regularization parameter]:value' \
  '--save_kernels=[directory to save kernels]:dir:_files -/' \
  '--load_kernels=[directory to load kernels]:dir:_files -/' \
  '--processes=[number of sub-processes]:nbr' \
  '--compute_rmse[compute RMSE map]' \
  '--compute_nrmse[compute NRMSE map]' \
  '--skip_b0_check[skip b0 existence validation]' \
  '--compute_only[compute kernels only]' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_dwi:_files' \
  '2:in_bval:_files' \
  '3:in_bvec:_files' && ret=0

return ret
