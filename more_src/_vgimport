#compdef vgimport
# _vgimport — import an exported volume group (LVM2); make it active on this host
# upstream: https://gitlab.com/lvmteam/lvm2

_vgimport() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-a --all)'{-a,--all}'[all exported vgs]' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '*:vg:'
}

_vgimport "$@"
