#compdef xl
# Documentation: https://xenbits.xen.org/docs/unstable/man/xl.1.html
# Reference accessed: 2026-05-21
# Verified: upstream Xen xl(1) manpage at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'console:attach to domain console'
  'create:create and start a domain'
  'config-update:update saved config'
  'destroy:terminate a domain'
  'domid:name to ID'
  'domname:ID to name'
  'dump-core:dump VM memory'
  'help:show help'
  'list:list domains'
  'mem-set:set memory balloon'
  'mem-max:set max memory'
  'migrate:migrate to another host'
  'pause:pause a domain'
  'reboot:reboot a domain'
  'rename:rename domain'
  'remus:enable Remus/COLO HA'
  'restore:restore from save'
  'resume:resume suspended domain'
  'save:save running domain'
  'sharing:show shared pages'
  'shutdown:graceful shutdown'
  'suspend:suspend domain'
  'sysrq:send Magic SysRq'
  'trigger:send trigger event'
  'unpause:resume paused domain'
  'vcpu-list:list VCPUs'
  'vcpu-pin:set VCPU affinity'
  'vcpu-set:enable VCPUs'
  'vm-list:list guest info'
  'vncviewer:attach to VNC'
  'debug-keys:debug keys'
  'dmesg:print Xen dmesg'
  'info:host info'
  'set-parameters:set host parameters'
  'top:host top'
  'uptime:host uptime'
  'claims:show claims'
  'sched-credit:credit scheduler'
  'sched-credit2:credit2 scheduler'
  'sched-rtds:RTDS scheduler'
  'cpupool-cpu-add:add CPU to pool'
  'cpupool-cpu-remove:remove CPU from pool'
  'cpupool-create:create a CPU pool'
  'cpupool-destroy:destroy CPU pool'
  'cpupool-list:list CPU pools'
  'cpupool-migrate:migrate domain to pool'
  'cpupool-numa-split:split pools by NUMA'
  'cpupool-rename:rename CPU pool'
  'block-attach:attach block device'
  'block-detach:detach block device'
  'block-list:list block devices'
  'cd-eject:eject CD'
  'cd-insert:insert CD'
  'channel-list:list channels'
  'network-attach:attach network device'
  'network-detach:detach network device'
  'network-list:list network devices'
  'vtpm-attach:attach vTPM'
  'vtpm-detach:detach vTPM'
  'vtpm-list:list vTPMs'
  'pci-assignable-add:make PCI assignable'
  'pci-assignable-list:list assignable PCI'
  'pci-assignable-remove:unmake PCI assignable'
  'pci-attach:attach PCI device'
  'pci-detach:detach PCI device'
  'pci-list:list PCI assignments'
  'usb-list:list USBs'
  'usbctrl-attach:attach USB controller'
  'usbctrl-detach:detach USB controller'
  'usbdev-attach:attach USB device'
  'usbdev-detach:detach USB device'
  'qemu-monitor-command:qemu monitor command'
  'getenforce:get FLASK enforce'
  'loadpolicy:load FLASK policy'
  'setenforce:set FLASK enforce'
)

_arguments -C \
  '-v[verbose]' \
  '-N[dry run]' \
  '-f[force]' \
  '-t[carriage-return progress]' \
  '-T[include timestamps]' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'xl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[quiet]' \
          '(-f --defconfig)'{-f=,--defconfig=}'[default config]:file:_files' \
          '-p[start paused]' \
          '-F[foreground]' \
          '(-V --vncviewer)'{-V,--vncviewer}'[start vncviewer]' \
          '(-A --vncviewer-autopass)'{-A,--vncviewer-autopass}'[vncviewer autopass]' \
          '-c[attach console]' \
          ':configfile:_files' && ret=0
        ;;
      (shutdown)
        _arguments \
          '(-a --all)'{-a,--all}'[shutdown all]' \
          '(-w --wait)'{-w,--wait}'[wait]' \
          '-F[ACPI fallback]' && ret=0
        ;;
      (list)
        _arguments \
          '(-l --long)'{-l,--long}'[long format]' \
          '(-Z --context)'{-Z,--context}'[show context]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '(-c --cpupool)'{-c,--cpupool}'[show cpupool]' \
          '(-n --numa)'{-n,--numa}'[show numa]' && ret=0
        ;;
    esac
    ;;
esac

return ret
