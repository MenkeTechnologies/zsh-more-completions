#compdef vivliostyle
# Documentation: https://raw.githubusercontent.com/vivliostyle/vivliostyle-cli/main/README.md
# Vivliostyle CLI - command-line publication workflow (CSS typesetting to PDF)

local ret=1

local -a subcmds
subcmds=(
  'init:create a vivliostyle config file'
  'build:build publication file(s)'
  'preview:open preview in browser'
)

_arguments -C \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'vivliostyle command' subcmds && ret=0
    ;;
  args)
    case "$words[1]" in
      init)
        _arguments -s \
          '--title=[title]:title' \
          '--author=[author]:author' \
          '(-l --language)'{-l,--language}'=[language]:language' \
          '(-s --size)'{-s,--size}'=[output size preset]:size' \
          '(-T --theme)'{-T,--theme}'=[theme path or package]:theme' \
          '--log-level=[log level]:level:(silent info verbose debug)' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      build)
        _arguments -s \
          '(-c --config)'{-c,--config}'=[config file]:config:_files' \
          '*'{-o,--output}'=[output path]:path:_files' \
          '*'{-f,--format}'=[output format]:format:(pdf webpub epub epub-opf)' \
          '(-s --size)'{-s,--size}'=[output size preset]:size' \
          '(-m --crop-marks)'{-m,--crop-marks}'[print crop marks]' \
          '--bleed=[bleed region]:bleed' \
          '--crop-offset=[crop offset]:offset' \
          '--css=[custom CSS string]:css' \
          '--style=[additional stylesheet]:style:_files' \
          '--user-style=[user stylesheet]:style:_files' \
          '(-d --single-doc)'{-d,--single-doc}'[single HTML document input]' \
          '(-p --press-ready)'{-p,--press-ready}'[generate press-ready PDF]' \
          '(-t --timeout)'{-t,--timeout}'=[timeout seconds]:seconds' \
          '*'{-T,--theme}'=[theme path or package]:theme' \
          '--title=[title]:title' \
          '--author=[author]:author' \
          '(-l --language)'{-l,--language}'=[language]:language' \
          '--reading-progression=[reading direction]:dir:(ltr rtl)' \
          '--render-mode=[render mode]:mode:(local docker)' \
          '--preflight=[preflight mode]:mode:(press-ready press-ready-local)' \
          '*--preflight-option=[preflight option]:option' \
          '--executable-browser=[browser executable path]:path:_files' \
          '--image=[docker image]:image' \
          '--viewer=[viewer URL]:url' \
          '--viewer-param=[viewer parameters]:params' \
          '--browser=[browser type]:browser:(chromium firefox webkit)' \
          '--proxy-server=[proxy server]:server' \
          '--proxy-bypass=[proxy bypass]:bypass' \
          '--proxy-user=[proxy user]:user' \
          '--proxy-pass=[proxy password]:pass' \
          '--log-level=[log level]:level:(silent info verbose debug)' \
          '--ignore-https-errors[ignore HTTPS errors]' \
          '--host=[host]:host' \
          '--port=[port]:port' \
          '--no-enable-static-serve[disable static file serving]' \
          '--vite-config-file=[vite config path]:path:_files' \
          '--no-vite-config-file[ignore vite config file]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:input:_files' && ret=0
        ;;
      preview)
        _arguments -s \
          '(-c --config)'{-c,--config}'=[config file]:config:_files' \
          '*'{-T,--theme}'=[theme path or package]:theme' \
          '(-s --size)'{-s,--size}'=[output size preset]:size' \
          '(-m --crop-marks)'{-m,--crop-marks}'[print crop marks]' \
          '--bleed=[bleed region]:bleed' \
          '--crop-offset=[crop offset]:offset' \
          '--css=[custom CSS string]:css' \
          '--style=[additional stylesheet]:style:_files' \
          '--user-style=[user stylesheet]:style:_files' \
          '(-d --single-doc)'{-d,--single-doc}'[single HTML document input]' \
          '(-q --quick)'{-q,--quick}'[quick loading with rough page count]' \
          '--title=[title]:title' \
          '--author=[author]:author' \
          '(-l --language)'{-l,--language}'=[language]:language' \
          '--reading-progression=[reading direction]:dir:(ltr rtl)' \
          '--executable-browser=[browser executable path]:path:_files' \
          '--viewer=[viewer URL]:url' \
          '--viewer-param=[viewer parameters]:params' \
          '--browser=[browser type]:browser:(chromium firefox webkit)' \
          '--proxy-server=[proxy server]:server' \
          '--proxy-bypass=[proxy bypass]:bypass' \
          '--proxy-user=[proxy user]:user' \
          '--proxy-pass=[proxy password]:pass' \
          '--log-level=[log level]:level:(silent info verbose debug)' \
          '--ignore-https-errors[ignore HTTPS errors]' \
          '--host=[host]:host' \
          '--port=[port]:port' \
          '--no-open-viewer[do not open viewer]' \
          '--no-enable-static-serve[disable static file serving]' \
          '--no-enable-viewer-start-page[disable viewer start page]' \
          '--vite-config-file=[vite config path]:path:_files' \
          '--no-vite-config-file[ignore vite config file]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:input:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
