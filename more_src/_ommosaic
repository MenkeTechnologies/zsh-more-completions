#compdef ommosaic
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/ommosaic/node5.html
# Stack a list of OM product images, optionally aligning before stacking

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--imagesets=[list of input image datasets to be mosaiced]:files:_files' \
  '--mosaicedset=[name of output mosaiced image dataset]:file:_files' \
  '--correlset=[name of output correlation file dataset]:file:_files' \
  '--binaxis=[image binning factor, 0 for largest of inputs]:value' \
  '--mincorr=[minimum acceptable correlation for alignment]:value' \
  '--nsigma=[pixel selection threshold for cross-correlation]:value' \
  '--minfraction=[minimum acceptable area overlap before alignment]:value' \
  '--maxdx=[maximum x and y offsets between reference pixels]:value' \
  '--numintervals=[number of intervals to split an offset value into]:n' \
  '--di=[correlation image is 2*di+1 pixels square]:value' \
  '--minnumpixels=[minimum pixels above background for cross-correlation]:n' \
  '*:param=value:_default' && ret=0

return ret
