#compdef ipdbpp
# Documentation: https://github.com/gotcha/ipdb/blob/master/ipdb/__main__.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. No canonical ipdbpp CLI; mirrors ipdb interface (STUB).

# ipdbpp: pdbpp-flavored ipdb (no distinct upstream CLI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*'{-c,--command}'[run command on start]:cmd:' \
  '-m[run target as module]' \
  '*:python script:_files -g "*.py"' && ret=0
return ret
