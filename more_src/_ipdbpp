#compdef ipdbpp

# ipdbpp: pdbpp-flavored ipdb
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-c[run command on start]:cmd:' \
  '-m[run module]:module:' \
  '-p[post-mortem on file]:file:_files' \
  '*:python script:_files -g "*.py"' && ret=0
return ret
