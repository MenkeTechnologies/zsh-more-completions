#compdef vconfig
# Documentation: https://man.archlinux.org/search?q=vconfig
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add a VLAN to an interface'
  'rem:remove a VLAN interface'
  'set_flag:set a flag on a VLAN interface'
  'set_egress_map:set egress priority map'
  'set_ingress_map:set ingress priority map'
  'set_name_type:set VLAN name type'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vconfig command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '1:interface:_net_interfaces' \
          '2:vlan_id:' && ret=0 ;;
      (rem)
        _arguments \
          '1:vlan_interface:_net_interfaces' && ret=0 ;;
      (set_flag)
        _arguments \
          '1:vlan_interface:_net_interfaces' \
          '2:flag:(0 1)' \
          '3:value:(0 1)' && ret=0 ;;
      (set_egress_map|set_ingress_map)
        _arguments \
          '1:vlan_interface:_net_interfaces' \
          '2:skb_priority:' \
          '3:vlan_qos:' && ret=0 ;;
      (set_name_type)
        _arguments \
          '1:name_type:(VLAN_PLUS_VID VLAN_PLUS_VID_NO_PAD DEV_PLUS_VID DEV_PLUS_VID_NO_PAD)' && ret=0 ;;
    esac ;;
esac

return ret
