#compdef troposphere-cli
# Documentation: https://github.com/jeanphix/troposphere-cli
# troposphere-cli - manage troposphere CloudFormation stacks

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-r --region)'{-r,--region}'=[AWS region]:region:' \
  '1:command:(create update list events outputs parameters template)' \
  '*::arg:_files' && ret=0

return ret
