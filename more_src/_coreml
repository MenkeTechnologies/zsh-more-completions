#compdef coremlcompiler coremlc coreml-tools coreml
# _coreml — Apple coremlcompiler convert and compile Core ML mlmodel and mlpackage assets for iOS macOS deployment (apple team, Swift/ObjC); custom argparse
# upstream: https://developer.apple.com/documentation/coreml

_coreml() {
    local -a sub=(
        'compile:compile mlmodel/mlpackage to mlmodelc'
        'generate:generate model class file'
        'metadata:show model metadata'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-target+[target arch]:t:(arm64 x86_64 universal)' \
        '-deployment-target+[OS version]:str:' \
        '-output+[output dir]:dir:_files -/' \
        '-language+[language]:l:(swift objective-c)' \
        '-class-prefix+[prefix]:str:' \
        '-debug-logs[debug logs]' \
        '-debug-stats[debug stats]' \
        '-developer-mode[developer mode]' \
        '-disable-optimization[disable optimization]' \
        '-encrypted[output encrypted model]' \
        '-min-deployment-target+[version]:str:' \
        '-stdout[output to stdout]' \
        '-suppress-output[suppress output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coreml subcommand' sub ;;
        args)
            case $words[1] in
                compile|generate|metadata) _arguments '*:mlmodel:_files -g "*.mlmodel *.mlpackage *.mlmodelc"' ;;
            esac
            ;;
    esac
}

_coreml "$@"
