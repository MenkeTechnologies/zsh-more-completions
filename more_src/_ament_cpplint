#compdef ament_cpplint
# Documentation: https://github.com/ament/ament_lint/blob/rolling/ament_cpplint/ament_cpplint/main.py
# ament_cpplint - check C/C++ code against the Google style guide with cpplint

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--filters=[comma separated list of category filters to apply]:filters:' \
  '--linelength=[the maximum line length]:N:' \
  '--root=[the root directory used for header guard calculation]:root:_files -/' \
  '*--exclude=[exclude specific file names and directory names from the check]:filename:_files' \
  '--output=[the output format]:format:(default eclipse)' \
  '--quiet[do not print anything when there are no errors]' \
  '--xunit-file=[generate a xunit compliant XML file]:file:_files' \
  '*:path:_files' && ret=0

return ret
