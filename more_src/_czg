#compdef czg

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'ai:OpenAI-powered subject generation'
  'emoji:output commit message with emoji'
  'break:append ! after type/scope'
  'checkbox:scope selection via checkboxes'
  'gpg:sign commit message with GPG'
)

_arguments -C \
  '--alias=[predefined commit alias]:name:' \
  '--config=[config file]:file:_files' \
  '(-N --ai-num)'{-N=,--ai-num=}'[AI subject suggestions count]:n:' \
  '(-M --ai-model)'{-M=,--ai-model=}'[AI model]:model:' \
  '--api-key=[OpenAI API key]:key:' \
  '--api-model=[default model]:model:' \
  '--api-proxy=[API proxy URL]:url:' \
  '--api-endpoint=[API endpoint]:url:' \
  '(-r --retry)'{-r,--retry}'[resubmit using previous message]' \
  '--no-ai[disable AI for this session]' \
  '--unset-proxy[remove stored proxy]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-a[stage all]' \
  '-s[signoff]' \
  '-S[GPG sign]' \
  '--amend[amend commit]' \
  '--allow-empty[allow empty commit]' \
  '(-n --no-verify)'{-n,--no-verify}'[skip git hooks]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'czg subcommand' subcommands && ret=0
    ;;
esac

return ret
