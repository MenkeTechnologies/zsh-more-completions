#compdef mantra
# Documentation: https://github.com/MrEmpy/Mantra
# tool used to hunt down API key leaks in JS files and pages

local ret=1

_arguments -s -S \
  '-s[silent: operate without displaying the banner]' \
  '-t[thread number (concurrency workers)]:n' \
  '-ua[customize HTTP User-Agent header]:ua' \
  '-d[detailed: verbose output with line numbers for matches]' \
  '-c[supply cookie data for requests]:cookies' \
  '-ep[append custom (regexp) pattern]:pattern' && ret=0

return ret
