#compdef djvudump djvuextract djvudump-tools
# _djvudump — DjVuLibre djvudump and djvuextract CLI for hex-dump-style structural inspection and chunk extraction of DjVu document files showing IFF chunks (djvu team, C++); getopt
# upstream: https://djvu.sourceforge.net/

_djvudump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-u[unprotected]' \
        '--unprotected[unprotected]' \
        '-D[show dump only]' \
        '--dump-only[show dump only]' \
        '-S[summary]' \
        '--summary[summary]' \
        '-x[expand chunks]' \
        '--expand[expand chunks]' \
        '-r+[chunk]:c:(BGjp BG44 FG44 FGjp FGbz Sjbz INFO DIRM NAVM ANTa ANTz TXTa TXTz INCL Djvu Djvm)' \
        '--chunk=+[chunk]:c:(BGjp BG44 FG44 FGjp FGbz Sjbz INFO DIRM NAVM ANTa ANTz TXTa TXTz INCL Djvu Djvm)' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '-p+[page]:n:' \
        '--page=+[page]:n:' \
        '*:DjVu file:_files -g "*.djvu *.djv *.djz"'
}

_djvudump "$@"
