#compdef reek

# Zsh completion for reek (Ruby code smell detector)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-c,--config}'=[configuration file]:file:_files' \
  '--smell=[only check specific smell]:smell' \
  '--format=[output format]:format:(text yaml json html xml code_climate)' \
  '--no-progress[do not show progress bar]' \
  '--no-wiki-links[do not show wiki links in output]' \
  '--no-documentation[do not warn about missing documentation]' \
  {-s,--single-line}'[show each smell on a single line]' \
  {-S,--sort-by-issue-count}'[sort by issue count]' \
  '--force-exclusion[force excluding files specified in config]' \
  '--stdin-filename=[filename to use for stdin]:file:_files' \
  '*:files:_files -g "*.rb"' && ret=0

return ret
