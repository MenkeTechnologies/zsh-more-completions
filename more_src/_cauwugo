#compdef cauwugo
# Documentation: https://github.com/pacak/bpaf
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cauwugo is the bpaf-based completion helper shipped from pacak/bpaf.
# It delegates completion to the binary itself via the `--bpaf-complete-rev=2`
# protocol; the loop below is the dynamic completion shim bpaf emits for zsh.
IFS=$'\n' lines=($( "${words[1]}" --bpaf-complete-rev=2 "${words[@]:1}" ))
for line in "${(@)lines}" ; do
    IFS=$'\0' parts=($( echo $line ))
    cmd=()
    if [[ -n $parts[2] ]] ; then
        descr=($parts[2])
        cmd+=(-d descr)
    fi
    if [[ -n $parts[3] ]] ; then
        cmd+=(-X "${parts[3]}")
    fi
    if [[ -n $parts[4] ]] ; then
        cmd+=(-J "${parts[4]}")
    fi
    compadd ${cmd[@]} -- "$parts[1]"
done
