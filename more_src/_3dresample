#compdef 3dresample
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dresample.html
# AFNI resample a dataset to new orientation, grid, or voxel size

local ret=1

_arguments -s -S \
  '-help[display help information]' \
  '-hist[show program change history]' \
  '-version[display version information]' \
  '-bound_type[boundary to preserve]:type:(FOV SLAB CENT_ORIG CENT)' \
  '-debug[print debug information]:level' \
  '-dxyz[resample to new voxel dimensions]:dx' \
  '(-input -inset)'{-input,-inset}'[input dataset]:dataset:_files' \
  '-master[align grid to reference dataset]:dataset:_files' \
  '-orient[reorient to new axis order 3-char code]:code' \
  '-prefix[output dataset name]:prefix' \
  '-rmode[resampling method]:mode:(NN Li Cu Bk)' \
  '-upsample[upsample voxels by factor]:factor' \
  '-downsample[downsample voxels by factor]:factor' \
  '-delta_scale[rescale voxel sizes by factor]:factor' \
  '*:dataset:_files' && ret=0

return ret
