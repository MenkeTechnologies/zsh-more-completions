#compdef kdoctor

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'run:run diagnostics against the cluster'
      'version:print version'
    )
    _describe -t commands 'kdoctor command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-n --namespace)'{-n,--namespace}'=[kubernetes namespace]:namespace' \
      '*:check arguments: _default' \
      && ret=0
    ;;
esac

return ret
