#compdef kdoctor
# Documentation: https://github.com/Kotlin/kdoctor/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kdoctor: Kotlin Multiplatform environment analysis tool. Corrected
# from prior file: it is NOT a Kubernetes diagnostic tool; removed
# invented run/version subcommands and -n/--namespace. kdoctor is a
# flag-only command per upstream README.
local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)--version[report a version of KDoctor]' \
  '(-v --verbose)'{-v,--verbose}'[report extended information]' \
  '(-a --all)'{-a,--all}'[run extra diagnostics (synthetic build and current project analysis)]' \
  '(- *)'{-h,--help}'[show help and exit]' && ret=0
return ret
