#compdef cufflinks

# Cufflinks: transcript assembly + abundance estimation from RNA-Seq
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-o --output-dir)'{-o,--output-dir=}'[output directory]:dir:_files -/' \
  '(-p --num-threads)'{-p,--num-threads=}'[threads]:n:' \
  '(-G --GTF)'{-G,--GTF=}'[GTF reference (quantify only)]:file:_files' \
  '(-g --GTF-guide)'{-g,--GTF-guide=}'[guide GTF (allow novel transcripts)]:file:_files' \
  '(-M --mask-file)'{-M,--mask-file=}'[mask GTF (e.g. rRNA/tRNA)]:file:_files' \
  '(-b --frag-bias-correct)'{-b,--frag-bias-correct=}'[FASTA for bias correction]:file:_files' \
  '(-u --multi-read-correct)'{-u,--multi-read-correct}'[multi-mapped read correction]' \
  '--library-type=[library type]:type:(ff-firststrand ff-secondstrand ff-unstranded fr-unstranded fr-firststrand fr-secondstrand transfrags)' \
  '--frag-len-mean=[mean fragment length]:n:' \
  '--frag-len-std-dev=[fragment length std dev]:n:' \
  '--total-hits-norm[total hits normalization]' \
  '--compatible-hits-norm[compatible hits normalization]' \
  '-N[upper-quartile normalization]' \
  '--no-effective-length-correction[no effective length correction]' \
  '--no-length-correction[no length correction]' \
  '(-F --min-isoform-fraction)'{-F,--min-isoform-fraction=}'[min isoform fraction]:val:' \
  '(-j --pre-mrna-fraction)'{-j,--pre-mrna-fraction=}'[pre-mRNA fraction]:val:' \
  '(-I --max-intron-length)'{-I,--max-intron-length=}'[max intron length]:n:' \
  '-a[junction alpha]:val:' \
  '-A[small anchor fraction]:val:' \
  '--no-update-check[skip update check]' \
  '--seed=[random seed]:n:' \
  '*:BAM file:_files -g "*.bam"' && ret=0
return ret
