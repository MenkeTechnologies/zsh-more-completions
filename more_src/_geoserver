#compdef geoserver
# Documentation: https://geoserver.org/
# Reference accessed: 2026-05-16
# Verified: GeoServer is a Java web service distributed as a Jetty-
# bundled .war. The startup.sh/shutdown.sh wrappers take no
# documented CLI flags; configuration is via JVM -D properties and
# web.xml. No CLI completion warranted beyond a passthrough.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# geoserver: Java web mapping server (service, no CLI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:arg:_files' && ret=0
return ret
