#compdef umoci

# Zsh completion for umoci - OCI image manipulation tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--log=[log level]:level:(info debug warn error)' \
  '--verbose[verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:modify OCI image configuration'
      'unpack:unpack an OCI image to a runtime bundle'
      'repack:repack a runtime bundle into an OCI image'
      'new:create a new empty image'
      'tag:create a new tag for an image'
      'remove:remove a tag from an image'
      'stat:display status of an image tag'
      'list:list tags in an OCI image'
      'raw:advanced low-level operations'
      'gc:garbage collect unreferenced blobs'
      'init:create a new OCI layout'
      'insert:insert content into an OCI image'
    )
    _describe -t commands 'umoci command' commands && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--image=[OCI image reference]:image' \
          '--tag=[output tag]:tag' \
          '*--config.user=[set user]:user' \
          '*--config.exposedports=[expose port]:port' \
          '*--config.env=[set environment variable]:env' \
          '*--config.entrypoint=[set entrypoint]:entrypoint' \
          '*--config.cmd=[set command]:cmd' \
          '*--config.volume=[set volume]:volume' \
          '*--config.label=[set label]:label' \
          '--config.workingdir=[set working directory]:dir' \
          '--config.stopsignal=[set stop signal]:signal' \
          '--author=[set author]:author' \
          '--created=[set creation timestamp]:timestamp' \
          '--os=[set OS]:os' \
          '--architecture=[set architecture]:arch' \
          '--history.comment=[set history comment]:comment' \
          '--history.created_by=[set history created_by]:created_by' \
          '--clear=[clear configuration]:field:(config.labels config.volumes config.exposedports config.env config.entrypoint config.cmd)' && ret=0
        ;;
      unpack)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--image=[OCI image reference]:image' \
          '--uid-map=[UID mapping]:mapping' \
          '--gid-map=[GID mapping]:mapping' \
          '--rootless[rootless unpacking]' \
          '1:bundle path:_directories' && ret=0
        ;;
      repack)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--image=[OCI image reference]:image' \
          '--history.comment=[set history comment]:comment' \
          '--history.created_by=[set history created_by]:created_by' \
          '--no-history[do not add history entry]' \
          '1:bundle path:_directories' && ret=0
        ;;
      new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--image=[OCI image reference]:image' && ret=0
        ;;
      tag)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--image=[OCI image reference]:image' \
          '1:new tag:' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--image=[OCI image reference]:image' && ret=0
        ;;
      stat)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--image=[OCI image reference]:image' \
          '--json[output in JSON format]' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--layout=[OCI layout path]:path:_directories' && ret=0
        ;;
      raw)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->raw_cmds' \
          '*::arg:->raw_args' && ret=0
        case $state in
          raw_cmds)
            local -a raw_cmds=(
              'runtime-config:generate runtime config'
              'unpack:raw unpack of an image'
              'config:output image config'
              'manifest:output image manifest'
              'cat:output raw blob'
            )
            _describe -t commands 'raw subcommand' raw_cmds && ret=0
            ;;
          raw_args)
            _arguments -s -S \
              '(- *)'{-h,--help}'[show help]' \
              '--image=[OCI image reference]:image' && ret=0
            ;;
        esac
        ;;
      gc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--layout=[OCI layout path]:path:_directories' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--layout=[OCI layout path]:path:_directories' && ret=0
        ;;
      insert)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--image=[OCI image reference]:image' \
          '--opaque[make the insertion opaque]' \
          '--whiteout[add a whiteout entry]' \
          '--tag=[output tag]:tag' \
          '--history.comment=[set history comment]:comment' \
          '--history.created_by=[set history created_by]:created_by' \
          '--no-history[do not add history entry]' \
          '1:source:_files' \
          '2:destination path:' && ret=0
        ;;
    esac
    ;;
esac

return ret
