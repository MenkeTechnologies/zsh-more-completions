#compdef ssmtp

_arguments -s \
  '-au[SMTP username]:user:' \
  '-ap[SMTP password]:pw:' \
  '-am[SMTP auth mech]:mech:(LOGIN CRAM-MD5)' \
  '-4[IPv4 only]' \
  '-6[IPv6 only]' \
  '-ba[ARPANET mode]' \
  '-bd[daemon mode]' \
  '-bi[init alias DB]' \
  '-bm[standard delivery]' \
  '-bp[print queue]' \
  '-bs[SMTP from stdin]' \
  '-bt[address test]' \
  '-bv[verify only]' \
  '-bz[freeze file]' \
  '-C[config file]:file:_files' \
  '-F[full name]:name:' \
  '-f[from address]:addr:' \
  '-r[from address]:addr:' \
  '-d[debug level]:level:' \
  '-t[recipients from headers]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-q[process queue]:time:' \
  '*:recipient:'
