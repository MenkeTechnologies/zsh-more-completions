#compdef gatk
# Documentation: https://man.archlinux.org/search?q=gatk
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--list[list all tools]' \
  '--version[show version]' \
  '--java-options=[JVM options]:options:' \
  '--spark-runner=[Spark runner]:runner:(LOCAL SPARK GCS)' \
  '--spark-master=[Spark master URL]:url:' \
  '--tmp-dir=[temporary directory]:dir:_files -/' \
  '--verbosity=[log verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '--QUIET[suppress output]' \
  '1:tool:->tools' \
  '*:: :->args' && ret=0

case $state in
  (tools)
    local -a tools=(
      'HaplotypeCaller:Call germline SNPs and indels'
      'Mutect2:Call somatic SNPs and indels'
      'GenotypeGVCFs:Genotype gVCFs'
      'CombineGVCFs:Combine per-sample gVCFs'
      'GenomicsDBImport:Import gVCFs to GenomicsDB'
      'BaseRecalibrator:Generate base quality recalibration table'
      'ApplyBQSR:Apply base quality score recalibration'
      'MarkDuplicates:Mark duplicate reads'
      'MarkDuplicatesSpark:Mark duplicates using Spark'
      'GatherBamFiles:Gather BAM files'
      'GatherVcfs:Gather VCF files'
      'MergeVcfs:Merge VCF files'
      'SelectVariants:Select a subset of variants'
      'VariantFiltration:Filter variants by annotation'
      'VariantRecalibrator:Build variant recalibration model'
      'ApplyVQSR:Apply variant quality score recalibration'
      'FilterMutectCalls:Filter Mutect2 calls'
      'GetPileupSummaries:Summarize counts of reads'
      'CalculateContamination:Calculate contamination'
      'CollectReadCounts:Collect read counts'
      'DenoiseReadCounts:Denoise read counts'
      'ModelSegments:Model segments from denoised counts'
      'CreateReadCountPanelOfNormals:Create panel of normals'
      'CollectAllelicCounts:Collect allelic counts'
      'SplitNCigarReads:Split reads with N in CIGAR'
      'AddOrReplaceReadGroups:Add or replace read groups'
      'SortSam:Sort SAM/BAM file'
      'ReorderSam:Reorder SAM/BAM file'
      'CreateSequenceDictionary:Create sequence dictionary'
      'FastqToSam:Convert FASTQ to SAM'
      'SamToFastq:Convert SAM to FASTQ'
      'ValidateSamFile:Validate SAM/BAM file'
      'CollectInsertSizeMetrics:Collect insert size metrics'
      'CollectAlignmentSummaryMetrics:Collect alignment metrics'
      'CollectWgsMetrics:Collect WGS metrics'
      'DepthOfCoverage:Calculate depth of coverage'
      'CountVariants:Count variants in a VCF'
      'LeftAlignAndTrimVariants:Left-align and trim variants'
      'LiftoverVcf:Liftover VCF to a new reference'
      'IndexFeatureFile:Index feature files'
      'Funcotator:Functionally annotate variants'
      'LearnReadOrientationModel:Learn orientation bias model'
      'CNNScoreVariants:Score variants with CNN'
      'PathSeqPipelineSpark:Identify microorganisms in sequencing data'
    )
    _describe -t tools 'tool' tools && ret=0
    ;;
  (args)
    _arguments \
      '-I=[input BAM/CRAM]:file:_files -g "*.(bam|cram|sam)"' \
      '-O=[output file]:file:_files' \
      '-R=[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
      '-L=[intervals]:intervals:_files' \
      '-XL=[exclude intervals]:intervals:_files' \
      '-V=[variant file]:file:_files -g "*.(vcf|vcf.gz|bcf)"' \
      '--known-sites=[known sites VCF]:file:_files -g "*.(vcf|vcf.gz)"' \
      '--dbsnp=[dbSNP VCF]:file:_files -g "*.(vcf|vcf.gz)"' \
      '--germline-resource=[germline resource]:file:_files -g "*.(vcf|vcf.gz)"' \
      '--panel-of-normals=[panel of normals]:file:_files -g "*.(vcf|vcf.gz)"' \
      '--bqsr-recal-file=[BQSR recal file]:file:_files' \
      '--native-pair-hmm-threads=[threads for PairHMM]:threads:' \
      '--emit-ref-confidence=[reference confidence mode]:mode:(NONE BP_RESOLUTION GVCF)' \
      '-ERC=[reference confidence mode]:mode:(NONE BP_RESOLUTION GVCF)' \
      '--min-base-quality-score=[min base quality]:quality:' \
      '-stand-call-conf=[call confidence threshold]:confidence:' \
      '--max-reads-per-alignment-start=[max reads per start]:count:' \
      '--sample-name=[sample name]:name:' \
      '--annotation=[annotation to apply]:annotation:' \
      '--annotation-group=[annotation group]:group:' \
      '*:file:_files' && ret=0
    ;;
esac

return ret
