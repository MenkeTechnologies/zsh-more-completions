#compdef kubeshark
# _kubeshark-bin — Kubeshark k8s traffic sniffer (Up9 / Kubeshark, Go); Wireshark for k8s, captures pod traffic
# upstream: https://github.com/kubeshark/kubeshark

_kubeshark-bin() {
    local -a sub=(
        'tap:run capture/forward UI session (default)'
        'proxy:run proxy to the kubeshark hub'
        'logs:print logs from running kubeshark pods'
        'console:open kubeshark console'
        'clean:remove kubeshark resources'
        'check:check installation'
        'config:manage config'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--debug[debug]' \
        '--kube-context+[kube context]:context:' \
        '--kube-config+[kubeconfig]:file:_files' \
        '--set+[set config]:k=v:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kubeshark subcommand' sub ;;
        args)
            case $words[1] in
                tap) _arguments \
                    '-r+[regex of pods to tap]:regex:' \
                    '--regex+[regex of pods to tap]:regex:' \
                    '-n+[namespaces]:ns:' \
                    '--namespaces+[namespaces]:ns:' \
                    '-A[all namespaces]' \
                    '--all-namespaces[all namespaces]' \
                    '--all-pods[all pods]' \
                    '--scripting-source+[scripting source dir]:dir:_files -/' \
                    '--port+[port]:port:' \
                    '--proxy-port+[proxy port]:port:' \
                    '--no-browser[no browser]' \
                    '--license+[license]:str:' \
                    '*:filter:' ;;
                proxy) _arguments '--port+[port]:port:' ;;
                logs) _arguments '--file+[file]:file:_files' ;;
            esac
            ;;
    esac
}

_kubeshark-bin "$@"
