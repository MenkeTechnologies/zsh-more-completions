#compdef dysk

# Zsh completion for dysk - disk information tool

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[show all filesystems]' \
  '(-c --csv)'{-c,--csv}'[output as CSV]' \
  '(-f --filter)'{-f,--filter}'[filter expression]:filter' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '(-s --sort)'{-s,--sort}'[sort by column]:column:(type disk used use free size mount)' \
  '--cols[columns to display]:columns' \
  '--color[color mode]:mode:(auto yes no)' \
  '--units[units]:units:(si binary)' \
  '*:mount point:_files -/'
