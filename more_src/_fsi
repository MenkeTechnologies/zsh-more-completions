#compdef fsi fsiAnyCpu dotnet-fsi
# Documentation: https://man.archlinux.org/search?q=fsi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '-?[show help]' \
  '--version[show version]' \
  '*--use:-[use file as initial input]:file:_files -g "*.fs *.fsx *.fsi"' \
  '*-u:-[use file as initial input]:file:_files -g "*.fs *.fsx *.fsi"' \
  '*--load:-[load source on startup]:file:_files -g "*.fs *.fsx *.fsi"' \
  '*--reference:-[reference assembly]:file:_files -g "*.dll"' \
  '*-r:-[reference assembly]:file:_files -g "*.dll"' \
  '*--lib:-[search lib path]:dir:_files -/' \
  '*-I:-[search lib path]:dir:_files -/' \
  '--exec[exit after loading files]' \
  '--gui[enable Windows Forms event loop]' \
  '--gui+[enable Windows Forms event loop]' \
  '--gui-[disable Windows Forms event loop]' \
  '--quiet[suppress informational]' \
  '--readline[readline support]' \
  '--readline+[readline support]' \
  '--readline-[disable readline]' \
  '--use\:script[execute script]:file:_files -g "*.fsx"' \
  '--shadowcopyreferences[shadow copy referenced assemblies]' \
  '--codepage:-[source codepage]:n:' \
  '--debug[enable debug info]' \
  '--define:-[define symbol]:sym:' \
  '-d:-[define symbol]:sym:' \
  '--noframework[no implicit references]' \
  '--optimize[enable optimisations]' \
  '--optimize+[enable optimisations]' \
  '--optimize-[disable optimisations]' \
  '--tailcalls[enable tail calls]' \
  '--tailcalls+[enable tail calls]' \
  '--checked[overflow checking on]' \
  '--checked+[overflow checking on]' \
  '--checked-[overflow checking off]' \
  '--utf8output[output messages in UTF-8]' \
  '--mlcompatibility[ignore ML-compat warnings]' \
  '--nologo[no banner]' \
  '--nowarn:-[disable warning numbers]:nums:' \
  '--warnon:-[enable warning]:nums:' \
  '--warn:-[warning level 0-5]:lvl:(0 1 2 3 4 5)' \
  '--warnaserror[treat warnings as errors]' \
  '--warnaserror+[treat warnings as errors]' \
  '--warnaserror-[reset]' \
  '--targetprofile:-[target framework]:p:(mscorlib netcore netstandard)' \
  '--langversion:-[F# language version]:ver:(default latest preview 4.6 4.7 5.0 6.0 7.0 8.0)' \
  '--use\:nuget[use NuGet for #r references]' \
  '--gui[enable WinForms event loop]' \
  '*:script:_files -g "*.fsx *.fs"' && ret=0

return ret
