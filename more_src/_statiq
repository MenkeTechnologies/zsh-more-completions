#compdef statiq
# Documentation: https://www.statiq.dev/guide/running/command-line
# Statiq static site generator CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --log-level)'{-l,--log-level}'=[minimum log level]:level:' \
  '(-f --log-file)'{-f,--log-file}'=[log to file]:file:_files' \
  '(-s --setting)'{-s,--setting}'=[key=value setting]:setting:' \
  '(-i --input)'{-i,--input}'=[input path]:path:_files -/' \
  '(-o --output)'{-o,--output}'=[output path]:path:_files -/' \
  '(-r --root)'{-r,--root}'=[root folder]:path:_files -/' \
  '(-n --normal)'{-n,--normal}'[run normal pipelines]' \
  '--attach[pause until debugger attaches]' \
  '--noclean[do not clean output path]' \
  '--nocache[do not cache during execution]' \
  '--stdin[read standard input]' \
  '--serial[run pipelines serially]' \
  '1:command:(build preview serve deploy pipelines)' \
  '*::arg:_files' && ret=0

return ret
