#compdef squint squint-cljs

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'compile:compile CLJS files to JavaScript'
  'run:compile and run a .cljs file'
  'watch:watch source directories and recompile on change'
  'repl:start a console REPL'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[squint.edn config file]:file:_files -g "*.edn"' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--extension=[output file extension]:ext:(mjs js jsx)' \
  '*--paths=[source paths]:path:_files -/' \
  '*--copy-resources=[resource extensions to copy]:ext:' \
  '--imports=[import map JSON]:file:_files -g "*.json"' \
  '--no-source-maps[disable source maps]' \
  '--source-maps[generate source maps]' \
  '--elide-imports[do not emit import statements]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'squint command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (compile)
        _arguments '*::file:_files -g "*.{cljs,cljc}"' && ret=0 ;;
      (run)
        _arguments \
          '--main=[main function]:fn:' \
          '*::file:_files -g "*.{cljs,cljc}"' && ret=0 ;;
    esac ;;
esac

return ret
