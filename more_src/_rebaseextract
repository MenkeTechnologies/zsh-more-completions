#compdef rebaseextract

# EMBOSS rebaseextract: convert REBASE flat files into EMBOSS enzyme data
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-infile=[REBASE proto.X (proto reference) file]:file:_files' \
  '-withrefm=[REBASE withrefm.X file (with references)]:file:_files' \
  '-equivalences[create equivalent-name file]' \
  '*:REBASE file:_files' && ret=0
return ret
