#compdef semgrep
# _semgrep-bin — Semgrep static analyzer (Semgrep Inc, OCaml/Python); fast syntactic + semantic pattern matching for code audit
# upstream: https://github.com/semgrep/semgrep

_semgrep-bin() {
    local -a sub=(
        'scan:run scan (default)'
        'ci:run scan in CI mode'
        'lsp:run language server'
        'login:authenticate to Semgrep Cloud'
        'logout:logout'
        'install-semgrep-pro:install pro engine'
        'show:show rule/scan info'
        'shouldafound:find shouldafound matches'
        'publish:publish rules to registry'
        'test:run tests on rules'
        'validate:validate rules'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '(-c --config)'{-c,--config}'+[rule pattern]:pattern:' \
        '-e+[pattern string]:pattern:' \
        '--pattern+[pattern string]:pattern:' \
        '-l+[language]:lang:(python javascript typescript java go ruby c cpp csharp php scala rust kotlin swift terraform yaml json dockerfile bash html)' \
        '--lang+[language]:lang:' \
        '--exclude+[exclude path]:glob:' \
        '--exclude-rule+[exclude rule]:rule:' \
        '--include+[include path]:glob:' \
        '--baseline-commit+[baseline commit]:commit:' \
        '--max-target-bytes+[max bytes]:n:' \
        '--max-memory+[max memory MB]:n:' \
        '--max-chars-per-line+[max chars per line]:n:' \
        '--max-lines-per-finding+[max lines per finding]:n:' \
        '-o+[output file]:file:_files' \
        '--output+[output file]:file:_files' \
        '--json[json output]' \
        '--sarif[sarif output]' \
        '--gitlab-sast[gitlab sast]' \
        '--gitlab-secrets[gitlab secrets]' \
        '--junit-xml[junit xml]' \
        '--vim[vim output]' \
        '--emacs[emacs output]' \
        '--text[text output]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--metrics+[metrics]:metrics:(auto on off)' \
        '--no-rewrite-rule-ids[no rewrite rule ids]' \
        '--jobs+[jobs]:n:' \
        '-j+[jobs]:n:' \
        '--scan-unknown-extensions[scan unknown extensions]' \
        '--strict[strict]' \
        '--error[exit non-zero on findings]' \
        '--severity+[severity filter]:level:(INFO WARNING ERROR)' \
        '--dataflow-traces[show dataflow traces]' \
        '--enable-version-check[enable version check]' \
        '--disable-version-check[disable version check]' \
        '--enable-nosem[enable nosem comments]' \
        '--disable-nosem[disable nosem comments]' \
        '--autofix[apply autofix]' \
        '--dryrun[dry run autofix]' \
        '--time[show timing info]' \
        '--timeout+[per-file timeout]:n:' \
        '--timeout-threshold+[max timeouts]:n:' \
        '--use-git-ignore[respect .gitignore]' \
        '--no-git-ignore[ignore .gitignore]' \
        '--scan-from+[scan from path]:path:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'semgrep subcommand' sub ;;
        args)
            _arguments '*:targets:_files'
            ;;
    esac
}

_semgrep-bin "$@"
