#compdef compleasm
# Documentation: https://github.com/huangnengCSU/compleasm
# compleasm: efficient and accurate reimplementation of BUSCO for genome completeness

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    if (( CURRENT == 1 )); then
      _values 'compleasm subcommand' \
        'run[run miniprot alignment and completeness evaluation]' \
        'analyze[evaluate completeness from a provided miniprot alignment]' \
        'download[download a specified BUSCO lineage]' \
        'list[list local or remote BUSCO lineages]' \
        'miniprot[run miniprot alignment]' && ret=0
    else
      case $words[1] in
        run)
          _arguments -s -S \
            '(-a --assembly_path)'{-a+,--assembly_path=}'[input genome file in FASTA]:file:_files' \
            '(-o --output_dir)'{-o+,--output_dir=}'[output folder]:dir:_files -/' \
            '(-t --threads)'{-t+,--threads=}'[number of threads]:threads' \
            '(-l --lineage)'{-l+,--lineage=}'[BUSCO lineage name]:lineage' \
            '(-L --library_path)'{-L+,--library_path=}'[directory for downloaded lineages]:dir:_files -/' \
            '--specified_contigs=[contigs to be evaluated]:contigs' \
            '--autolineage[automatically search for the best matching lineage]' \
            '--sepp_execute_path=[path to sepp executable]:file:_files' \
            '--min_diff=[minimum gene score difference]:value' \
            '--min_identity=[minimum gene identity]:value' \
            '--min_length_percent=[minimum gene length percent]:value' \
            '--min_complete=[minimum gene complete length]:value' && ret=0
          ;;
      esac
    fi
    ;;
esac

return ret
