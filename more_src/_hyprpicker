#compdef hyprpicker

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --autocopy)'{-a,--autocopy}'[automatically copy selected color to clipboard]' \
  '(-f --format)'{-f,--format}'+[output color format]:format:(hex rgb hsl hsv cmyk)' \
  '(-n --no-fancy)'{-n,--no-fancy}'[disable fancy rendering]' \
  '(-r --render-inactive)'{-r,--render-inactive}'[render on all monitors]' \
  '(-z --no-zoom)'{-z,--no-zoom}'[disable zoom lens]' \
  '--quiet[do not print selected color]' && ret=0

return ret
