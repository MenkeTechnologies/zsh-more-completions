#compdef justniffer
# Documentation: https://onotelli.github.io/justniffer/MAN.html
# Network TCP packet sniffer producing customizable logs

local ret=1

_arguments -s -S \
  '--help[show command-line usage information]' \
  '(-V --version)'{-V,--version}'[display the version number]' \
  '(-f --filecap)'{-f,--filecap}'+[input file in tcpdump capture format]:pcap file:_files' \
  '(-i --interface)'{-i,--interface}'+[network interface to listen on]:interface:_net_interfaces' \
  '(-l --log-format)'{-l,--log-format}'+[log format using customizable keywords]:format:' \
  '(-a --append-log-format)'{-a,--append-log-format}'+[append format to default Apache log format]:format:' \
  '(-c --config)'{-c,--config}'+[load a configuration file]:config file:_files' \
  '(-U --user)'{-U,--user}'+[impersonate a user when executing --execute]:user:_users' \
  '(-e --execute)'{-e,--execute}'+[run command during request/response phase]:command:_command_names' \
  '(-p --packet-filter)'{-p,--packet-filter}'+[apply packet filter using tcpdump syntax]:filter:' \
  '(-u --unprintable)'{-u,--unprintable}'[replace unprintable characters with dots]' \
  '(-t --truncated)'{-t,--truncated}'[handle truncated streams not properly closed]' \
  '(-x --hex-encode)'{-x,--hex-encode}'[encode unprintable characters as hex]' \
  '(-r --raw)'{-r,--raw}'[display raw streams]' \
  '(-n --not-found)'{-n,--not-found}'+[default value when data unavailable]:value:' \
  '(-s --max-tcp-streams)'{-s,--max-tcp-streams}'+[max concurrent TCP streams]:count:' \
  '(-d --max-fragmented-ip)'{-d,--max-fragmented-ip}'+[max concurrent fragmented IP hosts]:count:' \
  '(-F --force-read-pcap)'{-F,--force-read-pcap}'[force reading pcap file ignoring snaplen]' \
  '(-m --capture-in-the-middle)'{-m,--capture-in-the-middle}'[capture midstream packets]' \
  '(-P --python)'{-P,--python}'+[execute Python function app in script]:script:_files' \
  '(-N --no-newline)'{-N,--no-newline}'[prevent automatic newline insertion at log end]' \
  '*:pcap file:_files' && ret=0

return ret
