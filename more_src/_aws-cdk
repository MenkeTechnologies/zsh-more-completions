#compdef cdk

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list stacks'
  'ls:list stacks'
  'synthesize:synthesize stacks'
  'synth:synthesize stacks'
  'bootstrap:bootstrap CDK toolkit'
  'gc:garbage collect bootstrap'
  'deploy:deploy stacks'
  'rollback:rollback stack'
  'import:import resources'
  'watch:watch and deploy'
  'destroy:destroy stacks'
  'diff:diff with deployed stack'
  'metadata:show metadata'
  'init:initialize project'
  'migrate:migrate from CFN/TF'
  'context:context commands'
  'docs:open docs'
  'doctor:check setup'
  'notices:show notices'
  'acknowledge:acknowledge notice'
  'ack:acknowledge notice'
  'completion:generate completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*-a+[app cmd]:c:' \
  '*--app=[app cmd]:c:' \
  '*--build=[build cmd]:c:' \
  '*-c+[k=v context]:v:' \
  '*--context=[k=v]:v:' \
  '*--plugin=[plugin]:p:' \
  '*--trace[trace]' \
  '*--strict[strict]' \
  '*--lookups=[lookups]:b:(true false)' \
  '*--ignore-errors[ignore errors]' \
  '*-j[JSON output]' \
  '*--json[JSON output]' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '*--debug[debug]' \
  '*--profile=[profile]:p:' \
  '*--proxy=[proxy URL]:url:' \
  '*--ca-bundle-path=[CA bundle]:file:_files' \
  '*-i+[EC2 IAM]' \
  '*--ec2creds=[EC2 IAM]:b:(true false)' \
  '*--version-reporting=[version reporting]:b:(true false)' \
  '*--path-metadata=[path metadata]:b:(true false)' \
  '*--asset-metadata=[asset metadata]:b:(true false)' \
  '*--role-arn=[role ARN]:arn:' \
  '*--toolkit-stack-name=[stack name]:n:' \
  '*--staging[staging]' \
  '*--no-color[no color]' \
  '*--ci[CI mode]' \
  '*-o+[output dir]:dir:_files -/' \
  '*--output=[output dir]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cdk command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy)
        _arguments \
          '*--all[all stacks]' \
          '*--require-approval=[approval level]:l:(never any-change broadening)' \
          '*--exclusively[exclusively]' \
          '*--force[force]' \
          '*--toolkit-stack-name=[name]:n:' \
          '*--no-execute[no execute]' \
          '*--method=[method]:m:(direct change-set prepare-change-set)' \
          '*--change-set-name=[change set name]:n:' \
          '*--watch[watch]' \
          '*--hotswap[hotswap]' \
          '*--hotswap-fallback[hotswap fallback]' \
          '*--logs[show logs]' \
          '*--concurrency=[concurrency]:n:' \
          '*--asset-parallelism[asset parallelism]' \
          '*--asset-prebuild[asset prebuild]' \
          '*--ignore-no-stacks[ignore no stacks]' \
          '*--rollback=[rollback]:b:(true false)' \
          '*--progress=[progress]:m:(bar events)' \
          '*--outputs-file=[outputs file]:file:_files' \
          '*-O+[outputs file]:file:_files' \
          '*--verify-no-runtime-updates[no runtime updates]' \
          '*--build-exclude=[exclude]:e:' \
          '*-E+[exclude]:e:' \
          '*-t+[k=v tag]:t:' \
          '*--tags=[k=v tag]:t:' \
          '*: :' && ret=0 ;;
      (synth|synthesize|diff|destroy|list|ls)
        _arguments '*: :' && ret=0 ;;
      (bootstrap)
        _arguments \
          '*--bootstrap-bucket-name=[bucket]:b:' \
          '*--bootstrap-kms-key-id=[KMS key]:k:' \
          '*--bootstrap-customer-key[customer key]' \
          '*--qualifier=[qualifier]:q:' \
          '*--public-access-block-configuration=[public access]:b:(true false)' \
          '*-t+[k=v tag]:t:' \
          '*--cloudformation-execution-policies=[policies]:p:' \
          '*--trust=[trust accounts]:a:' \
          '*--trust-for-lookup=[trust lookup]:a:' \
          '*--show-template[show template]' \
          '*--template=[template file]:file:_files' \
          '*--toolkit-stack-name=[name]:n:' \
          '*: :' && ret=0 ;;
      (init)
        _arguments \
          '--language=[language]:l:(typescript javascript python java csharp fsharp go)' \
          '-l+[language]:l:' \
          '--list[list templates]' \
          '*: :' && ret=0 ;;
      (context)
        _arguments \
          '--clear[clear all]' \
          '--reset=[reset key]:k:' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
