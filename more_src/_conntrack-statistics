#compdef conntrack-statistics conntrack-stats
# _conntrack-statistics — netfilter conntrack-tools statistics helper (small wrapper that periodically dumps /proc/net/stat/nf_conntrack into a parsable table; -i interval seconds, -n count iterations, -o output file, -p print only deltas, -q quiet, -V version, -h help)
# upstream: https://git.netfilter.org/conntrack-tools
# Common flag shape from conntrack-tools src/stats.c on tip.

_conntrack-statistics() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-i+[interval seconds]:seconds:' \
        '-n+[iterations]:n:' \
        '-o+[output file]:file:_files' \
        '-p[deltas only]' \
        '-q[quiet]'
}

_conntrack-statistics "$@"
