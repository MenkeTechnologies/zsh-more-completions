#compdef truffleruby
# _truffleruby — TruffleRuby high-performance Ruby on GraalVM (Oracle); CRuby-compatible runtime + native image
# upstream: https://github.com/oracle/truffleruby

_truffleruby() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version + verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '--copyright[show copyright]' \
        '-w[verbose warnings]' \
        '-W+[warning level]:level:(0 1 2)' \
        '-e+[expression]:expr:' \
        '-I+[include dir]:dir:_files -/' \
        '-r+[require library]:lib:' \
        '-x+[skip headers up to script]:dir:' \
        '-c[only check syntax]' \
        '-n[loop over stdin]' \
        '-p[loop + print]' \
        '-a[autosplit (with -n/-p)]' \
        '-l[line ending fixup]' \
        '-T+[safe level]:n:' \
        '-Eenc[input encoding]:enc:' \
        '-K+[default encoding]:enc:(u U a A e E s S n N)' \
        '-F+[split pattern]:pattern:' \
        '-i+[in-place backup ext]:ext:' \
        '-s[strip script switches]' \
        '-d[debug mode]' \
        '--debug[debug mode]' \
        '--jit[enable JIT]' \
        '--graal[force Graal JIT]' \
        '--native[run native image]' \
        '--jvm[run on JVM]' \
        '--engine.+[GraalVM engine option]:opt:' \
        '--vm.+[VM arg]:arg:' \
        '--polyglot[enable polyglot]' \
        '*:script:_files -g "*.rb"'
}

_truffleruby "$@"
