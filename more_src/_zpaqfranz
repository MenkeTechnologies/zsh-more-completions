#compdef zpaqfranz
# Documentation: https://man.archlinux.org/search?q=zpaqfranz
# Reference accessed: 2026-05-16

# Zsh completion for zpaqfranz archiver

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'zpaqfranz' add extract list test && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
