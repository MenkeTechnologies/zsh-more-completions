#compdef scipion3 scipion
# Documentation: https://scipion-em.github.io/docs/release-3.0.0/docs/scipion-modes/install-plugins-command-line.html
# Scipion cryo-EM image processing framework launcher

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(run python tests test config install installp installb uninstallp pip printenv where last viewer help version project)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $words[1] in
      install|installp) _arguments \
        '*-p[plugin name]:plugin:' \
        '(-j)-j[number of processors]:n:' \
        '--devel[install in development mode]' \
        '--noBin[skip binaries]' \
        '--checkUpdates[check for plugin updates]' && ret=0 ;;
      tests|test) _arguments \
        '*--grep[only run tests containing words]:words:' \
        '*--skip[skip tests containing words]:words:' \
        '--pattern=[test file pattern]:pattern:' \
        '--mode=[detail level]:mode:(modules classes onlyclasses all)' \
        '--run[run selected tests]' \
        '--show[show available tests]' \
        '--log=[generate log files]:logdir:_files -/' \
        '*:test:' && ret=0 ;;
      run|python) _files ;;
    esac
    ;;
esac

return ret
