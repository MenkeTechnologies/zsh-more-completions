#compdef pamac-manager
# Documentation: https://wiki.manjaro.org/index.php/Pamac
# Reference accessed: 2026-05-16
# Verified: GUI binary; no documented CLI flags beyond standard GTK.

# pamac-manager: Manjaro package manager (GTK GUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' && ret=0
return ret
