#compdef node-sass
# Documentation: https://github.com/sass/node-sass
# node-sass - wrapper around libsass to compile .scss/.sass to CSS

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-w --watch)'{-w,--watch}'[watch a directory or file for changes]' \
  '(-r --recursive)'{-r,--recursive}'[recursively watch directories or files]' \
  '(-o --output)'{-o,--output}'[output directory]:dir:_files -/' \
  '(-x --omit-source-map-url)'{-x,--omit-source-map-url}'[omit source map URL comment from output]' \
  '(-i --indented-syntax)'{-i,--indented-syntax}'[treat stdin as sass code (not scss)]' \
  '--output-style=[CSS output style]:style:(nested expanded compact compressed)' \
  '--indent-type=[indentation character]:type:(space tab)' \
  '--indent-width=[indentation size (max 10)]:width:' \
  '--linefeed=[linefeed style]:style:(cr crlf lf lfcr)' \
  '--source-comments[include debug info in output]' \
  '--source-map=[emit source map]:path:_files' \
  '--source-map-contents[embed include contents in map]' \
  '--source-map-embed[embed sourceMappingUrl as data URI]' \
  '--source-map-root=[base path for source map references]:path:_files -/' \
  '--include-path=[path to look for imported files]:path:_files -/' \
  '--follow[follow symlinked directories]' \
  '--importer=[path to .js file with custom importer]:file:_files -g "*.js"' \
  '--functions=[path to .js file with custom functions]:file:_files -g "*.js"' \
  '(-q --quiet)'{-q,--quiet}'[suppress log output except errors]' \
  '--precision=[precision for numbers]:precision:' \
  '--error-bell[output a bell after errors]' \
  '*:input:_files -g "*.(scss|sass)"' && ret=0

return ret
