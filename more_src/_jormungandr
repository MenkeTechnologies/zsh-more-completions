#compdef jormungandr

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[YAML node config]:file:_files -g "*.{yaml,yml}"' \
  '--genesis-block=[binary block 0 file]:file:_files' \
  '--genesis-block-hash=[block 0 hash]:hash:' \
  '--secret=[node secret YAML]:file:_files -g "*.{yaml,yml}"' \
  '--storage=[blockchain storage directory]:dir:_files -/' \
  '--log-level=[log verbosity]:level:(off critical error warn info debug trace)' \
  '--log-output=[log output target]:target:(stderr stdout file)' \
  '--log-format=[log format]:format:(plain json)' \
  '--rest-listen=[REST listen address]:addr:' \
  '--listen=[gRPC listen address]:addr:' \
  '--trusted-peer=[trusted peer multiaddr/public_id]:peer:' \
  '--no-rest[disable REST API]' \
  '--leadership-logs-max-entries=[max leadership log entries]:n:' \
  '--quic-tls-cert=[QUIC TLS cert]:file:_files' \
  '--quic-tls-key=[QUIC TLS key]:file:_files' \
  '*::passthrough:' && ret=0

return ret
