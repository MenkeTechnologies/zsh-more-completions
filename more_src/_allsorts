#compdef allsorts
# Documentation: https://github.com/yeslogic/allsorts-tools
# Allsorts font tools: parse, shape, subset and inspect OpenType fonts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'bitmaps:extract bitmaps from EBLC/EBDT or CBLC/CBDT tables'
      'cmap:dump the cmap character to glyph index entries'
      'dump:print or extract information from a font file'
      'has-table:check if the font contains the table given via -t'
      'instance:apply axis values to a variable font to make a static font'
      'layout-features:print the font GSUB and GPOS features'
      'shape:shape text according to font, language and script'
      'specimen:generate an HTML font specimen sheet'
      'subset:create a font containing only glyphs for the supplied text'
      'validate:parse all glyphs and report any errors'
      'variations:list a variable font axes and pre-defined instances'
      'view:generate an SVG of glyphs from shaped text or codepoints'
    )
    _describe -t commands 'allsorts command' cmds && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
