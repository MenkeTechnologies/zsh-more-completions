#compdef nw_topology
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: print tree topology (cladogram).

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-b[keep branch lengths]' \
  '-I[remove inner node labels]' \
  '-L[remove leaf labels]' \
  '*:newick file:_files' && ret=0

return ret
