#compdef logria
# Documentation: https://github.com/ReagentX/Logria/blob/develop/docs/README.md
# logria - powerful CLI tool for log aggregation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '(-e --exec)'{-e,--exec}'[command to listen to, ex: tail -f log.txt]:stream' \
  '(-p --paths)'{-p,--paths}'[print current configuration paths]' \
  '(-m --mindless)'{-m,--mindless}'[disable variable polling rate based on incoming message rate]' \
  '(-t --no-history-tape)'{-t,--no-history-tape}'[disable command history disk cache]' \
  '(-d --docs)'{-d,--docs}'[print documentation]' && ret=0

return ret
