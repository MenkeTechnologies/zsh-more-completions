#compdef kafka-replica-verification

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--broker-list[DEPRECATED - Comma-separated list of broker host:port]:host\:port:'
    '--fetch-size[Fetch size per request]:bytes:'
    '--max-wait-ms[Max wait time for each fetch request]:ms:'
    '--topic-white-list[Regex for topic inclusion]:regex:'
    '--report-interval-ms[Interval for reporting lag]:ms:'
)

_arguments -s -S $arguments
