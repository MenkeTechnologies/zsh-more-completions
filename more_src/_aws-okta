#compdef aws-okta
# Documentation: https://github.com/segmentio/aws-okta
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add a new okta credential'
  'completion:generate shell completion'
  'cred-process:return creds in JSON for credential_process'
  'env:emit env vars for AWS profile'
  'exec:exec command with AWS env vars'
  'help:show help'
  'list:list profiles in AWS config'
  'login:login to okta and assume role'
  'remove:remove the credentials for okta'
  'rotate:rotate the access key'
  'write-to-credentials:write creds to ~/.aws/credentials'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-b --backend)'{-b+,--backend=}'[secret backend]:b:(kwallet secret-service file pass keychain)' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '--mfa-provider=[MFA provider]:p:' \
  '--mfa-factor-type=[MFA factor type]:t:(push token:software:totp token:hardware u2f sms call)' \
  '--mfa-duo-device=[Duo device]:dev:(phone1 phone2 token)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'aws-okta command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (exec)
        _arguments \
          '(-a --assume-role-ttl)'{-a+,--assume-role-ttl=}'[role TTL]:dur:' \
          '(-t --session-ttl)'{-t+,--session-ttl=}'[session TTL]:dur:' \
          '1:profile:' \
          '*: :_command_names' && ret=0 ;;
      (login|env|cred-process|write-to-credentials|remove|rotate)
        _arguments '*:profile:' && ret=0 ;;
    esac ;;
esac

return ret
