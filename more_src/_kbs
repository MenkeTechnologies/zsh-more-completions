#compdef kbs
# _kbs — Confidential Containers Key Broker Service (Trustee KBS gateway: attestation + secret-release)
# upstream: https://github.com/confidential-containers/trustee
# Flags from kbs/src/config.rs Cli on tip (clap); KBS_CONFIG_FILE env var also binds.

_kbs() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-c --config-file)'{-c,--config-file}'=[path to KBS config file (TOML/YAML/JSON)]:file:_files'
}

_kbs "$@"
