#compdef pmnsadd
# Documentation: https://man.archlinux.org/man/pmnsadd.1.en
# Add a subtree of names to a Performance Co-Pilot PMNS

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '-n+[load an alternative PMNS from file]:pmnsfile:_files' \
  '*:file:_files' && ret=0

return ret
