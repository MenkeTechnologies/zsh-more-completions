#compdef frm
# Documentation: frm --help (GNU Mailutils)
# Source: display the From: lines of messages in a mailbox.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-d --debug)'{-d,--debug}'[enable debug output]' \
    '(-f --field)'{-f+,--field=}'[header field to display]:name:' \
    '(-l --to --no-to)-l[include To: information]' \
    '--to[include To:]' \
    '--no-to[exclude To:]' \
    '(-n --number --no-number)-n[display message numbers]' \
    '--number[display numbers]' '--no-number[hide numbers]' \
    '(-Q --Quiet)'{-Q,--Quiet}'[do not display headers]' \
    '(-q --query)'{-q,--query}'[print message if mailbox has unread mail]' \
    '(-S --summary --no-summary)-S[print summary of messages]' \
    '--summary[print summary]' '--no-summary[no summary]' \
    '(-s --status)'{-s+,--status=}'[select by status]:status:(new unread old read)' \
    '(-t --align --no-align)-t[tidy mode: align subjects]' \
    '--align[tidy align]' '--no-align[no alignment]' \
    '--debug-level=[Mailutils debug level]:level:' \
    '--debug-line-info[show source info in debug]' \
    '--no-debug-line-info[hide source info]' \
    '--config-file=[config file]:file:_files' \
    '--config-lint[check config syntax and exit]' \
    '--config-verbose[verbose config parsing]' \
    '--no-config[do not load configuration files]' \
    '*:url:' \
    && ret=0

return ret
