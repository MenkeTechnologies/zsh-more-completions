#compdef @AddEdge
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@AddEdge.html
# Create composite edge-enhanced datasets and drive AFNI to display them

local ret=1

_arguments -s -S \
  '-help[display help screen]' \
  '-examinelist[use list of paired datasets from file]:file:_files' \
  '-ax_mont[axial montage string (default 2x2:24)]:montformat' \
  '-ax_geom[axial image window geometry]:geomformat' \
  '-sag_geom[sagittal image window geometry]:geomformat' \
  '-layout[use AFNI layout file for display]:file:_files' \
  '-no_layout[do not use layout; use AFNI as it is open]' \
  '-edge_percentile[edge threshold value (default 30%)]:nn' \
  '-single_edge[show only a single edge in composite image]' \
  '-opa[set opacity of overlay (default 9 opaque)]:opa' \
  '-keep_temp[do not remove temporary files]' \
  '-no_deoblique[do not deoblique any data to show overlap]' \
  '-auto_record[save jpeg files of current slices without prompting]' \
  '(-no_auto)-auto[close old AFNI sessions and relaunch in review mode]' \
  '(-auto)-no_auto[opposite of -auto]' \
  '*:dataset:_files' && ret=0

return ret
