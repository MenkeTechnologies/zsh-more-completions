#compdef scil_fodf_metrics
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_fodf_metrics.html
# Scilpy: compute fODF metrics (AFD, NuFO, peaks) from an fODF SH volume

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--sphere=[sphere for peak extraction]:sphere' \
  '--mask=[binary mask]:mask:_files' \
  '--at=[absolute threshold]:a_threshold' \
  '--rt=[relative threshold]:r_threshold' \
  '--abs_peaks_and_values[save absolute peaks and values]' \
  '--sh_basis=[SH basis]:basis:(descoteaux07 tournier07 descoteaux07_legacy tournier07_legacy)' \
  '--processes=[number of sub-processes]:nbr' \
  '--not_all[only saved metrics are computed]' \
  '--afd_max=[AFD max output]:file:_files' \
  '--afd_total=[AFD total output]:file:_files' \
  '--afd_sum=[AFD sum output]:file:_files' \
  '--nufo=[NuFO output]:file:_files' \
  '--rgb=[RGB output]:file:_files' \
  '--peaks=[peaks output]:file:_files' \
  '--peak_values=[peak values output]:file:_files' \
  '--peak_indices=[peak indices output]:file:_files' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_fODF:_files' && ret=0

return ret
