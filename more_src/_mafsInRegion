#compdef mafsInRegion
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: extract MAFs in a genomic region

local ret=1

_arguments -s -S \
  '-outDir[output separate files named by bed name field to outDir]' \
  '-keepInitialGaps[keep alignment columns at block boundaries gapped in all species]' \
  '1:regions bed:_files -g "*.bed"' \
  '2:output maf or dir:_files' \
  '*:input maf:_files -g "*.maf"' && ret=0

return ret
