#compdef extremetuxracer etr
# Documentation: https://man.archlinux.org/search?q=extremetuxracer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--fullscreen[fullscreen mode]' \
  '--windowed[windowed mode]' \
  '--data-dir=+[data dir]:dir:_files -/' && ret=0

return ret
