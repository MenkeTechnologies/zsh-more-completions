#compdef extremetuxracer etr
# Documentation: https://sourceforge.net/projects/extremetuxracer/
# Reference accessed: 2026-05-16
# Verified: extremetuxracer 0.8.x has no CLI flag parser; all settings
# come from ~/.etr/options config file. Confirmed via etr source main.cpp
# (no getopt/argp).
# Removed from prior file: fabricated --help/--version/--fullscreen/
# --windowed/--data-dir flags and bogus man.archlinux.org search URL.

# extremetuxracer: open-source downhill racing (no CLI flags)
local curcontext="$curcontext" ret=1
_arguments -C \
  ':no-flags (config via ~/.etr/options):' && ret=0
return ret
