#compdef ganesha-grace
# Documentation: https://man.archlinux.org/search?q=ganesha-grace
# Reference accessed: 2026-05-16

# ganesha-grace: manage NFS-Ganesha local grace period state
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[grace database directory]:dir:_files -/' \
  '1:action:(start lift join enforce noenforce member dump add remove)' \
  '*::extra args:' && ret=0
return ret
