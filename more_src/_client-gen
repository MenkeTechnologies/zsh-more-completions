#compdef client-gen
# _client-gen — Kubernetes typed clientset generator (kubernetes/code-generator)
# upstream: https://github.com/kubernetes/code-generator
# Flags from cmd/client-gen/args/args.go on tip.

_client-gen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--output-dir=[output directory]:dir:_files -/' \
        '--output-pkg=[output Go package path]:pkg:' \
        '--go-header-file=[Go header file prepended to generated files]:file:_files' \
        '*--input=[input GroupVersion (e.g. v1,extensions/v1beta1)]:gv:' \
        '*--included-types-overrides=[per-type IncludedTypesOverrides (group/version/type)]:override:' \
        '--input-base=[input package base path]:pkg:' \
        '(-n --clientset-name)'{-n,--clientset-name=}'[clientset name]:name:' \
        '--clientset-api-path=[clientset API path]:path:' \
        '--clientset-only=[generate only the clientset shim]:bool:(true false)' \
        '--fake-clientset=[generate the fake clientset]:bool:(true false)' \
        '--plural-exceptions=[singular=plural exceptions (comma-sep)]:list:' \
        '--apply-configuration-package=[apply-configuration package path]:pkg:' \
        '--prefers-protobuf=[prefer protobuf over JSON]:bool:(true false)' \
        '*--lint-rules=[gengo lint rules to enable (comma-sep)]:rules:' \
        '-v[klog verbosity level]:n:'
}

_client-gen "$@"
