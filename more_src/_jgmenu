#compdef jgmenu
# _jgmenu — lightweight standalone menu (johanmalm/jgmenu)
# upstream: https://github.com/johanmalm/jgmenu
# Flags from src/jgmenu.c + src/args.c.

_jgmenu() {
    local -a args
    args=(
        '(- *)--help[show help]'
        '(- *)--version[show version]'
        '--no-spawn[redirect command to stdout instead of executing]'
        '--checkout=[checkout submenu <tag> on startup]:tag:'
        '--config-file=[specify config file]:file:_files'
        '--icon-size=[icon size in px (default 22, 0 disables)]:size:'
        '--at-pointer[launch menu at the mouse pointer]'
        '--hide-on-startup[start menu in hidden state]'
        '--simple[short-lived mode (ignore tint2 / exit on click)]'
        '--vsimple[--simple + disable icons + ignore jgmenurc]'
        '--csv-file=[menu file (jgmenu CSV format)]:file:_files -g "*.csv"'
        '--csv-cmd=[command producing menu data]:cmd:'
        '--center[center the menu]'
        '--persistent[keep the menu open]'
        '--die-when-loaded[exit as soon as the menu loads]'
        '*--override=[override one config line (key = value)]:override:'
        '1:command:(init)'
    )
    _arguments -s -S $args
}

_jgmenu "$@"
