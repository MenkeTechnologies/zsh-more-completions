#compdef docfd
# docfd - Find documentation files in a project

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --path)'{-p+,--path=}'[search path]:directory:_files -/' \
  '--max-depth=[max directory depth]:depth:' \
  '--exts=[file extensions to search]:extensions:' \
  '--hidden[include hidden files]' \
  '--no-ignore[do not respect .gitignore]' \
  '--glob=[glob pattern to include]:glob:' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(table json path)' \
  '*:search pattern:' \
  && ret=0

return ret
