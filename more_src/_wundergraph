#compdef wunderctl

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'up:start the WunderGraph server'
      'generate:generate configuration and code'
      'node:manage WunderGraph node'
      'start:start in production mode'
      'create:create a new WunderGraph project'
      'login:log in to WunderGraph Cloud'
      'logout:log out'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (up)
        _arguments \
          '--debug[enable debug mode]' \
          '--listen-addr=[listen address]:address:' \
          '--clear-cache[clear cache before starting]' \
          '--wundergraph-dir=[WunderGraph directory]:dir:_files -/' && ret=0
        ;;
      (generate)
        _arguments \
          '--wundergraph-dir=[WunderGraph directory]:dir:_files -/' && ret=0
        ;;
      (start)
        _arguments \
          '--listen-addr=[listen address]:address:' \
          '--wundergraph-dir=[WunderGraph directory]:dir:_files -/' && ret=0
        ;;
      (create)
        _arguments \
          '--init=[template]:template:' \
          '1:directory:' && ret=0
        ;;
    esac
    ;;
esac

return ret
