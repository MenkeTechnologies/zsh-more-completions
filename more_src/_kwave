#compdef kwave

# Kwave: KDE sound editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--disable-splashscreen[skip splash screen]' \
  '--iconic[start minimized]' \
  '--logfile=[log file]:file:_files' \
  '*:sound file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3|m4a|wma|au|aac)"' && ret=0
return ret
