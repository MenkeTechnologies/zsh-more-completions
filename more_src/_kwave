#compdef kwave
# Documentation: https://docs.kde.org/trunk5/en/kwave/kwave/command_line.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Kwave: KDE sound editor.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--disable-splashscreen[skip splash screen]' \
  '--iconic[start minimized (implies --disable-splashscreen)]' \
  '--gui=[GUI mode]:mode:(SDI MDI TAB)' \
  '--logfile=[log session actions to file]:file:_files' \
  '*:sound file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3|m4a|wma|au|aac)"' && ret=0
return ret
