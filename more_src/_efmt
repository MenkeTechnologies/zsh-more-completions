#compdef efmt
# Documentation: https://github.com/sile/efmt
# Erlang code formatter

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--verbose[output debug log messages]' \
  '(-c --check)'{-c,--check}'[check if input is formatted correctly]' \
  '(-w --write)'{-w,--write}'[overwrite input file with formatted text]' \
  '--show-files[show the target input files]' \
  '*'{-e,--exclude-file}'+[exclude files matching regex from default targets]:regex' \
  '--parallel[execute formatting in parallel]' \
  '--default-off[treat files as if @efmt:off appears at start]' \
  '--disable-rebar3-mode[do not assume project is built with rebar3]' \
  '--allow-partial-failure[do not error even if input has wrong Erlang code]' \
  '--color[show colored diff (works with --check)]' \
  '--check-line-length=[validate non-comment lines do not exceed length]:length' \
  '*:erlang file:_files' && ret=0

return ret
