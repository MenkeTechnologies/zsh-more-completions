#compdef prthis
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/prthis.html
# List history item of a dataset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[in keyword]:in:' \
  'bcount=[bcount keyword]:bcount:' \
  'log=[log keyword]:log:' \
  'task=[task keyword]:task:' \
  '*:visibility dataset:_files' && ret=0

return ret
