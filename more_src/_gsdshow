#compdef gsdshow
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss33.html
# SMURF: display the contents of headers and arrays for GSD files.

local ret=1

_arguments -s -S \
  'IN=[input GSD file to list]:file:_files' \
  'DESCRIPTIONS=[show header descriptions]:flag:(TRUE FALSE)' \
  'SHOWDATA=[show data array]:flag:(TRUE FALSE)' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:file:_files' && ret=0

return ret
