#compdef jackmeter jack_meter
# Documentation: https://github.com/njh/jackmeter/blob/main/jack_meter.1
# Reference accessed: 2026-05-19
# Verified: njh/jackmeter jack_meter(1) manpage + jack_meter.c getopt
# string "s:w:f:r:nhv". Upstream binary is jack_meter; both names
# completed. Removed fabricated -d (dumb mode) and -n-as-client-name;
# added real -w (width), -s (server), -v.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show usage]' \
  '(- *)-v[show usage/version]' \
  '-f[refreshes per second (default 8)]:hz:' \
  '-r[reference signal level for 0dB]:dB:' \
  '-w[meter width in characters (default 79)]:width:' \
  '-s[JACK server name]:server:' \
  '-n[output level as a number in dB instead of bar graph]' \
  '*:JACK port(s) to meter:' && ret=0
return ret
