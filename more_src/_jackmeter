#compdef jackmeter
# Documentation: https://man.archlinux.org/search?q=jackmeter
# Reference accessed: 2026-05-16

# jackmeter: terminal-style JACK level meter
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-f[update rate (Hz)]:hz:' \
  '-r[ref level (dBFS, default 0)]:dB:' \
  '-n[client name]:name:' \
  '-d[run in dumb mode (one line per update)]' \
  '*:JACK port(s) to meter:' && ret=0
return ret
