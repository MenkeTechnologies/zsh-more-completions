#compdef ttyplot
# Documentation: https://github.com/tenox7/ttyplot
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for ttyplot - Terminal plotting tool

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-2[two plots / second in reverse video]' \
  '-r[calculate rate for counter-style metrics]' \
  '-c+[plot line character]:char:' \
  '-e+[error character when value above max]:char:' \
  '-E+[error character when value below min]:char:' \
  '-s+[initial plot scale]:scale:' \
  '-m+[maximum value]:max:' \
  '-M+[minimum value]:min:' \
  '-t+[plot title]:title:' \
  '-u+[unit label]:unit:' \
  '-C+[color scheme]:color:(0 1 2 3 4 5 6 7 dark1 dark2 light1 light2)' \
  && return 0
