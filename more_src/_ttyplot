#compdef ttyplot

# Zsh completion for ttyplot - Terminal plotting tool

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-t[title of the plot]:title:' \
  '-u[unit label]:unit:' \
  '-m[minimum value]:min:' \
  '-M[maximum value]:max:' \
  '-s[softmax (initial max value)]:softmax:' \
  '-c[color of the plot]:color:(0 1 2 3 4 5 6 7)' \
  '-C[color of the second line]:color:(0 1 2 3 4 5 6 7)' \
  '-e[error/second line mode]' \
  '-E[stacked error/second line mode]' \
  '-S[use SI suffixes for values]' \
  '-w[width in characters]:width:' \
  && return 0
