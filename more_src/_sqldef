#compdef mysqldef psqldef sqlite3def mssqldef
# Documentation: https://github.com/sqldef/sqldef
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# sqldef ships per-database binaries: mysqldef, psqldef, sqlite3def, mssqldef.
# Flag set verified from cmd/mysqldef source; sister binaries share the same
# operational flag surface with database-specific connection options.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-u --user)'{-u+,--user=}'[database user]:user:_users' \
  '(-p --password)'{-p+,--password=}'[database password]:password:' \
  '--password-prompt[force password prompt]' \
  '(-h --host)'{-h+,--host=}'[database host]:host:_hosts' \
  '(-P --port)'{-P+,--port=}'[database port]:port:' \
  '(-S --socket)'{-S+,--socket=}'[unix socket]:file:_files' \
  '--ssl-mode=[SSL mode]:mode:(PREFERRED REQUIRED DISABLED)' \
  '--ssl-ca=[SSL trusted CA file]:file:_files' \
  '--enable-cleartext-plugin[enable cleartext authentication plugin]' \
  '--file=[read desired schema SQL from file]:file:_files' \
  '--export[dump current schema to stdout]' \
  '--dry-run[show DDLs without applying]' \
  '--check[like --dry-run, exit 2 if DDL would apply]' \
  '--apply[apply DDLs to the database]' \
  '--enable-drop[enable destructive changes (DROP)]' \
  '--before-apply=[execute SQL before applying DDLs]:sql:' \
  '*--config=[YAML configuration file]:file:_files' \
  '*--config-inline=[inline YAML configuration]:yaml:' \
  '--skip-view[skip managing views]' \
  '*:database:' && ret=0

return ret
