#compdef sqldef

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'apply:apply DDL to database'
      'export:export live schema to SQL'
      'migration:migration helpers'
      'version:print version'
    )
    _describe -t commands 'sqldef command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '--help[show help]' \
      '(-f --file)'{-f,--file}'=[schema SQL file]:file:_files' \
      '(-U --user)'{-U,--user}'=[DB user]:user' \
      '--host=[DB host]:host' \
      '(-p --port)'{-p,--port}'=[DB port]:port' \
      '(-d --database)'{-d,--database}'=[database name]:db' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
