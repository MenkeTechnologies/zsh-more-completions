#compdef fontimage
# Documentation: https://fontforge.org/docs/fontutils/fontimage.html
# Generate a thumbnail image of a font

local ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--o=[output image file (.bmp or .png)]:output file:_files' \
  '--width=[width of output image in pixels]:width' \
  '--height=[height of output image in pixels]:height' \
  '*--pixelsize=[pixelsize at which to display text]:pixelsize' \
  '--fontname[include the fontname as a line of text]' \
  '*--text=[UTF-8 string to display]:text' \
  '*:font file:_files' && ret=0

return ret
