#compdef pee
# _pee — moreutils pee (tee for pipes: reads stdin and writes it to each child command, each launched in its own subshell; --[no-]ignore-sigpipe and --[no-]ignore-write-errors control how broken-pipe children are handled)
# upstream: https://salsa.debian.org/built-using-team/moreutils (joeyh)
# Flags from moreutils pee.c on tip.

_pee() {
    _arguments \
        '--ignore-sigpipe[ignore SIGPIPE from children]' \
        '--no-ignore-sigpipe[propagate SIGPIPE]' \
        '--ignore-write-errors[ignore write errors to children]' \
        '--no-ignore-write-errors[surface write errors]' \
        '*:command:'
}

_pee "$@"
