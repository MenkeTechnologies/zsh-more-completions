#compdef condor_sos
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_sos.html
# issue a command with a longer timeout via a daemon command port reserved for emergencies

local ret=1

_arguments -s -S \
  '-help[display usage information]' \
  '-version[display version information]' \
  '-debug[print extra debugging information as the command executes]' \
  '-timeoutmult[multiply any timeouts set for the command by the given value]:value' \
  '*:::command:_normal' && ret=0

return ret
