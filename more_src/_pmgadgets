#compdef pmgadgets
# _pmgadgets — Qt-based simple GUI widgets for PCP scripts (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pmgadgets/main.cpp usage block.

_pmgadgets() {
    _arguments \
        '(- *)-?[show help]' \
        '(- *)-help[show help]' \
        '-header+[window title]:title:' \
        '-noslider[do not display a text-box slider]' \
        '-noframe[do not display a frame around the text box]' \
        '*:message:'
}

_pmgadgets "$@"
