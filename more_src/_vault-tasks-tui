autoload -U is-at-least

_vault-tasks-tui() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-v+[Vault to open (can be a single file or a directory)]:PATH:_files' \
'--vault-path=[Vault to open (can be a single file or a directory)]:PATH:_files' \
'-t+[Tick rate, i.e. number of ticks per second]:FLOAT:_default' \
'--tick-rate=[Tick rate, i.e. number of ticks per second]:FLOAT:_default' \
'-f+[Frame rate, i.e. number of frames per second]:FLOAT:_default' \
'--frame-rate=[Frame rate, i.e. number of frames per second]:FLOAT:_default' \
'-c+[Use a custom config file]:PATH:_files' \
'--config-path=[Use a custom config file]:PATH:_files' \
'-s[Show frame rate and tick rate]' \
'--show-fps[Show frame rate and tick rate]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_vault-tasks-tui_commands" \
"*::: :->vault-tasks-tui" \
&& ret=0
    case $state in
    (vault-tasks-tui)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:vault-tasks-tui-command-$line[1]:"
        case $line[1] in
            (explorer)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(filter)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(time-management)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(calendar)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(generate-config)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::path:_files' \
&& ret=0
;;
(generate-completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(stdout)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(new-task)
_arguments "${_arguments_options[@]}" : \
'-f+[Filename to append the new tasks to]:FILENAME:_default' \
'--filename=[Filename to append the new tasks to]:FILENAME:_default' \
'-h[Print help]' \
'--help[Print help]' \
'*::tasks -- Tasks to create, use usual vault-tasks syntax:_default' \
&& ret=0
;;
(fix)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_vault-tasks-tui__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:vault-tasks-tui-help-command-$line[1]:"
        case $line[1] in
            (explorer)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(filter)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(time-management)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(calendar)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(generate-config)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(generate-completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(stdout)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(new-task)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(fix)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_vault-tasks-tui_commands] )) ||
_vault-tasks-tui_commands() {
    local commands; commands=(
'explorer:Open explorer view' \
'filter:Open filter view' \
'time-management:Open Time Management view' \
'calendar:Open Calendar view' \
'generate-config:Generates a new configuration file from the default one' \
'generate-completions:Generates shell completions' \
'stdout:Write tasks to STDOUT' \
'new-task:Creates a new task' \
'fix:Fix your tasks without opening the TUI' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'vault-tasks-tui commands' commands "$@"
}
