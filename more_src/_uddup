#compdef uddup
# Documentation: https://github.com/rotemreiss/uddup
# URLs de-duplication tool for better recon

local ret=1

_arguments -s -S \
  '(-u --urls)'{-u,--urls}'[file with a list of urls]:urls file:_files' \
  '(-o --output)'{-o,--output}'[save results to a file]:output file:_files' \
  '(-s --silent)'{-s,--silent}'[print only the result URLs]' \
  '(-fp --filter-path)'{-fp,--filter-path}'[filter paths by a given Regex]:regex' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
