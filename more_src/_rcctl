#compdef rcctl
# _rcctl — OpenBSD rcctl (front-end for rc.d(8); enable/disable daemons, set/get rc.conf.local variables, start/stop/reload/restart/check, and bulk-query state via ls)
# upstream: https://github.com/openbsd/src (usr.sbin/rcctl)
# Subcommands + flags from usr.sbin/rcctl/rcctl.8 on tip.

_rcctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-d[debug]' \
        '-f[force]' \
        '-q[quiet]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'rcctl command' \
                '(get:get rc variable getdef:get default value set:set rc variable enable:enable daemon disable:disable daemon order:set/list start order ls:list daemons by state check:check daemon configtest:configtest daemon reload:reload daemon restart:restart daemon start:start daemon stop:stop daemon)'
            ;;
        args)
            case $line[1] in
                ls) _describe -t commands 'ls filter' '(all failed off on rogue started stopped)' ;;
            esac
            ;;
    esac
}

_rcctl "$@"
