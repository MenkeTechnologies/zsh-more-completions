#compdef ngscheckmate_fastq
# Documentation: https://github.com/parklab/NGSCheckMate
# NGSCheckMate FASTQ-mode pattern counter (C program)

local ret=1

_arguments -s -S \
  '(-1 --fastq1)'{-1,--fastq1}'=[FASTQ file or first paired-end file]:file:_files' \
  '(-2 --fastq2)'{-2,--fastq2}'=[second paired-end FASTQ file]:file:_files' \
  '(-s --ss)'{-s,--ss}'=[subsampling rate]:rate' \
  '(-d --depth)'{-d,--depth}'=[target depth]:depth' \
  '(-R --reference_length)'{-R,--reference_length}'=[genomic region length]:len' \
  '(-L --pattern_length)'{-L,--pattern_length}'=[flanking sequence length]:len' \
  '(-p --maxthread)'{-p,--maxthread}'=[number of threads]:n' \
  '*:pt file:_files' && ret=0

return ret
