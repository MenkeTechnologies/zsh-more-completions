#compdef CompositeTransformUtil
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/CompositeTransformUtil.cxx — assemble/disassemble ITK composite transforms (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(--assemble --disassemble)--disassemble[disassemble a composite transform]' \
    '(--assemble --disassemble)--assemble[assemble component transforms into one composite]' \
    '*:transform file or prefix:_files' \
    && ret=0

return ret
