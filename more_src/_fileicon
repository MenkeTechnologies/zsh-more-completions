#compdef fileicon
# Documentation: https://github.com/mklement0/fileicon
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# macOS file icon utility. Subcommands: set, get, rm/remove, test.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--man[show manual page]' \
  '--version[show version]' \
  '--home[show project home page]' \
  '-q[quiet output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a cmds=(
      'set:assign a custom icon to a file or folder'
      'get:extract the custom icon to an image file'
      'rm:remove a custom icon'
      'remove:remove a custom icon (alias for rm)'
      'test:check whether a file/folder has a custom icon'
    )
    _describe -t cmds 'fileicon command' cmds && ret=0
    ;;
  (args)
    case $line[1] in
      (get)
        _arguments \
          '-f[force replacement of existing output file]' \
          '-q[quiet]' \
          '1:file or folder:_files' \
          '2:icon output file:_files' && ret=0 ;;
      (set|rm|remove|test)
        _arguments \
          '-q[quiet]' \
          '1:file or folder:_files' \
          '2:image file:_files' && ret=0 ;;
    esac ;;
esac

return ret
