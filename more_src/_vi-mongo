#compdef vi-mongo
# ============================================================================
# _vi-mongo — zsh completion for Maciej Kopec's vi-mongo, a Go TUI
#              MongoDB client (mongo-driver v1.14.0)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/kopecmaciej/vi-mongo
#   Author     : Maciej Kopec  (kopecmaciej)
#   License    : Apache-2.0
#   Stars      : 223
#   Language   : Go
#   Module     : github.com/kopecmaciej/vi-mongo
#   Binary     : vi-mongo  (rootCmd.Use = "vi-mongo" in cmd/cmd.go;
#                            built from root main.go calling
#                            cmd.Execute)
#   Last push  : 2026-05-13
#
# WHAT IT IS
#   vi-mongo is "a MongoDB TUI manager designed to simplify data
#   visualization and quick manipulation" — Maciej Kopec's tview-
#   based terminal UI client for MongoDB.  The application keeps a
#   per-user YAML config (default `$HOME/.config/vi-mongo/
#   config.yaml`) with a list of named MongoDB connections,
#   per-connection AES-encrypted credentials (key path configurable
#   via `--key-path`), and persistent UI preferences.  Once
#   connected the TUI exposes vi-style navigation, query / filter /
#   sort, document editing, aggregation pipelines, server stats,
#   and a `--jump db-name/collection-name` shortcut that lets the
#   user open the binary directly inside a particular collection.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/cmd.go spf13/cobra
#                       rootCmd + Flags init block)
#   vi-mongo [OPTIONS]
#
#   Options:
#     -c, --config <FILE>          Config file
#                                    [default: $HOME/.config/
#                                              vi-mongo/config.yaml]
#     -v, --version                Show version and exit
#     -d, --debug                  Enable debug mode (DEBUG-level
#                                  zerolog output)
#     -w, --welcome-page           Show welcome page on startup
#     -p, --connection-page        Show connection page on startup
#     -n, --connection-name <NAME> Connect to a specific MongoDB
#                                  connection by name (must exist
#                                  in the config file)
#     -l, --connection-list        List all available connections
#                                  and exit
#     -j, --jump <DB/COLL>         Jump directly to db-name/
#                                  collection-name (skips both
#                                  welcome + connection pages)
#         --key-path <FILE>        Path to the encryption key file
#                                  (saves it to the config and exits)
#         --gen-key                Generate a valid encryption key
#                                  and exit (prints instructions for
#                                  installing it)
#         --paths                  Show paths to config files and
#                                  log directory and exit
#
#   Standard cobra auto-flags:
#     -h, --help                   Show help
#
#   Environment variable:
#     ENV=vi-dev                   When set, default keybindings
#                                  and styles are loaded from the
#                                  in-tree defaults instead of the
#                                  per-user override files (used by
#                                  the developer dev-loop).
#
# AXIS / CORPUS POSITION
#   Direct dependency on `go.mongodb.org/mongo-driver v1.14.0`
#   declared in go.mod — the canonical Go MongoDB driver maintained
#   by MongoDB Inc (mongodb/mongo-go-driver).  The driver provides
#   typed `mongo.Client` / `mongo.Database` / `mongo.Collection`
#   constructors over the official wire protocol (OP_MSG,
#   OP_COMPRESSED), connection-string parsing via
#   `options.Client().ApplyURI(uri)`, full BSON document support
#   via the sibling `bsonx` and `bson` packages, change streams,
#   transactions, GridFS, SDAM discovery, and async cursors.
#   vi-mongo's `internal/mongo/` uses the driver directly to open
#   sessions, run `find`/`aggregate`/`runCommand`, and stream
#   document pages into the tview UI.  Verified via:
#     gh api repos/kopecmaciej/vi-mongo/contents/go.mod
#       → go.mongodb.org/mongo-driver v1.14.0
#       → github.com/spf13/cobra v1.8.1
#     gh api repos/kopecmaciej/vi-mongo/contents/cmd/cmd.go
#       → rootCmd = &cobra.Command{Use: "vi-mongo", ...}
#   This entry is the Go=135 leader bump that continues Axis 80
#   (MongoDB Driver Library) opened at R909 with Rust=mongodb 3.0.0
#   (Lydanne/mongobar).  Round-number R910 commit landmark.
#
#   No completion for `vi-mongo` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_vi-mongo() {
    _arguments -s \
        '(-c --config)'{-c+,--config=}'[config file (default $HOME/.config/vi-mongo/config.yaml)]:config file:_files -g "*.{yaml,yml}"' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-d --debug)'{-d,--debug}'[enable debug mode]' \
        '(-w --welcome-page)'{-w,--welcome-page}'[show welcome page on startup]' \
        '(-p --connection-page)'{-p,--connection-page}'[show connection page on startup]' \
        '(-n --connection-name)'{-n+,--connection-name=}'[connect by named MongoDB connection]:name:' \
        '(- *)'{-l,--connection-list}'[list all available connections and exit]' \
        '(-j --jump)'{-j+,--jump=}'[jump to db-name/collection-name]:db/coll:' \
        '--key-path=[path to encryption key file]:key file:_files' \
        '(- *)--gen-key[generate a valid encryption key and exit]' \
        '(- *)--paths[show paths to config files and log and exit]' \
        '(- *)'{-h,--help}'[show help]'
}

_vi-mongo "$@"
