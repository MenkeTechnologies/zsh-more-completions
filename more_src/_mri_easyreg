#compdef mri_easyreg
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_easyreg
# FreeSurfer learning-based affine and nonlinear registration

local ret=1

_arguments -s -S \
  '--ref[reference image (.nii/.nii.gz/.mgz)]:ref:_files' \
  '--flo[floating image]:flo:_files' \
  '--ref_seg[SynthSeg v2 seg of reference (auto if missing)]:ref_seg:_files' \
  '--flo_seg[SynthSeg v2 seg of floating (auto if missing)]:flo_seg:_files' \
  '--ref_reg[file for deformed reference image]:ref_reg:_files' \
  '--flo_reg[file for deformed floating image]:flo_reg:_files' \
  '--fwd_field[forward deformation field]:fwd_field:_files' \
  '--bak_field[backward deformation field]:bak_field:_files' \
  '--threads[number of threads (-1 for max)]:threads:' \
  '--affine_only[perform affine registration only]' && ret=0

return ret
