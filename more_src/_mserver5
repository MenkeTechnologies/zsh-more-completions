#compdef mserver5
# Documentation: https://www.monetdb.org/documentation/
# MonetDB version 5 database server

local ret=1

_arguments -s -S \
  '--help[show available options]' \
  '--version[show version information]' \
  '--dbpath=[path where mserver5 finds a database]:path:_files -/' \
  '--dbextra=[location for transient data storage]:path:_files -/' \
  '--config=[configuration file with name=value options]:file:_files' \
  '*--set[set a configuration option]:option=value:' \
  '--in-memory[operate entirely in RAM without persisting]' \
  '--readonly[open the database in read-only mode]' \
  '--single-user[permit only one concurrent user connection]' \
  '--dbtrace=[trace log file]:file:_files' \
  '*--loadmodule[load a dynamic module]:module:' \
  '(--debug -d)'{--debug=,-d+}'[set debugging output level]:value:' \
  '--threads[debug thread and parallelism]' && ret=0

return ret
