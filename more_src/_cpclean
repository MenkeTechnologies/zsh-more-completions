#compdef cpclean

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-o+[output project file]:file:_files -g "*.pto"' \
  '-n+[iterations]:n:' \
  '-p[skip pair check]' \
  '-w[skip whole project check]' \
  '-s+[std dev threshold]:val:' \
  '-v[verbose]' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
