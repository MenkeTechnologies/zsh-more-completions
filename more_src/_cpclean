#compdef cpclean
# Documentation: https://wiki.panotools.org/Cpclean
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cpclean - Hugin tool to remove wrong/outlier control points from a Hugin
# project (.pto). Short forms below mirror Hugin's man page conventions.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(-o --output)'{-o+,--output=}'[output project file]:file:_files -g "*.pto"' \
  '(-n --max-distance)'{-n+,--max-distance=}'[threshold multiplier (mean + n*sigma)]:n:' \
  '(-p --pairwise-checking)'{-p,--pairwise-checking}'[only image-pair CP checking (skip step 2)]' \
  '(-w --whole-pano-checking)'{-w,--whole-pano-checking}'[only whole-pano CP checking (skip step 1)]' \
  '--dont-optimize[skip optimisation; use current image positions]' \
  '--check-line-cp[include line CPs in step 2 calculations]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
