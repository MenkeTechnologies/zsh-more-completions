#compdef liquibase

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'update:run pending changes'
  'update-count:run N changes'
  'update-count-sql:show SQL for N changes'
  'update-sql:show SQL for pending changes'
  'update-to-tag:apply changes up to tag'
  'update-to-tag-sql:show SQL up to tag'
  'rollback:rollback to tag'
  'rollback-count:rollback N changes'
  'rollback-count-sql:show rollback SQL for N'
  'rollback-sql:show rollback SQL'
  'rollback-to-date:rollback to date'
  'rollback-to-date-sql:show rollback SQL to date'
  'snapshot:capture DB snapshot'
  'snapshot-reference:capture reference snapshot'
  'diff:diff two databases'
  'diff-changelog:generate changelog from diff'
  'generate-changelog:generate changelog from DB'
  'changelog-sync:sync changelog without applying'
  'changelog-sync-sql:show SQL for sync'
  'changelog-sync-to-tag:sync to tag'
  'mark-next-changeset-ran:mark next as ran'
  'history:show migration history'
  'status:show pending changes'
  'tag:tag current state'
  'tag-exists:check if tag exists'
  'unexpected-changesets:show changesets in DB but not changelog'
  'validate:validate changelog'
  'calculate-checksum:calculate checksum'
  'clear-checksums:clear checksums'
  'release-locks:release locks'
  'list-locks:list locks'
  'drop-all:drop all DB objects'
  'init:initialize project'
  'flow:run a flow file'
  'checks:run quality checks'
  'connect:test database connection'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--changelog-file=[changelog file]:file:_files -g "*.xml *.yml *.yaml *.json *.sql"' \
  '*--url=[JDBC URL]:url:' \
  '*--username=[user]:user:_users' \
  '*--password=[pass]:p:' \
  '*--driver=[JDBC driver]:d:' \
  '*--classpath=[classpath]:cp:' \
  '*--default-schema-name=[default schema]:s:' \
  '*--liquibase-schema-name=[liquibase schema]:s:' \
  '*--contexts=[contexts csv]:list:' \
  '*--label-filter=[label filter]:l:' \
  '*--log-level=[log level]:l:(SEVERE WARNING INFO CONFIG FINE FINER FINEST DEBUG ERROR WARN OFF)' \
  '*--log-file=[log file]:file:_files' \
  '*--output-file=[output file]:file:_files' \
  '*--defaults-file=[defaults file]:file:_files -g "*.properties"' \
  '*--license-key=[license key]:k:' \
  '*--show-banner=[show banner]:b:(true false)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'liquibase command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
