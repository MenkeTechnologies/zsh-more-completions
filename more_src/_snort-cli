#compdef snort-cli
# _snort-cli — Martin Roesch Snort open-source IDS/IPS CLI alias (snort team, C); custom argparse
# upstream: https://github.com/snort3/snort3

_snort-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-A+[alert mode]:m:(none console alert_fast alert_full alert_syslog alert_unified2 alert_csv alert_json)' \
        '-b[log packets in pcap]' \
        '-B+[mask]:str:' \
        '-c+[config file]:file:_files -g "*.{lua,conf}"' \
        '-C[print payloads in ascii]' \
        '-d[dump app layer]' \
        '-D[daemon mode]' \
        '-e[display second layer headers]' \
        '-E[generate alert events]' \
        '-f+[log facility]:str:' \
        '-F+[BPF file]:file:_files' \
        '-G+[event log id base]:n:' \
        '-g+[group]:_groups' \
        '-i+[interface]:_net_interfaces' \
        '-I[add ifname to alerts]' \
        '-k+[checksum level]:m:(all noip notcp noudp noicmp none)' \
        '-K+[log format]:m:(pcap none ascii)' \
        '-l+[log dir]:dir:_files -/' \
        '-L+[log file]:file:_files' \
        '-M[log to syslog]' \
        '-n+[exit after n packets]:n:' \
        '-N[turn off logging]' \
        '-O[obfuscate IPs]' \
        '-p[don'\''t put network card into promiscuous mode]' \
        '-P+[snaplen]:n:' \
        '-q[quiet]' \
        '-Q[inline mode]' \
        '-r+[pcap file]:file:_files -g "*.pcap*"' \
        '-R+[rule file]:file:_files -g "*.rules"' \
        '-s+[log alerts to syslog]' \
        '-S+[name=value]:str:' \
        '-t+[chroot dir]:dir:_files -/' \
        '-T[test config and exit]' \
        '-u+[user]:_users' \
        '-U[use UTC timestamps]' \
        '-v[verbose]' \
        '-X[dump raw packet starting at link layer]' \
        '-y[year in timestamps]' \
        '-z+[max threads]:n:' \
        '-Z+[perfmon dir]:dir:_files -/' \
        '--alert-before-pass[alert before pass]' \
        '--bpf=+[BPF filter]:str:' \
        '--create-pidfile[create pid file]' \
        '--daq=+[daq module]:str:' \
        '--daq-dir=+[daq dir]:dir:_files -/' \
        '--daq-list[list daq modules]' \
        '--daq-mode=+[daq mode]:m:(passive inline read-file)' \
        '--daq-var=+[var]:str:' \
        '--disable-inline-init-failopen[disable inline init failopen]' \
        '--dump-builtin-rules=+[gid]:n:' \
        '--dump-defaults[dump defaults]' \
        '--dump-version[dump version]' \
        '--enable-inline-test[enable inline test mode]' \
        '--gen-msg-map=+[file]:file:_files' \
        '--help-builtin=+[name]:str:' \
        '--help-counts=+[name]:str:' \
        '--help-module=+[name]:str:' \
        '--help-modules[help modules]' \
        '--list-builtin[list builtins]' \
        '--list-gids[list gids]' \
        '--list-modules[list modules]' \
        '--list-plugins[list plugins]' \
        '--logid=+[id]:n:' \
        '--lua=+[lua chunk]:str:' \
        '--markup[markup output]' \
        '--max-packet-threads=+[n]:n:' \
        '--mem-check[memory check]' \
        '--nostamps[no timestamps]' \
        '--pause[pause on startup]' \
        '--pcap-show[show pcap]' \
        '--pid-path=+[dir]:dir:_files -/' \
        '--plugin-path=+[dir]:dir:_files -/' \
        '--process-all-events[process all events]' \
        '--rule=+[rule]:str:' \
        '--rule-path=+[dir]:dir:_files -/' \
        '--run-prefix=+[prefix]:str:' \
        '--script-path=+[dir]:dir:_files -/' \
        '--show-plugins[show plugins]' \
        '--snaplen=+[bytes]:n:' \
        '--stdin-rules[read rules from stdin]' \
        '--talos[run with talos rules]' \
        '--tweaks=+[name]:str:' \
        '--warn-all[warn all]' \
        '*:arg:'
}

_snort-cli "$@"
