#compdef impacket-ticketer

# Impacket ticketer.py: forge Kerberos Golden/Silver tickets
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-request[request ticket from KDC]' \
  '-domain[domain name]:domain:' \
  '-domain-sid[domain SID]:sid:' \
  '-aesKey[domain AES key]:key:' \
  '-nthash[domain NT hash]:hash:' \
  '-spn[service principal name (silver ticket)]:spn:' \
  '-extra-pac[generate PAC_REQUESTOR/PAC_UPN_DNS_INFO]' \
  '-extra-sid[extra SID for SIDHistory]:sid:' \
  '-old-pac[use old PAC structure]' \
  '-duration[ticket lifetime hours]:n:' \
  '-groups[group RIDs (comma list)]:rids:' \
  '-user-id[user RID]:n:' \
  '-ts[print timestamp on every output line]' \
  '-debug[debug]' \
  '-keytab[use keytab file]:file:_files' \
  '-impersonate[user to impersonate]:user:' \
  '-dc-ip[KDC IP]:ip:' \
  '*:username:' && ret=0
return ret
