#compdef impacket-ticketer
# Documentation: https://github.com/fortra/impacket/blob/master/examples/ticketer.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-ticketer: forge Kerberos golden/silver tickets (TGTs and service tickets)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-spn[service principal name (silver ticket)]:spn:' \
  '-request[request the TGT/TGS from the KDC]' \
  '-domain[FQDN domain]:domain:' \
  '-domain-sid[domain SID]:sid:' \
  '-aesKey[AES key for the target service or krbtgt]:hex:' \
  '-nthash[NT hash for the target service or krbtgt]:hash:' \
  '-keytab[keytab file]:file:_files' \
  '-groups[group SIDs (comma-separated)]:sids:' \
  '-user-id[user RID]:rid:' \
  '-extra-sid[extra SID(s) to embed (comma-separated)]:sids:' \
  '-extra-pac[include EXTRA_PAC buffers]' \
  '-old-pac[generate PRE-Windows 2003 PAC]' \
  '-duration[ticket lifetime in hours]:hours:' \
  '-ts[add timestamp to logging]' \
  '-debug[enable DEBUG output]' \
  '-impersonate[user to impersonate (S4U)]:user:' \
  '-user[user to authenticate as (when -request)]:user:' \
  '-password[password for -user]:pass:' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-dc-ip[domain controller IP]:ip:' \
  '1:target username:' && ret=0
return ret
