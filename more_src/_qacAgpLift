#compdef qacAgpLift
# UCSC kent: use AGP to combine per-scaffold qac into per-chrom qac

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-mScore=[score to use for missing data (0-99)]:n:' \
  ':scaffold to chrom agp:_files' \
  ':scaffolds qac:_files' \
  ':chrom qac:_files' && ret=0

return ret
