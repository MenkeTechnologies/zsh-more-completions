#compdef refactor apply-refact
# Documentation: https://hackage.haskell.org/package/apply-refact
# Refactor Haskell source files using HLint suggestions (refactor executable)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--refact-file=[refact file containing refactoring instructions]:file:_files' \
  '-i[refactor in-place, overwriting the input file]' \
  '-s[stepwise: prompt before each refactoring hint]' \
  '--pos=[specify which hint to perform (line,col)]:position' \
  '*-X+[add a default language pragma affecting parsing]:pragma' \
  '--debug[output the GHC AST for debugging]' \
  '--roundtrip[test formatting without applying refactorings]' \
  '--version[show version]' \
  '*:file:_files' && ret=0

return ret
