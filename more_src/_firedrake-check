#compdef firedrake-check
# Documentation: https://www.firedrakeproject.org/install.html
# Run the Firedrake smoke tests

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--mpiexec=[the mpiexec executable to use for parallel tests]:mpiexec:_command_names' && ret=0

return ret
