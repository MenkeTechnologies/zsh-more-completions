#compdef tophat2

# TopHat 2: spliced-read alignment (RNA-Seq)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output directory]:dir:_files -/' \
  '-p[threads]:n:' \
  '-N[max read mismatches]:n:' \
  '-a[min anchor length]:n:' \
  '-i[min intron length]:n:' \
  '-I[max intron length]:n:' \
  '-G[GTF annotation]:file:_files -g "*.gtf"' \
  '--transcriptome-index=[transcriptome index prefix]:prefix:' \
  '-T[only map to transcriptome]' \
  '--library-type=[library type]:type:(fr-unstranded fr-firststrand fr-secondstrand)' \
  '-r[expected mate inner distance]:n:' \
  '--mate-std-dev=[mate distance std dev]:n:' \
  '--no-novel-juncs[no novel junctions]' \
  '--no-novel-indels[no novel indels]' \
  '--coverage-search[coverage-based junction search]' \
  '--microexon-search[search microexons]' \
  '--bowtie1[use Bowtie 1]' \
  '*:bowtie index and reads:_files' && ret=0
return ret
