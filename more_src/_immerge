#compdef immerge
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/immerge.html
# MIRIAD: linear merging of images of different resolutions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[two input images hi-res then lo-res]:in:_files' \
  'out=[output merged image]:out:_files' \
  'factor=[flux calibration scaling factor]:factor:' \
  'uvrange=[Fourier annulus for agreement]:uvrange:' \
  'region=[region of interest]:region:' \
  'device=[PGPLOT device]:device:' \
  'guard=[guard band width in pixels]:guard:' \
  'options=[normalize,zero,feather,shift,notaper]:options:(normalize zero feather shift notaper)' \
  '*:image:_files' && ret=0

return ret
