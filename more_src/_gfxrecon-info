#compdef gfxrecon-info
# Documentation: https://vulkan.lunarg.com/doc/view/latest/linux/capture_tools.html
# gfxrecon-info - print information describing GFXReconstruct capture files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage information]' \
  '--version[print version information]' \
  '*:capture file:_files' && ret=0

return ret
