#compdef chatblade
# Documentation: https://github.com/npiv/chatblade
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# npiv/chatblade - CLI Swiss Army Knife for ChatGPT

_arguments -s -S \
  '*:query text:_default' \
  '--openai-api-key=[API key]:key:' \
  '--openai-base-url=[OpenAI-compatible base URL]:url:_urls' \
  '--temperature=[sampling temperature]:float:' \
  '(-c --chat-gpt)'{-c,--chat-gpt}'=[model name or alias 3.5 4 4t 4o mini o1 o1mini]:model:' \
  '(-i --interactive)'{-i,--interactive}'[REPL session]' \
  '(-s --stream)'{-s,--stream}'[stream tokens]' \
  '(-t --tokens)'{-t,--tokens}'[estimate tokens/cost only]' \
  '--version[show version]' \
  '(-p --prompt-file)'{-p,--prompt-file}'=[prompt name or file path]:file:_files' \
  '(-e --extract)'{-e,--extract}'[extract JSON or fenced code]' \
  '(-r --raw)'{-r,--raw}'[plain text output]' \
  '(-n --no-format)'{-n,--no-format}'[disable pretty formatting]' \
  '(-o --only)'{-o,--only}'[print assistant reply only]' \
  '--theme=[Pygments style]:theme:' \
  '(-l --last)'{-l,--last}'[use scratch session]' \
  '(-S --session)'{-S,--session}'=[named session]:session:' \
  '--session-list[list sessions]' \
  '--session-path[print session file path]' \
  '--session-dump[dump session JSON]' \
  '--session-delete[delete session]' \
  '--session-rename=[rename session to]:newname:' \
  '--debug[hidden debug]'
