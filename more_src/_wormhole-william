#compdef wormhole-william

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'send:Send a file, directory, or text'
      'receive:Receive a file, directory, or text'
      'recv:Receive a file, directory, or text'
    )
    _describe -t commands 'wormhole-william command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      send)
        _arguments -s -S \
          '--code=[use a specific wormhole code]:code' \
          '--code-length=[length of generated code words]:length' \
          '--verify[display verification string]' \
          '--hide-progress[hide progress bar]' \
          '--relay-url=[relay server URL]:url' \
          '--transit-helper=[transit relay URL]:url' \
          '-text[send text instead of a file]' \
          '--text[send text instead of a file]' \
          '*:file to send:_files' && ret=0
        ;;
      receive|recv)
        _arguments -s -S \
          '--code=[wormhole code to receive]:code' \
          '--verify[display verification string]' \
          '--hide-progress[hide progress bar]' \
          '--relay-url=[relay server URL]:url' \
          '--transit-helper=[transit relay URL]:url' \
          '--output-file=[output file path]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
