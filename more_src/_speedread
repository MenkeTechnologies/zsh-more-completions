#compdef speedread
# Documentation: https://man.archlinux.org/search?q=speedread
# Reference accessed: 2026-05-16

# Zsh completion for speedread (RSVP reader)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-w --wpm)'{-w,--wpm}'[words per minute]:wpm' \
  '1:file:_files' && ret=0

return ret
