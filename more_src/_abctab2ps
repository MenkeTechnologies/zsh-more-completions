#compdef abctab2ps
# Documentation: https://github.com/cdalitz/abctab2ps (doc/manpages/abctab2ps.1)
# Typeset ABC music and lute tablature to PostScript

local ret=1

_arguments -s -S \
  '(-h)-h[quick help and default settings]' \
  '-1[write every tune on a separate page]' \
  '-a[set maximal permitted shrinking (0..1)]:alfa:' \
  '-b[break at all line ends]' \
  '-B[try to typeset N bars per line]:barsperline:' \
  '-c[treat input as one long line]' \
  '-d[set staff distance]:distance:' \
  '-D[look for format files in directory]:fmtdir:_files -/' \
  '-e[typeset only tunes matching xref selectors]:selectors:' \
  '-R[search the rhythm field]:selectors:' \
  '-C[search the composer field]:selectors:' \
  '-S[search the source field]:selectors:' \
  '-T[search the title field]:selectors:' \
  '-E[make EPSF output, one file per tune]' \
  '-f[set the input file]:infile:_files -g "*.abc"' \
  '-F[read format from file]:formatfile:_files -g "*.fmt"' \
  '-g[set glue mode]:mode:(shrink space stretch fill)' \
  '-H[show the default format parameters]' \
  '-I[write index file Ind.ps]' \
  '-k[number every N bars (0 = first bar per staff)]:nbars:' \
  '-l[print in landscape mode]' \
  '-m[set the left margin]:margin:' \
  '-maxs[obsolete memory allocation option]:nsymbols:' \
  '-maxv[obsolete memory allocation option]:nvoices:' \
  '-noauthor[suppress the %%For author DSC comment]' \
  '-notab[suppress all tablature routines and fonts]' \
  '-nofrenchtab[do not include the french tab font]' \
  '-noitaliantab[do not include the italian tab font]' \
  '-nogermantab[do not include the german tab font]' \
  '-n[include historical notes at bottom of each tune]' \
  '-N[write page numbers]' \
  '-o[obsolete, ignored]' \
  '-O[write output to outfile.ps (= derives from input)]:outfile:_files' \
  '-p[generate pretty output]' \
  '-P[another pretty output format]' \
  '-paper[set paper format]:format:(a4 letter)' \
  '-s[scale music output by factor]:scale:' \
  '-t[transpose all music]:transposition:' \
  '-tabsize[set tablature font size]:fontsize:' \
  '-transposegchords[transpose guitar chords too]' \
  '-v[set screen output verbosity]:verbosity:' \
  '-V[select specified voices, e.g. 1,4-5]:voices:' \
  '-w[set staff width]:width:' \
  '-x[include xref numbers in tune title]' \
  '-X[set note-spacing strictness (0..1)]:strictness:' \
  '*:abc file:_files -g "*.abc"' && ret=0

return ret
