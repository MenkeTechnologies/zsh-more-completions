#compdef hgSpeciesRna
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: create a fasta file with RNA from one species

local ret=1

_arguments -s -S \
  '-est[get ESTs rather than mRNAs]' \
  '-filter=[only read accessions listed in file]:file:_files' \
  '1:database:' \
  '2:Genus:' \
  '3:species:' \
  '4:output fasta:_files' && ret=0

return ret
