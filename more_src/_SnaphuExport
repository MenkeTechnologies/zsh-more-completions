#compdef SnaphuExport
# Documentation: https://github.com/senbox-org/s1tbx/blob/master/jlinda/jlinda-nest/src/main/java/org/jlinda/nest/dataio/SnaphuExportOp.java
# ESA SNAP gpt SnaphuExport operator - export interferogram for SNAPHU unwrapping

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show operator help]' \
  '-e[show detailed error messages with stack trace]' \
  '-t+[set target output file]:target:_files' \
  '-f+[set output file format]:format:(GeoTIFF GeoTIFF-BigTIFF HDF5 BEAM-DIMAP NetCDF4-CF)' \
  '-p+[read processing parameters from file]:param file:_files' \
  '-c+[set tile cache size in bytes]:size' \
  '-q+[set maximum parallelism]:threads' \
  '-x[clear internal tile cache after each tile row]' \
  '*-S-[define a source product location]:source=file:_files' \
  '*-D-[define a system property]:name=value' \
  '-PtargetFolder=-[output folder for the SNAPHU export]:folder:_files -/' \
  '-PstatCostMode=-[statistical-cost mode]:mode:(TOPO DEFO SMOOTH NOSTATCOSTS)' \
  '-PinitMethod=-[wrapped-phase initialization algorithm]:method:(MST MCF)' \
  '-PnumberOfTileRows=-[number of tile rows]:rows' \
  '-PnumberOfTileCols=-[number of tile columns]:cols' \
  '-PnumberOfProcessors=-[number of concurrent processing threads]:n' \
  '-ProwOverlap=-[overlap in pixels between neighboring tiles (rows)]:pixels' \
  '-PcolOverlap=-[overlap in pixels between neighboring tiles (cols)]:pixels' \
  '-PtileCostThreshold=-[cost threshold for reliable-region boundaries]:threshold' \
  '*:source product:_files' && ret=0

return ret
