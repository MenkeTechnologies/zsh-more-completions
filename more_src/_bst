#compdef bst
# Source: https://github.com/apache/buildstream/blob/5349c6c84b23c31fcaee98a2e6101a0aa2668258/src/buildstream/data/zsh/_bst
# Repository: apache/buildstream (src/buildstream/data/zsh/_bst)
_bst_cmpl() {
    local idx completions name
    idx="${#words[@]}"
    # ZSH arrays start at 1
    let idx=idx-1
    completions=( $( env COMP_WORDS="$words" \
                     COMP_CWORD=$idx \
                     _BST_COMPLETION=complete bst ) )
    for name in ${completions[@]}; do
        # For items that are an incomplete path, do not add trailing space
        if [[ $name = */ ]]; then
            compadd -S '' $name
        else
            A=($name)
            compadd -a A
        fi
    done
    return 0
}
_bst_cmpl "$@"
