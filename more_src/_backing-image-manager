#compdef backing-image-manager
# _backing-image-manager — Longhorn backing-image cache + sync server (longhorn/backing-image-manager)
# upstream: https://github.com/longhorn/backing-image-manager
# Flags from main.go + app/cmd/start.go (urfave/cli v1) on tip.

_backing-image-manager() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print version and exit]' \
        '--debug[enable debug logging]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                daemon:'run the backing-image-manager daemon'
                backing-image:'manage backing images'
                data-source:'run/inspect a backing-image data source'
            )
            _describe -t commands 'backing-image-manager command' cmds
            ;;
        args)
            case $words[1] in
                daemon)
                    _arguments \
                        '--listen=[gRPC listen address]:host\:port:' \
                        '--sync-listen=[HTTP sync server address]:host\:port:' \
                        '--disk-uuid=[disk UUID to bind to]:uuid:' \
                        '--port-range=[allowed sync server port range]:range:'
                    ;;
            esac
            ;;
    esac
}

_backing-image-manager "$@"
