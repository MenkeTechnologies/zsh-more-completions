#compdef rnaalifold
# Documentation: https://man.archlinux.org/search?q=rnaalifold
# Reference accessed: 2026-05-16

# ViennaRNA RNAalifold: consensus secondary structure for RNA alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-r --ribosum)'{-r,--ribosum}'[use RIBOSUM scoring matrix]' \
  '(-p --partfunc)'{-p,--partfunc}'[compute partition function]' \
  '--MEA=[maximum expected accuracy structure]:gamma:' \
  '--mis[output minimum information score consensus]' \
  '(-T --temp)'{-T,--temp=}'[temperature in C]:temp:' \
  '(-d --dangles)'{-d,--dangles=}'[dangling end model]:d:(0 1 2 3)' \
  '(-c --circ)'{-c,--circ}'[circular RNA]' \
  '--cfactor=[cov term weight]:val:' \
  '--nfactor=[non-cov penalty weight]:val:' \
  '--paramFile=[parameter file]:file:_files' \
  '--color[colour structure plot]' \
  '--aln[print mountain plot of alignment]' \
  '--aln-EPS[generate EPS alignment plot]' \
  '--aln-stk[output alignment in Stockholm format]' \
  '--auto-id[auto-generate sequence IDs]' \
  '*:RNA alignment file:_files -g "*.(stk|sto|aln|fa|fasta)"' && ret=0
return ret
