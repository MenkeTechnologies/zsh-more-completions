#compdef distrobox
# Documentation: https://github.com/89luca89/distrobox/blob/main/docs/usage/usage.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a container'
  'enter:enter a container'
  'list:list containers'
  'ls:list containers'
  'rm:remove containers'
  'stop:stop containers'
  'upgrade:upgrade containers'
  'ephemeral:run ephemeral container'
  'assemble:assemble from manifest'
  'generate-entry:generate desktop entry'
  'host-exec:execute host command from container'
  'export:export apps to host'
  'init:init inside container'
  'init-hooks:run init hooks'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--verbose[verbose]' \
  '*-v[verbose]' \
  '*--root[run as root]' \
  '*-r[run as root]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'distrobox command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '(--image -i)'{-i+,--image=}'[image]:img:' \
          '(--name -n)'{-n+,--name=}'[name]:n:' \
          '(--hostname)--hostname=[hostname]:h:_hosts' \
          '(--pull -p)'{-p,--pull}'[pull image]' \
          '(--yes -Y)'{-Y,--yes}'[non-interactive]' \
          '(--no-entry -ne)'{-ne,--no-entry}'[no menu entry]' \
          '(--clone -c)'{-c+,--clone=}'[clone container]:c:' \
          '(--root)--root[run as root]' \
          '(--init -I)'{-I,--init}'[run as init]' \
          '(--nvidia)--nvidia[NVIDIA support]' \
          '(--unshare-netns)--unshare-netns[unshare netns]' \
          '(--unshare-process)--unshare-process[unshare PID ns]' \
          '(--unshare-devsys)--unshare-devsys[unshare /dev,/sys]' \
          '(--unshare-ipc)--unshare-ipc[unshare IPC]' \
          '(--unshare-all)--unshare-all[unshare all]' \
          '(--home -H)'{-H+,--home=}'[home dir]:dir:_files -/' \
          '(--volume)*--volume=[volume]:v:' \
          '(--additional-flags -a)'{-a+,--additional-flags=}'[additional flags]:f:' \
          '(--additional-packages -ap)'{-ap+,--additional-packages=}'[extra packages]:p:' \
          '(--init-hooks -i)'{-i+,--init-hooks=}'[init hooks]:cmds:' \
          '(--pre-init-hooks -prh)'{-prh+,--pre-init-hooks=}'[pre-init hooks]:cmds:' \
          '(--dry-run -d)'{-d,--dry-run}'[dry run]' \
          '(--absolutely-disable-root-password-i-am-really-positively-sure)--absolutely-disable-root-password-i-am-really-positively-sure[disable root pass]' \
          '*: :' && ret=0 ;;
      (enter)
        _arguments \
          '(--name -n)'{-n+,--name=}'[name]:n:' \
          '(--root -r)'{-r,--root}'[root]' \
          '(--clean-path)--clean-path[clean PATH]' \
          '(--no-tty -T)'{-T,--no-tty}'[no TTY]' \
          '(--no-workdir -nw)'{-nw,--no-workdir}'[no workdir]' \
          '(--additional-flags -a)'{-a+,--additional-flags=}'[flags]:f:' \
          '(--dry-run -d)'{-d,--dry-run}'[dry run]' \
          '*: :' && ret=0 ;;
      (rm)
        _arguments \
          '(--name -n)'{-n+,--name=}'[name]:n:' \
          '(--force -f)'{-f,--force}'[force]' \
          '(--yes -Y)'{-Y,--yes}'[yes]' \
          '(--rm-home)--rm-home[remove home dir]' \
          '*: :' && ret=0 ;;
      (stop)
        _arguments \
          '(--name -n)'{-n+,--name=}'[name]:n:' \
          '(--yes -Y)'{-Y,--yes}'[yes]' \
          '*: :' && ret=0 ;;
      (export)
        _arguments \
          '(--app -a)'{-a+,--app=}'[app name]:app:' \
          '(--bin -b)'{-b+,--bin=}'[bin name]:bin:' \
          '(--service -s)'{-s+,--service=}'[service]:s:' \
          '(--delete -d)'{-d,--delete}'[delete]' \
          '(--export-path -ep)'{-ep+,--export-path=}'[export path]:dir:_files -/' \
          '(--export-label -el)'{-el+,--export-label=}'[label]:l:' \
          '(--extra-flags -ef)'{-ef+,--extra-flags=}'[extra flags]:f:' \
          '*: :' && ret=0 ;;
      (upgrade)
        _arguments \
          '(--all -a)'{-a,--all}'[all]' \
          '(--name -n)*'{-n+,--name=}'[name]:n:' \
          '*: :' && ret=0 ;;
      (ephemeral)
        _arguments \
          '(--root -r)'{-r,--root}'[root]' \
          '(--image -i)'{-i+,--image=}'[image]:img:' \
          '(--init-hooks -ih)'{-ih+,--init-hooks=}'[init hooks]:cmds:' \
          '(--additional-packages -ap)'{-ap+,--additional-packages=}'[extra pkgs]:p:' \
          '*: :' && ret=0 ;;
      (assemble)
        _arguments \
          '1:subcommand:(create rm)' \
          '(--file -f)'{-f+,--file=}'[manifest file]:file:_files' \
          '(--name -n)'{-n+,--name=}'[name]:n:' \
          '(--replace -R)'{-R,--replace}'[replace]' \
          '*: :' && ret=0 ;;
      (list|ls)
        _arguments \
          '(--no-color -nc)'{-nc,--no-color}'[no color]' \
          '(--root -r)'{-r,--root}'[root]' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
