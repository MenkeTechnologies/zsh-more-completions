#compdef smbpasswd-cli
# _smbpasswd-cli — Samba smbpasswd change Samba user password CLI alias (samba team, C); custom argparse
# upstream: https://github.com/samba-team/samba

_smbpasswd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[add user]' \
        '-c+[config file]:file:_files -g "smb.conf"' \
        '-x[delete user]' \
        '-d[disable user]' \
        '-e[enable user]' \
        '-i[interdomain trust account]' \
        '-l+[log basename]:str:' \
        '-n[set null password]' \
        '-r+[remote machine]:host:_hosts' \
        '-R+[name resolve order]:str:' \
        '-s[silent]' \
        '-U+[username]:_users' \
        '-D+[debug level]:n:' \
        '-m[machine account]' \
        '-w+[pdb file password]:str:' \
        '-W+[ldap password]:str:' \
        '*:username:_users'
}

_smbpasswd-cli "$@"
