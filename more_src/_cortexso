#compdef cortexso
# Documentation: https://github.com/janhq/cortex.cpp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cortexso (alias for cortex / cortex.cpp) - local AI / LLM platform from Jan AI.
# Common subcommands: start, pull, run, ps, stop, models, engines, hardware.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start the cortex server'
  'stop:stop the cortex server'
  'pull:download a model from Hugging Face / cortexso hub'
  'run:run a model (use -d for detached)'
  'ps:list running models'
  'models:manage models'
  'engines:manage inference engines'
  'hardware:detect or activate hardware acceleration'
  'update:update cortex'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'cortexso command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run|pull) _arguments '-d[run detached]' '*:model:' && ret=0 ;;
    esac ;;
esac

return ret
