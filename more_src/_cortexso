#compdef cortexso
# Documentation: https://man.archlinux.org/search?q=cortexso
# Reference accessed: 2026-05-16

# cortexso / cortex CLI — thin wrapper; see `cortexso --help` if installed.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '*:args:_default' && ret=0

return ret
