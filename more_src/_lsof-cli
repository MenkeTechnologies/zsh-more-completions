#compdef lsof-cli
# _lsof-cli — Vic Abell lsof list open files CLI alias (lsof-org team, C); custom argparse
# upstream: https://github.com/lsof-org/lsof

_lsof-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-a[and-mode for selectors]' \
        '-b[avoid blocking calls]' \
        '-c+[command pattern]:str:' \
        '-d+[fd range]:str:' \
        '-D+[directory operation]:d:(a u r b f k i)' \
        '-E[show file descriptor sockets]' \
        '-F+[fields output]:str:' \
        '-f[follow]' \
        '-G[show flags]' \
        '-g+[pgid]:n:' \
        '-i+[internet selector]:str:' \
        '-K+[task list]:str:' \
        '-k+[kernel file]:file:_files' \
        '-l[no convert UIDs to login names]' \
        '-m+[memory map file]:file:_files' \
        '-N[NFS files]' \
        '-n[no convert addresses to names]' \
        '-O[avoid expensive operations]' \
        '-o+[output offset width]:n:' \
        '-P[no convert port numbers to names]' \
        '-p+[pid]:pid:_pids' \
        '-Q[output errors only when -s_size]' \
        '-q[do not warn if some files cant be examined]' \
        '-R[show parent PID]' \
        '-r+[repeat seconds]:n:' \
        '-s+[size or family]:str:' \
        '-S+[avoid blocking timeout seconds]:n:' \
        '-T+[TCP fields]:str:' \
        '-t[terse output (PIDs only)]' \
        '-U[show unix sockets]' \
        '-u+[user]:_users' \
        '-V[show errors if no files matched]' \
        '-w[suppress warnings]' \
        '-X[skip cross over]' \
        '-x[follow symlinks]' \
        '-Z+[selinux context]:str:' \
        '+c+[command width]:n:' \
        '+d+[directory]:dir:_files -/' \
        '+D+[directory recursive]:dir:_files -/' \
        '+E[verbose endpoint reporting]' \
        '+f+[file open flags]:str:' \
        '+L+[link count]:n:' \
        '+m+[map file output]:file:_files' \
        '+M[disable extras]' \
        '+r+[repeat with no output]:n:' \
        '+w[issue warnings]' \
        '*:file or path:_files'
}

_lsof-cli "$@"
