#compdef succepstrum
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/succepstrum.c
# Compute the complex CEPSTRUM of a seismic trace

local ret=1

_arguments -s -S \
  'sign1=[sign1]:sign1:' \
  'sign2=[sign2]:sign2:' \
  'mode=[mode]:mode:' \
  'unwrap=[unwrap]:unwrap:' \
  'trend=[trend]:trend:' \
  'zeromean=[zeromean]:zeromean:' \
  'dphase=[dphase]:dphase:' \
  'phase=[phase]:phase:' \
  '*:file:_files' && ret=0

return ret
