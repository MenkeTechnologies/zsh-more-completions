#compdef brillo

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-A[increase brightness]:percent' \
  '-U[decrease brightness]:percent' \
  '-S[set brightness]:percent' \
  '-G[get brightness]' \
  '-O[store current brightness]' \
  '-I[restore stored brightness]' \
  '-L[list available devices]' \
  '-s=[device type]:type:(backlight keyboard leds)' \
  '-k=[specific device]:device' \
  '-e[set minimum brightness cap]:percent' \
  '-c[commit changes]' \
  '-r[use raw values]' \
  '-q[quiet output]' \
  '-u[use microseconds for transitions]:microseconds' && ret=0

return ret
