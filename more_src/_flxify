#compdef flxify
# Documentation: https://www.npmjs.com/package/@flxify/cli
# Reference accessed: 2026-05-23
# Verified: npm package @flxify/cli options.

# Zsh completion for flxify - terminal text transformation utility

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-t --theme)'{-t+,--theme=}'[theme on startup]:theme:(standard-dark standard-light cyber-neon nordic-frost monokai-pro stealth)' \
  '[file]:file:_files' && ret=0

return ret
