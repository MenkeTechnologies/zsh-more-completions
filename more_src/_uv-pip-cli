#compdef uv
# Documentation: https://man.archlinux.org/search?q=uv
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add deps to pyproject.toml'
  'build:build distributions'
  'cache:manage uv cache'
  'export:export lockfile to requirements format'
  'generate-shell-completion:print shell completion'
  'help:show help'
  'init:initialize a project'
  'lock:create or update lockfile'
  'pip:pip-compatible interface'
  'publish:upload distributions'
  'python:manage Python installations'
  'remove:remove deps from pyproject.toml'
  'run:run a command in project env'
  'self:manage uv itself'
  'sync:sync env to lockfile'
  'tool:run/install standalone tools'
  'tree:show dependency tree'
  'venv:create a virtualenv'
  'version:show or update package version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-q[quiet]' \
  '*--quiet[quiet]' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '*--color=[color mode]:m:(auto always never)' \
  '*--native-tls[use native TLS]' \
  '*--offline[offline]' \
  '*--no-progress[disable progress bars]' \
  '*--no-cache[bypass cache]' \
  '*--cache-dir=[cache dir]:dir:_files -/' \
  '*--config-file=[config file]:file:_files -g "*.toml"' \
  '*--no-config[skip config]' \
  '*--directory=[change to directory]:dir:_files -/' \
  '*--project=[project dir]:dir:_files -/' \
  '*--isolated[isolated mode]' \
  '*--preview[enable preview features]' \
  '*--python-fetch=[Python fetch policy]:p:(automatic manual never)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'uv command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (pip)
        local -a pipsubs
        pipsubs=(
          'install:install packages'
          'uninstall:uninstall packages'
          'sync:sync env to requirements'
          'list:list installed packages'
          'show:show package info'
          'tree:show dependency tree'
          'check:verify env compatibility'
          'freeze:freeze installed packages'
          'compile:compile requirements file'
        )
        _arguments -C \
          '1: :->pipcmd' \
          '*::arg:->piparg' && ret=0
        case $state in
          (pipcmd) _describe -t cmds 'uv pip command' pipsubs && ret=0 ;;
          (piparg)
            case $line[1] in
              (install)
                _arguments \
                  '(-r --requirement)*'{-r+,--requirement=}'[requirements file]:file:_files -g "*.txt *.in"' \
                  '(-c --constraint)*'{-c+,--constraint=}'[constraints]:file:_files' \
                  '(-e --editable)*'{-e+,--editable=}'[editable]:dir:_files -/' \
                  '--upgrade[upgrade all]' \
                  '-U[upgrade]' \
                  '-P+[upgrade package]:p:' \
                  '--upgrade-package=[upgrade package]:p:' \
                  '--reinstall[reinstall all]' \
                  '--reinstall-package=[reinstall package]:p:' \
                  '--no-deps[no deps]' \
                  '--no-build[no build]' \
                  '--no-build-isolation[no build isolation]' \
                  '--no-binary=[no binary for package]:p:' \
                  '--only-binary=[only binary for package]:p:' \
                  '--prefer-binary[prefer binary]' \
                  '--strict[strict resolver]' \
                  '--break-system-packages[allow break system pkgs]' \
                  '--target=[target dir]:dir:_files -/' \
                  '--prefix=[prefix dir]:dir:_files -/' \
                  '--user[user install]' \
                  '--system[system install]' \
                  '--python=[python interpreter]:py:' \
                  '--python-version=[python version]:v:' \
                  '--python-platform=[python platform]:p:' \
                  '--index=[index url]:url:' \
                  '--extra-index-url=[extra index url]:url:' \
                  '--default-index=[default index url]:url:' \
                  '--index-strategy=[index strategy]:s:(first-index unsafe-first-match unsafe-best-match)' \
                  '--keyring-provider=[keyring provider]:p:(disabled subprocess)' \
                  '--resolution=[resolution]:r:(highest lowest lowest-direct)' \
                  '--prerelease=[prerelease]:p:(disallow allow if-necessary explicit if-necessary-or-explicit)' \
                  '--exclude-newer=[exclude newer than]:date:' \
                  '--link-mode=[link mode]:m:(clone copy hardlink symlink)' \
                  '--compile-bytecode[compile bytecode]' \
                  '--no-config[no config]' \
                  '--require-hashes[require hashes]' \
                  '--verify-hashes[verify hashes]' \
                  '--allow-empty-requirements[allow empty]' \
                  '--dry-run[dry run]' \
                  '*: :' && ret=0 ;;
              (uninstall)
                _arguments \
                  '(-r --requirement)*'{-r+,--requirement=}'[requirements file]:file:_files' \
                  '--target=[target dir]:dir:_files -/' \
                  '--prefix=[prefix dir]:dir:_files -/' \
                  '--python=[python]:py:' \
                  '--system[system]' \
                  '*:package:' && ret=0 ;;
              (compile)
                _arguments \
                  '(-o --output-file)'{-o+,--output-file=}'[output file]:file:_files' \
                  '(-c --constraint)*'{-c+,--constraint=}'[constraints]:file:_files' \
                  '--all-extras[all extras]' \
                  '--no-emit-package=[no emit pkg]:p:' \
                  '--no-strip-extras[no strip extras]' \
                  '--no-strip-markers[no strip markers]' \
                  '--no-annotate[no annotate]' \
                  '--no-header[no header]' \
                  '--annotation-style=[annotation style]:s:(line split)' \
                  '--upgrade[upgrade all]' \
                  '-U[upgrade]' \
                  '--upgrade-package=[upgrade pkg]:p:' \
                  '--generate-hashes[generate hashes]' \
                  '--allow-unsafe[allow unsafe]' \
                  '--no-build-isolation[no build isolation]' \
                  '--python-version=[python version]:v:' \
                  '--exclude-newer=[exclude newer than]:date:' \
                  '*: :_files -g "*.in *.txt"' && ret=0 ;;
              (list|freeze)
                _arguments \
                  '(-f --format)'{-f+,--format=}'[output format]:f:(columns freeze json)' \
                  '--system[system]' \
                  '--editable[only editable]' \
                  '--exclude-editable[exclude editable]' \
                  '--strict[strict]' \
                  '--python=[python]:py:' \
                  '*: :' && ret=0 ;;
              (sync)
                _arguments \
                  '(-r --requirement)*'{-r+,--requirement=}'[requirements file]:file:_files' \
                  '--reinstall[reinstall]' \
                  '--strict[strict]' \
                  '--break-system-packages[break system pkgs]' \
                  '--target=[target]:dir:_files -/' \
                  '--prefix=[prefix]:dir:_files -/' \
                  '--python=[python]:py:' \
                  '--system[system]' \
                  '*: :_files' && ret=0 ;;
              (*) _files ;;
            esac ;;
        esac ;;
      (run)
        _arguments \
          '(--with)*--with=[extra dep]:p:' \
          '(--with-editable)*--with-editable=[editable dep]:dir:_files -/' \
          '(--with-requirements)*--with-requirements=[req file]:file:_files' \
          '(--no-project)--no-project[no project]' \
          '(--locked)--locked[locked]' \
          '(--frozen)--frozen[frozen]' \
          '(--all-extras)--all-extras[all extras]' \
          '(--extra)*--extra=[extra]:e:' \
          '(--no-extra)*--no-extra=[no extra]:e:' \
          '(--reinstall)--reinstall[reinstall]' \
          '(--upgrade)--upgrade[upgrade]' \
          '(-U)-U[upgrade]' \
          '(--no-sync)--no-sync[no sync]' \
          '(--isolated)--isolated[isolated]' \
          '(--package)--package=[package]:p:' \
          '(--script)--script[script]' \
          '(--module -m)*'{-m+,--module=}'[python module]:m:' \
          '(--python -p)*'{-p+,--python=}'[python]:py:' \
          '*: :_command_names -e' && ret=0 ;;
      (sync)
        _arguments \
          '(--locked)--locked[locked]' \
          '(--frozen)--frozen[frozen]' \
          '(--no-install-project)--no-install-project[no install project]' \
          '(--no-install-workspace)--no-install-workspace[no install workspace]' \
          '(--no-install-package)*--no-install-package=[no install pkg]:p:' \
          '(--all-extras)--all-extras[all extras]' \
          '(--extra)*--extra=[extra]:e:' \
          '(--no-extra)*--no-extra=[no extra]:e:' \
          '(--package)--package=[package]:p:' \
          '(--reinstall)--reinstall[reinstall]' \
          '(--reinstall-package)*--reinstall-package=[reinstall pkg]:p:' \
          '(--upgrade)--upgrade[upgrade]' \
          '(-U)-U[upgrade]' \
          '(--upgrade-package)*--upgrade-package=[upgrade pkg]:p:' \
          '(--all-packages)--all-packages[all packages]' \
          '(--inexact)--inexact[inexact]' \
          '(--dry-run)--dry-run[dry run]' \
          '*: :' && ret=0 ;;
      (lock)
        _arguments \
          '(--upgrade)--upgrade[upgrade all]' \
          '(-U)-U[upgrade]' \
          '(--upgrade-package)*--upgrade-package=[upgrade pkg]:p:' \
          '(--no-build)--no-build[no build]' \
          '(--no-binary)--no-binary[no binary]' \
          '(--check)--check[check lock is up-to-date]' \
          '(--locked)--locked[locked]' \
          '(--frozen)--frozen[frozen]' \
          '*: :' && ret=0 ;;
      (init)
        _arguments \
          '(--name)--name=[project name]:n:' \
          '(--package)--package[create as package]' \
          '(--app)--app[application init]' \
          '(--lib)--lib[library init]' \
          '(--no-readme)--no-readme[no README]' \
          '(--no-pin-python)--no-pin-python[no pin python]' \
          '(--no-workspace)--no-workspace[no workspace]' \
          '(--vcs)--vcs=[vcs]:v:(git none)' \
          '(--build-backend)--build-backend=[backend]:b:(hatch flit pdm setuptools maturin scikit)' \
          '(--no-readme)--no-readme[no readme]' \
          '*: :_files -/' && ret=0 ;;
      (add|remove)
        _arguments \
          '(--dev)--dev[dev dependency]' \
          '(--optional)--optional=[optional group]:g:' \
          '(--group)--group=[dependency group]:g:' \
          '(--editable)--editable[editable]' \
          '(--raw-sources)--raw-sources[raw sources]' \
          '(--rev)--rev=[git rev]:r:' \
          '(--tag)--tag=[git tag]:t:' \
          '(--branch)--branch=[git branch]:b:' \
          '(--extra)*--extra=[extra]:e:' \
          '(--package)--package=[package]:p:' \
          '(--no-sync)--no-sync[no sync]' \
          '(--locked)--locked[locked]' \
          '(--frozen)--frozen[frozen]' \
          '*:package:' && ret=0 ;;
      (tool)
        _arguments \
          '1:subcommand:(run install upgrade list uninstall update-shell dir)' \
          '*: :' && ret=0 ;;
      (python)
        _arguments \
          '1:subcommand:(list install uninstall pin find dir)' \
          '*: :' && ret=0 ;;
      (cache)
        _arguments \
          '1:subcommand:(clean prune dir)' \
          '*: :' && ret=0 ;;
      (self)
        _arguments \
          '1:subcommand:(update version)' \
          '*: :' && ret=0 ;;
      (venv)
        _arguments \
          '(--python -p)'{-p+,--python=}'[python]:py:' \
          '(--seed)--seed[install pip in venv]' \
          '(--allow-existing)--allow-existing[allow existing]' \
          '(--prompt)--prompt=[prompt name]:p:' \
          '(--system-site-packages)--system-site-packages[use system site-packages]' \
          '(--relocatable)--relocatable[relocatable]' \
          '(--link-mode)--link-mode=[link mode]:m:(clone copy hardlink symlink)' \
          '*: :_files -/' && ret=0 ;;
      (build)
        _arguments \
          '(--package)--package=[package]:p:' \
          '(--all-packages)--all-packages[all packages]' \
          '(--out-dir -o)'{-o+,--out-dir=}'[output dir]:dir:_files -/' \
          '(--sdist)--sdist[sdist only]' \
          '(--wheel)--wheel[wheel only]' \
          '(--no-build-isolation)--no-build-isolation[no build isolation]' \
          '(--no-build-logs)--no-build-logs[no build logs]' \
          '*: :_files' && ret=0 ;;
      (publish)
        _arguments \
          '(--publish-url)--publish-url=[publish URL]:url:' \
          '(--username -u)'{-u+,--username=}'[username]:u:' \
          '(--password -p)'{-p+,--password=}'[password]:p:' \
          '(--keyring-provider)--keyring-provider=[keyring]:p:(disabled subprocess)' \
          '(--token)--token=[token]:t:' \
          '(--trusted-publishing)--trusted-publishing=[trusted publishing]:t:(automatic always never)' \
          '*: :_files' && ret=0 ;;
      (export)
        _arguments \
          '(--format)--format=[format]:f:(requirements-txt pylock.toml)' \
          '(--output-file -o)'{-o+,--output-file=}'[output]:file:_files' \
          '(--no-emit-package)*--no-emit-package=[no emit pkg]:p:' \
          '(--no-emit-project)--no-emit-project[no emit project]' \
          '(--all-extras)--all-extras[all extras]' \
          '(--extra)*--extra=[extra]:e:' \
          '(--locked)--locked[locked]' \
          '(--frozen)--frozen[frozen]' \
          '(--package)--package=[package]:p:' \
          '*: :_files' && ret=0 ;;
      (tree)
        _arguments \
          '(--package)--package=[package]:p:' \
          '(--depth -d)'{-d+,--depth=}'[max depth]:n:' \
          '(--prune)*--prune=[prune package]:p:' \
          '(--invert)--invert[invert dependency tree]' \
          '(--locked)--locked[locked]' \
          '(--frozen)--frozen[frozen]' \
          '*: :' && ret=0 ;;
      (version)
        _arguments \
          '(--package)--package=[package]:p:' \
          '(--bump)--bump=[bump kind]:k:(major minor patch alpha beta rc post dev stable)' \
          '(--dry-run)--dry-run[dry run]' \
          '(--short)--short[short output]' \
          '(--output-format)--output-format=[format]:f:(json text)' \
          '*:version:' && ret=0 ;;
      (generate-shell-completion)
        _arguments '1:shell:(bash zsh fish powershell elvish nushell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
