#compdef dcb-maxrate
# Documentation: https://man.archlinux.org/man/dcb-maxrate.8.en
# dcb maxrate - manage traffic class maximum rate limiting

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'dcb maxrate command' \
      'show[display maxrate settings]' 'set[configure maxrate settings]' \
      'dev[network device]' 'tc-maxrate[traffic class maximum rates]' && ret=0
    ;;
esac

return ret
