#compdef diffoci
# Documentation: https://github.com/reproducible-containers/diffoci
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# reproducible-containers/diffoci — cobra CLI (cmd/diffoci)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'diff:compare two container images'
  'pull:pull image'
  'help:show help for a command'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug[enable debug output]' \
  '--platform=[platform (e.g. linux/amd64)]:platform:' \
  '--backend=[backend]:backend:(containerd local)' \
  '--containerd-address=[containerd socket]:path:_files' \
  '--containerd-namespace=[containerd namespace]:ns:' \
  '--semantic[non-strict comparison]' \
  '--report-dir=[dump conflicting files here]:dir:_files -/' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'diffoci command' commands && ret=0 ;;
esac

return ret
