#compdef esl-afetch
# Documentation: http://hmmer.org/documentation.html
# Easel: retrieve alignments from a multi-MSA database

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-f[interpret second argument as a keyfile for batch retrieval]' \
  '-o+[output retrieved alignments to file]:file:_files' \
  '-O[output to a file named after the key being fetched]' \
  '--index[create an SSI index of names and accessions in the msafile]' \
  '*:msa file:_files' && ret=0

return ret
