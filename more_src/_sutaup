#compdef sutaup
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/sutaup.c
# forward and inverse T-X and F-K global slant stacks

local ret=1

_arguments -s -S \
  'option=[option]:option:' \
  'dt=[dt]:dt:' \
  'nx=[nx]:nx:' \
  'dx=[dx]:dx:' \
  'npoints=[npoints]:npoints:' \
  'pmin=[pmin]:pmin:' \
  'pmax=[pmax]:pmax:' \
  'np=[np]:np:' \
  'ntau=[ntau]:ntau:' \
  'fmin=[fmin]:fmin:' \
  'xmin=[xmin]:xmin:' \
  'verbose=[verbose]:verbose:' \
  'tmpdir=[tmpdir]:tmpdir:' \
  '*:file:_files' && ret=0

return ret
