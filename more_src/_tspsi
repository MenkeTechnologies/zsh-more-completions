#compdef tspsi
# _tspsi — TSDuck tspsi MPEG-2 transport-stream PSI/SI table extractor printing PAT CAT PMT NIT BAT SDT EIT TOT TDT and DVB descriptors in text or XML (tsduck team, C++); custom argparse
# upstream: https://github.com/tsduck/tsduck

_tspsi() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--version[show version]' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-a[all tables]' \
        '--all[all tables]' \
        '-o+[output file]:file:_files' \
        '--output-file=+[output file]:file:_files' \
        '--text-output=+[file]:file:_files' \
        '--xml-output=+[file]:file:_files' \
        '--json-output=+[file]:file:_files' \
        '--pid=+[pid csv]:str:' \
        '--no-cat[no CAT]' \
        '--no-pat[no PAT]' \
        '--no-pmt[no PMT]' \
        '--no-nit[no NIT]' \
        '--no-bat[no BAT]' \
        '--no-sdt[no SDT]' \
        '--no-eit[no EIT]' \
        '--no-tot[no TOT]' \
        '--no-tdt[no TDT]' \
        '--no-rst[no RST]' \
        '--no-rrt[no RRT]' \
        '--time-reference=+[r]:r:(system tdt utc local)' \
        '--default-charset=+[c]:str:' \
        '--display-charset[display charset]' \
        '--brief[brief output]' \
        '--full[full output]' \
        '--no-cas[no CAS]' \
        '--cas-vendor=+[v]:str:' \
        '-I+[input plugin]:p:(file null udp ip http https rist srt dektec dvb fork)' \
        '--input=+[input plugin]:p:(file null udp ip http https rist srt dektec dvb fork)' \
        '*:input ts file:_files -g "*.ts *.m2ts *.mpeg *.mpg"'
}

_tspsi "$@"
