#compdef solr-operator
# _solr-operator — Apache Solr Operator
# upstream: https://github.com/apache/solr-operator
# Flags from main.go on tip.

_solr-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--zk-operator=[use the Zookeeper operator + CRD]:bool:(true false)' \
        '--watch-namespaces=[comma-separated namespaces to watch (empty=all)]:csv:' \
        '--tls-skip-verify-server=[skip client verification of server TLS cert]:bool:(true false)' \
        '--tls-client-cert-path=[TLS client cert file]:file:_files' \
        '--tls-client-cert-key-path=[TLS client cert key file]:file:_files' \
        '--tls-ca-cert-path=[TLS CA cert file]:file:_files' \
        '--tls-watch-cert=[hot-reload TLS cert on update]:bool:(true false)' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_solr-operator "$@"
