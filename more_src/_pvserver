#compdef pvserver
# Documentation: https://docs.paraview.org/en/latest/UsersGuide/commandLineArguments.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ParaView pvserver: combined data + render server
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--enable-bt[stack-trace on crash]' \
  '--cslog=[ClientServerStream log file]:file:_files' \
  '--no-mpi[skip MPI initialization]' \
  '--mpi[initialize MPI regardless]' \
  '--use-mpi-ssend[use MPI_SSend instead of MPI_Send]' \
  '--hostname=[override hostname]:host:' \
  '--connect-id=[connect identifier]:n:' \
  '(-p --server-port)'{-p+,--server-port=}'[listen port]:n:' \
  '(-r --reverse-connection)'{-r,--reverse-connection}'[reverse client connection]' \
  '--client-host=[reverse client host]:host:' \
  '--force-offscreen-rendering[headless offscreen render windows]' \
  '--displays=[rendering display list]:list:' \
  '--displays-assignment-mode=[displays assignment mode]:mode:' \
  '*::options:_files' && ret=0
return ret
