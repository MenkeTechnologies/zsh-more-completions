#compdef pvserver

# ParaView pvserver: combined data + render server
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--server-port=[port to listen on]:n:' \
  '-sp=[port (alt form)]:n:' \
  '--client-host=[client host for reverse connection]:host:' \
  '-ch=[client host (alt)]:host:' \
  '--reverse-connection[reverse client connection]' \
  '-rc[reverse connection (alt)]' \
  '--displays[display list for distributed rendering]:list:' \
  '--enable-bt[backtrace on signal]' \
  '--force-offscreen-rendering[force OSMesa rendering]' \
  '--connect-id=[connect identifier]:id:' \
  '--use-offscreen-rendering[use offscreen rendering]' \
  '--multi-clients[allow multiple client connections]' \
  '--print-monitors[print monitor info and exit]' \
  '*::options:_files' && ret=0
return ret
