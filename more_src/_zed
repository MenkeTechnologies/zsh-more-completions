#compdef zed
# Documentation: https://zed.dev/docs/reference/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org search URL.
# Added verified: --diff, --user-data-dir, --zed.

local curcontext="$curcontext" state line ret=1

_arguments -S -A "-*" \
  '(-w --wait)'{-w,--wait}'[wait for all opened files to be closed before exit]' \
  '(-n --new)'{-n,--new}'[open paths in a new workspace window]' \
  '(-a --add)'{-a,--add}'[add paths to the currently focused workspace]' \
  '(-r --reuse)'{-r,--reuse}'[replace current window workspace with new paths]' \
  '--foreground[run Zed in the foreground with terminal attached]' \
  '--uninstall[remove Zed and all related files]' \
  '--diff[open diff view between OLD_PATH and NEW_PATH]:OLD_PATH:_files' \
  '--user-data-dir=[custom directory for user data]:dir:_files -/' \
  '--zed=[custom path to the Zed application]:path:_files' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:path:_files' && ret=0

return ret
