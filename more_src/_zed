#compdef zed

# Zsh completion for Zed editor

local curcontext="$curcontext" state line ret=1

_arguments -S -A "-*" \
  '(-w --wait)'{-w,--wait}'[wait for the files to be closed before exiting]' \
  '(-n --new)'{-n,--new}'[open in a new workspace window]' \
  '(-a --add)'{-a,--add}'[add path to the currently focused workspace]' \
  '(-r --reuse)'{-r,--reuse}'[reuse an existing window if the path is already open]' \
  '--foreground[start Zed with logs appearing in the terminal]' \
  '--uninstall[uninstall Zed and related files]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '*:path:_files' && ret=0

return ret
