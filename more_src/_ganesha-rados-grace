#compdef ganesha-rados-grace

# ganesha-rados-grace: manipulate Ceph RADOS-stored Ganesha grace database
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-c[Ceph config file]:file:_files' \
  '-p[RADOS pool name]:pool:' \
  '-n[Ceph user/client name]:name:' \
  '-N[RADOS namespace]:namespace:' \
  '-o[grace DB object name]:oid:' \
  '*:: :->cmd' && ret=0
case $state in
  cmd) _values 'subcommand' \
    'dump[show grace DB contents]' \
    'add[add nodeid to grace DB]' \
    'start[set N=current epoch, mark grace started]' \
    'join[join existing grace period]' \
    'lift[lift grace from nodeid]' \
    'remove[remove nodeid from grace DB]' \
    'enforce[mark a node enforce]' \
    'noenforce[clear a node enforce]' \
    'member[set node membership]' \
    'wait[wait for next grace]' ;;
esac
return ret
