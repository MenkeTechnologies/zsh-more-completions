#compdef ganesha-rados-grace
# Documentation: https://man.archlinux.org/search?q=ganesha-rados-grace
# Reference accessed: 2026-05-16

# ganesha-rados-grace: manage NFS-Ganesha grace period state via Ceph RADOS
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'dump:dump the grace database'
  'add:add a node to the cluster'
  'start:start grace period on node'
  'join:join an existing grace period'
  'lift:lift grace period for a node'
  'remove:remove a node from the cluster'
  'enforce:enforce grace for a node'
  'noenforce:disable enforce for a node'
  'member:test membership of a node'
)

_arguments -C \
  '(- *)-h[show help]' \
  '--cephconf=[ceph config file]:file:_files' \
  '--ns=[RADOS namespace]:ns:' \
  '--oid=[RADOS object id]:oid:' \
  '--pool=[RADOS pool]:pool:' \
  '--userid=[Ceph user id]:user:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'rados-grace command' commands && ret=0 ;;
esac
return ret
