#compdef spm_export_vocab
# Documentation: https://github.com/google/sentencepiece/blob/master/src/spm_export_vocab_main.cc
# SentencePiece vocabulary exporter

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model=[input model file name]:model:_files' \
  '--output=[output filename]:file:_files' \
  '--output_format=[output format: vocab pieces+scores, syms pieces+indices]:format:(vocab syms)' \
  '*:model file:_files' && ret=0

return ret
