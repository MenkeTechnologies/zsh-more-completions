#compdef force
# Documentation: https://github.com/ForceCLI/force
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# force: command-line interface to force.com (Salesforce)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:authenticate with Salesforce'
  'logout:remove saved authentication'
  'logins:list all stored logins'
  'active:view or set active account'
  'whoami:display current user'
  'query:execute SOQL'
  'bulk:Bulk API 1.0 operations'
  'bulk2:Bulk API 2.0 operations'
  'record:create/modify/view records'
  'export:fetch all source to a directory'
  'import:import source from a directory'
  'push:deploy metadata from a directory'
  'fetch:export specific artifacts'
  'create:create Apex class, trigger, page, component'
  'sobject:create/delete schema objects'
  'field:manage SObject fields'
  'describe:inspect objects and metadata'
  'apex:execute anonymous Apex'
  'test:run Apex tests'
  'log:fetch debug logs'
  'trace:manage trace flags'
  'rest:execute REST requests'
  'limits:display org limits'
  'apiversion:set API version'
  'version:display CLI version'
  'package:manage installed packages'
  'open:launch authenticated browser session'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'force command' commands && ret=0 ;;
  (args) _default && ret=0 ;;
esac

return ret
