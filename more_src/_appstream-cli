#compdef appstreamcli appstream-cli
# _appstream-cli — AppStream appstreamcli (manage / query the AppStream component metadata pool that powers software centers; search/get/refresh/install/install-foreign/validate/news-to-metainfo/compose/dump/status)
# upstream: https://github.com/ximion/appstream
# Subcommands from appstream tools/appstreamcli.c on tip.

_appstreamcli() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--no-color[disable color]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'appstreamcli command' \
                '(search:search components get:get component info what-provides:find providers of an interface dump:dump metadata refresh-cache:refresh system cache refresh:alias of refresh-cache validate:validate metainfo file install:install (uses package manager) install-foreign:install a foreign metainfo file news-to-metainfo:convert news file compose:compose metadata for a tree status:show daemon/pool status convert:convert metainfo formats put:put metainfo into a destination remove:remove metainfo from a destination check-syscompat:test compatibility os-info:show OS info)'
            ;;
        args)
            case $line[1] in
                search) _arguments '*:query:' ;;
                get|install) _arguments '1:component id:' ;;
                what-provides) _arguments '1:kind:(mediatype id codec font modalias dbus python2 python3 firmware library binary)' '2:value:' ;;
                validate|news-to-metainfo|convert) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_appstreamcli "$@"
