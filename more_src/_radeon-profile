#compdef radeon-profile
# _radeon-profile — Marek Kubas marazmista radeon-profile CLI Qt5 GUI application monitoring AMD ATI Radeon graphics card temperature voltage fan speed core memory clock-state-DPM-PowerPlay-profile-management-overclock-frequency-limit-setting for the radeon amdgpu kernel driver on Linux fglrx-legacy-driver mode (Marek Kubas team, C++); custom argparse
# upstream: https://github.com/marazmista/radeon-profile

_radeon-profile() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--no-tray[no tray icon]' \
        '--minimized[start minimized]' \
        '--config=+[file]:file:_files -g "*.conf *.cfg *.ini"' \
        '--gpu=+[card]:str:' \
        '--debug[debug]' \
        '--server[server mode]' \
        '--port=+[port]:n:' \
        '--client=+[host:port]:str:' \
        '*::'
}

_radeon-profile "$@"
