#compdef ksysguard
# Documentation: https://man.archlinux.org/search?q=ksysguard
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help-all[show all options]' \
  '--showprocesses[show process table only]' \
  '--display=[X display]:display:' \
  '*:tab_file:_files -g "*.sgrd"' && ret=0

return ret
