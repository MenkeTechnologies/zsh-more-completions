#compdef ksysguard
# Documentation: https://invent.kde.org/plasma/ksysguard/-/blob/master/gui/ksysguard.cpp
# Reference accessed: 2026-05-19
# Verified: upstream KDE ksysguard.cpp main() - aboutData.setupCommandLine
# only (standard KDE/Qt options); single optional positional worksheet
# argument. Removed from prior file: invented --help-all, --showprocesses,
# --display flags and bogus man.archlinux.org search URL.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '*:worksheet file:_files' && ret=0

return ret
