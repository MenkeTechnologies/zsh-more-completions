#compdef wizcli
# Documentation: https://man.archlinux.org/search?q=wizcli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'auth:authenticate to Wiz'
      'config:manage CLI config'
      'docker:container image scanning helpers'
      'iac:IaC scanning helpers'
      'directory:filesystem scanning helpers'
      'sast:SAST helpers'
      'version:print version'
    )
    _describe -t commands 'wizcli command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '--format=[output format]:format:(json table)' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
