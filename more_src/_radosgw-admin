#compdef radosgw-admin

local curcontext="$curcontext" state line ret=1
local -a categories actions

categories=(
  user subuser key bucket object bi bilog period realm zonegroup zone
  caps policy role role-policy lc gc reshard mdlog datalog
  topic restore quota metadata orphans log usage
  'global':"global quota commands"
)

_arguments -C \
  '(- *)--help[show help]' \
  '--uid=[user ID]:uid:' \
  '--bucket=[bucket name]:bucket:' \
  '--display-name=[user display name]:name:' \
  '--access-key=[S3 access key]:key:' \
  '--secret=[S3 secret key]:secret:' \
  '--gen-access-key[generate random access key]' \
  '--gen-secret[generate random secret]' \
  '--format=[output format]:format:(json xml)' \
  '--date=[date YYYY-MM-DD]:date:' \
  '--purge-data[also remove all user data]' \
  '--purge-objects[also remove all bucket objects]' \
  '--max-buckets=[max buckets per user]:n:' \
  '--admin[set admin flag]' \
  '--system[set system flag]' \
  '--pool=[RADOS pool]:pool:' \
  '--object=[object name]:obj:' \
  '--placement-id=[placement target]:id:' \
  '--storage-class=[storage class]:class:' \
  '--num-shards=[bucket index shards]:n:' \
  '--max-size=[max size]:bytes:' \
  '--max-objects=[max object count]:n:' \
  '--quota-scope=[quota scope]:scope:(user bucket)' \
  '--shard-id=[shard ID]:id:' \
  '--rgw-zone=[zone name]:zone:' \
  '--rgw-zonegroup=[zonegroup name]:zonegroup:' \
  '--rgw-realm=[realm name]:realm:' \
  '--rgw-region=[region name (deprecated)]:region:' \
  '--master[set as master in zone/zonegroup]' \
  '--default[set as default]' \
  '--read-only[mark as read-only]' \
  '--marker=[pagination marker]:marker:' \
  '--max-entries=[max entries]:n:' \
  '--start-marker=[start marker]:marker:' \
  '--end-marker=[end marker]:marker:' \
  '--source-zone=[source zone]:zone:' \
  '--metadata-key=[metadata key]:key:' \
  '--id=[ID]:id:' \
  '--start-date=[start date]:date:' \
  '--end-date=[end date]:date:' \
  '--show-log-entries=[show log entries]:flag:(true false)' \
  '--show-log-sum=[show log summary]:flag:(true false)' \
  '--bypass-gc[bypass garbage collector queue]' \
  '--inconsistent-index[allow inconsistent index for emergency]' \
  '--yes-i-really-mean-it[confirm dangerous op]' \
  '1: :->category' \
  '2: :->action' \
  '*::arg:->args' && ret=0

case $state in
  (category)
    _describe -t categories 'radosgw-admin category' categories && ret=0
    ;;
  (action)
    case $line[1] in
      (user)
        _values 'user action' create modify info rename rm suspend enable check stats list && ret=0
        ;;
      (subuser)
        _values 'subuser action' create modify rm && ret=0
        ;;
      (key)
        _values 'key action' create rm && ret=0
        ;;
      (bucket)
        _values 'bucket action' list 'limit check' link unlink chown stats rm check rewrite radoslist reshard 'sync disable' 'sync enable' 'logging list' 'logging info' 'logging flush' && ret=0
        ;;
      (object)
        _values 'object action' rm stat manifest unlink rewrite reindex expire && ret=0
        ;;
      (bi)
        _values 'bi action' get put list purge && ret=0
        ;;
      (bilog)
        _values 'bilog action' list trim && ret=0
        ;;
      (period)
        _values 'period action' delete get get-current pull push list update commit && ret=0
        ;;
      (realm)
        _values 'realm action' create rm get get-default list list-periods rename set default pull && ret=0
        ;;
      (zonegroup|zone)
        _values 'zg/zone action' create delete get modify list rename remove add default placement && ret=0
        ;;
      (caps)
        _values 'caps action' add rm && ret=0
        ;;
      (role)
        _values 'role action' create delete get list modify && ret=0
        ;;
      (role-policy)
        _values 'role-policy action' put list get delete && ret=0
        ;;
      (lc)
        _values 'lc action' get list process && ret=0
        ;;
      (gc)
        _values 'gc action' list process && ret=0
        ;;
      (reshard)
        _values 'reshard action' add list process status cancel && ret=0
        ;;
      (mdlog|datalog)
        _values 'log action' list trim status && ret=0
        ;;
      (topic)
        _values 'topic action' list get rm stats dump && ret=0
        ;;
      (quota)
        _values 'quota action' set enable disable && ret=0
        ;;
      (metadata)
        _values 'metadata action' get put rm list 'sync status' && ret=0
        ;;
      (orphans)
        _values 'orphans action' find finish list-jobs && ret=0
        ;;
      (log)
        _values 'log action' list show rm && ret=0
        ;;
      (usage)
        _values 'usage action' show trim && ret=0
        ;;
      (global)
        _values 'global action' 'quota get' 'quota set' 'quota enable' 'quota disable' && ret=0
        ;;
      (restore)
        _values 'restore action' list status && ret=0
        ;;
    esac
    ;;
esac

return ret
