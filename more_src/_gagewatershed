#compdef gagewatershed GageWatershed
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/GageWatershed.html
# TauDEM: delineate gage watersheds draining to outlet points

local ret=1

_arguments -s -S \
  '-p[input D8 flow direction grid]:pfile:_files' \
  '-gw[output gage watersheds grid]:gwfile:_files' \
  '-o[input outlets file (OGR readable dataset)]:outletfile:_files' \
  '-id[output watershed downslope connectivity text file]:idfile:_files' \
  '(-lyrno)-lyrname[OGR layer name for outlets]:layer name:' \
  '(-lyrname)-lyrno[OGR layer number for outlets]:layer number:' \
  '*:file:_files' && ret=0

return ret
