#compdef jb jsonnet-bundler

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize new empty jsonnetfile'
  'install:install new dependencies'
  'i:alias for install'
  'update:update all or specified deps'
  'u:alias for update'
  'rewrite:rewrite legacy imports to absolute'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--jsonnetpkg-home=[directory to cache packages]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[suppress git output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'jb command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install|update|i|u)
        _arguments \
          '--single[only update direct deps]' \
          '*:URI:' && ret=0 ;;
    esac ;;
esac

return ret
