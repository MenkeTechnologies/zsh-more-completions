#compdef openhab-cli
# Documentation: https://www.openhab.org/docs/installation/linux.html
# openhab-cli: openHAB control command line utility

local ret=1
local -a subcmds
subcmds=(
  'start:start openHAB in the terminal'
  'stop:stop the running openHAB instance'
  'restart:restart the running openHAB instance'
  'status:check if openHAB is running'
  'console:open the openHAB console (Karaf)'
  'client:open the openHAB remote client'
  'backup:store the current configuration of openHAB'
  'restore:restore openHAB configuration from a backup'
  'showlogs:display the log messages of openHAB'
  'logs:display the log messages of openHAB'
  'clean-cache:clean the openHAB temporary folders'
  'info:display distribution information'
  'reset-ownership:give openHAB control of its own directories'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--full[create a full backup including cache and tmp]' \
  '--textconfig[restore only text configuration]' \
  '--uiconfig[restore only UI configuration]' \
  '(-d --debug)'{-d,--debug}'[start in debug mode]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'openhab-cli command' subcmds && ret=0 ;;
  args)
    case $line[1] in
      backup|restore) _files && ret=0 ;;
    esac ;;
esac

return ret
