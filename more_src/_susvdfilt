#compdef susvdfilt
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/susvdfilt.c
# SVD (Eigen) filter

local ret=1

_arguments -s -S \
  'ntrw=[ntrw]:ntrw:' \
  'verbose=[verbose]:verbose:' \
  'numpp=[numpp]:numpp:' \
  'subtract=[subtract]:subtract:' \
  'tmpdir=[tmpdir]:tmpdir:' \
  '*:file:_files' && ret=0

return ret
