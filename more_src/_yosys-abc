#compdef yosys-abc

# Yosys yosys-abc: Berkeley ABC compiled into Yosys for logic optimization
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-c[execute command]:cmd:' \
  '-f[execute commands from file]:file:_files' \
  '-o[output file]:file:_files' \
  '-q[quiet mode]' \
  '-x[exit on error]' \
  '-S[show statistics on exit]' \
  '-T[disable cache]' \
  '*:input netlist or script:_files' && ret=0
return ret
