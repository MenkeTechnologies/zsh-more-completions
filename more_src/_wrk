#compdef wrk

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  {-c,--connections}'[number of connections to keep open]:connections' \
  {-d,--duration}'[duration of test]:duration (e.g. 10s, 5m)' \
  {-t,--threads}'[number of threads]:threads' \
  {-s,--script}'[load Lua script]:script:_files -g "*.lua"' \
  {-H,--header}'[add header to request]:header' \
  '--latency[print detailed latency statistics]' \
  '--timeout[socket/request timeout]:timeout (e.g. 2s)' \
  '1:URL' \
  && ret=0

return ret
