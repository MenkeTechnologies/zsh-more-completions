#compdef create-better-t-stack
# Documentation: https://www.npmjs.com/package/create-better-t-stack
# Reference accessed: 2026-05-23
# Verified: npm view create-better-t-stack bin; npm readme Usage and Options sections.

# Zsh completion for create-better-t-stack - full-stack TypeScript monorepo scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-V --version)'{-V,--version}'[output version number]'   '(-y --yes)'{-y,--yes}'[use default configuration]'   '--template=[starter template]:template:(mern pern t3 uniwind none)'   '--database=[database type]:db:(none sqlite postgres mysql mongodb)'   '--orm=[ORM type]:orm:(none drizzle prisma mongoose)'   '--dry-run[validate configuration without writing files]'   '--auth=[authentication provider]:auth:(better-auth clerk none)'   '--payments=[payments provider]:payments:(polar none)'   '--frontend=[frontend types]:frontend:(tanstack-router react-router tanstack-start next nuxt svelte solid astro native-bare native-uniwind native-unistyles none)'   '--addons=[additional addons]:addon:(pwa tauri electrobun starlight biome lefthook husky mcp turborepo nx fumadocs ultracite oxlint opentui wxt skills evlog none)'   '--examples=[examples to include]:example:(todo ai none)'   '--git[initialize git repository]'   '--no-git[skip git initialization]'   '--package-manager=[package manager]:manager:(npm pnpm bun)'   '--install[install dependencies]'   '--no-install[skip installing dependencies]'   '--db-setup=[database setup]:setup:(turso d1 neon supabase prisma-postgres planetscale mongodb-atlas docker none)'   '--web-deploy=[web deployment]:deploy:(cloudflare none)'   '--server-deploy=[server deployment]:deploy:(cloudflare none)'   '--backend=[backend framework]:backend:(hono express fastify elysia convex self none)'   '--runtime=[runtime]:runtime:(bun node workers none)'   '--api=[API type]:api:(trpc orpc none)'   '--directory-conflict=[directory strategy]:strategy:(merge overwrite increment error)'   '--manual-db[skip automatic database setup prompts]'   '--input=[JSON payload for create-json or add-json]:json:'   '--name=[schema name for schema subcommand]:name:(all createInput addInput addonOptions dbSetupOptions cli)'   '(-h --help)'{-h,--help}'[display help]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' create-json add-json schema mcp && ret=0
    ;;
  args)
    case $line[1] in
      schema)
        _arguments -C           '--name=[schema to output]:name:(all createInput addInput addonOptions dbSetupOptions cli)' && ret=0
        ;;
      create-json|add-json)
        _arguments -C           '--input=[JSON payload]:json:' && ret=0
        ;;
      *)
        _arguments -C           '(-y --yes)'{-y,--yes}'[use default configuration]'           '--template=[starter template]:template:(mern pern t3 uniwind none)'           '--database=[database type]:db:(none sqlite postgres mysql mongodb)'           '--orm=[ORM type]:orm:(none drizzle prisma mongoose)'           '--dry-run[validate without writing files]'           '--package-manager=[package manager]:manager:(npm pnpm bun)'           '--install[install dependencies]'           '--no-install[skip installing dependencies]'           ':project directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
