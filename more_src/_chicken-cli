# _chicken-cli — CHICKEN Scheme chicken-cli CLI command-line frontend wrapping the CHICKEN Scheme R5RS Scheme implementation that compiles Scheme programs to C code as well as offering an interactive mode open-source written in C and Scheme originally Felix L. Winkelmann now CHICKEN team practical and portable Scheme system csc csi chicken-install eggs Cheney-on-the-MTA garbage collector compiler interpreter eggs FFI continuations call/cc tail-calls hygienic-macros r5rs r7rs compile interpret install uninstall status feathers profile debug optimize (CHICKEN team Felix L. Winkelmann, C/Scheme); custom argparse
# upstream: https://www.call-cc.org/

_chicken-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-quiet[quiet]' \
        '-no-trace[no trace]' \
        '-no-warnings[no warnings]' \
        '-debug-info[debug info]' \
        '-debug-level=+[N]:n:' \
        '-c[compile only]' \
        '-cc=+[cmd]:str:' \
        '-cxx=+[cmd]:str:' \
        '-ld=+[cmd]:str:' \
        '-I+[dir]:dir:_files -/' \
        '*-I+[dir]:dir:_files -/' \
        '-L+[dir]:dir:_files -/' \
        '*-L+[dir]:dir:_files -/' \
        '-l+[lib]:str:' \
        '*-l+[lib]:str:' \
        '-include-path=+[dir]:dir:_files -/' \
        '-static[static link]' \
        '-shared[shared]' \
        '-dynamic[dynamic]' \
        '-o+[output]:file:_files' \
        '-J[shorter trampolines]' \
        '-O+[level]:n:' \
        '*-O+[level]:n:' \
        '-optimize-level=+[N]:n:' \
        '-disable-interrupts[disable interrupts]' \
        '-no-feature=+[name]:str:' \
        '*-no-feature=+[name]:str:' \
        '-feature=+[name]:str:' \
        '*-feature=+[name]:str:' \
        '-prelude=+[expr]:str:' \
        '-postlude=+[expr]:str:' \
        '-types[print types]' \
        '-emit-types-file=+[file]:file:_files' \
        '-consult-types-file=+[file]:file:_files' \
        '-inline[inline]' \
        '-uses=+[unit]:str:' \
        '-keep-shadowed-macros[keep shadowed macros]' \
        '-emit-import-library=+[name]:str:' \
        '-emit-all-import-libraries[emit all]' \
        '-unit=+[name]:str:' \
        '-require-extension=+[name]:str:' \
        '*-R+[require]:str:' \
        '-prologue=+[file]:file:_files' \
        '-epilogue=+[file]:file:_files' \
        '-pp+[cmd]:str:' \
        '-ssr[scrutinize sequence reads]' \
        '-strict-types[strict types]' \
        '-specialize[specialize]' \
        '-no-bound-checks[no bound checks]' \
        '-no-procedure-checks[no procedure checks]' \
        '-no-argc-checks[no argc checks]' \
        '-block[whole-module block]' \
        '-emit-link-file=+[file]:file:_files' \
        '-no-symbol-escape[no symbol escape]' \
        '-no-parentheses-synonyms[no parentheses synonyms]' \
        '-no-elevation[no elevation]' \
        '-fixnum-arithmetic[fixnum arithmetic]' \
        '-script[script mode]' \
        '-s[script mode]' \
        '-ss[script main-mode]' \
        '-sx[script mode trace]' \
        '-eval=+[expr]:str:' \
        '*-e+[expr]:str:' \
        '-batch[batch mode]' \
        '-b[batch mode]' \
        '-quiet-feathers[quiet feathers]' \
        '-:?+[runtime option]:str:' \
        '-target=+[arch]:str:' \
        '-port=+[port]:n:' \
        '-host=+[host]:_hosts' \
        '-deploy[deploy]' \
        '-deployed[deployed]' \
        '-cross+[name]:str:' \
        '-coll-dir=+[dir]:dir:_files -/' \
        '-extension[extension]' \
        '-emit-link-file=+[file]:file:_files' \
        '*:scheme file:_files -g "*.scm *.ss *.scheme"'
}

_chicken-cli "$@"
