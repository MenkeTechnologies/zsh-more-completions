#compdef kdiamond
# Documentation: https://apps.kde.org/kdiamond/
# Reference accessed: 2026-05-16
# Verified: KDE kdiamond GUI app. KAboutData standard flags only.
# Removed from prior file: bogus man.archlinux.org search URL.

# kdiamond: KDE Bejeweled-like puzzle (GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' && ret=0
return ret
