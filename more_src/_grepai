_grepai() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'init:initialize grepai in the current directory'
        'watch:start the real-time file watcher daemon'
        'search:semantic codebase search with natural language'
        'trace:trace symbol callers/callees/graph'
        'refs:trace property/data readers/writers/graph'
        'workspace:manage multi-project workspaces'
        'status:display index status'
        'stats:show token savings achieved by grepai'
        'agent-setup:configure AI agents to use grepai'
        'mcp-serve:start grepai as an MCP (Model Context Protocol) server'
        'update:self-update grepai to latest version'
        'completion:generate shell completion scripts'
        'version:print version information'
        'help:show help for a command'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'grepai command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                init)
                    _arguments \
                        '(-p --provider)'{-p+,--provider=}'[embedding provider]:provider:(ollama lmstudio openai synthetic openrouter)' \
                        '(-m --model)'{-m+,--model=}'[embedding model]:model:(text-embedding-3-small text-embedding-3-large qwen3-embedding-8b)' \
                        '(-b --backend)'{-b+,--backend=}'[storage backend]:backend:(gob postgres qdrant)' \
                        '--yes[use defaults without prompting]' \
                        '--inherit[inherit configuration from main worktree]' \
                        '--ui[run interactive Bubble Tea wizard]' && ret=0
                    ;;
                watch)
                    _arguments \
                        '--background[run in background mode]' \
                        '--log-dir=[directory for log files]:dir:_files -/' \
                        '--status[show background watcher status]' \
                        '--stop[stop the background watcher]' \
                        '--workspace=[workspace name for multi-project mode]:workspace:' \
                        '--no-ui[disable interactive UI in foreground]' && ret=0
                    ;;
                search)
                    _arguments \
                        '(-n --limit)'{-n+,--limit=}'[max results (default 10)]:n:' \
                        '(-j --json)'{-j,--json}'[output results in JSON]' \
                        '(-t --toon)'{-t,--toon}'[output results in TOON]' \
                        '(-c --compact)'{-c,--compact}'[minimal output (needs --json or --toon)]' \
                        '--workspace=[workspace name]:workspace:' \
                        '*--project=[project name within workspace]:project:' \
                        '*:query:' && ret=0
                    ;;
                trace)
                    _arguments -C \
                        '(-): :->trsub' \
                        '*::trarg:->trarg' && ret=0
                    case $state in
                        trsub)
                            local -a trsubs=(
                                'callers:find all functions that call the symbol'
                                'callees:find all functions called by the symbol'
                                'graph:build a call graph around the symbol'
                            )
                            _describe -t commands 'trace subcommand' trsubs && ret=0
                            ;;
                        trarg)
                            _arguments \
                                '(-m --mode)'{-m+,--mode=}'[extraction mode]:mode:(fast precise)' \
                                '1:symbol:' && ret=0
                            ;;
                    esac
                    ;;
                refs)
                    _arguments -C \
                        '(-): :->rfsub' \
                        '*::rfarg:->rfarg' && ret=0
                    case $state in
                        rfsub)
                            local -a rfsubs=(
                                'readers:find functions that read the property/data symbol'
                                'writers:find functions that write the property/data symbol'
                                'graph:show readers+writers graph'
                            )
                            _describe -t commands 'refs subcommand' rfsubs && ret=0
                            ;;
                        rfarg)
                            _arguments \
                                '--json[output results in JSON]' \
                                '(-t --toon)'{-t,--toon}'[output results in TOON]' \
                                '1:symbol:' && ret=0
                            ;;
                    esac
                    ;;
                workspace)
                    local -a wssubs=(
                        'list:list all workspaces'
                        'show:show workspace details'
                        'status:show workspace indexing status'
                        'create:create a workspace'
                        'add:add a project path to a workspace'
                        'remove:remove a project from a workspace'
                        'delete:delete a workspace'
                    )
                    _describe -t commands 'workspace subcommand' wssubs && ret=0
                    ;;
                status)
                    _arguments '--no-ui[plain-text summary]' && ret=0
                    ;;
                stats)
                    _arguments \
                        '(-j --json)'{-j,--json}'[output results in JSON]' \
                        '--history[show per-day history breakdown]' \
                        '(-l --limit)'{-l+,--limit=}'[max days with --history (default 30)]:n:' \
                        '--no-ui[plain text instead of interactive UI]' && ret=0
                    ;;
                mcp-serve)
                    _arguments \
                        '--workspace=[workspace name for workspace-only mode]:workspace:' \
                        '1:project path:_files -/' && ret=0
                    ;;
                update)
                    _arguments \
                        '--check[only check for updates, do not install]' \
                        '--force[force update even if on latest version]' && ret=0
                    ;;
                completion)
                    local -a shells=(
                        'zsh:generate zsh completion script'
                        'bash:generate bash completion script'
                        'fish:generate fish completion script'
                    )
                    _describe -t commands 'shell' shells && ret=0
                    ;;
                agent-setup)
                    _arguments '--with-subagent[install grepai subagent template]' && ret=0
                    ;;
                version|help)
                    ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_grepai "$@"
