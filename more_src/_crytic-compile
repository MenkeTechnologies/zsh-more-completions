#compdef crytic-compile
# Documentation: https://github.com/crytic/crytic-compile
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Smart contract compile abstraction wrapping solc/hardhat/foundry/truffle/brownie.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--compile-force-framework=[force a specific compilation framework]:framework:(solc solc-standard-json hardhat truffle brownie foundry buidler dapp embark waffle etherlime etherscan vyper)' \
  '--compile-libraries=[link libraries to deployed addresses]:libs:' \
  '--compile-remove-metadata[remove metadata from bytecode]' \
  '--compile-custom-build=[custom build command]:cmd:' \
  '--ignore-compile[do not compile - use existing artifacts]' \
  '--solc=[solc executable]:solc:_files' \
  '--solc-remaps=[solc remappings]:remaps:' \
  '--solc-args=[extra solc args]:args:' \
  '--solc-disable-warnings[hide solc warnings]' \
  '--solc-working-dir=[solc working dir]:dir:_files -/' \
  '--solc-solcs-select=[solc versions via solc-select]:versions:' \
  '--solc-solcs-bin=[solc binaries (comma list)]:bins:' \
  '--solc-standard-json[use solc --standard-json]' \
  '--solc-force-legacy-json[use legacy AST JSON output]' \
  '--truffle-version=[npx truffle version]:version:' \
  '--truffle-ignore-compile[skip truffle compile]' \
  '--truffle-build-directory=[truffle build dir]:dir:_files -/' \
  '--hardhat-cache-directory=[hardhat cache dir]:dir:_files -/' \
  '--hardhat-artifacts-directory=[hardhat artifacts dir]:dir:_files -/' \
  '--hardhat-ignore-compile[skip hardhat compile]' \
  '--foundry-ignore-compile[skip forge build]' \
  '--foundry-out-directory=[foundry out dir]:dir:_files -/' \
  '--foundry-compile-all[include test/script in foundry build]' \
  '--vyper=[vyper executable]:vyper:_files' \
  '--export-format=[export artifact format]:format:(standard solc truffle archive)' \
  '--export-dir=[export directory]:dir:_files -/' \
  '--export-zip=[archive zip path]:file:_files' \
  '--export-zip-type=[zip compression]:type:(lzma bzip2 gzip stored)' \
  '*:target:_files'
