#compdef Gblocks
# Documentation: https://www.biologiacomputacional.org/gblocks
# Gblocks: selection of conserved blocks from multiple alignments

local ret=1

_arguments -s -S \
  '-t=-[type of sequence]:type:(p d c)' \
  '-b1=-[minimum number of sequences for a conserved position]:n:' \
  '-b2=-[minimum number of sequences for a flanking position]:n:' \
  '-b3=-[maximum number of contiguous nonconserved positions]:n:' \
  '-b4=-[minimum length of a block]:n:' \
  '-b5=-[allowed gap positions]:gaps:(n h a)' \
  '-b6=-[use similarity matrices (protein only)]:flag:(y n)' \
  '-e=-[generic file extension for output]:ext:' \
  '-p=-[produce results and parameters files]:flag:(y n t s)' \
  '-v=-[characters per line in output files]:n:' \
  '-d=-[print debugging messages]:flag:(y n)' \
  '-s=-[save a postscript graph of the selected blocks]:flag:(y n)' \
  '-k=-[concatenated codon blocks (codon mode)]:flag:(y n)' \
  '-u=-[use input file as parameters file]:flag:(y n)' \
  '*:alignment file:_files' && ret=0

return ret
