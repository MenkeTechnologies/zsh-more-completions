#compdef lsz

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[ASCII transfer (convert line endings)]' \
  '-b[binary transfer mode]' \
  '-B+[buffer size in bytes]:buffer size:' \
  '-c+[send command to remote]:command:' \
  '-C+[send command and collect output]:command:' \
  '-d[change all directory names to dots]' \
  '-e[force sender to escape all control characters]' \
  '-E[rename incoming files if they already exist]' \
  '-f[send full pathname]' \
  '-h[print help message]' \
  '-i+[send ZMODEM command before transfer]:command:' \
  '-k[send files in 1024-byte blocks (YMODEM-1K)]' \
  '-L+[set ZMODEM subpacket length]:length:' \
  '-l+[set ZMODEM frame length]:length:' \
  '-m+[minimum baud rate for uploads]:baud rate:' \
  '-n[send file only if destination is older or missing]' \
  '-N[send file only if source is newer or longer]' \
  '-o[disable timeout code]' \
  '-O[disable timeout during ZMODEM packet send]' \
  '-p[protect existing destination files]' \
  '-q[quiet mode, suppress output]' \
  '-r[resume interrupted file transfer]' \
  '-R[restricted mode]' \
  '-s+[set HH:MM:SS stop time]:time:' \
  '-S[use YMODEM single-file transfer]' \
  '-t+[set timeout in seconds]:timeout:' \
  '-T[do not use turbo mode]' \
  '-u[unlink files after successful transfer]' \
  '-U[disable timeout on first ZMODEM data packet]' \
  '-v[verbose output]' \
  '-vv[very verbose output]' \
  '-w+[set window size for ZMODEM]:window size:' \
  '-X[use XMODEM protocol]' \
  '-y[overwrite existing files at destination]' \
  '-Y[overwrite existing files, skip same/newer files]' \
  '-Z[use ZMODEM protocol]' \
  '--version[display version information]' \
  '*:file to send:_files' \
  && ret=0

return ret
