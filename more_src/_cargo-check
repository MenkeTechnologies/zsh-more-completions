#compdef cargo-check

# Zsh completion for cargo-check (Rust type checking without building)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-p+[package to check]:package' \
  '--package=[package to check]:package' \
  '--all[check all packages in workspace]' \
  '--workspace[check all packages in workspace]' \
  '--exclude=[exclude packages]:package' \
  '--lib[check only library]' \
  '--bin=[check only specified binary]:binary' \
  '--bins[check all binaries]' \
  '--example=[check only specified example]:example' \
  '--examples[check all examples]' \
  '--test=[check only specified test target]:test' \
  '--tests[check all tests]' \
  '--bench=[check only specified bench target]:bench' \
  '--benches[check all benches]' \
  '--all-targets[check all targets]' \
  '-j+[number of parallel jobs]:jobs' \
  '--jobs=[number of parallel jobs]:jobs' \
  '--features=[space-separated list of features]:features' \
  '--all-features[activate all features]' \
  '--no-default-features[do not activate default features]' \
  '--target=[target triple]:target' \
  '--target-dir=[directory for generated artifacts]:directory:_directories' \
  '--manifest-path=[path to Cargo.toml]:file:_files' \
  '--message-format=[error format]:format:(human json short)' \
  '--release[check in release mode]' \
  '--profile=[check with specified profile]:profile' \
  '-q[do not print cargo log messages]' \
  '--quiet[do not print cargo log messages]' \
  '-v[use verbose output]' \
  '--verbose[use verbose output]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[require Cargo.lock is up to date]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without network access]' \
  '--future-incompat-report[output future incompatibility report]' \
  '--timings=[output build timing info]:format:(html json)'
