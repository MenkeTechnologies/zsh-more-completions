#compdef vorpastat
# Documentation: https://github.com/BrunoLevy/geogram/wiki/Vorpaline
# Geogram vorpastat: measure Hausdorff distance between two meshes

local ret=1

_arguments -s -S \
  '*stat\:sampling_step=[sampling step (%% bbox diagonal)]:step:' \
  '*algo\:predicates=[geometric predicates]:pred:(fast exact)' \
  '*algo\:nn_search=[nearest neighbors search]:nn:' \
  '*sys\:multithread=[enable multi-threaded computations]:val:(true false)' \
  '*sys\:max_threads=[maximum concurrent threads]:n:' \
  '*debug=[toggle debug mode]:debug:(true false)' \
  '1:mesh1:_files' \
  '2:mesh2:_files' && ret=0

return ret
