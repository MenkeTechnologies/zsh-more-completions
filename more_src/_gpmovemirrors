#compdef gpmovemirrors
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gpmovemirrors.html
# Move mirror segments to a new location in a Greenplum Database system

local ret=1

_arguments -s -S \
  '-?[display online help]' \
  '--version[display the utility version]' \
  '-a[do not prompt for confirmation]' \
  '-i[move configuration file]:file:_files' \
  '-d[coordinator data directory]:dir:_files -/' \
  '-l[directory where log files are written]:dir:_files -/' \
  '-b[max segments per host to operate on in parallel (1-128)]:num' \
  '-B[number of hosts to work on in parallel (1-64)]:num' \
  '-v[set logging output to verbose]' \
  '--hba-hostnames[use IP (0) or host names (1) in pg_hba.conf]:value:(0 1)' && ret=0

return ret
