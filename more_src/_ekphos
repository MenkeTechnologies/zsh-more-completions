# ekphos: terminal-based markdown research tool (Rust)

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--reset[reset configuration]' \
  '*:path:_files' && ret=0

return ret
