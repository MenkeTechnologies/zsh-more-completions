#compdef kape
# Documentation: https://github.com/AndrewRathbun/Awesome-KAPE
# Kroll Artifact Parser and Extractor (KAPE)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--tsource=[target source drive]:source' \
  '--target=[targets to collect]:target' \
  '--tdest=[target output destination]:directory:_directories' \
  '--tflush[delete files in tdest before collection]' \
  '--tlist[list available targets]' \
  '--tdetail[show detailed target info]' \
  '--tvars=[variables to pass to targets]:vars' \
  '--msource=[source directory to process]:directory:_directories' \
  '--module=[modules to run]:module' \
  '--mdest=[module output destination]:directory:_directories' \
  '--mflush[delete files in mdest before processing]' \
  '--mlist[list available modules]' \
  '--mdetail[show detailed module info]' \
  '--mvars=[key:value pairs for modules]:vars' \
  '--mef=[module export format]:format' \
  '--zip=[create ZIP container]:name' \
  '--zpw=[ZIP password]:password' \
  '--vhdx=[create VHDX container]:name' \
  '--vhd=[create VHD container]:name' \
  '--zv=[ZIP verification option]:value' \
  '--asu=[Azure Storage SAS URI]:uri' \
  '--s3url=[S3 presigned URL]:url' \
  '--scd=[default upload directory path]:path' \
  '--rlc[retain local copy]' \
  '--sftp=[SFTP server config]:server' \
  '--scs=[SFTP connection settings]:settings' \
  '--scp=[SFTP port]:port' \
  '--scu=[SFTP username]:user' \
  '--sftpu[display SFTP user passwords]' \
  '--sync[update Targets/Modules from KapeFiles]' \
  '--overwrite[overwrite local configs during sync]' \
  '--gui[launch GUI version]' \
  '--debug[enable debug logging]' \
  '--trace[enable trace logging]' \
  '--vss[process Volume Shadow Copies]' \
  '--cu[delete config files after batch]' \
  '--ul[use linear mode for batch]' \
  '--sim[simulate file copying]' \
  '--hex=[SHA-1 exclusion file path]:file:_files' \
  '--ifw[ignore FTK process warning]' && ret=0

return ret
