#compdef create-tauri-ui
# Documentation: https://www.npmjs.com/package/create-tauri-ui
# Reference accessed: 2026-05-24
# Verified: npm view create-tauri-ui bin; npm readme CLI reference and battery flags.

# Zsh completion for create-tauri-ui - Tauri desktop app scaffolder with shadcn/ui

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-t --template)'{-t,--template=}'[frontend template]:template:(vite next start react-router astro)' \
  '--identifier=[Tauri app identifier]:id:' \
  '--preset=[shadcn preset code]:preset:' \
  '--size-optimize[optimize release binaries for size]' \
  '--no-size-optimize[skip release size optimization]' \
  '--starter[include starter dashboard battery]' \
  '--no-starter[skip starter dashboard battery]' \
  '--invoke-example[include Rust invoke example battery]' \
  '--no-invoke-example[skip Rust invoke example battery]' \
  '--workflow[include GitHub release workflow battery]' \
  '--no-workflow[skip GitHub release workflow battery]' \
  '--dir=[project directory]:directory:_directories' \
  '--target-os=[comma-separated workflow platforms]:platforms:' \
  '(-f --force)'{-f,--force}'[overwrite existing target directory]' \
  '(-y --yes)'{-y,--yes}'[accept defaults; skip confirmations]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' add update remove && ret=0
    ;;
  args)
    case $line[1] in
      add|update|remove)
        _arguments -C \
          ':battery:(workflow starter invoke-example size-optimize)' \
          '--target-os=[comma-separated platforms]:platforms:' \
          '(-f --force)'{-f,--force}'[overwrite battery wiring]' \
          '(-y --yes)'{-y,--yes}'[accept defaults]' && ret=0
        ;;
      *)
        _arguments -C \
          '(-t --template)'{-t,--template=}'[frontend template]:template:(vite next start react-router astro)' \
          '--identifier=[Tauri app identifier]:id:' \
          '(-y --yes)'{-y,--yes}'[accept defaults]' \
          ':project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
