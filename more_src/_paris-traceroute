#compdef paris-traceroute

_arguments -s \
  '-4[IPv4]' \
  '-6[IPv6]' \
  '(-a --algorithm)'{-a,--algorithm=}'[algorithm]:algo:(paris-traceroute mda)' \
  '(-d --debug)'{-d,--debug}'[libparistraceroute debug]' \
  '(-p --dst-port)'{-p,--dst-port=}'[destination port]:port:' \
  '(-s --src-port)'{-s,--src-port=}'[source port]:port:' \
  '(-I --icmp)'{-I,--icmp}'[use ICMP]' \
  '(-P --protocol)'{-P,--protocol=}'[protocol]:proto:(udp icmp)' \
  '(-T --tcp)'{-T,--tcp}'[use TCP]' \
  '(-U --udp)'{-U,--udp}'[use UDP]' \
  '-z[min interval between probes]:wait:' \
  '(- *)'{-h,--help}'[show help]' \
  ':host:_hosts'
