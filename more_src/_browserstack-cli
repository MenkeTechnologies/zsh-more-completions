#compdef browserstack-cli bstack
# _browserstack-cli — BrowserStack browserstack-cli CLI command-line frontend to the BrowserStack cloud platform supporting cross-browser cross-OS Real Device Automate App Live Cucumber Cypress Playwright WebDriverIO Selenium Appium-test-launching parallel-running browserstack.yml-defined session management dashboard reporting (BrowserStack team, JavaScript); commander
# upstream: https://www.browserstack.com/

_browserstack-cli() {
    local -a sub=(
        'auth:authenticate'
        'init:scaffold a project'
        'run:run tests in cloud'
        'devices:list available devices'
        'browsers:list available browsers'
        'session:fetch session details'
        'parallel:parallelism management'
        'plugin:plugin management'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[user]:str:' \
        '--user=+[user]:str:' \
        '-k+[access key]:str:' \
        '--access-key=+[key]:str:' \
        '-c+[config file]:file:_files -g "browserstack.yml *.yaml *.json"' \
        '--config-path=+[file]:file:_files -g "*.yml *.yaml *.json"' \
        '--framework=+[f]:f:(cypress playwright webdriverio selenium appium nightwatch testcafe puppeteer cucumber jest mocha)' \
        '-p+[parallels]:n:' \
        '--parallels=+[N]:n:' \
        '--browsers=+[list]:str:' \
        '--os=+[list]:str:' \
        '--devices=+[list]:str:' \
        '--build=+[name]:str:' \
        '--project=+[name]:str:' \
        '--local[use local tunnel]' \
        '--no-local[no local tunnel]' \
        '--debug[debug]' \
        '--no-color[disable color output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'browserstack-cli subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments '*:script:_files' ;;
                session) _arguments '*:session id:' ;;
            esac
            ;;
    esac
}

_browserstack-cli "$@"
