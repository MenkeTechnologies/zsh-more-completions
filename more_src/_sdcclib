#compdef sdcclib

# sdcclib: SDCC library archive tool
# Documentation: https://sdcc.sourceforge.net/doc/sdccman.pdf
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-c[create library]' \
  '-a[add files]' \
  '-r[replace files]' \
  '-d[delete files]' \
  '-l[list contents]' \
  '-x[extract files]' \
  '-v[verbose]' \
  '*:library member files:_files -g "*.(lib|rel|o)"' && ret=0
return ret
