#compdef cerbosctl
# _cerbosctl — CLI for the Cerbos authorization PDP (cerbos/cerbos)
# upstream: https://github.com/cerbos/cerbos
# Subcommands from cmd/cerbosctl/root/root.go (kong).

_cerbosctl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--server=[gRPC address of the Cerbos server (CERBOS_SERVER)]:host\:port:' \
        '--username=[admin username (CERBOS_USERNAME)]:user:' \
        '--password=[admin password (CERBOS_PASSWORD)]:password:' \
        '--insecure[skip TLS certificate verification]' \
        '--plaintext[talk to the server without TLS]' \
        '--ca-cert=[CA certificate path]:file:_files' \
        '--cert=[client certificate path]:file:_files' \
        '--key=[client key path]:file:_files' \
        '--connect-timeout=[connection timeout]:duration:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_cerbosctl_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                get)
                    _arguments \
                        '1: :(principal_policy pp resource_policy rp derived_roles dr export_variables ev schemas)' \
                        '*:resource id:' \
                        '-o+[output format]:format:(yaml json pretty-json)' && ret=0 ;;
                put)
                    _arguments \
                        '1: :(policy p schema s)' \
                        '*:file:_files -g "*.(yaml|yml|json)"' && ret=0 ;;
                delete)
                    _arguments \
                        '1: :(schema s)' \
                        '*:schema id:' && ret=0 ;;
                enable|disable)
                    _arguments \
                        '1: :(policy p)' \
                        '*:policy id:' && ret=0 ;;
                inspect)
                    _arguments \
                        '1: :(policies)' \
                        '*:policy id pattern:' && ret=0 ;;
                store)
                    _arguments \
                        '1: :(add modify replace-files)' \
                        '*:store args:_files' && ret=0 ;;
                hub)
                    _arguments \
                        '1: :(playbook deploy)' \
                        '*:hub args:' && ret=0 ;;
                audit|decisions|version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_cerbosctl_commands] )) ||
_cerbosctl_commands() {
    local -a commands
    commands=(
        'get:list or view policies and schemas'
        'put:create / update policies or schemas'
        'delete:delete schemas (use disable/enable for policies)'
        'disable:disable policies'
        'enable:enable policies'
        'inspect:inspect policies (referenced actions, attributes, schemas)'
        'store:store management (add / modify / replace-files)'
        'hub:Cerbos Hub operations'
        'audit:view audit logs'
        'decisions:open the interactive decision-log viewer'
        'version:print cerbosctl and PDP version'
    )
    _describe -t commands 'cerbosctl command' commands
}

_cerbosctl "$@"
