#compdef ipcalc-ng

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --check)'{-c,--check}'[check valid IP]' \
  '(-r --random)'{-r,--random}'+[generate random network]:bits:' \
  '(-S --split)'{-S,--split}'+[split network]:size:' \
  '(-d --deaggregate)'{-d,--deaggregate}'[deaggregate to a range of networks]' \
  '(-i --info)'{-i,--info}'[print info]' \
  '(-b --no-binary)'{-b,--no-binary}'[do not print binary]' \
  '(-s --show-hostname)'{-s,--show-hostname}'[show hostname]' \
  '(-j --json)'{-j,--json}'[JSON output]' \
  '(-J --json-pretty)'{-J,--json-pretty}'[pretty JSON output]' \
  '(-n --no-decode)'{-n,--no-decode}'[do not decode]' \
  '(-4 --ipv4)'{-4,--ipv4}'[IPv4]' \
  '(-6 --ipv6)'{-6,--ipv6}'[IPv6]' \
  '*:address:' && ret=0

return ret
