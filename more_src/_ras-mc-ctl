#compdef ras-mc-ctl
# Documentation: https://man.archlinux.org/search?q=ras-mc-ctl
# Reference accessed: 2026-05-16

# ras-mc-ctl: memory-controller / EDAC RAS event manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--quiet[quiet mode]' \
  '--mainboard[show mainboard info]' \
  '--status[print EDAC status]' \
  '--print-labels[print configured DIMM labels]' \
  '--guess-labels[guess DIMM labels from DMI]' \
  '--register-labels[load DIMM labels into kernel]' \
  '--layout[print board memory layout]' \
  '--errors[show error counts]' \
  '--error-count[show error counts]' \
  '--summary[print summary]' \
  '--vendor-errors-summary[per-vendor error summary]' \
  '--vendor-errors-detail[per-vendor error detail]' \
  '--filter-errors-by=[filter errors]:filter:' \
  '--vendor-errors-summary-detail[summary + detail]' \
  '--ce-uc[show CE+UC]' \
  '--display[display info from DB]' \
  '--display-memory[show memory display]' \
  '--show-pci[show PCI errors]' \
  '--show-disabled[show disabled rows]' \
  '*::ras-mc-ctl args:_files' && ret=0
return ret
