#compdef ras-mc-ctl

# ras-mc-ctl: control rasdaemon and memory controller / DIMM labels
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--mainboard[print mainboard info]' \
  '--status[show DIMM error status]' \
  '--print-labels[print DIMM labels]' \
  '--guess-labels[print likely DIMM labels]' \
  '--register-labels[load DIMM labels into kernel]' \
  '--summary[show error summary]' \
  '--errors[show all stored errors]' \
  '--error-count[show error count]' \
  '--vendor-errors-summary[show vendor errors summary]' \
  '--vendor-errors[show all vendor errors]' \
  '--vendor-errors-count[show vendor error counts]' \
  '--vendor-errors-summary[vendor errors summary]' \
  '--vendor-errors[vendor errors]' \
  '--vendor-errors-count[vendor errors count]' \
  '--layout[show memory layout]' \
  '*::ras-mc-ctl args:_files' && ret=0
return ret
