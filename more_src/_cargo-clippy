#compdef cargo-clippy
# Documentation: cargo clippy --help
# Source: Rust cargo-clippy — Clippy lints over a package.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--no-deps[run Clippy only on the given crate (skip deps)]' \
    '--fix[automatically apply lint suggestions]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--explain=[print documentation for a given lint]:lint:' \
    '*-W+[warn lint]:lint:' \
    '*-A+[allow lint]:lint:' \
    '*-D+[deny lint]:lint:' \
    '*-F+[forbid lint]:lint:' \
    '--manifest-path=[Cargo.toml path]:file:_files -g "Cargo.toml"' \
    '--frozen[require Cargo.lock and cache are up to date]' \
    '--locked[require Cargo.lock is up to date]' \
    '--offline[run without accessing the network]' \
    '(-p --package)*'{-p,--package=}'[package to lint]:package:' \
    '--workspace[lint all members of the workspace]' \
    '*--exclude=[exclude packages]:package:' \
    '--lib[lint the library target]' \
    '*--bin=[lint specific binary]:name:' \
    '--bins[lint all binary targets]' \
    '*--example=[lint specific example]:name:' \
    '--examples[lint all example targets]' \
    '*--test=[lint specific test]:name:' \
    '--tests[lint all test targets]' \
    '*--bench=[lint specific benchmark]:name:' \
    '--benches[lint all benchmark targets]' \
    '--all-targets[lint all targets]' \
    '*--features=[features to activate]:feature:' \
    '--all-features[activate all available features]' \
    '--no-default-features[do not activate the default feature]' \
    '*--target=[build for the target triple]:triple:' \
    '--release[lint in release mode]' \
    '--target-dir=[directory for build artifacts]:dir:_files -/' \
    '(-j --jobs)'{-j,--jobs=}'[parallel jobs]:n:' \
    '--message-format=[diagnostic format]:format:(human short json json-diagnostic-rendered-ansi)' \
    '*::clippy args:_files' \
    && ret=0

return ret
