#compdef puppet-node
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/node.md
# puppet node - retrieve and clean node objects, facts, certs and reports

local ret=1

_arguments -s -S \
  '--render-as=[output render format]:format:(json s yaml console dot)' \
  '--verbose[whether to log verbosely]' \
  '--debug[whether to log debug information]' \
  '--terminus=[backend for retrieving or altering node data]:terminus:(exec json memory msgpack plain rest store_configs yaml)' \
  '1:action:(clean find info)' \
  '*::host:_hosts' && ret=0

return ret
