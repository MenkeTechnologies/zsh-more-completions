#compdef ibazel

_ibazel_commands() {
  local -a commands=(
    'build:build the specified targets'
    'test:build and test the specified targets'
    'run:build and run the specified target'
  )
  _describe 'command' commands
}

_ibazel() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '--run_output[write run output to file]:file:_files' \
    '--run_output_interactive[write interactive output to file]:file:_files' \
    '--profile_dev[profile ibazel dev stats]:file:_files' \
    '--log_to_file[log to file]:file:_files' \
    '--nolive_reload[disable live reload]' \
    '--nonotify[disable desktop notifications]' \
    '--poll[use polling instead of inotify]' \
    '1:command:_ibazel_commands' \
    '*:target'
}

_ibazel "$@"
