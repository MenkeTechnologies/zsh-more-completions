#compdef mdx-deck
# Documentation: https://github.com/jxnblk/mdx-deck
# MDX Deck MDX-based presentation tool

local ret=1

_arguments -s -S \
  '(-h --host)'{-h,--host}'=[dev server host]:host:' \
  '(-p --port)'{-p,--port}'=[dev server port]:port:' \
  '--no-open[do not open the browser]' \
  '1:command:(build)' \
  '*::deck:_files -g "*.mdx"' && ret=0

return ret
