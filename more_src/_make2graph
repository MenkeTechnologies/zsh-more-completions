#compdef make2graph
# Documentation: https://github.com/lindenb/makefile2graph
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for make2graph Makefile graph (graphviz)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-B[disable built-in and -include rules]' \
  '-d+[make debug level]:level' \
  '*:make target:{ _message "Makefile target name" }' && ret=0

return ret
