#compdef make2graph
# Documentation: https://github.com/lindenb/makefile2graph
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# make2graph: parse `make -Bnd` output and render as a graph

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --format)'{-f,--format=}'[output format]:format:((d\:dot x\:xml g\:gexf M\:Mermaid P\:PlantUML E\:deepest L\:list))' \
  '(-b --basename)'{-b,--basename}'[show only file basename]' \
  '(-s --suffix)'{-s,--suffix}'[show only file extension]' \
  '(-r --root)'{-r,--root}'[include ROOT node in output]' \
  '(-c --colorscheme)'{-c,--colorscheme=}'[apply colorscheme to nodes]:scheme:' \
  '(-g --graph-attributes)'{-g,--graph-attributes=}'[graph-level attributes]:attrs:' \
  '(-n --node-attributes)'{-n,--node-attributes=}'[node-level attributes]:attrs:' \
  '(-e --edge-attributes)'{-e,--edge-attributes=}'[edge-level attributes]:attrs:' \
  '(-d --dirty-attributes)'{-d,--dirty-attributes=}'[dirty-node attributes]:attrs:' && ret=0

return ret
