#compdef make2graph
# Documentation: https://man.archlinux.org/search?q=make2graph
# Reference accessed: 2026-05-16

# Zsh completion for make2graph Makefile graph (graphviz)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-B[disable built-in and -include rules]' \
  '-d+[make debug level]:level' \
  '*:make target:{ _message "Makefile target name" }' && ret=0

return ret
