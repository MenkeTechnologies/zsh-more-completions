#compdef jank
# Documentation: https://man.archlinux.org/search?q=jank
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'repl:start a REPL'
  'run:run a Clojure source file'
  'compile-module:compile a single module'
  'compile:compile a project'
  'cpp-repl:run an interactive C++ REPL'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--class-path=[colon-separated module path]:path:' \
  '--module-path=[colon-separated module path (alias)]:path:' \
  '--output-dir=[directory for compiled modules]:dir:_files -/' \
  '--profile[enable compiler/runtime profiling]' \
  '--profile-output=[profile output file]:file:_files' \
  '--optimization=[optimization level]:level:(0 1 2 3)' \
  '-O+[optimization level]:level:(0 1 2 3)' \
  '--gc-incremental[enable incremental GC]' \
  '--include-dir=[additional include directory]:dir:_files -/' \
  '--library-dir=[additional library directory]:dir:_files -/' \
  '--ee-pic[generate position-independent code]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'jank command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run|compile|compile-module)
        _arguments '*::file:_files -g "*.{clj,jank}"' && ret=0 ;;
    esac ;;
esac

return ret
