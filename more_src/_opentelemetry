#compdef otelcol-contrib
# _opentelemetry — OpenTelemetry Collector (open-telemetry)
# upstream: https://github.com/open-telemetry/opentelemetry-collector-contrib

_opentelemetry() {
    local curcontext="$curcontext" state line ret=1

    local -a commands=(
        'components:list available components'
        'validate:validate configuration'
    )

    _arguments -C \
        '--config=[configuration file or URI]:config:_files' \
        '*--set=[set a config key value]:key=value:' \
        '--feature-gates=[enable or disable feature gates]:gates:' \
        '--version[show version]' \
        '--help[show help]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'otelcol-contrib command' commands && ret=0 ;;
        args)
            case $line[1] in
                validate)
                    _arguments \
                        '--config=[configuration file or URI]:config:_files' \
                        '--help[show help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_opentelemetry "$@"
