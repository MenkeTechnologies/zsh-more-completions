#compdef stable-diffusion sd-cpp stable-diffusion-cpp
# _stable-diffusion — leejet stable-diffusion.cpp pure C/C++ inference of Stable Diffusion 1.x/2.x/SDXL/SD3 turbo SDXL Turbo and LCM with GGML quantization (leejet team, C++); getopt
# upstream: https://github.com/leejet/stable-diffusion.cpp

_stable-diffusion() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-M+[mode]:m:(txt2img img2img convert)' \
        '--mode=+[mode]:m:(txt2img img2img convert)' \
        '-m+[model]:file:_files -g "*.gguf *.safetensors *.ckpt *.bin"' \
        '--model=+[model]:file:_files -g "*.gguf *.safetensors *.ckpt *.bin"' \
        '--vae=+[file]:file:_files -g "*.gguf *.safetensors *.ckpt"' \
        '--taesd=+[file]:file:_files -g "*.gguf *.safetensors"' \
        '--clip_l=+[file]:file:_files -g "*.gguf *.safetensors"' \
        '--t5xxl=+[file]:file:_files -g "*.gguf *.safetensors"' \
        '--control-net=+[file]:file:_files -g "*.gguf *.safetensors"' \
        '--embd-dir=+[dir]:dir:_files -/' \
        '--lora-model-dir=+[dir]:dir:_files -/' \
        '-p+[prompt]:str:' \
        '--prompt=+[prompt]:str:' \
        '-n+[negative prompt]:str:' \
        '--negative-prompt=+[negative prompt]:str:' \
        '--cfg-scale=+[F]:f:' \
        '--strength=+[F]:f:' \
        '-H+[height]:n:' \
        '--height=+[height]:n:' \
        '-W+[width]:n:' \
        '--width=+[width]:n:' \
        '--sampling-method=+[s]:s:(euler euler_a heun dpm2 dpm++2s_a dpm++2m dpm++2mv2 ipndm lcm ddim)' \
        '--steps=+[N]:n:' \
        '-s+[seed]:n:' \
        '--seed=+[seed]:n:' \
        '-b+[batch count]:n:' \
        '--batch-count=+[batch count]:n:' \
        '-t+[threads]:n:' \
        '--threads=+[threads]:n:' \
        '-i+[input img]:file:_files -g "*.png *.jpg *.jpeg *.webp"' \
        '--init-img=+[input img]:file:_files -g "*.png *.jpg *.jpeg *.webp"' \
        '--mask=+[mask img]:file:_files -g "*.png *.jpg *.jpeg *.webp"' \
        '--control-image=+[ctrl img]:file:_files -g "*.png *.jpg *.jpeg *.webp"' \
        '--control-strength=+[F]:f:' \
        '--style-ratio=+[F]:f:' \
        '--type=+[wtype]:w:(f32 f16 q4_0 q4_1 q5_0 q5_1 q8_0 q2_K q3_K q3_K_S q4_K q4_K_S q5_K q5_K_S q6_K)' \
        '--rng=+[r]:r:(std_default cuda)' \
        '-o+[output file]:file:_files -g "*.png *.jpg *.jpeg *.webp"' \
        '--output=+[output file]:file:_files -g "*.png *.jpg *.jpeg *.webp"' \
        '--clip-skip=+[N]:n:' \
        '--upscale-model=+[file]:file:_files -g "*.gguf *.safetensors"' \
        '--upscale-repeats=+[N]:n:' \
        '--canny[apply Canny]' \
        '--color[color output]' \
        '--verbose-log[verbose log]'
}

_stable-diffusion "$@"
