#compdef cifbuild
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/cifbuild/node15.html
# Construct CCF Calibration or Master Index Files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--calindexset=[output calibration index set filename]:file:_files' \
  '--withccfpath=[use directories from ccfpath param]:bool:(yes no)' \
  '--usecanonicalname=[autogenerate CIF name from ODF identifier]:bool:(yes no)' \
  '--ccfpath=[colon-separated dirs to search for constituents]:path' \
  '--recurse=[recursively search subdirectories]:bool:(yes no)' \
  '--fileglob=[file name patterns to match constituents]:glob' \
  '--fullpath=[write complete path names in the index set]:bool:(yes no)' \
  '--withobservationdate=[use user-specified observation date]:bool:(yes no)' \
  '--observationdate=[date the observation was conducted]:date' \
  '--analysisdate=[date the analysis is performed]:date' \
  '--category=[category of constituents to locate]:category' \
  '--ignorecategory=[disable CATEGORY attribute filtering]:bool:(yes no)' \
  '--masterindex=[create a master calibration index set]:bool:(yes no)' \
  '--withmasterindexset=[use master index set]:bool:(yes no)' \
  '--masterindexset=[MIF filename for calibration evaluation]:file:_files' \
  '--append=[append constituents to an existing index set]:bool:(yes no)' \
  '*:param=value:_default' && ret=0

return ret
