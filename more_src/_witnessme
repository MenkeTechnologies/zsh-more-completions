#compdef witnessme

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'screenshot:screenshot web targets'
  'grab:grab data via XPath or links'
)

_arguments -C \
  '--threads=[concurrent tabs]:n:' \
  '--timeout=[timeout seconds]:n:' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'witnessme subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (screenshot)
        _arguments -s \
          '*'{-p,--ports}'=[ports]:port:' \
          '*:target:_files' && ret=0 ;;
      (grab)
        _arguments -s \
          '(-x --xpath)'{-x,--xpath}'=[XPath]:xpath:' \
          '(-l --links)'{-l,--links}'[get all links]' \
          '*:target:_files' && ret=0 ;;
    esac
    ;;
esac

return ret
