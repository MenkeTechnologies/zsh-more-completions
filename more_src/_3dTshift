#compdef 3dTshift
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTshift.html
# AFNI slice-timing correction for 3D+time datasets

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-verbose[print lots of messages]' \
  '-TR[override TR value]:tr' \
  '-tzero[align all slices to time offset]:offset' \
  '-slice[align slices to given slice number offset]:slice' \
  '-prefix[output file prefix]:prefix' \
  '-ignore[ignore first ii points]:count' \
  '-rlt[remove mean and linear trend, do not restore]' \
  '-rlt+[remove mean and linear trend, restore mean]' \
  '-no_detrend[do not remove or restore linear trend]' \
  '-Fourier[Fourier interpolation (default)]' \
  '-linear[linear interpolation]' \
  '-cubic[cubic Lagrange interpolation]' \
  '-quintic[quintic Lagrange interpolation]' \
  '-heptic[heptic Lagrange interpolation]' \
  '-wsinc5[weighted sinc interpolation +/-5]' \
  '-wsinc9[weighted sinc interpolation +/-9]' \
  '-tpattern[slice timing pattern]:pattern' \
  '-voxshift[per-voxel shift dataset]:dataset:_files' \
  '*:dataset:_files' && ret=0

return ret
