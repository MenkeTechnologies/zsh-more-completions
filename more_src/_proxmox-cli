#compdef proxmox-cli pveum pvesh pvesm pvecm qm pct
# _proxmox-cli — Proxmox Server Solutions GmbH proxmox-cli CLI command-line frontend wrapping the Proxmox Virtual Environment PVE complete open-source server virtualization management platform tightly integrating KVM hypervisor and LXC software-defined storage and networking written in Perl C originally Martin Maurer and Dietmar Maurer Proxmox VE pveum pvesh pvesm pvecm qm pct ha-manager pveceph pveperf pvereport pveversion pveproxy pvestatd pmxcfs ZFS Ceph storage backup backup-restore replication firewall HA cluster start stop reset restart shutdown create destroy clone migrate snapshot list status config (Proxmox Server Solutions GmbH team Martin Maurer Dietmar Maurer, Perl/C); custom argparse
# upstream: https://www.proxmox.com/

_proxmox-cli() {
    local -a sub=(
        'qm:KVM VM management'
        'pct:LXC container management'
        'pveum:user management'
        'pvesh:API shell'
        'pvesm:storage management'
        'pvecm:cluster management'
        'pveceph:Ceph operations'
        'pveperf:performance test'
        'pvereport:diagnostic report'
        'pveversion:show version'
        'ha-manager:HA manager'
        'pveproxy:proxy management'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--noheader[no header]' \
        '--output-format=+[fmt]:f:(text json json-pretty yaml)' \
        '--noborder[no border]' \
        '--noheader[no header]' \
        '--human-readable[human readable]' \
        '-H[human readable]' \
        '--vmid=+[id]:n:' \
        '--vmstateonly[VM state only]' \
        '--node=+[name]:str:' \
        '--storage=+[name]:str:' \
        '--bridge=+[name]:str:' \
        '--memory=+[MB]:n:' \
        '--cores=+[N]:n:' \
        '--sockets=+[N]:n:' \
        '--cpu=+[type]:str:' \
        '--ostype=+[t]:t:(other wxp w2k w2k3 w2k8 wvista win7 win8 win10 win11 l24 l26 solaris)' \
        '--ide0=+[options]:str:' \
        '--sata0=+[options]:str:' \
        '--scsi0=+[options]:str:' \
        '--virtio0=+[options]:str:' \
        '--net0=+[options]:str:' \
        '--bootdisk=+[name]:str:' \
        '--boot=+[order]:str:' \
        '--name=+[name]:str:' \
        '--description=+[text]:str:' \
        '--start[start after create]' \
        '--force[force]' \
        '--purge[purge]' \
        '--full[full clone]' \
        '--target=+[node]:str:' \
        '--source=+[node]:str:' \
        '--online[online migration]' \
        '--with-local-disks[with local disks]' \
        '--snapshot=+[name]:str:' \
        '--keep[keep]' \
        '--quiet[quiet]' \
        '--filesystem=+[options]:str:' \
        '--password=+[password]:str:' \
        '--hostname=+[host]:_hosts' \
        '--ostemplate=+[name]:str:' \
        '--rootfs=+[options]:str:' \
        '--mp0=+[options]:str:' \
        '--unprivileged=+[v]:v:(0 1)' \
        '--features=+[options]:str:' \
        '--ssh-public-keys=+[file]:file:_files' \
        '--all[apply to all]' \
        '--vms=+[ids]:str:' \
        '--type=+[t]:str:' \
        '--id=+[id]:str:' \
        '--mode=+[m]:str:' \
        '--state=+[s]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'proxmox subcommand' sub ;;
        args)
            case $words[1] in
                qm) _arguments '1:op:(start stop reset restart shutdown create destroy clone migrate suspend resume snapshot listsnapshot delsnapshot rollback config set status list monitor showcmd unlock template importovf importdisk move-disk pending sendkey rescan terminate cleanup mtunnel pendingthrow guest disk vmgenid wait reload)' '*:arg:' ;;
                pct) _arguments '1:op:(start stop restart shutdown create destroy clone migrate suspend resume snapshot listsnapshot delsnapshot rollback config set status list enter exec console pull push fsck template mount unmount move-volume resize unlock cpusets)' '*:arg:' ;;
                pveum) _arguments '1:op:(user group role acl ldap ad oidc tfa token)' '*:arg:' ;;
                pvesm) _arguments '1:op:(add remove list status path scan add iscsi nfs glusterfs cephfs zfspool rbd cifs)' '*:arg:' ;;
                pvecm) _arguments '1:op:(create add status nodes delnode addnode expected updatecerts qdevice keygen)' '*:arg:' ;;
                pveceph) _arguments '1:op:(install init createmgr createmon createosd destroyosd pool fs purge status lspools)' '*:arg:' ;;
                ha-manager) _arguments '1:op:(status add update remove config groupadd groupset groupremove migrate relocate crm-command)' '*:arg:' ;;
            esac
            ;;
    esac
}

_proxmox-cli "$@"
