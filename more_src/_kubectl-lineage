#compdef kubectl-lineage
# Documentation: https://man.archlinux.org/search?q=kubectl-lineage
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'=[namespace]:namespace' \
  '--all-namespaces[all namespaces]' \
  '--context=[kube context]:context' \
  '1:command:(tree list graph)' \
  '*:resource or args: _default'
