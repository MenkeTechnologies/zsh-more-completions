#compdef berks berkshelf
# Documentation: https://docs.chef.io/berkshelf/
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'apply:apply version locks to a Chef environment'
  'contingent:list cookbooks that depend on a given cookbook'
  'info:display information about a cookbook'
  'install:install cookbooks from the Berksfile'
  'list:list all cookbooks and their dependencies'
  'outdated:list outdated cookbooks'
  'package:package cookbooks into a tar.gz archive'
  'search:search for cookbooks on the remote source'
  'shelf:manage the local cookbook shelf'
  'show:display the path to a cookbook'
  'update:update all cookbooks or the given cookbook'
  'upload:upload cookbooks to the Chef Server'
  'vendor:vendor cookbooks into a directory'
  'verify:verify the Berksfile.lock'
  'version:display version'
  'help:describe available commands'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  {-c,--config}'[path to configuration file]:config file:_files' \
  {-F,--format}'[output format]:format:(table json)' \
  {-q,--quiet}'[suppress output]' \
  {-d,--debug}'[enable debug output]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'berks subcommand' subcommands && ret=0 ;;
  args) _normal && ret=0 ;;
esac

return ret
