#compdef cpptraj

# Amber cpptraj: trajectory analysis tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '--defines[print compile-time definitions]' \
  '--internal-version[print internal version]' \
  '-debug[set debug level]:level:' \
  '-p[topology file]:file:_files' \
  '-i[input script file]:file:_files' \
  '-y[trajectory file to read]:file:_files' \
  '-x[trajectory file to write]:file:_files' \
  '-c[reference coordinates]:file:_files' \
  '-d[data file output]:file:_files' \
  '-w[data file output (alt)]:file:_files' \
  '-r[restart input]:file:_files' \
  '-rsr[print resource summary on exit]' \
  '-mr[run in masterless mode]' \
  '--mpi[MPI mode]' \
  '--openmp[OpenMP mode]' \
  '--cuda[CUDA mode]' \
  '*::cpptraj script and args:_files' && ret=0
return ret
