#compdef cdrskin
# Documentation: https://man.archlinux.org/search?q=cdrskin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  'dev=[burner device]:dev:_files -g "/dev/*"' \
  '-v[verbose]' \
  '-vv[more verbose]' \
  '-vvv[even more verbose]' \
  '-vvvv[trace]' \
  'speed=[burn speed]:speed:' \
  'fs=[FIFO buffer size in bytes]:bytes:' \
  '-eject[eject after writing]' \
  '-dummy[simulate burn]' \
  '-dao[DAO mode]' \
  '-tao[TAO mode]' \
  '-sao[SAO mode]' \
  '-multi[allow multi-session]' \
  '-pad[pad short tracks]' \
  '-data[data track mode]' \
  '-mode2[mode 2]' \
  '-text[CD-TEXT]' \
  'blank=[blank disc]:type:(all fast deformat_quickest deformat_sequential format_overwrite format_if_needed format_if_dirty)' \
  'modesty_on_drive=[drive idle pattern]:value:' \
  '-format[format DVD+RW or BD-R]' \
  '-checkdrive[probe drive]' \
  '-toc[show TOC]' \
  '-prcap[print drive capabilities]' \
  '-msinfo[print multi-session info]' \
  '-load[load disc]' \
  '-tell_media_space[print free media space]' \
  '*:file:_files' && ret=0

return ret
