#compdef cdrskin
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/cdrskin.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  'dev=[burner device address]:dev:_files -g "/dev/*"' \
  '--devices[list accessible CD drives]' \
  '--device_links[list drives with symbolic links]' \
  '-scanbus[scan system for drives]' \
  '-v[verbose]' \
  '-vv[more verbose]' \
  '-vvv[even more verbose]' \
  '-vvvv[trace]' \
  'speed=[burn speed]:speed:' \
  'fs=[FIFO buffer size in bytes]:bytes:' \
  'padsize=[pad track with trailing zeros]:bytes:' \
  'tsize=[announce exact track size]:bytes:' \
  '-eject[eject after writing]' \
  '-dummy[simulate burn]' \
  '-dao[DAO (disc-at-once) mode]' \
  '-tao[TAO (track-at-once) mode]' \
  '-sao[SAO (session-at-once) mode]' \
  '-multi[keep media appendable for further sessions]' \
  '-pad[pad short tracks]' \
  '-audio[mark following tracks as audio]' \
  '-data[mark following tracks as data]' \
  '-mode2[mode 2 data]' \
  '-text[CD-TEXT]' \
  'blank=[blank or format disc]:type:(all fast deformat_quickest deformat_sequential format_overwrite format_if_needed format_if_dirty)' \
  'modesty_on_drive=[drive idle pattern]:value:' \
  '-format[format DVD+RW or BD-R]' \
  '-checkdrive[probe drive and exit]' \
  '-minfo[show loaded media details]' \
  '-toc[show TOC]' \
  '-prcap[print drive capabilities]' \
  '-msinfo[print multi-session info]' \
  '-load[load disc]' \
  '-tell_media_space[print free media space]' \
  '*:file:_files' && ret=0

return ret
