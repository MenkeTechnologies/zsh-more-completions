#compdef lbzcat
# Documentation: https://man.archlinux.org/search?q=lbzcat
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --decompress)'{-d,--decompress}'[decompress]' \
  '(-k --keep)'{-k,--keep}'[keep input file]' \
  '(-f --force)'{-f,--force}'[force]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-s --small)'{-s,--small}'[small mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-n --threads)'{-n,--threads}'+[threads]:n:' \
  '*:file:_files -g "*.bz2"' && ret=0

return ret
