#compdef rrdupdate
# Documentation: https://man.archlinux.org/search?q=rrdupdate
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-t --template)'{-t,--template}'+[ds names]:ds:' \
  '(-d --daemon)'{-d,--daemon}'+[rrdcached socket]:sock:' \
  '(-s --skip-past-updates)'{-s,--skip-past-updates}'[skip past updates]' \
  '*:rrd file:_files -g "*.rrd"' && ret=0

return ret
