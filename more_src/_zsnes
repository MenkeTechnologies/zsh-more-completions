#compdef zsnes
# Documentation: https://manpages.debian.org/bookworm/zsnes/zsnes.6.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm zsnes(6) manpage OPTIONS list. ZSNES is a
# Super Nintendo emulator (last release 1.51, 2007); options are
# single-dash short form. Prior file's bogus man.archlinux.org URL +
# fabricated -mv/-y/-? flags were removed in earlier audit.

# zsnes: Super Nintendo emulator (legacy)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[start in debug mode]' \
  '-v[run game in video mode N]:n:' \
  '-m[disable sound]' \
  '-i[sound interpolation: 0=none 1=linear 2=gaussian 3=cubic]:mode:(0 1 2 3)' \
  '-l[language]:lang:(0 1 2 3 4 5)' \
  '-r[reset on load]' \
  '-s[sound rate in Hz]:rate:(8000 11025 16000 22050 32000 44100 48000)' \
  '*:rom:_files -g "*.(smc|sfc|fig|zip|swc|jma)(-.)"' && ret=0
return ret
