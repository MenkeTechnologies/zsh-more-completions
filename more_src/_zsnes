#compdef zsnes

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-? -d[debug rom]' \
  '-v+[video mode]:mode:' \
  '-m[mute]' \
  '-mv[mute volume]' \
  '-i+[interpolation]:mode:' \
  '-l+[language]:lang:' \
  '-r[reset]' \
  '-s+[sound rate Hz]:rate:(8000 11025 16000 22050 32000 44100 48000)' \
  '-y[stereo]' \
  '*:rom:_files -g "*.{smc,sfc,zip}"' && ret=0

return ret
