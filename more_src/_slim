#compdef slim docker-slim

# Zsh completion for slim (formerly docker-slim) - container image optimizer

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'build:analyze and optimize a container image'
  'xray:inspect and analyze a container image'
  'lint:lint a Dockerfile'
  'profile:profile a container image'
  'version:show version information'
  'help:show help'
  'update:update slim'
  'images:list container images'
  'containerize:containerize a fat image'
  'convert:convert a container image'
  'run:run a containerized command'
  'merge:merge container images'
  'registry:interact with container registries'
  'vulnerability:scan for vulnerabilities'
  'debug:debug a containerized app'
  'install-sensor:install the slim sensor'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '--report[save report to a file]:file:_files' \
  '--check-version[check for new version]' \
  '--debug[enable debug logging]' \
  '--verbose[enable verbose logging]' \
  '--log-level[set log level]:level:(trace debug info warn error fatal panic)' \
  '--log[log file]:file:_files' \
  '--log-format[log format]:format:(text json)' \
  '--quiet[suppress all output]' \
  '--output-format[output format]:format:(text json)' \
  '--state-path[state directory path]:path:_files -/' \
  '--archive-state[archive state directory]:path:_files -/' \
  '--in-container[run in container mode]' \
  '--host[Docker host]:host:' \
  '--tls[use TLS to connect to Docker]' \
  '--tls-verify[verify TLS certificates]' \
  '--tls-cert-path[path to TLS certificates]:path:_files -/' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'slim subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (build|profile)
        _arguments \
          '--target[target image]:image:' \
          '--tag[custom tag for optimized image]:tag:' \
          '--http-probe[enable HTTP probing]' \
          '--http-probe-cmd[custom HTTP probe command]:command:' \
          '--http-probe-cmd-file[file with HTTP probe commands]:file:_files' \
          '--http-probe-ports[ports to probe]:ports:' \
          '--http-probe-full[do a full HTTP probe]' \
          '--http-probe-exit-on-failure[exit on HTTP probe failure]' \
          '--http-probe-crawl[crawl HTTP endpoints]' \
          '--show-clogs[show container logs]' \
          '--show-blogs[show build logs]' \
          '--copy-meta-artifacts[copy meta artifacts]:path:_files -/' \
          '--remove-file-artifacts[remove file artifacts]' \
          '--include-path[include path from original image]:path:' \
          '--include-path-file[file with paths to include]:file:_files' \
          '--include-bin[include binary from original image]:binary:' \
          '--include-exe[include executable from original image]:executable:' \
          '--include-shell[include shell in optimized image]' \
          '--exclude-pattern[exclude pattern]:pattern:' \
          '--exclude-mounts[exclude mounted volumes]' \
          '--mount[mount a volume]:volume:' \
          '--continue-after[continue after mode]:mode:(enter signal probe exec timeout)' \
          '--env[set environment variable]:key=value:' \
          '--workdir[set working directory]:directory:' \
          '--network[container network]:network:' \
          '--expose[expose a port]:port:' \
          '--publish[publish a port]:port:' \
          '--cmd[override CMD]:command:' \
          '--entrypoint[override ENTRYPOINT]:entrypoint:' \
          '--exec[execute command in container]:command:' \
          '--exec-file[file with commands to execute]:file:_files' \
          '--sensor-ipc-endpoint[sensor IPC endpoint]:endpoint:' \
          '--sensor-ipc-mode[sensor IPC mode]:mode:(proxy)' && ret=0
        ;;
      (xray)
        _arguments \
          '--target[target image]:image:' \
          '--changes[change types to detect]:types:' \
          '--layer[select specific layers]:layer:' \
          '--add-image-manifest[add image manifest to report]' \
          '--add-image-config[add image config to report]' \
          '--rm-file-artifacts[remove file artifacts]' \
          '--hash-data[hash data in report]:algorithm:(sha256 sha512 md5)' \
          '--detect-duplicates[detect duplicate files]' \
          '--show-duplicates[show duplicate files]' \
          '--show-special-perms[show files with special permissions]' \
          '--detect-all-certs[detect all certificates]' \
          '--detect-all-cert-pks[detect all certificate private keys]' \
          '--top-changes-max[max number of top changes]:count:' && ret=0
        ;;
      (lint)
        _arguments \
          '--target[target Dockerfile]:file:_files -g "Dockerfile*"' \
          '--target-type[target type]:type:(dockerfile)' \
          '--skip-check[skip check]:check ID:' \
          '--include-check[include check]:check ID:' \
          '--show-nohits[show rules with no hits]' \
          '--show-snippet[show code snippet]' \
          '--list-checks[list available checks]' && ret=0
        ;;
    esac
    ;;
esac

return ret
