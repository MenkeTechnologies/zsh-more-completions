#compdef cargo-llvm-cov

# Zsh completion for cargo-llvm-cov (Rust LLVM source-based code coverage)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'test:Run tests and generate coverage (default)'
      'run:Run a binary or example and generate coverage'
      'report:Generate coverage report from stored data'
      'show-env:Output env vars needed for coverage builds'
      'clean:Remove artifacts generated by cargo-llvm-cov'
      'nextest:Run tests with cargo-nextest and generate coverage'
    )
    _describe -t commands 'cargo-llvm-cov command' commands && ret=0
    ;;
  args)
    local -a common_flags=(
      '-h[Print help]'
      '--help[Print help]'
      '-v[Use verbose output]'
      '--verbose[Use verbose output]'
      '--color=[Coloring]:when:(auto always never)'
      '--manifest-path=[Path to Cargo.toml]:file:_files'
      '-p+[Package to test]:package'
      '--package=[Package to test]:package'
      '--exclude=[Packages to exclude]:package'
      '--workspace[Test all packages in workspace]'
      '--all[Alias for --workspace]'
      '--lib[Test only library targets]'
      '--bin=[Test only the specified binary]:name'
      '--bins[Test all binary targets]'
      '--example=[Test only the specified example]:name'
      '--examples[Test all example targets]'
      '--test=[Test only the specified test target]:name'
      '--tests[Test all test targets]'
      '--bench=[Test only the specified bench target]:name'
      '--benches[Test all bench targets]'
      '--doc[Test only documentation tests]'
      '--all-targets[Test all targets]'
      '--release[Build in release mode]'
      '--profile=[Build with the specified profile]:profile'
      '-j+[Number of parallel jobs]:jobs'
      '--jobs=[Number of parallel jobs]:jobs'
      '--features=[Features to compile]:features'
      '--all-features[Activate all features]'
      '--no-default-features[Do not activate the default feature]'
      '--target=[Target triple]:target'
      '--target-dir=[Directory for generated artifacts]:dir:_directories'
      '--frozen[Require Cargo.lock and cache are up to date]'
      '--locked[Require Cargo.lock is up to date]'
      '--offline[Run without accessing the network]'
      '--ignore-filename-regex=[Skip files matching regex]:regex'
      '--ignore-run-fail[Continue even if tests fail]'
      '--no-cfg-coverage[Do not set cfg=coverage]'
      '--no-cfg-coverage-nightly[Do not set cfg=coverage_nightly]'
      '--no-report[Run tests but do not generate report]'
      '--fail-under-functions=[Fail if function coverage below threshold]:percent'
      '--fail-under-lines=[Fail if line coverage below threshold]:percent'
      '--fail-under-regions=[Fail if region coverage below threshold]:percent'
      '--show-missing-lines[Show missing lines after running tests]'
      '--include-build-script[Include build scripts in coverage]'
      '--dep-coverage=[Show coverage of specified dependency]:crate'
      '--skip-functions[Skip functions in coverage report]'
      '--branch[Enable branch coverage]'
    )

    local -a output_flags=(
      '--text[Output text coverage report]'
      '--html[Output HTML coverage report]'
      '--open[Open HTML report in browser]'
      '--lcov[Output coverage in lcov format]'
      '--json[Output coverage in JSON format]'
      '--cobertura[Output coverage in Cobertura XML format]'
      '--codecov[Output coverage in Codecov JSON format]'
      '--summary-only[Show only summary in report]'
      '--output-path=[Output file for report]:file:_files'
      '--output-dir=[Output directory for HTML report]:dir:_directories'
    )

    case ${words[1]} in
      test)
        _arguments -s -S \
          $common_flags \
          $output_flags \
          '--no-run[Compile but do not run tests]' \
          '--doctests[Include doc tests in coverage]' \
          '*:args' && ret=0
        ;;
      run)
        _arguments -s -S \
          $common_flags \
          $output_flags \
          '*:args' && ret=0
        ;;
      report)
        _arguments -s -S \
          $common_flags \
          $output_flags && ret=0
        ;;
      show-env)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--export-prefix[Prepend export to env var output]' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-v[Use verbose output]' \
          '--verbose[Use verbose output]' \
          '--manifest-path=[Path to Cargo.toml]:file:_files' \
          '--target-dir=[Directory for generated artifacts]:dir:_directories' \
          '--workspace[Clean all packages in workspace]' && ret=0
        ;;
      nextest)
        _arguments -s -S \
          $common_flags \
          $output_flags \
          '--doctests[Include doc tests in coverage]' \
          '--no-run[Compile but do not run tests]' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
