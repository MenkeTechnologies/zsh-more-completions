#compdef nw_indent
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: indent Newick for readability.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-c[compact: remove indentation]' \
  '-t+[indentation text (default two spaces)]:text:' \
  '*:newick file:_files' && ret=0

return ret
