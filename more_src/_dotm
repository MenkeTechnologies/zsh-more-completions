autoload -U is-at-least

_dotm() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-d+[Path to the dotfiles directory (default\: current directory)]:DIR:_files' \
'--dir=[Path to the dotfiles directory (default\: current directory)]:DIR:_files' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_dotm_commands" \
"*::: :->dotm" \
&& ret=0
    case $state in
    (dotm)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dotm-command-$line[1]:"
        case $line[1] in
            (deploy)
_arguments "${_arguments_options[@]}" : \
'--host=[Target host (defaults to system hostname)]:HOST:_default' \
'-p+[Deploy only this package (and its dependencies)]:PACKAGE:_default' \
'--package=[Deploy only this package (and its dependencies)]:PACKAGE:_default' \
'--dry-run[Show what would be done without making changes]' \
'--force[Overwrite existing unmanaged files]' \
'--system[Operate on system packages (requires root)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(undeploy)
_arguments "${_arguments_options[@]}" : \
'-p+[Undeploy only this package]:PACKAGE:_default' \
'--package=[Undeploy only this package]:PACKAGE:_default' \
'--system[Operate on system packages (requires root)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'-p+[Filter to a specific package]:PACKAGE:_default' \
'--package=[Filter to a specific package]:PACKAGE:_default' \
'-v[Show all files, not just problems]' \
'--verbose[Show all files, not just problems]' \
'-s[One-line summary for shell integration (no output when clean)]' \
'--short[One-line summary for shell integration (no output when clean)]' \
'--system[Operate on system packages (requires root)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(diff)
_arguments "${_arguments_options[@]}" : \
'--host=[Target host (defaults to system hostname)]:HOST:_default' \
'--system[Operate on system packages (requires root)]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Only show diff for a specific file path:_default' \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
'--warn-suggestions[Warn about undeployed suggested packages]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':name -- Package name:_default' \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
'--force[Overwrite if file already exists in package]' \
'--system[Operate on system packages]' \
'-h[Print help]' \
'--help[Print help]' \
':package -- Package to add files to:_default' \
'*::files -- Files to add:_files' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_dotm__subcmd__list_commands" \
"*::: :->list" \
&& ret=0

    case $state in
    (list)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dotm-list-command-$line[1]:"
        case $line[1] in
            (packages)
_arguments "${_arguments_options[@]}" : \
'-v[Show package details]' \
'--verbose[Show package details]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(roles)
_arguments "${_arguments_options[@]}" : \
'-v[Show included packages]' \
'--verbose[Show included packages]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(hosts)
_arguments "${_arguments_options[@]}" : \
'-v[Show assigned roles]' \
'--verbose[Show assigned roles]' \
'--tree[Show host → role → package tree]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_dotm__subcmd__list__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dotm-list-help-command-$line[1]:"
        case $line[1] in
            (packages)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(roles)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(hosts)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(commit)
_arguments "${_arguments_options[@]}" : \
'-m+[Commit message (auto-generated if not provided)]:MESSAGE:_default' \
'--message=[Commit message (auto-generated if not provided)]:MESSAGE:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(push)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(pull)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(restore)
_arguments "${_arguments_options[@]}" : \
'-p+[Filter to a specific package]:PACKAGE:_default' \
'--package=[Filter to a specific package]:PACKAGE:_default' \
'--system[Restore only system packages]' \
'--dry-run[Show what would be done without making changes]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(prune)
_arguments "${_arguments_options[@]}" : \
'--host=[Target host (defaults to system hostname)]:HOST:_default' \
'--dry-run[Show what would be pruned without removing]' \
'--system[Operate on system packages]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(sync)
_arguments "${_arguments_options[@]}" : \
'--host=[Target host (defaults to system hostname)]:HOST:_default' \
'--no-push[Skip pushing after deploy]' \
'--force[Overwrite existing unmanaged files]' \
'--system[Operate on system packages (requires root)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_dotm__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dotm-help-command-$line[1]:"
        case $line[1] in
            (deploy)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(undeploy)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(diff)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
":: :_dotm__subcmd__help__subcmd__list_commands" \
"*::: :->list" \
&& ret=0

    case $state in
    (list)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dotm-help-list-command-$line[1]:"
        case $line[1] in
            (packages)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(roles)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(hosts)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
(commit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(push)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(pull)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(restore)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(prune)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(sync)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_dotm_commands] )) ||
_dotm_commands() {
    local commands; commands=(
'deploy:Deploy configs for the current host' \
'undeploy:Remove all managed symlinks and copies' \
'status:Show deployment status' \
'diff:Show diffs for files modified since last deploy' \
'check:Validate configuration' \
'init:Initialize a new package' \
'add:Add existing files to a package' \
'list:List available packages, roles, or hosts' \
'commit:Commit all changes in the dotfiles repository' \
'push:Push dotfiles repository to remote' \
'pull:Pull dotfiles repository from remote' \
'completions:Generate shell completions' \
'restore:Restore files to their pre-dotm state' \
'prune:Remove files that are no longer managed by any package' \
'sync:Pull, deploy, and optionally push in one step' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'dotm commands' commands "$@"
}
