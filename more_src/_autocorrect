#compdef autocorrect
# Documentation: https://man.archlinux.org/search?q=autocorrect
# Reference accessed: 2026-05-16

# huacnlee/autocorrect autocorrect-cli — src/cli.rs (clap)

local curcontext="$curcontext" state line ret=1

local -a base=(
  '--lint[lint and report problems]'
  '--fix[rewrite files with fixes]'
  '--debug[verbose debug logging]'
  '(-q)--quiet[suppress progress]'
  '--format=[output format]:format:(diff json rdjson)'
  '--threads=[worker threads; 0=CPUs]:count:'
  '(-c)'{-c+,--config=}'[config file]:file:_files'
  '--type=[force syntax]:type:'
  '--stdin[read text from stdin]'
  '--no-diff-bg-color[disable diff background color]'
  '--ndbc[alias of --no-diff-bg-color]'
  '--strict[warnings yield non-zero exit]'
  '1:path:_files -/'
)

_arguments -s -S \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd)
    local -a cmds=(
      'init:write default autocorrect config'
      'server:start LSP server'
      'update:update autocorrect (if built with feature)'
    )
    _alternative \
      "subcommands:subcommand:($cmds)" \
      "files:file:_path_files -/" && ret=0
    ;;
  (rest)
    case $line[1] in
      (init)
        _arguments -s -S \
          '--local[use built-in config without download]' \
          '(-f)--force[overwrite existing config]' && ret=0
        ;;
      (server|update)
        _nothing
        ret=0
        ;;
      (*)
        _arguments -s -S $base '*:path:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
