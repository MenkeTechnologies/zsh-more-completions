#compdef pridefetch

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --flag)'{-f,--flag}'[specify pride flag]:flag:(gay lesbian bi trans enby pan ace aro aroace genderfluid genderqueer agender)' \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
  '--small[use small flag art]' \
  '--large[use large flag art]' \
  '--list-flags[list available flags]' \
  '--id[override distro ID]:distro id' \
  && ret=0

return ret
