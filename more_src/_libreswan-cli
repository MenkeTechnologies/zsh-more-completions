#compdef libreswan-cli
# _libreswan-cli — Libreswan IPsec implementation for Linux CLI alias (libreswan team, C); custom argparse via ipsec command
# upstream: https://github.com/libreswan/libreswan

_libreswan-cli() {
    local -a sub=(
        'addconn:add connection from config file'
        'algparse:debug algorithm parsing'
        'auto:control IKE connections'
        'auto --add:add connection'
        'auto --delete:delete connection'
        'auto --listen:reload and listen'
        'auto --rereadall:reread all'
        'auto --rereadcerts:reread certs'
        'auto --rereadsecrets:reread secrets'
        'auto --route:route connection'
        'auto --unroute:unroute connection'
        'auto --replace:replace connection'
        'auto --up:start connection'
        'auto --down:stop connection'
        'auto --start:start connection'
        'auto --status:show status'
        'auto --statusall:show all status'
        'briefstatus:brief status'
        'certutil:cert utility'
        'checkconfig:check configuration'
        'checknflog:check nflog'
        'checknss:check NSS db'
        'crlutil:CRL utility'
        'dbg:show debug info'
        'fipsstatus:show FIPS status'
        'getpeercon_server:get peercon server'
        'import:import certs'
        'initnss:init NSS database'
        'krb5:Kerberos commands'
        'letsencrypt:Let'\''s Encrypt cert helper'
        'listall:list all certs'
        'listcacerts:list CA certs'
        'listcerts:list certs'
        'listcrls:list CRLs'
        'listpubkeys:list pubkeys'
        'modutil:NSS modutil'
        'newhostkey:generate host key'
        'nss:NSS commands'
        'pk12util:PKCS12 utility'
        'pluto:run pluto daemon'
        'purgeocsp:purge OCSP cache'
        'readwriteconf:read/write config'
        'restart:restart ipsec'
        'rsasigkey:generate RSA signing key'
        'secrets:secrets reread'
        'send-pr:report bugs'
        'setup:setup script'
        'show:show config'
        'showhostkey:show host key'
        'showroute:show route'
        'shuntstatus:show shunt status'
        'start:start ipsec'
        'status:show status'
        'stop:stop ipsec'
        'trafficstatus:show traffic status'
        'unbound:unbound dns daemon'
        'verify:verify install'
        'version:show version'
        'whack:talk to pluto'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "ipsec.conf"' \
        '--secrets=+[secrets file]:file:_files -g "ipsec.secrets"' \
        '--name=+[connection name]:str:' \
        '--ctlsocket=+[ctl socket]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ipsec subcommand' sub ;;
    esac
}

_libreswan-cli "$@"
