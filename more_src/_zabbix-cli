#compdef zabbix-cli

_zabbix_cli_commands() {
    local -a commands
    commands=(
        'show_alarms:Show active alarms'
        'show_host:Show host information'
        'show_hosts:List hosts'
        'show_hostgroups:List host groups'
        'show_templates:List templates'
        'show_items:Show items for a host'
        'show_triggers:Show triggers'
        'show_usermacro:Show user macros'
        'show_global_macros:Show global macros'
        'show_users:List users'
        'show_usergroups:List user groups'
        'create_host:Create a new host'
        'create_hostgroup:Create a new host group'
        'create_user:Create a new user'
        'create_usergroup:Create a new user group'
        'update_host:Update host properties'
        'remove_host:Remove a host'
        'add_host_to_hostgroup:Add host to a host group'
        'remove_host_from_hostgroup:Remove host from a host group'
        'link_template_to_host:Link a template to a host'
        'unlink_template_from_host:Unlink a template from a host'
        'acknowledge_event:Acknowledge an event/alarm'
        'acknowledge_trigger:Acknowledge a trigger'
        'enable_host:Enable a host'
        'disable_host:Disable a host'
        'enable_trigger:Enable a trigger'
        'disable_trigger:Disable a trigger'
        'create_maintenance:Create a maintenance window'
        'delete_maintenance:Delete a maintenance window'
        'show_maintenance:Show maintenance windows'
        'export_configuration:Export Zabbix configuration'
        'import_configuration:Import Zabbix configuration'
        'define_global_macro:Define a global macro'
        'define_host_usermacro:Define a host macro'
    )
    _describe -t commands 'zabbix-cli command' commands
}

_zabbix_cli() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '(-c --config)'{-c,--config}'[Configuration file]:file:_files' \
        '--output[Output format]:format:(json csv table)' \
        '--url[Zabbix server URL]:url:' \
        '--user[Username]:user:' \
        '--auth-token[Authentication token]:token:' \
        '(-C --command)'{-C,--command}'[Run a single command]:command:' \
        '(-f --file)'{-f,--file}'[Execute commands from file]:file:_files' \
        '1:command:_zabbix_cli_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                show_host|update_host|remove_host|enable_host|disable_host)
                    _arguments '1:hostname:'
                    ;;
                show_hosts)
                    _arguments \
                        '--hostgroup[Filter by host group]:group:' \
                        '--limit[Limit results]:limit:'
                    ;;
                create_host)
                    _arguments \
                        '1:hostname:' \
                        '2:hostgroup:' \
                        '3:proxy:' \
                        '4:status:(enabled disabled)'
                    ;;
                link_template_to_host|unlink_template_from_host)
                    _arguments '1:template:' '2:hostname:'
                    ;;
                add_host_to_hostgroup|remove_host_from_hostgroup)
                    _arguments '1:hostname:' '2:hostgroup:'
                    ;;
                acknowledge_event)
                    _arguments '1:event_id:' '2:message:'
                    ;;
                create_maintenance)
                    _arguments \
                        '1:name:' \
                        '2:hostgroup:' \
                        '3:duration:' \
                        '4:description:'
                    ;;
                export_configuration)
                    _arguments \
                        '1:directory:_directories' \
                        '2:type:(hosts hostgroups templates)'
                    ;;
                import_configuration)
                    _arguments '1:file:_files'
                    ;;
            esac
            ;;
    esac
}

_zabbix_cli "$@"
