#compdef prusti-rustc cargo-prusti
# _prusti-rustc — Prusti: Viper-backed Rust verifier (viperproject/prusti-dev)
# upstream: https://github.com/viperproject/prusti-dev
# Flags configured via PRUSTI_* env vars or --PRUSTI-LONG= long names; rustc args pass through.

_prusti-rustc() {
    local -a args
    args=(
        '--check-overflows[enable arithmetic overflow checks (PRUSTI_CHECK_OVERFLOWS)]'
        '--check-panics[verify that explicit panics are unreachable (PRUSTI_CHECK_PANICS)]'
        '--no-verify[parse and type-check without running verification (PRUSTI_NO_VERIFY)]'
        '--full-compilation[compile after verification (PRUSTI_FULL_COMPILATION)]'
        '--print-desugared-specs[print desugared specifications]'
        '--print-typeckd-specs[print specifications after type-checking]'
        '--print-collected-verification-items[print items selected for verification]'
        '--server-address=[Viper server address (PRUSTI_SERVER_ADDRESS)]:host\:port:'
        '--server-max-stored-verifiers=[max cached verifier instances on the server]:count:'
        '--backend=[verification backend]:backend:(Silicon Carbon)'
        '--use-more-complete-exhale[use more complete exhale in Silicon]'
        '--check-foldunfold-state[debug: assert fold/unfold state consistency]'
        '--encode-unsigned-num-constraint[encode unsigned numeric constraints]'
        '--cargo-path=[path to cargo for cargo-prusti]:cargo:_files'
        '--log=[RUST_LOG style log filter for Prusti (PRUSTI_LOG)]:filter:'
        '--log-dir=[directory for Prusti log output (PRUSTI_LOG_DIR)]:dir:_files -/'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '*:Rust source file:_files -g "*.rs"'
    )
    _arguments -s -S $args
}

_prusti-rustc "$@"
