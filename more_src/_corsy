#compdef corsy

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-u --url)'{-u,--url}'[Single URL to test]:url:' \
  '(-i --input)'{-i,--input}'[File containing URLs to test]:file:_files' \
  '(-t --threads)'{-t,--threads}'[Number of threads]:number:' \
  '(-d --delay)'{-d,--delay}'[Delay between requests in seconds]:seconds:' \
  '(-o --output)'{-o,--output}'[Output file for results]:file:_files' \
  '--headers[Custom headers as JSON string]:headers:' \
  '--origin[Custom origin to test]:origin:' \
  '--timeout[Request timeout in seconds]:seconds:' \
  '--only-supported[Only test supported origins]' \
  '(- *)--help[Show help message]' \
  && ret=0

return ret
