#compdef awx awx-cli

local curcontext="$curcontext" state line ret=1
local -a resources

resources=(
  'login:authenticate to AWX'
  'logout:remove stored credentials'
  'config:show current config'
  'ping:ping the AWX server'
  'monitor:monitor a running job'
  'send:send objects (export)'
  'receive:receive objects (import)'
  'import:import objects'
  'export:export objects'
  'me:show current user'
  'metrics:show server metrics'
  'mesh_visualizer:show mesh visualizer'
  'ad_hoc:ad-hoc commands'
  'application:OAuth applications'
  'credential:credentials'
  'credential_type:credential types'
  'execution_environment:execution environments'
  'group:host groups'
  'host:hosts'
  'instance:control plane instances'
  'instance_group:instance groups'
  'inventories:inventories'
  'inventory_source:inventory sources'
  'inventory_update:inventory updates'
  'job:jobs'
  'job_template:job templates'
  'label:labels'
  'node:workflow nodes'
  'notification_template:notification templates'
  'organization:organizations'
  'project:projects'
  'project_update:project updates'
  'role:roles'
  'schedule:schedules'
  'setting:settings'
  'team:teams'
  'user:users'
  'workflow:workflow job templates'
  'workflow_job:workflow jobs'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-f --conf.format)'{-f,--conf.format=}'[output format]:format:(json yaml human)' \
  '--conf.host=[AWX host URL]:url:' \
  '(-k --conf.insecure)'{-k,--conf.insecure}'[skip TLS verification]' \
  '--conf.username=[AWX username]:user:_users' \
  '--conf.password=[AWX password]:password:' \
  '--conf.token=[AWX token]:token:' \
  '1: :->resource' \
  '*::arg:->args' && ret=0

case $state in
  (resource)
    _describe -t resources 'awx resource' resources && ret=0
    ;;
  (args)
    case $line[1] in
      (job_template|workflow|workflow_job_template)
        _values 'action' \
          'get' 'list' 'create' 'modify' 'delete' 'launch' 'survey_spec' 'copy' \
          'associate' 'disassociate' && ret=0
        ;;
      (job|workflow_job)
        _values 'action' \
          'get' 'list' 'cancel' 'relaunch' 'stdout' 'events' && ret=0
        ;;
      (project)
        _values 'action' \
          'get' 'list' 'create' 'modify' 'delete' 'update' 'copy' && ret=0
        ;;
      (inventory|inventories|host|group|inventory_source)
        _values 'action' \
          'get' 'list' 'create' 'modify' 'delete' 'copy' 'update' \
          'associate' 'disassociate' && ret=0
        ;;
      (credential|credential_type|organization|team|user|label|schedule|notification_template|application|execution_environment|instance_group)
        _values 'action' \
          'get' 'list' 'create' 'modify' 'delete' 'copy' && ret=0
        ;;
      (role)
        _values 'role action' 'get' 'list' 'grant' 'revoke' && ret=0
        ;;
    esac
    ;;
esac

return ret
