#compdef pylint-config
# Documentation: https://man.archlinux.org/search?q=pylint-config
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'generate:generate a sample pylintrc'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pylint-config subcommand' subcommands && ret=0
    ;;
esac

return ret
