#compdef scylla scyllatop nodetool
# Documentation:
#   scylla: https://github.com/scylladb/scylladb/blob/master/db/config.cc
#   scyllatop: https://github.com/scylladb/scylladb/blob/master/tools/scyllatop/scyllatop.py
#   nodetool: https://github.com/scylladb/scylladb/blob/master/tools/scylla-nodetool.cc
# Reference accessed: 2026-05-21
# Verified: upstream sources at the URLs above.
# Removed from prior file: --enable-cdc (no such CLI flag in db/config.cc;
# "cdc" is a feature::UNUSED entry, not a CLI option), scyllatop -c/-l/-a
# (wrong meanings: -c is --collectd boolean, -l is --list boolean, -a doesn't
# exist), nodetool -p as solo port (real is -p/--port with --rest-api-port
# precedence) and -u with no long form (real is --username/-u).

local curcontext="$curcontext" state line ret=1

case $service in
  (scylla)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '--help-loggers[show loggers]' \
      '--default-log-level+[default log level]:level:(trace debug info warn error)' \
      '--log-to-syslog+[log to syslog]:bool:(0 1)' \
      '--log-to-stdout+[log to stdout]:bool:(0 1)' \
      '--cluster-name+[cluster name]:name:' \
      '--listen-address+[listen address]:addr:' \
      '--rpc-address+[RPC address]:addr:' \
      '--broadcast-address+[broadcast address]:addr:' \
      '--broadcast-rpc-address+[broadcast RPC address]:addr:' \
      '--api-address+[API address]:addr:' \
      '--api-port+[API port]:port:' \
      '--prometheus-address+[prometheus address]:addr:' \
      '--prometheus-port+[prometheus port]:port:' \
      '--prometheus-prefix+[prometheus metric prefix]:prefix:' \
      '--seed-provider-class-name+[seed provider class]:class:' \
      '--seed-provider-parameters+[seed provider params]:params:' \
      '--data-file-directories+[data dirs csv]:list:' \
      '--commitlog-directory+[commitlog dir]:dir:_files -/' \
      '--hints-directory+[hints dir]:dir:_files -/' \
      '--saved-caches-directory+[saved caches dir]:dir:_files -/' \
      '--workdir+[work dir]:dir:_files -/' \
      '--developer-mode+[dev mode]:bool:(0 1)' \
      '--smp+[SMP threads]:n:' \
      '--memory+[memory size]:size:' \
      '--reserve-memory+[reserve memory]:size:' \
      '--cpuset+[CPU set]:set:' \
      '--num-tokens+[num tokens]:n:' \
      '--overprovisioned[overprovisioned]' \
      '--abort-on-seastar-bad-alloc[abort on seastar bad_alloc]' \
      '--abort-on-lsa-bad-alloc+[abort on LSA bad_alloc]:bool:(0 1)' \
      '--task-quota-ms+[task quota ms]:ms:' \
      '--blocked-reactor-notify-ms+[blocked reactor threshold ms]:ms:' \
      '--authenticator+[authenticator]:class:(AllowAllAuthenticator PasswordAuthenticator)' \
      '--authorizer+[authorizer]:class:(AllowAllAuthorizer CassandraAuthorizer)' \
      '--alternator-address+[Alternator address]:addr:' \
      '--alternator-port+[Alternator port]:port:' \
      '--alternator-https-port+[Alternator HTTPS port]:port:' \
      '--alternator-write-isolation+[alternator write isolation]:mode:(only_rmw_uses_lwt always_use_lwt forbid_rmw unsafe_rmw)' \
      '--enable-tablets+[enable tablets]:bool:(true false)' \
      '--io-properties-file+[IO properties YAML]:file:_files -g "*.yaml"' \
      '--max-io-requests+[max IO requests]:n:' \
      '*--config-file=[config file]:file:_files -g "*.yaml"' && ret=0 ;;
  (scyllatop)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-v --verbosity)'{-v+,--verbosity=}'[python log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
      '(-i --interval)'{-i+,--interval=}'[refresh interval seconds]:seconds:' \
      '(-s --socket)'{-s+,--socket=}'[collectd unixsock path]:file:_files' \
      '(-p --prometheus-address)'{-p+,--prometheus-address=}'[prometheus endpoint URL]:url:' \
      '--print-config[print collectd.conf snippet]' \
      '(-l --list)'{-l,--list}'[list all metrics]' \
      '(-c --collectd)'{-c,--collectd}'[use collectd instead of Prometheus]' \
      '(-L --logfile)'{-L+,--logfile=}'[log file path]:file:_files' \
      '(-S --shell)'{-S,--shell}'[enter IPython debug shell]' \
      '(-F --fake)'{-F,--fake}'[fake metric updates (dev only)]' \
      '(-n --iterations)'{-n+,--iterations=}'[exit after N iterations]:n:' \
      '(-b --batch)'{-b,--batch}'[batch mode: dump to stdout]' \
      '(-t --ttl)'{-t+,--ttl=}'[absent metric TTL seconds]:seconds:' \
      '*:metric pattern:' && ret=0 ;;
  (nodetool)
    _arguments -C \
      '(-h --host)'{-h+,--host=}'[ScyllaDB node hostname/ip]:host:_hosts' \
      '(-p --port)'{-p+,--port=}'[REST API port]:port:' \
      '--rest-api-port=[REST API port (takes precedence)]:port:' \
      '(-u --username)'{-u+,--username=}'[remote jmx username (unused)]:user:_users' \
      '--password=[remote jmx password (unused)]:pass:' \
      '-pw+[remote jmx password (unused)]:pass:' \
      '--password-file=[jmx password file (unused)]:file:_files' \
      '-pwf+[jmx password file (unused)]:file:_files' \
      '(-pp --print-port)'{-pp,--print-port}'[disambiguate hosts by port]' \
      '*::subcommand:_files' && ret=0 ;;
esac

return ret
