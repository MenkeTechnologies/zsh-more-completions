#compdef scylla scyllatop nodetool

local curcontext="$curcontext" state line ret=1

case $service in
  (scylla)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '--help-loggers[show loggers]' \
      '--default-log-level+[default log level]:l:(trace debug info warn error)' \
      '--log-to-syslog+[log to syslog]:b:(0 1)' \
      '--log-to-stdout+[log to stdout]:b:(0 1)' \
      '--cluster-name+[cluster name]:name:' \
      '--listen-address+[listen address]:addr:' \
      '--rpc-address+[RPC address]:addr:' \
      '--api-address+[API address]:addr:' \
      '--api-port+[API port]:port:' \
      '--prometheus-address+[prometheus address]:addr:' \
      '--prometheus-port+[prometheus port]:port:' \
      '--seeds+[seed nodes csv]:list:' \
      '--seed-provider+[seed provider]:p:' \
      '--data-file-directories+[data dirs csv]:list:' \
      '--commitlog-directory+[commitlog dir]:dir:_files -/' \
      '--workdir+[work dir]:dir:_files -/' \
      '--developer-mode+[dev mode]:b:(0 1)' \
      '--smp+[SMP threads]:n:' \
      '--memory+[memory]:size:' \
      '--reserve-memory+[reserve memory]:size:' \
      '--num-tokens+[num tokens]:n:' \
      '--alternator-port+[alternator port]:port:' \
      '--alternator-write-isolation+[alt write iso]:i:(only_rmw_uses_lwt always_use_lwt forbid_rmw unsafe_rmw)' \
      '--enable-cdc+[enable CDC]:b:(true false)' \
      '--enable-tablets+[enable tablets]:b:(true false)' \
      '--io-properties-file+[io properties]:file:_files' \
      '*: :' && ret=0 ;;
  (scyllatop)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '-c+[columns]:n:' \
      '-l+[limit]:n:' \
      '-a+[address]:addr:' \
      '-i+[interval ms]:ms:' \
      '*: :' && ret=0 ;;
  (nodetool)
    _arguments -C \
      '(- *)-h[host]:host:_hosts' \
      '-p+[port]:port:' \
      '-u+[user]:user:_users' \
      '-pw+[password]:pass:' \
      '-pwf+[password file]:file:_files' \
      '*::: :_files' && ret=0 ;;
esac

return ret
