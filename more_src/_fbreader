#compdef fbreader FBReader
# Documentation: https://man.archlinux.org/search?q=fbreader
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[show version]' \
  '*:ebook:_files -g "*.{epub,fb2,mobi,html,txt,rtf,chm,pdb}"' && ret=0

return ret
