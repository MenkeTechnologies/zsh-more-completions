#compdef cyrus-sync_reset
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/sync_reset.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org sync_reset(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-sync_reset: destroy replica account contents on Cyrus replica
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-f --force)'{-f,--force}'[force operation (required safety guard)]' \
  '*:user:_users' && ret=0
return ret
