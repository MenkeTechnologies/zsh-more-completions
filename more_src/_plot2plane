#compdef plot2plane
# Documentation: https://www.star.bris.ac.uk/~mbt/stilts/sun256/plot2plane-usage.html
# STILTS: draw a plot on 2-dimensional plane axes

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'xpix=[output image X size in pixels]:int:' \
  'ypix=[output image Y size in pixels]:int:' \
  'insets=[padding around plotting area]:insets:' \
  'omode=[output mode]:mode:(swing out cgi discard auto)' \
  'out=[output file location]:out:_files' \
  'ofmt=[output graphics format]:fmt:' \
  'storage=[data storage policy]:storage:(simple memory disk policy cache basic-cache persistent parallel)' \
  'legend=[display legend]:legend:(true false null)' \
  'xmin=[X axis data minimum]:double:' \
  'xmax=[X axis data maximum]:double:' \
  'ymin=[Y axis data minimum]:double:' \
  'ymax=[Y axis data maximum]:double:' \
  'xscale=[X axis scaling]:scale:(linear log asinh symlog)' \
  'yscale=[Y axis scaling]:scale:(linear log asinh symlog)' \
  'xlabel=[X axis label]:label:' \
  'ylabel=[Y axis label]:label:' \
  'title=[plot title text]:title:' \
  'grid=[display grid lines]:grid:(true false)' \
  '*:arg:' && ret=0

return ret
