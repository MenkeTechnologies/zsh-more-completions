#compdef ttxn
# Documentation: https://adobe-type-tools.github.io/afdko/AFDKO-Overview.html
# AFDKO: normalized ttx-style dump for comparing fonts

local ret=1

_arguments -s -S \
  '-nh[suppress hints in the glyph outline dump]' \
  '-nv[suppress version info (head.fontRevision and name ID 3)]' \
  '-se[show if lookup is wrapped in an Extension lookup type]' \
  '-supressTTFDiffs[remove glyphs/cmap mappings to suppress TTF/OTF differences]' \
  '-a[allow virtual GIDs]' \
  '-o[output file]:output:_files' \
  '-h[print help]' \
  '-u[print usage]' \
  '*:font:_files' && ret=0

return ret
