#compdef skopeo

# Zsh completion for Skopeo - container image operations

local curcontext="$curcontext" state line ret=1

_skopeo_commands() {
  local -a commands=(
    'copy:copy an image from one location to another'
    'delete:delete an image from a registry'
    'inspect:inspect properties of an image'
    'list-tags:list tags in a repository'
    'login:log in to a container registry'
    'logout:log out from a container registry'
    'manifest-digest:compute a manifest digest'
    'standalone-sign:create a signature using local files'
    'standalone-verify:verify a signature using local files'
    'sync:synchronize images between registries'
    'generate-sigstore-key:generate a sigstore key pair'
    'help:help about any command'
  )
  _describe -t commands 'skopeo command' commands
}

_skopeo_transport() {
  local -a transports=(
    'docker\://'
    'docker-archive\:'
    'docker-daemon\:'
    'oci\:'
    'oci-archive\:'
    'dir\:'
    'containers-storage\:'
  )
  _describe -t transports 'transport' transports
}

_skopeo_global_flags() {
  _arguments -s -S \
    '--command-timeout[timeout for the command]:duration' \
    '--debug[enable debug output]' \
    '--insecure-policy[use a permissive signature verification policy]' \
    '--override-arch[use arch instead of running architecture]:arch:(amd64 arm64 arm s390x ppc64le)' \
    '--override-os[use OS instead of running OS]:os:(linux windows darwin)' \
    '--override-variant[use variant instead of running variant]:variant' \
    '--policy[path to a trust policy file]:file:_files' \
    '--registries.d[directory for registry configuration]:dir:_directories' \
    '--tmpdir[temporary directory]:dir:_directories' \
    "$@"
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--command-timeout[timeout for the command]:duration' \
  '--debug[enable debug output]' \
  '--insecure-policy[use a permissive signature verification policy]' \
  '--override-arch[use arch instead of running architecture]:arch:(amd64 arm64 arm s390x ppc64le)' \
  '--override-os[use OS instead of running OS]:os:(linux windows darwin)' \
  '--override-variant[use variant instead of running variant]:variant' \
  '--policy[path to a trust policy file]:file:_files' \
  '--registries.d[directory for registry configuration]:dir:_directories' \
  '--tmpdir[temporary directory]:dir:_directories' \
  '1: :_skopeo_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      copy)
        _skopeo_global_flags \
          '(-a --all)'{-a,--all}'[copy all images if source is a list]' \
          '--additional-tag[additional tags for dest image]:tag' \
          '--authfile[path of the authentication file]:file:_files' \
          '--dest-authfile[path of the dest authentication file]:file:_files' \
          '--dest-cert-dir[path to certificates]:dir:_directories' \
          '--dest-compress[compress tarball image layers]' \
          '--dest-compress-format[compression format]:format:(gzip zstd zstd:chunked)' \
          '--dest-compress-level[compression level]:level' \
          '--dest-creds[credentials for dest]:username\:password' \
          '--dest-daemon-host[dest docker daemon host]:host' \
          '--dest-no-creds[do not use credentials for dest]' \
          '--dest-oci-accept-uncompressed-layers[allow uncompressed layers]' \
          '--dest-password[dest password]:password' \
          '--dest-precompute-digests[precompute digests]' \
          '--dest-registry-token[dest registry bearer token]:token' \
          '--dest-shared-blob-dir[shared blob dir]:dir:_directories' \
          '--dest-tls-verify[require HTTPS and verify certs for dest]' \
          '--dest-username[dest username]:username' \
          '--digestfile[write digest to file]:file:_files' \
          '--encrypt-layer[encrypt layers]:indices' \
          '--encryption-key[encryption key]:key' \
          '(-f --format)'{-f,--format}'[manifest type]:format:(oci v2s1 v2s2)' \
          '--multi-arch[how to handle multi-arch images]:strategy:(system all index-only)' \
          '--preserve-digests[preserve digests during copy]' \
          '--remove-signatures[do not copy signatures from source]' \
          '--retry-times[number of retries]:num' \
          '--sign-by[sign by GPG key]:key' \
          '--sign-by-sigstore[sign by sigstore]:file:_files' \
          '--sign-by-sigstore-private-key[sign by sigstore private key]:file:_files' \
          '--sign-passphrase-file[passphrase file]:file:_files' \
          '--src-authfile[path of the src authentication file]:file:_files' \
          '--src-cert-dir[path to certificates]:dir:_directories' \
          '--src-creds[credentials for source]:username\:password' \
          '--src-daemon-host[source docker daemon host]:host' \
          '--src-no-creds[do not use credentials for source]' \
          '--src-password[source password]:password' \
          '--src-registry-token[source registry bearer token]:token' \
          '--src-shared-blob-dir[shared blob dir]:dir:_directories' \
          '--src-tls-verify[require HTTPS and verify certs for source]' \
          '--src-username[source username]:username' \
          '1:source:' '2:destination:' && ret=0
        ;;
      delete)
        _skopeo_global_flags \
          '--authfile[path of the authentication file]:file:_files' \
          '--cert-dir[path to certificates]:dir:_directories' \
          '--creds[credentials for the registry]:username\:password' \
          '--no-creds[do not use credentials]' \
          '--registry-token[registry bearer token]:token' \
          '--tls-verify[require HTTPS and verify certs]' \
          '1:image:' && ret=0
        ;;
      inspect)
        _skopeo_global_flags \
          '--authfile[path of the authentication file]:file:_files' \
          '--cert-dir[path to certificates]:dir:_directories' \
          '--config[output raw config]' \
          '--creds[credentials for the registry]:username\:password' \
          '(-f --format)'{-f,--format}'[Go template output format]:format' \
          '--no-creds[do not use credentials]' \
          '--no-tags[do not list tags of image]' \
          '--raw[output raw manifest]' \
          '--registry-token[registry bearer token]:token' \
          '--retry-times[number of retries]:num' \
          '--shared-blob-dir[shared blob dir]:dir:_directories' \
          '--tls-verify[require HTTPS and verify certs]' \
          '1:image:' && ret=0
        ;;
      list-tags)
        _skopeo_global_flags \
          '--authfile[path of the authentication file]:file:_files' \
          '--cert-dir[path to certificates]:dir:_directories' \
          '--creds[credentials for the registry]:username\:password' \
          '--no-creds[do not use credentials]' \
          '--registry-token[registry bearer token]:token' \
          '--tls-verify[require HTTPS and verify certs]' \
          '1:repository:' && ret=0
        ;;
      login)
        _skopeo_global_flags \
          '--authfile[path of the authentication file]:file:_files' \
          '--cert-dir[path to certificates]:dir:_directories' \
          '--get-login[return the current login user]' \
          '(-p --password)'{-p,--password}'[password]:password' \
          '--password-stdin[read password from stdin]' \
          '--tls-verify[require HTTPS and verify certs]' \
          '(-u --username)'{-u,--username}'[username]:username' \
          '--compat-auth-file[path of compat auth file]:file:_files' \
          '1:registry:' && ret=0
        ;;
      logout)
        _skopeo_global_flags \
          '(-a --all)'{-a,--all}'[remove all authentications]' \
          '--authfile[path of the authentication file]:file:_files' \
          '--compat-auth-file[path of compat auth file]:file:_files' \
          '1:registry:' && ret=0
        ;;
      sync)
        _skopeo_global_flags \
          '(-s --src)'{-s,--src}'[source transport]:transport:(docker dir yaml)' \
          '(-d --dest)'{-d,--dest}'[destination transport]:transport:(docker dir)' \
          '--authfile[path of the authentication file]:file:_files' \
          '--dest-authfile[path of the dest authentication file]:file:_files' \
          '--dest-creds[credentials for dest]:username\:password' \
          '--dest-tls-verify[require HTTPS and verify certs for dest]' \
          '--dest-username[dest username]:username' \
          '--dest-password[dest password]:password' \
          '(-f --format)'{-f,--format}'[manifest type]:format:(oci v2s1 v2s2)' \
          '--keep-going[tolerate errors when syncing]' \
          '--preserve-digests[preserve digests during sync]' \
          '--remove-signatures[do not copy signatures from source]' \
          '--retry-times[number of retries]:num' \
          '--scoped[scope the dest with source repo path]' \
          '--src-authfile[path of the src authentication file]:file:_files' \
          '--src-creds[credentials for source]:username\:password' \
          '--src-tls-verify[require HTTPS and verify certs for source]' \
          '--src-username[source username]:username' \
          '--src-password[source password]:password' \
          '(-a --all)'{-a,--all}'[copy all images if source is a list]' \
          '--dry-run[only print what would be done]' \
          '1:source:' '2:destination:' && ret=0
        ;;
      manifest-digest)
        _arguments '1:manifest file:_files' && ret=0
        ;;
      generate-sigstore-key)
        _arguments \
          '--output-prefix[prefix for generated key files]:prefix' && ret=0
        ;;
    esac
    ;;
esac

return ret
