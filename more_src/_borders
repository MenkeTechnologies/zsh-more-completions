#compdef borders
# Documentation: https://github.com/FelixKratz/JankyBorders/wiki/Man-Page
# Source: FelixKratz/JankyBorders — lightweight macOS focused-window border drawer.
# Reference accessed: 2026-06-01
# Reads ~/.config/borders/bordersrc when launched without args.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    'style=[border style]:style:(round square uniform)' \
    'active_color=[focused window color (0xAARRGGBB or gradient(...) or glow(...))]:color:_default' \
    'inactive_color=[unfocused window color]:color:_default' \
    'background_color=[background fill color for all windows]:color:_default' \
    'width=[border thickness in points]:width:_default' \
    'hidpi=[retina rendering]:state:(on off)' \
    'ax_focus=[use accessibility API for focus detection]:state:(on off)' \
    'blacklist=[comma-separated app names to exclude]:apps:_default' \
    'whitelist=[comma-separated app names to include]:apps:_default' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
