#compdef jmess
# Documentation: https://github.com/jackaudio/jack-example-tools
# save and restore JACK port connections via XML

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --disconnectall)'{-d,--disconnectall}'[disconnect all connections, with confirmation]' \
  '(-D --DisconnectAll)'{-D,--DisconnectAll}'[disconnect all connections, no confirmation]' \
  '(-c --connect)'{-c,--connect}'+[load connections from input XML file]:file:_files -g "*.xml"' \
  '(-s --save)'{-s,--save}'+[save current connections to output XML file]:file:_files -g "*.xml"' && ret=0

return ret
