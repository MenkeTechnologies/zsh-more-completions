#compdef caip-in-cluster-controller-manager
# _caip-in-cluster-controller-manager — Cluster API IPAM Provider In-Cluster (CAIP-in-cluster)
# upstream: https://github.com/kubernetes-sigs/cluster-api-ipam-provider-in-cluster
# Flags from main.go on tip.

_caip-in-cluster-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--namespace=[restrict provider to a single namespace]:ns:' \
        '--watch-filter=[watch-filter label value]:value:' \
        '--webhook-port=[webhook server bind port]:port:' \
        '--webhook-cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--webhook-cert-name=[webhook TLS cert filename]:name:' \
        '--webhook-key-name=[webhook TLS key filename]:name:' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_caip-in-cluster-controller-manager "$@"
