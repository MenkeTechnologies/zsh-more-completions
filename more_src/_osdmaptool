#compdef osdmaptool
# Documentation: https://docs.ceph.com/en/latest/man/8/osdmaptool/
# Ceph OSD cluster map manipulation tool.

local ret=1

_arguments -s -S \
  '--print[print a plaintext dump of the map]' \
  '--dump=[dump the map in the given format]:format:(plain json)' \
  '--clobber[overwrite mapfilename if changes are made]' \
  '--import-crush=[load the CRUSH map from mapfile]:mapfile:_files' \
  '--export-crush=[extract the CRUSH map to mapfile]:mapfile:_files' \
  '--createsimple=[create a basic OSD map with given device count]:numosd:' \
  '--pg-bits=[bits per OSD for initial pg counts]:bits:' \
  '--pgp-bits=[bits per OSD for pgp_num]:bits:' \
  '--create-from-conf[create OSD map with default configuration]' \
  '--test-map-pgs[print mappings from placement groups to OSDs]' \
  '--pool=[restrict testing to the specified pool id]:poolid:' \
  '--range-first=[starting range for iteration]:n:' \
  '--range-last=[ending range for iteration]:n:' \
  '--test-map-pgs-dump[print pg summary and OSD mappings]' \
  '--test-map-pgs-dump-all[print pgs mapped to all OSDs]' \
  '--test-random[random mapping of placement groups to OSDs]' \
  '--test-map-pg=[map a particular placement group to OSDs]:pgid:' \
  '--test-map-object=[map placement group by object name]:objectname:' \
  '--test-crush[map placement groups to acting OSDs]' \
  '--mark-up-in[mark osds up and in (not persisted)]' \
  '--mark-out[mark an osd as out (not persisted)]' \
  '--mark-up=[mark an osd as up (not persisted)]:osdid:' \
  '--mark-in=[mark an osd as in (not persisted)]:osdid:' \
  '--tree[display a hierarchical tree of the map]' \
  '--clear-temp[clear pg_temp and primary_temp]' \
  '--clean-temps[clean pg_temps]' \
  '--health[dump health checks]' \
  '--with-default-pool[include default pool when creating map]' \
  '--upmap-cleanup=[remove upmap entries, write commands to file]:file:_files' \
  '--upmap=[calculate pg upmap entries, write commands to file]:file:_files' \
  '--upmap-max=[max upmap entries to calculate]:n:' \
  '--upmap-deviation=[max deviation from target]:n:' \
  '--upmap-pool=[restrict upmap balancing to pool(s)]:pool:' \
  '--upmap-active[keep applying changes until balanced]' \
  '--adjust-crush-weight=[change CRUSH weight of osdid]:osdid\:weight:' \
  '--save[write modified osdmap with upmap or crush changes]' \
  '--read=[balance read operations, write commands to file]:file:_files' \
  '--read-pool=[pool for read balancer to adjust]:pool:' \
  '--vstart[prefix upmap and read output with ./bin/]' \
  '*:mapfile:_files' && ret=0

return ret
