#compdef lvm-driver
# _lvm-driver — OpenEBS LVM-LocalPV CSI driver (provisions PVs backed by LVM volume groups; runs as controller or node plugin)
# upstream: https://github.com/openebs/lvm-localpv
# Flags from cmd/main.go on tip (cobra).

_lvm-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--nodeid=[NodeID identifying the node running this driver]:id:' \
        '--version=[display driver version]:ver:' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--name=[name of this driver]:name:' \
        '--plugin=[type of this driver]:type:(controller-plugin csi-plugin node-plugin)' \
        '--setiolimits[set iops/bps rate limit for pods accessing volumes]' \
        '--container-runtime=[container runtime in use]:rt:(containerd cri-o docker)' \
        '--listen-address=[Prometheus metrics TCP address]:addr:' \
        '--metrics-path=[Prometheus metrics path]:path:' \
        '--disable-exporter-metrics=[exclude exporter self-metrics]:bool:(true false)' \
        '--kube-api-qps=[QPS used when talking to the Kubernetes API server]:n:' \
        '--kube-api-burst=[burst used when talking to the Kubernetes API server]:n:' \
        '*--riops-per-gb=[read IOPS/GB limit per vg-prefix (vg-prefix:value)]:spec:' \
        '*--wiops-per-gb=[write IOPS/GB limit per vg-prefix]:spec:' \
        '*--rbps-per-gb=[read BPS/GB limit per vg-prefix]:spec:' \
        '*--wbps-per-gb=[write BPS/GB limit per vg-prefix]:spec:' \
        '--node-polling-interval=[interval (s) between node polls]:s:' \
        '--kubelet-dir=[kubelet directory]:dir:_files -/' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_lvm-driver "$@"
