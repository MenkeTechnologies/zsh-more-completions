_openapi-to-graphql() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '(-s --strict)'{-s,--strict}'[throw an error rather than work around OAS issues]' \
        '--save=[save SDL schema to file and exit (no server)]:file:_files -g "*.graphql *.gql *.graphqls"' \
        '(-p --port)'{-p,--port}'=[live server port (default 3000)]:port:' \
        '(-u --url)'{-u,--url}'=[override the base URL for resolver REST calls]:url:' \
        '--cors[enable CORS on the live server]' \
        '(-o --operationIdFieldNames)'{-o,--operationIdFieldNames}'[create field names based on operationId]' \
        '(-f --fillEmptyResponses)'{-f,--fillEmptyResponses}'[create placeholder schemas for operations with no response body]' \
        '--addLimitArgument[add limit argument on list-returning fields]' \
        '--genericPayloadArgName[use requestBody as mutation payload argument name]' \
        '--simpleNames[only remove illegal characters from OAS names]' \
        '--simpleEnumValues[only remove illegal characters from OAS enum values]' \
        '--singularNames[experimental: create more meaningful names from operation path]' \
        '*'{-H,--header}'=[add header to every REST call KEY\:VAL (repeatable)]:header:' \
        '*'{-Q,--queryString}'=[add query parameter to every REST call KEY\:VAL (repeatable)]:qs:' \
        '--no-viewer[do not create GraphQL viewer objects for authentication credentials]' \
        '--no-extensions[do not add extensions about failed REST calls to GraphQL errors]' \
        '--no-equivalentToMessages[do not append "Equivalent to <REST op>" hints to field descriptions]' \
        '*:OAS JSON/YAML file or remote URL:_files -g "*.json *.yaml *.yml"'
}

_openapi-to-graphql "$@"
