#compdef GetMeshAndTopology
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/GetMeshAndTopology.cxx — extract VTK mesh and topology from a binary volume (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:binaryimage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:valueimage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:out (output prefix):_default' \
    '4:paramname:_default' \
    '5:ValueScale:_default' \
    '6::AntiAliasParm (default 0.001):_default' \
    '7::offscreen.png:_files -g "*.png"' \
    '8::inflation-iterations:_default' \
    && ret=0

return ret
