#compdef argoexec
# _argoexec — Argo Workflows executor sidecar (argoproj/argo-workflows)
# upstream: https://github.com/argoproj/argo-workflows
# Subcommands from cmd/argoexec/commands/root.go (cobra).

_argoexec() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--loglevel=[log level]:level:(debug info warn error)' \
        '--gloglevel=[glog level]:n:' \
        '--log-format=[log format]:fmt:(text json)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--context=[kubeconfig context]:ctx:' \
        '--namespace=[kubernetes namespace]:ns:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'init:initialize input artifacts'
                'wait:wait for the main container to complete'
                'kill:kill the main/sidecar containers'
                'data:execute a data step'
                'resource:execute a resource step'
                'emissary:run as the emissary executor'
                'agent:run as the workflow agent'
                'artifact:operate on artifacts'
                'artifact-plugin-init:init artifact plugin'
                'artifact-plugin-sidecar:run artifact plugin sidecar'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_argoexec "$@"
