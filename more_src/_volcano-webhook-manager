#compdef volcano-webhook-manager vc-webhook-manager
# _volcano-webhook-manager — Volcano admission webhook server (validates+mutates PodGroup/Queue/Job/HierarchicalQueue)
# upstream: https://github.com/volcano-sh/volcano
# Flags from cmd/webhook-manager/app/options/options.go on tip.

_volcano-webhook-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--master=[k8s API server address (overrides kubeconfig)]:url:_urls' \
        '--kubeconfig=[kubeconfig file path]:file:_files' \
        '--tls-cert-file=[TLS cert file]:file:_files' \
        '--tls-private-key-file=[TLS private key file]:file:_files' \
        '--listen-address=[admission controller listen address]:addr:' \
        '--port=[admission controller listen port]:port:' \
        '--version[show version and exit]' \
        '--kube-api-qps=[QPS to k8s apiserver]:n:' \
        '--kube-api-burst=[burst to k8s apiserver]:n:' \
        '--ca-cert-file=[x509 CA cert for HTTPS]:file:_files' \
        '--webhook-namespace=[this webhook namespace]:ns:' \
        '--webhook-service-name=[this webhook service name]:name:' \
        '--webhook-url=[this webhook URL]:url:_urls' \
        '--enabled-admission=[comma-separated list of enabled admission paths]:list:' \
        '--admission-conf=[configmap file for this webhook]:file:_files' \
        '--enable-healthz[enable health check endpoint]' \
        '--healthz-address=[health check server listen address]:addr:' \
        '--graceful-shutdown-time=[wait duration during graceful shutdown]:dur:' \
        '--enable-queue-allocated-pods-check[reject queue delete when queue has allocated pods]' \
        '--max-queue-depth=[maximum depth of hierarchical queues]:n:' \
        '--enable-root-queue-protection=[protect root queue resource attributes]:bool:(true false)' \
        '--log-flush-frequency=[max seconds between log flushes]:dur:'
}

_volcano-webhook-manager "$@"
