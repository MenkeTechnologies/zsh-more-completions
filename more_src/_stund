#compdef stund
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man8/stund.8.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# stund: STUN protocol (Simple Traversal of UDP through NATs) Server

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '--help[print useful help]' \
  '-v[verbose output]' \
  '-h+[main IP address]:host:_hosts' \
  '-a+[second IP address]:host:_hosts' \
  '-p+[primary port (default 3478)]:port:' \
  '-o+[secondary port (default 3479)]:port:' \
  '-b[detach process and run in background]' \
  '-m+[starting port for the STERM server]:port:' && ret=0

return ret
