#compdef stund

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-h[show help]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-b[run in background]' \
  '-l[log to syslog]' \
  '-m+[primary media port]:port:' \
  '-h+[primary host address]:host:_hosts' \
  '-a+[alternate host address]:host:_hosts' && ret=0

return ret
