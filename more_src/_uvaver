#compdef uvaver
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvaver.html
# MIRIAD uvaver - copy and average uv data

local ret=1

_arguments -s -S \
  'vis=[input uv dataset names]:vis:_files' \
  'select=[uv selection filters]:select' \
  'line=[uv line type line,nchan,start,width,step]:line' \
  'ref=[reference line type line,start,width]:ref' \
  'stokes=[output polarizations]:stokes' \
  'interval=[time averaging window in minutes]:interval' \
  'options=[nocal,nopass,nopol,relax,vector,scalar,scavec]:options' \
  'out=[output uv dataset name]:out:_files' \
  '*:visibility data:_files' && ret=0

return ret
