#compdef grub-file
# _grub-file — GRUB grub-file (file(1)-style identifier that the GRUB scripting engine uses to decide whether a path is e.g. an ELF kernel, an i386 multiboot binary, a multiboot2 binary, an iso9660 layout, a portable executable, an xen kernel image, etc.; subcommand-style flags: --is-i386-xen-pae-domu, --is-i386-pc-multiboot, --is-i386-pc-multiboot2, --is-i386-xen-pae-domu, --is-arm-efi, --is-x86_64-xen-dom0, --is-x86_64-xen-domu, --is-arm64-efi)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-file.in on tip.

_grub-file() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--is-i386-xen-pae-domu[i386 xen pae domu]' \
        '--is-x86_64-xen-dom0[x86_64 xen dom0]' \
        '--is-x86_64-xen-domu[x86_64 xen domu]' \
        '--is-i386-pc-multiboot[i386 pc multiboot]' \
        '--is-i386-pc-multiboot2[i386 pc multiboot2]' \
        '--is-arm-efi[arm efi]' \
        '--is-arm64-efi[arm64 efi]' \
        '--is-i386-multiboot[i386 multiboot]' \
        '--is-i386-multiboot2[i386 multiboot2]' \
        '--is-elf[elf]' \
        '--is-x86_64-efi[x86_64 efi]' \
        '--is-x86_64-multiboot[x86_64 multiboot]' \
        '--is-x86_64-multiboot2[x86_64 multiboot2]' \
        '*:file:_files'
}

_grub-file "$@"
