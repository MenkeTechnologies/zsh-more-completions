#compdef handlr
# Documentation: https://github.com/chmln/handlr
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a commands=(
      'list:list default applications'
      'open:open a path/URL with its default handler'
      'set:set the default handler for a mime type or extension'
      'unset:unset the default handler for a mime type'
      'get:get the handler for a mime type or extension'
      'launch:launch a handler with arguments'
      'add:add a handler for a mime type'
      'autoadd:automatically add handlers'
      'mime:show MIME type information'
      'remove:delete a handler entry'
    )
    _describe -t commands 'handlr command' commands && ret=0
    ;;
  args)
    case $words[1] in
      list)
        _arguments -s -S \
          '--all[list all handlers]' \
          '--json[output as JSON]' && ret=0
        ;;
      get)
        _arguments -s -S \
          '--json[output as JSON]' \
          '1:mime type or extension:' && ret=0
        ;;
      set)
        _arguments -s -S \
          '1:mime type:' \
          '2:handler:' && ret=0
        ;;
      unset)
        _arguments -s -S \
          '1:mime type:' && ret=0
        ;;
      open)
        _arguments -s -S \
          '*:path:_files' && ret=0
        ;;
      launch)
        _arguments -s -S \
          '1:handler:' \
          '*:arguments:_files' && ret=0
        ;;
      add)
        _arguments -s -S \
          '1:mime type:' \
          '2:handler:' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '1:mime type:' \
          '2:handler:' && ret=0
        ;;
      mime)
        _arguments -s -S \
          '--json[output as JSON]' \
          '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac
return ret
