#compdef handlr
# Zsh completion for handlr - Default application handler
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a commands=(
      'list:list default applications'
      'open:open a path with its default handler'
      'set:set the default handler for a mime type'
      'unset:unset the default handler for a mime type'
      'get:get the handler for a mime type or extension'
      'launch:launch a handler with arguments'
      'add:add a handler for a mime type'
    )
    _describe -t commands 'handlr command' commands && ret=0
    ;;
  args)
    case $words[1] in
      list)
        _arguments -s -S \
          '--all[list all handlers]' \
          '--json[output as JSON]' && ret=0
        ;;
      get)
        _arguments -s -S \
          '--json[output as JSON]' \
          '1:mime type or extension:' && ret=0
        ;;
      set)
        _arguments -s -S \
          '1:mime type:' \
          '2:handler:' && ret=0
        ;;
      unset)
        _arguments -s -S \
          '1:mime type:' && ret=0
        ;;
      open)
        _arguments -s -S \
          '1:path:_files' && ret=0
        ;;
      launch)
        _arguments -s -S \
          '1:handler:' \
          '*:arguments:_files' && ret=0
        ;;
      add)
        _arguments -s -S \
          '1:mime type:' \
          '2:handler:' && ret=0
        ;;
    esac
    ;;
esac
return ret
