#compdef ovsdb-client

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'list-dbs:list known databases'
  'get-schema:print schema as JSON'
  'list-tables:print table names'
  'list-columns:print column info'
  'convert:convert DB to schema'
  'needs-conversion:print yes/no'
  'get-schema-version:print schema version'
  'get-schema-cksum:print schema checksum'
  'transact:send transaction and print reply'
  'query:read-only transaction'
  'dump:retrieve all data'
  'backup:snapshot of schema and data'
  'restore:replace data from snapshot'
  'monitor:monitor table contents'
  'monitor-cond:conditional monitor'
  'monitor-cond-since:conditional monitor with history'
  'wait:wait for DB state'
  'lock:acquire RFC 7047 lock'
  'steal:steal lock'
  'unlock:unlock'
  'help:show help'
)

_arguments -C \
  '--no-leader-only[accept any cluster server]' \
  '(-f --format)'{-f,--format=}'[output format]:fmt:(table list html csv json)' \
  '(-d --data)'{-d,--data=}'[data format]:fmt:(string bare json)' \
  '--no-headings[no table headings]' \
  '--pretty[pretty-print JSON]' \
  '--bare[bare output]' \
  '--max-column-width=[max column width]:n:' \
  '--timestamp[include timestamps]' \
  '(-t --timeout)'{-t,--timeout=}'[timeout secs]:secs:' \
  '--pidfile=[pid file]:file:_files' \
  '--overwrite-pidfile[overwrite pidfile]' \
  '--detach[detach to background]' \
  '--monitor[monitor child]' \
  '--no-chdir[no chdir]' \
  '--no-self-confinement[no self confinement]' \
  '--user=[run as user]:user:_users' \
  '*'{-v,--verbose=}'[verbosity]:spec:' \
  '--log-file=[log file]:file:_files' \
  '--syslog-target=[syslog target]:host:port:' \
  '--syslog-method=[syslog method]:method:' \
  '(-p --private-key)'{-p,--private-key=}'[private key]:file:_files' \
  '(-c --certificate)'{-c,--certificate=}'[certificate]:file:_files' \
  '(-C --ca-cert)'{-C,--ca-cert=}'[CA cert]:file:_files' \
  '--ssl-server-name=[SNI server name]:name:' \
  '--bootstrap-ca-cert=[bootstrap CA cert]:file:_files' \
  '--ssl-protocols=[SSL protocols]:list:' \
  '--ssl-ciphers=[SSL ciphers]:list:' \
  '--ssl-ciphersuites=[SSL ciphersuites]:list:' \
  '--record=[record dir]:dir:_files -/' \
  '--replay=[replay dir]:dir:_files -/' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ovsdb-client subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (restore)
        _arguments '--force[force restore]' && ret=0
        ;;
      (monitor|monitor-cond|monitor-cond-since)
        _arguments '--detach[detach]' && ret=0
        ;;
    esac
    ;;
esac

return ret
