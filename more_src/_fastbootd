#compdef fastbootd
# Documentation: https://android.googlesource.com/platform/system/core/+/master/fastboot/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fastbootd: Android fastboot protocol server (user-space)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::fastbootd args:_files' && ret=0
return ret
