#compdef fastbootd
# Documentation: https://man.archlinux.org/search?q=fastbootd
# Reference accessed: 2026-05-16

# fastbootd: Android fastboot protocol server (user-space)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::fastbootd args:_files' && ret=0
return ret
