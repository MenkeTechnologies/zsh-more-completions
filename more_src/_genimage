#compdef genimage
# Documentation: source-direct extraction from upstream
# pengutronix/genimage config.c lines 332-550 (the static
# `struct config opts[]` array) + lines 181-273 (the
# `set_config_opts()` getopt_long loop).  Every option is built
# at runtime from the optlist via
#   long_options[i].name = c->name;
#   o->has_arg = 1;
# (config.c:233-234), so every option below takes exactly one
# argument.  The only hardcoded short options are -h and -v.
# Reference accessed: 2026-05-30 via gh api.
# genimage is Pengutronix's filesystem / disk / flash image
# builder, used by Buildroot, Yocto, and embedded-Linux build
# systems to assemble SD-card / eMMC / NAND / NOR images from a
# rootpath plus a config-file recipe (genimage.cfg).  No
# completion existed in the repo before this round.

# Image-builder helper-command options: every option below
# (cpio/dd/debugfs/e2fsck/genext2fs/genisoimage/mcopy/mmd/
# mkcramfs/mkdosfs/mke2fs/mkfserofs/mkfsjffs2/mkfsf2fs/
# mkfsbtrfs/openssl/sloadf2fs/mkfsubifs/mksquashfs/qemu-img/
# rauc/tar/tune2fs/ubinize/mkimage/fiptool/veritysetup) takes
# the *path or name of the corresponding external binary that
# genimage will exec to build that image type.  Decoded
# source-direct from config.c's opts[] array.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '(-v --version)'{-v,--version}'[print PACKAGE_VERSION and exit]' \
  '--loglevel=[verbosity level (env GENIMAGE_LOGLEVEL; default 1)]:level:(0 1 2 3)' \
  '--rootpath=[input rootfs directory (env GENIMAGE_ROOTPATH; default "root")]:dir:_files -/' \
  '--tmppath=[temporary work directory (env GENIMAGE_TMPPATH; default "tmp")]:dir:_files -/' \
  '--inputpath=[input file directory (env GENIMAGE_INPUTPATH; default "input")]:dir:_files -/' \
  '--outputpath=[output image directory (env GENIMAGE_OUTPUTPATH; default "images")]:dir:_files -/' \
  '--includepath=[search-path for "include" directives (env GENIMAGE_INCLUDEPATH; requires libconfuse with searchpath support)]:path:_files -/' \
  '--cpio=[cpio binary to exec (env GENIMAGE_CPIO; default "cpio")]:cmd:_command_names -e' \
  '--dd=[dd binary to exec (env GENIMAGE_DD; default "dd")]:cmd:_command_names -e' \
  '--debugfs=[debugfs binary to exec (env GENIMAGE_DEBUGFS; default "debugfs")]:cmd:_command_names -e' \
  '--e2fsck=[e2fsck binary to exec (env GENIMAGE_E2FSCK; default "e2fsck")]:cmd:_command_names -e' \
  '--genext2fs=[genext2fs binary to exec (env GENIMAGE_GENEXT2FS; default "genext2fs")]:cmd:_command_names -e' \
  '--genisoimage=[genisoimage binary to exec (env GENIMAGE_GENISOIMAGE; default "genisoimage")]:cmd:_command_names -e' \
  '--mcopy=[mtools mcopy binary to exec (env GENIMAGE_MCOPY; default "mcopy")]:cmd:_command_names -e' \
  '--mmd=[mtools mmd binary to exec (env GENIMAGE_MMD; default "mmd")]:cmd:_command_names -e' \
  '--mkcramfs=[mkfs.cramfs binary to exec (env GENIMAGE_MKCRAMFS; default "mkfs.cramfs")]:cmd:_command_names -e' \
  '--mkdosfs=[mkdosfs binary to exec (env GENIMAGE_MKDOSFS; default "mkdosfs")]:cmd:_command_names -e' \
  '--mke2fs=[mke2fs binary to exec (env GENIMAGE_MKE2FS; default "mke2fs")]:cmd:_command_names -e' \
  '--mkfserofs=[mkfs.erofs binary to exec (env GENIMAGE_MKFSEROFS; default "mkfs.erofs")]:cmd:_command_names -e' \
  '--mkfsjffs2=[mkfs.jffs2 binary to exec (env GENIMAGE_MKFJFFS2; default "mkfs.jffs2")]:cmd:_command_names -e' \
  '--mkfsf2fs=[mkfs.f2fs binary to exec (env GENIMAGE_MKFSF2FS; default "mkfs.f2fs")]:cmd:_command_names -e' \
  '--mkfsbtrfs=[mkfs.btrfs binary to exec (env GENIMAGE_MKFSBTRFS; default "mkfs.btrfs")]:cmd:_command_names -e' \
  '--openssl=[openssl binary to exec for verity/FIT (env GENIMAGE_OPENSSL; default "openssl")]:cmd:_command_names -e' \
  '--sloadf2fs=[sload.f2fs binary to exec (env GENIMAGE_SLOADF2FS; default "sload.f2fs")]:cmd:_command_names -e' \
  '--mkfsubifs=[mkfs.ubifs binary to exec (env GENIMAGE_MKFSUBIFS; default "mkfs.ubifs")]:cmd:_command_names -e' \
  '--mksquashfs=[mksquashfs binary to exec (env GENIMAGE_MKSQUASHFS; default "mksquashfs")]:cmd:_command_names -e' \
  '--qemu-img=[qemu-img binary to exec (env GENIMAGE_QEMU; default "qemu-img")]:cmd:_command_names -e' \
  '--randomseed=[seed for the deterministic random32 generator (env GENIMAGE_RANDOMSEED)]:seed:' \
  '--rauc=[rauc binary to exec (env GENIMAGE_RAUC; default "rauc")]:cmd:_command_names -e' \
  '--tar=[tar binary to exec (env GENIMAGE_TAR; default "tar")]:cmd:_command_names -e' \
  '--tune2fs=[tune2fs binary to exec (env GENIMAGE_TUNE2FS; default "tune2fs")]:cmd:_command_names -e' \
  '--ubinize=[ubinize binary to exec (env GENIMAGE_UBINIZE; default "ubinize")]:cmd:_command_names -e' \
  '--mkimage=[U-Boot mkimage binary to exec (env GENIMAGE_MKIMAGE; default "mkimage")]:cmd:_command_names -e' \
  '--fiptool=[ATF fiptool binary to exec for FIP images (env GENIMAGE_FIPTOOL; default "fiptool")]:cmd:_command_names -e' \
  '--veritysetup=[veritysetup binary to exec for dm-verity images (env GENIMAGE_VERITYSETUP; default "veritysetup")]:cmd:_command_names -e' \
  '--config=[input config file recipe (env GENIMAGE_CONFIG; default "genimage.cfg")]:cfg:_files -g "*.(cfg|conf)"' \
  '--configdump=[dump effective parsed config to FILE ("-" for stdout; env GENIMAGE_CONFIGDUMP)]:file:_files'
