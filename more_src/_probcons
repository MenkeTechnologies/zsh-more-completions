#compdef probcons
# ProbCons: probabilistic consistency-based multiple alignment

local ret=1

_arguments -s -S \
  '-clustalw[output alignment in CLUSTALW format instead of MFA]' \
  '(-c --consistency)'{-c,--consistency}'[passes of consistency transformation (0-5)]:passes:' \
  '(-ir --iterative-refinement)'{-ir,--iterative-refinement}'[passes of iterative refinement (0-1000)]:passes:' \
  '(-pre --pre-training)'{-pre,--pre-training}'[rounds of pretraining (0-20)]:rounds:' \
  '-pairs[generate pairwise alignments for all sequence pairs]' \
  '-viterbi[use Viterbi algorithm for all-pairs alignment]' \
  '(-v --verbose)'{-v,--verbose}'[display progress information]' \
  '-annot[write alignment annotation to file]:file:_files' \
  '(-t --train)'{-t,--train}'[compute EM transition probabilities and save to file]:file:_files' \
  '(-e --emissions)'{-e,--emissions}'[reestimate emission probabilities during training]' \
  '(-p --paramfile)'{-p,--paramfile}'[load parameters from file]:file:_files' \
  '(-a --alignment-order)'{-a,--alignment-order}'[output sequences in alignment order]' \
  '*:sequence file:_files' && ret=0

return ret
