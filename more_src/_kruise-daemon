#compdef kruise-daemon
# _kruise-daemon — OpenKruise per-node daemon (image pulling, CRI ops)
# upstream: https://github.com/openkruise/kruise
# Flags from cmd/daemon/main.go on tip.

_kruise-daemon() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--addr=[metrics/healthz bind host\:port]:host\:port:' \
        '--pprof-addr=[pprof bind host\:port]:host\:port:' \
        '--enable-pprof=[enable pprof endpoint]:bool:(true false)' \
        '--plugin-config-file=[CredentialProviderPlugin config file]:file:_files' \
        '--plugin-bin-dir=[directory of plugin binaries]:dir:_files -/' \
        '--max-workers-for-pull-image=[max image-pull workers]:n:' \
        '--rest-config-qps=[QPS for REST config (0=client-go default)]:n:' \
        '--rest-config-burst=[burst for REST config (0=client-go default)]:n:' \
        '--feature-gates=[feature gates]:gates:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_kruise-daemon "$@"
