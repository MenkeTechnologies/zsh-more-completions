#compdef asinfo
# Aerospike info CLI for issuing cluster management info commands

local ret=1

_arguments -s -S \
  '(-E)-E[show program usage details]' \
  '-h+[server IP address or FQDN]:host:_hosts' \
  '-p+[server service port]:port:' \
  '-U+[Aerospike username]:username:' \
  '-P+[Aerospike user password]:password:' \
  '--auth=[authentication mode]:mode:(EXTERNAL EXTERNAL_INSECURE INTERNAL PKI)' \
  '-v+[command to transmit to the server]:command:' \
  '-l[replace semicolons with line breaks in response]' \
  '-t+[TLS hostname verification]:tls-name:' \
  '(-V)-V[show asinfo version]' \
  '--timeout=[timeout duration in seconds]:secs:' \
  '--tls-enable[activate TLS for connections]' \
  '--tls-cafile=[path to trusted CA certificate file]:path:_files' \
  '--tls-certfile=[path to certificate chain]:path:_files' \
  '--tls-keyfile=[path to key file]:path:_files' \
  '--config-file=[read specified configuration file]:path:_files' \
  '--no-config-file[skip reading any configuration file]' && ret=0

return ret
