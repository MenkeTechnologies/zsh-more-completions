#compdef oxfmt

# Zsh completion for oxfmt (oxc-project/oxc formatter); flags from
# https://oxc.rs/docs/guide/usage/formatter/cli.html

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--init[bootstrap .oxfmtrc.json with defaults]' \
  '--migrate=[import config from another formatter]:source:(prettier biome)' \
  '--lsp[start the oxfmt language server]' \
  '--stdin-filepath=[virtual filename for stdin input]:path:_files' \
  '--write[format files in place (default mode)]' \
  '--check[verify formatting without writing]' \
  '--list-different[list files that differ from formatted output]' \
  '(-c --config)'{-c,--config=}'[config file (.json .jsonc .ts .js variants)]:config:_files' \
  '--disable-nested-config[ignore config files in child directories]' \
  '*--ignore-path=[additional ignore file]:ignore file:_files' \
  '--with-node-modules[format files inside node_modules]' \
  '--no-error-on-unmatched-pattern[exit successfully when globs match nothing]' \
  '--threads=[number of worker threads]:count:' \
  '*:path or glob pattern:_files' && ret=0

return ret
