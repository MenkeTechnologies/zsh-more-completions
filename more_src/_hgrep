#compdef hgrep

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[context lines around each match]:lines:' \
  '-C[lines of context before and after each match]:lines:' \
  '-B[lines of context before each match]:lines:' \
  '-A[lines of context after each match]:lines:' \
  '-G[generate grep output]' \
  '-H[always print filename headers]' \
  '--no-filename[suppress filename headers]' \
  '-n[print line numbers]' \
  '-r[recursive search]' \
  '-l[only print filenames with matches]' \
  '-i[case insensitive matching]' \
  '-w[match whole words only]' \
  '--color[colorize output]:when:(auto always never)' \
  '--theme[syntax highlighting theme]:theme:' \
  '--no-grid[disable grid border in output]' \
  '--tab[set tab width]:width:' \
  '--first-only[show only the first match in each file]' \
  '-t[file type filter]:type:' \
  '-T[negate file type filter]:type:' \
  '-g[glob pattern to include]:glob:' \
  '--glob[glob pattern to include]:glob:' \
  '--hidden[search hidden files]' \
  '--no-ignore[do not respect .gitignore]' \
  '--max-count[max matches per file]:count:' \
  '--max-depth[max directory depth]:depth:' \
  '1:pattern:' \
  '*:path:_files' && ret=0

return ret
