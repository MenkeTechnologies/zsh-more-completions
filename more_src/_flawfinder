#compdef flawfinder

# Zsh completion for flawfinder (C/C++ source code security analyzer)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--allowlink[allow following symbolic links]' \
  '--columns[show column numbers]' \
  '--context[show context lines around hits]' \
  '--csv[generate CSV output]' \
  '--dataonly[show only data (no headers/footers)]' \
  '--diffhitlist[show only hits not in given hitlist]:hitlist:_files' \
  '--falsepositive[attempt to skip false positives]' \
  '--followdotdir[follow directories starting with dot]' \
  '--html[generate HTML output]' \
  '--immediate[immediately display hits]' \
  '--inputs[show only inputs (functions accepting user data)]' \
  '--listrules[list all rules (CWEs)]' \
  '(-m --minlevel)'{-m,--minlevel}'[minimum risk level to report]:level:(0 1 2 3 4 5)' \
  '--neverignore[never honor ignore directives in source]' \
  '--nolink[do not follow symbolic links]' \
  '--omittime[omit time to run from output]' \
  '--patch[examine only files changed by patch]:patch file:_files' \
  '--quiet[suppress status information]' \
  '--regex[only report hits matching pattern]:regex' \
  '--savehitlist[save hitlist to file]:file:_files' \
  '--singleline[show each hit on a single line]' \
  '--loadhitlist[load hitlist from file]:file:_files' \
  '--sarif[generate SARIF output]' \
  '(-D --dotdirectories)'{-D,--dotdirectories}'[search hidden directories]' \
  '--version[show version]' \
  '--help[show help]' \
  '*:file or directory:_files' && ret=0

return ret
