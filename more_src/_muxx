#compdef muxx
# Source: cargo binstall muxx@1.12.0
# Probed via: completion zsh
# Repository: https://github.com/harshsandhu44/muxx

autoload -U is-at-least

_muxx() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_muxx_commands" \
"*::: :->muxx" \
&& ret=0
    case $state in
    (muxx)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:muxx-command-$line[1]:"
        case $line[1] in
            (attach)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':session -- Name of the tmux session to attach to:_default' \
&& ret=0
;;
(connect)
_arguments "${_arguments_options[@]}" : \
'-c+[Create a new session from this directory path]:CWD:_files -/' \
'--cwd=[Create a new session from this directory path]:CWD:_files -/' \
'--name=[Override the session name (only applies with --cwd)]:NAME:_default' \
'--cmd=[Shell command to send on new session creation only]:CMD:_default' \
'--no-attach[Create the session without attaching to it]' \
'--force[Attach to existing session even if its path differs from the requested path]' \
'-h[Print help]' \
'--help[Print help]' \
'::session -- Existing session name or config alias to connect to:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'*--tag=[Filter sessions by tag (repeatable\: --tag work --tag rust)]:TAGS:_default' \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(kill)
_arguments "${_arguments_options[@]}" : \
'--force[Kill even if it is the current session]' \
'-h[Print help]' \
'--help[Print help]' \
':name -- Session name to kill:_default' \
&& ret=0
;;
(rename)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':from -- Current session name:_default' \
':to -- New session name:_default' \
&& ret=0
;;
(pick)
_arguments "${_arguments_options[@]}" : \
'*--tag=[Only show sessions matching all given tags]:TAGS:_default' \
'--no-attach[Select without attaching (for testing)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(tag)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_muxx__subcmd__tag_commands" \
"*::: :->tag" \
&& ret=0

    case $state in
    (tag)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:muxx-tag-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':session -- Session name to tag:_default' \
'*::tags -- Tags to add — omit to pick interactively with fzf:_default' \
&& ret=0
;;
(rm)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':session -- Session name:_default' \
'*::tags -- Tags to remove — omit to pick interactively with fzf:_default' \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::tag -- Tag to delete globally (omit to pick interactively with fzf):_default' \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':session -- Session name:_default' \
&& ret=0
;;
(clear)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':session -- Session name:_default' \
&& ret=0
;;
(ls)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::session -- Session name (omit to list all tagged sessions):_default' \
&& ret=0
;;
        esac
    ;;
esac
;;
(current)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(gc)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(note)
_arguments "${_arguments_options[@]}" : \
'--clear[Clear the note]' \
'-h[Print help]' \
'--help[Print help]' \
':session -- Session name:_default' \
'::text -- Note text to set (omit to print the current note):_default' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(last)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
'--name=[Override the session name]:NAME:_default' \
'--cmd=[Shell command to send on session creation]:CMD:_default' \
'--no-attach[Create the session without attaching to it]' \
'--force[Attach to existing session even if its path differs from the requested path]' \
'-h[Print help]' \
'--help[Print help]' \
':path -- Directory path for the new session:_files -/' \
&& ret=0
;;
(version)
_arguments "${_arguments_options[@]}" : \
'--verbose[Show OS and architecture details]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_muxx__subcmd__config_commands" \
"*::: :->config" \
&& ret=0

    case $state in
    (config)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:muxx-config-command-$line[1]:"
        case $line[1] in
            (show)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(path)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
        esac
    ;;
esac
;;
(init)
_arguments "${_arguments_options[@]}" : \
'--name=[Project name (default\: sanitized directory name)]:NAME:_default' \
'--startup=[Startup command to run when the session is created]:STARTUP:_default' \
'*--tag=[Tags to assign; repeatable\: --tag work --tag rust]:TAGS:_default' \
'--no-create[Register without creating a session]' \
'--no-attach[Create the session without attaching to it]' \
'--force[Overwrite an existing project config without warning]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Output file path (omit to print to stdout):_default' \
&& ret=0
;;
(import)
_arguments "${_arguments_options[@]}" : \
'--merge[Merge with existing data instead of replacing]' \
'-h[Print help]' \
'--help[Print help]' \
':path -- Input file path:_default' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_muxx_commands] )) ||
_muxx_commands() {
    local commands; commands=(
'attach:Attach to or switch to an existing session by name' \
'connect:Connect to or create a session (default when no subcommand given)' \
'list:List all tmux sessions' \
'kill:Kill a session by name' \
'rename:Rename an existing tmux session' \
'pick:Interactively pick a session using fzf' \
'tag:Add, remove, or list tags on sessions' \
'current:Print the current session name' \
'doctor:Validate environment and configuration' \
'gc:Remove tags and notes for sessions that no longer exist in tmux' \
'note:Get or set a short note on a session' \
'status:Print current session name, tags, and note (for shell prompt integration)' \
'completion:Print shell completion script' \
'last:Re-attach to the last used session' \
'new:Create a new session from a directory path (shorthand for connect --cwd)' \
'version:Print version information' \
'config:Manage the muxx configuration file' \
'init:Register the current project and optionally create a session' \
'export:Export tags and notes to a TOML file' \
'import:Import tags and notes from a TOML file' \
    )
    _describe -t commands 'muxx commands' commands "$@"
}
