#compdef coco coco-r
# Documentation: https://ssw.jku.at/Coco/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Coco/R compiler generator: produces scanners/parsers from .ATG grammars.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-bak[generate backup of generated code]' \
  '-c[generate compiler skeleton]' \
  '-frames+[frames directory]:dir:_files -/' \
  '-genRREBNF[generate Raptor-style EBNF]' \
  '-lines[output line directives]' \
  '-namespace+[output namespace]:namespace:' \
  '-package+[output package (Java)]:package:' \
  '-o+[output directory]:dir:_files -/' \
  '-prefix+[output file prefix]:prefix:' \
  '-single[generate single file]' \
  '-trace+[trace switches: AFGIJPSX]:trace:' \
  '*:atg_file:_files -g "*.atg"' && ret=0

return ret
