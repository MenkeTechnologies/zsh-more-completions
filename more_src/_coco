#compdef coco coco-r

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-bak[generate backup of generated code]' \
  '-c[generate compiler skeleton]' \
  '-frames+[frames directory]:dir:_files -/' \
  '-genRREBNF[generate Raptor-style EBNF]' \
  '-lines[output line directives]' \
  '-namespace+[namespace]:ns:' \
  '-o+[output directory]:dir:_files -/' \
  '-prefix+[output file prefix]:prefix:' \
  '-single[generate single file]' \
  '-trace+[trace string]:trace:' \
  '*:atg_file:_files -g "*.atg"' && ret=0

return ret
