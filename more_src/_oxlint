#compdef oxlint
# Documentation: https://oxc.rs/docs/guide/usage/linter/cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--quiet[suppress warnings, report only errors]' \
  '*'{-A,--allow=}'[allow a rule or category]:rule' \
  '*'{-W,--warn=}'[warn on a rule or category]:rule' \
  '*'{-D,--deny=}'[deny a rule or category (treat as error)]:rule' \
  '--fix[automatically fix problems where possible]' \
  '--fix-suggestions[apply suggested fixes]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '--tsconfig=[TypeScript config file]:file:_files' \
  '--ignore-path=[ignore file path]:file:_files' \
  '*--ignore-pattern=[ignore glob pattern]:glob' \
  '--no-ignore[do not respect ignore files]' \
  '--init[initialize default oxlint configuration]' \
  '--lsp[run as language server]' \
  '--rules[print all registered rules]' \
  '--debug[output timing and diagnostic data]' \
  '--type-aware[enable type-aware lint rules]' \
  '--disable-react-plugin[disable react plugin]' \
  '--disable-unicorn-plugin[disable unicorn plugin]' \
  '--disable-oxc-plugin[disable oxc plugin]' \
  '--disable-typescript-plugin[disable typescript plugin]' \
  '--disable-import-plugin[disable import plugin]' \
  '--disable-jsdoc-plugin[disable jsdoc plugin]' \
  '--disable-jest-plugin[disable jest plugin]' \
  '--disable-jsx-a11y-plugin[disable jsx-a11y plugin]' \
  '--disable-nextjs-plugin[disable nextjs plugin]' \
  '--disable-promise-plugin[disable promise plugin]' \
  '--disable-node-plugin[disable node plugin]' \
  '--disable-security-plugin[disable security plugin]' \
  '--react-perf-plugin[enable react-perf plugin]' \
  '--import-plugin[enable import plugin]' \
  '--jsdoc-plugin[enable jsdoc plugin]' \
  '--jest-plugin[enable jest plugin]' \
  '--jsx-a11y-plugin[enable jsx-a11y plugin]' \
  '--nextjs-plugin[enable nextjs plugin]' \
  '--promise-plugin[enable promise plugin]' \
  '--node-plugin[enable node plugin]' \
  '--security-plugin[enable security plugin]' \
  '(-f --format)'{-f,--format=}'[output format]:format:(default json unix checkstyle github stylish sarif)' \
  '--threads=[number of threads]:threads' \
  '--max-warnings=[maximum number of warnings]:count' \
  '--symlinks[follow symlinks]' \
  '*:file:_files'
