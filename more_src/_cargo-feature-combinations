#compdef cargo-feature-combinations
# Documentation: https://crates.io/crates/cargo-feature-combinations
# run cargo commands against combinations of features

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--diagnostics-only[show only warnings and errors]' \
  '--dedupe[diagnostics-only with deduplication across combinations]' \
  '--summary-only[hide cargo output, show only summary table]' \
  '--fail-fast[stop at the first failing feature combination]' \
  '--exclude-package[remove a package from feature combination testing]:package' \
  '--only-packages-with-lib-target[restrict testing to packages with library targets]' \
  '--errors-only[permit warnings but display errors only]' \
  '--pedantic[treat warnings as errors in summary]' \
  '--show-pruned[display redundant combinations excluded from testing]' \
  '*::cargo command:(matrix check test build run clippy)' && ret=0

return ret
