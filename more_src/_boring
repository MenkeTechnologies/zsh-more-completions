#compdef boring
# Documentation: https://github.com/alebeck/boring
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# boring: simple SSH tunnel manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list tunnels'
  'l:list tunnels (alias)'
  'open:open tunnels'
  'o:open tunnels (alias)'
  'close:close tunnels'
  'c:close tunnels (alias)'
  'edit:edit the configuration file'
  'e:edit the configuration file (alias)'
  'version:show version'
  'v:show version (alias)'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'boring command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (open|o|close|c|list|l)
        _arguments \
          '(-a --all)'{-a,--all}'[apply to all tunnels]' \
          '(-g --group)'{-g,--group=}'[target a specific group]:group:' \
          '*:pattern:' && ret=0
        ;;
    esac
    ;;
esac

return ret
