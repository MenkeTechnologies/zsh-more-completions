#compdef cueprint
# Documentation: https://github.com/svend/cuetools
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --input-format)'{-i+,--input-format=}'[input format]:format:(cue toc)' \
  '(-n --track-number)'{-n+,--track-number=}'[track number]:n:' \
  '(-d --disc-template)'{-d+,--disc-template=}'[disc info template]:template:' \
  '(-t --track-template)'{-t+,--track-template=}'[track info template]:template:' \
  '*:cue_or_toc:_files -g "*.{cue,toc}"' && ret=0

return ret
