#compdef splitFile
# UCSC kent: split up a file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-head=[put head in front of each output]:file:_files' \
  '-tail=[put tail at end of each output]:file:_files' \
  ':source:_files' \
  ':lines per file:' \
  ':out base name:_files' && ret=0

return ret
