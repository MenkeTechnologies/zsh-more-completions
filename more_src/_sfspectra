#compdef sfspectra
# Documentation: https://www.reproducibility.org/blog/2012/03/30/program-of-the-month-sfspectra/
# Madagascar: frequency spectra

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'all=[compute average spectrum for all traces (y/n)]:all:(y n)' \
  'opt=[pad to optimal FFT size (y/n)]:opt:(y n)' \
  '*: :_files' && ret=0

return ret
