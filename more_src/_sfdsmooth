#compdef sfdsmooth
# Documentation: https://github.com/ahay/src/blob/master/system/generic/Mdsmooth.c
# Madagascar: multi-dimensional triangle smoothing - derivative

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  '*rect=[smoothing radius on the n-th axis]:radius' \
  'ider=[direction of the derivative (0 means no derivative)]:axis' \
  'repeat=[repeat smoothing several times]:count' \
  'nderiv=[derivative filter accuracy]:value' \
  '*:RSF file:_files' && ret=0

return ret
