#compdef wezterm
# _wezterm-bin — WezTerm GPU-accelerated terminal (Wez Furlong, Rust); cross-platform terminal + multiplexer with Lua config
# upstream: https://github.com/wez/wezterm

_wezterm-bin() {
    local -a sub=(
        'cli:wezterm-mux client commands'
        'connect:connect to a domain'
        'imgcat:cat an image file (kitty/iTerm2 protocols)'
        'kill:kill running wezterm'
        'ls-fonts:list font configuration'
        'replay:replay a recorded session'
        'serial:open a serial port'
        'show-keys:show key assignments'
        'ssh:run wezterm-ssh'
        'start:start wezterm GUI'
        'shell-completion:print completion script'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--config-file+[config file]:file:_files -g "*.lua"' \
        '--config+[KEY=value pair]:str:' \
        '--skip-config[ignore config]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wezterm subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '--cwd+[cwd]:dir:_files -/' \
                    '--always-new-process[always new process]' \
                    '--position+[position]:str:' \
                    '--class+[wm class]:str:' \
                    '--workspace+[workspace name]:str:' \
                    '--no-auto-connect[no auto-connect to mux]' \
                    '--domain+[domain name]:str:' \
                    '--attach[attach to mux instead of new window]' \
                    '*::command:_command_names -e' ;;
                cli) _arguments \
                    '1:cli cmd:(list list-clients spawn split-pane send-text get-text proxy tlscreds adjust-pane-size kill-pane move-pane-to-new-tab rename-workspace activate-pane activate-pane-direction activate-tab set-tab-title set-window-title zoom-pane)' \
                    '*:args:' ;;
                ssh) _arguments \
                    '--config-file+[config file]:file:_files' \
                    '--config+[KEY=value]:str:' \
                    '*::host args:' ;;
                connect) _arguments \
                    '--new-tab[open new tab]' \
                    '--cwd+[cwd]:dir:_files -/' \
                    '--class+[wm class]:str:' \
                    '--workspace+[workspace name]:str:' \
                    '*:domain:' ;;
                imgcat) _arguments \
                    '--width+[width]:str:' \
                    '--height+[height]:str:' \
                    '--no-preserve-aspect-ratio[do not preserve aspect ratio]' \
                    '--position+[position]:str:' \
                    '--hold[hold image]' \
                    '*:image:_files' ;;
                shell-completion) _arguments '--shell+[shell]:shell:(bash zsh fish elvish power-shell)' ;;
            esac
            ;;
    esac
}

_wezterm-bin "$@"
