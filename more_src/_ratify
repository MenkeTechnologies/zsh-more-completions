#compdef ratify
# Documentation: https://github.com/notaryproject/ratify
# Reference accessed: 2026-05-20
# Verified: upstream cmd/ratify/cmd/verify.go.

_arguments -s -S \
  '(- *)'{-h,--help}'[Show help]' \
  '1:command:(verify referrer resolve discover serve version)' \
  '(-s --subject)'{-s+,--subject=}'[subject reference]:uri:' \
  '(-c --config)'{-c+,--config=}'[ratify config file]:file:_files' \
  '(-t --artifactType)'{-t+,--artifactType=}'[artifact type filter]:type:' \
  '--silent[silent output]' \
  '*::args: _default'
