#compdef heron-cli heron2 heron-admin
# _heron-cli — Apache Heron heron-cli CLI command-line frontend wrapping the Apache Heron distributed real-time stream-processing framework providing submit activate deactivate kill restart update topology cluster role environ config-path config-property checkpoint stateful stateless heron-explorer heron-tracker heron-shell heron-ui heron-apiserver YARN-Mesos-Aurora-Kubernetes (ASF Heron Twitter team, Java/C++); custom argparse
# upstream: https://heron.apache.org/

_heron-cli() {
    local -a sub=(
        'submit:submit a topology'
        'activate:activate a topology'
        'deactivate:deactivate a topology'
        'kill:kill a topology'
        'restart:restart a topology'
        'update:update a topology'
        'config:topology config'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config-path=+[dir]:dir:_files -/' \
        '--config-property=+[k=v]:str:' \
        '--service-url=+[url]:str:' \
        '--cluster=+[name]:str:' \
        '--role=+[name]:str:' \
        '--environ=+[name]:str:' \
        '--container-id=+[id]:n:' \
        '--dry-run[dry run]' \
        '--dry-run-format=+[fmt]:f:(table raw json)' \
        '--deploy-deactivated[deploy deactivated]' \
        '--enable-checkpoint[checkpointing]' \
        '--checkpoint-interval=+[sec]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'heron subcommand' sub ;;
        args)
            case $words[1] in
                submit) _arguments '1:cluster/role/env:' '2:topology jar:_files -g "*.jar"' '3:class:' ;;
                activate|deactivate|kill|restart|update) _arguments '1:cluster/role/env:' '2:topology:' ;;
            esac
            ;;
    esac
}

_heron-cli "$@"
