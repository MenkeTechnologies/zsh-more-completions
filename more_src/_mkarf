#compdef mkarf
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/mkarf.html
# Generate an ARF for Chandra imaging data (and grating 0th order)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'asphistfile=[file containing the binned aspect history]:file:_files' \
  'outfile=[the name of the output ARF file]:file:_files' \
  'sourcepixelx=[X sky position [pixels] of the point source]:sourcepixelx:' \
  'sourcepixely=[Y sky position [pixels] of the point source]:sourcepixely:' \
  'engrid=[energy grid specification string]:engrid:' \
  'obsfile=[FITS file with mission, detector, SIM, time keywords]:file:_files' \
  'pbkfile=[deprecated parameter]:file:_files' \
  'detsubsys=[detector subsystem selection passed to ARDLIB]:detsubsys:' \
  'grating=[compute a zeroth order grating ARF]:grating:(NONE HETG LETG)' \
  'maskfile=[the mask file (msk1.fits) for the observation]:file:_files' \
  'dafile=[ACIS dead area coefficients file]:dafile:' \
  'mirror=[mirror parameter (must be HRMA for Chandra)]:mirror:' \
  'ardlibparfile=[the name of the parameter file used by ARDLIB]:file:_files' \
  'geompar=[the name of the Pixlib Geometry parameter file]:file:_files' \
  'verbose=[the verbosity level for messages]:verbose:(0 1 2 3 4 5)' \
  'clobber=[existing output files will be overwritten]:clobber:(yes no)' && ret=0

return ret
