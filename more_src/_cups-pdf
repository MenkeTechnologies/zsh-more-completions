#compdef cups-pdf
# Documentation: man cups-pdf
# Source: alexivkin/CUPS-PDF-to-PDF cups-pdf.c (master) — CUPS PDF backend (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:job:_default' \
    '2:user:_users' \
    '3:title:_default' \
    '4:copies:_default' \
    '5:options:_default' \
    '6::file:_files -g "*.ps"' \
    && ret=0

return ret
