#compdef virt-copy-in virt-copy-out virt-tar-in virt-tar-out

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '*-a+[disk image]:file:_files' \
  '*--add=[disk image]:file:_files' \
  '-c+[libvirt URI]:uri:' \
  '--connect=[libvirt URI]:uri:' \
  '-d+[libvirt domain]:domain:' \
  '--domain=[libvirt domain]:domain:' \
  '--echo-keys[echo keys to terminal]' \
  '--format=[disk format]:fmt:(raw qcow2 vmdk vdi)' \
  '--key=[disk decryption key]:key:' \
  '--keys-from-stdin[read keys from stdin]' \
  '--no-cache[disable cache]' \
  '*: :_files' && ret=0

return ret
