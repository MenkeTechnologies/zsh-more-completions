#compdef virt-copy-in virt-copy-out virt-tar-in virt-tar-out
# Documentation: https://libguestfs.org/virt-copy-in.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. These tools are thin shell
# wrappers around guestfish; only -a and -d are documented in their own
# man pages. Other options pass through to guestfish(1).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '*-a+[disk image]:file:_files' \
  '*--add=[disk image]:file:_files' \
  '-d+[libvirt domain]:domain:' \
  '--domain=[libvirt domain]:domain:' \
  '*: :_files' && ret=0

return ret
