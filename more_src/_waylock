#compdef waylock

# Zsh completion for waylock (Wayland screen locker)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--init-color=[Color when idle (RRGGBB)]:hex color' \
  '--input-color=[Color when receiving input (RRGGBB)]:hex color' \
  '--fail-color=[Color on authentication failure (RRGGBB)]:hex color' \
  '--fork-on-lock[Fork to background after locking]' \
  '--ready-fd=[FD to signal readiness on]:fd' \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' && ret=0

return ret
