#compdef waylock
# Documentation: https://man.archlinux.org/man/waylock.1.en
# Reference accessed: 2026-05-17
# Verified: ifreund/waylock Wayland screenlocker upstream. NOTE:
# uses single-dash long flags (Zig style), not GNU `--long`. Real
# flags: -h, -version, -log-level, -fork-on-lock, -ready-fd,
# -ignore-empty-password, -init-color, -input-color,
# -input-alt-color, -fail-color.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --long aliases (waylock uses single-dash only).

local ret=1
_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-version[show version]' \
  '-log-level[log level]:level:(error warning info debug)' \
  '-fork-on-lock[fork to background after locking]' \
  '-ready-fd+[FD to signal readiness on]:fd:' \
  '-ignore-empty-password[do not unlock on empty password]' \
  '-init-color+[idle color (0xRRGGBB)]:color:' \
  '-input-color+[input color (0xRRGGBB)]:color:' \
  '-input-alt-color+[alternate input color (0xRRGGBB)]:color:' \
  '-fail-color+[auth-fail color (0xRRGGBB)]:color:' && ret=0
return ret
