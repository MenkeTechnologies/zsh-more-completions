#compdef git-cz

# Zsh completion for git-cz - commitizen-style git commit wrapper

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[stage all modified files before commit]' \
  '(-d --dry-run)'{-d,--dry-run}'[do not actually commit]' \
  '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive mode]' \
  '(-D --disable-emoji)'{-D,--disable-emoji}'[disable emoji in commit messages]' \
  '(-A --amend)'{-A,--amend}'[amend the previous commit]' \
  '(-S --gpg-sign)'{-S,--gpg-sign}'[GPG-sign the commit]' \
  '(-t --type)'{-t,--type}'[commit type]:type:(feat fix docs style refactor perf test build ci chore revert)' \
  '(-m --message)'{-m,--message}'[commit message]:message:' \
  '(-s --subject)'{-s,--subject}'[commit subject]:subject:' \
  '--scope[commit scope]:scope:' \
  '--body[commit body]:body:' \
  '--breaking[breaking change description]:description:' \
  '--issues[related issues]:issues:' \
  '*:file:_files'
