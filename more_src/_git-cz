#compdef git-cz
# Documentation: https://github.com/streamich/git-cz
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git-cz - commitizen-style git commit wrapper

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--non-interactive[run without interactive prompts]' \
  '--disable-emoji[remove emoji from commit messages]' \
  '--type=[commit type]:type:(feat fix docs style refactor perf test build ci chore revert)' \
  '--subject=[commit subject]:subject' \
  '--scope=[commit scope]:scope' \
  '--body=[commit body]:body' \
  '--breaking=[breaking change description]:description' \
  '--issues=[related issues]:issues' \
  '--lerna=[lerna packages affected]:packages' \
  '*:file:_files'
