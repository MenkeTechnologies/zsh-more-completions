#compdef sif
# Documentation: https://man.archlinux.org/search?q=sif
# Reference accessed: 2026-05-16

# sif: Singularity Image Format toolkit
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'add:add a data object to SIF'
  'del:delete a data object'
  'dump:dump a data object'
  'header:show the global header'
  'info:show info'
  'list:list data objects'
  'new:create a new SIF file'
  'setprim:set primary partition'
  'completion:emit shell completion'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'sif command' commands && ret=0 ;;
esac
return ret
