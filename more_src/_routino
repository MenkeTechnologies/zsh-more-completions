#compdef routino routino-router
# Documentation: https://manpages.debian.org/bookworm/routino/routino-router.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm routino-router(1) manpage. The Routino
# package ships separate binaries (planetsplitter/filedumper/
# visualiser/falsenodes) with distinct flag sets; this completion
# covers `routino` / `routino-router`.
# Removed from prior file: bogus man.archlinux.org search URL.

# routino: Routino route planner (OSM-based)
local -a transports
transports=(foot horse wheelchair bicycle moped motorcycle motorcar goods hgv psv)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--help-profile-xml[show profile XML help]' \
  '--help-profile-json[show profile JSON help]' \
  '--help-profile-perl[show profile Perl help]' \
  '--version[show version]' \
  '--dir=[data directory]:dir:_files -/' \
  '--prefix=[file name prefix]:prefix:' \
  '--profiles=[profiles XML file]:file:_files' \
  '--translations=[translations XML file]:file:_files' \
  '--exact-nodes-only[match only exact nodes]' \
  '--quiet[quiet output]' \
  '--loggable[loggable output format]' \
  '--logtime[include timing in log]' \
  '--logmemory[include memory in log]' \
  '--language=[output language]:lang:' \
  '(--output-gpx-track --output-gpx-route --output-text --output-text-all --output-none --output-stdout)--output-html[HTML output]' \
  '(--output-html --output-gpx-route --output-text --output-text-all --output-none --output-stdout)--output-gpx-track[GPX track output]' \
  '(--output-html --output-gpx-track --output-text --output-text-all --output-none --output-stdout)--output-gpx-route[GPX route output]' \
  '(--output-html --output-gpx-track --output-gpx-route --output-text-all --output-none --output-stdout)--output-text[text output]' \
  '(--output-html --output-gpx-track --output-gpx-route --output-text --output-none --output-stdout)--output-text-all[full text output]' \
  '(--output-html --output-gpx-track --output-gpx-route --output-text --output-text-all --output-stdout)--output-none[no file output]' \
  '(--output-html --output-gpx-track --output-gpx-route --output-text --output-text-all --output-none)--output-stdout[output to stdout]' \
  '--profile=[profile name]:profile:' \
  '--transport=[transport mode]:transport:('"$transports"')' \
  '(--quickest)--shortest[find shortest route]' \
  '(--shortest)--quickest[find quickest route]' \
  '--reverse[reverse the route]' \
  '--loop[make a loop route]' \
  '--heading=[initial heading in degrees]:deg:' \
  '*--lon1=[waypoint longitude]:lon:' \
  '*--lat1=[waypoint latitude]:lat:' \
  '--oneway=[honor oneway tags]:bool:(0 1)' \
  '--turns=[honor turn restrictions]:bool:(0 1)' \
  '--weight=[vehicle weight in tonnes]:tonnes:' \
  '--height=[vehicle height in metres]:m:' \
  '--width=[vehicle width in metres]:m:' \
  '--length=[vehicle length in metres]:m:' && ret=0
return ret
