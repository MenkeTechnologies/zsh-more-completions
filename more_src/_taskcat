#compdef taskcat

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'test:deploy test stacks and assert outputs'
      'lint:lint CloudFormation templates'
      'list:list legacy or deployed stacks from config'
      'upload:upload templates to S3 bucket'
      'delete:delete stacks from a taskcat run'
    )
    _describe -t commands 'taskcat command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-p --project-root)'{-p,--project-root}'=[project directory]:directory:_directories' \
      '(-c --config-file)'{-c,--config-file}'=[taskcat config]:file:_files' \
      '--no-verify[skip template verification]' \
      '*--lint-disable=[disable lint rules]:rule' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
