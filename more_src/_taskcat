#compdef taskcat
# Documentation: https://github.com/aws-quickstart/taskcat
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --project-root)'{-p,--project-root}'=[project directory]:directory:_directories' \
  '(-c --config-file)'{-c,--config-file}'=[taskcat config]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--no-verify[skip template verification]' \
  '*--lint-disable=[disable lint rules]:rule:' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'test:deploy test stacks and assert outputs'
      'lint:lint CloudFormation templates'
      'list:list legacy or deployed stacks from config'
      'upload:upload templates to S3 bucket'
      'delete:delete stacks from a taskcat run'
      'package:package CloudFormation templates'
      'deploy:deploy CloudFormation stack from config'
      'update-ami:update AMI IDs in templates'
    )
    _describe -t commands 'taskcat command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      (test)
        _arguments -s -S \
          '(-t --test-names)'{-t,--test-names}'=[comma-separated tests to run]:tests:' \
          '(-r --regions)'{-r,--regions}'=[comma-separated regions]:regions:' \
          '(-i --input-file)'{-i,--input-file}'=[config or template path]:file:_files' \
          '(-n --no-delete)'{-n,--no-delete}'[do not delete stacks after run]' \
          '(-k --keep-failed)'{-k,--keep-failed}'[keep stacks on failure]' \
          '(-s --skip-upload)'{-s,--skip-upload}'[use existing S3 bucket templates]' \
          '(-d --output-directory)'{-d,--output-directory}'=[log output directory]:dir:_directories' \
          '(-m --minimal-output)'{-m,--minimal-output}'[minimal output]' \
          '--enable-sig-v2[enable legacy S3 signature v2]' \
          '--dont-wait-for-delete[exit after delete call]' \
          '--lint-disable[skip cfn-lint validation]' \
          '*: : _default' && ret=0
        ;;
      (lint)
        _arguments -s -S \
          '(-i --input-file)'{-i,--input-file}'=[config or template path]:file:_files' \
          '*: : _default' && ret=0
        ;;
      (list)
        _arguments -s -S \
          '*: : _default' && ret=0
        ;;
      (upload)
        _arguments -s -S \
          '(-p --project-root)'{-p,--project-root}'=[project directory]:directory:_directories' \
          '*: : _default' && ret=0
        ;;
      (delete)
        _arguments -s -S \
          '*: : _default' && ret=0
        ;;
      (*)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
