#compdef ganon
# Documentation: https://pirovc.github.io/ganon/
# Highly efficient metagenomics binning and taxonomic profiling

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'ganon command' \
      'build[download and build a default database]' \
      'build-custom[build a database from custom sequences]' \
      'update[update a default database]' \
      'classify[classify reads against a database]' \
      'reassign[reassign reads with multiple matches]' \
      'report[generate a taxonomic report]' \
      'table[generate a table from multiple reports]' && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments -s \
          '--db-prefix=[database output prefix]:prefix:_files' \
          '--source=[reference source]:source:(refseq genbank)' \
          '--organism-group=[taxonomic groups]:group:(archaea bacteria fungi human invertebrate metagenomes plant protozoa vertebrate_mammalian vertebrate_other viral)' \
          '--taxid=[specific taxonomic ids]:taxid:' \
          '--taxonomy=[taxonomy system]:tax:(ncbi gtdb skip)' \
          '--complete-genomes[include only complete genomes]' \
          '--reference-genomes[include only reference genomes]' \
          '--top=[top assemblies per taxa]:n:' \
          '--filter-type=[filter type]:type:(ibf hibf)' \
          '--max-fp=[maximum false positive rate]:fp:' \
          '--filter-size=[fixed filter size]:size:' \
          '--kmer-size=[k-mer length]:k:' \
          '--window-size=[minimizer window size]:w:' \
          '--mode=[build mode]:mode:(avg smaller smallest faster fastest)' \
          '--threads=[number of threads]:threads:' \
          '--verbose[verbose output]' \
          '--quiet[quiet output]'
        ;;
      build-custom)
        _arguments -s \
          '--db-prefix=[database output prefix]:prefix:_files' \
          '--input=[input sequence files or directories]:input:_files' \
          '--input-file=[file defining inputs]:file:_files' \
          '--input-target=[parsing unit]:target:(file sequence)' \
          '--input-recursive[search directories recursively]' \
          '--taxonomy=[taxonomy source]:tax:(ncbi gtdb skip)' \
          '--taxonomy-files=[local taxonomy files]:files:_files' \
          '--level=[classification level]:level:(file sequence assembly leaves species genus custom)' \
          '--max-fp=[maximum false positive rate]:fp:' \
          '--filter-size=[fixed filter size]:size:' \
          '--kmer-size=[k-mer length]:k:' \
          '--window-size=[minimizer window size]:w:' \
          '--genome-size-files=[custom genome size files]:files:_files' \
          '--skip-genome-size[skip genome size estimation]' \
          '--threads=[number of threads]:threads:' \
          '--verbose[verbose output]'
        ;;
      classify)
        _arguments -s \
          '--db-prefix=[database prefix(es)]:prefix:_files' \
          '--single-reads=[single-end read files]:reads:_files' \
          '--paired-reads=[paired-end read files]:reads:_files' \
          '--output-prefix=[output file prefix]:prefix:_files' \
          '--output-one[write a single output file]' \
          '--output-all[write all classification files]' \
          '--output-unclassified[write unclassified read ids]' \
          '--rel-cutoff=[minimum k-mer match percentage]:cutoff:' \
          '--rel-filter=[filter threshold for matches]:filter:' \
          '--fpr-query=[false positive rate threshold]:fpr:' \
          '--min-count=[minimum count to report taxa]:count:' \
          '--multiple-matches=[multiple match resolution]:mode:(em lca skip)' \
          '--report-type=[report type]:type:(abundance reads dist matches corr)' \
          '--hierarchy-labels=[hierarchic level labels]:labels:' \
          '--threads=[number of threads]:threads:' \
          '--verbose[verbose output]'
        ;;
      report)
        _arguments -s \
          '--db-prefix=[database prefix]:prefix:_files' \
          '--input=[ganon classify .rep files]:input:_files' \
          '--output-prefix=[output file prefix]:prefix:_files' \
          '--report-type=[report type]:type:(reads abundance dist dist+abundance matches corr)' \
          '--ranks=[taxonomic ranks to report]:ranks:' \
          '--top-percentile=[top percentile filter]:pct:' \
          '--min-count=[minimum count filter]:count:' \
          '--max-count=[maximum count filter]:count:' \
          '--names=[filter by taxon names]:names:' \
          '--names-with=[filter by partial names]:names:' \
          '--taxids=[filter by taxids]:taxids:' \
          '--output-format=[output format]:fmt:(text tsv csv bioboxes)' \
          '--sort=[sort order]:sort:(rank lineage count unique)' \
          '--normalize[normalize counts]' \
          '--split-hierarchy[split output per hierarchy]'
        ;;
      table)
        _arguments -s \
          '--input=[ganon report .tre files]:input:_files' \
          '--output-file=[output table file]:file:_files' \
          '--rank=[taxonomic rank]:rank:' \
          '--min-count=[minimum count]:count:' \
          '--min-frequency=[minimum frequency]:freq:' \
          '--top-sample=[top entries per sample]:n:' \
          '--top-all=[top entries across all]:n:' \
          '--unclassified-label=[label for unclassified]:label:' \
          '--filtered-label=[label for filtered]:label:' \
          '--skip-zeros[skip zero rows and columns]' \
          '--transpose[transpose the table]'
        ;;
      update)
        _arguments -s \
          '--db-prefix=[database prefix to update]:prefix:_files' \
          '--output-db-prefix=[new database prefix]:prefix:_files' \
          '--threads=[number of threads]:threads:' \
          '--verbose[verbose output]'
        ;;
    esac
    ;;
esac

return ret
