#compdef clog-cli
# Documentation: https://github.com/clog-tool/clog-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# clog-cli: conventional changelog generator (binary name clog)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-r --repository)'{-r+,--repository=}'[repository URL for commit/issue links]:url:' \
  '(-f --from)'{-f+,--from=}'[start commit hash]:commit:' \
  '(-t --to)'{-t+,--to=}'[end commit hash]:commit:' \
  '(-T --format)'{-T+,--format=}'[output format]:format:(markdown json)' \
  '(-M --major)'{-M,--major}'[increment major version]' \
  '(-m --minor)'{-m,--minor}'[increment minor version]' \
  '(-p --patch)'{-p,--patch}'[increment patch version]' \
  '(-s --subtitle)'{-s+,--subtitle=}'[release subtitle]:text:' \
  '(-o --outfile)'{-o+,--outfile=}'[output file]:file:_files' \
  '(-c --config)'{-c+,--config=}'[configuration TOML file]:file:_files' \
  '(-i --infile)'{-i+,--infile=}'[changelog to append to]:file:_files' \
  '(-C --changelog)'{-C+,--changelog=}'[previous changelog to prepend to]:file:_files' \
  '(-F --from-latest-tag)'{-F,--from-latest-tag}'[use latest tag as start]' \
  '(-l --link-style)'{-l+,--link-style=}'[repo link style]:style:(github gitlab stash cgit)' \
  '(-g --git-dir)'{-g+,--git-dir=}'[local .git directory]:dir:_directories' \
  '(-w --work-tree)'{-w+,--work-tree=}'[local working tree]:dir:_directories' \
  '--setversion=[set specific version]:version:' && ret=0

return ret
