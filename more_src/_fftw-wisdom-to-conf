#compdef fftw-wisdom-to-conf
# Documentation: https://www.fftw.org/fftw3_doc/Wisdom.html
# Source: FFTW/fftw3 tools/fftw-wisdom-to-conf.in — convert wisdom on stdin to C config code on stdout (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    {-h,--help}'[print help]' \
    {-V,--version}'[print version/copyright info]' \
    && ret=0

return ret
