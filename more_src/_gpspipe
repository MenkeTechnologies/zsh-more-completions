#compdef gpspipe
# Documentation: https://man.archlinux.org/search?q=gpspipe
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-2 --split24)'{-2,--split24}'[split AIS Type 24A and B]' \
  '(-d --daemonize)'{-d,--daemonize}'[run as daemon]' \
  '(-D --debug)'{-D,--debug}'+[debug level]:level:' \
  '(-l --sleep)'{-l,--sleep}'[sleep before connecting]' \
  '(-n --count)'{-n,--count}'+[stop after N packets]:n:' \
  '(-N --counted-only)'{-N,--counted-only}'[only count packets]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '(-p --profile)'{-p,--profile}'[include profiling info]' \
  '(-P --pps)'{-P,--pps}'[include PPS messages]' \
  '(-r --raw)'{-r,--raw}'[raw NMEA output]' \
  '(-R --raw2)'{-R,--raw2}'[raw binary output]' \
  '(-s --serial)'{-s,--serial}'+[also write to serial device]:dev:_files' \
  '(-S --scaled)'{-S,--scaled}'[scaled output (AIS)]' \
  '(-t --timestamp)'{-t,--timestamp}'[timestamp output]' \
  '(-T --timefmt)'{-T,--timefmt}'+[strftime time format]:fmt:' \
  '(-u --usec)'{-u,--usec}'[microsecond precision]' \
  '(-w --json)'{-w,--json}'[JSON streaming]' \
  '(-x --seconds)'{-x,--seconds}'+[run for N seconds]:sec:' \
  '(-Z --iso8601)'{-Z,--iso8601}'[ISO 8601 timestamps]' \
  '*:gpsd_source:' && ret=0

return ret
