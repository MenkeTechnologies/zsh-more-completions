#compdef cdoing
# Documentation: https://github.com/awaisshah228/cdoing-agent
# Reference accessed: 2026-05-22
# Verified: packages/cli/src/index.ts Commander program and subcommands.

# Zsh completion for cdoing - multi-provider AI coding assistant CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-m --model)'{-m,--model}'[model id]:model:' \
  '(-p --provider)'{-p,--provider}'[AI provider]:provider:(anthropic openai google custom)' \
  '--base-url[base URL for custom providers]:url:' \
  '--api-key[API key override]:key:' \
  '--mode[permission mode]:mode:(ask auto-edit auto)' \
  '(-d --dir)'{-d,--dir}'[working directory]:directory:_directories' \
  '--login[OAuth login]:provider:(anthropic openai-codex google github-copilot)' \
  '--logout[clear stored OAuth tokens]' \
  '--print[non-interactive print output]' \
  '(-r --resume)'{-r,--resume}'[resume conversation by ID]:id:' \
  '(-c --continue)'{-c,--continue}'[continue most recent conversation]' \
  '--max-turns[maximum agent turns]:turns:' \
  '--output-format[output format]:format:(text json stream-json)' \
  '--verbose[enable verbose logging]' \
  '--system-prompt[custom system prompt]:text:' \
  '--allowed-tools[comma-separated allowed tools]:tools:' \
  '--disallowed-tools[comma-separated disallowed tools]:tools:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'cdoing command' \
      'config[manage configuration]' \
      'init[initialize project with .cdoing/config.md]' \
      'doctor[diagnose setup]' \
      'completions[generate shell completion script]' \
      'index[index codebase for search]' && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _arguments \
          '1:action:(get set list)' \
          '2:key:' \
          '3:value:' && ret=0
        ;;
      completions)
        _arguments '1:shell:(zsh bash)' && ret=0
        ;;
      index)
        _arguments \
          '--full[rebuild index from scratch]' \
          '(-d --dir)'{-d,--dir}'[directory to index]:directory:_directories' \
          '--stats[show index statistics only]' && ret=0
        ;;
      *)
        _arguments '*:prompt:' && ret=0
        ;;
    esac
    ;;
esac

return ret
