#compdef wdio-cli
# _wdio-cli — WebdriverIO wdio-cli CLI command-line frontend for the WebdriverIO Next Generation Selenium-WebDriver-based browser and mobile-automation testing framework launching test runners config wizard mocha jasmine cucumber spec dot allure junit JsonReporter outputting Sauce Labs BrowserStack-cloud-integration (WebdriverIO team, JavaScript); commander
# upstream: https://webdriver.io/

_wdio-cli() {
    local -a sub=(
        'config:run config wizard'
        'install:install service or reporter'
        'repl:start REPL session'
        'run:run tests with config'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--watch[watch mode]' \
        '--hostname=+[host]:_hosts' \
        '--port=+[port]:n:' \
        '--path=+[path]:str:' \
        '--logLevel=+[l]:l:(trace debug info warn error silent)' \
        '--bail=+[N]:n:' \
        '--baseUrl=+[url]:str:' \
        '--waitforTimeout=+[ms]:n:' \
        '--framework=+[f]:f:(mocha jasmine cucumber)' \
        '--reporters=+[list]:str:' \
        '--user=+[user]:str:' \
        '--key=+[key]:str:' \
        '--mochaOpts=+[opts]:str:' \
        '--jasmineNodeOpts=+[opts]:str:' \
        '--cucumberOpts=+[opts]:str:' \
        '--spec=+[files]:str:' \
        '--exclude=+[files]:str:' \
        '--suite=+[name]:str:' \
        '--capabilities=+[json]:str:' \
        '--maxInstances=+[N]:n:' \
        '--coverage[enable coverage]' \
        '--no-prompt[no prompt]' \
        '--update-snapshots=+[m]:m:(new all none)' \
        '--from-snapshots[run only snapshot tests]' \
        '--repeat=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wdio-cli subcommand' sub ;;
        args)
            _arguments '*:wdio.conf:_files -g "wdio.conf.* *.js *.ts"'
            ;;
    esac
}

_wdio-cli "$@"
