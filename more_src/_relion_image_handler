#compdef relion_image_handler
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: perform per-image operations on MRC images, stacks and movies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input STAR file, image (.mrc) or movie/stack (.mrcs)]:file:_files' \
  '--o=[output name]:file:_files' \
  '--float16[write in half-precision 16 bit floating point]' \
  '--multiply_constant=[multiply pixel values by this constant]:value' \
  '--divide_constant=[divide pixel values by this constant]:value' \
  '--add_constant=[add this constant to pixel values]:value' \
  '--subtract_constant=[subtract this constant from pixel values]:value' \
  '--threshold_above=[set values higher than this to this value]:value' \
  '--threshold_below=[set values lower than this to this value]:value' \
  '--multiply=[multiply input image(s) by pixel values in this image]:file:_files' \
  '--divide=[divide input image(s) by pixel values in this image]:file:_files' \
  '--add=[add pixel values in this image to the input]:file:_files' \
  '--subtract=[subtract pixel values in this image from the input]:file:_files' \
  '--fsc=[calculate FSC curve with this image]:file:_files' \
  '--power[calculate power spectrum of the input image]' \
  '--guinier[calculate Guinier plot and B-factor]' \
  '--guinier_minres=[lowest resolution (A) for B-factor fitting]:value' \
  '--guinier_maxres=[highest resolution (A) for B-factor fitting]:value' \
  '--adjust_power=[adjust power spectrum to match this image]:file:_files' \
  '--fourier_filter=[multiply Fourier transform with this image]:file:_files' \
  '--optimise_scale_subtract[optimise scale between maps before subtraction]' \
  '--optimise_bfactor_subtract=[search range for relative B-factor (A^2)]:value' \
  '--mask_optimise_subtract=[use only voxels in this mask to optimise scale]:file:_files' \
  '--stats[calculate per-image statistics]' \
  '--com[calculate center of mass]' \
  '--bfactor=[apply a B-factor (A^2)]:value' \
  '--lowpass=[low-pass filter frequency (A)]:value' \
  '--highpass=[high-pass filter frequency (A)]:value' \
  '--directional=[directionality of low-pass filter (X, Y or Z)]:axis:(X Y Z)' \
  '--LoG=[diameter for optimal Laplacian of Gaussian filter (A)]:value' \
  '--angpix=[pixel size (A)]:value' \
  '--rescale_angpix=[scale image(s) to this new pixel size (A)]:value' \
  '--force_header_angpix=[change pixel size in header without rescaling]:value' \
  '--new_box=[resize image(s) to this new box size (pixels)]:value' \
  '--filter_edge_width=[width of raised cosine on filter edge]:value' \
  '--flipX[flip 2D image or 3D map in X-direction]' \
  '--flipY[flip 2D image or 3D map in Y-direction]' \
  '--flipZ[flip 3D map in Z-direction]' \
  '--invert_hand[invert hand by flipping X preserving symmetry origin]' \
  '--shift_com[shift image(s) to their center-of-mass]' \
  '--shift_x=[shift images this many pixels in X]:value' \
  '--shift_y=[shift images this many pixels in Y]:value' \
  '--shift_z=[shift images this many pixels in Z]:value' \
  '--avg_ampl[calculate average amplitude spectrum]' \
  '--avg_ampl2[calculate average amplitude spectrum]' \
  '--avg_ampl2_ali[calculate average amplitude spectrum for aligned images]' \
  '--average[calculate average of all images without alignment]' \
  '--correct_avg_ampl=[correct all images with this average amplitude spectrum]:file:_files' \
  '--minr_ampl_corr=[minimum radius (Fourier pixels) to apply average amplitudes]:value' \
  '--remove_nan[replace non-numerical values (NaN, inf)]' \
  '--replace_nan=[replace non-numerical values with this value]:value' \
  '--phase_randomise=[randomise phases beyond this resolution (A)]:value' \
  '--sym=[symmetrise 3D map with this point group]:group' \
  '--add_edge[add a barcode-like edge to micrograph/movie frames]' \
  '--avg_bin=[width (frames) for binning average]:value' \
  '--avg_first=[first frame to include in averaging]:value' \
  '--avg_last=[last frame to include in averaging]:value' \
  '--black=[pixel value for black]:value' \
  '--white=[pixel value for white]:value' \
  '--sigma_contrast=[set white/black this many stddev from mean]:value' \
  '--colour_fire[black-grey-white-red colour scheme]' \
  '--colour_ice[blue-black-grey-white colour scheme]' \
  '--colour_rainbow[cyan-blue-black-red-yellow colour scheme]' \
  '*:file:_files' && ret=0

return ret
