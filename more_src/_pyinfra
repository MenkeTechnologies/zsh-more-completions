#compdef pyinfra
# _pyinfra — infrastructure automation tool (pyinfra-dev/pyinfra)
# upstream: https://github.com/pyinfra-dev/pyinfra

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--dry[dry run mode]' \
  '--limit=[limit execution to hosts]:hosts:' \
  '--serial[execute operations serially]' \
  '--no-wait[do not wait between operations]' \
  '--debug[debug mode]' \
  '--debug-facts[print fact debug info]' \
  '--debug-operations[print operation debug info]' \
  '--support[print support info]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-y --yes)'{-y,--yes}'[auto-confirm operations]' \
  '--sudo[use sudo]' \
  '--sudo-user=[sudo user]:user:' \
  '--su-user=[su user]:user:' \
  '--port=[SSH port]:port:' \
  '--user=[SSH user]:user:' \
  '--key=[SSH key file]:file:_files' \
  '--key-password=[SSH key password]:password:' \
  '--password=[SSH password]:password:' \
  '--shell-executable=[shell to use]:shell:_command_names' \
  '--data=[extra data key=value]:data:' \
  '1:inventory:_files' \
  '*:operations or deploy:_files'
