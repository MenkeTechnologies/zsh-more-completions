#compdef pyinfra

# Zsh completion for pyinfra - infrastructure automation in Python

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--version[show version]' \
  '--dry[dry run, do not execute]' \
  '--debug[enable debug mode]' \
  '--debug-facts[print raw facts data]' \
  '--debug-operations[print raw operation data]' \
  '--serial[run operations serially]' \
  '--no-wait[do not wait between operations]' \
  '--parallel[number of parallel processes]:number:' \
  '--limit[limit targets]:limit:' \
  '--fail-percent[percent of hosts that can fail]:percent:' \
  '--data[extra data in key=value format]:data:' \
  '--group-data[extra group data]:data:' \
  '--config[config file]:file:_files' \
  '--chdir[change directory before running]:dir:_directories' \
  '--su-user[su to user]:user:_users' \
  '--sudo[execute with sudo]' \
  '--sudo-user[sudo to user]:user:_users' \
  '--use-sudo-password[prompt for sudo password]' \
  '--port[SSH port]:port:' \
  '--user[SSH user]:user:_users' \
  '--key[SSH private key]:file:_files' \
  '--key-password[SSH private key password]:password:' \
  '--password[SSH password]:password:' \
  '1:inventory:_files' \
  '2:operations or deploy file:_files' \
  '*::args:' && ret=0

return ret
