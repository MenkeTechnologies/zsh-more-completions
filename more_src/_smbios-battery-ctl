#compdef smbios-battery-ctl

# smbios-battery-ctl: configure Dell battery primary mode
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  "--get-charging-mode[get charging mode]" "--set-charging-mode=[set charging mode]:val:(express adaptive standard primarily-ac-use custom)" "--set-custom-charge-interval=[set custom charge interval]:start end:" \
  '*::smbios-battery-ctl args:_files' && ret=0
return ret
