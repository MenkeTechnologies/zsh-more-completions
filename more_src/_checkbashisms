#compdef checkbashisms
# Documentation: https://manpages.debian.org/checkbashisms.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for checkbashisms (Debian devscripts) - check shell scripts for bashisms

_arguments -s -S \
  '(-n --newline)'{-n,--newline}'[check for echo -n usage]' \
  '(-p --posix)'{-p,--posix}'[check for non-POSIX issues required by Debian Policy 10.4 (implies -n)]' \
  '(-f --force)'{-f,--force}'[force checking even of non-shell scripts]' \
  '(-l --lint)'{-l,--lint}'[act like a linter for editor integration]' \
  '(-x --extra)'{-x,--extra}'[highlight non-bashism lines useful for false-positive triage]' \
  '(-e --early-fail)'{-e,--early-fail}'[exit immediately after first error]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version and copyright]' \
  '*:script file:_files' && return 0
