#compdef cabal-diff
# _cabal-diff — diff cabal package APIs across versions (phadej/cabal-extras)
# upstream: https://github.com/phadej/cabal-extras
# Flags from cabal-diff/src/CabalDiff/Main.hs (optparse-applicative).

_cabal-diff() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-w --with-compiler)'{-w+,--with-compiler=}'[compiler to use]:ghc:_command_names -e' \
        '--old-compiler=[compiler for old version]:ghc:_command_names -e' \
        '--new-compiler=[compiler for new version]:ghc:_command_names -e' \
        '1:package name:' \
        '2:old version:' \
        '3:new version:'
}

_cabal-diff "$@"
