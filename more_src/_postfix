#compdef postfix
# _postfix — Postfix mail-system control program (start/stop/reload the master(8) daemon, check config, rotate logs, manage TLS, run multi-instance helpers)
# upstream: https://github.com/vdukhovni/postfix
# Flags + commands from postfix/man/man1/postfix.1 on tip; -c is required when not using the default configuration directory.

_postfix() {
    _arguments \
        '-c+[config directory (default /etc/postfix)]:dir:_files -/' \
        '-D[run main.cf master(8) in debug mode]' \
        '-v[verbose mode (more diagnostics)]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'postfix command' \
                '(check:warn about bad ownership/permissions + create missing dirs start:start the postfix system start-fg:start with master(8) in foreground (init mode if PID 1) stop:stop in orderly fashion abort:stop abruptly flush:force delivery of every deferred message reload:re-read configuration files status:show running/stopped status set-permissions:set ownership + permissions per postfix-files (accepts name=value) logrotate:rotate $maillog_file non-bdb:migrate from BDB hash/btree to lmdb/cdb tls:opportunistic TLS + key/cert management upgrade-configuration:add/update main.cf + master.cf settings)'
            ;;
    esac
}

_postfix "$@"
