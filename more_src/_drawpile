#compdef drawpile
# Documentation: https://raw.githubusercontent.com/drawpile/Drawpile/main/src/desktop/main.cpp
# Reference accessed: 2026-05-16
# Verified: upstream Drawpile main.cpp QCommandLineOption registration.
# Also inherits Qt's standard --help and --version.
# Removed from prior file: bogus man.archlinux.org search URL.

# drawpile: collaborative drawing program
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--data-dir=[override read-only data directory]:dir:_files -/' \
  '--portable-data-dir=[override settings directory]:dir:_files -/' \
  '--opengl=[OpenGL implementation override]:impl:' \
  '--buffer=[swap buffering (1/2/3)]:n:(1 2 3)' \
  '--join=[open the given session URL]:url:' \
  '--open=[open the given file]:file:_files' \
  '--blank=[start with blank canvas WxHxcolor]:WxHxcolor:' \
  '--start-page=[start page]:page:' \
  '--single-session[run in single-session mode]' \
  '--no-restore-window-position[do not restore main window position]' \
  '--auto-record=[record session to file]:file:_files' \
  '--connect-strategy=[connection strategy]:strategy:' \
  '--renderer=[canvas renderer]:renderer:(none system qgraphicsview opengl)' \
  '--no-native-dialogs[disable native dialogs]' \
  '*:url or file:_files' && ret=0
return ret
