#compdef connmanctl

# Zsh completion for connmanctl (ConnMan network manager CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'state:show current state'
      'technologies:list available technologies'
      'enable:enable a technology'
      'disable:disable a technology'
      'tether:enable/disable tethering'
      'services:list available services'
      'peers:list available peers'
      'scan:scan for services'
      'connect:connect to a service'
      'disconnect:disconnect from a service'
      'move-before:move service before another'
      'move-after:move service after another'
      'config:configure a service'
      'monitor:monitor property changes'
      'vpnconnections:list VPN connections'
      'vpnagent:register VPN agent'
      'session:create a session'
      'help:show help'
      'exit:exit interactive mode'
      'quit:quit interactive mode'
    )
    _describe -t commands 'connmanctl command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (enable|disable|scan)
        _arguments '1:technology:(wifi bluetooth cellular ethernet gadget)' && ret=0
        ;;
      (connect|disconnect)
        local -a services
        services=(${(f)"$(connmanctl services 2>/dev/null | awk '{print $NF}')"})
        _arguments '1:service:compadd -a services' && ret=0
        ;;
      (tether)
        _arguments \
          '1:technology:(wifi bluetooth)' \
          '2:action:(on off)' \
          '3:SSID' \
          '4:passphrase' && ret=0
        ;;
      (config)
        _arguments \
          '1:service' \
          '--autoconnect[set autoconnect]:value:(yes no)' \
          '--ipv4[set IPv4 configuration]:method:(dhcp manual off)' \
          '--ipv6[set IPv6 configuration]:method:(auto manual off)' \
          '--nameservers[set nameservers]:nameservers' \
          '--timeservers[set timeservers]:timeservers' \
          '--domains[set search domains]:domains' \
          '--proxy[set proxy]:method:(direct auto manual)' \
          '--remove[remove service]' && ret=0
        ;;
      (monitor)
        _arguments \
          '--services[monitor services]' \
          '--tech[monitor technologies]' \
          '--manager[monitor manager]' \
          '--vpnmanager[monitor VPN manager]' \
          '--vpnconnection[monitor VPN connections]' && ret=0
        ;;
    esac
    ;;
esac

return ret
