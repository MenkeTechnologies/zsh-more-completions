#compdef cargo-cmd
# Documentation: https://man.archlinux.org/search?q=cargo-cmd
# Reference accessed: 2026-05-16

# https://github.com/simonhyll/cargo-commander — run commands defined in Commander.toml

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-f --file)'{-f,--file}'=[custom Commander file]:file:_files' \
  '(-p --parallel)'{-p,--parallel}'[run commands in parallel]' \
  '1:command_name_orm_url_or_file:_default' \
  '*::args:_default' && return 0
