#compdef lodestar
# Documentation: https://man.archlinux.org/search?q=lodestar
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--network=[Consensus network preset]:network:(mainnet gnosis chiado hoodi)' \
  '--data-dir=[Beacon database directory]:directory:_directories' \
  '--execution-endpoint=[Engine API URL]:url:' \
  '--jwt-secret=[JWT secret file for Engine API]:file:_files' \
  '--checkpoint-sync-url=[Trusted checkpoint sync URL]:url:' \
  '--rest.port=[HTTP beacon API port]:port:' \
  '--metrics.port=[Prometheus port]:port:' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'beacon:Run the Lodestar beacon node'
      'validator:Run a dedicated validator client'
      'bootnode:Run discv5 bootnode'
      'lightclient:Run an optimistic light client'
      'dev:Developer utilities and ephemeral networks'
      'cli:Miscellaneous maintenance tools'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
