#compdef iperf3
# _iperf3 — ESnet iperf3 (rewrite of iperf2; cross-platform TCP/UDP/SCTP throughput tester with JSON output and built-in client/server modes)
# upstream: https://github.com/esnet/iperf
# Flags from src/iperf_api.c longopts on tip.

_iperf3() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-p --port)'{-p+,--port=}'[server port]:port:' \
        '(-f --format)'{-f+,--format=}'[output format]:fmt:(k m g K M G t)' \
        '(-i --interval)'{-i+,--interval=}'[report interval (sec)]:sec:' \
        '(-D --daemon)'{-D,--daemon}'[run server as daemon]' \
        '(-1 --one-off)'{-1,--one-off}'[handle one connection then exit]' \
        '(-V --verbose)'{-V,--verbose}'[verbose output]' \
        '(-J --json)'{-J,--json}'[JSON output]' \
        '--json-stream[stream JSON output (one object per line)]' \
        '--json-stream-full-output[include final summary in JSON stream]' \
        '(- 1 -s --server -c --client)'{-s,--server}'[server mode]' \
        '(- 1 -s --server -c --client)'{-c+,--client=}'[client mode (host)]:host:_hosts' \
        '(-u --udp)'{-u,--udp}'[use UDP]' \
        '(-b --bitrate --bandwidth)'{-b+,--bitrate=,--bandwidth=}'[target bitrate (suffix k/m/g)]:rate:' \
        '--server-bitrate-limit=[max accepted client bitrate]:rate:' \
        '--server-max-duration=[max client test duration accepted]:sec:' \
        '(-t --time)'{-t+,--time=}'[test duration (sec)]:sec:' \
        '(-n --bytes)'{-n+,--bytes=}'[bytes to send (overrides -t)]:n:' \
        '(-k --blockcount)'{-k+,--blockcount=}'[block count to send (overrides -t)]:n:' \
        '(-l --length)'{-l+,--length=}'[buffer length per read/write]:bytes:' \
        '(-P --parallel)'{-P+,--parallel=}'[parallel streams]:n:' \
        '(-R --reverse --bidir)'{-R,--reverse}'[server sends to client]' \
        '(-R --reverse --bidir)--bidir[full-duplex test]' \
        '(-w --window)'{-w+,--window=}'[socket buffer size / window]:bytes:' \
        '(-B --bind)'{-B+,--bind=}'[bind source address]:ip:' \
        '--bind-dev=[bind to network interface]:iface:_net_interfaces' \
        '--cport=[client source port]:port:' \
        '(-M --set-mss)'{-M+,--set-mss=}'[set TCP MSS]:bytes:' \
        '(-N --no-delay)'{-N,--no-delay}'[set TCP_NODELAY]' \
        '(-4 -6)'{-4,--version4}'[use IPv4 only]' \
        '(-4 -6)'{-6,--version6}'[use IPv6 only]' \
        '(-S --tos)'{-S+,--tos=}'[IP type-of-service]:tos:' \
        '--dscp=[IP DSCP]:dscp:' \
        '--extra-data=[opaque string included in JSON output]:str:' \
        '(-L --flowlabel)'{-L+,--flowlabel=}'[IPv6 flow label]:n:' \
        '(-Z --zerocopy)'{-Z,--zerocopy}'[use sendfile() zero-copy]' \
        '(-O --omit)'{-O+,--omit=}'[omit first N seconds]:sec:' \
        '(-F --file)'{-F+,--file=}'[use file payload]:file:_files' \
        '--repeating-payload[use a known repeating payload]' \
        '--timestamps=[prepend timestamp to each report]:fmt:' \
        '(-A --affinity)'{-A+,--affinity=}'[CPU affinity]:cpu:' \
        '(-T --title)'{-T+,--title=}'[per-line output prefix]:str:' \
        '(-C --congestion --linux-congestion)'{-C+,--congestion=,--linux-congestion=}'[TCP congestion algorithm]:algo:' \
        '--sctp[use SCTP]' \
        '--nstreams=[SCTP streams]:n:' \
        '(-X --xbind)'{-X+,--xbind=}'[bind SCTP association]:host:' \
        '(-I --pidfile)'{-I+,--pidfile=}'[write server pid file]:file:_files' \
        '--logfile=[write output to file]:file:_files' \
        '--forceflush[flush after each line]' \
        '--get-server-output[print server output in client]' \
        '--udp-counters-64bit[64-bit UDP counters]' \
        '--no-fq-socket-pacing[disable FQ socket pacing]' \
        '--dont-fragment[set IP DF bit]' \
        '--skip-rx-copy[skip rx copy (MSG_TRUNC)]' \
        '--username=[client SSL/RSA username]:user:' \
        '--rsa-public-key-path=[client RSA public key file]:file:_files' \
        '--rsa-private-key-path=[server RSA private key file]:file:_files' \
        '--authorized-users-path=[server authorized users file]:file:_files' \
        '--time-skew-threshold=[server max accepted skew (sec)]:sec:' \
        '--use-pkcs1-padding[use PKCS#1 padding (interop)]' \
        '--fq-rate=[FQ pacing rate (bps)]:rate:' \
        '--pacing-timer=[pacing timer (us)]:us:' \
        '--connect-timeout=[client connect timeout (ms)]:ms:' \
        '--idle-timeout=[server idle timeout (sec)]:sec:' \
        '--rcv-timeout=[server receive timeout (ms)]:ms:' \
        '--snd-timeout=[send timeout (ms)]:ms:' \
        '--cntl-ka=[enable TCP keepalive on control connection]:cfg:'
}

_iperf3 "$@"
