#compdef simpdftex
# Documentation: simpdftex --help (TeX Live 2026)
# Source: TeX simpdftex — compile TeX -> PDF via dvips+gs (or dvipdfm/dvipdfmx).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--mode=[METAFONT mode string]:mode:' \
    '--dvipsopts=[dvips option string]:opts:' \
    '--extradvipsopts=[extra dvips options]:opts:' \
    '--pdf[do not echo final pdf name]' \
    '--default[default mode]' \
    '--maxpk=[max PK fonts]:n:' \
    '--maxpfb=[max PFB fonts]:n:' \
    '--extendedname[include format-tag in jobname]' \
    '--no-echo-version[skip version echo]' \
    '--tex-path=[TeX binaries directory]:dir:_files -/' \
    '--keep-psfile[keep intermediate PostScript]' \
    '--distiller-path=[distiller binary directory]:dir:_files -/' \
    '--debug[verbose / debugging output]' \
    '--distiller=[distiller program]:prog:_command_names -e' \
    '--distiller-filter=[program piped to distiller]:prog:_command_names -e' \
    '--distilleropts=[distiller options]:opts:' \
    '(- *)--help[show help]' \
    '--outdir=[output directory]:dir:_files -/' \
    '--extratexopts=[extra LaTeX options]:opts:' \
    '--dvipdfmopts=[dvipdfm/dvipdfmx options]:opts:' \
    '1:format name:(latex pdflatex xelatex tex pdftex etex)' \
    '*:tex or dvi file:_files -g "*.{tex,dvi}"' \
    && ret=0

return ret
