#compdef sf-mcp-server
# Documentation: https://github.com/salesforcecli/mcp
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (@salesforce/mcp).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--orgs=[authorized orgs (comma list, or DEFAULT_TARGET_ORG/DEFAULT_TARGET_DEV_HUB/ALLOW_ALL_ORGS)]:orgs:' \
  '--toolsets=[enable tool groups (orgs,metadata,data,users,all)]:toolsets:' \
  '--tools=[enable specific tool names (comma list)]:tools:' \
  '--allow-non-ga-tools[permit non-GA tools alongside GA tools]' \
  '--debug[emit debug log output]' \
  '--dynamic-tools[enable experimental dynamic tool loading]' \
  '--no-telemetry[disable automatic data collection]' && ret=0

return ret
