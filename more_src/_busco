#compdef busco busco-cli
# _busco — Felipe Simao Mathieu Seppey BUSCO Benchmarking Universal Single-Copy Orthologs assembly completeness assessor (metashot team, Python); argparse
# upstream: https://gitlab.com/ezlab/busco

_busco() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i+[input fasta]:file:_files -g "*.fa *.fasta *.fna *.faa *.aa *.fa.gz"' \
        '--in=+[input fasta]:file:_files -g "*.fa *.fasta *.fna *.faa *.aa *.fa.gz"' \
        '-o+[output name]:str:' \
        '--out=+[output name]:str:' \
        '--out_path=+[output path]:dir:_files -/' \
        '-m+[mode]:m:(genome geno proteins prot transcriptome tran)' \
        '--mode=+[mode]:m:(genome geno proteins prot transcriptome tran)' \
        '-l+[lineage dataset]:str:' \
        '--lineage_dataset=+[lineage dataset]:str:' \
        '-c+[CPUs]:n:' \
        '--cpu=+[CPUs]:n:' \
        '-e+[evalue]:f:' \
        '--evalue=+[evalue]:f:' \
        '-r[restart]' \
        '--restart[restart]' \
        '-f[force overwrite]' \
        '--force[force overwrite]' \
        '--config=+[config file]:file:_files -g "*.ini *.cfg"' \
        '--auto-lineage[auto lineage]' \
        '--auto-lineage-prok[auto lineage prokaryotic]' \
        '--auto-lineage-euk[auto lineage eukaryotic]' \
        '--update-data[update datasets]' \
        '--list-datasets[list datasets]' \
        '--datasets-version=+[version]:str:' \
        '--download_path=+[download path]:dir:_files -/' \
        '--download_base_url=+[base url]:url:_urls' \
        '--download=+[dataset]:str:' \
        '--metaeuk_parameters=+[params]:str:' \
        '--metaeuk_rerun_parameters=+[params]:str:' \
        '--augustus[use augustus]' \
        '--augustus_parameters=+[params]:str:' \
        '--augustus_species=+[species]:str:' \
        '--miniprot[use miniprot]' \
        '--miniprot_parameters=+[params]:str:' \
        '--limit=+[N]:n:' \
        '--long[long algorithm]' \
        '--use_augustus[use augustus]' \
        '--use_miniprot[use miniprot]' \
        '--use_metaeuk[use metaeuk]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--scaffold_composition[scaffold composition]' \
        '--contig_break=+[N]:n:' \
        '--tar[tar archive output]' \
        '--skip_bbtools[skip bbtools]' \
        '--offline[offline mode]'
}

_busco "$@"
