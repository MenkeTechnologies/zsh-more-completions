#compdef fillbad
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss49.html
# KAPPA: remove regions of bad values from an NDF

local ret=1

_arguments -s \
  'BLOCK=[maximum block size in pixels]:block' \
  'IN=[input NDF containing bad values]:NDF:_files' \
  'MEMORY=[process whole array or in chunks]:memory:(TRUE FALSE)' \
  'NITER=[number of relaxation iterations]:niter' \
  'OUT=[output NDF free of bad values]:NDF:_files' \
  'SIZE=[initial scale lengths in pixels]:size' \
  'TITLE=[title for the output NDF]:title' \
  'VARIANCE=[propagate and use variance]:variance:(TRUE FALSE)' \
  '*:NDF:_files' && ret=0

return ret
