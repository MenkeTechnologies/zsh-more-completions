#compdef arq

# Completion for arq - Python async job queue CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--burst[burst mode, exit when queue is empty]' \
  '--check[health check]' \
  '--watch=[watch directory for changes and reload]:directory:_directories' \
  {-v,--verbose}'[verbose output]' \
  '1:worker settings module (e.g. app.WorkerSettings)' && ret=0

return ret
