#compdef virt-bootstrap

# virt-bootstrap: extract container image into rootfs for libvirt-lxc
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-f[format]:format:(dir qcow2)' \
  '--format=[format]:format:(dir qcow2)' \
  '-i[idmap (uid:gid:count)]:idmap:' \
  '--idmap=[idmap (uid:gid:count)]:idmap:' \
  '-u[username]:user:_users' \
  '--username=[username]:user:_users' \
  '-p[password]:pass:' \
  '--password=[password]:pass:' \
  '--root-password=[root password]:pass:' \
  '--no-cache[do not cache layers]' \
  '--insecure[insecure registry]' \
  '*:source dest:_files' && ret=0
return ret
