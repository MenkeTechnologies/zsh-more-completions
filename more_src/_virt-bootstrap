#compdef virt-bootstrap
# Documentation: https://github.com/virt-manager/virt-bootstrap
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above and
# src/virtBootstrap/virt_bootstrap.py master source.

# virt-bootstrap: extract container image into rootfs for libvirt-lxc
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-f --format)'{-f+,--format=}'[output root filesystem format]:format:(dir qcow2)' \
  '--root-password=[set root password]:pass:' \
  '--no-cache[do not store downloaded Docker images]' \
  '(-d --debug)'{-d,--debug}'[show debug messages]' \
  '(-q --quiet)'{-q,--quiet}'[do not print progress messages]' \
  '--status-only[show only progress information]' \
  '(-u --username)'{-u+,--username=}'[username for source registry]:user:' \
  '(-p --password)'{-p+,--password=}'[password for source registry]:pass:' \
  '--not-secure[ignore HTTPS errors]' \
  '--uidmap=[map UIDs (host:guest:count)]:uidmap:' \
  '--gidmap=[map GIDs (host:guest:count)]:gidmap:' \
  '--idmap=[map both UIDs and GIDs]:idmap:' \
  ':source URI:' \
  ':destination folder:_files -/' && ret=0
return ret
