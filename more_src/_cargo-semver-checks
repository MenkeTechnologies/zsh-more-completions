#compdef cargo-semver-checks

# Zsh completion for cargo-semver-checks (Rust semver compatibility checker)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[use verbose output]' \
  '--verbose[use verbose output]' \
  '-q[do not print cargo log messages]' \
  '--quiet[do not print cargo log messages]' \
  '--color=[coloring]:when:(auto always never)' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check-release:check for semver violations in a new release'
    )
    _describe -t commands 'cargo-semver-checks command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      check-release)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-p+[package to check]:package' \
          '--package=[package to check]:package' \
          '--workspace[check all packages in workspace]' \
          '--exclude=[exclude packages]:package' \
          '--manifest-path=[path to Cargo.toml]:file:_files' \
          '--current-rustdoc=[path to current rustdoc JSON]:file:_files' \
          '--baseline-rustdoc=[path to baseline rustdoc JSON]:file:_files' \
          '--baseline-rev=[git revision to use as baseline]:rev' \
          '--baseline-version=[crates.io version to use as baseline]:version' \
          '--baseline-root=[root directory for baseline]:directory:_directories' \
          '--release-type=[set the release type]:type:(major minor patch)' \
          '--default-features[activate default features]' \
          '--all-features[activate all features]' \
          '--features=[activate features]:features' \
          '--target=[target triple]:target' \
          '--json[output JSON]' \
          '--output-format=[output format]:format:(human json)' && ret=0
        ;;
    esac
    ;;
esac

return ret
