#compdef kafka-protobuf-console-producer
# Documentation: https://docs.confluent.io/platform/current/schema-registry/fundamentals/serdes-develop/serdes-protobuf.html
# kafka-protobuf-console-producer - produce Protobuf data to a Kafka topic from JSON

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--bootstrap-server[Kafka broker to connect to]:broker:' \
  '--topic[topic to produce to]:topic:' \
  '*--property[set a reader property (e.g. schema.registry.url, value.schema, key.schema, parse.key)]:property:' \
  '--producer.config[producer config properties file]:file:_files' \
  '*:arg:' && ret=0

return ret
