#compdef oxen

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--config-dir=[Directory for oxen user and auth config]:directory:_directories' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'add:Stage paths or files for the next commit'
      'branch:List, create, or delete branches'
      'checkout:Restore working tree paths or switch branch'
      'clean:Discard or clean repository state'
      'clone:Clone a remote Oxen repository'
      'commit:Record changes to the repository'
      'config:Get or set configuration values'
      'create-remote:Create remote repository metadata'
      'db:Query or manage indexed databases'
      'delete-remote:Delete a remote repository'
      'df:Inspect tabular or dataframe assets'
      'diff:Show changes between commits or working tree'
      'download:Download remote repository content'
      'fetch:Fetch updates from remotes'
      'embeddings:Manage embedding indexes and queries'
      'info:Show repository or object information'
      'init:Create a new Oxen repository'
      'load:Load data or repository fixtures'
      'log:Display commit history'
      'ls:List repository paths with metadata'
      'merge:Merge changes between branches'
      'migrate:Run repository migrations'
      'moo:Easter egg / diagnostics'
      'node:Show or manage node metadata'
      'prune:Prune obsolete cached objects'
      'fsck:Verify and repair repository structure'
      'pull:Integrate remote changes'
      'push:Publish commits to a remote'
      'restore:Restore paths from a commit'
      'remote:Manage named remotes'
      'rm:Remove tracked paths'
      'save:Snapshot local experimental state'
      'schemas:Define or inspect data schemas'
      'status:Show working tree status'
      'tree:Display repository tree'
      'upload:Upload blobs or datasets to a remote'
      'workspace:Manage remote workspaces on OxenHub'
    )
    _describe -t commands 'oxen command' commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
