#compdef ctmconv
# Documentation: https://openctm.sourceforge.net/?page=ctmconv
# ctmconv - OpenCTM mesh format converter

local ret=1

_arguments -s -S \
  '--scale=[scale the mesh by a scalar factor]:factor:' \
  '--upaxis=[set up axis (flip if != Z)]:axis:(X Y Z -X -Y -Z)' \
  '--flip[flip triangle orientation]' \
  '--calc-normals[calculate normals if source has none]' \
  '--no-normals[do not export normals]' \
  '--no-texcoords[do not export texture coordinates]' \
  '--no-colors[do not export vertex colors]' \
  '--method=[select compression method]:method:(RAW MG1 MG2)' \
  '--level=[set compression level (0-9)]:level:' \
  '--vprec=[set vertex precision]:value:' \
  '--vprecrel=[set vertex precision, relative method]:value:' \
  '--nprec=[set normal precision]:value:' \
  '--tprec=[set texture map precision]:value:' \
  '--cprec=[set color precision]:value:' \
  '--aprec=[set attributes precision]:value:' \
  '--comment=[set the file comment]:comment:' \
  '--texfile=[set the texture file name reference]:file:_files' \
  '*:mesh file:_files -g "*.{ctm,ply,stl,3ds,dae,obj,lwo,off,vrml}"' && ret=0

return ret
