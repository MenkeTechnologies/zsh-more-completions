#compdef gmkspl
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/Apps/gMakeSplines.cxx
# gmkspl - GENIE cross-section spline generation application

local ret=1

_arguments -s -S \
  '-p[comma separated list of neutrino PDG codes]:pdgs:' \
  '-t[comma separated list of target PDG codes]:targets:' \
  '-f[ROOT file containing a ROOT/GEANT geometry description]:file:_files' \
  '(-o --output-cross-sections)'{-o,--output-cross-sections}'[output XML file with computed cross-section data]:xml:_files' \
  '-n[number of knots per spline]:knots:' \
  '-e[maximum energy in spline]:energy:' \
  '--no-copy[do not write out the input cross-sections in the output file]' \
  '--seed[random number seed]:seed:' \
  '--input-cross-sections[XML file with pre-computed free-nucleon cross-sections]:xml:_files' \
  '--event-generator-list[event generators to load in event generation drivers]:list:' \
  '--tune[GENIE comprehensive neutrino interaction model tune]:tune:' \
  '--xml-path[directory to load XML files from (overrides env vars)]:dir:_files -/' \
  '--message-thresholds[XML file customizing message stream thresholds]:xml:_files' \
  '*: :_files' && ret=0

return ret
