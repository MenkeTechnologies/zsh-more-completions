#compdef qlandkartegt
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/qlandkartegt.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  {-d,--debug}'[enable debugging messages]' \
  {-n,--no-splash}'[do not display splash screen]' \
  '(-m --monitor)'{-m,--monitor=}'+[monitor file descriptor for activity]:fd:' \
  '*:file:_files -g "*.{qlb,gpx,kml,kmz,wpt,plt,rte,tif,jnx}"' && ret=0

return ret
