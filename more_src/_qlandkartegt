local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:file:_files -g "*.{qlb,gpx,kml,kmz,wpt,plt,rte,tif,jnx}"' && ret=0

return ret
