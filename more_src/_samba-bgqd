#compdef samba-bgqd

# samba-bgqd: Samba background queue daemon (print job queueing)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-?[show help]' \
  '--usage[short usage]' \
  '-d[debug level]:n:' \
  '--debuglevel=[debug level]:n:' \
  '--debug-stdout[log to stdout instead of file]' \
  '-s[config file]:file:_files' \
  '--configfile=[config file]:file:_files' \
  '-l[log directory]:dir:_files -/' \
  '--log-basename=[log file basename]:name:' \
  '--option=[set smb.conf option]:opt:' \
  '-F[run in foreground]' \
  '--foreground[run in foreground]' \
  '--no-process-group[do not become process group leader]' \
  '-i[allow interactive output (with -F)]' \
  '--interactive[allow interactive output]' \
  '--ready-signal-fd=[fd to write ready signal]:n:' \
  '--parent-watch-fd=[parent watch fd]:n:' \
  '*::samba-bgqd args:_files' && ret=0
return ret
