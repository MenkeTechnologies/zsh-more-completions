#compdef samba-bgqd
# Documentation: https://www.samba.org/samba/docs/current/man-html/samba-bgqd.8.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: Per Samba docs samba-bgqd takes no flags; it is a helper spawned by
# smbd/spoolssd and "not intended to be called by users or administrators".

local curcontext="$curcontext" state line ret=1
_arguments -s -S && ret=0
return ret
