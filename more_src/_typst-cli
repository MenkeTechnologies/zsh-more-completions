#compdef typst
# Documentation: https://github.com/typst/typst
# Reference accessed: 2026-05-21
# Verified: typst/typst upstream — markup-based typesetting compiler.
# Binary is `typst`; Debian package is `typst-cli`. Subcommands:
# compile/c, watch/w, init, query, fonts, completions, update, help.
# Global flags: -h/--help, -V/--version, --cert, --color. Per-cmd
# flags: --root, --input, --font-path, --ignore-system-fonts,
# --package-path, --package-cache-path, --creation-timestamp,
# --features, --diagnostic-format, -f/--format pdf|png|svg|html,
# --pages, --ppi, --make-deps, --pdf-standard, --open, --timings,
# --theme.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'compile:compile a Typst input to PDF/PNG/SVG'
  'c:compile (alias)'
  'watch:watch and recompile on change'
  'w:watch (alias)'
  'init:initialize a new project from template'
  'query:execute a query against compiled doc'
  'fonts:list fonts'
  'completions:generate shell completions'
  'help:show help'
  'update:update typst itself'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--cert=[CA cert]:file:_files' \
  '*--color=[color]:c:(auto always never)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'typst command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (compile|c|watch|w)
        _arguments \
          '(--root)--root=[project root]:dir:_files -/' \
          '(--input)*--input=[k=v sys input]:v:' \
          '(--font-path)*--font-path=[font dir]:dir:_files -/' \
          '(--ignore-system-fonts)--ignore-system-fonts[ignore system fonts]' \
          '(--package-path)--package-path=[package path]:dir:_files -/' \
          '(--package-cache-path)--package-cache-path=[package cache]:dir:_files -/' \
          '(--creation-timestamp)--creation-timestamp=[unix ts]:n:' \
          '(--features)*--features=[features csv]:list:' \
          '(--diagnostic-format)--diagnostic-format=[diag format]:f:(human short)' \
          '(--format -f)'{-f+,--format=}'[output format]:f:(pdf png svg html)' \
          '(--pages)--pages=[page ranges]:p:' \
          '(--ppi)--ppi=[pixels per inch]:n:' \
          '(--make-deps)--make-deps=[deps file]:file:_files' \
          '(--pdf-standard)*--pdf-standard=[standard]:s:(1.7 a-2b a-3b)' \
          '(--open)--open=[open after compile]:cmd:' \
          '(--timings)--timings=[timings file]:file:_files' \
          '(--theme)--theme=[HTML theme]:t:(dark light auto)' \
          '*: :_files -g "*.typ"' && ret=0 ;;
      (init)
        _arguments \
          '(--package-path)--package-path=[package path]:dir:_files -/' \
          '*:template:' && ret=0 ;;
      (query)
        _arguments \
          '(--root)--root=[root]:dir:_files -/' \
          '(--field)--field=[field]:f:' \
          '(--one)--one[expect one match]' \
          '(--format)--format=[format]:f:(json yaml)' \
          '(--input)*--input=[k=v]:v:' \
          '(--font-path)*--font-path=[dir]:dir:_files -/' \
          '*: :' && ret=0 ;;
      (fonts)
        _arguments \
          '(--font-path)*--font-path=[dir]:dir:_files -/' \
          '(--variants)--variants[show variants]' \
          '*: :' && ret=0 ;;
      (completions)
        _arguments '1:shell:(bash zsh fish elvish powershell)' && ret=0 ;;
      (update)
        _arguments \
          '(--force -f)'{-f,--force}'[force]' \
          '(--revert)--revert[revert]' \
          '*:version:' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
