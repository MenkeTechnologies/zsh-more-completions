#compdef terragrunt
# Documentation: https://terragrunt.gruntwork.io/docs/reference/cli-options/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run-all:run terragrunt across stack'
  'graph-dependencies:show dep graph'
  'hclfmt:format HCL'
  'aws-provider-patch:patch AWS provider'
  'render-json:render config to JSON'
  'output-module-groups:show module groups'
  'validate-inputs:validate inputs'
  'terragrunt-info:show info'
  'awsproviderpatch:alias of aws-provider-patch'
  'help:show help'
  'init:run terraform init'
  'plan:run terraform plan'
  'apply:run terraform apply'
  'destroy:run terraform destroy'
  'output:run terraform output'
  'show:run terraform show'
  'state:run terraform state'
  'workspace:run terraform workspace'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--terragrunt-config=[config file]:file:_files -g "*.hcl *.json"' \
  '*--terragrunt-tfpath=[terraform path]:file:_files' \
  '*--terragrunt-no-auto-init[no auto init]' \
  '*--terragrunt-no-auto-retry[no auto retry]' \
  '*--terragrunt-no-auto-approve[no auto approve]' \
  '*--terragrunt-non-interactive[non-interactive]' \
  '*--terragrunt-working-dir=[working dir]:dir:_files -/' \
  '*--terragrunt-download-dir=[download dir]:dir:_files -/' \
  '*--terragrunt-source=[source URL]:url:' \
  '*--terragrunt-source-update[source update]' \
  '*--terragrunt-source-map=[source map]:m:' \
  '*--terragrunt-iam-role=[IAM role ARN]:arn:' \
  '*--terragrunt-iam-assume-role-duration=[duration]:t:' \
  '*--terragrunt-iam-assume-role-session-name=[session name]:n:' \
  '*--terragrunt-ignore-dependency-errors[ignore dep errors]' \
  '*--terragrunt-ignore-dependency-order[ignore dep order]' \
  '*--terragrunt-ignore-external-dependencies[ignore external deps]' \
  '*--terragrunt-include-external-dependencies[include external deps]' \
  '*--terragrunt-parallelism=[parallelism]:n:' \
  '*--terragrunt-debug[debug]' \
  '*--terragrunt-log-level=[log level]:l:(panic fatal error warn info debug trace)' \
  '*--terragrunt-no-color[no color]' \
  '*--terragrunt-check[hclfmt check]' \
  '*--terragrunt-diff[hclfmt diff]' \
  '*--terragrunt-hclfmt-file=[hclfmt file]:file:_files' \
  '*--terragrunt-hclfmt-stdin[stdin]' \
  '*--terragrunt-include-dir=[include dir]:dir:_files -/' \
  '*--terragrunt-exclude-dir=[exclude dir]:dir:_files -/' \
  '*--terragrunt-strict-include[strict include]' \
  '*--terragrunt-modules-that-include=[modules that include]:m:' \
  '*--terragrunt-fetch-dependency-output-from-state[fetch dep output from state]' \
  '*--terragrunt-use-partial-parse-config-cache[partial parse cache]' \
  '*--terragrunt-include-module-prefix[module prefix]' \
  '*--terragrunt-fail-on-state-bucket-creation[fail on bucket create]' \
  '*--terragrunt-disable-bucket-update[disable bucket update]' \
  '*--terragrunt-disable-command-validation[disable cmd validation]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'terragrunt command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
