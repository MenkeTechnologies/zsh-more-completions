#compdef create-mastra
# Documentation: https://mastra.ai/reference/cli/create-mastra
# Reference accessed: 2026-05-24
# Verified: npm view create-mastra bin; Mastra create-mastra CLI reference at the URL above.

# Zsh completion for create-mastra - Mastra AI application scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--version[output the version number]' \
  '--project-name=[project and directory name]:name:' \
  '--default[quickstart with defaults: src, OpenAI, no examples]' \
  '--components=[comma-separated components]:components:(agents tools workflows scorers)' \
  '--llm=[default model provider]:provider:(openai anthropic groq google cerebras)' \
  '--llm-api-key=[API key for the model provider]:key:' \
  '--example[include example code]' \
  '--no-example[do not include example code]' \
  '--template=[template name or GitHub URL]:template:' \
  '--timeout=[package install timeout in ms]:ms:' \
  '--dir=[Mastra source directory]:directory:_directories' \
  '--mcp=[MCP server for code editor]:editor:(cursor cursor-global windsurf vscode)' \
  '--skills=[agents to install Mastra skills for]:agents:' \
  '--observability[enable Mastra platform observability during creation]' \
  '--no-observability[skip observability prompt]' \
  '--observability-project=[platform project name when observability enabled]:name:' \
  '--help[display help for command]' \
  ':project name:' && ret=0

return ret
