#compdef clib

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install packages'
  'search:search for packages'
  'init:create a package.json file'
  'update:update installed packages'
  'upgrade:upgrade clib to the latest version'
  'uninstall:uninstall packages'
  'configure:configure package'
  'build:build the package'
  'help:show help for a command'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'clib command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      install)
        _arguments -s -S \
          '-o+[set output directory]:directory:_directories' \
          '-P+[set prefix]:prefix:_directories' \
          '-N[skip cache]' \
          '-c[skip cleanup]' \
          '-f[force install]' \
          '-g[install globally]' \
          '-S[save to package.json]' \
          '-D[save as dev dependency]' \
          '--save[save to package.json]' \
          '--save-dev[save as dev dependency]' \
          '*:package:' && ret=0
        ;;
      search)
        _arguments -s -S \
          '*:query:' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          '*:package:' && ret=0
        ;;
    esac
    ;;
esac

return ret
