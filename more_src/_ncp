#compdef ncp
# Documentation: https://github.com/AvianFlu/ncp
# ncp - asynchronous recursive file copy utility

local ret=1

_arguments -s -S \
  '--limit=[number of pending file system requests to keep open]:n:' \
  '--filter=[regular expression selecting which files to copy]:regex:' \
  '--stopOnErr[stop copying immediately on the first error]' \
  '1:source:_files' \
  '2:dest:_files' && ret=0

return ret
