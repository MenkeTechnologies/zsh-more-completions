#compdef tpm2_seal
# _tpm2_seal — tpm2-software tpm2_seal seal arbitrary user data into TPM2 keyedHash object protected by policy (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_seal() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[parent object context]:str:' \
        '--parent-context=+[parent object context]:str:' \
        '-C+[parent object context]:str:' \
        '-i+[input data file or stdin]:file:_files' \
        '--data=+[input data file or stdin]:file:_files' \
        '-p+[parent password auth]:str:' \
        '--auth=+[object password]:str:' \
        '-P+[parent password auth]:str:' \
        '-r+[sealed object out priv]:file:_files' \
        '--private=+[sealed object out priv]:file:_files' \
        '-u+[sealed object out pub]:file:_files' \
        '--public=+[sealed object out pub]:file:_files' \
        '-L+[policy file]:file:_files' \
        '--policy=+[policy file]:file:_files' \
        '-a+[object attributes]:str:' \
        '--attributes=+[object attributes]:str:' \
        '-g+[hash algorithm]:h:(sha1 sha256 sha384 sha512)' \
        '--hash-algorithm=+[hash algorithm]:h:(sha1 sha256 sha384 sha512)' \
        '-l+[creation log]:file:_files' \
        '--creation-log=+[creation log]:file:_files' \
        '-q+[qualifying data]:str:' \
        '--qualification=+[qualifying data]:str:' \
        '-t+[creation ticket]:file:_files' \
        '--creation-ticket=+[creation ticket]:file:_files' \
        '-d+[creation data]:file:_files' \
        '--creation-data=+[creation data]:file:_files' \
        '-S+[session]:str:' \
        '--session=+[session]:str:' \
        '-Q[do not output anything]' \
        '--cphash=+[cp hash file]:file:_files' \
        '--rphash=+[rp hash file]:file:_files' \
        '--format=+[output format]:f:(json yaml)'
}

_tpm2_seal "$@"
