#compdef enter

# Zsh completion for Enter Code (autonomous AI agent)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--plan[force Plan Mode where the agent proposes steps before execution]' \
  '--rewind[access the checkpoint system to roll back code or conversation states]' \
  '--help[show help message]' \
  '--version[show version information]' \
  '1: :->command_or_prompt' \
  '*:: :->args' && ret=0

case $state in
  command_or_prompt)
    local -a commands
    commands=(
      'login:authenticate with your Enter Pro account'
      'init:scaffold a new project in the cloud'
      'list:list all active projects and status'
      'status:health check of the current project'
      'open:open project dashboard or live URL'
      'db:manage the integrated cloud database'
      'storage:manage cloud file storage and buckets'
      'secret:set or retrieve environment variables'
      'auth:configure user authentication providers'
      'build:trigger a cloud-side build'
      'publish:deploy the current iteration to production'
      'domain:manage custom domains'
      'logs:stream real-time logs from cloud'
      'switch:change the underlying LLM model'
      'skill:manage Agent Skills'
    )
    _describe -t commands 'command' commands || _message 'prompt'
    ;;
  args)
    case $line[1] in
      db|storage|secret|auth|domain|skill)
        local -a subcommands
        case $line[1] in
          db) subcommands=('list' 'create' 'delete' 'shell' 'push' 'pull') ;;
          storage) subcommands=('list' 'upload' 'download' 'delete') ;;
          secret) subcommands=('list' 'set' 'unset') ;;
          auth) subcommands=('list' 'enable' 'disable' 'config') ;;
          domain) subcommands=('list' 'attach' 'detach' 'verify') ;;
          skill) subcommands=('list' 'install' 'uninstall' 'update') ;;
        esac
        _describe -t subcommands 'subcommand' subcommands
        ;;
    esac
    ;;
esac

return ret
