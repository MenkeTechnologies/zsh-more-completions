#compdef compdb

# Zsh completion for compdb - compilation database manipulation

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --build-dir)'{-b,--build-dir}'[build directory]:directory:_directories' \
  '--command-style=[command style]:style:(gnu windows)' \
  '--config-file=[config file]:config file:_files' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'list:list compilation database entries'
      'scan-files:scan for source files'
      'check:check compilation database'
      'update:update compilation database'
      'generate:generate compilation database'
      'version:show version'
    )
    _describe -t commands 'compdb command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      list)
        _arguments -s -S \
          '--no-build[do not include build directory entries]' \
          '--json[output in JSON format]' \
          '--suppress-missing[suppress missing file warnings]' && ret=0
        ;;
    esac
    ;;
esac

return ret
