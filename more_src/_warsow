#compdef warsow
# Documentation: (no Debian/Ubuntu manpage; Qfusion engine convention)
# Reference accessed: 2026-05-16
# Verified: no upstream manpage retrievable. Warsow runs on the Qfusion engine
# (Quake-derivative similar to ioquake3); engine convention uses +cmd cbuf
# parsing with cvars like vid_fullscreen, vid_width, vid_height.

# Warsow: fast-paced FPS (Qfusion engine)
local curcontext="$curcontext" ret=1
_arguments -C \
  '+set[set cvar before init]:cvar:: :' \
  '+exec[execute config at startup]:file:_files -g "*.cfg"' \
  '+map[load map at startup]:map:' \
  '+connect[connect to server]:host:_hosts' \
  '+demo[play demo at startup]:name:' \
  '*::extra args:_files' && ret=0
return ret
