#compdef last
# _last — OpenBSD last (list user sessions from wtmp(5) in reverse time order; -d snapshot at date, -f alternate wtmp file, -h hostname filter, -t tty filter, -n limit, -s strip seconds, -c compress consecutive runs, -T show full time)
# upstream: https://github.com/openbsd/src (usr.bin/last)
# Flags from usr.bin/last/last.1 on tip.

_last() {
    _arguments \
        '-c[print consecutive entries on one line]' \
        '-s[strip seconds from times]' \
        '-T[show full timestamps]' \
        '-d+[snapshot date]:date:' \
        '-f+[wtmp file]:file:_files' \
        '-h+[host filter]:host:_hosts' \
        '-n+[max entries]:number:' \
        '-t+[tty filter]:tty:' \
        '*:user:_users'
}

_last "$@"
