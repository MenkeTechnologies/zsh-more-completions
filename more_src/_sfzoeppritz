#compdef sfzoeppritz
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mzoeppritz.c
# Madagascar: testing the Zoeppritz equation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'na=[number of angles]:count' \
  'a0=[first angle]:value' \
  'da=[angle increment]:value' \
  'icoef=[1 displacement, 2 potential, 3 energy, 4 real part]:coef:(1 2 3 4)' \
  'vp1=[P velocity, medium 1]:velocity' \
  'vp2=[P velocity, medium 2]:velocity' \
  'vs1=[S velocity, medium 1]:velocity' \
  'vs2=[S velocity, medium 2]:velocity' \
  'rho1=[density, medium 1]:density' \
  'rho2=[density, medium 2]:density' \
  'incp=[incident P (or S)]:flag:(y n)' \
  'outp=[reflected/transmitted P (or S)]:flag:(y n)' \
  'refl=[reflection or transmission]:flag:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
