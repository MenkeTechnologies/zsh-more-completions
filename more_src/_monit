#compdef monit

# Zsh completion for monit - process monitoring daemon

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'start:start a service'
  'stop:stop a service'
  'restart:restart a service'
  'monitor:enable monitoring of a service'
  'unmonitor:disable monitoring of a service'
  'reload:reinitialize monit'
  'status:print full status information'
  'summary:print short status information'
  'report:report status of services'
  'quit:kill the monit daemon process'
  'validate:check all services and start if not running'
  'procmatch:test a process matching pattern'
)

local -a services
services=( ${(f)"$(command monit summary 2>/dev/null | awk 'NR>2 && NF>1 {print $1}')"} )

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '-c[use this configuration file]:config file:_files' \
  '-d[run as a daemon with specified poll interval]:seconds:' \
  '-g[set group name for start/stop/restart]:group name:' \
  '-l[use this log file]:log file:_files' \
  '-p[use this pid file]:pid file:_files' \
  '-s[use this state file]:state file:_files' \
  '-B[batch command line mode]' \
  '-I[do not run in background (for init)]' \
  '-i[print monit unique ID]' \
  '-r[reset monit unique ID]' \
  '-t[run syntax check for configuration file]' \
  '-v[verbose mode]' \
  '-vv[very verbose mode]' \
  '-H[print fingerprint of TLS certificate]:certfile:_files' \
  '-V[version]' \
  '-h[help]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'monit subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (start|stop|restart|monitor|unmonitor)
        _arguments '1:service name:(all ${services})' && ret=0
        ;;
      (status|summary)
        _arguments '1:service name:(${services})' && ret=0
        ;;
      (procmatch)
        _arguments '1:pattern:' && ret=0
        ;;
      (report)
        _arguments '1:type:(up down initialising unmonitored total)' && ret=0
        ;;
    esac
    ;;
esac

return ret
