#compdef conmonctl
# _conmonctl — Containers project conmonctl CLI command-line frontend to conmon the OCI container monitor process supervisor for crun runc launching attaching log-streaming exit-status-recording cgroupless-container-pid-namespace-exec workflow for Podman CRI-O Kubernetes-CRI-OCI-runtime-bundle container management (Containers team, C); cobra
# upstream: https://github.com/containers/conmon

_conmonctl() {
    local -a sub=(
        'start:start a conmon supervisor'
        'stop:stop conmon process'
        'attach:attach to running container'
        'exec:exec inside container'
        'logs:fetch container logs'
        'status:show container status'
        'list:list managed containers'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--container-id=+[id]:str:' \
        '--container-name=+[name]:str:' \
        '--container-uuid=+[uuid]:str:' \
        '--container-pid-file=+[file]:file:_files' \
        '--bundle=+[dir]:dir:_files -/' \
        '--exec-bundle=+[dir]:dir:_files -/' \
        '--socket-path=+[file]:file:_files' \
        '--log-path=+[file]:file:_files' \
        '--log-tag=+[tag]:str:' \
        '--log-size-max=+[N]:n:' \
        '--log-level=+[l]:l:(debug info warn error)' \
        '--runtime=+[path]:file:_files' \
        '--runtime-arg=+[arg]:str:' \
        '--runtime-opt=+[opt]:str:' \
        '--terminal[allocate tty]' \
        '--no-stdin[no stdin]' \
        '--no-new-keyring[no new keyring]' \
        '--no-pivot[no pivot root]' \
        '--syslog[log to syslog]' \
        '--persist-dir=+[dir]:dir:_files -/' \
        '--restore=+[checkpoint]:str:' \
        '--api-version=+[v]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'conmonctl subcommand' sub ;;
    esac
}

_conmonctl "$@"
