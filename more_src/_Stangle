#compdef Stangle
# Documentation: https://stat.ethz.ch/R-manual/R-devel/library/utils/html/Sweave.html
# R CMD Stangle: front-end for Stangle and other vignette engines

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help message and exit]' \
  '(-v --version)'{-v,--version}'[print version info and exit]' \
  '--engine=[use named vignette engine]:engine:' \
  '--encoding=[assume encoding for file]:encoding:' \
  '--options=[comma-separated list of Stangle options]:options:' \
  '*:file:_files' && ret=0

return ret
