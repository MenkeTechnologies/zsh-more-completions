#compdef cargo-minimal-versions
# proper use of -Z minimal-versions and -Z direct-minimal-versions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--direct[use -Z direct-minimal-versions instead of -Z minimal-versions]' \
  '--ignore-private[skip crates with publish = false]' \
  '--detach-path-deps=-[remove path fields from dependencies]::mode:(all skip-exact)' \
  '1:cargo subcommand:(build check test)' \
  '*::cargo options:_default' && ret=0

return ret
