#compdef lasheight
# Documentation: https://github.com/LAStools/LAStools
# LAStools: compute height of each point above the ground

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help]' \
  '-version[report tool version]' \
  '-gui[start with files loaded into GUI]' \
  '-v[verbose output]' \
  '-ground_points+[external ground points file for TIN]:file:_files -g "*.(las|laz|txt|LAS|LAZ)"' \
  '-all_ground_points[use all external points instead of clipping]' \
  '*-class+[point classes to use as ground reference]:code' \
  '-replace_z[store heights to z coordinate]' \
  '-drop_below+[remove points below height threshold]:height' \
  '-drop_above+[remove points above height threshold]:height' \
  '-drop_between+[remove points within height range]:low' \
  '-classify_below+[assign class to points below threshold]:height' \
  '-classify_above+[assign class to points above threshold]:height' \
  '-classify_between+[assign class to points within range]:low' \
  '*-ignore_class+[exclude classes from processing]:code' \
  '-do_not_store_in_user_data[skip storing height in user_data field]' \
  '-store_as_extra_bytes[store height with cm precision as short]' \
  '-store_precise_as_extra_bytes[store height with mm precision as int]' \
  '-store_in_user_data[store heights even with other output]' \
  '-scale_u+[scale factor for quantized height (default 10.0)]:factor' \
  '-skip_files[skip files lacking ground points]' \
  '*-i+[input LAS/LAZ file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-odir+[output directory]:dir:_files -/' \
  '-odix+[output filename suffix]:suffix' \
  '-olas[output uncompressed LAS]' \
  '-olaz[output compressed LAZ]' \
  '-cores+[process files in parallel on N cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
