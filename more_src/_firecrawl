#compdef firecrawl

# Zsh completion for Firecrawl CLI
# https://github.com/mendableai/firecrawl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'scrape:Scrape a single page'
  'crawl:Recursively scrape an entire website'
  'search:Search the web and optionally scrape results'
  'map:Map out site structure'
  'browser:Launch cloud browser sessions'
  'login:Authenticate with Firecrawl'
  'credit-usage:Check remaining credits'
)

_arguments -s -S \
  '--api-key=[Firecrawl API key]:key:' \
  '--api-url=[custom API URL]:url:' \
  '(-o --output)'{-o,--output}'[output file path]:path:_files' \
  '(-f --format)'{-f,--format}'[output format]:format:(json markdown text)' \
  '--quiet[suppress progress messages]' \
  '--help[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'firecrawl command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (scrape)
        _arguments -s -S \
          '--formats=[comma-separated formats]:formats:(markdown html screenshot links json)' \
          '--only-main-content[extract only primary content]' \
          '--include-tags=[HTML tags to include]:tags:' \
          '--exclude-tags=[HTML tags to exclude]:tags:' \
          '--wait-for=[wait time in ms]:ms:' \
          '1:url:' && ret=0
        ;;
      (crawl)
        _arguments -s -S \
          '--limit=[max number of pages]:number:' \
          '--max-depth=[maximum discovery depth]:number:' \
          '--exclude-paths=[comma-separated paths to ignore]:paths:' \
          '--include-paths=[comma-separated paths to include]:paths:' \
          '--poll-interval=[interval to check completion (s)]:seconds:' \
          '1:url:' && ret=0
        ;;
      (search)
        _arguments -s -S \
          '--limit=[number of search results]:number:' \
          '--scrape[automatically scrape content]' \
          '1:query:' && ret=0
        ;;
      (map)
        _arguments -s -S \
          '--search=[search for content within site map]:query:' \
          '1:url:' && ret=0
        ;;
      (browser)
        _arguments -s -S '1:subcommand:(launch-session execute)' && ret=0
        ;;
      (login)
        _arguments -s -S \
          '--browser[open browser for authentication]' \
          '--api-key=[direct API key setup]:key:' && ret=0
        ;;
    esac
    ;;
esac

return ret
