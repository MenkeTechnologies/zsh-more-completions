#compdef mcp-proxy
# Documentation: https://man.archlinux.org/search?q=mcp-proxy
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/mcp-proxy
local ret=1

_arguments -C -s -S \
  '--version[show version and exit]' \
  '(-H --headers)'{-H,--headers}'[SSE header key and value]:key: :value' \
  '--transport[SSE or streamable HTTP client transport]:mode:(sse streamablehttp)' \
  '--client-id[OAuth2 client ID]:id' \
  '--client-secret[OAuth2 client secret]:secret' \
  '--token-url[OAuth2 token URL]:url' \
  '--verify-ssl[SSL verification when acting as a client]:value' \
  '--no-verify-ssl[disable SSL verification]' \
  '(-e --env)'{-e,--env}'[env var for spawned default server]:key: :value' \
  '--cwd[working directory for default stdio server]:directory:_files -/' \
  '--pass-environment[pass through environment to spawned servers]' \
  '--no-pass-environment[do not pass environment]' \
  '--log-level[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--debug[enable debug logging]' \
  '--no-debug[disable debug logging]' \
  '*--named-server[define named stdio server name and command string]:name: :command string' \
  '--named-server-config[JSON file with named server definitions]:file:_files' \
  '--port[port for SSE server (stdio bridge mode)]:port' \
  '--host[bind host for SSE server]:host' \
  '--stateless[stateless streamable HTTP mode]' \
  '--no-stateless[disable stateless mode]' \
  '--sse-port[deprecated; same as --port]:port' \
  '--sse-host[deprecated; same as --host]:host' \
  '*--allow-origin[allowed CORS origins for SSE server]:origin' \
  '*--expose-header[Access-Control-Expose-Headers value]:header' \
  '*::URL command or arguments:_default' && ret=0

return ret
