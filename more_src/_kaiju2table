#compdef kaiju2table
# Documentation: https://github.com/bioinformatics-centre/kaiju
# Convert kaiju output into a summary table at a given taxonomic rank

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-t[nodes.dmp taxonomy file]:nodes:_files' \
  '-n[names.dmp taxonomy file]:names:_files' \
  '-r[taxonomic rank]:rank:(superkingdom phylum class order family genus species)' \
  '-o[output file]:output:_files' \
  '-m[minimum abundance threshold percent]:percent:' \
  '-c[minimum read count threshold]:count:' \
  '-l[comma-separated list of ranks]:ranks:' \
  '-u[do not count unclassified reads for percentages]' \
  '-p[print full taxon path]' \
  '*:kaiju output:_files' && ret=0

return ret
