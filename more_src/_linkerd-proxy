#compdef linkerd-proxy
# Documentation: https://man.archlinux.org/search?q=linkerd-proxy
# Reference accessed: 2026-05-16

# linkerd-proxy: sidecar proxy for Linkerd2
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*::linkerd-proxy args:_files' && ret=0
return ret
