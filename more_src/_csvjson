#compdef csvjson

# Zsh completion for csvjson - csvkit CSV to JSON converter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --indent)'{-i,--indent}'[indent level for JSON output]:indent level' \
  '(-k --key)'{-k,--key}'[column name to use as top-level key]:column name' \
  '--lat[column name containing latitude]:column name' \
  '--lon[column name containing longitude]:column name' \
  '--type[output type]:type:(feature FeatureCollection)' \
  '--geometry[column name containing a GeoJSON geometry]:column name' \
  '--crs[coordinate reference system for GeoJSON output]:CRS string' \
  '--no-bbox[do not include bounding box in GeoJSON]' \
  '--stream[output newline-delimited JSON]' \
  '(-y --snifflimit)'{-y,--snifflimit}'[limit CSV dialect sniffing to N bytes]:bytes' \
  '(-I --no-inference)'{-I,--no-inference}'[disable type inference during parsing]' \
  '--no-header-row[use default column names instead of header row]' \
  '(-d --delimiter)'{-d,--delimiter}'[delimiting character of input CSV]:delimiter' \
  '(-t --tabs)'{-t,--tabs}'[input CSV is tab-delimited]' \
  '(-q --quotechar)'{-q,--quotechar}'[character used to quote strings]:character' \
  '(-u --quoting)'{-u,--quoting}'[quoting style]:style:(0 1 2 3)' \
  '(-b --no-doublequote)'{-b,--no-doublequote}'[disable double-quote escaping]' \
  '(-p --escapechar)'{-p,--escapechar}'[character used to escape the delimiter]:character' \
  '(-z --maxfieldsize)'{-z,--maxfieldsize}'[maximum length of a single field]:size' \
  '(-e --encoding)'{-e,--encoding}'[encoding of the input CSV file]:encoding' \
  '(-S --skipinitialspace)'{-S,--skipinitialspace}'[ignore whitespace after delimiter]' \
  '(-H --no-header-row)'{-H,--no-header-row}'[specify that the input CSV has no header row]' \
  '--skip-lines[number of lines to skip before header]:count' \
  '(-l --linenumbers)'{-l,--linenumbers}'[insert a column of line numbers]' \
  '--zero[when using --linenumbers, start from zero]' \
  '*:CSV file:_files -g "*.csv *.tsv"'
