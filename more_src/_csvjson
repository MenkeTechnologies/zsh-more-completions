#compdef csvjson
# Documentation: https://csvkit.readthedocs.io/en/latest/scripts/csvjson.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# csvkit: convert CSV to JSON or GeoJSON.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[print full tracebacks on errors]' \
  '(-i --indent)'{-i,--indent}'[indent JSON output by N spaces]:indent' \
  '(-k --key)'{-k,--key}'[column name to use as top-level key]:column' \
  '--lat=[column name containing latitude]:column' \
  '--lon=[column name containing longitude]:column' \
  '--type=[column index/name containing GeoJSON type]:column' \
  '--geometry=[column containing GeoJSON geometry]:column' \
  '--crs=[coordinate reference system string]:crs' \
  '--no-bbox[disable bounding-box calculation]' \
  '--stream[output newline-delimited JSON]' \
  '(-y --snifflimit)'{-y,--snifflimit}'[limit CSV dialect sniffing to N bytes]:bytes' \
  '(-I --no-inference)'{-I,--no-inference}'[disable type inference]' \
  '(-d --delimiter)'{-d,--delimiter}'[delimiting character]:char' \
  '(-t --tabs)'{-t,--tabs}'[input is tab-delimited]' \
  '(-q --quotechar)'{-q,--quotechar}'[character used to quote strings]:char' \
  '(-u --quoting)'{-u,--quoting}'[quoting style]:style:(0 1 2 3)' \
  '(-b --no-doublequote)'{-b,--no-doublequote}'[disable double-quote escaping]' \
  '(-p --escapechar)'{-p,--escapechar}'[escape character]:char' \
  '(-z --maxfieldsize)'{-z,--maxfieldsize}'[maximum field length]:size' \
  '(-e --encoding)'{-e,--encoding}'[input encoding]:encoding' \
  '(-L --locale)'{-L,--locale}'[locale for parsing formatted numbers]:locale' \
  '(-S --skipinitialspace)'{-S,--skipinitialspace}'[ignore whitespace after delimiter]' \
  '--blanks[do not convert empty cells to NULL]' \
  '--null-value=[treat string as NULL]:value' \
  '--date-format=[strptime date format]:format' \
  '--datetime-format=[strptime datetime format]:format' \
  '(-H --no-header-row)'{-H,--no-header-row}'[input CSV has no header row]' \
  '-K+[skip lines before header]:number' \
  '--skip-lines=[skip lines before header]:number' \
  '(-l --linenumbers)'{-l,--linenumbers}'[insert column of line numbers]' \
  '--zero[use zero-based line numbers]' \
  '*:CSV file:_files -g "*.{csv,tsv,txt}"'
