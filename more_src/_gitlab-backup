#compdef gitlab-backup
# Documentation: https://docs.gitlab.com/administration/backup_restore/backup_gitlab/
# GitLab Omnibus backup/restore command

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(create restore)' \
  '*::arg:(SKIP= INCREMENTAL=yes PREVIOUS_BACKUP= BACKUP= GITLAB_ASSUME_YES=1 STRATEGY=copy)' && ret=0

return ret
