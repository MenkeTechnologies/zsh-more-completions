#compdef stylish-haskell
# Documentation: https://github.com/haskell/stylish-haskell
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c+,--config=}'[configuration file]:config file:_files -g "*.yaml"' \
  '(-i --inplace)'{-i,--inplace}'[process files in-place]' \
  '(-r --recursive)'{-r,--recursive}'[recursively process directories]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --defaults)'{-d,--defaults}'[dump default configuration to stdout]' \
  '*'{-e+,--extension=}'[language extension]:extension:' \
  '*:Haskell source files:_files -g "*.hs"' && ret=0

return ret
