#compdef stylish-haskell

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c+[configuration file]:config file:_files -g ".stylish-haskell.yaml"' \
  '--config=[configuration file]:config file:_files -g ".stylish-haskell.yaml"' \
  '-i[process files in-place]' \
  '--inplace[process files in-place]' \
  '-r[recursively process directories]' \
  '--recursive[recursively process directories]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-d[generate default configuration]' \
  '--defaults[generate default configuration]' \
  '-e+[language extension]:extension:' \
  '--extension=[language extension]:extension:' \
  '*:Haskell source files:_files -g "*.hs"' && ret=0

return ret
