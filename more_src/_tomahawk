#compdef tomahawk

# Tomahawk: social music player (now Hatchet)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--license[show license]' \
  '--debug[debug logging]' \
  '*:URLs/files:_files' && ret=0
return ret
