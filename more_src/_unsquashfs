#compdef unsquashfs

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-version[show version]' \
  '-d+[set destination directory for extraction]:directory:_directories' \
  '-n+[set number of processors to use]:number' \
  '-i[show information about the squashfs archive]' \
  '-l[list filesystem without extracting]' \
  '-ll[list filesystem with file attributes]' \
  '-lln[list filesystem with file attributes and numeric uid/gid]' \
  '-lls[list filesystem in ls -l style]' \
  '-s[display superblock information]' \
  '-stat[display filesystem information]' \
  '-f[force overwrite of existing files]' \
  '*-e[extract specific files/directories]:file' \
  '-excludes[treat extract arguments as exclude patterns]' \
  '-no-progress[do not display progress bar]' \
  '-da+[set data queue buffer size]:size' \
  '-data-queue+[set data queue buffer size]:size' \
  '-fr+[set fragment queue buffer size]:size' \
  '-frag-queue+[set fragment queue buffer size]:size' \
  '-regex[treat extract names as POSIX regular expressions]' \
  '-no-xattrs[do not extract extended attributes]' \
  '-xattrs[extract extended attributes]' \
  '-pf+[output pseudo file]:file:_files' \
  '-quiet[suppress all output]' \
  '-verbose[print files as they are extracted]' \
  '1:squashfs archive:_files' \
  && ret=0

return ret
