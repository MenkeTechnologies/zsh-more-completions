#compdef kafka-e2e-latency
# Documentation: https://github.com/apache/kafka/blob/trunk/tools/src/main/java/org/apache/kafka/tools/EndToEndLatency.java
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--bootstrap-server[REQUIRED: Kafka broker list]:host\:port:'
    '--topic[REQUIRED: Topic to use for the test]:topic:'
    '--num-records[REQUIRED: Number of messages to send]:count:'
    '--producer-acks[REQUIRED: Producer acks (1 or all)]:acks:(1 all)'
    '--record-size[REQUIRED: Size of each message payload in bytes]:bytes:'
    '--command-config[Property file with configs for the clients]:file:_files'
    '--record-key-size[Size of the message key in bytes]:bytes:'
    '--record-header-key-size[Size of the message header key in bytes]:bytes:'
    '--record-header-size[Size of message header value in bytes]:bytes:'
    '--num-headers[Number of headers per record]:count:'
)

_arguments -s -S $arguments
