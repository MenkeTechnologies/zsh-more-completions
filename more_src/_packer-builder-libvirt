#compdef packer-builder-libvirt
# _packer-builder-libvirt — HashiCorp Packer libvirt-qemu builder plugin (loaded by packer build for templates that declare builder type "libvirt-qemu" / "qemu-libvirt"; plugin binary itself only exposes --version, --debug; the build-time options live in the JSON/HCL template)
# upstream: https://github.com/digitalocean/packer-plugin-libvirt
# Flags from packer-plugin-libvirt main.go on tip.

_packer-builder-libvirt() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--debug[debug to stderr]' \
        '--plugin[run as plugin]'
}

_packer-builder-libvirt "$@"
