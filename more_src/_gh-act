#compdef gh-act
# Documentation: https://nektosact.com/usage/index.html
# gh act: GitHub CLI extension to run GitHub Actions locally (wraps nektos/act)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-W --workflows)'{-W+,--workflows=}'[path to workflow file or directory]:path:_files' \
  '(-j --job)'{-j+,--job=}'[run a specific job]:job id' \
  '(-l --list)'{-l,--list}'[list available workflows]' \
  '(-e --eventpath)'{-e+,--eventpath=}'[path to event JSON file]:path:_files' \
  '--input=[set workflow_dispatch input KEY=value]:input' \
  '--input-file=[read inputs from a file]:path:_files' \
  '--matrix=[run only the specified matrix configuration]:matrix' \
  '*'{-s+,--secret=}'[set a secret KEY=value]:secret' \
  '--secret-file=[read secrets from a file]:path:_files' \
  '*--var=[set a repository variable KEY=value]:var' \
  '--var-file=[read variables from a file]:path:_files' \
  '(-n --dryrun)'{-n,--dryrun}'[dry run, do not run containers]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-a --actor)'{-a+,--actor=}'[set the actor name]:actor' \
  '*'{-P+,--platform=}'[set the platform image mapping]:platform' \
  '(-p --pull)'{-p,--pull}'[pull docker images]' \
  '(-b --bind)'{-b,--bind}'[bind the working directory into the container]' \
  '--reuse[reuse containers between runs]' \
  '--rm[remove containers after run]' \
  '(-w --watch)'{-w,--watch}'[watch for changes and re-run]' \
  '--container-architecture=[set the container architecture]:arch' \
  '--artifact-server-path=[enable the artifact server at this path]:path:_files -/' \
  '--action-offline-mode[use cached actions and images, skip remote pulls]' \
  '--graph[draw the workflow dependency graph]' \
  '*:event:_default' && ret=0

return ret
