#compdef qrsh
# Documentation: http://gridscheduler.sourceforge.net/htmlman/htmlman1/qrsh.html
# Grid Engine: submit an interactive rsh-style job to the cluster

local ret=1

_arguments -s \
  '-help[display all options]' \
  '-@+[use the options contained in the given file]:option file:_files' \
  '-ac+[add the given name/value pairs to the job context]:context' \
  '-ar+[assign the job to an existing advance reservation]:ar id' \
  '-A+[account string to charge for resource consumption]:account' \
  '-binding+[request a specific processor core binding]:binding' \
  '-b+[treat command as binary or script]:value:(y yes n no)' \
  '-cwd[execute the job from the current working directory]' \
  '-dc+[remove the given variables from the job context]:context' \
  '-display+[X display specifier for xterm]:display' \
  '-dl+[deadline initiation time]:date time' \
  '-e+[standard error stream path]:path:_files' \
  '-hard[following resource requirements are hard]' \
  '-h+[holds to place on the job]:holds' \
  '-hold_jid+[job dependency list]:job list' \
  '-hold_jid_ad+[array job dependency list]:job list' \
  '-i+[standard input stream file]:file:_files' \
  '-inherit[read the job id from the JOB_ID environment variable]' \
  '-j+[merge stderr into stdout]:value:(y yes n no)' \
  '-js+[job share relative to other jobs]:job share' \
  '-jsv+[client JSV instance to verify the job specification]:jsv url' \
  '-l+[launch in a queue meeting the resource request list]:resource' \
  '-m+[circumstances under which mail is sent]:events' \
  '-M+[list of users to which mail is sent]:users' \
  '-masterq+[cluster queues for the parallel job master queue]:queues' \
  '-notify[send warning signals prior to SIGSTOP or SIGKILL]' \
  '-now+[start the job immediately or not at all]:value:(y yes n no)' \
  '-N+[name of the job]:name' \
  '-noshell[do not start the command line in a login shell]' \
  '-nostdin[suppress the STDIN input stream]' \
  '-o+[standard output stream path]:path:_files' \
  '-P+[project to which the job is assigned]:project' \
  '-p+[priority of the job]:priority' \
  '-pe+[parallel programming environment to instantiate]:pe' \
  '-pty+[start in or without a pseudo terminal]:value:(y yes n no)' \
  '-q+[list of cluster queues which may be used]:queues' \
  '-R+[whether a reservation should be done]:value:(y yes n no)' \
  '-S+[interpreting shell for the job]:shell:_files' \
  '-sc+[set the given name/value pairs as the job context]:context' \
  '-soft[following resource requirements are soft]' \
  '-v+[environment variables to export]:variable' \
  '-verbose[print job session establishment information]' \
  '-verify[print detailed job information instead of submitting]' \
  '-V[export all environment variables active within qrsh]' \
  '-w+[validation level applied to the job]:level:(e w n p v)' \
  '-wd+[execute the job from the given directory]:dir:_files -/' \
  '*:::command:_command_names -e' && ret=0

return ret
