#compdef JLinkSTM32
# Documentation: https://kb.segger.com/J-Link_STM32_Utility
# SEGGER J-Link STM32 Utility — unsecure STM32 devices and disable hardware watchdog

local ret=1

_arguments -s -S \
  '-IP[select IP as host interface to connect to J-Link]:host:' \
  '-USB[connect via USB serial number]:sn:' \
  '-SelectEmuBySN[connect to J-Link by serial number]:sn:' \
  '-Speed[initial interface speed in kHz]:khz:(adaptive auto 1000)' \
  '-SetPowerTarget[power target via pin 19 of debug connector]:mode:' \
  '-SetDeviceFamily[STM32 device family by ID or device string]:family:' \
  '-Exit[close automatically instead of waiting for input]:mode:' && ret=0

return ret
