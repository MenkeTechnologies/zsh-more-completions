#compdef dotool
# Documentation: https://man.archlinux.org/search?q=dotool
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '--version[display version]' \
  '--list-keys[list recognized key names]' \
  '*:command file:_files' && ret=0

return ret
