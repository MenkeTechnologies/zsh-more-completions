#compdef grub-script-check
# _grub-script-check — GRUB grub-script-check (syntax-check a grub.cfg before it goes on the ESP — catches typos and unbalanced if/then blocks; -V version, -v verbose, --help; positional argument is the script file (default stdin))
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-script-check.c on tip.

_grub-script-check() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '*:script:_files'
}

_grub-script-check "$@"
