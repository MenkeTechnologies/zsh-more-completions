#compdef seaview
# Documentation: http://doua.prabi.fr/software/seaview
# SeaView: graphical multiple sequence alignment and phylogeny editor

local ret=1

_arguments -s -S \
  '-fast[suppress double buffering (accelerates display on slow systems)]' \
  '-fontsize[set the font size]:size:' \
  '*:alignment or tree file:_files' && ret=0

return ret
