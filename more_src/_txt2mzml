#compdef txt2mzml
# Documentation: https://proteowizard.sourceforge.io/tools/tools_base.html
# ProteoWizard: convert a text spectrum file to mzML

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:input text file:_files' \
  '2:output mzML file:_files' && ret=0

return ret
