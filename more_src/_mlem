#compdef mlem
# ML model registry and deployment tool by Iterative

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--verbose[enable verbose output]' \
  '--no-analytics[disable analytics]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'apply:apply a saved model to data'
      'build:build a model package'
      'clone:clone a MLEM object from remote to local'
      'declare:declare a deployment'
      'deploy:deploy a model'
      'import:import an external model into MLEM'
      'init:initialize a MLEM project'
      'link:create a link to a MLEM object'
      'list:list MLEM objects'
      'pprint:pretty-print a MLEM object'
      'serve:serve a model locally'
      'types:list available MLEM types'
    )
    _describe -t commands 'mlem command' commands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments \
          '--host[host to bind]:host:' \
          '--port[port to bind]:port:' \
          '--server[server type]:type:' \
          '*:model:_files' && ret=0
        ;;
      deploy)
        _arguments \
          '--model[model to deploy]:model:_files' \
          '--env[deployment environment]:env:' \
          '*:deployment:' && ret=0
        ;;
      build)
        _arguments \
          '--target[build target]:target:' \
          '--model[model to build]:model:_files' \
          '*:output:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
