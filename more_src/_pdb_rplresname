#compdef pdb_rplresname
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Performs in-place replacement of a residue name by another

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[residue name replacement in from:to form, e.g. -HIS:HIP]:from\:to' \
  '*:PDB file:_files' && ret=0

return ret
