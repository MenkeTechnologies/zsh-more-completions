#compdef docui

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-e+[docker endpoint]:endpoint:' \
  '--endpoint=[docker endpoint]:endpoint:' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--log-file=[log file path]:file:_files' && ret=0

return ret
