_bluehawk() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '*--plugin=[load Bluehawk plugin (repeatable)]:path:_files' \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _bh_cmds=(
                'check:validate Bluehawk markup syntax'
                'copy:clone source tree with Bluehawk commands applied'
                'list:list info'
                'snip:extract code snippets'
            )
            _describe -t commands 'bluehawk command' _bh_cmds && ret=0
            ;;
        args)
            case $words[1] in
                check)
                    _arguments \
                        '--logLevel=[verbosity (0=none/1=errors/2=warn/3=all)]:n:(0 1 2 3)' \
                        '*: :_files' && ret=0
                    ;;
                copy)
                    _arguments \
                        '1:root path:_files -/' \
                        '(-o --output)'{-o,--output}'=[output directory (REQUIRED)]:dir:_files -/' \
                        '*'{-i,--ignore}'=[ignore pattern (repeatable)]:pattern:' \
                        '--state=[select state]:state:' \
                        '--rename=[rename JSON record string]:json:' \
                        '--logLevel=[verbosity]:n:(0 1 2 3)' && ret=0
                    ;;
                list)
                    _arguments \
                        '--json[output as JSON]' \
                        '--logLevel=[verbosity]:n:(0 1 2 3)' && ret=0
                    ;;
                snip)
                    _arguments \
                        '(-o --output)'{-o,--output}'=[output directory (REQUIRED)]:dir:_files -/' \
                        '*'{-i,--ignore}'=[ignore pattern (repeatable)]:pattern:' \
                        '--state=[select state]:state:' \
                        '*--id=[select snippets by id (repeatable)]:id:' \
                        '(-f --format)'{-f,--format}'=[generate formatted snippets]:format:(rst docusaurus)' \
                        '--json[output as JSON]' \
                        '--logLevel=[verbosity]:n:(0 1 2 3)' \
                        '*: :_files' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_bluehawk "$@"
