#compdef relax
# Documentation: https://docs.rosettacommons.org/docs/latest/application_documentation/structure_prediction/relax
# Rosetta relax all-atom structure refinement application

local ret=1

_arguments -s -S \
  '-help[display all available options]' \
  '-relax:fast[do a simple small-cycle fast relax (default)]' \
  '-relax:thorough[do a preset large-cycle relax]' \
  '-relax:classic[run the classic relax protocol]' \
  '-relax:constrain_relax_to_start_coords[constrain relax to starting coordinates]' \
  '-relax:constrain_relax_to_native_coords[constrain relax to native coordinates]' \
  '-relax:ramp_constraints[ramp coordinate constraints during relax]' \
  '-relax:coord_constrain_sidechains[also constrain sidechain coordinates]' \
  '-in:file:s+[input PDB file]:pdb:_files -g "*.pdb"' \
  '-in:file:l+[list of input PDB files]:pdblist:_files' \
  '-in:file:silent+[silent format input file]:silent:_files' \
  '-database+[path to Rosetta database directory]:database:_files -/' \
  '-score:weights+[scoring function weights file]:weights:_files' \
  '-nstruct+[number of output structures]:nstruct:' \
  '-out:nstruct+[number of output structures]:nstruct:' \
  '-out:path:all+[output directory path]:path:_files -/' \
  '-out:pdb[output in PDB format]' \
  '-overwrite[overwrite existing output files]' \
  '-ex1[extra chi1 rotamer sampling]' \
  '-ex2[extra chi2 rotamer sampling]' \
  '-use_input_sc[retain input sidechain conformations]' \
  '-ignore_unrecognized_res[allow unrecognized residues]' \
  '-ignore_zero_occupancy+[read zero-occupancy atoms]:bool:(true false)' \
  '-run:constant_seed[use a deterministic random seed]' \
  '*-mute+[suppress output from a tracer channel]:channel:' \
  '*-unmute+[enable output from a tracer channel]:channel:' \
  '*:file:_files' && ret=0

return ret
