#compdef benchi
# Documentation: https://man.archlinux.org/search?q=benchi
# Reference accessed: 2026-05-16

_arguments -s -S \
  '-config=[path to benchmark YAML config]:config file:_files' \
  '-out=[results output directory path]:directory:_directories' \
  '*-tool+[only run this benchmark tool (repeatable)]:tool:' \
  '*-tests+[only run this test name (repeatable)]:test:' \
  '-v[print version and exit]'
