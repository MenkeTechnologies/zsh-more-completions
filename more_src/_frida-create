#compdef frida-create
# Documentation: https://github.com/frida/frida-tools/blob/main/frida_tools/creator.py
# Generate a boilerplate Frida agent or CModule project

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[output version information and exit]' \
  '(-n --project-name)'{-n,--project-name}'=[project name]:name' \
  '(-o --output-directory)'{-o,--output-directory}'=[output directory]:dir:_files -/' \
  '(-t --template)'{-t,--template}'=[template file]:template:(agent cmodule)' && ret=0

return ret
