#compdef elasticsearch-syskeygen
# Documentation: https://man.archlinux.org/search?q=elasticsearch-syskeygen
# Reference accessed: 2026-05-16

# elasticsearch-syskeygen: generate system_key for Elasticsearch
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '--silent[silent]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-E[config setting key=value]:kv:' \
  '*::elasticsearch-syskeygen args:_files' && ret=0
return ret
