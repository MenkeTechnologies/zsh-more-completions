#compdef cmdr
# Documentation: https://github.com/reyyanxahmed/cmdr
# Reference accessed: 2026-05-22
# Verified: src/cli/args.ts and bin/cmdr.ts CLI help output.

# Zsh completion for cmdr - local-first multi-agent coding tool (Ollama)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-m --model)'{-m,--model}'[model name]:model:' \
  '(-u --ollama-url)'{-u,--ollama-url}'[Ollama server URL]:url:' \
  '--provider[LLM provider]:provider:(ollama openai anthropic qwen)' \
  '(-p --prompt)'{-p,--prompt}'[single prompt and exit]:prompt:' \
  '--dangerously-skip-permissions[auto-approve all tool calls]' \
  '(-r --resume)'{-r,--resume}'[resume session by ID]:id:' \
  '(-c --continue)'{-c,--continue}'[resume most recent session]' \
  '--cwd[working directory]:directory:_directories' \
  '--verbose[print full tool output]' \
  '--max-turns[maximum agent turns]:turns:' \
  '(-t --team)'{-t,--team}'[team preset]:preset:(review fullstack security)' \
  '--output-format[output format]:format:(text json stream-json)' \
  '(-e --effort)'{-e,--effort}'[effort level]:level:(low medium high max)' \
  '--fast[alias for --effort low]' \
  '(-i --image)'{-i,--image}'[attach image]:file:_files' \
  '--no-buddy[disable buddy companion]' \
  '--browser[enable browser automation tools]' \
  '--port[HTTP server port for serve]:port:' \
  '--host[HTTP server host for serve]:host:' \
  '--watch[directory to watch for daemon]:directory:_directories' \
  '--on-change[command on file change]:command:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'cmdr command' \
      'serve[start HTTP/SSE server]' \
      'daemon[file-watch daemon]' && ret=0
    ;;
  args)
    case $line[1] in
      daemon)
        _values 'daemon action' start status stop && ret=0
        ;;
      *)
        _arguments '*:prompt:' && ret=0
        ;;
    esac
    ;;
esac

return ret
