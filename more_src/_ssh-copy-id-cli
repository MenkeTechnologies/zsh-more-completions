#compdef ssh-copy-id
# _ssh-copy-id-cli — OpenSSH push public key to remote authorized_keys; uses ssh
# upstream: https://github.com/openssh/openssh-portable

_ssh-copy-id-cli() {
    _arguments \
        '-f[force, no test before install]' \
        '-h[show help]' \
        '-i+[identity file]:file:_files' \
        '-n[dry run]' \
        '-o+[ssh option]:str:' \
        '-p+[port]:port:' \
        '-s[use sftp instead of ssh exec]' \
        '*:user@host:_hosts'
}

_ssh-copy-id-cli "$@"
