#compdef dx dioxus

# Zsh completion for Dioxus CLI

_dioxus() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'build:build the Rust WASM app and all of its assets'
    'translate:translate some source file to a Dioxus component'
    'serve:build, watch and serve the Rust WASM app and all of its assets'
    'new:create a new project for Dioxus'
    'init:initialize a new project in the current directory'
    'clean:clean output artifacts'
    'bundle:bundle the Rust desktop app and all of its assets'
    'fmt:autoformat RSX code'
    'check:check the project for issues'
    'link:link a web, desktop, or mobile project'
    'config:manage Dioxus CLI configuration'
    'doctor:check the system for Dioxus development requirements'
    'completions:generate shell completions'
    'version:print Dioxus CLI version'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'dioxus command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        build)
          _arguments -s -S \
            '--release[build in release mode]' \
            '--platform=[target platform]:platform:(web desktop fullstack static-generation liveview)' \
            '--features=[features to activate]:features:' \
            '--target=[build target]:target:' \
            '--verbose[verbose output]' \
            '--example=[build a specific example]:example:' \
            '--package=[build a specific package]:package:' \
            '--skip-assets[skip asset optimization]' \
            && ret=0
          ;;
        serve)
          _arguments -s -S \
            '--release[build in release mode]' \
            '--platform=[target platform]:platform:(web desktop fullstack static-generation liveview)' \
            '--features=[features to activate]:features:' \
            '--target=[build target]:target:' \
            '--verbose[verbose output]' \
            '--example=[serve a specific example]:example:' \
            '--package=[serve a specific package]:package:' \
            '--hot-reload[enable hot reloading]' \
            '--port=[port to serve on]:port:' \
            '--addr=[address to serve on]:address:' \
            '--open[open in browser]' \
            '--cross-origin-policy[enable cross-origin policy]' \
            && ret=0
          ;;
        new)
          _arguments -s -S \
            '--template=[template]:template:(web desktop fullstack)' \
            '--yes[accept defaults]' \
            '1:project name:' \
            && ret=0
          ;;
        fmt)
          _arguments -s -S \
            '--check[check formatting without modifying files]' \
            '--raw=[raw RSX to format]:rsx:' \
            '-f+[file to format]:file:_files -g "*.rs"' \
            '--file=[file to format]:file:_files -g "*.rs"' \
            && ret=0
          ;;
        translate)
          _arguments -s -S \
            '-c[write output to component]' \
            '--component[write output to component]' \
            '-f+[file to translate]:file:_files -g "*.html"' \
            '--file=[file to translate]:file:_files -g "*.html"' \
            && ret=0
          ;;
        *)
          _arguments -s -S '--help[display help]' && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_dioxus "$@"
