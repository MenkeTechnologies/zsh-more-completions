#compdef moonx
# Documentation: https://www.npmjs.com/package/@moonrepo/cli
# Reference accessed: 2026-05-23
# Verified: npx moonx --help (@moonrepo/cli moonx bin).

# Zsh completion for moonx - Moonrepo low-level task executor

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'exec:execute task targets in the action pipeline'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--ci=[execute as CI environment]:bool:(true false)' \
  '(-f --force)'{-f,--force}'[force run and bypass cache]' \
  '(-i --interactive)'{-i,--interactive}'[run pipeline interactively]' \
  '(-p --plan)'{-p+,--plan=}'[execution plan JSON path]:file:_files' \
  '(-s --summary)'{-s+,--summary=}'[pipeline summary level]:level:(none minimal normal detailed)' \
  '--ignore-ci-checks[ignore run in CI task checks]' \
  '--on-failure=[on task failure]:mode:(bail continue)' \
  '--query=[filter tasks by query]:query:' \
  '--no-actions[run without sync and setup actions]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'moonx command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (exec)
        _arguments \
          ':task target:' \
          '*:passthrough args:' && ret=0 ;;
    esac ;;
esac

return ret
