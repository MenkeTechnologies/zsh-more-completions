#compdef artillery

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'aws:AWS commands'
  'cloud:Artillery Cloud'
  'completion:generate completion'
  'convert:convert YAML/JSON between formats'
  'dino:print dino'
  'help:show help'
  'kill:kill running test'
  'list-running:list running tests'
  'open:open running test in browser'
  'plugins:plugin commands'
  'pro:Artillery Pro'
  'quick:quick load test'
  'report:generate HTML report'
  'run:run test script'
  'run-fargate:run on Fargate'
  'run-lambda:run on Lambda'
  'stop:stop test'
  'sync:sync logs'
  'test:test runner'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'artillery command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run|run-fargate|run-lambda)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '(-i --input)'{-i+,--input=}'[input file]:file:_files' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' \
          '(-d --dotenv)'{-d+,--dotenv=}'[dotenv file]:file:_files' \
          '(-e --environment)'{-e+,--environment=}'[env]:e:' \
          '(-t --target)'{-t+,--target=}'[target URL]:url:' \
          '(-w --overrides)'{-w+,--overrides=}'[override JSON]:j:' \
          '(-k --insecure)'{-k,--insecure}'[insecure TLS]' \
          '(-p --payload)'{-p+,--payload=}'[payload csv]:file:_files' \
          '(-v --variables)'{-v+,--variables=}'[variables JSON]:j:' \
          '(--scenario-name)--scenario-name=[scenario name]:s:' \
          '(--record)--record[record to cloud]' \
          '(--key)--key=[Artillery Cloud key]:k:' \
          '(--note)--note=[run note]:n:' \
          '(--name)--name=[run name]:n:' \
          '(--tags)--tags=[tags csv]:list:' \
          '*: :_files -g "*.yml *.yaml *.json"' && ret=0 ;;
      (report)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '*: :_files -g "*.json"' && ret=0 ;;
      (quick)
        _arguments \
          '(-c --count)'{-c+,--count=}'[VUs]:n:' \
          '(-n --num)'{-n+,--num=}'[requests per VU]:n:' \
          '(-r --rate)'{-r+,--rate=}'[rate per sec]:n:' \
          '(-d --duration)'{-d+,--duration=}'[duration s]:s:' \
          '(-t --think)'{-t+,--think=}'[think time s]:s:' \
          '(-i --insecure)'{-i,--insecure}'[insecure]' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '*: :_urls' && ret=0 ;;
      (cloud|aws|pro)
        _arguments \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
