#compdef barman-cloud-backup-keep
# Documentation: https://docs.pgbarman.org/release/3.10.0/barman-cloud-backup-keep.1.html
# Reference accessed: 2026-05-17
# Verified: Barman 3.10 barman-cloud-backup-keep upstream — mark/
# unmark cloud backups as protected from retention. Real flags:
# -V/--version, -h/--help, -v/--verbose, -q/--quiet, -t/--test,
# --cloud-provider, -r/--release, -s/--status, --target,
# --endpoint-url, -P/--aws-profile, --read-timeout,
# --azure-credential.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--cloud-provider)--cloud-provider=+[cloud provider]:provider:(aws-s3 azure-blob-storage google-cloud-storage)' \
  '(--endpoint-url)--endpoint-url=+[endpoint URL]:url:' \
  '(-P --profile)'{-P,--profile}'+[AWS profile]:profile:' \
  '(--azure-credential)--azure-credential=+[Azure credential]:cred:(azure-cli managed-identity)' \
  '(-t --test)'{-t,--test}'[test connectivity]' \
  '(-r --release)'{-r,--release}'[release keep]' \
  '(-s --status)'{-s,--status}'[show keep status]' \
  '(--target)--target=+[keep target]:target:(full standalone)' \
  '*:server_name destination_url backup_id:' && ret=0

return ret
