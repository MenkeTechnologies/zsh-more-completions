#compdef kubectl-cilium
# Documentation: https://man.archlinux.org/search?q=kubectl-cilium
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-n --namespace)'{-n,--namespace}'=[Kubernetes namespace]:namespace:' \
  '--kubeconfig=[path]:file:_files' \
  '--context=[kube context]:context:' \
  '*::args: _default'
