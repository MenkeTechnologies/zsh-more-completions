_blaise() {
    _arguments -s \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '--source=[Pascal source file]:source:_files -g "*.pas"' \
        '--output=[output binary path]:output:_files' \
        '*--unit-path=[add directory to unit search path (repeatable)]:dir:_files -/' \
        '--target=[code generation target]:target:(linux-x86_64 macos-arm64)' \
        '--emit-ir[print QBE IR to stdout and exit]' \
        '--debug[enable runtime memory leak reporting on exit]' \
        '--debug-opdf[emit OPDF debug info as .opdf.s companion]' \
        '-iV[print version (FPC compatibility probe)]' \
        '-iTP[print target processor (FPC compatibility probe)]' \
        '-iTO[print target OS (FPC compatibility probe)]' \
        '-FE+[output directory (FPC style)]:dir:_files -/' \
        '*-Fu+[unit search path (FPC style, repeatable)]:path:_files -/' \
        '-FU+[unit output directory (FPC style)]:dir:_files -/' \
        '-o+[output binary name (FPC style)]:name:' \
        '-Mobjfpc[language mode (FPC compatibility)]' \
        '-O+[optimization level (FPC compatibility)]:level:(0 1 2 3 s)' \
        '-g[enable debug info]' \
        '-gl[enable line-number debug info]' \
        '-CX[smart linking]' \
        '*-d+[define conditional symbol]:symbol:' \
        '*:Pascal source file:_files -g "*.pas"'
}

_blaise "$@"
