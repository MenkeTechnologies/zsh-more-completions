#
#   Verified via:
#     gh api repos/graemeg/blaise/contents/README.adoc
#       → "modern, self-hosting Object Pascal compiler"
#       → "Blaise bootstraps and recompiles itself with byte-
#          for-byte fixpoint"
#       → "QBE backend, with an LLVM backend in active
#          development"
#     gh api repos/graemeg/blaise/contents/compiler/src/main/
#         pascal/Blaise.pas
#       → const Version = '0.10.0-dev'; CompilerName = 'Blaise';
#       → procedure PrintUsage lists every flag verbatim:
#         --source / --output / --unit-path / --target /
#         --emit-ir / --debug / --debug-opdf
#       → procedure HandleFPCInfoQuery handles -iV / -iTP /
