#compdef ldconfig
# _ldconfig-cli — glibc dynamic linker config + cache refresher; rebuild /etc/ld.so.cache
# upstream: https://sourceware.org/glibc

_ldconfig-cli() {
    _arguments \
        '(-c --format)'{-c,--format}'+[cache format]:format:(old new compat)' \
        '(-C)-C+[cache file]:file:_files' \
        '(-f)-f+[config file]:file:_files' \
        '(-i --ignore-aux-cache)'{-i,--ignore-aux-cache}'[ignore aux cache]' \
        '(-l)-l[do not start fresh cache]' \
        '(-n)-n[only update specific dirs]' \
        '(-N)-N[do not rebuild cache]' \
        '(-p --print-cache)'{-p,--print-cache}'[print cache contents]' \
        '(-r)-r+[chroot dir]:dir:_files -/' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-X)-X[no symlink update]' \
        '--help[show help]' \
        '*:dir:_files -/'
}

_ldconfig-cli "$@"
