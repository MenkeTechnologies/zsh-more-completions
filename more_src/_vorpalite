#compdef vorpalite
# Documentation: https://github.com/BrunoLevy/geogram/wiki/Vorpaline
# Geogram Vorpaline mesh reconstruction, repair and remeshing tool

local ret=1

_arguments -s -S \
  '*profile=[Vorpaline mode]:profile:(scan convert repair heal cad tet poly hex quad)' \
  '*debug=[toggle debug mode]:debug:(true false)' \
  '*pre=[toggle pre-processing phase]:pre:(true false)' \
  '*pre\:repair=[repair input mesh]:repair:(true false)' \
  '*pre\:epsilon=[colocate tolerance (%% bbox diagonal)]:epsilon:' \
  '*pre\:max_hole_area=[fill holes smaller than (%% total area)]:area:' \
  '*pre\:max_hole_edges=[fill holes with fewer edges than]:edges:' \
  '*pre\:min_comp_area=[remove small components (%% total area)]:area:' \
  '*pre\:margin=[expand border (%% bbox diagonal)]:margin:' \
  '*pre\:Nsmooth_iter=[normals smoothing iterations]:iters:' \
  '*remesh=[toggle remeshing phase]:remesh:(true false)' \
  '*remesh\:nb_pts=[number of vertices]:pts:' \
  '*remesh\:anisotropy=[anisotropy factor]:aniso:' \
  '*remesh\:gradation=[mesh gradation exponent]:grad:' \
  '*remesh\:multi_nerve=[insert vertices to preserve topology]:val:(true false)' \
  '*remesh\:RVC_centroids=[use restricted Voronoi cell centroids]:val:(true false)' \
  '*remesh\:refine=[insert points to lower Hausdorff distance]:val:(true false)' \
  '*remesh\:max_dist=[max distance to source mesh (rel avg edge len)]:dist:' \
  '*remesh\:sharp_edges=[reconstruct sharp edges]:val:(true false)' \
  '*post=[toggle post-processing phase]:post:(true false)' \
  '*post\:repair=[repair output mesh]:val:(true false)' \
  '*post\:max_hole_area=[fill holes smaller than (%% total area)]:area:' \
  '*post\:max_hole_edges=[fill holes with fewer edges than]:edges:' \
  '*post\:min_comp_area=[remove small components (%% total area)]:area:' \
  '*post\:compute_normals=[compute normals]:val:(true false)' \
  '*co3ne=[use reconstruction]:val:(true false)' \
  '*co3ne\:nb_neighbors=[neighbors used in reconstruction]:n:' \
  '*co3ne\:radius=[search radius (%% bbox diagonal)]:radius:' \
  '*co3ne\:max_N_angle=[filter bad triangles (degrees)]:angle:' \
  '*tet=[toggle tetrahedral meshing]:val:(true false)' \
  '*tet\:refine=[add points to improve mesh quality]:val:(true false)' \
  '*tet\:quality=[desired element quality]:q:' \
  '*hex=[toggle hex-dominant meshing]:val:(true false)' \
  '*quad=[toggle quad-dominant meshing]:val:(true false)' \
  '*algo\:predicates=[geometric predicates]:pred:(fast exact)' \
  '*algo\:delaunay=[Delaunay algorithm]:algo:' \
  '*sys\:multithread=[enable multi-threaded computations]:val:(true false)' \
  '*sys\:max_threads=[maximum concurrent threads]:n:' \
  '*:mesh:_files' && ret=0

return ret
