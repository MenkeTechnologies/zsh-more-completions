#compdef kubectl-prof
local curcontext="$curcontext" state line ret=1
local -a _pods
if command -v kubectl &>/dev/null 2>&1; then
  _pods=(${(f)"$(kubectl get pods --no-headers -o custom-columns=':metadata.name' 2>/dev/null)"})
fi
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--lang=[programming language runtime]:language:(go java python ruby node clang perf rust)' \
  '--event=[profiling event type]:event:(cpu alloc lock cache-misses wall)' \
  '--duration=[profiling duration]:duration:' \
  '--interval=[sampling interval]:interval:' \
  '(-n --namespace)'{-n,--namespace}'=[Kubernetes namespace]:namespace:' \
  '--output-dir=[directory for output files]:directory:_directories' \
  '--target-container=[target container name]:container:' \
  '--service-account=[service account to use]:service-account:' \
  '--image-pull-secret=[image pull secret name]:secret:' \
  '--cpu=[CPU resource request/limit]:cpu:' \
  '--memory=[memory resource request/limit]:memory:' \
  '1:pod name:'"(${_pods[*]})" && ret=0
return ret
