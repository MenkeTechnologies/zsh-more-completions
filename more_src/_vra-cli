#compdef vra-cli vra
# _vra-cli — VMware vRealize Automation CLI alias (sammcgeown/community team, Go); cobra
# upstream: https://github.com/sammcgeown/vra-cli

_vra-cli() {
    local -a sub=(
        'login:save credentials'
        'logout:clear credentials'
        'whoami:show current user'
        'config:configuration management'
        'config set:set config option'
        'config get:get config option'
        'completion:generate completion'
        'create:create resource'
        'create blueprint:create blueprint'
        'create deployment:create deployment'
        'create catalogitem:create catalog item'
        'create cloudtemplate:create cloud template'
        'create variable:create variable'
        'delete:delete resource'
        'delete blueprint:delete blueprint'
        'delete deployment:delete deployment'
        'delete catalogitem:delete catalog item'
        'export:export resource'
        'export blueprint:export blueprint'
        'export pipeline:export pipeline'
        'get:get resource'
        'get blueprint:get blueprint'
        'get deployment:get deployment'
        'get catalogitem:get catalog item'
        'get cloudtemplate:get cloud template'
        'get pipeline:get pipeline'
        'get variable:get variable'
        'get integration:get integration'
        'get endpoint:get endpoint'
        'get user:get user'
        'get project:get project'
        'get release:get release'
        'help:show help'
        'import:import resource'
        'import blueprint:import blueprint'
        'import pipeline:import pipeline'
        'import yaml:import YAML'
        'update:update resource'
        'update blueprint:update blueprint'
        'update deployment:update deployment'
        'update catalogitem:update catalog item'
        'execute:execute resource'
        'execute pipeline:execute pipeline'
        'execute deployment:execute deployment'
        'apply:apply yaml'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--server=+[server URL]:url:_urls' \
        '--username=+[user]:_users' \
        '--password=+[password]:str:' \
        '--apitoken=+[api token]:str:' \
        '--domain=+[domain]:str:' \
        '--config=+[config file]:file:_files' \
        '--debug[debug]' \
        '--insecure[skip TLS verification]' \
        '--ignore-cert[skip TLS verification]' \
        '--ignoreCertWarnings[skip TLS warnings]' \
        '-o+[output]:f:(json yaml table export)' \
        '--output=+[output]:f:(json yaml table export)' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vra subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_vra-cli "$@"
