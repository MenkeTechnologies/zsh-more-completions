#compdef yarn-session.sh flink-yarn
# _flink-yarn — Apache Flink yarn-session.sh (long-running YARN session for repeated job submission; -n number of taskmanagers (legacy), -s slots-per-tm, -jm JobManager memory, -tm taskmanager memory, -nm YARN app name, -q list queues, -qu YARN queue, -z Zookeeper namespace, -d detach after launch, -id reattach to running session)
# upstream: https://github.com/apache/flink (flink-yarn)
# Flags from Apache Flink flink-yarn src/main/java/org/apache/flink/yarn/cli/FlinkYarnSessionCli.java on tip.

_flink-yarn() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-n+[taskmanagers]:n:' \
        '--container+[taskmanagers]:n:' \
        '-s+[slots per TM]:n:' \
        '--slots+[slots per TM]:n:' \
        '-jm+[JM memory MiB]:mb:' \
        '--jobManagerMemory+[JM memory MiB]:mb:' \
        '-tm+[TM memory MiB]:mb:' \
        '--taskManagerMemory+[TM memory MiB]:mb:' \
        '-nm+[YARN app name]:name:' \
        '--name+[YARN app name]:name:' \
        '-q[list YARN queues]' \
        '--query[list YARN queues]' \
        '-qu+[YARN queue]:queue:' \
        '--queue+[YARN queue]:queue:' \
        '-z+[ZK namespace]:ns:' \
        '--zookeeperNamespace+[ZK namespace]:ns:' \
        '-d[detach]' \
        '--detached[detach]' \
        '-id+[attach to existing session]:appId:' \
        '--applicationId+[attach to existing session]:appId:' \
        '-yqu+[YARN queue]:queue:' \
        '-yat+[YARN app type]:type:' \
        '*-D+[KEY=VALUE]:property:'
}

_flink-yarn "$@"
