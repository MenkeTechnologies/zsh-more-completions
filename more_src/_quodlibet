#compdef quodlibet

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'play:start playback'
  'stop:stop playback'
  'pause:pause playback'
  'play-pause:toggle playback'
  'next:next track'
  'previous:previous track'
  'volume-up:increase volume'
  'volume-down:decrease volume'
  'status:show status'
  'song:show current song'
  'song-list:show song list'
  'queue:show queue'
  'enqueue:queue track'
  'unqueue:remove from queue'
  'add-location:open file'
  'random:random track'
  'repeat:toggle repeat'
  'shuffle:toggle shuffle'
  'open-browser:open browser'
  'hide-window:hide window'
  'show-window:show window'
  'toggle-window:toggle window'
  'set-rating:set rating'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[debug mode]' \
  '--no-plugins[disable plugins]' \
  '--run-server[run as remote server]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'quodlibet command' commands && ret=0 ;;
esac

return ret
