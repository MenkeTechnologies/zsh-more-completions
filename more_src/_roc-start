#
# roc-start CLI surface (decoded from
# ArgParser.roc):
#   Global:
#     -v / --verbosity LEVEL    verbose | quiet | silent
#     -h / --help               (auto-injected by weaver)
#     -V / --version            (auto-injected by weaver)
#
#   Subcommands:
#     app <packages...>     Create a new roc app
#       -f / --force        Force overwrite of existing file
#       --no-plugin         Use fallback generation instead of plugin
#       -o / --out FILE     Output file (default: main.roc)
#       -p / --platform     Platform (e.g. basic-cli=latest)
#     package <packages...> Create a new roc package
#       -f / --force        Force overwrite
#     upgrade [packages...] Upgrade platform/packages
#       -i / --in FILE      Input file to upgrade
#       -p / --platform     Platform to upgrade to
#     update                Update repos/plugins/themes
#       -k / --packages     Update package repositories
#       -f / --platforms    Update platform repositories
#       -s / --plugins      Update platform plugins
#       -t / --themes       Update color themes
#       -i / --install      Install latest roc-start
#     config                Configure default settings
#       --set-theme NAME    Set default color theme
#       --set-verbosity LV  Set default verbosity
#       --set-default-platform PLATFORM
#                           Set default platform
#
# roc-start is a CLI tool for initializing new
# Roc projects and managing dependencies for
# existing projects.  Authored by Ian McLerran
# (imclerran).  20 GH stars.  Sister tools: roc
# (Roc compiler — in corpus), roc-lang/basic-cli
# (Roc CLI platform — library, not standalone
# tool), weaver (the CLI library itself; in
# corpus already under `_weaver` for
# ServiceWeaver — DIFFERENT TOOL; namespace
# collision between Roc weaver and Google's
# ServiceWeaver).
#
# Critical extraction note: roc-start uses **Roc
# `weaver` library** at ArgParser.roc:3 — corpus's
# **first documented Roc CLI library**.  `weaver`
# is smores56/weaver, the de-facto Roc CLI
# argument parser.  Distributed as a tarball URL
# in the Roc package format (Roc has no central
# package registry — packages are referenced by
# GitHub release URLs with content-addressable
# hashes).  Distinct from raw `cli.Arg` (Roc
# basic-cli platform's argv accessor with `to_os_
# raw`), Roc's `Stdin`/`Stdout` modules.  weaver
# adds: typed option constructors (`Opt.flag`,
# `Opt.maybe_str`, `Opt.maybe_u64`), typed
# positional constructors (`Param.str`, `Param.
# str_list`), subcommand combinators
# (`SubCmd.optional`, `SubCmd.required`,
# `SubCmd.finish`), `Cli.weave` record-builder,
# `Cli.map` pipe-mapped post-parse transformers,
# `Cli.finish` finalization with name/version/
# authors/description metadata, `Cli.assert_valid`
# compile-time validation.  Extends cross-
# language CLI taxonomy to FIFTY-EIGHT library
# variants: Rust (6), Go (4), Python (3),
# Crystal 1 OptionParser (R269), Haskell (R270),
# OCaml (R271), C (R272), Java (R276),
# Kotlin (R277), Scala (R278), Dart (R279),
# Ruby (R280), Perl (R281), PHP (R282),
# Swift (R283), F# (R284), Lua (R285), C# (R286),
# Nim 1 parseopt (R287), Zig (R288), D (R289),
# Racket (R290), Common Lisp 1 (R291),
# Erlang (R292), Tcl (R293), Pharo Smalltalk (R294),
# Common Lisp 2 clingon (R295), Julia (R296),
# SWI-Prolog optparse (R297), Pony stdlib cli (R298),
# Crystal 2 Admiral (R299), V stdlib `flag` (R300),
# Nim 2 cligen (R301), Clojure 1 babashka.cli
# (R302), Gleam Glint (R303), Ada GNAT.Command_
# Line (R304), C++ 1 CLI11 (R305), Elixir Optimus
# (R306), Vala GLib.OptionContext (R307), Hare
# stdlib getopt (R308), Standard ML stdlib GetOpt
# (R309), Fortran M_CLI2 (R310), Guile (ice-9
# getopt-long) (R311), Free Pascal TCustomApplication
# (R312), Idris 2 System.GetOpts (R313), Mercury
# stdlib getopt_io (R314), Eiffel Gobo AP_PARSER
# (R315), C++ 2 boost::program_options (R316),
# Forth/Gforth `next-arg` (R317), Clojure 2
# org.clojure/tools.cli (R318), **Roc weaver**
# (R319 — NEW).  **MAJOR PATTERN MILESTONE**: 58
# cross-language CLI library variants documented.
# Roc joins the taxonomy as a 2022-era pure-
# functional-with-uniqueness-types language by
# Richard Feldman.
#
# Critical extraction note: roc-start uses **Roc
# `{ Cli.weave <- field: value, ... }` record-
# arrow-weave CLI spec pattern** at ArgParser.roc:
# 33-43, 73-94, 105-122 — Roc's `{ COMBINATOR <-
# field: value, ... }` is the RECORD-BUILDER
# SYNTAX with a LEADING COMBINATOR.  Each field's
# value is "WOVEN" into the parser result via the
# combinator.  Sister to R270 Haskell `<*>`
# applicative-style (each field assembles via
# `(<*>)`), R303 Gleam Glint's `glint.add(at:,
# do:)` pipe-builder, R313 Idris 2 `MkOpt`
# constructor.  Roc's `<-` ARROW INSIDE RECORD-
# LITERAL is UNIQUE — the combinator (here
# `Cli.weave`) determines how the fields combine.
# Corpus's **first documented record-arrow-weave
# CLI spec pattern**.
#
# Critical extraction note: roc-start uses **Roc
# `|> Cli.map(FN)` pipe-mapped post-parse
# transformers** at ArgParser.roc:34-35, 76-78,
# 79-81, 92, 132, 137 — `Opt.maybe_str(...) |>
# Cli.map(verbosity_to_log_level)` applies a
# POST-PARSE TRANSFORMER via Roc's `|>` PIPE
# OPERATOR.  Each `Cli.map` transforms the parsed
# value through a pure function.  Distinct from
# R302 Clojure babashka.cli `:assoc-fn` (mutation
# hook), R318 Clojure tools.cli `:parse-fn`
# (replace-the-string transformer), R311 Guile
# `(option-ref options 'NAME #f)` (caller-side
# transformation post-parse).  Roc's approach:
# PURE-FUNCTIONAL POST-PARSE MAPPING via `|>`
# pipe — composable, lazy, type-safe.  Corpus's
# **first documented pipe-mapped-post-parse CLI
# pattern**.
#
# Critical extraction note: roc-start uses **Roc
# `SubCmd.optional([sub1, sub2, ...]) +
# SubCmd.finish({mapper: Ctor})` constructor-as-
# mapper subcommand dispatch** at ArgParser.roc:
# 36, 90-94, 99-104, 119-122, 129-132, 138-141 —
# `SubCmd.optional(LIST)` declares an OPTIONAL
# subcommand chosen from a list.  Each subcommand
# is built via `{ Cli.weave <- ... } |>
# SubCmd.finish({ name, description, mapper })`
# where `mapper` BINDS the parsed subcommand to
# an ADT CONSTRUCTOR.  When the user runs
# `roc-start app pkg1 pkg2`, weaver produces
# `App { packages: [...], force: false, ... }`
# as the parsed value.  Distinct from R302
# babashka.cli `:fn HANDLER` (handler called
# directly with parsed opts map), R313 Idris 2
# ADT-as-parsed-value (similar but no `mapper`
# field — uses constructor arity directly).
# Roc's approach: CONSTRUCTOR-AS-MAPPER — parsed
# subcommand becomes a TAGGED ADT variant for
# caller to pattern-match.  Corpus's **first
# documented constructor-as-mapper CLI pattern**.
#
# Critical extraction note: roc-start uses **Roc
# `Param.str_list({ name: "packages", help: "..."})`
# for REPEATABLE POSITIONALS** at ArgParser.roc:
# 82-83, 108-110 — `Param.str_list` accepts ZERO
# or MORE string positional args.  Distinct from
# R313 Idris 2 `glint.named_arg` (typed single
# positional), R310 Fortran M_CLI2 (comma-
# separated array via single flag), R272 C POSIX
# getopt (positionals via argv after parsing).
# Roc's approach: TYPED `Param.str_list`
# constructor for repeatable positionals — sister
# to R303 Gleam Glint `strings_flag` plural-suffix
# but Roc's is for POSITIONALS not FLAGS.
# Corpus's **first documented `Param.str_list`
# CLI pattern**.
#
# Critical extraction note: roc-start uses **Roc
# `app [main!] { dependency: "https://github.com/.../tarball-hash.tar.br" }`
# URL-tarball-dependency app manifest** at
# main.roc:1-13 — Roc's APP MANIFEST declares
# dependencies via URL.  `cli: platform "URL"`
# declares the PLATFORM (Roc's effect-providing
# runtime); `weaver: "URL"` declares a library
# dependency.  Each URL points to a
# CONTENT-ADDRESSABLE TARBALL on GitHub releases
# (hash in the path).  No central package
# registry.  Distinct from R270 Haskell Hackage,
# R311 Guile no-package-manager, R272 C
# `#include <header.h>` headers).  Corpus's
# **first documented URL-tarball-dependency CLI
# pattern**.
#
# Critical extraction note: roc-start uses **Roc
# `|> Cli.finish({...}) |> Cli.assert_valid`
# finalization chain** at ArgParser.roc:43-52 —
# the parser is FINALIZED via `|> Cli.finish({
# name, version, authors, description,
# text_style })` and VALIDATED via `|> Cli.
# assert_valid` (compile-time check that the
# spec is consistent).  Distinct from R313
# Idris 2 (no separate finalization — `getOpt`
# is called directly), R305 C++ CLI11 (no
# separate validation step — relies on runtime
# parse errors), R302 babashka.cli (no
# validation step).  Roc's approach: PIPELINE-
# FINALIZATION-AND-VALIDATION — corpus's **first
# documented pipeline-finalization-and-validation
# CLI pattern**.
#
# Hunt-skip notes: skipped `_roc` (Roc compiler
# in corpus + blacklisted), `_weaver` (in corpus
# but for Google ServiceWeaver — DIFFERENT TOOL,
# namespace collision with Roc's weaver library).
# Skipped `_unison` (DUP with stock zsh).
# Probed `smores56/roc-query` (1 star, GraphQL
# client example — small CLI), `isaacvando/gob`
# (19 stars, stack-based language in Roc but
# `gob.roc` uses manual arg parsing without
# weaver).  Chose roc-start: 20 GH stars
# (Ian McLerran), 5 subcommands (app, package,
# upgrade, update, config) + global verbosity,
# extensive use of weaver patterns (Cli.weave
# record-builder with `<-` arrow, Opt.flag /
# Opt.maybe_str / Param.str_list typed
# constructors, |> Cli.map post-parse transformers,
# SubCmd.optional + SubCmd.finish for subcommand
# dispatch with mapper constructors, |> Cli.finish
# / |> Cli.assert_valid pipeline finalization),
# real binary distributed via Roc package
# manager (URL tarballs).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 5 subcommands decoded source-direct from
# SubCmd.optional list at ArgParser.roc:36
local -a roc_start_subcmds=(
  'app:create a new roc app with the specified name, platform, and packages'
  'package:create a new roc package main file with all specified packages'
  'upgrade:upgrade the platform and/or packages in an app or package'
  'update:update platform and package repositories, plugins, themes'
  'config:configure the default settings for the roc-start CLI'
)

local -a verbosity_levels=(
  'verbose:print all log messages'
  'quiet:print only errors'
  'silent:print nothing'
)

_arguments -C \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  '(-v --verbosity)'{-v+,--verbosity=}'[set the verbosity level]:level:->verbosities' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  verbosities)
    _describe -t verbosity_levels 'verbosity level' verbosity_levels && ret=0
    ;;
  subcmd)
    _describe -t commands 'roc-start subcommand' roc_start_subcmds && ret=0
    ;;
  args)
    case $words[1] in
      app)
        # decoded from app_subcommand at ArgParser.roc:60-95
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[force overwrite of existing file]' \
          '--no-plugin[use fallback generation instead of platform-specific plugin]' \
          '(-o --out)'{-o+,--out=}'[output file name (default: main.roc)]:output filename:_files -g "*.roc"' \
          '(-p --platform)'{-p+,--platform=}'[platform to use (e.g. basic-cli=latest)]:platform[=version]:' \
          '(-h --help)'{-h,--help}'[display app help]' \
          '*:package[=version]:' && ret=0
        ;;
      package)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[force overwrite of existing file]' \
          '(-h --help)'{-h,--help}'[display package help]' \
          '*:package[=version]:' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          '(-i --in)'{-i+,--in=}'[input file to upgrade (default: main.roc)]:input filename:_files -g "*.roc"' \
          '(-p --platform)'{-p+,--platform=}'[platform[=version] to upgrade to]:platform[=version]:' \
          '(-h --help)'{-h,--help}'[display upgrade help]' \
          '*:package[=version] (omit for all):' && ret=0
        ;;
      update)
        _arguments -s -S \
          '(-k --packages)'{-k,--packages}'[update the package repositories]' \
          '(-f --platforms)'{-f,--platforms}'[update the platform repositories]' \
          '(-s --plugins)'{-s,--plugins}'[update the platform plugins]' \
          '(-t --themes)'{-t,--themes}'[update the available color themes]' \
          '(-i --install)'{-i,--install}'[install the latest version of roc-start]' \
          '(-h --help)'{-h,--help}'[display update help]' && ret=0
        ;;
      config)
        _arguments -s -S \
          '--set-theme=[set the default color theme for the CLI]:theme name:' \
          '--set-verbosity=[set the default verbosity level]:level:(verbose quiet silent)' \
          '--set-default-platform=[set the default platform for new apps]:platform[=version]:' \
          '(-h --help)'{-h,--help}'[display config help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
