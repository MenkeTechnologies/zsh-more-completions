#compdef voms-proxy-info

# voms-proxy-info: show information about a VOMS GSI proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-q[quiet]' \
  '-file[proxy file]:file:_files' \
  '-conf[config file]:file:_files' \
  '-vo[show VO]' \
  '-acsubject[AC subject]' \
  '-acissuer[AC issuer]' \
  '-actimeleft[AC time left]' \
  '-subject[show subject]' \
  '-issuer[show issuer]' \
  '-identity[show identity]' \
  '-type[show proxy type]' \
  '-strength[show strength]' \
  '-timeleft[show time left]' \
  '-key[show key]' \
  '-fqan[show FQANs]' \
  '-text[show all]' \
  '-all[show all]' \
  '-path[show path]' \
  '-server[show server]' \
  '-uri[show URI]' \
  '-included[show included files]' \
  '-keyusage[show key usage]' \
  '-chain[show full chain]' \
  '-targets[show targets]' \
  '*::voms-proxy-info args:_files' && ret=0
return ret
