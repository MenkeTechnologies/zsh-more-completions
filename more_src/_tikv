#compdef tikv-server tikv-ctl

local curcontext="$curcontext" state line ret=1

case "$service" in
  tikv-server)
    _arguments -s -S \
      '(- *)'{-h,--help}'[Show help]' \
      '(- *)'{-V,--version}'[Show version]' \
      {-A,--addr}'[Set listening address]:address' \
      '--advertise-addr[Set advertise address]:address' \
      {-C,--config}'[Configuration file path]:config:_files' \
      '--data-dir[Data directory]:directory:_files -/' \
      '--capacity[Store capacity]:capacity' \
      '--pd-endpoints[PD endpoints]:endpoints' \
      '--labels[Server labels]:labels' \
      '--log-file[Log file path]:file:_files' \
      '--log-level[Log level]:level:(trace debug info warn error off)' \
      '--status-addr[Status server address]:address' \
      '--advertise-status-addr[Advertise status address]:address' \
      '--metrics-addr[Prometheus pushgateway address]:address' \
      && ret=0
    ;;
  tikv-ctl)
    _tikv_ctl_commands() {
      local -a commands=(
        'raft:Print raft log entry'
        'size:Print region size'
        'scan:Raw scan of the data'
        'print:Print the raw value'
        'mvcc:Print MVCC info'
        'diff:Diff two regions'
        'compact:Compact a column family in a range'
        'compact-cluster:Compact the whole cluster'
        'unsafe-recover:Unsafe recovery operations'
        'recreate-region:Recreate a region'
        'tombstone:Set some regions to tombstone'
        'store:Print store info'
        'cluster:Print cluster info'
        'bad-regions:Get all bad regions'
        'modify-tikv-config:Modify TiKV config'
        'metrics:Print metrics'
        'region-properties:Show region properties'
        'split-region:Split a region'
        'fail:Inject failures'
        'encryption-meta:Dump encryption metadata'
        'bad-ssts:Get all bad SST files'
      )
      _describe -t commands 'tikv-ctl command' commands
    }

    _arguments -s -S -C \
      '(- *)'{-h,--help}'[Show help]' \
      '(- *)'{-V,--version}'[Show version]' \
      '--host[TiKV host]:host' \
      '--ca-path[TLS CA certificate path]:file:_files' \
      '--cert-path[TLS certificate path]:file:_files' \
      '--key-path[TLS key path]:file:_files' \
      '--pd[PD endpoints]:endpoints' \
      {-C,--config}'[Configuration file path]:config:_files' \
      {-d,--data-dir}'[TiKV data directory]:directory:_files -/' \
      '--skip-paranoid-checks[Skip paranoid checks when opening RocksDB]' \
      '1:command:_tikv_ctl_commands' \
      '*::arg:->args' && ret=0

    case "$state" in
      args)
        case "$words[1]" in
          raft)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--region[Region ID]:region-id' \
              '--index[Log index]:index' \
              '--key[Key]:key' \
              && ret=0
            ;;
          size)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--region[Region ID]:region-id' \
              '--cf[Column family]:cf:(default write lock)' \
              && ret=0
            ;;
          scan)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--from[Start key]:key' \
              '--to[End key]:key' \
              '--limit[Limit]:limit' \
              '--cf[Column family]:cf:(default write lock)' \
              '--start-ts[Start timestamp]:ts' \
              '--commit-ts[Commit timestamp]:ts' \
              && ret=0
            ;;
          print)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--cf[Column family]:cf:(default write lock)' \
              '--key[Key]:key' \
              && ret=0
            ;;
          mvcc)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--key[Key]:key' \
              '--cf[Column family]:cf:(default write lock)' \
              '--start-ts[Start timestamp]:ts' \
              '--commit-ts[Commit timestamp]:ts' \
              && ret=0
            ;;
          diff)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--region[Region ID]:region-id' \
              '--to-host[Target host]:host' \
              && ret=0
            ;;
          compact)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--region[Region ID]:region-id' \
              '--db[Database type]:db:(kv raft)' \
              '--cf[Column family]:cf:(default write lock)' \
              '--from[Start key]:key' \
              '--to[End key]:key' \
              '--threads[Number of threads]:threads' \
              '--bottommost[Bottommost level compaction]:mode:(skip force)' \
              && ret=0
            ;;
          compact-cluster)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--db[Database type]:db:(kv raft)' \
              '--cf[Column family]:cf:(default write lock)' \
              '--from[Start key]:key' \
              '--to[End key]:key' \
              '--threads[Number of threads]:threads' \
              '--bottommost[Bottommost level compaction]:mode:(skip force)' \
              && ret=0
            ;;
          unsafe-recover)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '*:args' \
              && ret=0
            ;;
          recreate-region)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--region[Region ID]:region-id' \
              '--pd[PD endpoints]:endpoints' \
              && ret=0
            ;;
          tombstone)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--regions[Region IDs]:regions' \
              '--pd[PD endpoints]:endpoints' \
              '--force[Force operation]' \
              && ret=0
            ;;
          store)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              && ret=0
            ;;
          cluster)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              && ret=0
            ;;
          bad-regions)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              && ret=0
            ;;
          modify-tikv-config)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--name[Config name]:name' \
              '--value[Config value]:value' \
              && ret=0
            ;;
          metrics)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--tag[Metrics tag]:tag' \
              && ret=0
            ;;
          region-properties)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--region[Region ID]:region-id' \
              && ret=0
            ;;
          split-region)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '--region[Region ID]:region-id' \
              '--key[Split key]:key' \
              && ret=0
            ;;
          fail)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '1:subcommand:((inject\:"Inject a failure" recover\:"Recover from a failure" list\:"List failures"))' \
              && ret=0
            ;;
          encryption-meta)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              '1:subcommand:((dump-key\:"Dump data key" dump-file\:"Dump file encryption info"))' \
              && ret=0
            ;;
          bad-ssts)
            _arguments -s -S \
              '(- *)'{-h,--help}'[Show help]' \
              && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
