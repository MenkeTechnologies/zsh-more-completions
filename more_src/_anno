#compdef anno
# Documentation: man anno(1)
# Source: nmh uip/anno.c (master) — annotate nmh messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-component+[header component field]:component:_default' \
    '(-inplace -noinplace)-inplace[annotate in place]' \
    '(-inplace -noinplace)-noinplace[create new message]' \
    '(-date -nodate)-date[add Date header]' \
    '(-date -nodate)-nodate[no Date header]' \
    '-text+[annotation body text]:text:_default' \
    '-version[show version]' \
    '-help[show help]' \
    '-draft[annotate draft message]' \
    '-list[list annotations]' \
    '-delete[delete annotation]' \
    '-number+[annotation instance number]:N:_default' \
    '-append[append annotation]' \
    '(-preserve -nopreserve)-preserve[preserve last modified time]' \
    '(-preserve -nopreserve)-nopreserve[do not preserve mtime]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
