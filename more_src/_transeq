#compdef transeq
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/transeq.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS transeq: translate nucleic acid sequences to protein
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' \
  '-sequence=[nucleic acid sequence(s)]:file:_files' \
  '-outseq=[output sequence]:file:_files' \
  '-frame=[translation frame]:frame:(1 2 3 F -1 -2 -3 R 6)' \
  '-table=[genetic code]:code:(0 1 2 3 4 5 6 9 10 11 12 13 14 15 16 21 22 23)' \
  '-regions=[regions to translate]:regions:' \
  '-trim[trim trailing stop codons]' \
  '-clean[replace stop codons with X]' \
  '-alternative[alternative initiation codons]' \
  '-methionine[force first AA to Met for full-length ORFs]' \
  '-nomethionine[disable forced Met translation]' \
  '*:sequence:_files' && ret=0

return ret
