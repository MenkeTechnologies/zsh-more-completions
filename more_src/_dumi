#
# THE dumi CLI — Umi yParser + js-yaml + markdown-it + React
#
# dumi's CLI is in src/cli.ts and src/service/cli.ts.  Uses
# Umi's yParser (yargs-parser fork) for argv parsing.
#
# Source:
#     // src/cli.ts
#     (async () => {
#         logger.info(chalk.cyan.bold(`dumi v${version}`));
#         await run({ presets: [require.resolve('./preset')] });
#     })();
#
#     // src/service/cli.ts
#     const args = yParser(process.argv.slice(2), {
#         alias: { version: ['v'], help: ['h'] },
#         boolean: ['version'],
#     });
#     const command = args._[0];
#     if (command === 'dev') { dev(); }
#     else { new DumiService().run2({ name: args._[0], args }); }
#
# Commands:
#   dev                  start development server with HMR
#                        (default port 8000; configurable)
#   build                build production-ready static site
#                        to dist/
#   setup                initialize new project / regenerate
#                        config files (.dumirc.ts)
#   preview              preview built static site locally
#   generate <type>      code generators (page, plugin, etc.)
#   g <type>             alias for generate
#   plugin <command>     plugin management (list, add, remove)
#   webpack <command>    webpack config inspection
#   config <command>     config file inspection
#   version              show dumi + umi versions
#   help                 show help
#
# Global flags:
#   -v, --version        show version
#   -h, --help           show help
#
# Common command flags (vary by subcommand):
#   --port=N             dev server port (default 8000)
#   --host=HOST          dev server host (default 0.0.0.0)
#   --config=PATH        custom config file path
#   --mode=MODE          NODE_ENV mode (development|production)
#   --no-mfsu            disable MFSU (Module Federation Speed Up)
#
# js-yaml is used in dumi's Markdown front-matter parsing
# pipeline (markdown files like docs/guide.md start with
# `---` YAML front-matter blocks containing title, order,
# nav, group, hero, features, etc.).  dumi parses these via
# js-yaml v4.1 to extract page metadata.
#
# Five-axis distinctness from serde_yaml (R669) + yaml.v3 (R670):
#
#   1. PARSE + DUMP PLAIN-OBJECT API — js-yaml's load/dump
#      operate on POJOs.  serde_yaml uses typed derive;
#      yaml.v3 uses struct tags.
#
#   2. SCHEMA OPTIONS — CORE / JSON / FAILSAFE schemas.
#
#   3. CUSTOM TYPE CLASS — extensible via Type instances.
#
#   4. SYNCHRONOUS PARSING — no async API.
#
#   5. VITALY-PUZRIN / NODECA ECOSYSTEM PROVENANCE — same
#      maintainer as markdown-it (R667); "scientific" JS
#      library emphasis.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/umijs/dumi/blob/master/src/cli.ts
# https://github.com/umijs/dumi/blob/master/src/service/cli.ts
# Umi yParser config + dumi service constants.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _dumi_cmds
_dumi_cmds=(
    'dev:start development server with HMR'
    'build:build production-ready static site to dist/'
    'setup:initialize new project / regenerate config files'
    'preview:preview built static site locally'
    'generate:code generators (page, plugin, etc.)'
    'g:code generators (alias for generate)'
    'plugin:plugin management (list, add, remove)'
    'webpack:webpack config inspection'
    'config:config file inspection'
    'version:show dumi + umi versions'
    'help:show help for a subcommand'
)

_arguments -C \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '--port=[dev server port]:port:_default' \
    '--host=[dev server host]:host:_default' \
    '--config=[custom config file path]:path:_files -g "*.(ts|js|mjs)"' \
    '--mode=[NODE_ENV mode]:mode:(development production)' \
    '--no-mfsu[disable MFSU (Module Federation Speed Up)]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'dumi subcommand' _dumi_cmds && ret=0
        ;;
    args)
        case $words[1] in
            generate|g)
                _values 'generator type' 'page' 'plugin' 'demo' 'guide' && ret=0
                ;;
            plugin)
                _values 'plugin action' 'list' 'add' 'remove' && ret=0
                ;;
            webpack)
                _values 'webpack action' 'inspect' && ret=0
                ;;
            config)
                _values 'config action' 'list' 'show' && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _dumi_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
