#compdef aa-enforce aa-complain aa-disable aa-audit aa-allowall
# _aa-enforce — AppArmor mode utilities (aa-enforce / aa-complain / aa-disable / aa-audit / aa-allowall flip a profile's mode in /etc/apparmor.d/* and reload it into the kernel; --base profile directory, --version, --help; positional argument is the profile name or path)
# upstream: https://gitlab.com/apparmor/apparmor
# Flags from apparmor/apparmor utils/aa-enforce on tip.

_aa-enforce() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-d+[base dir]:dir:_files -/' \
        '--base+[base dir]:dir:_files -/' \
        '*:profile:_files -g "*.profile"'
}

_aa-enforce "$@"
