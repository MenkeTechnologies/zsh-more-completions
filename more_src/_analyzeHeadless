#compdef analyzeHeadless
# _analyzeHeadless — Ghidra headless analyzer driver (NationalSecurityAgency/ghidra)
# upstream: https://github.com/NationalSecurityAgency/ghidra
# Flags from Ghidra/RuntimeScripts/support/analyzeHeadlessREADME.md.

_analyzeHeadless() {
    _arguments \
        '*-import=[import file(s) or directory]:file:_files' \
        '*-process=[process existing project file]:file:_files' \
        '*-preScript=[run script before analysis]:script:' \
        '*-postScript=[run script after analysis]:script:' \
        '-scriptPath=[semicolon-separated script directories]:paths:' \
        '-propertiesPath=[semicolon-separated property directories]:paths:' \
        '-scriptlog=[path to script log file]:file:_files' \
        '-log=[path to log file]:file:_files' \
        '-overwrite[overwrite existing project files]' \
        '-mirror[mirror server repository]' \
        '-recursive=[recurse N levels into directories]:depth:' \
        '-readOnly[do not save changes to project]' \
        '-deleteProject[delete project after processing]' \
        '-noanalysis[skip auto-analysis]' \
        '-processor=[language ID for processor]:lang:' \
        '-cspec=[compiler spec ID]:cspec:' \
        '-analysisTimeoutPerFile=[per-file analysis timeout in seconds]:s:' \
        '-keystore=[keystore path for shared project]:file:_files' \
        '-connect=[server user ID]:userid:_users' \
        '-p[prompt for password (server mode)]' \
        '-commit=[commit changes with comment]:comment:' \
        '-okToDelete[allow scripts to delete files]' \
        '-max-cpu=[max CPU cores to use]:n:' \
        '-librarySearchPaths=[semicolon-separated library paths]:paths:' \
        '-loader=[desired loader name]:loader:' \
        '1:project location:_files -/' \
        '2:project_name[/folder_path] or ghidra URL:'
}

_analyzeHeadless "$@"
