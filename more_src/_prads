#compdef prads
# Documentation: https://manpages.debian.org/testing/prads/prads.1.en.html
# Passive Real-time Asset Detection System

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-i+[network device to sniff on]:interface:_net_interfaces' \
  '-r+[read pcap file]:pcap file:_files' \
  '-c+[read config from file]:config file:_files' \
  '-b+[apply Berkeley packet filter]:filter:' \
  '-u+[run under user identity]:user:_users' \
  '-g+[run under group identity]:group:_groups' \
  '-d[do not drop privileges]' \
  '-a+[specify home nets]:nets:' \
  '-D[daemonize]' \
  '-p+[name of pidfile inside chroot]:pidfile:_files' \
  '-l+[log asset data to file]:logfile:_files' \
  '-f+[log assets to named pipe]:fifo:_files' \
  '-B[log connections to ringbuffer]' \
  '-C+[chroot into dir before dropping privs]:dir:_files -/' \
  '*-v[verbose output, repeat for more verbosity]' \
  '-q[quiet, try harder not to produce output]' \
  '*:pcap file:_files' && ret=0

return ret
