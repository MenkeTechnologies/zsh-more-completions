#compdef osu_allgather
# Documentation: https://github.com/forresti/osu-micro-benchmarks/blob/master/README
# OSU MPI collective micro-benchmark

local ret=1

_arguments -s \
  '-m[set minimum and maximum message length (e.g. 2:128)]:size:' \
  '-i[number of iterations per message length]:count:' \
  '-x[number of warmup iterations to skip]:count:' \
  '-f[report additional statistics (min/max latency and iterations)]' \
  '-M[maximum per-process memory allocation in bytes]:bytes:' \
  '-d[memory/device type for buffers]:type:(managed cuda openacc)' \
  '-h[display help message]' && ret=0

return ret
