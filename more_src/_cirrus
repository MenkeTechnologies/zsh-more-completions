#compdef cirrus

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run a Cirrus task locally'
  'serve:start the persistent worker server'
  'worker:run / manage a persistent worker'
  'validate:validate a .cirrus.yml configuration'
  'lint:lint a .cirrus.yml file'
  'internal:internal helpers'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[path to a Cirrus configuration]:file:_files -g ".cirrus.{yml,yaml}"' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cirrus command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-e --environment)*'{-e+,--environment=}'[env var KEY=VALUE]:env:' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '--dirty[do not rsync working directory]' \
          '--lazy-pull[lazy-pull container images]' \
          '--simple-renderer[use simple renderer]' \
          '--container-backend=[container backend]:backend:(docker podman)' \
          '--artifacts-dir=[output directory for artifacts]:dir:_files -/' \
          '--always-pull[always pull container images]' \
          '--output=[output format]:format:(travis simple)' \
          '*::task:' && ret=0 ;;
      (worker)
        local -a worker_subs=(
          'run:run a persistent worker'
          'pause:pause a worker'
          'resume:resume a paused worker'
        )
        _describe -t wcmds 'worker subcommand' worker_subs && ret=0
        _arguments \
          '--name=[worker name]:name:' \
          '--token=[worker token]:token:' \
          '--user=[run as user]:user:_users' \
          '--rpc-endpoint=[Cirrus CI RPC endpoint]:url:' \
          '--labels=[worker labels (comma-separated)]:labels:' && ret=0 ;;
      (validate|lint)
        _arguments \
          '*::file:_files -g ".cirrus.{yml,yaml}"' && ret=0 ;;
      (serve)
        _arguments \
          '--listen=[listen address]:address:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
