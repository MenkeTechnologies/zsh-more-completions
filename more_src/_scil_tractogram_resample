#compdef scil_tractogram_resample
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_tractogram_resample.html
# Resample a tractogram to a given number of streamlines

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--never_upsample[prevent upsampling; only downsample]' \
  '--seed=[random seed for reproducible resampling]:seed' \
  '--point_wise_std=[add noise (mm) to streamline points]:std' \
  '--tube_radius=[max distance (mm) for generating streamlines]:radius' \
  '--gaussian=[smooth upsampled streamlines using gaussian sigma]:sigma' \
  '--keep_invalid_streamlines[retain generated streamlines that exceed bounding box]' \
  '--compress=[compress resulting streamlines with max distance threshold]:th' \
  '--downsample_per_cluster[downsample per Quickbundles cluster]' \
  '*--qbx_thresholds[Quickbundles threshold values]:threshold' \
  '--reference=[reference anatomy for tck/vtk/fib/dpy]:nifti:_files -g "*.nii *.nii.gz"' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[force overwrite of output files]' \
  '1:in_tractogram:_files' \
  '2:nb_streamlines:' \
  '3:out_tractogram:_files' && ret=0

return ret
