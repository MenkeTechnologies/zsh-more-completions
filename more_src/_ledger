#compdef ledger

# completions for ledger double-entry accounting CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-f+,--file=}'[read journal from file]:journal file:_files' \
  {-o+,--output=}'[write output to file]:output file:_files' \
  '--init-file=[read init file]:init file:_files' \
  '--account=[prepend account name]:account name' \
  {-b+,--begin=}'[start date]:date' \
  {-e+,--end=}'[end date]:date' \
  {-p+,--period=}'[report period]:period' \
  '--current[show only transactions on or before today]' \
  '--cleared[show only cleared transactions]' \
  '--uncleared[show only uncleared transactions]' \
  '--pending[show only pending transactions]' \
  '--real[show only real transactions]' \
  '--budget[show budget report]' \
  '--add-budget[add budgeted transactions]' \
  '--unbudgeted[show only unbudgeted transactions]' \
  '--forecast=[enable forecasting]:forecast expression' \
  {-l+,--limit=}'[limit which postings are used]:expression' \
  {-t+,--amount=}'[set amount expression]:expression' \
  {-T+,--total=}'[set total expression]:expression' \
  {-d+,--display=}'[limit which postings are displayed]:expression' \
  '--amount-data[show only amount data]' \
  '--total-data[show only total data]' \
  {-j,--amount-data}'[show only amounts in columns]' \
  {-J,--total-data}'[show only totals in columns]' \
  {-S+,--sort=}'[sort by expression]:expression' \
  '--sort-all=[sort all postings]:expression' \
  '--sort-xacts=[sort transactions]:expression' \
  {-w,--wide}'[assume 132-column terminal]' \
  '--head=[show first N transactions]:count' \
  '--tail=[show last N transactions]:count' \
  '--pager=[send output through pager]:pager command' \
  '--no-pager[do not use pager]' \
  '--color[use color output]' \
  '--no-color[disable color output]' \
  '--force-color[force color output]' \
  '--force-pager[force pager usage]' \
  {-E,--empty}'[show accounts with zero balance]' \
  {-c,--collapse}'[collapse entries with multiple postings]' \
  {-V,--market}'[show market value]' \
  {-X+,--exchange=}'[convert to given commodity]:commodity' \
  '--flat[do not indent accounts]' \
  '--depth=[limit account depth]:depth' \
  '--group-by=[group postings by expression]:expression' \
  '--group-title-format=[format for group titles]:format' \
  '--date-format=[format for dates]:date format' \
  '--input-date-format=[format for input dates]:date format' \
  '--strict[strict mode for account and commodity names]' \
  '--pedantic[pedantic mode, error on warnings]' \
  '--explicit[require explicit amounts]' \
  '--permissive[be more permissive with parsing]' \
  '--price-db=[price database file]:file:_files' \
  '--master-account=[set master account]:account' \
  '--day-break[break transactions that span midnight]' \
  '--no-revalued[do not show revalued postings]' \
  '--immediate[evaluate immediately]' \
  {-y+,--date-format=}'[set date format]:format' \
  '1:command:(balance register print accounts payees commodities tags xml csv emacs equity budget cleared)' \
  '*:query:' && ret=0

return ret
