#compdef bridgetown

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'new:create a new Bridgetown site'
      'build:build the site'
      'serve:serve the site locally'
      'start:start the site with live reload'
      'console:start an interactive console'
      'plugins:manage plugins'
      'configure:configure a plugin or automation'
      'deploy:deploy the site'
      'clean:clean the site output'
      'doctor:check site for common issues'
      'webpack:run webpack commands'
      'esbuild:run esbuild commands'
      'help:show help'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (new)
        _arguments \
          '(-t --apply)'{-t,--apply}'=[apply an automation]:automation:' \
          '--skip-bundle[skip bundle install]' \
          '--skip-yarn[skip yarn install]' \
          '--use-sass[use Sass for styling]' \
          '-e[frontend bundler]:bundler:(webpack esbuild)' \
          '1:path:_files -/' && ret=0
        ;;
      (build)
        _arguments \
          '(-s --source)'{-s,--source}'=[source directory]:dir:_files -/' \
          '(-d --destination)'{-d,--destination}'=[destination directory]:dir:_files -/' \
          '(-e --environment)'{-e,--environment}'=[build environment]:environment:' \
          '--future[publish posts with future date]' \
          '--unpublished[render posts marked as unpublished]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '(-V --verbose)'{-V,--verbose}'[verbose output]' \
          '--profile[show build profile]' \
          '--trace[show full backtrace on errors]' && ret=0
        ;;
      (serve|start)
        _arguments \
          '(-s --source)'{-s,--source}'=[source directory]:dir:_files -/' \
          '(-d --destination)'{-d,--destination}'=[destination directory]:dir:_files -/' \
          '(-H --host)'{-H,--host}'=[host to bind to]:host:' \
          '(-P --port)'{-P,--port}'=[port to serve on]:port:' \
          '(-l --livereload)'{-l,--livereload}'[enable live reload]' \
          '--skip-initial-build[skip the initial build]' \
          '(-o --open-url)'{-o,--open-url}'[open URL in browser]' \
          '(-e --environment)'{-e,--environment}'=[build environment]:environment:' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' && ret=0
        ;;
      (configure)
        _arguments '1:automation:' && ret=0
        ;;
    esac
    ;;
esac

return ret
