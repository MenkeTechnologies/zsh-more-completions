#compdef crunchy-cli
# Documentation: https://github.com/crunchy-labs/crunchy-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crunchy-labs/crunchy-cli crunchy-cli-core/src/lib.rs (+ download/archive/search/login/command.rs)
# clap Parser/Subcommand; flattened login credentials and Verbosity.

local curcontext="$curcontext" state line ret=1
local -a scmds

scmds=(
  'archive:multi-track MKV archive'
  'download:single-audio/video download'
  'login:persist refresh token to config dir'
  'search:Crunchyroll library search / inspect URLs'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[version string]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-q --quiet)'{-q,--quiet}'[quiet (forces non-interactive defaults)]' \
  '--lang=[override metadata locale]:locale:' \
  '--experimental-fixes[enable stabilization shims in crunchyroll-rs]' \
  '--credentials=[email\:password login]:creds:' \
  '--anonymous[anonymous session (no premium)]' \
  '--proxy=[https or socks5; see long_help forms]:proxy url:' \
  '--user-agent=[custom User-Agent header]:string:' \
  '--speed-limit=[max throughput number{B,KB,MB}]:limit:' \
  '1: :->c1' \
  '*:: :->rest' && ret=0

case $state in
  c1)
    _describe -t commands 'crunchy-cli' scmds && ret=0
    ;;
  rest)
    case $line[1] in
      login)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help]' \
          '--version[version]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' \
          '--lang=[locale]:locale:' \
          '--experimental-fixes' \
          '--credentials=[email\:password]:creds:' \
          '--anonymous' \
          '--proxy=[proxy spec]:url:' \
          '--user-agent=[UA string]:string:' \
          '--speed-limit=[limit]:lim:' \
          '--remove[purge saved session instead of saving]' && ret=0
        ;;
      download)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help]' \
          '--version[version]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' \
          '--lang=[locale]:locale:' \
          '--experimental-fixes' \
          '--credentials=[email\:password]:creds:' \
          '--anonymous' \
          '--proxy=[proxy spec]:url:' \
          '--user-agent=[UA string]:string:' \
          '--speed-limit=[limit]:lim:' \
          '(-a --audio)'{-a,--audio=}'[audio locale (series URLs)]:locale:' \
          '(-s --subtitle)'{-s,--subtitle=}'[subtitle locale]:locale:' \
          '(-o --output)'{-o,--output=}'[filename template]:template:' \
          '--output-specials=[special-episode template]:template:' \
          '--universal-output[sanitize template tokens for all OSes]' \
          '(-r --resolution)'{-r,--resolution=}'[video resolution]:res:(best worst 1080p 720p 480p 360p 240p)' \
          '--language-tagging=[audio/sub tagging]:tag:(default ietf)' \
          '--ffmpeg-preset=[transcode preset or raw ffmpeg args]:preset:' \
          '--ffmpeg-threads=[ffmpeg thread count]:n:' \
          '--skip-existing[skip filenames that already exist]' \
          '--skip-specials[skip episode 0 / decimal specials]' \
          '--include-chapters[embed intro/credits chapters]' \
          '--yes[answer interactive season prompts affirmatively]' \
          '--force-hardsub[burn subtitles even if container supports soft subs]' \
          '(-t --threads)'{-t,--threads=}'[parallel segment download threads]:n:' \
          '*:Crunchyroll URL or filter:_urls' && ret=0
        ;;
      archive)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help]' \
          '--version[version]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' \
          '--lang=[locale]:locale:' \
          '--experimental-fixes' \
          '--credentials=[email\:password]:creds:' \
          '--anonymous' \
          '--proxy=[proxy spec]:url:' \
          '--user-agent=[UA string]:string:' \
          '--speed-limit=[limit]:lim:' \
          '*'{-a,--audio=}'[audio track (repeat for multi)]:locale:' \
          '(-s --subtitle)'{-s,--subtitle=}'[subtitle locale]:locale:' \
          '(-o --output)'{-o,--output=}'[MKV filename template]:template:' \
          '--output-specials=[special-episode template]:template:' \
          '--universal-output[sanitize template tokens]' \
          '(-r --resolution)'{-r,--resolution=}'[video resolution]:res:(best worst 1080p 720p 480p 360p 240p)' \
          '--language-tagging=[track tagging]:tag:(default ietf)' \
          '--ffmpeg-preset=[transcode preset]:preset:' \
          '--ffmpeg-threads=[ffmpeg thread count]:n:' \
          '(-m --merge)'{-m,--merge=}'[multi-video merge policy]:mode:(audio video auto sync)' \
          '--merge-time-tolerance=[length delta in ms for auto merge]:ms:' \
          '--merge-sync-tolerance=[sync fingerprint equality slack]:n:' \
          '--sync-precision=[offset averaging runs]:n:' \
          '--default-subtitle=[forced/default subtitle locale]:locale:' \
          '--include-fonts[embed subtitle fonts in MKV]' \
          '--include-chapters[embed chapters (audio merge mode)]' \
          '--skip-existing[skip filenames that already exist]' \
          '--skip-existing-method=[what to diff when skipping]:kind:(audio subtitle)' \
          '--skip-specials[skip specials]' \
          '--yes[auto-pick seasons]' \
          '(-t --threads)'{-t,--threads=}'[download threads]:n:' \
          '*:Crunchyroll URL or filter:_urls' && ret=0
        ;;
      search)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help]' \
          '--version[version]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' \
          '--lang=[locale]:locale:' \
          '--experimental-fixes' \
          '--credentials=[email\:password]:creds:' \
          '--anonymous' \
          '--proxy=[proxy spec]:url:' \
          '--user-agent=[UA string]:string:' \
          '--speed-limit=[limit]:lim:' \
          '*--audio=[search audio filter locale]:locale:' \
          '(-o --output)'{-o,--output=}'[mustache-style output template]:tpl:' \
          '--search-top-results-limit=[cap top search hits]:n:' \
          '--search-series-limit=[series result cap]:n:' \
          '--search-movie-listing-limit=[movie listing cap]:n:' \
          '--search-episode-limit=[episode cap]:n:' \
          '--search-music-limit=[concert/music cap]:n:' \
          '*:URL or free-text query:_default' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
