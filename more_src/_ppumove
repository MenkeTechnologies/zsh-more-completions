#compdef ppumove

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-q[quiet]' \
  '-h[show help]' \
  '-v[verbose]' \
  '-b[create BSD style ld script]' \
  '-s[statically link the unit]' \
  '-S[same as -s for compatibility]' \
  '-e+[extension for unit files]:ext:' \
  '-o+[output filename]:file:_files' \
  '-d+[output directory]:dir:_files -/' \
  '*:ppu file:_files -g "*.ppu"' && ret=0

return ret
