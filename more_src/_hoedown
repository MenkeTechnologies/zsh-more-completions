#compdef hoedown
# Documentation: https://github.com/hoedown/hoedown
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hoedown: standards-compliant Markdown renderer in C (Sundown fork)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-T --time)'{-T,--time}'[show conversion time]' \
  '--html[render HTML output (default)]' \
  '--html-toc[render HTML table of contents]' \
  '(-i --max-nesting)'{-i+,--max-nesting=}'[max parsing nesting depth]:n:' \
  '(-t --toc-level)'{-t+,--toc-level=}'[max TOC level]:n:' \
  '--html-tag-escape[escape all HTML]' \
  '--html-skip-html[strip all HTML tags]' \
  '--html-hard-wrap[render each linebreak as <br>]' \
  '--html-use-xhtml[render XHTML]' \
  '--tables[parse PHP-Markdown tables]' \
  '--fenced-code[parse fenced code blocks]' \
  '--footnotes[parse footnotes]' \
  '--autolink[autolink safe URLs]' \
  '--strikethrough[parse strikethrough spans]' \
  '--underline[parse underline instead of emphasis]' \
  '--highlight[parse highlight spans]' \
  '--quote[parse "quote" spans]' \
  '--superscript[parse superscript spans]' \
  '--math[parse $math$ spans]' \
  '--no-intra-emphasis[disable intra-word emphasis]' \
  '--space-headers[require space after # in headers]' \
  '--disable-indented-code[do not parse indented code blocks]' \
  '*:Markdown file:_files -g "*.(md|markdown)"' && ret=0

return ret
