#compdef mpvc

# Zsh completion for mpvc - an mpc-like control interface for mpv

local curcontext="$curcontext" state line ret=1

_mpvc_commands() {
  local -a commands=(
    'add:add files/urls to playlist'
    'play:resume playback'
    'pause:pause playback'
    'toggle:toggle between play/pause'
    'stop:always stop playback'
    'next:play next media in playlist'
    'prev:play previous media in playlist'
    'current:print currently playing media'
    'playlist:print all items in playlist'
    'status:print mpv status'
    'remove:remove playlist entry'
    'clear:clear the playlist'
    'mute:mute playback'
    'seek:seek n seconds'
    'volume:set or adjust volume'
    'repeat:toggle repeat for current file'
    'loop:toggle loop playback of playlist'
    'shuffle:shuffle the playlist'
    'time:print current and total time'
    'format:set output format string'
    'kill:kill the mpv process'
    'quit:alias for kill'
  )
  _describe -t commands 'mpvc command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-S --socket)'{-S,--socket}'[socket location]:socket:_files' \
  '(-q --quiet)'{-q,--quiet}'[be quiet]' \
  '(-k --kill)'{-k,--kill}'[kill the mpv process]' \
  '1: :_mpvc_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      add)
        _files
        ;;
      *)
        _message 'no more arguments'
        ;;
    esac
    ;;
esac

return ret
