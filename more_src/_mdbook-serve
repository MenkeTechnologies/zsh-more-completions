#compdef mdbook-serve

# Zsh completion for mdbook serve subcommand (standalone)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-d+[output directory]:directory:_directories' \
  '--dest-dir=[output directory]:directory:_directories' \
  '-n+[hostname to listen on]:hostname' \
  '--hostname=[hostname to listen on]:hostname' \
  '-p+[port to listen on]:port' \
  '--port=[port to listen on]:port' \
  '-o[open browser after starting server]' \
  '--open[open browser after starting server]' \
  '1:directory:_directories' && ret=0

return ret
