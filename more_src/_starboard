#compdef starboard

# Zsh completion for starboard - Kubernetes security toolkit (Aqua)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--kubeconfig[path to kubeconfig]:file:_files' \
  '--namespace[Kubernetes namespace]:namespace:' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[all namespaces]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'find:find security reports'
      'generate:generate security reports'
      'cleanup:delete security reports'
      'get:get security report details'
      'init:initialize starboard operator'
      'install:install starboard operator'
      'uninstall:uninstall starboard operator'
      'config:manage starboard configuration'
      'scan:scan Kubernetes resources'
      'version:show version info'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (scan)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--scanner[scanner to use]:scanner:(Trivy Aqua)' \
          '--delete-scan-job[delete scan job after completion]' \
          '*:resource:' \
          && ret=0
        ;;
      (find|get)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:report type:(vulnerabilities configaudit ciskubebench kubehunter)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
