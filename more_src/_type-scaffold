#compdef type-scaffold
# _type-scaffold — scaffold basic Kubernetes type definitions (kubernetes-sigs/controller-tools)
# upstream: https://github.com/kubernetes-sigs/controller-tools
# Flags from cmd/type-scaffold/main.go (cobra).

_type-scaffold() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kind=[Kubernetes Kind to scaffold]:kind:' \
        '--resource=[resource name (defaults to lowercase plural of kind)]:resource:' \
        '--namespaced=[whether the resource is namespaced]:val:(true false)'
}

_type-scaffold "$@"
