#compdef vncconfig
# _vncconfig — TigerVNC vncconfig (control a running Xtigervnc server: -display selects which, -get/-set/-list query VNC RFB params, -clip syncs clipboard, -iconic minimises the helper window)
# upstream: https://github.com/TigerVNC/tigervnc
# Flags from tigervnc unix/vncconfig/vncconfig.cxx on tip.

_vncconfig() {
    _arguments \
        '-display+[X display]:display:' \
        '-set+[set parameter]:name=val:' \
        '-get+[print parameter]:name:' \
        '-list[list parameters]' \
        '-nowin[no GUI window]' \
        '-iconic[start minimised]'
}

_vncconfig "$@"
