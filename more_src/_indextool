#compdef indextool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--config[config file]:file:_files' \
  '-c[config file]:file:_files' \
  '--check[check index for errors]:index:' \
  '--build-infixes[build infix index]:index:' \
  '--dumpheader[dump index header]:file:_files' \
  '--dumpconfig[dump index config]:file:_files' \
  '--dumpdocids[dump document IDs]:index:' \
  '--dumphitlist[dump hit list]:keyword:' \
  '--fold[apply charset folding]:keyword:' \
  '--htmlstrip[strip HTML]:file:_files' \
  '--morph[apply morphology]:word:' \
  '--buildstops[build stop words list]:output:_files' \
  '--buildfreqs[show word frequencies]' \
  '--checkconfig[validate config file]' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '--strip-path[strip path from file names]' \
  && ret=0

return ret
