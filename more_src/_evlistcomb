#compdef evlistcomb
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/evlistcomb/node4.html
# Merge event lists from all CCD/nodes into a single event file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--eventsets=[list of input events files]:files:_files' \
  '--instrument=[select instrument]:inst:(emos epn rgs)' \
  '--imagingset=[output event file for IMAGING/SPECTROSCOPY mode]:file:_files' \
  '--timingset=[output event file for TIMING/BURST/HTR mode]:file:_files' \
  '--maintable=[names of tables to be merged]:tables' \
  '--othertables=[secondary tables or arrays to propagate]:tables' \
  '--primarychecks=[primary attributes to check for compatibility]:attrs' \
  '--primaryonly=[primary attributes not propagated to extensions]:attrs' \
  '--extensionchecks=[attributes to check for merged extension compatibility]:attrs' \
  '--minattributes=[attributes to minimise in merged extensions]:attrs' \
  '--maxattributes=[attributes to maximise in merged extensions]:attrs' \
  '--mainattributes=[attributes to propagate to merged extensions]:attrs' \
  '--emosdatamodes=[DATAMODE keywords to distinguish EMOS input files]:modes' \
  '--epndatamodes=[DATAMODE keywords to distinguish EPN input files]:modes' \
  '--rgsdatamodes=[DATAMODE keywords to distinguish RGS input files]:modes' \
  '*:param=value:_default' && ret=0

return ret
