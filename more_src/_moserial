#compdef moserial
# Documentation: https://man.archlinux.org/man/extra/moserial/moserial.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--display=+[X display]:disp:' && ret=0

return ret
