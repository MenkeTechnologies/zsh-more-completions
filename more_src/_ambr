#compdef ambr
# Documentation: https://github.com/dalance/amber
# amber replace: code search and replace tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-r --regex --no-regex)'{-r,--regex}'[enable regular expression search]' \
  '--no-regex[disable regular expression search]' \
  '--key-from-file[use file contents of KEYWORD as keyword for search]' \
  '--rep-from-file[use file contents of REPLACEMENT as keyword for replacement]' \
  '--max-threads=[number of max threads]:num' \
  '--size-per-thread=[file size per one thread]:bytes' \
  '--bin-check-bytes=[read size for checking binary]:bytes' \
  '--mmap-bytes=[minimum size for using mmap]:bytes' \
  '--tbm[enable TBM matcher]' \
  '--sse[enable SSE 4.2]' \
  '(--column --no-column)--column[enable column output]' \
  '--no-column[disable column output]' \
  '(--row --no-row)--row[enable row output]' \
  '--no-row[disable row output]' \
  '(--file --no-file)--file[enable filename output]' \
  '--no-file[disable filename output]' \
  '(--statistics --no-statistics)--statistics[enable statistics output]' \
  '--no-statistics[disable statistics output]' \
  '(--skipped --no-skipped)--skipped[enable skipped file output]' \
  '--no-skipped[disable skipped file output]' \
  '(--color --no-color)--color[enable colored output]' \
  '--no-color[disable colored output]' \
  '(--recursive --no-recursive)--recursive[enable recursive directory search]' \
  '--no-recursive[disable recursive directory search]' \
  '(--symlink --no-symlink)--symlink[enable symbolic link follow]' \
  '--no-symlink[disable symbolic link follow]' \
  '(--binary --no-binary)--binary[enable binary file search]' \
  '--no-binary[disable binary file search]' \
  '(--skip-vcs --no-skip-vcs)--skip-vcs[enable vcs directory skip]' \
  '--no-skip-vcs[disable vcs directory skip]' \
  '(--skip-gitignore --no-skip-gitignore)--skip-gitignore[enable .gitignore skip]' \
  '--no-skip-gitignore[disable .gitignore skip]' \
  '(--parent-ignore --no-parent-ignore)--parent-ignore[enable .*ignore search at parent directories]' \
  '--no-parent-ignore[disable parent .*ignore search]' \
  '(--fixed-order --no-fixed-order)--fixed-order[enable output order guarantee]' \
  '--no-fixed-order[disable output order guarantee]' \
  '(--interactive --no-interactive)--interactive[enable interactive replace]' \
  '--no-interactive[disable interactive replace]' \
  '(--preserve-time --no-preserve-time)--preserve-time[enable timestamp preserve]' \
  '--no-preserve-time[disable timestamp preserve]' \
  '--verbose[verbose message output]' \
  '1:keyword' \
  '2:replacement' \
  '*:path:_files' && ret=0

return ret
