#compdef autoflake8
# Documentation: https://github.com/fsouza/autoflake8
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --check)'{-c,--check}'[check only]' \
  '--check-diff[show diff]' \
  '(-i --in-place)'{-i,--in-place}'[modify in place]' \
  '(-r --recursive)'{-r,--recursive}'[recursive]' \
  '*--exclude=[exclude pattern csv]:list:' \
  '*--keep-pass-statements[keep pass]' \
  '*--keep-pass-after-docstring[keep pass after docstring]' \
  '--quiet[quiet]' \
  '--verbose[verbose]' \
  '--exit-zero-even-if-changed[exit 0 even if changed]' \
  '--remove-imports=[remove imports csv]:list:' \
  '--remove-unused-variables[remove unused vars]' \
  '*: :_files -g "*.py"' && ret=0

return ret
