#compdef taste
# Documentation: https://man.archlinux.org/search?q=taste
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-t+[recommendation type]:type:(music movies shows books authors games podcasts)' \
  '-l+[result limit]:n:' \
  '-i+[info type]:info:(yes no)' \
  '*:query:' && ret=0

return ret
