#compdef pdf2docx
# Documentation: https://pdf2docx.readthedocs.io/en/latest/quickstart.cli.html
# Open source Python library for converting PDF to DOCX

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--start=[first page to convert]:page:' \
  '--end=[last page to convert]:page:' \
  '--pages=[specific page indices, comma-separated]:pages:' \
  '--zero_based_index=[toggle zero-based page numbering]:bool:(True False)' \
  '--multi_processing=[enable parallel processing]:bool:(True False)' \
  '--cpu_count=[number of processors to use]:count:' \
  '--password=[password for encrypted PDF]:password:' \
  '1:command:(convert debug table)' \
  '*::file:_files' && ret=0

return ret
