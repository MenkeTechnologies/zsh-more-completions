#compdef cargo-docset

# https://github.com/Robzz/cargo-docset — Dash/Zeal docset from rustdoc

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :_values subcommand docset' \
  '*:: :->docset' && ret=0

if [[ $state == docset ]]; then
  _arguments -s -S \
    '--manifest-path=[path to Cargo.toml]:path:_files -g "Cargo.toml"' \
    '(-p --package)'{-p,--package}'=[package spec]:package:' \
    '--workspace[document all workspace packages]' \
    '--exclude=[exclude package from workspace]:package:' \
    '--no-deps[do not document dependencies]' \
    '--document-private-items[document private items]' \
    '--no-clean[do not clean doc dir before rustdoc]' \
    '--all-features[activate all features]' \
    '--no-default-features[disable default feature]' \
    '-F+[space-separated features]:features:' \
    '--features=[space-separated features]:features:' \
    '--lib[document this package library only]' \
    '--bin=[document only one binary]:binary:' \
    '--bins[document all binaries]' \
    '--target=[target triple]:triple:' \
    '--target-dir=[build output directory]:directory:_files -/' \
    '--docset-name=[docset display name]:name:' \
    '--docset-index=[package for index page]:package:' \
    '--platform-family=[docset platform keyword]:family:' \
    '(-h --help)'{-h,--help}'[help]' \
    '(-V --version)'{-V,--version}'[version]' \
    '*::free_args:_default' && ret=0
fi

return ret
