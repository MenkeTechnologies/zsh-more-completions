#compdef ytarchive
# Documentation: https://man.archlinux.org/search?q=ytarchive
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '(-o --output)'{-o,--output}'=[Output directory]:dir:_files -/' \
  '(-t --threads)'{-t,--threads}'=[Download threads]:count:' \
  '(-r --retry-streams)'{-r,--retry-streams}'[Retry live streams]' \
  '--add-metadata[Embed metadata]' \
  '--no-merge[Keep separate audio/video]' \
  '*:YouTube URL or video ID:_default'
