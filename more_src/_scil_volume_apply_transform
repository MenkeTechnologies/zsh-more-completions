#compdef scil_volume_apply_transform
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_volume_apply_transform.html
# Scilpy: apply a 4x4 transformation matrix to a volume

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--inverse[apply the inverse transformation]' \
  '--keep_dtype[preserve input data type in output]' \
  '--interpolation=[interpolation method]:interp:(linear nearest)' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_file:_files' \
  '2:in_target_file:_files' \
  '3:in_transfo:_files' \
  '4:out_name:_files' && ret=0

return ret
