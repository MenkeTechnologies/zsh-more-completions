#compdef pipdeptree

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-a --all)'{-a,--all}'[show all packages including pip, setuptools, etc.]' \
  '(-l --local-only)'{-l,--local-only}'[only show locally installed packages]' \
  '(-p --packages)'{-p,--packages}'[comma-separated list of packages to show]:packages' \
  '(-e --exclude)'{-e,--exclude}'[comma-separated list of packages to exclude]:packages' \
  '--json[output as JSON]' \
  '--json-tree[output as JSON tree]' \
  '--mermaid[output as Mermaid flowchart]' \
  '--graph-output[output format for graphviz]:format:(dot pdf png svg)' \
  '(-r --reverse)'{-r,--reverse}'[show reverse dependency tree]' \
  '(-d --depth)'{-d,--depth}'[maximum depth of tree]:depth' \
  '--encoding[output encoding]:encoding' \
  '--warn[warning mode]:mode:(silence suppress fail)' \
  '--python[path to python executable]:python:_files' \
  '--freeze[show output similar to pip freeze]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && ret=0
return ret
