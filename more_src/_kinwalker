#compdef kinwalker
# kinwalker — predict RNA folding trajectories and first passage times (ViennaRNA)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage information]' \
  '--init_structure[start with a structure other than the open chain]' \
  '--interrupt[allow interrupted folding trajectories when barrier exceeded]' \
  '--printfront[create PostScript plots of front progression]' \
  '(-t --test)'{-t,--test}'[use test sequence]' \
  '(-v --verbose)'{-v,--verbose}'[print debugging messages about program progress]' \
  '--barrier_heuristic=[barrier heuristic]:heuristic:(M S B A)' \
  '--dangle=[dangling end model]:mode:(0 1 2)' \
  '--grouping=[grouping method]:grouping:(standard regroup)' \
  '--lookahead=[lookahead value]:int' \
  '--maxkeep=[maximum structures to keep]:int' \
  '--nolonely=[lonely pair handling]:int' \
  '--transcribed=[number of transcribed nucleotides]:int' \
  '--transcription_rate=[transcription rate]:float' \
  '--windowsize=[window size (0 = all)]:int' && ret=0

return ret
