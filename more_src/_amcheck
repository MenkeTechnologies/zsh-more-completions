#compdef amcheck
# _amcheck — Zmanda Amanda amcheck CLI for verifying Amanda backup configuration disk-list accessibility tape availability holding-disk space client connectivity used before amdump runs with email reporting (zmanda team, C); getopt
# upstream: https://github.com/zmanda/amanda

_amcheck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-w[show warnings]' \
        '-s[do server-side checks only]' \
        '--server-only[do server-side checks only]' \
        '-c[do client-side checks only]' \
        '--client-only[do client-side checks only]' \
        '-l[do local-only checks]' \
        '--local-only[do local-only checks]' \
        '-t[do tape checks only]' \
        '--tape-only[do tape checks only]' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '-m+[mail address]:str:' \
        '--mail=+[mail address]:str:' \
        '-M[do not send mail]' \
        '--no-mail[do not send mail]' \
        '-B[no broker check]' \
        '-w+[csv warnings]:str:' \
        '-o+[option]:str:' \
        '*:config hostname diskname:'
}

_amcheck "$@"
