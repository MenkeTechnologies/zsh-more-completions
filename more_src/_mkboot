#compdef mkboot
# Documentation: https://github.com/xiaolu/mkbootimg_tools
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: mkboot is a wrapper script with positional usage
#   `mkboot bootimg outdir`   (unpack)
#   `mkboot dir newbootimg`   (repack)
# It takes no documented CLI flags.

local curcontext="$curcontext" ret=1

_arguments -C \
  '1:input image or directory:_files' \
  '2:output directory or image:_files' && ret=0

return ret
