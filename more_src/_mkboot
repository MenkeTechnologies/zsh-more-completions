#compdef mkboot

# mkboot: build Android boot.img (kernel+ramdisk+dtb)
# Documentation: https://source.android.com/docs/core/architecture/bootloader/boot-image-header
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--kernel=[kernel image]:file:_files' \
  '--ramdisk=[ramdisk]:file:_files' \
  '--second=[second-stage bootloader]:file:_files' \
  '--dtb=[device tree blob]:file:_files -g "*.dtb"' \
  '--cmdline=[kernel cmdline]:cmdline:' \
  '--base=[base offset]:hex:' \
  '--kernel_offset=[kernel offset]:hex:' \
  '--ramdisk_offset=[ramdisk offset]:hex:' \
  '--second_offset=[second offset]:hex:' \
  '--tags_offset=[tags offset]:hex:' \
  '--pagesize=[page size]:n:(2048 4096 8192 16384)' \
  '--header_version=[header version]:n:(0 1 2 3 4)' \
  '--os_version=[OS version]:ver:' \
  '--os_patch_level=[OS patch level]:level:' \
  '--id[print SHA1 id]' \
  '-o[output boot.img]:file:_files -g "boot.img"' \
  '--output=[output boot.img]:file:_files -g "boot.img"' \
  '*::mkboot args:_files' && ret=0
return ret
