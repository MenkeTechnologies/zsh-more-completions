#compdef tclsh
# Documentation: https://manpages.org/tclsh
# Reference accessed: 2026-05-21
# Verified: tclsh(1) accepts -encoding name plus fileName arg ... .

local -a arguments

arguments=(
    '-encoding[specify encoding of script]:encoding'
    '*:Tcl script:_files -g "*.tcl"'
)

_arguments -s -S $arguments
