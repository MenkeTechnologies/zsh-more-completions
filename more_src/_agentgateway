_agentgateway() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'oneshot:run agentgateway as subprocess and exec command when ready (Linux only)'
        'migrate:migrate deprecated local config fields to frontendPolicies'
        'help:show help for a subcommand'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-V[print short version string]' \
        '--version[print full version as JSON]' \
        '(-c --config)'{-c+,--config=}'[inline config bytes]:config:' \
        '(-f --file)'{-f+,--file=}'[config file path (use - for stdin)]:config file:_files' \
        '--validate-only[parse config and exit without starting proxy]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'agentgateway subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                oneshot)
                    _arguments \
                        '(-c --config)'{-c+,--config=}'[inline config bytes]:config:' \
                        '(-f --file)'{-f+,--file=}'[config file path]:config file:_files' \
                        '--output=[write agentgateway subprocess stdout/stderr to file (/dev/null silences)]:output file:_files' \
                        '*::command and args:_command_names -e' && ret=0
                    ;;
                migrate)
                    _arguments \
                        '(-f --file)'{-f+,--file=}'[config file path (REQUIRED)]:config file:_files' && ret=0
                    ;;
                help)
                    ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_agentgateway "$@"
