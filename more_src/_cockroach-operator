#compdef cockroach-operator
# _cockroach-operator — CockroachDB Kubernetes operator (reconciles CrdbCluster CRs into StatefulSets + cockroach init Jobs)
# upstream: https://github.com/cockroachdb/cockroach-operator
# Flags from cmd/cockroach-operator/main.go on tip.

_cockroach-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-addr=[metric endpoint bind address]:addr:' \
        '--feature-gates=[csv of feature gates (e.g. RunAsNonRoot=false)]:gates:' \
        '--leader-election-id=[ID used for leader election]:id:' \
        '--enable-leader-election[enable leader election]' \
        '--skip-webhook-config[skip webhook configuration]' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_cockroach-operator "$@"
