#compdef calc
# Documentation: https://github.com/lcn2/calc
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# calc: arbitrary precision calculator (lcn2/calc)

_arguments -s -S \
  '-c[continue processing despite scan/parse errors]' \
  '-C[enable execution of custom builtin functions]' \
  '-d[disable opening title and resource debug messages]' \
  '-D+[set initial debug configuration values]:cfg:' \
  '-e[ignore environment variables on startup]' \
  '-f+[process file in shell script mode]:file:_files' \
  '-h[display help message]' \
  '-i[drop into interactive mode after command execution]' \
  '-m+[set permission mode (0-7)]:mode:(0 1 2 3 4 5 6 7)' \
  '-O[use legacy configuration defaults]' \
  '-p[enable pipe processing (no prompts, no header)]' \
  '-q[skip loading startup scripts]' \
  '-s[make command arguments available as strings]' \
  '-u[disable buffering of stdin/stdout]' \
  '-v[print version number and exit]' \
  '*:expression:'
