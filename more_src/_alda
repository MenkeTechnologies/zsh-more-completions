#compdef alda alda-player

# alda-lang/alda client/cmd/root.go

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*'{-v+,--verbosity=}'[log verbosity 0-3]:level:(0 1 2 3)' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd)
    local -a cmds=(
      doctor export format import instruments parse
      play ps repl shutdown stop telemetry update version
    )
    _describe -t commands 'alda command' cmds && ret=0
    ;;
  (rest)
    _arguments '*:args: _default' && ret=0
    ;;
esac

return ret
