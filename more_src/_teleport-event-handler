#compdef teleport-event-handler
# Documentation: https://github.com/gravitational/teleport-plugins/blob/master/event-handler/README.md
# Reference accessed: 2026-05-21
# Verified: upstream teleport-plugins/event-handler README.
# Removed from prior file: --namespace (not documented for event-handler;
# it's a tsh/tctl flag), --cursor-file (real flag is --cursor).
# Added: --teleport-refresh-enabled, --teleport-refresh-interval, --dry-run,
# --exit-on-last-event, --skip-session-types, --timeout, --cursor.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'configure:write a config file template'
  'start:start the event handler'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[enable debug logging]' \
  '-c+[config file]:file:_files' \
  '--config=[TOML configuration file]:file:_files' \
  '--teleport-addr=[Teleport host and port]:host:_hosts' \
  '--teleport-identity=[identity file]:file:_files' \
  '--teleport-ca=[Teleport TLS CA file]:file:_files' \
  '--teleport-cert=[Teleport TLS certificate]:file:_files' \
  '--teleport-key=[Teleport TLS key]:file:_files' \
  '--teleport-refresh-enabled[enable identity file reloading]' \
  '--teleport-refresh-interval=[identity reload frequency]:duration:' \
  '--fluentd-url=[Fluentd URL]:url:' \
  '--fluentd-session-url=[Fluentd session URL]:url:' \
  '--fluentd-ca=[Fluentd CA]:file:_files' \
  '--fluentd-cert=[Fluentd cert]:file:_files' \
  '--fluentd-key=[Fluentd key]:file:_files' \
  '--storage=[storage directory for state]:dir:_files -/' \
  '--types=[event types to forward (csv)]:types:' \
  '--skip-event-types=[event types to exclude]:types:' \
  '--skip-session-types=[session event types to exclude]:types:' \
  '--start-time=[minimum event time (RFC3339)]:RFC3339:' \
  '--cursor=[start cursor value]:cursor:' \
  '--batch=[event fetch batch size]:n:' \
  '--timeout=[polling timeout]:duration:' \
  '--dry-run[simulate export without connecting to Fluentd]' \
  '--exit-on-last-event[terminate after processing final event]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'teleport-event-handler command' commands && ret=0 ;;
esac
return ret
