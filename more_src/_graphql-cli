#compdef graphql

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-p --project)'{-p,--project}'=[project name]:project:' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'init:initialize a GraphQL config'
      'codegen:generate code from schema'
      'coverage:check schema coverage'
      'diff:compare schemas'
      'docs:serve schema docs'
      'get-schema:download a schema'
      'inspect:inspect a schema'
      'lint:lint a schema'
      'serve:serve a mock API'
      'similar:find similar queries'
      'validate:validate operations'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (init)
        _arguments '1:directory:_files -/' && ret=0
        ;;
      (codegen)
        _arguments \
          '(-c --config)'{-c,--config}'=[codegen config file]:file:_files' \
          '(-w --watch)'{-w,--watch}'[watch for changes]' \
          '--silent[suppress output]' && ret=0
        ;;
      (diff)
        _arguments \
          '1:old schema:_files' \
          '2:new schema:_files' && ret=0
        ;;
      (get-schema)
        _arguments \
          '(-e --endpoint)'{-e,--endpoint}'=[GraphQL endpoint]:url:' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '--header=[HTTP header]:header:' \
          '--json[output as JSON]' && ret=0
        ;;
      (validate)
        _arguments \
          '--schema=[schema file]:file:_files -g "*.graphql"' \
          '--documents=[document files]:files:_files -g "*.graphql"' && ret=0
        ;;
      (serve)
        _arguments \
          '(-p --port)'{-p,--port}'=[port]:port:' \
          '--hostname=[hostname]:host:' && ret=0
        ;;
    esac
    ;;
esac

return ret
