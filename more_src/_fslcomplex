#compdef fslcomplex
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/utilities/fslutils.html
# FSL: split or construct 3D/4D complex image files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-realabs[output absolute value from complex input]' \
  '-realphase[output phase from complex input]' \
  '-realpolar[output absolute value and phase from complex input]' \
  '-realcartesian[output real and imaginary parts from complex input]' \
  '-complex[construct complex from real and imaginary input]' \
  '-complexpolar[construct complex from absolute and phase input]' \
  '-complexsplit[split complex input into separate files]' \
  '-complexmerge[merge two complex inputs]' \
  '-copyonly[copy complex input to output]' \
  '*:image:_files' && ret=0

return ret
