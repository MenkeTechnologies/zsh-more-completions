#compdef terminator
# _terminator-bin — Terminator GNOME tiling terminal (Chris Jones, Python); pre-Tilix tiling terminal still in wide use
# upstream: https://github.com/gnome-terminator/terminator

_terminator-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-b --borderless)'{-b,--borderless}'[no border]' \
        '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen]' \
        '(-H --hidden)'{-H,--hidden}'[start hidden]' \
        '(-m --maximise)'{-m,--maximise}'[maximised]' \
        '(-T --title)'{-T,--title}'+[title]:title:' \
        '(-c --command)'{-c,--command}'+[command]:cmd:_command_names -e' \
        '(-x --execute)'{-x,--execute}'+[execute]:args:' \
        '(-l --layout)'{-l,--layout}'+[layout]:layout:' \
        '(-p --profile)'{-p,--profile}'+[profile]:profile:' \
        '(-r --role)'{-r,--role}'+[wm role]:role:' \
        '(-w --working-directory)'{-w,--working-directory}'+[cwd]:dir:_files -/' \
        '(-u --no-dbus)'{-u,--no-dbus}'[do not register on dbus]' \
        '(-i --icon)'{-i,--icon}'+[icon]:icon:' \
        '(-g --config)'{-g,--config}'+[config file]:file:_files' \
        '(-e --no-execute-bash)'{-e,--no-execute-bash}'[disable bash]' \
        '--classname+[wm class]:class:' \
        '--geometry+[geometry]:geom:' \
        '--unhide[unhide hidden window]' \
        '--new-tab[new tab]' \
        '(-s --select)'{-s,--select}'+[select group]:group:' \
        '(-G --gnome)'{-G,--gnome}'[use GNOME color scheme]'
}

_terminator-bin "$@"
