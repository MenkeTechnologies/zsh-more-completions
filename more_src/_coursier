#compdef coursier cs
# Documentation: https://get-coursier.io/docs/cli-overview
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# coursier (cs) - Scala application and artifact manager.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'bootstrap:create a standalone launcher'
      'channel:manage application channels'
      'complete-dep:dependency completion helper'
      'fetch:download artifacts'
      'install:install applications'
      'java:manage Java installations'
      'java-home:print Java home directory'
      'launch:run an application'
      'list:list installed applications'
      'resolve:list transitive dependencies'
      'search:search for applications by name'
      'setup:set up a Scala development environment'
      'uninstall:uninstall applications'
      'update:update applications'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      fetch|resolve|launch)
        _arguments -s -S \
          '(-r --repository)'{-r,--repository}'[add repository]:repository' \
          '--no-default[do not add default repositories]' \
          '--sbt-plugin-hack[enable sbt plugin hack]' \
          '--cache=[cache directory]:directory:_directories' \
          '--mode=[dependency resolution mode]:mode:(offline update-changing update)' \
          '(- *)'{-h,--help}'[show help]' \
          '*:dependency' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[force install]' \
          '--dir=[installation directory]:directory:_directories' \
          '--channel=[additional channel]:channel' \
          '(- *)'{-h,--help}'[show help]' \
          '*:application' && ret=0
        ;;
      java)
        _arguments -s -S \
          '--jvm=[JVM version]:version' \
          '--available[list available JVMs]' \
          '--installed[list installed JVMs]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
