#compdef qrstat
# Grid Engine: show the status of advance reservations

local ret=1

_arguments -s \
  '-help[print a listing of all options]' \
  '-ar+[print information about the given advance reservation ids]:ar ids' \
  '-explain[display the reason for the error state of an AR]' \
  '-u+[show only ARs created by the given users]:users' \
  '-xml[produce XML output]' && ret=0

return ret
