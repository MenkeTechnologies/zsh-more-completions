#compdef modelscope
# Documentation: https://github.com/modelscope/modelscope/blob/master/docs/source/command.md
# ModelScope CLI: download and manage models and datasets from ModelScope Hub

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model=[model id to download]:model:' \
  '--dataset=[dataset id to download]:dataset:' \
  '--revision=[model or dataset version]:revision:' \
  '--cache_dir=[directory to store downloaded files]:dir:_files -/' \
  '--local_dir=[custom local destination directory]:dir:_files -/' \
  '*--include=[glob patterns of files to download]:pattern:' \
  '*--exclude=[glob patterns of files to skip]:pattern:' \
  '--token=[access token for ModelScope]:token:' \
  '1:command:((
    download\:"download a model or dataset"
    login\:"authenticate with an access token"
    pipeline\:"run an inference pipeline"
    modelcard\:"manage model cards"
    model\:"manage models"
    server\:"start a local server"
    plugin\:"manage plugins"
  ))' \
  '*::arg:->args' && ret=0

return ret
