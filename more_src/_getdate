#compdef getdate
# Documentation: http://tdc-www.harvard.edu/software/wcstools/
# getdate: convert a date and time between various formats (WCSTools)

local ret=1

_arguments -s -S \
  '-n[number of decimal places in seconds, epoch, or JD]:number' \
  '-v[verbose]' \
  '1:conversion (oldtype2newtype):(jd2ep ep2jd jd2fd fd2jd ofd2fd fd2ofd dt2fd fd2dt ep2epb ep2epj ts2fd fd2ts)' \
  '*:date value:_message date' && ret=0

return ret
