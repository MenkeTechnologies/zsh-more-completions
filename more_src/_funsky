#compdef funsky
# Documentation: https://linux.die.net/man/1/funsky
# funsky - convert between image and sky coordinates in a FITS file

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-d[always use integer tlmin conversion (as ds9 does)]' \
  '-r[convert x,y to RA,Dec (default: RA,Dec to x,y)]' \
  '-o[include offset from the nominal target position (arcsec)]' \
  '-v[display input values also]' \
  '-T[output display in rdb format]' \
  '*:fits file:_files' && ret=0

return ret
