#compdef compliance-checker cchecker.py
# Documentation: https://github.com/ioos/compliance-checker/blob/master/README.md
# IOOS compliance checker for NetCDF/OPeNDAP datasets (CF, ACDD, IOOS)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[display compliance checker version]' \
  '*'{-t,--test}'=[select checks to perform (e.g. cf:1.6, acdd)]:test' \
  '(-c --criteria)'{-c,--criteria}'=[criteria for checks]:criteria:(lenient normal strict)' \
  '*'{-f,--format}'=[output format]:format:(text html json json_new)' \
  '*'{-o,--output}'=[output filename (- for stdout)]:output:_files' \
  '*'{-s,--skip-checks}'=[skip checks (<check_name> or <check_name>:<level>)]:check' \
  '*'{-i,--include-checks}'=[include only these checks]:check' \
  '(-D --describe-checks)'{-D,--describe-checks}'[describe checks for checkers given by -t]' \
  '(-l --list-tests)'{-l,--list-tests}'[list available tests]' \
  '*'{-v,--verbose}'[increase output (up to three times)]' \
  '(-d --download-standard-names)'{-d,--download-standard-names}'=[download a CF standard name table version]:version' \
  '*'{-O,--option}'=[additional checker option]:option' \
  '*:dataset:_files' && ret=0

return ret
