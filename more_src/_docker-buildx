#compdef docker-buildx

# Zsh completion for docker-buildx - Docker CLI plugin for extended build

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'bake:build from a file'
  'build:start a build'
  'create:create a new builder instance'
  'debug:start debugger'
  'du:disk usage'
  'imagetools:commands to work on images in registry'
  'inspect:inspect current builder instance'
  'ls:list builder instances'
  'prune:remove build cache'
  'rm:remove a builder instance'
  'stop:stop builder instance'
  'use:set the current builder instance'
  'version:show buildx version information'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'docker-buildx command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build)
        _arguments \
          '--add-host[add a custom host-to-IP mapping]:host\:ip' \
          '--allow[allow extra privileged entitlement]:entitlement' \
          '--attest[attestation parameters]:type=value' \
          '--build-arg[set build-time variables]:var=value' \
          '--build-context[additional build contexts]:name=value' \
          '--cache-from[external cache sources]:source' \
          '--cache-to[cache export destinations]:destination' \
          '(-f --file)'{-f,--file}'[name of Dockerfile]:Dockerfile:_files' \
          '--iidfile[write image ID to file]:file:_files' \
          '--label[set metadata for image]:label=value' \
          '--load[shorthand for --output=type=docker]' \
          '--metadata-file[write build result metadata to file]:file:_files' \
          '--network[set networking mode for RUN]:mode:(default host none)' \
          '--no-cache[do not use cache]' \
          '--no-cache-filter[do not cache specified stages]:stages' \
          '(-o --output)'{-o,--output}'[output destination]:output' \
          '--platform[set target platform]:platform' \
          '--progress[set type of progress output]:type:(auto plain tty)' \
          '--provenance[shorthand for --attest=type=provenance]:provenance' \
          '--pull[always attempt to pull newer image]' \
          '--push[shorthand for --output=type=registry]' \
          '--sbom[shorthand for --attest=type=sbom]:sbom' \
          '--secret[secret to expose to build]:secret' \
          '--shm-size[size of /dev/shm]:size' \
          '--ssh[SSH agent socket or keys]:ssh' \
          '(-t --tag)'{-t,--tag}'[name and optionally a tag]:name\:tag' \
          '--target[set the target build stage]:stage' \
          '--ulimit[ulimit options]:ulimit' \
          '*:context:_files -/' && ret=0
        ;;
      create)
        _arguments \
          '--append[append a node to builder instead of changing it]' \
          '--bootstrap[boot builder after creation]' \
          '--buildkitd-flags[flags for buildkitd daemon]:flags' \
          '--config[buildkitd config file]:file:_files' \
          '--driver[driver to use]:driver:(docker docker-container kubernetes remote)' \
          '--driver-opt[driver options]:options' \
          '--leave[remove a node from builder instead of changing it]' \
          '--name[builder instance name]:name' \
          '--node[create/modify node with given name]:name' \
          '--platform[fixed platforms for current node]:platforms' \
          '--use[set current builder instance]' && ret=0
        ;;
      inspect)
        _arguments \
          '--bootstrap[ensure builder has booted before inspecting]' \
          '1:builder name' && ret=0
        ;;
      ls)
        _arguments && ret=0
        ;;
      rm)
        _arguments \
          '--all-inactive[remove all inactive builders]' \
          '(-f --force)'{-f,--force}'[do not prompt for confirmation]' \
          '--keep-daemon[keep the buildkitd daemon running]' \
          '--keep-state[keep BuildKit state]' \
          '*:builder name' && ret=0
        ;;
      prune)
        _arguments \
          '(-a --all)'{-a,--all}'[include internal/frontend images]' \
          '(-f --force)'{-f,--force}'[do not prompt for confirmation]' \
          '--filter[provide filter values]:filter' \
          '--keep-storage[amount of disk space to keep]:bytes' \
          '--verbose[provide a more verbose output]' && ret=0
        ;;
      use)
        _arguments \
          '--default[set builder as default]' \
          '--global[builder persists context changes]' \
          '1:builder name' && ret=0
        ;;
    esac
    ;;
esac

return ret
