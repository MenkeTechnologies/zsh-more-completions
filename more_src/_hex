#compdef hex

# Zsh completion for hex (Elixir/Erlang package manager CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'audit:audit dependencies for known vulnerabilities'
      'build:build package'
      'config:read or update Hex config'
      'docs:fetch or open package documentation'
      'info:print Hex information'
      'organization:manage organizations'
      'outdated:show outdated packages'
      'owner:manage package ownership'
      'package:display package information'
      'publish:publish package or docs'
      'registry:manage Hex registries'
      'repo:manage Hex repositories'
      'retire:retire a package version'
      'search:search for packages'
      'sponsor:show sponsor information'
      'user:manage Hex user account'
    )
    _describe -t commands 'hex command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (docs)
        _arguments \
          '1:subcommand:(fetch offline online)' \
          '2:package' && ret=0
        ;;
      (info)
        _arguments '1:package' && ret=0
        ;;
      (search)
        _arguments '1:query' && ret=0
        ;;
      (publish)
        _arguments \
          '--organization[organization]:org' \
          '--replace[replace existing version]' \
          '--revert[revert version]:version' \
          '--yes[skip confirmation]' && ret=0
        ;;
      (outdated)
        _arguments \
          '--all[show all dependencies]' \
          '--pre[include pre-release versions]' && ret=0
        ;;
      (owner)
        _arguments '1:subcommand:(add list remove transfer)' && ret=0
        ;;
      (config)
        _arguments '1:key' '2:value' && ret=0
        ;;
      (user)
        _arguments '1:subcommand:(auth deauth key passphrase register reset whoami)' && ret=0
        ;;
    esac
    ;;
esac

return ret
