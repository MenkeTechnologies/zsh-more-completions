#compdef firehol fireqos firehol-ipset firehol-update-ipsets fireqos-show
# _firehol — Costa Tsaousis FireHOL Linux firewall framework for stateful iptables/netfilter with simple config syntax (firehol team, Bash); custom argparse
# upstream: https://github.com/firehol/firehol

_firehol() {
    local -a sub=(
        'start:start the firewall'
        'stop:flush firewall and accept all'
        'restart:restart firewall'
        'try:start with 30 second rollback'
        'condrestart:restart only if running'
        'reload:reload firewall'
        'status:show firewall status'
        'panic:emergency lockdown all traffic'
        'save:save firewall to file'
        'debug:show generated iptables'
        'explain:explain commands'
        'wizard:create config wizard'
        'check-config:syntax check config'
        'show:show current rules'
        'iptables:proxy iptables commands'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--save[save firewall to file]' \
        '--save-binary[save firewall in binary format]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'firehol subcommand' sub ;;
        args)
            case $words[1] in
                try) _arguments \
                    '--timeout=+[seconds]:n:' \
                    '*:config:_files -g "firehol.conf *.conf"' ;;
                save) _arguments '*:file:_files' ;;
                start|restart|reload) _arguments '*:config:_files -g "firehol.conf *.conf"' ;;
            esac
            ;;
    esac
}

_firehol "$@"
