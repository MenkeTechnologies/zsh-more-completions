#compdef installboot
# Documentation: man installboot(8)
# Source: netbsd/src usr.sbin/installboot — install disk bootstrap software (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B+[secondary bootstrap block offset]:s2bno:_default' \
    '-b+[primary bootstrap block number]:s1bno:_default' \
    '(-e)-c[clear existing bootstrap]' \
    '(-c)-e[edit options of existing bootstrap]' \
    '-f[force operation, ignore some errors]' \
    '-m+[target machine type]:machine:_default' \
    '-n[do not write to filesystem]' \
    '-o+[machine-specific options (comma-separated)]:options:_default' \
    '-t+[filesystem type]:fstype:_default' \
    '-u+[U-Boot search paths (colon-separated)]:paths:_files' \
    '-v[verbose operation]' \
    '1:filesystem or image:_files' \
    '2::primary boot block:_files' \
    '3::secondary boot block:_files' \
    && ret=0

return ret
