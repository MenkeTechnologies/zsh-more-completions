#compdef grr_server
# Documentation: https://grr-doc.readthedocs.io/en/latest/installing-and-running-grr/from-source.html
# GRR Rapid Response combined server component runner

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '--component=[server component to run]:component:(admin_ui frontend worker fleetspeak_server)' \
  '--verbose[turn on verbose logging]' \
  '--debug[break in debugger on unhandled exception]' \
  '--config=[primary configuration file]:file:_files' \
  '--secondary_configs=[secondary config files]:files:_files' \
  '--config_help[print config help]' \
  '--context=[config contexts]:context' \
  '(-p --parameter)'{-p,--parameter}'=[global config override]:param' && ret=0

return ret
