#compdef smooth
# Documentation: https://apbs.readthedocs.io/en/latest/using/tools.html
# Convolve OpenDX grid data with a filter

local ret=1

_arguments -s \
  '--format=[input/output data format]:format:(dx dxbin)' \
  '--input=[input mesh data file]:file:_files' \
  '--output=[output mesh data file]:file:_files' \
  '--filter=[convolution filter]:filter:(gaussian)' \
  '--stddev=[Gaussian standard deviation in A]:stddev' \
  '--bandwidth=[Gaussian bandwidth in units of stddev]:bandwidth' && ret=0

return ret
