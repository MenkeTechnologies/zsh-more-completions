#compdef xtool
# _xtool — Kabir Oberai xtool cross-platform Xcode replacement to build/sign/install iOS apps from Linux/Windows/macOS (xtool-org team, Swift); ArgumentParser
# upstream: https://github.com/xtool-org/xtool

_xtool() {
    local -a sub=(
        'new:create a new xtool project'
        'setup:configure signing'
        'sdk:manage SDK installs'
        'build:build the project'
        'dev:build run install in one step'
        'install:install the built app'
        'devenv:configure developer env'
        'ds:device sync'
        'wrapper:wrap an existing app'
        'plist:plist subcommands'
        'sign:sign an ipa'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--print-help-hidden[print hidden help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xtool subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '--template=+[template]:t:(default ios watchos tvos macos)' \
                    '*:name:' ;;
                build|dev) _arguments \
                    '--configuration=+[config]:c:(debug release)' \
                    '-c+[config]:c:(debug release)' \
                    '--scheme=+[scheme]:str:' \
                    '--destination=+[destination]:str:' \
                    '--arch=+[arch]:a:(arm64 x86_64)' \
                    '--sdk=+[sdk]:str:' ;;
                sdk) _arguments '1:sdk cmd:(install remove list)' '*:sdk:' ;;
                install) _arguments '*:ipa:_files -g "*.ipa"' ;;
                sign) _arguments \
                    '--identity=+[identity]:str:' \
                    '--provisioning-profile=+[profile]:file:_files' \
                    '*:ipa:_files -g "*.ipa"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_xtool "$@"
