#compdef rpmdev-checksig
# Documentation: https://github.com/rsrchboy/rpmdevtools/blob/master/rpmdev-checksig
# Reference accessed: 2026-05-16
# Verified: upstream rsrchboy/rpmdevtools. Wrapper around `rpm -K`;
# accepts positional RPM files only, no CLI flags.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# rpmdev-checksig: filter rpm -K output for unsigned/badly-signed packages
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:rpm file:_files -g "*.rpm(-.)"' && ret=0
return ret
