#compdef batbinevt
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/batbinevt.html
# Bin Swift BAT event or DPH data into light curves, spectra or images

local ret=1

_arguments -s -S \
  'infile=[input BAT event or DPH data, list or @file]:infile:_files' \
  'outfile=[output light curve or spectrum file]:outfile:_files' \
  'outtype=[output format]:outtype:(LC PHA PHA1 PHA2 DPH DPI DPITAB)' \
  'timedel=[time bin size in seconds]:timedel:' \
  'timebinalg=[time binning algorithm]:timebinalg:(uniform snr highsnr gti infile matchlc)' \
  'energybins=[energy bin ranges, file, INFILE, FILEBINS or CALDB]:energybins:' \
  'gtifile=[good time interval or time bin file]:gtifile:_files' \
  'ecol=[energy column name]:ecol:' \
  'weighted=[apply mask weighting]:weighted:(yes no INDEF)' \
  'outunits=[output units]:outunits:(RATE COUNTS INDEF)' \
  'timepixr=[time bin reference point]:timepixr:' \
  'maskwt=[mask weight map file]:maskwt:_files' \
  'tstart=[start time in MET]:tstart:' \
  'tstop=[stop time in MET]:tstop:' \
  'snrthresh=[signal-to-noise threshold]:snrthresh:' \
  'detmask=[detector quality map file]:detmask:_files' \
  'tcol=[TIME column name]:tcol:' \
  'countscol=[counts column name]:countscol:' \
  'xcol=[X coordinate column]:xcol:' \
  'ycol=[Y coordinate column]:ycol:' \
  'maskwtcol=[mask weight column name]:maskwtcol:' \
  'ebinquant=[energy bin quantization in keV]:ebinquant:' \
  'delzeroes=[delete zero-flux time bins]:delzeroes:(yes no)' \
  'minfracexp=[minimum fractional exposure]:minfracexp:' \
  'buffersize=[internal event buffer size]:buffersize:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
