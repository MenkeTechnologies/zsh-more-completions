#compdef tekton-cli tkn
# Documentation: https://github.com/tektoncd/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# tekton CLI (tkn): manage Tekton Pipelines / Triggers / Hub
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'bundle:manage tekton bundles'
  'chain:manage tekton chains'
  'clustertask:manage cluster tasks'
  'clustertriggerbinding:manage cluster trigger bindings'
  'completion:emit shell completion'
  'customrun:manage CustomRuns'
  'eventlistener:manage event listeners'
  'hub:operate on Tekton Hub'
  'pipeline:manage pipelines'
  'pipelinerun:manage pipeline runs'
  'plugin:manage tkn plugins'
  'resource:manage pipeline resources'
  'task:manage tasks'
  'taskrun:manage task runs'
  'triggerbinding:manage trigger bindings'
  'triggertemplate:manage trigger templates'
  'version:print version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '-c[k8s context]:context:' \
  '--context=[k8s context]:context:' \
  '-n[k8s namespace]:ns:' \
  '--namespace=[k8s namespace]:ns:' \
  '--cluster=[k8s cluster name]:cluster:' \
  '--nocolour[disable color output]' \
  '--insecure-skip-tls-verify[skip TLS verify]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'tkn command' commands && ret=0 ;;
esac
return ret
