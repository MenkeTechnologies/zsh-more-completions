#compdef braid
# Documentation: https://github.com/cristibalan/braid
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# braid - simple git submodule alternative (vendor mirrors of external repos)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:vendor an external repository'
  'update:bring in new changes from remote repos'
  'diff:show local modifications to vendored content'
  'push:send changes back to source repositories'
  'remove:remove a mirror'
  'setup:setup a mirror from .braids.json'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'braid command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add|update)
        _arguments \
          '--path=[subdirectory to track]:path:' \
          '--branch=[track a branch]:branch:' \
          '--tag=[lock to a tag]:tag:' \
          '--revision=[lock to a commit]:rev:' && ret=0 ;;
      (push)
        _arguments \
          '--branch=[push to a custom branch]:branch:' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
