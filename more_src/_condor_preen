#compdef condor_preen
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_preen.html
# remove extraneous files from HTCondor directories

local ret=1

_arguments -s -S \
  '-mail[send mail to the PREEN_ADMIN user instead of writing to stdout]' \
  '-remove[remove the offending files and directories]' \
  '-verbose[list all files and directories considered for deletion]' \
  '-debug[print extra debugging information to stderr]' \
  '-log[write extra debugging information to the given file]:filename:_files' && ret=0

return ret
