#compdef multipathd multipath
# _multipathd — Linux device-mapper multipath daemon + cli (Christophe Varoqui); manage multipath SCSI/NVMe block devices
# upstream: https://github.com/opensvc/multipath-tools

_multipathd() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'+[verbosity]:n:' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-d[debug]' \
        '-B[no bindings table changes]' \
        '-k[interactive shell]' \
        '-K[interactive shell without daemon]' \
        '-n[do not autodiscover devices]' \
        '-w[wait for device removal]' \
        '-s[no syslog logging]' \
        '-q[quiet]' \
        '-c+[check]:str:' \
        '-T+[topology check]:str:' \
        '-r[force reload]' \
        '-R+[max retries]:n:' \
        '-a+[add path]:dev:_files' \
        '-A[add new wwids]' \
        '-i+[ignore wwids]:str:' \
        '-l+[show topology level]:level:(short long)' \
        '-ll[show full topology]' \
        '-f[force unload then rescan]' \
        '-F[force unload]' \
        '-e+[edit feature]:str:' \
        '-t+[show config table]:section:' \
        '-w[wait for daemon]' \
        '-W[print waiters]' \
        '*:device:_files'
}

_multipathd "$@"
