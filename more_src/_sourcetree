#compdef sourcetree stree
# _sourcetree — Atlassian Sourcetree macOS/Windows Git/Hg GUI CLI alias (Atlassian, Objective-C/C#); custom argparse
# upstream: https://www.sourcetreeapp.com

_sourcetree() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--new[new instance]' \
        '-n[new instance]' \
        '--repo=+[repository path]:dir:_files -/' \
        '-r+[repository path]:dir:_files -/' \
        '--open=+[open path]:dir:_files -/' \
        '-o+[open path]:dir:_files -/' \
        '--clone=+[clone URL]:url:_urls' \
        '-c+[clone URL]:url:_urls' \
        '--debug[debug mode]' \
        '*:path:_files -/'
}

_sourcetree "$@"
