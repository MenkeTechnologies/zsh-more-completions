#compdef qjackctl
# _qjackctl — Qt frontend for JACK audio + control (rncbc/qjackctl)
# upstream: https://github.com/rncbc/qjackctl
# Flags from src/qjackctlSetup.cpp (QCommandLineParser).

_qjackctl() {
    _arguments \
        '(- *)'{-h,--help,-?}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-s --start)'{-s,--start}'[start the JACK audio server immediately]' \
        '(-p --preset)'{-p+,--preset=}'[default settings preset name]:preset:' \
        '(-a --active-patchbay)'{-a+,--active-patchbay=}'[active patchbay definition file]:file:_files -g "*.xml"' \
        '(-n --server-name)'{-n+,--server-name=}'[default JACK server name]:name:'
}

_qjackctl "$@"
