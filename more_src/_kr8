#compdef kr8
# Documentation: https://man.archlinux.org/search?q=kr8
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '-c=[path to cluster config file / directory]:path:_files' \
  '-d=[output directory]:directory:_directories' \
  '-x[clear output dir before render]' \
  '-f[force overwrite dirty files]' \
  '*:component or args: _default'
