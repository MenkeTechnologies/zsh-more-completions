#compdef kr8
# Documentation: https://github.com/ice-bergtech/kr8
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Rewritten: prior file
# invented -c/-d/-x/-f scalar flags. kr8 is a cobra CLI with
# subcommands (generate/format/completion/get/init/jsonnet/render/
# version) and persistent flags shown in `kr8 --help`.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'completion:generate shell autocompletion scripts'
  'format:format jsonnet files in a directory'
  'generate:generate components'
  'get:display one or many kr8+ resources'
  'init:initialize kr8+ config repos, components and clusters'
  'jsonnet:jsonnet utilities'
  'render:render files'
  'version:return the current version of kr8+'
  'help:help about any command'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[help for kr8]' \
  '(-B --base)'{-B+,--base=}'[kr8+ root configuration directory]:dir:_files -/' \
  '(-D --clusterdir)'{-D+,--clusterdir=}'[kr8+ cluster directory]:dir:_files -/' \
  '--color[enable colorized output]' \
  '(-d --componentdir)'{-d+,--componentdir=}'[kr8+ component directory]:dir:_files -/' \
  '--config=[a single config file with kr8+ configuration]:file:_files' \
  '--debug[log additional information]' \
  '*--ext-str-file=[set jsonnet extVars from file contents (key=file)]:keyfile:' \
  '(-J --jpath)'{-J+,--jpath=}'[additional jsonnet library directories]:dir:_files -/' \
  '(-L --loglevel)'{-L+,--loglevel=}'[set zerolog log level]:level:' \
  '--parallel=[parallelism level]:n:' \
  '--profiledir=[directory to write pprof profile data to]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kr8 command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (completion) _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
