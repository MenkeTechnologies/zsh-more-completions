#compdef vite-node

# Zsh completion for vite-node - run TypeScript/ESM with Vite

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-r+[root directory]:directory:_directories' \
  '--root=[root directory]:directory:_directories' \
  '-c+[config file]:config:_files -g "vite.config.*"' \
  '--config=[config file]:config:_files -g "vite.config.*"' \
  '-m+[mode]:mode:(development production)' \
  '--mode=[mode]:mode:(development production)' \
  '-w[watch mode]' \
  '--watch[watch mode]' \
  '--script[run as script]' \
  '--options-inline=[inline vite options]:options' \
  '*:file:_files -g "*.{ts,mts,cts,tsx,js,mjs,cjs,jsx}"' && ret=0

return ret
