#compdef crc

# Zsh completion for crc (CodeReady Containers / Red Hat OpenShift Local)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'start:start the OpenShift cluster'
      'stop:stop the OpenShift cluster'
      'delete:delete the OpenShift cluster'
      'status:display cluster status'
      'console:open the OpenShift web console'
      'setup:set up prerequisites'
      'cleanup:undo changes from setup'
      'config:manage configuration'
      'ip:get IP address of the cluster'
      'oc-env:display oc command environment'
      'podman-env:display podman command environment'
      'version:print version'
      'completion:generate shell completions'
    )
    _describe -t commands 'crc command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (start)
        _arguments \
          '(-b --bundle)'{-b,--bundle}'[bundle path]:bundle:_files' \
          '(-p --pull-secret-file)'{-p,--pull-secret-file}'[pull secret file]:file:_files' \
          '(-c --cpus)'{-c,--cpus}'[number of CPUs]:cpus' \
          '(-m --memory)'{-m,--memory}'[memory in MiB]:memory' \
          '(-d --disk-size)'{-d,--disk-size}'[disk size in GiB]:disk' \
          '-n[nameserver]:nameserver' && ret=0
        ;;
      (config)
        local -a subcmds=(
          'get:get config value'
          'set:set config value'
          'unset:unset config value'
          'view:view all config values'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (console)
        _arguments \
          '--credentials[show credentials]' \
          '--url[show URL only]' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash fish powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
