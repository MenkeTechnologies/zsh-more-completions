#compdef viper

# Viper CLI - configuration management tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:config file:_files' \
  '*:file:_files' && ret=0

return ret
