#compdef syslinux-common
# Documentation: https://man.archlinux.org/search?q=syslinux-common
# Reference accessed: 2026-05-16

# syslinux-common: shared modules/data for syslinux bootloader
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::syslinux-common args:_files' && ret=0
return ret
