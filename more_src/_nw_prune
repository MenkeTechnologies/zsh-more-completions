#compdef nw_prune
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: remove tree branches by label.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-f[read labels from a file]' \
  '-v[reverse: keep nodes whose labels are NOT listed]' \
  '*:newick file:_files' && ret=0

return ret
