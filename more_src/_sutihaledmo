#compdef sutihaledmo
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/dip_moveout/sutihaledmo.c
# TI Hale Dip MoveOut (based on Hale's PhD thesis)

local ret=1

_arguments -s -S \
  'nxmax=[maximum number of midpoints in common offset gather]:nxmax' \
  'option=[1 Hale, 2 Bleistein TA, 3 Bleistein cos*cos, 4 Zhang, 5 Tsvankin, 6 Tsvankin VTI]:option:(1 2 3 4 5 6)' \
  'dx=[midpoint sampling interval between traces]:dx' \
  'v=[velocity (m/s)]:v' \
  'h=[source-receiver half-offset (m)]:h' \
  'ntpad=[number of time samples to pad]:ntpad' \
  'nxpad=[number of midpoints to pad]:nxpad' \
  'file=[name of file with vnmo as a function of p]:file:_files' \
  'e=[Thomsen epsilon]:e' \
  'd=[Thomsen delta]:d' \
  '*:file:_files' && ret=0

return ret
