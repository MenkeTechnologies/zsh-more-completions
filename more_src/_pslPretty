#compdef pslPretty
# UCSC kent: convert PSL to human-readable output

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-axt[save in axt-like format]' \
  '-dot=[output a dot every N records]:n:' \
  '-long[don'\''t abbreviate long inserts]' \
  '-check=[output alignment checks to file]:file:_files' \
  ':in psl:_files' \
  ':target list:_files' \
  ':query list:_files' \
  ':pretty out:_files' && ret=0

return ret
