#compdef daemonize

# bmc/daemonize — daemonize.c usage() + x_getopt string ac:u:p:vo:e:E:l:

_arguments -s -S \
  '(-h --help)'{-h,--help}'[usage]' \
  '-a[append stdout/stderr logs instead of truncating]' \
  '-c+[chdir before exec]:directory:_files -/' \
  '-e+[redirect stderr to file]:file:_files' \
  '-E+[set env VAR=val for child]:var=value:' \
  '-o+[redirect stdout to file]:file:_files' \
  '-p+[write PID file]:file:_files' \
  '-u+[drop privileges to user]:user:_users' \
  '-l+[single-instance lockfile]:file:_files' \
  '-v[verbose daemonization]' \
  '1:executable:_command_names -e' \
  '*:arguments:_normal'
