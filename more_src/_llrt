#compdef llrt
# Documentation: https://github.com/awslabs/llrt
# Reference accessed: 2026-05-27
# Verified: upstream llrt/src/main.rs usage() string and start_cli() arg dispatch
# on main branch.

local curcontext="$curcontext" state line ret=1
local -a _llrt_subcommands

_llrt_subcommands=(
  'compile:compile JS to bytecode and compress it with zstd'
  'test:run tests with provided arguments'
)

_arguments -C \
  '(-v --version)'{-v,--version}'[print version information]' \
  '(-h --help)'{-h,--help}'[print help message]' \
  '(-e --eval)'{-e+,--eval=}'[evaluate the provided source code]:source:' \
  '*--import=[load and execute a module before the main script]:file:_files -g "*.(js|mjs|cjs|lrt)"' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _alternative \
      'subcommands:subcommand:(($_llrt_subcommands))' \
      'files:file:_files -g "*.(js|mjs|cjs|lrt)"' && ret=0
    ;;
  args)
    case $line[1] in
      compile)
        _arguments \
          '--executable[create a self-contained executable with the LLRT runtime]' \
          '1:input:_files -g "*.(js|mjs|cjs)"' \
          '2:output:_files -g "*.lrt"' && ret=0
        ;;
      test)
        _arguments \
          '-d+[test directory]:directory:_files -/' \
          '*:test filter:' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
