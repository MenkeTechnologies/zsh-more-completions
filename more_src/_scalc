#compdef scalc
# _scalc — The Document Foundation LibreOffice scalc CLI symlink launching LibreOffice Calc the spreadsheet application opening .ods .xlsx .xls .csv .xlsm files with options for headless server mode startup splash invisible single-document instance window position size convert-to PDF format export (LibreOffice team, C++); getopt
# upstream: https://www.libreoffice.org/

_scalc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--writer[start as Writer]' \
        '--calc[start as Calc]' \
        '--draw[start as Draw]' \
        '--impress[start as Impress]' \
        '--base[start as Base]' \
        '--math[start as Math]' \
        '--global[start as global doc]' \
        '--web[start as html doc]' \
        '--show=+[file]:file:_files' \
        '--view=+[file]:file:_files' \
        '--norestore[no restore]' \
        '--quickstart[quickstart mode]' \
        '--nologo[no logo]' \
        '--nodefault[no default doc]' \
        '--nolockcheck[no lock check]' \
        '--nofirststartwizard[no first start wizard]' \
        '--nocrashreport[no crash report]' \
        '--invisible[no UI window]' \
        '--minimized[start minimized]' \
        '--headless[headless mode]' \
        '--accept=+[connection string]:str:' \
        '--unaccept=+[connection string]:str:' \
        '--language=+[lang]:str:' \
        '--safe-mode[safe mode]' \
        '--convert-to+[output filter]:str:' \
        '--outdir=+[dir]:dir:_files -/' \
        '--print-to-file[print to file]' \
        '--printer-name=+[printer]:str:' \
        '--cat[print plain text to stdout]' \
        '--pt+[port]:n:' \
        '*:spreadsheet:_files -g "*.ods *.xlsx *.xls *.csv *.xlsm *.fods *.sxc"'
}

_scalc "$@"
