#compdef postgrey
# Documentation: https://man.archlinux.org/search?q=postgrey
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --daemonize)'{-d,--daemonize}'[run as daemon]' \
  '(--unix --inet)--unix=+[Unix socket]:file:_files' \
  '(--unix --inet)--inet=+[TCP port]:port:' \
  '--pidfile=+[PID file]:file:_files' \
  '--group=+[run as group]:group:_groups' \
  '--user=+[run as user]:user:_users' \
  '--syslog-facility=+[syslog facility]:fac:(LOG_DAEMON LOG_MAIL LOG_LOCAL0 LOG_LOCAL1 LOG_LOCAL2 LOG_LOCAL3 LOG_LOCAL4 LOG_LOCAL5 LOG_LOCAL6 LOG_LOCAL7)' \
  '--syslog-name=+[syslog ident]:name:' \
  '--dbdir=+[database directory]:dir:_files -/' \
  '--delay=+[greylist delay seconds]:sec:' \
  '--max-age=+[max age days]:days:' \
  '--retry-count=+[retry count]:n:' \
  '--greylist-action=+[greylist action]:action:(DEFER_IF_PERMIT 450 DUNNO)' \
  '--greylist-text=+[greylist response text]:text:' \
  '--auto-whitelist-clients=+[auto-whitelist count]:n:' \
  '--whitelist-clients=+[client whitelist file]:file:_files' \
  '--whitelist-recipients=+[recipient whitelist file]:file:_files' \
  '--privacy[anonymize log]' \
  '--reject-message=[reject text]:msg:' \
  '--listen-queue-size=+[listen queue size]:n:' \
  '--lookup-by-subnet[lookup IPs by subnet]' \
  '--lookup-by-host[lookup IPs by host]' \
  '--hostname=+[my hostname]:host:_hosts' \
  '--x-greylist-header[add X-Greylist header]' && ret=0

return ret
