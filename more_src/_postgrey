#compdef postgrey
# Documentation: https://manpages.debian.org/trixie/postgrey/postgrey.8.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)--version[output version information]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity level]' \
  '(-q --quiet)'{-q,--quiet}'[decrease verbosity level]' \
  '--syslog-facility=[syslog facility]:facility:' \
  '(-u --unix)'{-u,--unix=}'[listen on unix socket PATH]:path:_files' \
  '--socketmode=[unix socket permission]:mode:' \
  '(-i --inet)'{-i,--inet=}'[listen on HOST:PORT]:address:' \
  '(-d --daemonize)'{-d,--daemonize}'[run in the background]' \
  '--pidfile=[put daemon pid into file]:file:_files' \
  '--user=[run as user]:user:_users' \
  '--group=[run as group]:group:_groups' \
  '--dbdir=[put db files in path]:dir:_files -/' \
  '--delay=[greylist for N seconds]:seconds:' \
  '--max-age=[delete entries older than N days]:days:' \
  '--retry-window=[allow N days for first retrial]:days:' \
  '--greylist-action=[action returned to Postfix when greylisted]:action:' \
  '--greylist-text=[response text when mail is greylisted]:text:' \
  '--lookup-by-subnet[strip last N bits from IP addresses]' \
  '--ipv4cidr=[cidr for IPv4 subnet lookup]:n:' \
  '--ipv6cidr=[cidr for IPv6 subnet lookup]:n:' \
  '--lookup-by-host[do not strip bits from IP addresses]' \
  '--privacy[store data using one-way hash functions]' \
  '--hostname=[set the hostname]:host:_hosts' \
  '--exim[exim compatibility: do not reuse socket]' \
  '--whitelist-clients=[client whitelist file]:file:_files' \
  '--whitelist-recipients=[recipient whitelist file]:file:_files' \
  '--auto-whitelist-clients=[whitelist after N successful deliveries]:n:' \
  '--listen-queue-size=[listen queue size]:n:' \
  '--x-greylist-header=[X-Greylist header text]:text:' && ret=0

return ret
