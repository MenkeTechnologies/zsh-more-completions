#compdef librespeed-cli
# Documentation: https://man.archlinux.org/search?q=librespeed-cli
# Reference accessed: 2026-05-16

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-4 --ipv4)'{-4,--ipv4}'[force IPv4]' \
  '(-6 --ipv6)'{-6,--ipv6}'[force IPv6]' \
  '--no-download[skip download]' \
  '--no-upload[skip upload]' \
  '--no-icmp[disable ICMP ping]' \
  '--concurrent=[concurrent requests]:n:' \
  '--bytes[show bytes]' \
  '--mebibytes[1024-based KB]' \
  '--distance=[unit]:unit:(mi km NM)' \
  '--share[share URL]' \
  '--simple[terse output]' \
  '--csv[CSV output]' \
  '--csv-delimiter=[delimiter]:char:' \
  '--csv-header[print headers]' \
  '--json[JSON output]' \
  '--list[list servers]' \
  '*--server=[server id]:id:' \
  '*--exclude=[exclude server]:id:' \
  '--server-json=[remote server list URL]:url:' \
  '--local-json=[local server list]:file:_files' \
  '--source=[source IP]:ip:' \
  '--interface=[bind interface]:iface:_net_interfaces' \
  '--timeout=[HTTP timeout]:seconds:' \
  '--duration=[test duration]:seconds:' \
  '--chunks=[download chunks]:n:' \
  '--upload-size=[upload KiB]:n:' \
  '--secure[HTTPS]' \
  '--ca-cert=[CA cert]:file:_files' \
  '--skip-cert-verify[skip TLS verify]' \
  '--no-pre-allocate[disable upload pre-allocate]' \
  '--telemetry-json=[telemetry config]:file:_files' \
  '--telemetry-level=[level]:level:(disabled basic full debug)' \
  '--telemetry-server=[telemetry URL]:url:' \
  '--telemetry-path=[upload path]:path:' \
  '--telemetry-share=[share path]:path:' \
  '--telemetry-extra=[extra message]:msg:'
