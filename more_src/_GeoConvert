#compdef GeoConvert
# Documentation: https://geographiclib.sourceforge.io/C++/doc/GeoConvert.1.html
# GeographicLib: convert between geographic coordinate representations

local ret=1

_arguments -s -S \
  '-g[output decimal degrees latitude and longitude (default)]' \
  '-d[output degrees, minutes, and seconds (DMS)]' \
  '-:[like -d but use colon as separator]' \
  '-u[output UTM or UPS]' \
  '-m[output MGRS]' \
  '-c[output meridian convergence and scale]' \
  '-z[set output zone]:zone:' \
  '-s[use standard UPS and UTM zones]' \
  '-t[like -s but force UPS to closest UTM zone]' \
  '-S[like -s until first legal conversion]' \
  '-T[like -t until first legal conversion]' \
  '-n[MGRS input refers to south-west corner not center]' \
  '-w[toggle longitude-first flag]' \
  '-p[set output precision]:prec:' \
  '-l[UTM/UPS uses long forms north and south]' \
  '-a[UTM/UPS uses abbreviations n and s (default)]' \
  '--comment-delimiter[set comment delimiter]:delim:' \
  '--version[print version and exit]' \
  '(-h --help)-h[print usage and exit]' \
  '(-h --help)--help[print full documentation and exit]' \
  '--input-file[read input from file]:infile:_files' \
  '--input-string[read input from string]:string:' \
  '--line-separator[set line separator character]:linesep:' \
  '--output-file[write output to file]:outfile:_files' && ret=0

return ret
