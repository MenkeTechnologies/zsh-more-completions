#compdef pmidi
# Documentation: pmidi(1) man page
# Reference accessed: 2026-05-30 via WebFetch of
# manpages.ubuntu.com/manpages/jammy/man1/pmidi.1.html.
# pmidi R73 — command-line ALSA MIDI sequencer player. Tiny C
# CLI; 3 documented flags + standard --help/--version, environment
# variable ALSA_OUTPUT_PORTS supplies default ports.

_arguments -s -S \
  '-p+[ALSA sequencer port(s) to send to (client:port, comma/space-separated for >16 channels)]:port(s):' \
  '-l[list possible output ports]' \
  '-d+[delay in seconds after song completion (default 2)]:seconds:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:MIDI file:_files -g "*.(mid|midi|MID|MIDI)"'
