#compdef ome_zarr
# Documentation: https://ome-zarr.readthedocs.io/en/stable/api/cli.html
# Command-line tool for reading and writing OME-Zarr (NGFF) filesets

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-v,--verbose}'[increase log verbosity]' \
  '*'{-q,--quiet}'[decrease log verbosity]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'ome_zarr command' \
      'info[print OME-Zarr metadata]' \
      'download[download an OME-Zarr fileset]' \
      'view[serve local Zarr and open in NGFF validator]' \
      'finder[serve local Zarr in a finder web view]' \
      'create[create a sample OME-Zarr image]' \
      'scale[generate a multiscale pyramid from a Zarr array]' \
      'csv_to_labels[map a CSV table onto label properties]' && ret=0
    ;;
  args)
    case $line[1] in
      info)
        _arguments -s \
          '--stats[print array statistics]' \
          '1:path:_files' && ret=0
        ;;
      download)
        _arguments -s \
          '--output=[output directory]:dir:_files -/' \
          '1:path:_files' && ret=0
        ;;
      view)
        _arguments -s \
          '--port=[server port]:port' \
          '(-f --force)'{-f,--force}'[open browser even if no valid data]' \
          '1:path:_files' && ret=0
        ;;
      finder)
        _arguments -s \
          '--port=[server port]:port' \
          '1:path:_files' && ret=0
        ;;
      create)
        _arguments -s \
          '--method=[sample image data]:method:(coins astronaut)' \
          '--format=[OME-Zarr version]:version' \
          '1:path:_files' && ret=0
        ;;
      scale)
        _arguments -s \
          '--copy-metadata[copy metadata to output]' \
          '--method=[downsampling method]:method:(nearest resize laplacian local_mean zoom)' \
          '--in-place[downsample in place]' \
          '--downscale=[downsampling factor]:factor' \
          '--max_layer=[maximum number of pyramid levels]:n' \
          '1:input array:_files' \
          '2:output directory:_files -/' \
          '3:axes' && ret=0
        ;;
      csv_to_labels)
        _arguments -s \
          '1:csv path:_files' \
          '2:csv id column' \
          '3:csv keys' \
          '4:zarr path:_files' \
          '5:zarr id column' && ret=0
        ;;
    esac
    ;;
esac

return ret
