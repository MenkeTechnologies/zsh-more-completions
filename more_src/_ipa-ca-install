#compdef ipa-ca-install
# Documentation: https://github.com/freeipa/freeipa/blob/master/install/tools/man/ipa-ca-install.1
# Reference accessed: 2026-05-16
# Verified: upstream install/tools/man/ipa-ca-install.1.

# ipa-ca-install: install IPA Certificate Authority
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-p --password)'{-p,--password=}'[Directory Manager password]:password:' \
  '(-w --admin-password)'{-w,--admin-password=}'[Admin user password]:password:' \
  '--external-ca[generate CSR for external CA signing]' \
  '--external-ca-type=[external CA type]:type:(generic ms-cs)' \
  '--external-ca-profile=[external CA profile]:profile:' \
  '--external-cert-file=[external CA cert file]:file:_files' \
  '--ca-subject=[CA cert subject DN]:dn:' \
  '--subject-base=[subject base for issued certs]:base:' \
  '--pki-config-override=[CA install overrides file]:file:_files' \
  '--ca-signing-algorithm=[signing algorithm]:algo:(SHA1withRSA SHA256withRSA SHA384withRSA SHA512withRSA)' \
  '--no-host-dns[do not use DNS for hostname lookup]' \
  '--random-serial-numbers[enable Random Serial Numbers]' \
  '--token-name=[PKCS#11 HSM token name]:name:' \
  '--token-library-path=[PKCS#11 library path]:path:_files' \
  '--token-password=[PKCS#11 token password]:password:' \
  '--token-password-file=[PKCS#11 token password file]:file:_files' \
  '--ca-key-type=[CA private key algorithm]:type:' \
  '--skip-conncheck[skip connection check]' \
  '--skip-schema-check[skip CA DS schema check]' \
  '(-U --unattended)'{-U,--unattended}'[unattended installation]' && ret=0
return ret
