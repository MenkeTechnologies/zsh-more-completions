#compdef cvemap vulnx
# Documentation: https://github.com/projectdiscovery/cvemap
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'search:find vulnerabilities with filters'
  'id:get details for specific CVE(s)'
  'filters:list available search fields'
  'analyze:aggregate data by fields'
  'auth:configure API access'
  'version:show version info'
  'update:update to latest version'
  'healthcheck:test connectivity'
)

_arguments -C \
  '--json[JSON output]' \
  '--silent[no banner]' \
  '--timeout=[timeout]:duration:' \
  '--proxy=[HTTP proxy]:url:' \
  '--debug[debug mode]' \
  '--disable-update-check[disable update check]' \
  '--update[update]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'cvemap subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (search)
        _arguments -s \
          '(-p --product)'{-p,--product}'=[product]:product:' \
          '--vendor=[vendor]:vendor:' \
          '(-s --severity)'{-s,--severity}'=[severity]:severity:(critical high medium low info unknown)' \
          '--tags=[tags]:tags:' \
          '--cvss-score=[CVSS score]:score:' \
          '--epss-score=[EPSS score]:score:' \
          '(-a --vuln-age)'{-a,--vuln-age}'=[age]:age:' \
          '--vuln-type=[type]:type:' \
          '--kev[only KEV]' \
          '(-t --template)'{-t,--template}'[only with templates]' \
          '--poc[only with PoC]' \
          '--hackerone[only HackerOne]' \
          '--remote-exploit[remote exploitable]' \
          '--vuln-status=[status]:status:' \
          '--detailed[detailed]' \
          '--highlight[highlight]' \
          '(-n --limit)'{-n,--limit}'=[limit]:n:' \
          '--offset=[offset]:n:' \
          '--sort-asc=[sort asc field]:field:' \
          '--sort-desc=[sort desc field]:field:' \
          '--fields=[fields]:fields:' \
          '--term-facets=[term facets]:facets:' \
          '--range-facets=[range facets]:facets:' \
          '--facet-size=[facet size]:n:' \
          '--output=[output file]:file:_files' \
          '--json[JSON]' && ret=0 ;;
      (id)
        _arguments -s \
          '--file=[file with CVE IDs]:file:_files' \
          '--json[JSON]' \
          '--output=[output file]:file:_files' \
          '*:cve id:' && ret=0 ;;
      (filters|healthcheck|update)
        _arguments -s \
          '--json[JSON]' \
          '--output=[output file]:file:_files' && ret=0 ;;
      (auth)
        _arguments -s \
          '--api-key=[API key]:key:' \
          '--test[test auth]' && ret=0 ;;
      (version)
        _arguments -s \
          '--disable-update-check[disable update check]' && ret=0 ;;
      (analyze)
        _arguments -s \
          '--fields=[fields]:fields:' \
          '--output=[output file]:file:_files' \
          '--json[JSON]' && ret=0 ;;
    esac
    ;;
esac

return ret
