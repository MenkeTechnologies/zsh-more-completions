#compdef tide-index
# Documentation: https://crux.ms/commands/tide-index.html
# Crux tide-index: build a peptide index from a protein database.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--memory-limit=[maximum RAM usage (GB)]:gb' \
  '--clip-nterm-methionine=[include peptides with/without N-term Met]:bool:(T F)' \
  '--isotopic-mass=[use average or monoisotopic masses]:type:(average mono)' \
  '--min-length=[minimum peptide length]:n' \
  '--max-length=[maximum peptide length]:n' \
  '--min-mass=[minimum peptide mass (Da)]:mass' \
  '--max-mass=[maximum peptide mass (Da)]:mass' \
  '--mods-spec=[general modification specification]:spec' \
  '--nterm-peptide-mods-spec=[N-terminal peptide modifications]:spec' \
  '--cterm-peptide-mods-spec=[C-terminal peptide modifications]:spec' \
  '--nterm-protein-mods-spec=[N-terminal protein modifications]:spec' \
  '--cterm-protein-mods-spec=[C-terminal protein modifications]:spec' \
  '--min-mods=[minimum modifications per peptide]:n' \
  '--max-mods=[maximum modifications per peptide]:n' \
  '--mod-precision=[decimal precision for modifications]:n' \
  '--auto-modifications=[infer modifications from spectra]:bool:(T F)' \
  '--auto-modifications-spectra=[spectra file for modification inference]:file:_files' \
  '--decoy-format=[decoy generation method]:fmt:(none shuffle peptide-reverse protein-reverse)' \
  '--decoy-prefix=[decoy protein name prefix]:prefix' \
  '--keep-terminal-aminos=[preserve terminal amino acids in decoys]:where:(N C NC none)' \
  '--num-decoys-per-target=[number of decoys per target]:n' \
  '--allow-dups=[allow duplicate target/decoy peptides]:bool:(T F)' \
  '--seed=[random seed value]:seed' \
  '--enzyme=[enzyme for in silico digestion]:enzyme' \
  '--custom-enzyme=[custom digestion rules]:rule' \
  '--digestion=[digestion type]:type:(full-digest partial-digest non-specific-digest)' \
  '--missed-cleavages=[maximum missed cleavage sites]:n' \
  '--peptide-list=[generate a peptide listing file]:bool:(T F)' \
  '--mass-precision=[decimal precision for mass values]:n' \
  '--temp-dir=[temporary file directory]:dir:_files -/' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--overwrite=[overwrite existing files]:bool:(T F)' \
  '--parameter-file=[configuration file]:file:_files' \
  '--verbosity=[verbosity level 0-60]:level' \
  '*:fasta/index:_files' && ret=0

return ret
