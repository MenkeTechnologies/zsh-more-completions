#compdef defmt-print

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'stdin:read frames from stdin (default)'
  'tcp:read frames over TCP'
  'serial:read frames from serial port'
)

_arguments -C \
  '(-e --elf)'{-e,--elf=}'[ELF with defmt symbol table]:file:_files' \
  '--json[emit JSON-lines]' \
  '--log-format=[frame log format]:fmt:' \
  '--host-log-format=[host log format]:fmt:' \
  '--show-skipped-frames[mark dropped frames]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-w --watch-elf)'{-w,--watch-elf}'[re-read ELF on change]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'defmt-print transport' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (tcp)
        _arguments \
          '--host=[host]:host:_hosts' \
          '--port=[port]:port:' \
          '--set-addr[pin connection address]' && ret=0
        ;;
      (serial)
        _arguments \
          '--path=[serial device]:dev:_files -g "/dev/tty*"' \
          '--baud=[baud rate]:baud:(9600 19200 38400 57600 115200 230400 460800 921600)' \
          '--dtr[assert DTR]' && ret=0
        ;;
    esac
    ;;
esac

return ret
