#compdef dhclient-cli
# _dhclient-cli — ISC dhclient Dynamic Host Configuration Protocol Client CLI alias (ISC team, C); custom argparse
# upstream: https://github.com/isc-projects/dhcp

_dhclient-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--version[show version]' \
        '-4[use IPv4]' \
        '-6[use IPv6]' \
        '-S[obtain server-id but not address]' \
        '-N[restrict to client IP retrieval]' \
        '-T[temporary address mode]' \
        '-P[prefix delegation only]' \
        '-R[use rapid commit]' \
        '-D+[DUID type]:t:(LL LLT EN)' \
        '--dad-wait-time=+[seconds]:n:' \
        '--prefix-len-hint=+[len]:n:' \
        '--decline-wait-time=+[seconds]:n:' \
        '-p+[port]:port:' \
        '-d[do not become a daemon]' \
        '-q[quiet]' \
        '-1[only one try]' \
        '-r[release lease]' \
        '-x[release lease and stop]' \
        '-nw[do not wait]' \
        '-n[do not configure interface]' \
        '-i[do not use script]' \
        '-pf+[pid file]:file:_files' \
        '-lf+[lease file]:file:_files' \
        '-cf+[config file]:file:_files -g "dhclient.conf"' \
        '-df+[duid file]:file:_files' \
        '-sf+[script file]:file:_files' \
        '-s+[server]:host:_hosts' \
        '-g+[relay]:str:' \
        '-V+[vendor class id]:str:' \
        '-I+[client id]:str:' \
        '-B[allow restart]' \
        '-w+[wait timeout]:n:' \
        '-v[verbose]' \
        '*:interface:_net_interfaces'
}

_dhclient-cli "$@"
