#compdef chalk
# Documentation: https://github.com/crashappsec/chalk
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for chalk-cli terminal styling

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '-v[version]' \
  '*:template string: ' && ret=0

return ret
