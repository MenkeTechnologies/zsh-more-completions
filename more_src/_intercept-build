#compdef intercept-build
# Documentation: https://github.com/rizsotto/scan-build/blob/master/libscanbuild/arguments.py
# intercept-build - generate a compilation database by intercepting build commands

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-v,--verbose}'[enable verbose output; repeat for more verbosity]' \
  '--cdb=[JSON compilation database output file]:file:_files' \
  '--override-compiler[use compiler wrapper even when better intercept methods exist]' \
  '--use-cc=[C compiler to use when interposing a wrapper]:compiler:_command_names -e' \
  '--use-c++=[C++ compiler to use when interposing a wrapper]:compiler:_command_names -e' \
  '--append[extend existing compilation database with new entries]' \
  '*::build command:_command_names -e' && ret=0

return ret
