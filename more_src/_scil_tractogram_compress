#compdef scil_tractogram_compress
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_tractogram_compress.html
# Compress a tractogram

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-e+[maximum compression distance in mm]:error_rate' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[force overwriting of the output files]' \
  '1:in_tractogram:_files -g "*.trk *.tck"' \
  '2:out_tractogram:_files -g "*.trk *.tck"' && ret=0

return ret
