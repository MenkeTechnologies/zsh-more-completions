#compdef somalier
# Documentation: https://github.com/brentp/somalier
# fast sample-swap and relatedness checks on BAMs/CRAMs/VCFs/GVCFs

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'extract:extract genotype-like information from VCF/BAM/CRAM/GVCF'
      'relate:calculate relatedness among samples from extracted data'
      'ancestry:predict ancestry on query samples'
      'AB_plot:HTML plot of autosomal allele balance and depth'
      'contamination:estimate contamination from extracted files'
      'find-sites:create a new sites VCF from a population VCF'
    )
    _describe -t commands 'somalier command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      extract)
        _arguments -s -S \
          '(-s --sites)'{-s,--sites}'=[sites VCF of variants to extract]:file:_files' \
          '(-f --fasta)'{-f,--fasta}'=[path to reference fasta]:file:_files' \
          '(-d --out-dir)'{-d,--out-dir}'=[output directory]:dir:_files -/' \
          '--sample-prefix=[prefix for sample name in digest]:prefix' \
          '*:file:_files' && ret=0
        ;;
      relate)
        _arguments -s -S \
          '(-g --groups)'{-g,--groups}'=[expected sample groups file]:file:_files' \
          '--sample-prefix=[sample prefixes to remove]:prefix' \
          '(-p --ped)'{-p,--ped}'=[pedigree/fam file]:file:_files' \
          '(-d --min-depth)'{-d,--min-depth}'=[minimum depth threshold]:depth' \
          '--min-ab=[het allele balance range]:ab' \
          '(-u --unknown)'{-u,--unknown}'[set unknown genotypes to hom-ref]' \
          '(-i --infer)'{-i,--infer}'[infer relationships]' \
          '(-o --output-prefix)'{-o,--output-prefix}'=[output prefix]:prefix' \
          '*:somalier file:_files' && ret=0
        ;;
      ancestry)
        _arguments -s -S \
          '--labels=[file of labeled samples]:file:_files' \
          '--n-pcs=[number of principal components]:n' \
          '(-o --output-prefix)'{-o,--output-prefix}'=[output prefix]:prefix' \
          '*:somalier file:_files' && ret=0
        ;;
      *)
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
