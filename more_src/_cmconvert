#compdef cmconvert
# Documentation: https://manpages.debian.org/testing/infernal/cmconvert.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Infernal cmconvert: convert CM format between Infernal versions
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-a[ASCII output (default)]' \
  '-b[binary output]' \
  '-1[output Infernal v1.0-1.0.2 ASCII CM format]' \
  '--mlhmm[output maximum-likelihood HMM in HMMER3 ASCII format]' \
  '--fhmm[output filter HMM in HMMER3 ASCII format]' \
  '*:input CM file:_files' && ret=0
return ret
