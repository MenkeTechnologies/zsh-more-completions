#compdef cmconvert
# Documentation: https://man.archlinux.org/search?q=cmconvert
# Reference accessed: 2026-05-16

# Infernal cmconvert: convert CM format between Infernal versions
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-a[ASCII output (default)]' \
  '-b[binary output]' \
  '-1[output v1.0 Infernal CM format]' \
  '-o[output file]:file:_files' \
  '*:input CM file:_files' && ret=0
return ret
