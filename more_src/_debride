#compdef debride

# Zsh completion for debride (Ruby dead method finder)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-e,--exclude}'=[file with methods to exclude]:file:_files' \
  {-f,--focus}'=[only report methods matching regex]:regex' \
  {-w,--whitelist}'=[file with whitelisted methods]:file:_files' \
  '--rails[Rails mode, whitelist common Rails methods]' \
  {-v,--verbose}'[verbose output]' \
  '*:files:_files -g "*.rb"' && ret=0

return ret
