#compdef bap-byteweight
# _bap-byteweight — train/run BAP Byteweight function-start signatures (BinaryAnalysisPlatform/bap)
# upstream: https://github.com/BinaryAnalysisPlatform/bap
# Subcommands from src/bap_byteweight_main.ml (Extension.Command).

_bap-byteweight() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                dump:'dump function starts in machine readable format'
                train:'train on specified set of files'
                find:'output function starts detected with Byteweight'
                fetch:'download signatures to current folder'
                install:'copy signatures to predefined location'
                update:'download and install signatures'
                symbols:'output ground-truth function starts from the binary'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                dump|find)
                    _arguments \
                        '--loader=[BAP loader]:loader:' \
                        '--compiler=[compiler signature set]:compiler:' \
                        '-i+[info to dump]:info:(byteweight symbols)' \
                        '--min-length=[min byte sequence length]:n:' \
                        '--max-length=[max byte sequence length]:n:' \
                        '--threshold=[detection threshold or Bayes factor]:f:' \
                        '1:database file:_files' \
                        '2:input file:_files' ;;
                train)
                    _arguments \
                        '--loader=[BAP loader]:loader:' \
                        '--operation=[training operation]:op:(update rewrite)' \
                        '--max-length=[max byte sequence length]:n:' \
                        '--compiler=[compiler signature set]:compiler:' \
                        '1:database file:_files' \
                        '*:training corpus file:_files' ;;
                fetch)
                    _arguments \
                        '-o+[output filename]:file:_files' \
                        '--url=[signature URL]:url:_urls' \
                        '--version=[version to fetch]:ver:' ;;
                install) _arguments '1:source signature file:_files' '2:destination:_files -/' ;;
                update)
                    _arguments \
                        '--url=[signature URL]:url:_urls' \
                        '--version=[version to install]:ver:' \
                        '1:destination:_files -/' ;;
                symbols)
                    _arguments \
                        '--loader=[BAP loader]:loader:' \
                        '(-n --print-name)'{-n,--print-name}'[print symbol names]' \
                        '(-s --print-size)'{-s,--print-size}'[print symbol sizes]' \
                        '1:input file:_files' ;;
            esac
            ;;
    esac
}

_bap-byteweight "$@"
