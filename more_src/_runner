#compdef runner run
# Documentation: https://github.com/kjanat/runner
# Reference accessed: 2026-05-21
# Verified: upstream repo at the URL above.
# STUB: dynamic clap CompleteEnv completer; original binary path was a stale
# /var/folders/... tmp dir from cargo-binstall probe. Fall back to file completion.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:file:_files' && ret=0
return ret
