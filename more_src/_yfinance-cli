#compdef yfinance-cli yfinance yf-cli
# _yfinance-cli — Ran Aroussi yfinance-cli CLI command-line frontend wrapping the yfinance Python library scraping the Yahoo Finance API providing historical OHLC data dividends splits earnings income-statement balance-sheet cash-flow recommendations major-holders insider-trades calendar quote info options-chain news financials sustainability (Ran Aroussi team, Python); click
# upstream: https://github.com/ranaroussi/yfinance

_yfinance-cli() {
    local -a sub=(
        'history:download historical OHLC data'
        'info:show ticker info'
        'quote:fetch live quote'
        'dividends:show dividends'
        'splits:show splits'
        'actions:show corporate actions'
        'financials:show financials'
        'income:income statement'
        'balance:balance sheet'
        'cashflow:cash flow statement'
        'earnings:earnings'
        'calendar:show calendar'
        'recommendations:recommendations'
        'analyst:analyst price targets'
        'holders:show holders'
        'institutional-holders:institutional holders'
        'major-holders:major holders'
        'mutual-fund:mutual fund holders'
        'insider:insider trades'
        'news:show news'
        'options:show options chain'
        'sustainability:sustainability data'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--period=+[p]:p:(1d 5d 1mo 3mo 6mo 1y 2y 5y 10y ytd max)' \
        '--interval=+[i]:i:(1m 2m 5m 15m 30m 60m 90m 1h 1d 5d 1wk 1mo 3mo)' \
        '--start=+[YYYY-MM-DD]:str:' \
        '--end=+[YYYY-MM-DD]:str:' \
        '--prepost[include pre/post market]' \
        '--actions[include actions]' \
        '--auto-adjust[auto adjust OHLC]' \
        '--back-adjust[back adjust to last close]' \
        '--proxy=+[url]:str:' \
        '--rounding[round to two decimals]' \
        '--threads=+[N]:n:' \
        '--group-by=+[g]:g:(column ticker)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table parquet)' \
        '--format=+[format]:f:(json yaml csv table parquet)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yfinance-cli subcommand' sub ;;
        args)
            _arguments '*:ticker:'
            ;;
    esac
}

_yfinance-cli "$@"
