#compdef rclone

# Zsh completion for rclone (cloud storage sync tool)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Show help]' \
  '--help[Show help]' \
  '-V[Show version]' \
  '--version[Show version]' \
  '-v[Increase verbosity]' \
  '--verbose[Increase verbosity]' \
  '-q[Decrease verbosity]' \
  '--quiet[Decrease verbosity]' \
  '--config=[Config file path]:config file:_files' \
  '--cache-dir=[Directory for cache]:cache dir:_directories' \
  '--temp-dir=[Directory for temp files]:temp dir:_directories' \
  '--timeout=[IO idle timeout]:timeout:' \
  '--contimeout=[Connect timeout]:timeout:' \
  '--retries=[Number of retries]:retries:' \
  '--low-level-retries=[Number of low-level retries]:retries:' \
  '--stats=[Interval between stats output]:interval:' \
  '--stats-one-line[One line stats display]' \
  '--progress[Show progress during transfer]' \
  '-P[Show progress during transfer]' \
  '--log-file=[Log file path]:log file:_files' \
  '--log-level=[Log level]:level:(DEBUG INFO NOTICE ERROR)' \
  '--dry-run[Dry run mode]' \
  '-n[Dry run mode]' \
  '--interactive[Interactive mode]' \
  '-i[Interactive mode]' \
  '--transfers=[Number of parallel transfers]:number:' \
  '--checkers=[Number of parallel checkers]:number:' \
  '--bwlimit=[Bandwidth limit]:limit:' \
  '--buffer-size=[In-memory buffer size per transfer]:size:' \
  '--max-depth=[Max recursion depth]:depth:' \
  '--no-traverse[Do not traverse destination filesystem]' \
  '--checksum[Skip files with matching size and checksum]' \
  '--size-only[Skip files with matching size]' \
  '--ignore-size[Skip files with matching checksum]' \
  '--update[Skip files that are newer on destination]' \
  '-u[Skip files that are newer on destination]' \
  '--delete-before[Delete dest files before transfer]' \
  '--delete-during[Delete dest files during transfer]' \
  '--delete-after[Delete dest files after transfer]' \
  '*--include=[Include files matching pattern]:pattern:' \
  '*--exclude=[Exclude files matching pattern]:pattern:' \
  '--filter-from=[Read filtering patterns from file]:file:_files' \
  '--include-from=[Read include patterns from file]:file:_files' \
  '--exclude-from=[Read exclude patterns from file]:file:_files' \
  '--min-size=[Minimum file size]:size:' \
  '--max-size=[Maximum file size]:size:' \
  '--min-age=[Minimum file age]:age:' \
  '--max-age=[Maximum file age]:age:' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'about:Get quota information from remote'
      'authorize:Remote authorization'
      'backend:Run backend-specific command'
      'bisync:Bidirectional sync'
      'cat:Concatenate files and send to stdout'
      'check:Check if source and destination match'
      'checksum:Check files against hash file'
      'cleanup:Clean up remote'
      'completion:Generate shell completions'
      'config:Enter an interactive config session'
      'copy:Copy files from source to dest'
      'copyto:Copy files from source to dest (single file)'
      'copyurl:Copy url content to dest'
      'cryptcheck:Check encrypted remote'
      'cryptdecode:Decrypt filenames'
      'dedupe:Interactively find duplicate files and delete/rename'
      'delete:Remove contents of path'
      'deletefile:Remove a single file'
      'genautocomplete:Generate shell completions'
      'gendocs:Generate documentation'
      'hashsum:Produce a hashsum file for all files'
      'link:Generate public link to file'
      'listremotes:List all configured remotes'
      'ls:List objects with size and path'
      'lsd:List directories'
      'lsf:List objects in format for parsing'
      'lsjson:List objects in JSON format'
      'lsl:List objects with modification time, size, and path'
      'md5sum:Produce MD5 hash for all files'
      'mkdir:Make directory on remote'
      'mount:Mount remote as filesystem'
      'move:Move files from source to dest'
      'moveto:Move file or directory from source to dest'
      'ncdu:Explore remote with ncdu-style UI'
      'nfsmount:Mount remote as NFS filesystem'
      'obscure:Obscure password'
      'purge:Remove path and all contents'
      'rc:Run rclone remote control command'
      'rcat:Copy standard input to remote'
      'rcd:Run rclone remote control daemon'
      'rmdir:Remove empty directory'
      'rmdirs:Remove empty directories'
      'selfupdate:Update rclone binary'
      'serve:Serve remote over a protocol'
      'settier:Change storage class/tier of objects'
      'sha1sum:Produce SHA1 hash for all files'
      'size:Show total size and count of objects'
      'sync:Sync source to dest (one-way)'
      'test:Run test commands'
      'touch:Create or update modification time of file'
      'tree:List remote in tree format'
      'version:Show version'
    )
    _describe -t commands 'rclone command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      serve)
        local -a serve_cmds=(
          'dlna:Serve remote over DLNA'
          'docker:Serve remote as Docker volume plugin'
          'ftp:Serve remote over FTP'
          'http:Serve remote over HTTP'
          'nfs:Serve remote over NFS'
          'restic:Serve remote for restic'
          'sftp:Serve remote over SFTP'
          'webdav:Serve remote over WebDAV'
        )
        _describe -t serve-commands 'serve protocol' serve_cmds && ret=0
        ;;
      config)
        local -a config_cmds=(
          'create:Create a new remote'
          'delete:Delete an existing remote'
          'disconnect:Disconnect from remote'
          'dump:Dump the config as JSON'
          'edit:Edit an existing remote'
          'file:Show path of config file'
          'password:Encrypt/decrypt config file'
          'paths:Show config file paths'
          'providers:List providers and their config'
          'reconnect:Reconnect to remote'
          'show:Print config file or specified remote'
          'touch:Ensure config file exists'
          'update:Update remote with named values'
          'userinfo:Print user info'
        )
        _describe -t config-commands 'config command' config_cmds && ret=0
        ;;
      copy|sync|move|check|bisync)
        _arguments \
          '*:remote path:_files' && ret=0
        ;;
      *)
        _arguments \
          '*:remote path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
