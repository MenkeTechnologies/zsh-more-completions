#compdef rclone
# Documentation: https://rclone.org/commands/rclone/
# Source: rclone/rclone — universal cloud-storage CLI (S3 / GCS / Azure / Dropbox / etc).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '--config=[config file path]:file:_files' \
    '--log-file=[log file path]:file:_files' \
    '--log-level=[log level]:level:(DEBUG INFO NOTICE ERROR)' \
    '(-v --verbose)*'{-v,--verbose}'[verbose (repeatable)]' \
    '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
    '--dry-run[do not run; show what would happen]' \
    '-i[interactive: ask before each non-idempotent action]' \
    '-P[show progress]' \
    '--stats=[interval between stats output]:duration:' \
    '--transfers=[parallel file transfers]:n:' \
    '--checkers=[parallel filesystem checks]:n:' \
    '--retries=[retry operations on error]:n:' \
    '--bwlimit=[bandwidth limit]:limit:' \
    '--max-depth=[recursion depth limit]:n:' \
    '--include=[include matching file glob]:pattern:' \
    '--exclude=[exclude matching file glob]:pattern:' \
    '--filter=[filter rule]:rule:' \
    '--no-traverse[do not traverse destination]' \
    '--update[skip files newer on destination]' \
    '--checksum[skip files with matching checksum]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'copy:copy files to/from cloud storage'
            'sync:synchronize source -> destination'
            'move:move/rename files in cloud storage'
            'ls:list files'
            'lsd:list directories only'
            'lsl:list files with size'
            'lsf:list files in simple format'
            'lsjson:list files as JSON'
            'mkdir:create a new directory'
            'rmdir:remove an empty directory'
            'rmdirs:remove empty directories recursively'
            'delete:delete files'
            'purge:remove a directory + all contents'
            'cat:display file contents'
            'mount:mount remote as a FUSE filesystem'
            'serve:serve remote over HTTP / FTP / WebDAV / SFTP / DLNA / etc'
            'check:check integrity of files'
            'dedupe:remove duplicate files'
            'version:show rclone version'
            'config:manage configuration'
            'listremotes:list configured remotes'
            'copyto:copy single file to destination path'
            'moveto:move single file to destination path'
            'link:create shareable link'
            'ncdu:interactive disk-usage analyzer'
            'tree:display directory structure as tree'
            'about:show usage / quota info'
            'genautocomplete:generate shell autocomplete'
            'gendocs:generate Markdown documentation'
            'hashsum:compute file hashes'
            'mkdir:make a directory'
            'obscure:obscure password to its rclone form'
            'rcat:copy stdin to remote file'
            'rcd:start remote control daemon'
            'reveal:reveal an obscured password'
            'selfupdate:update rclone in place'
            'settier:change storage tier of objects'
            'sha1sum:compute SHA1 sums'
            'md5sum:compute MD5 sums'
            'size:total size + object count of remote'
            'touch:create or change modification time'
            'completion:generate shell completion'
        )
        _describe -t subcmds 'rclone command' subcmds && ret=0
        ;;
    args)
        _default
        ;;
esac

return ret
