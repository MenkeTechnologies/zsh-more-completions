_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[scope the request to a namespace]:namespace:' \
  '(-v --verbosity)'{-v+,--verbosity=}'[log level]:level:(info debug trace warn error fatal panic)' \
  '*:: :_default'
