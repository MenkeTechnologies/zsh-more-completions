#compdef kubectl-df-pv
# Documentation: https://man.archlinux.org/search?q=kubectl-df-pv
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-l[label selector]:selector:' \
  '-n[namespace scope for PVC lookups]:namespace:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--context=[kube context]:context:' \
  '*:nodes or options: _default'
