#compdef iverilog
# Documentation: https://man.archlinux.org/man/iverilog.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-V[print compiler version and exit]' \
  '(- *)-R[print runtime paths and exit]' \
  '-B+[path to locate external programs]:dir:_directories' \
  '-c+[input file listing Verilog source files]:command file:_files' \
  '-f+[input file listing Verilog source files]:command file:_files' \
  '*-D+[define macro]:macro[=value]:' \
  '*-P+[override root module parameter via defparam]:parameter=value:' \
  '*-d+[activate debugging messages]:name:(scopes eval_tree elaborate synth2)' \
  '-E[preprocess only, without compilation]' \
  '-g+[specify language generation/feature]:generation:(1995 2001 2001-noconfig 2005 2005-sv 2009 2012 verilog-ams no-verilog-ams assertions supported-assertions no-assertions specify no-specify interconnect no-interconnect std-include no-std-include relative-include no-relative-include xtypes no-xtypes io-range-error no-io-range-error strict-ca-eval no-strict-ca-eval strict-expr-width no-strict-expr-width shared-loop-index no-shared-loop-index icarus-misc no-icarus-misc)' \
  '*-I+[append include directory to search path]:directory:_directories' \
  '-i[ignore missing modules]' \
  '*-L+[add directory to VPI module search path]:directory:_directories' \
  '*-l+[add library file to compilation]:library file:_files' \
  '*-M+[write contributing file list]:dependency file:_files' \
  '*-m+[add VPI module to load during simulation]:module:' \
  '-N+[dump final netlist to file]:netlist file:_files' \
  '-o+[place output in specified file]:output file:_files' \
  '*-p+[assign target-specific flag value]:flag=value:' \
  '-S[force synthesis even if not required]' \
  '-s+[specify top-level module for elaboration]:module name:' \
  '-T+[select min:typ:max time]:time:(min typ max)' \
  '-t+[set target format]:target:(null vvp)' \
  '-u[treat each source file as a separate compilation unit]' \
  '-v[turn on verbose messages]' \
  '*-W+[enable warning category]:category:(all anachronisms implicit macro-redefinition macro-replacement portbind select-range timescale infloop sensitivity-entire-vector sensitivity-entire-array)' \
  '*-Y+[add accepted filename suffix for library search]:suffix:' \
  '*:Verilog file:_files -g "*.(v|sv|vh|svh)"' && ret=0

return ret
