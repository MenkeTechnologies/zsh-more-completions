#compdef sfshapeagc
# Documentation: https://github.com/ahay/src/blob/master/user/fomels/Mshapeagc.c
# Madagascar: automatic gain control by shaping regularization

local ret=1

_arguments -s -S \
  'rect1=[smoothing radius on 1st axis]:rect1' \
  'rect2=[smoothing radius on 2nd axis]:rect2' \
  'rect3=[smoothing radius on 3rd axis]:rect3' \
  'niter=[number of iterations]:niter' \
  'eps=[regularization]:eps' \
  'verb=[verbosity]:verb:(y n)' \
  'gain=[output gain file]:gain:_files' \
  '*:RSF file:_files' && ret=0

return ret
