#compdef otbcli_DynamicConvert
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_DynamicConvert.html
# Orfeo ToolBox: rescale and convert image dynamic range and channels

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image file]:image:_files' \
  '-out[output image file]:output:_files' \
  '-type[transfer function for rescaling]:type:(linear log2)' \
  '-type.linear.gamma[gamma correction factor for linear rescaling]:value:' \
  '-mask[mask image indicating valid pixels]:image:_files' \
  '-quantile.high[histogram high-end percentile to exclude]:percent:' \
  '-quantile.low[histogram low-end percentile to exclude]:percent:' \
  '-channels[channel selection mode]:mode:(all grayscale rgb)' \
  '-channels.grayscale.channel[band index for grayscale mode]:index:' \
  '-channels.rgb.red[red channel band index]:index:' \
  '-channels.rgb.green[green channel band index]:index:' \
  '-channels.rgb.blue[blue channel band index]:index:' \
  '-outmin[minimum output value]:value:' \
  '-outmax[maximum output value]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
