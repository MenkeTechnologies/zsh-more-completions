#compdef kanboard-cli
# _kanboard-cli — Frédéric Guillot Kanboard project management CLI alias (kanboard team, PHP); custom argparse over JSON-RPC API
# upstream: https://github.com/kanboard/kanboard

_kanboard-cli() {
    local -a sub=(
        'login:save credentials'
        'logout:clear credentials'
        'project:list:list projects'
        'project:create:create project'
        'project:get:get project'
        'project:update:update project'
        'project:delete:delete project'
        'project:enable:enable project'
        'project:disable:disable project'
        'project:duplicate:duplicate project'
        'project:activity:show activity'
        'project:users:list users'
        'project:user:add:add user'
        'project:user:remove:remove user'
        'task:list:list tasks'
        'task:create:create task'
        'task:get:get task'
        'task:update:update task'
        'task:close:close task'
        'task:open:open task'
        'task:move:move task'
        'task:remove:remove task'
        'task:duplicate:duplicate task'
        'task:search:search tasks'
        'task:assign:assign task'
        'task:tag:add:add tag'
        'task:tag:remove:remove tag'
        'task:tag:list:list task tags'
        'subtask:list:list subtasks'
        'subtask:create:create subtask'
        'subtask:update:update subtask'
        'subtask:remove:remove subtask'
        'comment:list:list comments'
        'comment:create:create comment'
        'comment:update:update comment'
        'comment:remove:remove comment'
        'column:list:list columns'
        'column:add:add column'
        'column:remove:remove column'
        'swimlane:list:list swimlanes'
        'swimlane:add:add swimlane'
        'category:list:list categories'
        'category:add:add category'
        'user:list:list users'
        'user:create:create user'
        'user:delete:delete user'
        'user:update:update user'
        'group:list:list groups'
        'group:create:create group'
        'group:delete:delete group'
        'me:show current user'
        'activity:show activity'
        'tag:list:list tags'
        'tag:create:create tag'
        'tag:remove:remove tag'
        'webhook:fire:fire webhook'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--url=+[kanboard url]:url:_urls' \
        '--user=+[username]:user:_users' \
        '--token=+[api token]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kanboard subcommand' sub ;;
        args)
            case $words[1] in
                task:create) _arguments \
                    '--project-id=+[project id]:n:' \
                    '-p+[project id]:n:' \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--description=+[description]:str:' \
                    '--owner-id=+[owner id]:n:' \
                    '--column-id=+[column id]:n:' \
                    '--swimlane-id=+[swimlane id]:n:' \
                    '--priority=+[priority]:n:' \
                    '--color=+[color]:str:' \
                    '--tags=+[tags csv]:str:' \
                    '--due-date=+[due date]:str:' ;;
                task:get|task:close|task:open|task:remove|task:duplicate) _arguments '1:task id:' ;;
                project:create) _arguments \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--description=+[description]:str:' \
                    '--is-public[public]' \
                    '--start-date=+[start date]:str:' \
                    '--end-date=+[end date]:str:' \
                    '--owner-id=+[owner id]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_kanboard-cli "$@"
