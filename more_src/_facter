#compdef facter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'+[path to config file]:config:_files' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '--external-dir+[directory for external facts]:directory:_files -/' \
  '--custom-dir+[directory for custom facts]:directory:_files -/' \
  '--help[show help]' \
  '(-j --json)'{-j,--json}'[output in JSON format]' \
  '(-l --log-level)'{-l,--log-level}'+[set log level]:level:(none trace debug info warn error fatal)' \
  '--no-block[do not block on external facts]' \
  '--no-cache[disable caching]' \
  '--no-color[disable color output]' \
  '--no-custom-facts[do not load custom facts]' \
  '--no-external-facts[do not load external facts]' \
  '--no-ruby[do not load Ruby-based facts]' \
  '(-p --puppet)'{-p,--puppet}'[load Puppet settings to resolve facts]' \
  '--show-legacy[show legacy facts]' \
  '(-t --timing)'{-t,--timing}'[show time to resolve each fact]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--version[display version]' \
  '(-y --yaml)'{-y,--yaml}'[output in YAML format]' \
  '--strict[enable strict mode]' \
  '--trace[enable backtraces]' \
  '--hocon[output in HOCON format]' \
  '*:fact name:(os networking kernel memory processors filesystems disks mountpoints partitions ec2 gce az identity load_averages ssh timezone virtual hypervisors is_virtual ruby facterversion fips_enabled augeas dmi)' && ret=0

return ret
