#compdef chaos-client
# Documentation: https://github.com/projectdiscovery/chaos-client
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# projectdiscovery/chaos-client installs binary named 'chaos' (see _chaos).
# This file provides minimal fallback completion for invocations using the alt name 'chaos-client'.

_arguments -s -S \
  '(- *)-h[show help]' \
  '-d[target domain]:domain:' \
  '-key[ProjectDiscovery PDCP API key]:key:' \
  '-o[output file]:file:_files' \
  '-count[show subdomain count only]' \
  '-json[output in JSON format]' \
  '-silent[silent mode]' \
  '*: : _default'
