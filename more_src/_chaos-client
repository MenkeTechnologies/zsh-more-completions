#compdef chaos-client
# Documentation: https://man.archlinux.org/search?q=chaos-client
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--url=[Chaos DNS URL]:url' \
  '--token=[Chaos token]:token' \
  '1:command:(register list delete)' \
  '*: : _default'
