#compdef ssaducli
# Documentation: https://man.archlinux.org/search?q=ssaducli
# Reference accessed: 2026-05-16

# ssaducli: HPE Smart Storage Administrator CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)help[show help]' \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '(- *)version[show version]' \
  'controller[controller subtarget]' \
  'array[array subtarget]' \
  'logicaldrive[logical drive subtarget]' \
  'physicaldrive[physical drive subtarget]' \
  'enclosure[enclosure subtarget]' \
  'show[show config / status / detail]' \
  'add[add a drive/spare]' \
  'create[create a new array or LD]' \
  'delete[delete an array or LD]' \
  'rescan[rescan]' \
  'modify[modify properties]' \
  'flash[flash firmware]' \
  'set[set parameter]' \
  'expand[expand array]' \
  'transform[migrate RAID level]' \
  '*:ssaducli args:' && ret=0
return ret
