#compdef benthos-server

# Zsh completion for Benthos stream processor (server mode)
# Benthos is now Redpanda Connect, but the benthos binary is still widely used

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '(-c --config)'{-c,--config}'=[main config file]:file:_files -g "*.yaml *.yml *.json"' \
  '*'{-r,--resources}'=[resource config file or glob]:file:_files -g "*.yaml *.yml *.json"' \
  '(-t --templates)'{-t,--templates}'=[template config file or glob]:file:_files -g "*.yaml *.yml *.json"' \
  '--set=[override config field (dot path=value)]:override' \
  '--chilled[continue running if input/output block]' \
  '--log.level=[log level]:level:(TRACE DEBUG INFO WARN ERROR FATAL)' \
  '--log.format=[log format]:format:(json logfmt)' \
  '--log.add_timestamp[add timestamp to logs]' \
  '--log.static_fields=[static log fields JSON]:json' \
  '--http.address=[HTTP server address]:address' \
  '--http.enabled[enable HTTP server]' \
  '--http.root_path=[HTTP root path]:path' \
  '--http.debug_endpoints[enable debug endpoints]' \
  '--http.cert_file=[TLS certificate file]:file:_files' \
  '--http.key_file=[TLS key file]:file:_files' \
  '--streams[run in streams mode]' \
  '--no-api[disable REST API]' \
  '--env-file=[load environment from file]:file:_files' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'blobl:execute bloblang mappings'
      'create:create a config template'
      'echo:echo parsed config back'
      'lint:lint config files'
      'list:list available components'
      'run:run a Benthos pipeline'
      'streams:run in streams mode'
      'studio:connect to Benthos Studio'
      'test:run unit tests'
      'help:show help'
    )
    _describe -t commands 'benthos command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      lint|test)
        _files -g "*.yaml *.yml *.json" && ret=0
        ;;
      create)
        _arguments -s -S \
          '--small[only print core config]' \
          '--benthosconfig[print a full default config]' \
          '1:type:(input output processor cache rate_limit buffer)' && ret=0
        ;;
      list)
        _arguments -s -S \
          '--format=[output format]:format:(text json cue)' \
          '--status=[filter by component status]:status:(stable beta experimental deprecated)' \
          '1:type:(inputs outputs processors caches rate-limits buffers metrics tracers scanners all)' && ret=0
        ;;
      blobl)
        _arguments -s -S \
          '(-m --mapping)'{-m,--mapping}'=[bloblang mapping]:mapping' \
          '(-f --file)'{-f,--file}'=[bloblang mapping file]:file:_files -g "*.blobl"' \
          '--raw[consume raw input]' \
          '--pretty[pretty print output]' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
