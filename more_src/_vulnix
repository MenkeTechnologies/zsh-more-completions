#compdef vulnix
# Documentation: https://man.archlinux.org/search?q=vulnix
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '-c+[Path to user nixpkgs clone]:directory:_directories' \
  '-j+[Parallel CVE queries]:jobs:' \
  '--help[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'system:Scan current system closure'
      'derive:Scan a derivation graph'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
