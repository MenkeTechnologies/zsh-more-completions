#compdef h2c

# Zsh completion for h2c headers-to-curl (curl/h2c Perl tool)

_arguments -s -S \
  '-a[allow curl default headers]' \
  '-d[append curl man page HTML links]' \
  '-h[short help]' \
  '-H[emit HTTP URLs instead of curl]' \
  '-i[ignore HTTP version]' \
  '--libcurl[emit libcurl C instead of curl CLI]' \
  '-n[append notes after command]' \
  '-s[prefer short curl options]' \
  '-v[add curl --verbose]' && ret=0

return ret
