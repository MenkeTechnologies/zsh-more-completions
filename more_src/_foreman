#compdef foreman

_foreman_start() {
  _arguments \
    {-f,--procfile}'[specify Procfile]:file:_files' \
    {-d,--root}'[specify root directory]:dir:_directories' \
    {-e,--env}'[specify env file]:file:_files' \
    {-m,--formation}'[specify formation (type=num,...)]:formation:' \
    {-p,--port}'[specify port]:port:' \
    '--color[force color output]' \
    '--no-color[disable color output]' \
    '--timestamp[include timestamps]' \
    {-t,--timeout}'[specify timeout in seconds]:seconds:' \
    '--help[show help]'
}

_foreman_run() {
  _arguments \
    {-f,--procfile}'[specify Procfile]:file:_files' \
    {-d,--root}'[specify root directory]:dir:_directories' \
    {-e,--env}'[specify env file]:file:_files' \
    '--help[show help]' \
    '*::command:_command_names'
}

_foreman_check() {
  _arguments \
    {-f,--procfile}'[specify Procfile]:file:_files' \
    '--help[show help]'
}

_foreman_export() {
  _arguments \
    ':format:(systemd upstart supervisord)' \
    {-a,--app}'[specify app name]:name:' \
    {-l,--log}'[specify log directory]:dir:_directories' \
    {-d,--root}'[specify root directory]:dir:_directories' \
    {-f,--procfile}'[specify Procfile]:file:_files' \
    {-p,--port}'[specify port]:port:' \
    {-u,--user}'[specify user to run as]:user:_users' \
    {-m,--formation}'[specify formation (type=num,...)]:formation:' \
    {-t,--timeout}'[specify timeout in seconds]:seconds:' \
    '--color[force color output]' \
    '--no-color[disable color output]' \
    '--help[show help]'
}

_foreman() {
  local -a commands
  commands=(
    'start:start the application'
    'run:run a command using the application environment'
    'check:validate the Procfile'
    'export:export the application to another process management format'
  )

  _arguments \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::arguments:->arguments'

  case "$state" in
    command)
      _describe -t commands 'foreman command' commands
      ;;
    arguments)
      case "$words[1]" in
        start) _foreman_start ;;
        run) _foreman_run ;;
        check) _foreman_check ;;
        export) _foreman_export ;;
      esac
      ;;
  esac
}

_foreman "$@"
