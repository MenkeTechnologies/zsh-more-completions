#compdef crm_ticket

# crm_ticket: manage Booth/Geo-cluster tickets
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '-t[ticket name]:ticket:' \
  '--ticket=[ticket name]:ticket:' \
  '-l[list tickets]' \
  '--info[list tickets]' \
  '-L[list ticket states]' \
  '--ticket-state[list ticket states]' \
  '-w[show ticket constraints]' \
  '--constraints[show ticket constraints]' \
  '-q[query attribute]' \
  '--query=[query attribute]:attr:' \
  '-g[grant ticket]' \
  '--grant[grant ticket]' \
  '-r[revoke ticket]' \
  '--revoke[revoke ticket]' \
  '-s[standby ticket]' \
  '--standby[standby ticket]' \
  '-a[activate ticket]' \
  '--activate[activate ticket]' \
  '-v[attribute value]:value:' \
  '--set-attr-value=[attribute name]:name:' \
  '--get-attr-value=[attribute name]:name:' \
  '--del-attr[delete attribute]' \
  '-f[force]' \
  '--force[force]' \
  '--output-as=[output format]:fmt:(text xml html)' \
  '*::crm_ticket args:_files' && ret=0
return ret
