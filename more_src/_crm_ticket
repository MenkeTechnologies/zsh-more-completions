#compdef crm_ticket

# Pacemaker crm_ticket: query/grant/revoke tickets for booth multi-site
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-t --ticket)'{-t,--ticket=}'[ticket name]:ticket:' \
  '(-g --grant)'{-g,--grant}'[grant the ticket]' \
  '(-r --revoke)'{-r,--revoke}'[revoke the ticket]' \
  '(-s --standby)'{-s,--standby}'[place ticket on standby]' \
  '(-a --activate)'{-a,--activate}'[activate standby ticket]' \
  '(-G --query)'{-G,--query}'[query ticket attribute]' \
  '(-v --value)'{-v,--value=}'[set ticket attribute]:val:' \
  '(-D --delete)'{-D,--delete}'[delete ticket attribute]' \
  '(-S --set-name)'{-S,--set-name=}'[set name]:set:' \
  '(-i --id)'{-i,--id=}'[XML id]:id:' \
  '(-f --force)'{-f,--force}'[force]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '*::crm_ticket args:_files' && ret=0
return ret
