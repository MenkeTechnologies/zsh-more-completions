#compdef copyq
# Documentation: https://hluk.github.io/CopyQ/ (scripting API: https://copyq.readthedocs.io/en/latest/scripting-api.html)
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URLs above.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help for command or all commands]' \
  '(- *)--version[show version]' \
  '(-s --session)'{-s+,--session=}'[start or connect to a session]:session name:' \
  '--start-server[start the server and exit]' \
  '1:command:->command' \
  '*:argument:->args' && ret=0

case "$state" in
  command)
    local -a commands=(
      'show:Show main window'
      'toggle:Toggle main window visibility'
      'menu:Open context menu'
      'exit:Exit the application'
      'clipboard:Print clipboard content'
      'selection:Print X11 selection content'
      'paste:Paste clipboard to current window'
      'copy:Copy text to clipboard'
      'count:Print number of items in tab'
      'select:Copy item in given row to clipboard'
      'add:Add text to tab'
      'insert:Insert text item at given row'
      'remove:Remove items in given rows'
      'action:Execute a program on items'
      'popup:Show a popup notification'
      'session:Manage sessions'
      'edit:Edit items or edit new item'
      'next:Copy next item to clipboard'
      'previous:Copy previous item to clipboard'
      'read:Print raw data of items'
      'write:Write raw data to given row'
      'separator:Set separator for items on output'
      'tab:List tabs or set current tab'
      'removetab:Remove a tab'
      'renametab:Rename a tab'
      'exporttab:Export a tab'
      'importtab:Import a tab'
      'config:Get or set configuration options'
      'eval:Evaluate a script'
      'enable:Enable clipboard storing'
      'disable:Disable clipboard storing'
      'version:Show version'
      'help:Show help for a command'
      'monitor:Start clipboard monitor'
    )
    _describe -t commands 'copyq command' commands && ret=0
    ;;
  args)
    case "${words[2]}" in
      exporttab|importtab)
        _arguments '2:file:_files' && ret=0
        ;;
      tab|removetab|renametab)
        _message 'tab name' && ret=0
        ;;
      eval)
        _message 'script' && ret=0
        ;;
      *)
        _message 'argument' && ret=0
        ;;
    esac
    ;;
esac
return ret
