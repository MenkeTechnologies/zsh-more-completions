#compdef git-secrets2
# _git-secrets2 — AWS Labs awslabs git-secrets2 CLI command-line frontend wrapping the git-secrets prevents you from committing passwords and other sensitive information to a git repository open-source written in Bash scans commits commit messages and --no-ff merges to prevent adding secrets into your git repositories Hooks-based-pre-commit-pre-commit-msg-prepare-commit-msg AWS-providers add-provider register-aws scan-history (AWS Labs team, Bash); custom argparse
# upstream: https://github.com/awslabs/git-secrets

_git-secrets2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--install=+[path]:_files -/' \
        '--scan[scan current files]' \
        '--scan-history[scan history]' \
        '--commit-msg-hook[run commit-msg hook]' \
        '--prepare-commit-msg-hook[run prepare hook]' \
        '--pre-commit-hook[run pre-commit hook]' \
        '--list[list patterns]' \
        '--add=+[pattern]:str:' \
        '--add-provider=+[provider]:str:' \
        '--register-aws[register AWS]' \
        '--aws-provider[AWS provider]' \
        '--global[apply globally]' \
        '--literal[treat as literal]' \
        '-a[apply allowed]' \
        '--allowed=+[pattern]:str:' \
        '-r+[recursive]' \
        '--recursive[recursive]' \
        '-f+[force]' \
        '--force[force overwrite]' \
        '*:files:_files'
}

_git-secrets2 "$@"
