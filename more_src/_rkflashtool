#compdef rkflashtool
# Documentation: https://github.com/linux-rockchip/rkflashtool
# Tools for flashing Rockchip devices over the Rockusb protocol

local ret=1

_arguments -s -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'command' \
      'b[reboot device]' \
      'r[read flash (partition or offset/size)]' \
      'w[write flash (partition or offset/size)]' \
      'm[read 0x80 bytes DRAM]' \
      'i[read IDB flash]' \
      'p[fetch parameters]' \
      'e[erase flash (fill with 0xff)]' \
      'l[load DDR init (mask rom mode)]' \
      'L[load USB loader (mask rom mode)]' \
      'v[read chip version]' \
      'n[read NAND flash info]' \
      'j[write IDBlocks]' \
      'M[write SDRAM]' \
      'B[exec SDRAM]' \
      'P[write parameters]' && ret=0
    ;;
  args)
    _arguments ':offset:' ':size:' && ret=0
    ;;
esac

return ret
