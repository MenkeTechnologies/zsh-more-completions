#compdef batgrep
# Documentation: https://github.com/eth-p/bat-extras/blob/master/doc/batgrep.md
# Reference accessed: 2026-05-17
# Verified: eth-p/bat-extras batgrep.md upstream — own flag set
# (-i/--ignore-case, -s/--case-sensitive, -S/--smart-case,
# -A/--after-context, -B/--before-context, -C/--context,
# -p/--search-pattern, --no-follow, --no-snip, --no-highlight,
# --color, --no-color, --paging always|never|auto, --pager,
# --terminal-width, --no-separator, --rga). Most other flags are
# forwarded to ripgrep.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --theme, --style (those belong to bat, not batgrep);
# misnamed --search-pattern (real takes no value: it switches mode).

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case insensitive]' \
  '(-s --case-sensitive)'{-s,--case-sensitive}'[case sensitive]' \
  '(-S --smart-case)'{-S,--smart-case}'[smart case]' \
  '(-A --after-context)'{-A+,--after-context=}'[lines after match]:n:' \
  '(-B --before-context)'{-B+,--before-context=}'[lines before match]:n:' \
  '(-C --context)'{-C+,--context=}'[context lines]:n:' \
  '(-p --search-pattern)'{-p,--search-pattern}'[highlight pattern only]' \
  '--no-follow[do not follow symlinks]' \
  '--no-snip[do not snip files]' \
  '--no-highlight[do not highlight matches]' \
  '--no-separator[no separator between file results]' \
  '--color[force color]' \
  '--no-color[disable color]' \
  '--paging=[paging mode]:mode:(always never auto)' \
  '--pager=[pager command]:cmd:_command_names -e' \
  '--terminal-width=[terminal width]:n:' \
  '--rga[use ripgrep-all for binary files]' \
  '1:pattern:' \
  '*:path:_files' && ret=0
return ret
