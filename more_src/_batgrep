#compdef batgrep

# Zsh completion for batgrep (bat-extras - ripgrep with bat)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--paging=[paging mode]:mode:(auto always never)' \
  '--color=[colorize output]:when:(auto always never)' \
  '--theme=[bat theme]:theme' \
  '--style=[output style]:style' \
  '--context=[context lines]:lines' \
  '--search-pattern=[highlight pattern only]' \
  '--no-highlight[do not highlight matches]' \
  '--no-search-pattern[do not use pattern for searching]' \
  '--no-snip[do not snip]' \
  '--no-follow[do not follow symlinks]' \
  '--no-separator[no separator between file results]' \
  '-i[case insensitive]' \
  '--ignore-case[case insensitive]' \
  '-s[case sensitive]' \
  '--case-sensitive[case sensitive]' \
  '-S[smart case]' \
  '--smart-case[smart case]' \
  '*:pattern' && ret=0

return ret
