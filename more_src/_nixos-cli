#compdef nixos-cli
# _nixos-cli — NixOS system manager CLI alias (NixOS Foundation, Nix); custom argparse
# upstream: https://github.com/NixOS/nixpkgs

_nixos-cli() {
    local -a sub=(
        'rebuild:rebuild and switch system'
        'option:show options'
        'version:show NixOS version'
        'help:show help'
        'install:install NixOS'
        'generate-config:generate config'
        'enter:enter NixOS shell'
        'container:manage NixOS containers'
        'upgrade:upgrade channel'
        'rollback:rollback system'
        'list-generations:list generations'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--max-jobs=+[max jobs]:n:' \
        '-j+[max jobs]:n:' \
        '--cores=+[cores]:n:' \
        '--option=+[option]:str:' \
        '--keep-going[keep going]' \
        '-k[keep going]' \
        '--keep-failed[keep failed]' \
        '-K[keep failed]' \
        '--show-trace[show trace]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-build-output[no build output]' \
        '-Q[no build output]' \
        '--readonly-mode[readonly mode]' \
        '--repair[repair]' \
        '--builders=+[builders]:str:' \
        '--store=+[store URL]:url:_urls' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nixos subcommand' sub ;;
        args)
            case $words[1] in
                rebuild) _arguments \
                    '1:cmd:(switch boot test build dry-build dry-activate edit repl build-vm build-vm-with-bootloader build-image list-generations)' \
                    '--upgrade[upgrade channels first]' \
                    '--upgrade-all[upgrade all channels]' \
                    '--rollback[rollback]' \
                    '--use-substitutes[use substitutes]' \
                    '--install-bootloader[install bootloader]' \
                    '--no-build-nix[no build nix]' \
                    '--use-remote-sudo[use remote sudo]' \
                    '--profile-name=+[profile name]:str:' \
                    '-p+[profile name]:str:' \
                    '--specialisation=+[specialisation]:str:' \
                    '--build-host=+[build host]:host:_hosts' \
                    '--target-host=+[target host]:host:_hosts' \
                    '--use-substitutes[use substitutes]' \
                    '--flake=+[flake]:str:' \
                    '*:arg:' ;;
                container) _arguments \
                    '1:cmd:(list create destroy start stop status root-login show-ip update)' \
                    '*:arg:' ;;
                option) _arguments \
                    '--all[show all]' \
                    '--xml[xml output]' \
                    '--json[json output]' \
                    '*:option:' ;;
                install) _arguments \
                    '--root=+[root]:dir:_files -/' \
                    '--system=+[system]:str:' \
                    '--channel=+[channel]:str:' \
                    '--no-channel-copy[no channel copy]' \
                    '--no-root-passwd[no root passwd]' \
                    '--max-jobs=+[max jobs]:n:' \
                    '--flake=+[flake]:str:' ;;
                enter) _arguments \
                    '--root=+[root]:dir:_files -/' \
                    '--command=+[command]:str:' \
                    '-c+[command]:str:' \
                    '*:arg:' ;;
                rollback|list-generations) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_nixos-cli "$@"
