#compdef gql-tada gql.tada
# ============================================================================
# _gql-tada — zsh completion for 0no-co's gql.tada, "the magical GraphQL
#              query engine for TypeScript" — TS-Node=138 CLOSES Axis 83
#              GraphQL Client Library at 1/1/1 (triple-138 landmark)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/0no-co/gql.tada
#   Maintainer : 0no-co (Phil Plückthun, urql author)
#   License    : MIT
#   Stars      : 2935
#   Language   : TypeScript
#   Package    : gql.tada
#   Binaries   : gql-tada AND gql.tada  (package.json bin maps both
#                names to ./bin/cli.js)
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   gql.tada is "🪄 Magical GraphQL query engine for TypeScript" —
#   Phil Plückthun's compile-time GraphQL machinery that infers the
#   full TypeScript type of every query result directly from the
#   GraphQL schema via TypeScript's type system, without an external
#   codegen pass.  The companion CLI (`gql-tada` / `gql.tada`)
#   ships with seven workspace-scoped subcommands handled by
#   clipanion that complement the type-machinery:  it generates
#   schema artifacts, persisted-query manifests, output bundles,
#   and a "turbo" cache;  it runs schema-aware diagnostics
#   ("check") backed by the gql.tada @0no-co/graphqlsp TypeScript
#   plugin;  it scaffolds new projects ("init");  and it surfaces
#   environment diagnostics ("doctor").  The check command is the
#   primary CI hook — it walks every `gql\`…\`` template literal
#   in the project, type-checks it against the configured schema,
#   and reports diagnostics with configurable severity.
#
# CLI ARGUMENT GRAMMAR  (verbatim from packages/cli-utils/src/
#                       commands/<cmd>/index.ts — clipanion
#                       `Command` subclasses with `Option.*`
#                       declarators)
#   gql-tada <SUBCOMMAND> [OPTIONS]
#
#   Subcommands:
#     check
#       -c, --tsconfig <PATH>     Path to tsconfig.json used to read
#       -w, --fail-on-warn        Exit non-zero on any warning
#       -l, --level <LEVEL>       Minimum severity to display
#                                 [info|warn|error — default: info]
#
#     doctor                       Environment / setup diagnostics
#
#     generate-output | generate output
#       -c, --tsconfig <PATH>     Path to tsconfig.json
#       -o, --output <PATH>       Output file path
#       --force-ts-format         Force `.ts` output format
#                                 [default: false]
#       --disable-preprocessing   Disable schema preprocessing
#                                 [default: false]
#
#     generate-persisted | generate persisted
#       -c, --tsconfig <PATH>     Path to tsconfig.json
#       -o, --output <PATH>       Output manifest path
#       --disable-normalization   Disable persisted-query
#                                 normalization  [default: false]
#       --fail-on-warn            Exit non-zero on any warning
#
#     generate-schema | generate schema  <INPUT>
#       <INPUT>                   Schema source (URL or path)
#       -c, --tsconfig <PATH>     Path to tsconfig.json
#       -o, --output <PATH>       Output schema path
#       --header 'NAME: VALUE'    Custom HTTP header (repeatable)
#
#     init [<DIR>]                 Scaffold a gql.tada setup in DIR
#                                  (default: current directory)
#
#     turbo | generate turbo
#       -c, --tsconfig <PATH>     Path to tsconfig.json
#       -w, --fail-on-warn        Exit non-zero on any warning
#       -o, --output <PATH>       Turbo cache output path
#
#   Standard clipanion auto-flags:
#     -h, --help                  Show help
#     -v, --version               Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `graphql ^15.5.0 || ^16.0.0 || ^17.0.0`
#   declared in packages/cli-utils/package.json — the canonical
#   Node.js GraphQL reference implementation maintained by the
#   GraphQL Foundation (graphql/graphql-js, npm `graphql`).
#   `graphql-js` is THE reference implementation:  it exports
#   `parse`, `buildSchema`, `validate`, `execute`,
#   `introspectionQuery`, `printSchema`, `GraphQLSchema`,
#   `GraphQLObjectType`, the full visitor API, and every type
#   class used by every other Node GraphQL client.  gql.tada's
#   CLI uses `graphql/parse` and `graphql/buildSchema` to drive
#   its TypeScript-type inference engine, and the
#   `@0no-co/graphqlsp` TypeScript Server Plugin re-validates
#   every template-tag against the schema at edit time and
#   compile time.  Verified via:
#     gh api repos/0no-co/gql.tada/contents/package.json
#       → "bin": {"gql.tada": "./bin/cli.js",
#                 "gql-tada": "./bin/cli.js"}
#     gh api repos/0no-co/gql.tada/contents/packages/cli-utils/
#         package.json
#       → "graphql": "^15.5.0 || ^16.0.0 || ^17.0.0"
#     gh api repos/0no-co/gql.tada/contents/packages/cli-utils/
#         src/index.ts
#       → new Cli({binaryName: 'gql.tada'}); cli.register(
#         CheckCommand|DoctorCommand|GenerateOutputCommand|
#         GeneratePersisted|GenerateSchema|InitCommand|
#         TurboCommand)
#   This entry is the TS-Node=138 leader bump that CLOSES Axis 83
#   (GraphQL Client Library) at 1/1/1 three-language symmetry —
#   pairing Rust=graphql_client (R921 _graphql-client),
#   Go=gqlgenc/99designs gqlgen (R922 _gqlgenc), and TS-Node=
#   graphql/graphql-js (this entry).  Triple-138 landmark on
#   commit.
#
#   No completion for `gql-tada` or `gql.tada` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_gql-tada() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_gql-tada_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                check)
                    _arguments \
                        '(-c --tsconfig)'{-c,--tsconfig}'=[path to tsconfig.json]:tsconfig:_files -g "tsconfig*.json"' \
                        '(-w --fail-on-warn)'{-w,--fail-on-warn}'[exit non-zero on any warning]' \
                        '(-l --level)'{-l,--level}'=[minimum severity to display]:severity:(info warn error)' && ret=0 ;;
                doctor)
                    _arguments && ret=0 ;;
                generate-output)
                    _arguments \
                        '(-c --tsconfig)'{-c,--tsconfig}'=[path to tsconfig.json]:tsconfig:_files -g "tsconfig*.json"' \
                        '(-o --output)'{-o,--output}'=[output file path]:output:_files' \
                        '--force-ts-format[force .ts output format]' \
                        '--disable-preprocessing[disable schema preprocessing]' && ret=0 ;;
                generate-persisted)
                    _arguments \
                        '(-c --tsconfig)'{-c,--tsconfig}'=[path to tsconfig.json]:tsconfig:_files -g "tsconfig*.json"' \
                        '(-o --output)'{-o,--output}'=[output manifest path]:output:_files' \
                        '--disable-normalization[disable persisted-query normalization]' \
                        '--fail-on-warn[exit non-zero on any warning]' && ret=0 ;;
                generate-schema)
                    _arguments \
                        '(-c --tsconfig)'{-c,--tsconfig}'=[path to tsconfig.json]:tsconfig:_files -g "tsconfig*.json"' \
                        '(-o --output)'{-o,--output}'=[output schema path]:output:_files' \
                        '*--header=[custom HTTP header (repeatable)]:header:' \
                        ':schema source (URL or path):' && ret=0 ;;
                init)
                    _arguments \
                        ':project dir:_files -/' && ret=0 ;;
                turbo)
                    _arguments \
                        '(-c --tsconfig)'{-c,--tsconfig}'=[path to tsconfig.json]:tsconfig:_files -g "tsconfig*.json"' \
                        '(-w --fail-on-warn)'{-w,--fail-on-warn}'[exit non-zero on any warning]' \
                        '(-o --output)'{-o,--output}'=[turbo cache output path]:output:_files' && ret=0 ;;
                generate)
                    _arguments \
                        '1:generate subcommand:(output persisted schema turbo)' \
                        '*::arg:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_gql-tada_commands] )) ||
_gql-tada_commands() {
    local -a commands
    commands=(
        'check:type-check every gql`...` template against schema'
        'doctor:environment / setup diagnostics'
        'generate-output:generate output bundle'
        'generate-persisted:generate persisted-query manifest'
        'generate-schema:fetch/generate schema artifact'
        'init:scaffold a new gql.tada setup'
        'turbo:generate the turbo cache'
        'generate:generate group (output|persisted|schema|turbo)'
    )
    _describe -t commands 'gql-tada command' commands
}

_gql-tada "$@"
