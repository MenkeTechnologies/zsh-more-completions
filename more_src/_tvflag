#compdef tvflag
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/tvflag.html
# MIRIAD: interactive flagging of UV data on a TV display

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[input UV dataset]:vis:_files' \
  'server=[TV server]:server:' \
  'tvchan=[TV channel number]:tvchan:' \
  'range=[min and max scaling values]:range:' \
  'tvcorn=[lower-left corner device coords]:tvcorn:' \
  'line=[channel line selection]:line:' \
  'mode=[display format]:mode:(amplitude phase real imaginary)' \
  'taver=[running mean time window in minutes]:taver:' \
  'select=[visibility selection]:select:' \
  'options=[nosrc]:options:(nosrc)' \
  '*:image:_files' && ret=0

return ret
