#compdef jupytext

# Zsh completion for jupytext - Jupyter notebooks as text

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--to=[target format]:format:(notebook markdown rmarkdown script auto ipynb md Rmd py R jl)' \
  '--from=[source format]:format:(notebook markdown rmarkdown script auto ipynb md Rmd py R jl)' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '--update[update the output file rather than overwrite]' \
  '--set-formats=[set jupytext formats in notebook metadata]:formats:' \
  '--sync[synchronize all paired representations]' \
  '--pipe=[pipe the notebook through a command]:command:_command_names' \
  '--check=[run a command on the notebook and fail if modified]:command:_command_names' \
  '--test[test round-trip conversion]' \
  '--test-strict[strict round-trip test]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '--opt=[set a jupytext option]:option (key=value):' \
  '--format-options=[set format options]:options:' \
  '--set-kernel=[set the kernel in notebook metadata]:kernel:' \
  '*:notebook files:_files -g "*.{ipynb,md,Rmd,py,R,jl}"'
