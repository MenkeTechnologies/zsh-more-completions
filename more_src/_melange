#compdef melange

local curcontext="$curcontext" state line ret=1

_melange_commands() {
  local -a commands=(
    'build:build an APK from a YAML configuration'
    'bump:bump package version in a melange config'
    'completion:generate shell completion scripts'
    'convert:convert packages from other formats'
    'index:create an APK package index'
    'keygen:generate a signing key pair'
    'lint:lint a melange YAML file'
    'package-version:report the target package version'
    'query:query an APK index'
    'sign:sign an APK package'
    'update:update a melange config to latest version'
    'version:print the version'
  )
  _describe -t commands 'melange command' commands
}

_arguments -s -S \
  '--cache-dir[directory to store cache]:directory:_directories' \
  '--log-level[log level]:level:(debug info warn error)' \
  '--log-policy[log policy]:policy' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:_melange_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      build)
        _arguments -s -S \
          '--arch[target architecture]:arch' \
          '--build-date[date for build]' \
          '--build-option[build options]:option' \
          '--cache-dir[cache directory]:directory:_directories' \
          '--cpu[CPU to use]:cpu' \
          '--debug[enable debug logging]' \
          '--dependency-log[log dependencies to file]:file:_files' \
          '--empty-workspace[empty workspace before build]' \
          '--env-file[environment file]:file:_files' \
          '--generate-index[generate APKINDEX]' \
          '--guest-dir[guest directory]:directory:_directories' \
          '--keyring-append[keyring to append]:file:_files' \
          '--memory[memory to use]:memory' \
          '--namespace[namespace for build]' \
          '(-o --out-dir)'{-o,--out-dir}'[output directory]:directory:_directories' \
          '--overlay-bindir[overlay binary directory]:directory:_directories' \
          '--pipeline-dir[pipeline directory]:directory:_directories' \
          '(-r --repository-append)'{-r,--repository-append}'[repository to append]:repo' \
          '--runner[runner to use]:runner:(docker bubblewrap)' \
          '--signing-key[signing key file]:file:_files' \
          '--source-dir[source directory]:directory:_directories' \
          '--strip-origin-name[strip origin name]' \
          '--template[template file]:file:_files' \
          '--timeout[build timeout]:timeout' \
          '--workspace-dir[workspace directory]:directory:_directories' \
          '*:config file:_files' && ret=0
        ;;
      keygen)
        _arguments -s -S \
          '--key-name[name for the key]:name' \
          '*:output file:_files' && ret=0
        ;;
      sign)
        _arguments -s -S \
          '--signing-key[signing key file]:file:_files' \
          '*:package file:_files' && ret=0
        ;;
      index)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '--signing-key[signing key]:file:_files' \
          '--source[source directory]:directory:_directories' \
          '*:package file:_files' && ret=0
        ;;
      lint)
        _arguments -s -S \
          '*:config file:_files' && ret=0
        ;;
      convert)
        _arguments -s -S \
          '--out-dir[output directory]:directory:_directories' \
          '*:package:_files' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
