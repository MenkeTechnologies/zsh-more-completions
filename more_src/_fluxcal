#compdef fluxcal
# Documentation: http://psrchive.sourceforge.net/manuals/fluxcal/
# PSRCHIVE: generate flux calibrators.

local ret=1

_arguments -s -S \
  '-d+[calibrator database text file (from pac)]:file:_files' \
  '-i+[separation time interval for flux cal sets]:interval:' \
  '-a+[file format for flux calibrator extension data]:format:' \
  '-e+[file extension for solution output files]:ext:' \
  '*:archive:_files' && ret=0

return ret
