#compdef pdb_head
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Returns the first N coordinate (ATOM/HETATM) lines of the file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[number of coordinate lines to keep, e.g. -100]:line count' \
  '*:PDB file:_files' && ret=0

return ret
