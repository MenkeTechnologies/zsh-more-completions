#compdef nnUNetv2_apply_postprocessing
# Documentation: https://github.com/MIC-DKFZ/nnUNet/blob/master/documentation/how_to_use_nnunet.md
# Apply determined postprocessing to nnU-Net v2 predictions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[folder with predictions]:input folder:_files -/' \
  '-o[output folder]:output folder:_files -/' \
  '--pp_pkl_file[postprocessing pickle file]:pp file:_files' \
  '-plans_json[plans json file]:plans json:_files' \
  '-dataset_json[dataset json file]:dataset json:_files' \
  '*:arg:_files' && ret=0

return ret
