#compdef pilot-discovery
# Documentation: https://man.archlinux.org/search?q=pilot-discovery
# Reference accessed: 2026-05-16

# pilot-discovery: Istio control plane (discovery component)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'discovery:run discovery server'
  'request:make a request to admin API'
  'completion:emit shell completion'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--keepaliveInterval=[grpc keepalive interval]:duration:' \
  '--keepaliveTimeout=[grpc keepalive timeout]:duration:' \
  '--keepaliveMaxServerConnectionAge=[max server conn age]:duration:' \
  '--secureGRPCAddr=[secure grpc addr]:addr:' \
  '--grpcAddr=[grpc addr]:addr:' \
  '--monitoringAddr=[monitoring addr]:addr:' \
  '--httpsAddr=[https addr]:addr:' \
  '--httpAddr=[http addr]:addr:' \
  '--ctrlz_port=[ctrlz port]:port:' \
  '--ctrlz_address=[ctrlz address]:addr:' \
  '--meshConfig=[mesh config file]:file:_files' \
  '--networksConfig=[networks config file]:file:_files' \
  '--registries=[registries]:list:' \
  '--namespace=[k8s namespace]:ns:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--profile[enable pprof]' \
  '--log_as_json[log as json]' \
  '--log_caller=[log caller scope]:scope:' \
  '--log_output_level=[log output level]:level:' \
  '--log_stacktrace_level=[log stacktrace level]:level:' \
  '--log_target=[log target]:target:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'pilot-discovery command' commands && ret=0 ;;
esac
return ret
