#compdef dwg2pdf dwg2svg dwg2bmp dwg2png dwg2jpeg dwg2tiff dwg2gcode
# Documentation: https://man.archlinux.org/search?q=dwg2pdf
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,-help,--help}'[show help]' \
  '(-f -force --force)'{-f,-force,--force}'[overwrite existing output]' \
  '(-o -output --output)'{-o+,-output=,--output=}'[output file]:file:_files' \
  '-d+[debug level]:n:' \
  '-auto-fit[auto fit content]' \
  '-auto-orientation[auto detect page orientation]' \
  '-center[center content]' \
  '-flat[flatten to 2D]' \
  '-monochrome[render in monochrome]' \
  '-color-correction[apply color correction]' \
  '-page-size=[page size]:size:(A0 A1 A2 A3 A4 A5 Letter Legal Tabloid)' \
  '-resolution=[resolution (dpi)]:dpi:' \
  '-grayscale[grayscale output]' \
  '-no-margin[no page margin]' \
  '-margin=[page margin (mm)]:mm:' \
  '-pages=[page list]:list:' \
  '-scale=[scale factor]:scale:' \
  '-platform[Qt platform]:plat:(offscreen minimal xcb cocoa wayland)' \
  '*:cad_file:_files -g "*.{dxf,dwg,jww}"' && ret=0

return ret
