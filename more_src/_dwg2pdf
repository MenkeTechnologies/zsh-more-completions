#compdef dwg2pdf dxf2pdf
# Documentation: https://www.qcad.org/en/qcad-command-line-tools
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for QCAD's dwg2pdf / dxf2pdf - DWG/DXF to PDF converter

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,-help,--help}'[show help]' \
  '(-f -force --force)'{-f,-force,--force}'[overwrite existing output]' \
  '(-o -outfile --outfile)'{-o+,-outfile=,--outfile=}'[output PDF file]:file:_files' \
  '(-a -auto-fit)'{-a,-auto-fit}'[auto fit and center drawing to paper]' \
  '-auto-orientation[auto paper orientation by document bbox]' \
  '(-c -center)'{-c,-center}'[auto center drawing on paper]' \
  '(-l -landscape)'{-l,-landscape}'[landscape mode]' \
  '(-p -paper)'{-p+,-paper=}'[paper size (e.g. A4, Letter, WxH)]:size:(A0 A1 A2 A3 A4 A5 Letter Legal Tabloid)' \
  '(-s -scale)'{-s+,-scale=}'[drawing scale (e.g. 1:5)]:scale:' \
  '-offset=[offset in drawing units (X,Y)]:offset:' \
  '(-m -margin)'{-m+,-margin=}'[paper margin]:mm:' \
  '-block=[export specific blocks or layouts]:names:' \
  '-layer=[export specific layers]:names:' \
  '(-k -grayscale)'{-k,-grayscale}'[grayscale output]' \
  '(-n -monochrome)'{-n,-monochrome}'[monochrome (black/white)]' \
  '-color-correction[prevent white-on-white or black-on-black]' \
  '-pdf-version=[PDF version]:ver:(1.4 1.6 A-1B)' \
  '-printer=[print to a printer]:printer:' \
  '(-d -recompute-dim)'{-d,-recompute-dim}'[recompute empty dimension blocks]' \
  '(-fs -font-substitution)'{-fs,-font-substitution}'[replace specific fonts]' \
  '-platform[Qt platform]:plat:(offscreen minimal xcb cocoa wayland)' \
  '*:cad file:_files -g "*.{dxf,dwg}"' && ret=0

return ret
