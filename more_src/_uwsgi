#compdef uwsgi

# Zsh completion for uwsgi - uWSGI application server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--http=[add an HTTP socket]:address\:port' \
  '--http-socket=[bind to specified HTTP socket]:address\:port' \
  '--socket=[bind to specified UNIX/TCP socket]:socket' \
  '--uwsgi-socket=[bind to specified uwsgi socket]:socket' \
  '--fastcgi-socket=[bind to specified FastCGI socket]:socket' \
  '--wsgi-file=[load specified .wsgi file]:file:_files -g "*.py"' \
  '--module=[load a WSGI module]:module' \
  '--callable=[set WSGI callable name]:name' \
  '--wsgi=[load a WSGI module]:module' \
  '--ini=[load config from ini file]:file:_files -g "*.ini"' \
  '--yaml=[load config from YAML file]:file:_files -g "*.{yml,yaml}"' \
  '--json=[load config from JSON file]:file:_files -g "*.json"' \
  '--xml=[load config from XML file]:file:_files -g "*.xml"' \
  '--config=[load config from file]:file:_files' \
  '--processes=[spawn specified number of worker processes]:number' \
  '--workers=[spawn specified number of worker processes]:number' \
  '--threads=[run each worker in prethreaded mode with specified threads]:number' \
  '--harakiri=[set harakiri timeout]:seconds' \
  '--harakiri-verbose[enable verbose harakiri mode]' \
  '--master[enable master process]' \
  '--no-orphans[automatically kill workers if master dies]' \
  '--reload-on-rss=[reload worker if RSS exceeds specified size]:megabytes' \
  '--reload-on-as=[reload worker if address space exceeds specified size]:megabytes' \
  '--max-requests=[reload workers after specified number of requests]:number' \
  '--max-worker-lifetime=[reload workers after specified seconds]:seconds' \
  '--listen=[set listen queue size]:number' \
  '--buffer-size=[set internal buffer size]:bytes' \
  '--post-buffering=[enable post buffering]:bytes' \
  '--chmod-socket=[set socket permissions]:permissions' \
  '--chown-socket=[set socket ownership]:uid\:gid' \
  '--uid=[setuid to specified user]:user:_users' \
  '--gid=[setgid to specified group]:group:_groups' \
  '--chdir=[chdir to specified directory]:directory:_files -/' \
  '--chdir2=[chdir to specified directory after loading apps]:directory:_files -/' \
  '--home=[set virtualenv]:directory:_files -/' \
  '--virtualenv=[set virtualenv]:directory:_files -/' \
  '--venv=[set virtualenv]:directory:_files -/' \
  '--pyhome=[set Python home]:directory:_files -/' \
  '--pythonpath=[add Python path]:directory:_files -/' \
  '--env=[set environment variable]:KEY=VALUE' \
  '--vacuum[try to remove all generated sockets/pidfiles on exit]' \
  '--pidfile=[create pidfile]:file:_files' \
  '--pidfile2=[create pidfile before privileges drop]:file:_files' \
  '--daemonize=[daemonize and log to file]:log file:_files' \
  '--daemonize2=[daemonize and log to file after app loading]:log file:_files' \
  '--logto=[set logfile]:file:_files' \
  '--logto2=[set logfile after privileges drop]:file:_files' \
  '--log-maxsize=[rotate log after specified size]:bytes' \
  '--disable-logging[disable request logging]' \
  '--stats=[enable stats server on specified address]:address\:port' \
  '--stats-http[prefix stats server JSON output with HTTP headers]' \
  '--emperor=[run the Emperor]:glob pattern:_files -/' \
  '--emperor-tyrant[put the Emperor in Tyrant mode]' \
  '--emperor-stats=[set Emperor stats server address]:address\:port' \
  '--auto-procname[automatically set process names]' \
  '--procname-prefix=[add prefix to process names]:prefix' \
  '--enable-threads[enable threads]' \
  '--single-interpreter[do not use multiple interpreters]' \
  '--lazy[set lazy mode (load apps in workers)]' \
  '--lazy-apps[load apps in each worker]' \
  '--thunder-lock[serialize accept() on fd]' \
  '--static-map=[map mountpoint to static directory]:mountpoint=path' \
  '--static-map2=[like static-map but falls through]:mountpoint=path' \
  '--offload-threads=[set number of offload threads]:number' \
  '--route=[add a route]:route rule' \
  '--route-host=[add route based on Host header]:pattern action' \
  '--cache2=[create a cache]:spec' \
  '--queue=[enable shared queue of specified size]:number' \
  '--spooler=[run a spooler on specified directory]:directory:_files -/' \
  '--mule=[add a mule]:mule' \
  '--farm=[add a mule farm]:name\:mule_id[,mule_id...]' \
  '--attach-daemon=[attach external daemon]:command' \
  '--plugins=[load specified plugins]:plugins' \
  '--plugin=[load specified plugin]:plugin' \
  '--need-plugin=[load specified plugin (exit on fail)]:plugin' \
  '--logformat=[set log format]:format' \
  '--log-format=[set log format]:format' \
  '--touch-reload=[reload uWSGI if the specified file is modified]:file:_files' \
  '--touch-chain-reload=[trigger chain reload on file touch]:file:_files' \
  '--touch-logreopen=[trigger log reopen on file touch]:file:_files' \
  '--die-on-term[exit instead of brutal reload on SIGTERM]' \
  '--need-app[exit if no app can be loaded]' \
  '--strict[enable strict mode (config errors are fatal)]' \
  '--cheaper=[set cheaper mode (adaptive process spawning)]:minimum workers' \
  '--cheaper-algo=[set cheaper algorithm]:algorithm:(spare spare2 busyness backlog)' \
  '--cheaper-step=[number of workers to spawn at a time]:number' \
  '--close-on-exec[set close-on-exec on sockets]' \
  '--so-keepalive[enable TCP keepalive]' \
  '--check-static=[check for static files in directory]:directory:_files -/' \
  '--static-expires-type=[set Expires header for content types]:content_type=seconds' \
  '--manage-script-name[automatically rewrite SCRIPT_NAME and PATH_INFO]' \
  '--mount=[load app under mountpoint]:mountpoint=app' \
  '--protocol=[force specified protocol]:protocol:(uwsgi http fastcgi scgi)' \
  '--show-config[show current config]' \
  '--print=[print specified string]:string' \
  '--version[print uWSGI version]' \
  '*:file:_files' && ret=0

return ret
