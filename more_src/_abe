#compdef abe
# ============================================================================
# _abe — zsh completion for abecms's `abe`, a JavaScript "lightning
#         fast" CMS / static-site CLI (mongodb ^4.9.1)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/abecms/abecms
#   Author     : abe community (originally Antoine "ouafik" Henoux)
#   License    : MIT
#   Language   : JavaScript (Node.js, babel-compiled)
#   Package    : abecms v5.10.2
#   Binary     : abe  (package.json bin: dist/index.js)
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   abecms (the `abe` CLI) is "a lightning-fast CMS" — a Node.js
#   static-site CMS that authors structured content through a web
#   UI (themed templates + Markdown bodies), persists post metadata
#   in MongoDB, generates a static HTML site, and deploys the result
#   through pluggable backends (Surge, GitHub Pages, S3, SFTP).
#   The `abe` binary drives the full project lifecycle:  bootstrap
#   a new website (init), scaffold a new project tree (create),
#   regenerate all posts from filesystem content (generate-posts),
#   run the dev/preview web server (serve), and manage plugins +
#   Surge auth.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/index.js commander.js
#                       `program.command(...)` builders)
#   abe <SUBCOMMAND> [args...]
#
#   Top-level options:
#     -v, --version              Show version
#     -h, --help                 Show help
#
#   Subcommands (with aliases):
#     init           | i         Init a new abe website
#                                (interactive wizard:  picks plugins,
#                                MongoDB connection, deployer target)
#
#     create [PATH]  | c         Create a new abe project (writes
#                                a fresh tree at PATH or current
#                                directory)
#
#     generate-posts | gp        Save posts to files from folder
#       -t, --type <TYPE>          Posts status (draft / other)
#       -p, --path <PATH>          Relative path inside the project
#       -d, --destination <DIR>    Folder to save result
#
#     serve          | s         Run the abe dev / preview web
#                                server
#       -p, --port <N>             Web-server port
#       -i, --interactive          Open the browser on startup
#       -t, --templates <PATH>     Templates directory
#       -a, --assets    <PATH>     Static assets directory
#       -d, --destination <PATH>   Build output directory
#       -j, --json <PATH>          JSON data directory
#       -e, --env <ENV>            Environment
#                                  (development / production / ...)
#
#     install [PLUGIN]           Install abe plugin(s) — runs
#                                `npm install` for the plugin
#                                package in the project root
#
#     uninstall <PLUGIN> | un    Uninstall abe plugin(s)
#
#     login                      Log into Surge (for the surge.sh
#                                deployer target)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `mongodb ^4.9.1` declared in package.json
#   — the canonical official Node.js MongoDB driver maintained by
#   MongoDB Inc (mongodb/node-mongodb-native, npm `mongodb`).  The
#   driver provides typed `MongoClient.connect(uri)` factories,
#   `Db` / `Collection` constructors, BSON document support, change
#   streams, transactions, GridFS, retryable reads/writes, SDAM
#   topology discovery, and Promise + AsyncIterable cursor APIs.
#   abecms uses the driver directly in `src/cli/cms/operations/`
#   for post storage:  on startup it constructs a `MongoClient`
#   from the connection string in the project config, opens the
#   abe-content database, and serves CRUD over the posts +
#   revisions collections.  Verified via:
#     gh api repos/abecms/abecms/contents/package.json
#       → "mongodb": "^4.9.1"
#       → "bin": {"abe": "dist/index.js"}
#     gh api repos/abecms/abecms/contents/src/index.js
#       → program.command('init').alias('i')...
#         program.command('serve').alias('s')...
#         program.command('install [plugin]')...
#   This entry is the TS-Node=135 leader bump that CLOSES Axis 80
#   (MongoDB Driver Library) at 1/1/1 three-language symmetry —
#   pairing Rust=mongodb 3.0.0 (R909 _mongobar), Go=mongo-driver
#   v1.14.0 (R910 _vi-mongo), and TS-Node=node-mongodb ^4.9.1
#   (this entry).  Triple-135 landmark on commit.
#
#   No completion for `abe` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_abe() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-v,--version}'[show version]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_abe_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init|i)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
                create|c)
                    _arguments \
                        ':project path:_files -/' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                generate-posts|gp)
                    _arguments \
                        '(-t --type)'{-t+,--type=}'[posts status (draft/other)]:type:(draft other)' \
                        '(-p --path)'{-p+,--path=}'[relative path inside the project]:path:_files -/' \
                        '(-d --destination)'{-d+,--destination=}'[folder to save result]:destination:_files -/' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                serve|s)
                    _arguments \
                        '(-p --port)'{-p+,--port=}'[web server port]:port:' \
                        '(-i --interactive)'{-i,--interactive}'[open browser on startup]' \
                        '(-t --templates)'{-t+,--templates=}'[templates directory]:path:_files -/' \
                        '(-a --assets)'{-a+,--assets=}'[static assets directory]:path:_files -/' \
                        '(-d --destination)'{-d+,--destination=}'[build output directory]:path:_files -/' \
                        '(-j --json)'{-j+,--json=}'[JSON data directory]:path:_files -/' \
                        '(-e --env)'{-e+,--env=}'[environment]:env:(development production staging)' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                install)
                    _arguments \
                        ':plugin name:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                uninstall|un)
                    _arguments \
                        ':plugin name:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                login)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_abe_commands] )) ||
_abe_commands() {
    local -a commands
    commands=(
        'init:init a new abe website'
        'i:init a new abe website (alias)'
        'create:create a new abe project'
        'c:create a new abe project (alias)'
        'generate-posts:save posts to files from folder'
        'gp:generate-posts (alias)'
        'serve:run the abe dev/preview web server'
        's:serve (alias)'
        'install:install abe plugin(s)'
        'uninstall:uninstall abe plugin(s)'
        'un:uninstall (alias)'
        'login:log into Surge for the surge.sh deployer'
    )
    _describe -t commands 'abe command' commands
}

_abe "$@"
