#compdef earthtide
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/geodesy/earthtide.html
# Source: GenericMappingTools/gmt supplements/geodesy — compute solid-Earth tides (east/north/vertical).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-S[output Sun + Moon positions]' \
    '-L+[time-series at lon/lat]:lonlat:_default' \
    '-T+[evenly spaced time steps (min/max/inc)]:opts:_default' \
    '-C+[components to write (x/e, y/n, z/v)]:components:_default' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-r[pixel registration (default gridline)]' \
    '-bo+[binary output format]:format:_default' \
    '-o+[output column selection]:cols:_default' \
    && ret=0

return ret
