#compdef gimp-test-clipboard
# Documentation: https://github.com/GNOME/gimp/blob/master/tools/gimp-test-clipboard.c
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gimp-test-clipboard: debug helper for GIMP clipboard handling
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-v[verbose]' \
  '-c[copy image to clipboard]:file:_files -g "*.(png|jpg|jpeg|gif|tif|tiff|bmp|xcf)"' \
  '-p[paste clipboard image to file]:file:_files' \
  '*:files:_files' && ret=0
return ret
