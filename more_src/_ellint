#compdef ellint
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/ellint.html
# MIRIAD: integrate an image in elliptical annuli

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image]:in:_files' \
  'out=[output residual image]:out:_files' \
  'region=[region of interest]:region:' \
  'center=[annuli center offset in arcsec]:center:' \
  'pa=[ellipse major axis position angle]:pa:' \
  'incline=[inclination angle in degrees]:incline:' \
  'radius=[inner/outer radii and step]:radius:' \
  'telescop=[primary beam type override]:telescop:' \
  'scale=[amplitude scale factor]:scale:' \
  'options=[pbcorr,median,mode,natural,table,spline]:options:(pbcorr median mode natural table spline)' \
  'medsmooth=[radial profile smoothing]:medsmooth:' \
  'log=[output log file]:log:_files' \
  '*:image:_files' && ret=0

return ret
