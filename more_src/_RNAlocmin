#compdef RNAlocmin
# Documentation: https://www.tbi.univie.ac.at/RNA/RNAlocmin.1.html
# RNAlocmin — calculate local minima from structures via gradient walks (ViennaRNA)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--detailed-help[print help with all details and hidden options]' \
  '--full-help[print help including hidden options]' \
  '(-s --seq)'{-s,--seq}'=[FASTA file with sequence]:file:_files' \
  '(-p --previous)'{-p,--previous}'=[previous LM output]:file:_files' \
  '(-m --move)'{-m,--move}'=[move set]:move:(I S)' \
  '(-n --min-num)'{-n,--min-num}'=[maximum number of local minima]:int' \
  '--find-num=[maximum number of local minima to find]:int' \
  '(-v --verbose-lvl)'{-v,--verbose-lvl}'=[verbosity level]:level:(0 1 2 3 4)' \
  '--depth=[depth of saddle search]:int' \
  '--minh=[print minima with energy barrier greater than this]:double' \
  '--minh-lite[merge structures with smaller energy barrier]' \
  '(-w --walk)'{-w,--walk}'=[walk type]:walk:(D F R)' \
  '--noLP[work only with canonical structures]' \
  '(-e --useEOS)'{-e,--useEOS}'[use energy_of_struct rather than energy_of_move]' \
  '(-P --paramFile)'{-P,--paramFile}'=[read energy parameters from file]:file:_files' \
  '(-d --dangles)'{-d,--dangles}'=[treat dangling end energies]:mode:(0 1 2 3)' \
  '--fix-barriers=[barriers output file to fix]:file:_files' \
  '(-k --pseudoknots)'{-k,--pseudoknots}'[allow pseudoknots in input structures]' \
  '--just-read[just read structures and find their local minima]' \
  '(-N --neighborhood)'{-N,--neighborhood}'[output neighbourhood (rates)]' \
  '--degeneracy-off[turn off degeneracy approach]' \
  '--just-output[do not collect/cluster, just output]' \
  '(-b --bartree)'{-b,--bartree}'[generate a barrier tree]' \
  '--barr-name=[barrier tree output filename]:file:_files' \
  '--barrier-file=[saddle heights output file]:file:_files' \
  '(-r --rates)'{-r,--rates}'[create rates for treekin]' \
  '(-f --rates-file)'{-f,--rates-file}'=[rates output filename]:file:_files' \
  '(-T --temp)'{-T,--temp}'=[temperature in C]:double' \
  '--floodPortion[flood portion of conformation space]:double' \
  '--floodMax=[maximum number of flooded structures]:int' \
  '--numIntervals=[number of intervals for energy histogram]:int' \
  '--eRange=[energy range in kcal/mol]:float' \
  '--allegiance=[allegiance output filename]:file:_files' && ret=0

return ret
