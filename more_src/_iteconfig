#compdef iteconfig
# Documentation: man iteconfig(8)
# Source: netbsd/src usr.sbin/iteconfig — console bell and display attributes (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i[display current console state]' \
    '-f+[terminal device (default /dev/ttye0)]:file:_files' \
    '-v+[bell volume (0-63)]:volume:_default' \
    '-p+[bell pitch (10-1399)]:pitch:_default' \
    '-t+[beep duration in msec (1-5000)]:msec:_default' \
    '-w+[display width in pixel columns]:width:_default' \
    '-h+[display height in pixel rows]:height:_default' \
    '-d+[bitplane count for color display]:depth:_default' \
    '-x+[horizontal display offset]:offset:_default' \
    '-y+[vertical display offset]:offset:_default' \
    '*:color (0xRRGGBB, 0xGG, or 0xM):_default' \
    && ret=0

return ret
