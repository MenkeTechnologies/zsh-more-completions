#compdef binfmt
# _binfmt — systemd-binfmt-tools systemd-managed binfmt CLI generator wrapper around /proc/sys/fs/binfmt_misc handling registering matching unregistering custom executable formats interpreter glob magic offset mask flags for QEMU user emulation Mono Java DOSemu Wine binary dispatch (systemd team, C); getopt
# upstream: https://www.kernel.org/doc/html/latest/admin-guide/binfmt-misc.html

_binfmt() {
    local -a sub=(
        'register:register a new binfmt rule'
        'unregister:unregister a binfmt rule'
        'status:show binfmt status'
        'enable:enable binfmt_misc'
        'disable:disable binfmt_misc'
        'list:list configured rules'
        'flush:remove all rules'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-n+[name]:str:' \
        '--name=+[name]:str:' \
        '-m+[magic]:str:' \
        '--magic=+[magic]:str:' \
        '-M+[mask]:str:' \
        '--mask=+[mask]:str:' \
        '-o+[offset]:n:' \
        '--offset=+[offset]:n:' \
        '-e+[extension]:str:' \
        '--extension=+[extension]:str:' \
        '-t+[type]:t:(M E)' \
        '--type=+[type]:t:(M E)' \
        '-i+[interpreter]:file:_files' \
        '--interpreter=+[file]:file:_files' \
        '-f+[flags]:str:' \
        '--flags=+[flags]:str:(O C P F)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'binfmt subcommand' sub ;;
        args)
            case $words[1] in
                unregister) _arguments '1:name:' ;;
                register) _arguments '1:name:' ;;
            esac
            ;;
    esac
}

_binfmt "$@"
