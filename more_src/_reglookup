#compdef reglookup
# Documentation: https://linux.die.net/man/1/reglookup
# Windows NT+ registry reader/lookup tool

local ret=1

_arguments -s -S \
  '-p[path prefix filter]:prefix' \
  '-t[data type filter]:type:(NONE SZ EXPAND_SZ BINARY DWORD DWORD_BE LINK MULTI_SZ RSRC_LIST RSRC_DESC RSRC_REQ_LIST QWORD KEY)' \
  '-h[enable column header row]' \
  '-H[disable column header row]' \
  '-i[printed values inherit parent key timestamp]' \
  '-s[add security descriptor columns]' \
  '-S[disable security descriptor output]' \
  '-v[verbose output]' \
  '*:registry file:_files' && ret=0

return ret
