#compdef cargo-clean-recursive
# _cargo-clean-recursive — recursive cargo clean across nested workspaces (IgaguriMK/cargo-clean-recursive)
# upstream: https://github.com/IgaguriMK/cargo-clean-recursive
# Flags from src/main.rs (clap).

_cargo-clean-recursive() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-d --doc)'{-d,--doc}'[delete docs]' \
        '(-r --release)'{-r,--release}'[delete release target]' \
        '(-n --dry-run)'{-n,--dry-run}'[print without deleting]' \
        '--depth=[recursive search depth limit]:n:' \
        '*--skips=[directory names to skip scanning]:dir:' \
        '--io-error-handling=[IO error policy]:mode:(raise-unexpected raise-all skip)' \
        '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
        '1:target dir:_files -/'
}

_cargo-clean-recursive "$@"
