#compdef sampler
# Documentation: https://github.com/sqshq/sampler
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-c --config)'{-c,--config}'[configuration file (YAML)]:file:_files' \
  '*'{-v,--variable}'[set a variable for use in scripts]:name=value:' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0
return ret
