#compdef tfx
# Documentation: https://tfx.rocks/commands/workspace/
# tfx - standalone CLI for HCP Terraform and Terraform Enterprise

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--token=[API authentication token]:token' \
  '--tfe-hostname=[Terraform Enterprise/Cloud instance hostname]:hostname' \
  '--tfe-organization=[target organization]:org' \
  '1:command:(workspace ws organization project variable-set registry run plan apply release admin)' \
  '*::arg:_default' && ret=0

return ret
