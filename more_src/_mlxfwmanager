#compdef mstfwmanager mlxfwmanager

# mstfwmanager (a.k.a. mlxfwmanager): firmware update wrapper for Mellanox cards
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-d[device]:dev:' \
  '--dev=[device]:dev:' \
  '-i[firmware image]:file:_files' \
  '--image=[firmware image]:file:_files' \
  '-y[answer yes]' \
  '--yes[answer yes]' \
  '-u[update mode]' \
  '--update[update mode]' \
  '-f[force update]' \
  '--force[force update]' \
  '-q[query only]' \
  '--query[query only]' \
  '--online[try online update via mlxup]' \
  '--no-reset[do not reset device]' \
  '--no-progress[no progress bar]' \
  '*::mstfwmanager args:_files' && ret=0
return ret
