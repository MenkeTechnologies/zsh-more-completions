#compdef create-eth-app
# Documentation: https://www.npmjs.com/package/create-eth-app
# Reference accessed: 2026-05-23
# Verified: npx create-eth-app --help.

# Zsh completion for create-eth-app - bootstrap an Ethereum dApp

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --framework)'{-f,--framework=}'[UI framework]:framework:' \
  '(-t --template)'{-t,--template=}'[custom template]:template:' \
  ':project directory:_directories' && ret=0

return ret
