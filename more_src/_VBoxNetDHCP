#compdef VBoxNetDHCP
# Documentation: https://docs.oracle.com/en/virtualization/virtualbox/6.0/user/vboxmanage-dhcpserver.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# VBoxNetDHCP: VirtualBox built-in DHCP server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--network=[network name]:name:' \
  '--trunk-name=[trunk name]:name:' \
  '--trunk-type=[trunk type]:type:(none whatever netflt netadp srvnat)' \
  '--mac-address=[server MAC]:mac:' \
  '--ip-address=[server IP]:ip:' \
  '--netmask=[netmask]:mask:' \
  '--lower-ip=[lower IP of range]:ip:' \
  '--upper-ip=[upper IP of range]:ip:' \
  '--begin-config[begin config]' \
  '--end-config[end config]' \
  '--global[global option]' \
  '--group=[option group]:name:' \
  '--mac=[MAC binding]:mac:' \
  '--vm=[VM binding]:uuid:' \
  '--id=[option id]:id:' \
  '--option=[set option (key=value)]:kv:' \
  '--add-opt=[add option]:kv:' \
  '--del-opt=[delete option]:key:' \
  '--zap-options[zap options]' \
  '--min-lease-time=[min lease time]:seconds:' \
  '--default-lease-time=[default lease time]:seconds:' \
  '--max-lease-time=[max lease time]:seconds:' \
  '--persistent-leases-mode=[persistent leases mode]:mode:(yes no)' \
  '--forced-options=[forced options]:list:' \
  '--suppressed-options=[suppressed options]:list:' \
  '*::VBoxNetDHCP args:_files' && ret=0
return ret
