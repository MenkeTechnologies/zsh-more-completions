#compdef VBoxNetDHCP
# Documentation: https://github.com/mirror/vbox/blob/master/src/VBox/NetworkServices/Dhcpd/Config.cpp
# Reference accessed: 2026-05-21
# Verified: upstream VirtualBox Dhcpd Config.cpp source (RTGetOpt option array).

# VBoxNetDHCP: VirtualBox built-in DHCP server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--comment=[comment]:str:' \
  '(-c --config)'{-c+,--config=}'[configuration file]:file:_files' \
  '(-l --log)'{-l+,--log=}'[log destination]:dest:' \
  '(-d --log-destinations)'{-d+,--log-destinations=}'[log destinations]:dests:' \
  '(-f --log-flags)'{-f+,--log-flags=}'[log flags]:flags:' \
  '(-g --log-group-settings)'{-g+,--log-group-settings=}'[log group settings]:settings:' \
  '(-r --relaxed -s --strict)'{-r,--relaxed}'[relaxed mode]' \
  '(-s --strict -r --relaxed)'{-s,--strict}'[strict mode]' && ret=0
return ret
