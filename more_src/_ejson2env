#compdef ejson2env
# Documentation: https://github.com/Shopify/ejson2env
# ejson2env - decrypt EJSON secrets and export them as environment variables

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print the version]' \
  '(-k --keydir)'{-k,--keydir=}'[directory containing EJSON keys]:dir:_files -/' \
  '--key-from-stdin[read the private key from STDIN]' \
  '(-q --quiet)'{-q,--quiet}'[suppress export statement]' \
  '--trim-underscore[trim leading underscore from variable names]' \
  '*:ejson file:_files -g "*.ejson"' && ret=0

return ret
