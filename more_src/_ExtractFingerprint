#compdef ExtractFingerprint
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#ExtractFingerprint
# Picard: extract a fingerprint (VCF) from a SAM/BAM/CRAM file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM/BAM/CRAM file]:bam:_files -g "*.(bam|sam|cram)"' \
  {-O=,--OUTPUT=}'[output fingerprint file (VCF)]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  {-H=,--HAPLOTYPE_MAP=}'[file of haplotype information for fingerprinting]:file:_files' \
  {-C=,--CONTAMINATION=}'[estimated contamination in the input]:float:' \
  '--SAMPLE_ALIAS=[sample alias to associate with the fingerprint]:alias:' \
  '--LOCUS_MAX_READS=[max reads to use as evidence per locus]:int:' \
  '--EXTRACT_CONTAMINATION=[extract the contaminating sample fingerprint instead]:bool:(true false)' \
  '--TEST_INPUT_READABILITY=[check input files for readability]:bool:(true false)' \
  '--EXTRACT_NON_REPRESENTATIVES_TOO=[extract variants for every SNP in the database]:bool:(true false)' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:argument:_files' && ret=0

return ret
