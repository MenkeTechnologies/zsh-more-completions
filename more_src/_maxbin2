#compdef run_MaxBin.pl maxbin2
# MaxBin2 — binning metagenomic contigs using abundance and tetranucleotide frequency

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-contig[input contig FASTA file]:contig file:_files' \
  '-out[output file prefix]:output prefix:_files' \
  '-abund[abundance file (from jgi_summarize_bam_contig_depths or similar)]:abundance file:_files' \
  '-abund_list[list file of abundance files]:abundance list:_files' \
  '-reads[input reads FASTQ for abundance estimation]:reads file:_files' \
  '-reads_list[list file of reads files]:reads list:_files' \
  '-thread[number of threads]:threads' \
  '-min_contig_length[minimum contig length]:length' \
  '-max_iteration[maximum EM iterations]:iterations' \
  '-prob_threshold[probability threshold for binning]:threshold' \
  '-plotmarker[generate marker gene plots]' \
  '-markerset[marker gene set to use]:set:(107 40)' \
  '-verbose[verbose output]' \
  '-reassembly[perform reassembly]' \
  && ret=0

return ret
