#compdef perses
# Documentation: https://github.com/perses/perses/blob/main/docs/configuration/configuration.md
# Perses observability dashboard server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-config=[path to the YAML configuration file for the API]:config:_files' \
  '-log.format=[log format]:format:(text json)' \
  '-log.level=[log level]:level:(panic fatal error warning info debug trace)' \
  '-log.method-trace[include the calling method as a field in the log]' \
  '-pprof[enable pprof]' \
  '-web.hide-port[do not print the listened port on stdout]' \
  '-web.listen-address=[address to listen on for HTTP requests, web interface and telemetry]:address:' \
  '-web.telemetry-path=[path under which to expose metrics]:path:' \
  '-web.tls-cert-file=[path to the cert to use for the HTTPS server]:cert:_files' \
  '-web.tls-key-file=[path to the key to use for the HTTPS server]:key:_files' \
  '-web.tls-cipher-suites=[comma-separated list of TLS cipher suite names]:suites:' \
  '-web.tls-min-version=[minimum TLS version]:version:(1.2 1.3)' \
  '-web.tls-max-version=[maximum TLS version]:version:(1.2 1.3)' && ret=0

return ret
