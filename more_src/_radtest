#compdef radtest
# _radtest — FreeRADIUS radtest (shell wrapper around radclient(1) that builds a simple PAP / CHAP / MS-CHAP / EAP-MD5 Access-Request from arguments; positional: user password radius-server[:port] nas-port secret [ppphint] [nasname]; -t auth-type (pap|chap|mschap|eapmd5), -d dictionary, -x debug, -4/-6 IP family, -h help)
# upstream: https://github.com/FreeRADIUS/freeradius-server
# Flags from FreeRADIUS/freeradius-server scripts/radtest on tip.

_radtest() {
    _arguments \
        '-h[show help]' \
        '-t+[auth type]:type:(pap chap mschap eapmd5)' \
        '-d+[dictionary]:dir:_files -/' \
        '-x[debug]' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '1:user:' \
        '2:password:' \
        '3:server[:port]:_hosts' \
        '4:nas-port:' \
        '5:secret:' \
        '6::ppphint:' \
        '7::nasname:'
}

_radtest "$@"
