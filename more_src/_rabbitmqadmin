#compdef rabbitmqadmin

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-H,--host}'=[server hostname]:host:_hosts' \
  {-P,--port}'=[server port]:port' \
  {-V,--vhost}'=[virtual host]:vhost' \
  {-u,--username}'=[username]:username' \
  {-p,--password}'=[password]:password' \
  '--ssl[connect using SSL]' \
  {-f,--format}'=[output format]:format:(table long pretty_json kvp tsv raw_json bash)' \
  {-d,--depth}'=[depth for JSON output]:depth' \
  {-s,--sort}'=[sort column]:column' \
  '--sort-reverse[reverse sort order]' \
  {-N,--node}'=[target node]:node' \
  {-c,--config}'=[config file]:config file:_files' \
  {-b,--bash-completion}'[print bash completion script]' \
  {-q,--quiet}'[suppress informational messages]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'list:List objects'
      'show:Show overview'
      'declare:Declare an object'
      'delete:Delete an object'
      'close:Close a connection'
      'purge:Purge a queue'
      'get:Get messages from a queue'
      'publish:Publish a message to an exchange'
      'export:Export broker definitions'
      'import:Import broker definitions'
    )
    _describe -t commands 'rabbitmqadmin command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      list)
        local -a list_objects=(
          'queues' 'exchanges' 'bindings' 'connections' 'channels'
          'consumers' 'permissions' 'policies' 'nodes' 'vhosts' 'users'
        )
        _describe -t objects 'object type' list_objects && ret=0
        ;;
      declare)
        local -a declare_objects=(
          'queue' 'exchange' 'binding' 'vhost' 'user' 'permission' 'policy' 'parameter'
        )
        _describe -t objects 'object type' declare_objects && ret=0
        ;;
      delete)
        local -a delete_objects=(
          'queue' 'exchange' 'binding' 'vhost' 'user' 'permission' 'policy' 'parameter'
        )
        _describe -t objects 'object type' delete_objects && ret=0
        ;;
      close)
        _describe -t objects 'object type' '(connection)' && ret=0
        ;;
      purge)
        _describe -t objects 'object type' '(queue)' && ret=0
        ;;
      show)
        _describe -t objects 'object type' '(overview)' && ret=0
        ;;
      import|export)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
