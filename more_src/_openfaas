#compdef openfaas
# Documentation: https://docs.openfaas.com/cli/install/
# Reference accessed: 2026-05-20
# Verified: OpenFaaS CLI binary is `faas-cli`, not `openfaas`. There is no
# canonical `openfaas` executable upstream.
# STUB: minimal completion retained per "do not delete files" directive.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*::passthrough:_command_names' && ret=0

return ret
