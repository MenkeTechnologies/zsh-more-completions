#compdef faops
# Documentation: https://github.com/wang-q/faops
# lightweight tool for handling FASTA sequences with subcommands

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    count\:"count base statistics in FASTA files"
    size\:"count total bases in FASTA files"
    masked\:"identify masked or gap regions"
    frag\:"extract subsequences from a FASTA file"
    rc\:"reverse complement a FASTA file"
    one\:"retrieve a single FASTA record"
    some\:"extract multiple FASTA records by name"
    order\:"extract FASTA records in a specified order"
    replace\:"replace headers in a FASTA file"
    filter\:"filter FASTA records by criteria"
    split-name\:"divide sequences by their names"
    split-about\:"partition into chunks of approximate size"
    n50\:"calculate N50 and related metrics"
    dazz\:"rename records for dazz_db compatibility"
    interleave\:"interleave two paired-end files"
    region\:"extract genomic regions from FASTA"
    help\:"display usage information"
  ))' \
  '*::args:_files' && ret=0

return ret
