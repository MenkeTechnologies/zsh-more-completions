#compdef gam gam7
# Documentation: https://man.archlinux.org/search?q=gam
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a verbs

verbs=(
  'create:create a resource'
  'add:add a member or sub-resource'
  'update:update a resource'
  'delete:delete a resource'
  'remove:remove a member'
  'sync:sync members'
  'info:show info about a resource'
  'show:show settings'
  'print:bulk print to CSV'
  'csv:run a command for each line of a CSV'
  'loop:run a command for each result of a previous command'
  'select:select an alternate config / oauth file'
  'oauth:OAuth setup commands (create/info/refresh/delete/export/import)'
  'config:GAM config commands'
  'help:show help'
  'version:show GAM version'
  'redirect:redirect output to a file'
  'multiprocess:enable multiprocess execution'
  'cancelwipe:cancel a pending Chrome wipe'
  'commit-batch:run a batch file'
  'batch:run commands from a batch file'
  'tbatch:run a thread-pooled batch'
  'all:operate on all entities'
  'whatis:identify what an email address is'
  'check:integrity checks (e.g. svcacct)'
  'calendar:user calendar shortcut'
  'calendars:multi-user calendar shortcut'
  'cigroup:Cloud Identity groups'
  'cigroups:Cloud Identity groups (plural)'
  'cros:Chrome OS device shortcut'
  'crosfeatures:Chrome OS feature commands'
  'browser:Chrome browser commands'
  'browsers:Chrome browsers (plural)'
)

local -a entities=(
  'user:Google Workspace user'
  'users:multiple users'
  'group:Google group'
  'groups:multiple groups'
  'domain:Workspace domain'
  'domains:multiple domains'
  'org:organizational unit'
  'orgs:multiple OUs'
  'alias:email alias'
  'aliases:multiple aliases'
  'admin:admin role assignment'
  'admins:multiple admins'
  'building:building (resource calendar)'
  'feature:resource feature'
  'role:custom role'
  'roles:custom roles'
  'license:license'
  'licenses:multiple licenses'
  'mobile:mobile device'
  'mobiles:multiple mobiles'
  'crosdevice:Chrome OS device'
  'crosdevices:Chrome OS devices'
  'browser:Chrome browser'
  'browsers:Chrome browsers'
  'printer:Chrome printer'
  'printers:Chrome printers'
  'classroom:classroom course'
  'course:Classroom course'
  'courses:Classroom courses'
  'calendar:calendar resource'
  'calendars:calendar resources'
  'contact:user contact'
  'contacts:user contacts'
  'drive:Drive content'
  'drivefile:Drive file'
  'drivefiles:multiple Drive files'
  'driveactivity:Drive activity'
  'shareddrive:shared drive (Team Drive)'
  'shareddrives:shared drives'
  'gmail:Gmail commands'
  'message:Gmail message'
  'messages:Gmail messages'
  'thread:Gmail thread'
  'threads:Gmail threads'
  'filter:Gmail filter'
  'filters:Gmail filters'
  'label:Gmail label'
  'labels:Gmail labels'
  'sendas:send-as alias'
  'forwardingaddress:forwarding address'
  'vacation:vacation responder'
  'token:OAuth token'
  'tokens:OAuth tokens'
  'note:Keep note'
  'notes:Keep notes'
  'task:Tasks task'
  'tasks:Tasks list'
  'tasklist:Tasks tasklist'
  'meetrecording:Meet recording'
  'youtubechannel:YouTube channel'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->verb' \
  '2: :->entity' \
  '*::arg:->args' && ret=0

case $state in
  (verb) _describe -t verbs 'gam verb' verbs && ret=0 ;;
  (entity) _describe -t entities 'gam entity' entities && ret=0 ;;
esac

return ret
