#compdef hum2mid
# Documentation: https://extras.humdrum.org/man/hum2mid/
# Convert Humdrum **kern data into a Standard MIDI File

local ret=1

_arguments -s -S \
  '-C[do not store Humdrum file comments in output MIDI]' \
  '-i[re-map instrumental codes to MIDI timbre codes]:mapping:' \
  '-I[ignore Humdrum instrumental tandem interpretations]' \
  '-n[comment string to embed into output MIDI file]:string:' \
  '-o[filename to save Standard MIDI File output]:file:_files -g "*.mid"' \
  '-p[output MIDI does not realize articulations (plain)]' \
  '-P[do not pad end of MIDI output with a dummy note-off]' \
  '-f[use the given timbre number for all MIDI notes]:num:' \
  '-r[scale rhythmic durations by given number]:num:' \
  '-t[scale tempo by given factor]:num:' \
  '-T[do not save non-kern spines as text meta-messages]' \
  '-0[output a type-0 MIDI file (single track)]' \
  '--autopan[pan each channel from hard left to right]' \
  '--bend[use pitch bend for microtonal tunings; max cents]:cents:' \
  '--hv[apply random variation to note-attack loudnesses]:num:' \
  '--mv[apply metric variation to note-attack loudnesses]:num:' \
  '--no-rest[do not store initial rests in MIDI output]' \
  '--plus[store pitch spellings and phrases in MIDI Plus format]' \
  '--temperament[use a temperament definition file to tune pitches]:file:_files' \
  '--tempo[use the first tempo spine as the tempo track]' \
  '--timbres[list of instrument names and patch change values]:string:' \
  '--time[use the first time spine to control note timing]' \
  '*:Humdrum file:_files -g "*.(krn|hum)"' && ret=0

return ret
