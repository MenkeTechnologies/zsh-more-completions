#compdef swagger

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-q[silence logs]' \
  '--quiet[silence logs]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'diff:diff two swagger specs'
      'expand:expand \$ref in a swagger spec'
      'flatten:flatten a swagger spec'
      'generate:generate code from a swagger spec'
      'init:initialize a swagger spec'
      'mixin:merge swagger specs'
      'serve:serve the swagger spec as API docs'
      'validate:validate a swagger spec'
      'version:print version'
    )
    _describe -t commands 'swagger command' commands && ret=0
    ;;
  args)
    case $line[1] in
      generate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:target:(client server model support cli)' \
          '-f+[spec file]:spec file:_files' \
          '--spec=[spec file]:spec file:_files' \
          '-t+[target directory]:directory:_directories' \
          '--target=[target directory]:directory:_directories' \
          '-a+[API package name]:name' \
          '--api-package=[API package name]:name' \
          '-m+[model package name]:name' \
          '--model-package=[model package name]:name' \
          '-s+[server package name]:name' \
          '--server-package=[server package name]:name' \
          '-c+[client package name]:name' \
          '--client-package=[client package name]:name' \
          '--principal=[principal type]:type' \
          '--template-dir=[template directory]:directory:_directories' \
          '--config-file=[config file]:config file:_files' \
          '--name=[application name]:name' \
          '--skip-models[skip model generation]' \
          '--skip-operations[skip operation generation]' \
          '--skip-support[skip support file generation]' \
          '--skip-validation[skip spec validation]' \
          '--existing-models=[import path for existing models]:path' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[spec file]:spec file:_files' \
          '--spec=[spec file]:spec file:_files' \
          '--stop-on-error[stop on first error]' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-F+[spec file]:spec file:_files' \
          '--spec=[spec file]:spec file:_files' \
          '--host=[host to serve on]:host' \
          '--port=[port to serve on]:port' \
          '--base-path=[base path]:path' \
          '--flavor=[UI flavor]:flavor:(swagger redoc)' \
          '--no-open[do not open browser]' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-d[use destination spec]:spec file:_files' \
          '--dest=[destination spec]:spec file:_files' \
          '--break-only[only show breaking changes]' \
          '1:source spec:_files' && ret=0
        ;;
      flatten|expand)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--compact[compact output]' \
          '--format=[output format]:format:(json yaml)' \
          '-o+[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '1:spec file:_files' && ret=0
        ;;
      mixin)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--compact[compact output]' \
          '--format=[output format]:format:(json yaml)' \
          '-o+[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '*:spec files:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
