#compdef gnumeric
# Documentation: https://manpages.debian.org/gnumeric
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Gnumeric: GNOME spreadsheet.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--usage[show brief usage message]' \
  '--no-splash[no splash screen]' \
  '--dump-func-defs=+[dump function defs]:file:_files' \
  '--dump-func-state-tables=+[dump state tables]:file:_files' \
  '--debug-deps=+[dependency debug]:n:' \
  '--debug-share=+[debug share]:n:' \
  '--debug-print=+[print debug]:n:' \
  '--debug-input=+[input debug]:n:' \
  '(-g --geometry)'{-g+,--geometry=}'[window geometry]:geom:' \
  '--display=+[X display]:disp:' \
  '--screen=+[X screen]:screen:' \
  '--disable-sound[disable sound]' \
  '--enable-sound[enable sound]' \
  '--espeaker=+[sound server host:port]:host\:port:' \
  '--disable-crash-dialog[suppress bug report dialog]' \
  '--name=+[set window manager name]:name:' \
  '--class=+[set window manager class]:class:' \
  '--sm-client-id=+[session ID]:id:' \
  '--sm-config-prefix=+[session config prefix]:prefix:' \
  '--sm-disable[disable session manager]' \
  '*:spreadsheet:_files -g "*.{gnumeric,xls,xlsx,ods,csv,tsv,html}"' && ret=0

return ret
