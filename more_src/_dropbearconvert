#compdef dropbearconvert
# Documentation: https://man.archlinux.org/search?q=dropbearconvert
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:input format:(openssh dropbear)' \
  '2:output format:(openssh dropbear)' \
  '3:input file:_files' \
  '4:output file:_files' && ret=0

return ret
