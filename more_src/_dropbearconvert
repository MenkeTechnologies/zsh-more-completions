#compdef dropbearconvert
# Documentation: https://manpages.debian.org/dropbearconvert.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:input format:(openssh dropbear)' \
  '2:output format:(openssh dropbear)' \
  '3:input file:_files' \
  '4:output file:_files' && ret=0

return ret
