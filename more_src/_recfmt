#compdef recfmt
# Documentation: https://www.gnu.org/software/recutils/
# Reference accessed: 2026-06-10

# Zsh completion for recfmt (GNU Recutils)

_arguments -s -S \
  '-f+[template file]:template file:_files' \
  '-t+[select record type]:record type:' \
  '-e+[selection expression]:expression:' \
  '-n+[record number]:record number:' \
  '-c[print count of matching records]' \
  '*:file:_files'
