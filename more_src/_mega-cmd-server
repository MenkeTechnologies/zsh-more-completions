#compdef mega-cmd-server
# _mega-cmd-server — server companion to MEGAcmd interactive shell (meganz/MEGAcmd)
# upstream: https://github.com/meganz/MEGAcmd
# Flags from src/megacmd_server_main.cpp.

_mega-cmd-server() {
    _arguments \
        '--uninstall[uninstall the server]' \
        '--debug[enable debug logging]' \
        '--debug-full[enable full debug logging]' \
        '--verbose[enable verbose logging]' \
        '--verbose-full[enable full verbose logging]' \
        '--skip-lock-check[skip the inter-process lock check]' \
        '--wait-for=[wait for a specific request handle]:handle:' \
        '--disablepkp[disable public-key pinning (debug)]' \
        '--apiurl=[override API URL (debug)]:url:' \
        '--do-not-log-to-stdout[suppress stdout logging]'
}

_mega-cmd-server "$@"
