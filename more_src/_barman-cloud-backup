#compdef barman-cloud-backup

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-t --test)'{-t,--test}'[test cloud connectivity]' \
  '(-z --gzip)'{-z,--gzip}'[gzip compress]' \
  '(-j --bzip2)'{-j,--bzip2}'[bzip2 compress]' \
  '(-J --snappy)'{-J,--snappy}'[snappy compress]' \
  '(--cloud-provider)--cloud-provider=+[cloud provider]:provider:(aws-s3 azure-blob-storage google-cloud-storage)' \
  '(--endpoint-url)--endpoint-url=+[endpoint URL]:url:' \
  '(-P --profile)'{-P,--profile}'+[AWS profile]:profile:' \
  '(--encryption)--encryption=+[server-side encryption]:enc:' \
  '(--sse-kms-key-id)--sse-kms-key-id=+[KMS key id]:keyid:' \
  '(--azure-credential)--azure-credential=+[Azure credential]:cred:(azure-cli managed-identity)' \
  '(--max-archive-size)--max-archive-size=+[max archive size]:bytes:' \
  '(-h --host)'{-h,--host}'+[Postgres host]:host:_hosts' \
  '(-U --user)'{-U,--user}'+[Postgres user]:user:' \
  '(-d --dbname)'{-d,--dbname}'+[database name]:db:' \
  '(--immediate-checkpoint)--immediate-checkpoint[issue an immediate checkpoint]' \
  '(--jobs)--jobs=+[parallel jobs]:n:' \
  '(--name)--name=+[backup name]:name:' \
  '*:server_name destination_url:' && ret=0

return ret
