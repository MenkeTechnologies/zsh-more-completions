#compdef pveum

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'acl:manage access control lists'
  'group:manage groups'
  'pool:manage pools'
  'realm:manage authentication realms'
  'role:manage roles'
  'tfa:manage two-factor authentication'
  'token:manage API tokens'
  'user:manage users'
  'passwd:change password'
  'usermod:modify user (compat)'
  'useradd:add user (compat)'
  'userdel:delete user (compat)'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pveum command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (acl) _values 'subcommand' 'delete' 'list' 'modify' && ret=0 ;;
      (group) _values 'subcommand' 'add' 'delete' 'list' 'modify' && ret=0 ;;
      (pool) _values 'subcommand' 'add' 'delete' 'list' 'modify' && ret=0 ;;
      (realm) _values 'subcommand' 'add' 'delete' 'list' 'modify' 'sync' && ret=0 ;;
      (role) _values 'subcommand' 'add' 'delete' 'list' 'modify' && ret=0 ;;
      (tfa) _values 'subcommand' 'list' 'unlock' && ret=0 ;;
      (token) _values 'subcommand' 'add' 'delete' 'list' 'modify' 'permissions' 'remove' && ret=0 ;;
      (user) _values 'subcommand' 'add' 'delete' 'list' 'modify' 'permissions' 'tfa' 'token' && ret=0 ;;
    esac ;;
esac

return ret
