#compdef porkbun-cli
# Documentation: https://github.com/ac101m/porkbun-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for porkbun-cli
# https://github.com/ac101m/porkbun-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--key=[API key]:key:' \
  '--secret=[API secret]:secret:' \
  '--domain=[domain name]:domain:' \
  '--type=[record type]:type:(A AAAA CNAME MX NS TXT ALIAS CNAME)' \
  '--name=[record name]:name:' \
  '--content=[record content]:content:' \
  '--ttl=[time-to-live]:ttl:' \
  '--help[show help]' && ret=0

return ret
