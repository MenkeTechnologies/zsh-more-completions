#compdef porkbun-cli
# Documentation: https://github.com/ac101m/porkbun-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for porkbun-cli - Porkbun DNS management tool

local curcontext="$curcontext" state line ret=1

local -a porkbun_commands
porkbun_commands=(
  'show_ip:display external IP'
  'ping:verify API keys'
  'record:manage DNS records'
)

local -a record_commands
record_commands=(
  'list:list records for a domain'
  'create:create a new record'
  'edit:edit an existing record'
  'update:update record content'
  'delete:delete a record'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--apikey=[path to API key file]:file:_files' \
  '--secretapikey=[path to secret API key file]:file:_files' \
  '--delay=[polling interval in seconds]:seconds' \
  '1: :->cmds' \
  '*::args:->args' && ret=0

case "$state" in
  cmds)
    _describe -t commands 'porkbun-cli command' porkbun_commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      record)
        if (( CURRENT == 2 )); then
          _describe -t commands 'record subcommand' record_commands && ret=0
        else
          _arguments -s -S \
            '--name=[record name]:name' \
            '--type=[record type]:type:(A AAAA CNAME MX NS TXT ALIAS SRV CAA)' \
            '--ttl=[time-to-live]:ttl' \
            '--content=[record content]:content' \
            '--priority=[record priority]:priority' \
            '--apikey=[path to API key file]:file:_files' \
            '--secretapikey=[path to secret API key file]:file:_files' \
            '--delay=[polling interval in seconds]:seconds' \
            && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
