#compdef mysqlrouter_keyring

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize keyring'
  'set:set a keyring entry'
  'get:get a keyring entry'
  'list:list keyring entries'
  'delete:delete a keyring entry'
  'export:export the keyring'
  'master-delete:delete a master key entry'
  'master-list:list master keys'
  'master-rename:rename a master key'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--master-key-reader=[command to read master key]:command:' \
  '--master-key-writer=[command to write master key]:command:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'mysqlrouter_keyring subcommand' subcommands && ret=0
    ;;
esac

return ret
