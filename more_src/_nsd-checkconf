#compdef nsd-checkconf

_arguments -s \
  '-v[print options to stdout]' \
  '-f[print full pathnames]' \
  '(- *)-h[show help]' \
  '-o[query specific config option]:option:' \
  '-z[zone name (with -o)]:zone:' \
  '-p[pattern (with -o)]:pattern:' \
  '-s[print key secret]:keyname:' \
  '-t[print tls-auth domain]:tls-auth:' \
  ':config file:_files'
