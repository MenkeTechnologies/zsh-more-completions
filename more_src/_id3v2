#compdef id3v2

# Zsh completion for id3v2 - ID3v2 tag editor

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-l,--list}'[list tags]' \
  {-R,--list-rfc822}'[list tags in RFC 822 format]' \
  {-d,--delete-v2}'[delete v2 tag]' \
  {-s,--delete-v1}'[delete v1 tag]' \
  {-D,--delete-all}'[delete all tags]' \
  {-C,--convert}'[convert v1 tag to v2]' \
  {-a,--artist}'+[set artist]:artist' \
  {-A,--album}'+[set album]:album' \
  {-t,--song}'+[set title]:title' \
  {-c,--comment}'+[set comment]:comment' \
  {-g,--genre}'+[set genre]:genre' \
  {-y,--year}'+[set year]:year' \
  {-T,--track}'+[set track number]:track (NUM/TOTAL)' \
  '(- *)'{-L,--list-genres}'[list all genres]' \
  '*:audio files:_files -g "*.{mp3,mp2,mp1}"'
