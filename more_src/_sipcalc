#compdef sipcalc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-4[IPv4 mode]' \
  '-6[IPv6 mode]' \
  '-a[show all information]' \
  '-b[binary output]' \
  '-c[classful output]' \
  '-d[resolve DNS]' \
  '-I[show interface information]' \
  '-n[show network information]' \
  '-s[split network]:mask bits' \
  '-S[split by hosts]:host count' \
  '-u[output in unchanged format]' \
  '-w[show wildcard mask]' \
  '-x[hex output]' \
  '*:address/mask or interface' && ret=0

return ret
