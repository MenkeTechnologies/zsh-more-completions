#compdef fc-validate
# Documentation: fc-validate --help (fontconfig)
# Source: fontconfig fc-validate — validate font files and print result.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-i --index)'{-i,--index=}'[display only the INDEX face of each file]:index:' \
    '(-l --lang)'{-l,--lang=}'[language code to validate against]:lang:' \
    '(-v --verbose)'{-v,--verbose}'[show more detailed information]' \
    '(- *)'{-V,--version}'[display fontconfig version and exit]' \
    '(- *)'{-h,--help}'[display help and exit]' \
    '*:font file:_files -g "*.{ttf,otf,ttc,otc,pfa,pfb,pcf,woff,woff2,bdf}"' \
    && ret=0

return ret
