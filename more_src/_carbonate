#compdef carbonate carbon-aggregator carbon-cache carbon-relay carbon-client carbon-lookup carbon-list carbon-path carbon-sync carbon-sieve
# Documentation: https://github.com/graphite-project/carbonate
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

case $service in
  (carbonate)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-c --config-file)'{-c,--config-file}'+[carbonate config file]:file:_files' \
      '(-C --cluster)'{-C,--cluster}'+[cluster name]:name:' && ret=0 ;;
  (carbon-aggregator|carbon-cache|carbon-relay|carbon-client)
    _arguments \
      '--debug[debug mode]' \
      '--config=[config file]:file:_files' \
      '--logdir=[log directory]:dir:_files -/' \
      '--instance=[instance name]:name:' \
      '--pidfile=[PID file]:file:_files' \
      'start[start daemon]' \
      'stop[stop daemon]' \
      'status[show status]' \
      'restart[restart daemon]' && ret=0 ;;
  (carbon-list)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-c --config-file)'{-c,--config-file}'+[config file]:file:_files' \
      '(-C --cluster)'{-C,--cluster}'+[cluster]:name:' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-c --config-file)'{-c,--config-file}'+[config file]:file:_files' \
      '(-C --cluster)'{-C,--cluster}'+[cluster]:name:' && ret=0 ;;
esac

return ret
