#compdef phoenix-sandbox
# Documentation: https://man.archlinux.org/search?q=phoenix-sandbox
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-r+[zookeeper root znode]:znode:' \
  '-z+[zookeeper port]:port:' \
  '-q+[shut down silently]' && ret=0

return ret
