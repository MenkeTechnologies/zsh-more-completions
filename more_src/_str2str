#compdef str2str
# Documentation: https://manpages.debian.org/bullseye/rtklib/str2str.1.en.html
# RTKLIB stream server: relay GNSS streams between sources

local ret=1

_arguments -s \
  '-in[input stream path and format]:stream' \
  '*-out[output stream path and format]:stream' \
  '-msg[RTCM message types and intervals]:type' \
  '-sta[station identifier]:sta' \
  '-opt[receiver-dependent options]:opt' \
  '-s[timeout time (ms)]:msec' \
  '-r[reconnect interval (ms)]:msec' \
  '-n[nmea request cycle (ms)]:msec' \
  '-f[file swap margin (s)]:sec' \
  '-c[receiver commands file]:file:_files' \
  '-p[station position lat/lon/height]:lat: :lon: :hgt:' \
  '-px[station position x/y/z-ecef (m)]:x: :y: :z:' \
  '-a[antenna info]:antinfo' \
  '-i[receiver info]:rcvinfo' \
  '-o[antenna offset e/n/u (m)]:e: :n: :u:' \
  '-l[ftp/http local directory]:dir:_files -/' \
  '-x[http/ntrip proxy address]:proxy' \
  '-t[trace level]:level' \
  '-h[print help]' && ret=0

return ret
