#compdef openapi2postmanv2
# Documentation: https://github.com/postmanlabs/openapi-to-postman
# Convert OpenAPI specifications to Postman collections

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-v --version)'{-v,--version}'[specify version of the converter]' \
  '(-s --spec)'{-s,--spec}'=[OpenAPI specification file to convert]:file:_files' \
  '(-o --output)'{-o,--output}'=[destination file for the collection]:file:_files' \
  '(-p --pretty)'{-p,--pretty}'[pretty print the collection object]' \
  '(-i --interface-version)'{-i,--interface-version}'=[interface version of the converter]:version' \
  '(-O --options)'{-O,--options}'=[supply converter options]:options' \
  '(-c --options-config)'{-c,--options-config}'=[supply options through config file]:file:_files' \
  '(-t --test)'{-t,--test}'[test with an in-built sample specification]' \
  '--sync=[sync spec changes with existing Postman collection]:file:_files' \
  '--sync-options=[comma-separated list of sync options]:options' \
  '--sync-options-config=[JSON file containing sync options]:file:_files' \
  '*:file:_files' && ret=0

return ret
