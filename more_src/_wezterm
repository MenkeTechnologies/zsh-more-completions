#compdef wezterm

# Zsh completion for wezterm (GPU-accelerated terminal emulator)

local curcontext="$curcontext" state line ret=1

local -a wezterm_commands
wezterm_commands=(
  'start:start the GUI, optionally running an alternative program'
  'ssh:establish an SSH session'
  'serial:open a serial port'
  'connect:connect to a multiplexer server'
  'ls-fonts:display information about fonts'
  'show-keys:show key assignments'
  'cli:interact with experimental multiplexer'
  'imgcat:output an image to the terminal'
  'set-working-directory:advise the terminal of the current directory'
  'record:record a terminal session'
  'replay:replay a terminal session'
  'shell-completion:generate shell completions'
  'help:print help message'
)

_arguments -s -S \
  '--config-file=[specify the configuration file to use]:config file:_files' \
  '--config=[override specific configuration values]:key=value:' \
  '-n[skip loading wezterm.lua]' \
  '--skip-config[skip loading wezterm.lua]' \
  '-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '1:command:_describe -t commands command wezterm_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      start)
        _arguments -s -S \
          '--no-auto-connect[do not connect to running multiplexer server]' \
          '--always-new-process[force spawning a new process]' \
          '--new-tab[open a new tab in running instance]' \
          '--cwd=[set the current working directory]:directory:_directories' \
          '--class=[set the window class]:class:' \
          '--workspace=[set the workspace name]:workspace:' \
          '--position=[set initial window position]:x,y:' \
          '--domain=[specify the multiplexer domain]:domain:' \
          '--attach[attach to a domain rather than spawning]' \
          '-e[program and arguments to run]' \
          '*:program:_cmdstring' && ret=0
        ;;
      ssh)
        _arguments -s -S \
          '--ssh-option=[pass an extra option to the SSH command]:option=value:' \
          '-o=[pass an extra option to the SSH command]:option=value:' \
          '--class=[set the window class]:class:' \
          '--position=[set initial window position]:x,y:' \
          '-v[increase verbosity]' \
          '1:user@host:_hosts' \
          '*:program:' && ret=0
        ;;
      serial)
        _arguments -s -S \
          '--baud=[set the baud rate]:baud rate:(9600 19200 38400 57600 115200)' \
          '--class=[set the window class]:class:' \
          '--position=[set initial window position]:x,y:' \
          '1:serial port:_files -g "/dev/tty*"' && ret=0
        ;;
      connect)
        _arguments -s -S \
          '--class=[set the window class]:class:' \
          '--workspace=[set the workspace name]:workspace:' \
          '--position=[set initial window position]:x,y:' \
          '1:domain name:' \
          '*:program:' && ret=0
        ;;
      ls-fonts)
        _arguments -s -S \
          '--list-system[list all fonts on the system]' \
          '--text=[explain which fonts are used to render specified text]:text:' \
          '--codepoints=[explain which fonts are used to render specified codepoints]:codepoints:' && ret=0
        ;;
      show-keys)
        _arguments -s -S \
          '--key-table=[show keys for a specific table]:table:' \
          '--lua[output in Lua format]' && ret=0
        ;;
      cli)
        local -a cli_commands
        cli_commands=(
          'list:list windows, tabs and panes'
          'list-clients:list clients'
          'proxy:proxy a multiplexer connection'
          'tlscreds:obtain TLS credentials'
          'move-pane-to-new-tab:move a pane into a new tab'
          'split-pane:split the current pane'
          'spawn:spawn a command into a new window or tab'
          'send-text:send text to a pane'
          'get-text:get text from a pane'
          'activate-pane:activate a specific pane'
          'activate-pane-direction:activate an adjacent pane in the specified direction'
          'activate-tab:activate a specific tab'
          'set-tab-title:set the title for a tab'
          'set-window-title:set the title for a window'
          'rename-workspace:rename a workspace'
          'kill-pane:kill a pane'
          'zoom-pane:zoom/unzoom a pane'
          'adjust-pane-size:adjust the size of a pane'
          'get-pane-direction:determine which pane is in a specific direction'
        )
        _arguments -s -S \
          '--class=[set the window class]:class:' \
          '--no-auto-connect[do not connect to running multiplexer server]' \
          '--prefer-mux[prefer connecting to a multiplexer]' \
          '1:cli command:_describe -t commands command cli_commands' \
          '*::cli args:->cli_args' && ret=0
        case "$state" in
          cli_args)
            case "${line[1]}" in
              split-pane)
                _arguments -s -S \
                  '--horizontal[split horizontally]' \
                  '--left[split to the left]' \
                  '--right[split to the right]' \
                  '--top[split at the top]' \
                  '--bottom[split at the bottom]' \
                  '--top-level[split at the top level]' \
                  '--cells=[number of cells for new pane]:cells:' \
                  '--percent=[percentage for new pane]:percent:' \
                  '--cwd=[working directory for new pane]:directory:_directories' \
                  '--move-pane-id=[move this pane instead of spawning]:pane id:' \
                  '--pane-id=[target pane to split]:pane id:' \
                  '*:program:_cmdstring' && ret=0
                ;;
              spawn)
                _arguments -s -S \
                  '--pane-id=[target pane]:pane id:' \
                  '--domain-name=[spawn in a specific domain]:domain:' \
                  '--window-id=[spawn in a specific window]:window id:' \
                  '--new-window[spawn a new window]' \
                  '--cwd=[working directory]:directory:_directories' \
                  '--workspace=[workspace]:workspace:' \
                  '*:program:_cmdstring' && ret=0
                ;;
              send-text)
                _arguments -s -S \
                  '--pane-id=[target pane]:pane id:' \
                  '--no-paste[do not bracket with paste sequences]' \
                  ':text:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  '--format=[control output format]:format:(json table)' && ret=0
                ;;
              *)
                _arguments -s -S \
                  '--pane-id=[target pane]:pane id:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      imgcat)
        _arguments -s -S \
          '--width=[set display width]:width:' \
          '--height=[set display height]:height:' \
          '--no-preserve-aspect-ratio[do not preserve aspect ratio]' \
          '--position=[set the cursor position]:position:' \
          '--no-move-cursor[do not move the cursor after displaying]' \
          '--hold[wait for enter after displaying]' \
          '*:image file:_files -g "*.{png,jpg,jpeg,gif,bmp,svg,webp,tiff}"' && ret=0
        ;;
      shell-completion)
        _arguments -s -S \
          '--shell=[specify the shell]:shell:(bash fish zsh power-shell elvish)' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
