#compdef mpv

# Zsh completion for mpv - media player

_arguments -s -S \
  '--no-config[do not load default config files]' \
  '--config-dir[custom configuration directory]:dir:_files -/' \
  '(-v)--v[increment verbosity level]' \
  '--msg-level[control verbosity per module]:module/level:' \
  '--term-osd[control terminal OSD]:mode:(auto force no)' \
  '--term-osd-bar[enable OSD bar in terminal]' \
  '--term-status-msg[customize status line]:format:' \
  '--quiet[make console output less verbose]' \
  '--no-video[do not play video]' \
  '--no-audio[do not play audio]' \
  '--no-sub[do not render subtitles]' \
  '--no-terminal[disable terminal usage and input]' \
  '--really-quiet[be extra quiet]' \
  '--ao[select audio output backend]:ao:(alsa pulse jack oss null auto)' \
  '--vo[select video output backend]:vo:(gpu libmpv sdl null xv vdpau vaapi drm fbdev)' \
  '--audio-device[use a specific audio device]:device:' \
  '--audio-channels[audio channels]:channels:(auto mono stereo 2.1 5.1 7.1)' \
  '--audio-samplerate[audio samplerate]:rate:(44100 48000 96000)' \
  '--volume[startup volume]:volume:(0 50 100)' \
  '--mute[mute audio]' \
  '--speed[playback speed]:factor:' \
  '--start[start at time or chapter]:time:' \
  '--end[stop at time]:time:' \
  '--length[stop after given time has elapsed]:time:' \
  '--chapters[play chapters from-to]:chapters:' \
  '--edition[select edition number]:N:' \
  '--track-auto-selection[auto-select default tracks (yes/no)]:flag:(yes no)' \
  '--alang[audio language preference]:lang:' \
  '--slang[subtitle language preference]:lang:' \
  '--vlang[video language preference]:lang:' \
  '--aid[select audio track]:ID:' \
  '--vid[select video track]:ID:' \
  '--sid[select subtitle track]:ID:' \
  '--sub-file[additional subtitle file]:file:_files' \
  '--audio-file[additional audio file]:file:_files' \
  '--cache[enable cache (yes/no/auto)]:mode:(yes no auto)' \
  '--cache-secs[size of cache for network streams]:seconds:' \
  '--demuxer-max-bytes[max bytes to read ahead]:bytes:' \
  '--loop[loop file]:count:(yes no inf 0 1 2 3)' \
  '--loop-playlist[loop playlist]:count:(yes no inf force)' \
  '--shuffle[shuffle playlist]' \
  '--playlist[load playlist file]:file:_files' \
  '--ytdl[enable youtube-dl support]' \
  '--ytdl-format[video/audio format to download]:format:' \
  '--ytdl-raw-options[raw youtube-dl options]:options:' \
  '--fullscreen[start in fullscreen mode]' \
  '--fs[start in fullscreen mode]' \
  '--geometry[set screen size or position]:geometry:' \
  '--no-border[play without window border]' \
  '--ontop[place window on top of other windows]' \
  '--no-keepaspect[do not keep aspect ratio of video]' \
  '--window-scale[scale factor for video window]:factor:' \
  '--autofit[scale video to fit area]:size:' \
  '--autofit-larger[scale video if larger than specified]:size:' \
  '--panscan[enable pan and scan]:factor:' \
  '--screenshot-dir[directory for screenshots]:dir:_files -/' \
  '--screenshot-format[format for screenshots]:format:(jpg png ppm pgm)' \
  '--screenshot-template[screenshot filename template]:template:' \
  '--write-filename-in-watch-later-config[write filename in watch-later config]' \
  '--save-position-on-quit[always save current playback position on quit]' \
  '--watch-later-dir[directory for watch-later data]:dir:_files -/' \
  '--sub-font[subtitle font]:font:' \
  '--sub-font-size[subtitle font size]:size:' \
  '--sub-scale[subtitle scale]:scale:' \
  '--sub-pos[subtitle position]:pos:' \
  '--sub-delay[subtitle delay in seconds]:seconds:' \
  '--sub-speed[subtitle speed]:speed:' \
  '--sub-color[subtitle color]:color:' \
  '--sub-border-color[subtitle border color]:color:' \
  '--sub-border-size[subtitle border size]:size:' \
  '--sub-back-color[subtitle background color]:color:' \
  '--sub-shadow-offset[subtitle shadow offset]:offset:' \
  '--sub-shadow-color[subtitle shadow color]:color:' \
  '--sub-codepage[subtitle codepage]:codepage:' \
  '--vf[video filters]:filter:' \
  '--af[audio filters]:filter:' \
  '--hwdec[hardware video decoding API]:api:(no auto vdpau vaapi videotoolbox dxva2 nvdec d3d11va)' \
  '--gpu-api[GPU API]:api:(auto vulkan opengl d3d11)' \
  '--profile[use the given profile]:profile:' \
  '--input-conf[config file for key bindings]:file:_files' \
  '--input-ipc-server[start listening on a local socket for IPC]:path:_files' \
  '--idle[keep the player in idle mode even without playlist]' \
  '--force-window[force window creation even without input]:mode:(yes no immediate)' \
  '(--help)-h[show help]' \
  '(--help)--help[show help]' \
  '--version[show version]' \
  '*:media file or URL:_files'
