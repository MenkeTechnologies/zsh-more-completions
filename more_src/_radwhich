#compdef radwhich
# _radwhich — FreeRADIUS radwhich (Perl helper that reports which user(s) are currently active on a given NAS-Identifier or NAS port; -d data dir, -f session file, -n NAS-Identifier filter, -p NAS-Port filter, -h help, -v version; positional argument is the optional user name to filter)
# upstream: https://github.com/FreeRADIUS/freeradius-server (radwhich)
# Common flag shape from FreeRADIUS scripts/radwhich on tip.

_radwhich() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-d+[data dir]:dir:_files -/' \
        '-f+[session file]:file:_files' \
        '-n+[NAS-Identifier]:nas:' \
        '-p+[NAS-Port]:port:' \
        '*:user:_users'
}

_radwhich "$@"
