#compdef birdfont-import
# Documentation: https://man.archlinux.org/man/birdfont-import.1.en
# Generate a birdfont file from a set of SVG images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print command line options]' \
  '1:birdfont file:_files -g "*.bf"' \
  '*:svg files:_files -g "*.svg"' && ret=0

return ret
