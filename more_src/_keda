#compdef keda

# Zsh completion for keda - Kubernetes event-driven autoscaler CLI

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'completion:Generate the autocompletion script'
  'help:Help about any command'
  'install:Install KEDA'
  'uninstall:Uninstall KEDA'
  'upgrade:Upgrade KEDA'
  'version:Print version information'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'keda command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      install|upgrade)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--create-namespace[create the namespace if it does not exist]' \
          '--dry-run[simulate install]' \
          '(-n --namespace)'{-n,--namespace}'=[namespace to install KEDA]:namespace' \
          '--keda-version=[version of KEDA to install]:version' \
          '--set=[set values on the command line]:values' \
          '--values=[specify values YAML file]:file:_files' \
          '--wait[wait until install is ready]' && ret=0
        ;;
      uninstall)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--dry-run[simulate uninstall]' \
          '(-n --namespace)'{-n,--namespace}'=[namespace where KEDA is installed]:namespace' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
