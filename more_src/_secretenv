_secretenv_commands() {
    local commands; commands=(
'run:Run a command with secrets injected as env vars' \
'registry:Registry document operations' \
'profile:Distribution profile operations — install, list, update, and uninstall shared config fragments (v0.4)' \
'resolve:Print the backend URI an alias resolves to (no fetch) plus the cascade source and backend auth status' \
'get:Fetch a secret value by alias. Prompts for confirmation before printing to stdout' \
'doctor:Diagnose backend installation and auth state (Phase 10)' \
'setup:Initialize \`config.toml\` for a registry URI (Phase 11)' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'secretenv commands' commands "$@"
}
