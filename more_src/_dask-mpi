#compdef dask-mpi
# Documentation: https://mpi.dask.org/en/latest/cli.html
# dask-mpi - launch a Dask cluster from within an MPI environment

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--scheduler-file=[filename to JSON encoded scheduler information]:file:_files' \
  '--scheduler-port=[specify scheduler port number, defaults to random]:port' \
  '--scheduler-rank=[the MPI rank on which the scheduler will launch]:rank' \
  '--interface=[network interface like eth0 or ib0]:interface' \
  '--protocol=[network protocol to use like TCP]:protocol' \
  '--nthreads=[number of threads per worker]:threads' \
  '--memory-limit=[memory threshold before disk spilling]:limit' \
  '--local-directory=[directory to place worker files]:dir:_files -/' \
  '--scheduler[include a scheduler in the cluster]' \
  '--no-scheduler[do not include a scheduler, expand an existing cluster]' \
  '--nanny[wrap workers in a nanny process]' \
  '--no-nanny[do not wrap workers in a nanny process]' \
  '--exclusive-workers[workers occupy dedicated MPI ranks]' \
  '--inclusive-workers[workers share MPI ranks]' \
  '--worker-class=[class to use when creating workers]:class' \
  '--worker-options=[JSON serialised dict of options to pass to workers]:options' \
  '--dashboard[enable the diagnostics dashboard]' \
  '--no-dashboard[disable the diagnostics dashboard]' \
  '--dashboard-address=[address for visual diagnostics dashboard]:address' \
  '--name=[worker naming prefix]:name' \
  '*:arg:' && ret=0

return ret
