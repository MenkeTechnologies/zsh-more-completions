#compdef neu neutralinojs
# _neutralinojs — Neutralinojs lightweight desktop app framework CLI (neutralinojs/neutralinojs)
# upstream: https://github.com/neutralinojs/neutralinojs

_neutralinojs() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '1: :_neutralinojs_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                create)
                    _arguments \
                        '--template=[project template]:template:' \
                        '--help[show help]' \
                        '1:project name:' && ret=0 ;;
                build)
                    _arguments \
                        '--release[build for release]' \
                        '--copy-storage[copy storage directory]' \
                        '--help[show help]' && ret=0 ;;
                run)
                    _arguments \
                        '--arch=[target architecture]:arch:(x64 arm64 armhf ia32 universal)' \
                        '--help[show help]' && ret=0 ;;
                update)
                    _arguments \
                        '--help[show help]' && ret=0 ;;
                plugins)
                    _arguments \
                        '--help[show help]' \
                        '1:plugin name:' && ret=0 ;;
                *)
                    _arguments '--help[show help]' '*:args:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_neutralinojs_commands] )) ||
_neutralinojs_commands() {
    local -a commands
    commands=(
        'create:create a new Neutralinojs app'
        'build:build the app'
        'run:run the app'
        'update:update Neutralinojs binaries'
        'plugins:manage plugins'
        'version:show version'
    )
    _describe -t commands 'neu command' commands
}

_neutralinojs "$@"
