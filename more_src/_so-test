#compdef so-test
# _so-test — Security Onion so-test CLI for running unit and smoke tests across distributed Security Onion installation validating ES indices Suricata/Zeek/Sguil ingestion Kibana dashboards Hunt drilldowns (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-test() {
    local -a sub=(
        'all:run all tests'
        'unit:run unit tests'
        'smoke:run smoke tests'
        'integration:run integration tests'
        'soc:run SOC interface tests'
        'salt:run salt-stack tests'
        'elastic:run Elasticsearch tests'
        'suricata:run Suricata tests'
        'zeek:run Zeek tests'
        'stenographer:run Stenographer tests'
        'fleet:run Fleet tests'
        'hunt:run Hunt tests'
        'kibana:run Kibana tests'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '--filter=+[pattern]:str:' \
        '--no-cleanup[no cleanup]' \
        '--keep-temp[keep temp dir]' \
        '--report-file=+[file]:file:_files -g "*.html *.json *.xml *.txt"' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'so-test subcommand' sub ;;
        args) ;;
    esac
}

_so-test "$@"
