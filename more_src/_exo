#compdef exo
# Documentation: https://community.exoscale.com/reference/cli/exo/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# exo: command-line tool for Exoscale cloud (exoscale/cli).

_exo_commands() {
  local -a commands=(
    'compute:Compute services (instances, SKS, security groups, networking)'
    'config:CLI configuration'
    'dbaas:Database as a Service management'
    'dedicated-inference:AI model deployment'
    'dns:DNS management'
    'iam:Identity and Access Management'
    'limits:Display current account limits'
    'status:Exoscale service status'
    'storage:Object storage management'
    'version:Print version'
    'zone:List all available zones'
    'help:Show help'
  )
  _describe -t commands 'exo command' commands
}

_exo() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-O --output-format)'{-O,--output-format}'[Output format]:format:(json table text)' \
    '(-Q --quiet)'{-Q,--quiet}'[Quiet mode]' \
    '--output-template=[Go template for output]:template:' \
    '(-z --zone)'{-z,--zone}'[Default zone]:zone:' \
    '(-A --account)'{-A,--account}'[Account name]:account:' \
    '1:command:_exo_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        compute)
          local -a subcommands=(
            'instance:Instance management'
            'instance-pool:Instance Pool management'
            'instance-type:List instance types'
            'sks:Scalable Kubernetes Service'
            'security-group:Security Group management'
            'elastic-ip:Elastic IP management'
            'private-network:Private Network management'
            'anti-affinity-group:Anti-Affinity Group management'
            'ssh-key:SSH key management'
            'template:Instance template management'
            'snapshot:Snapshot management'
            'nlb:Network Load Balancer management'
            'block-storage:Block storage management'
          )
          _describe -t subcommands 'compute subcommand' subcommands
          ;;
        dbaas)
          local -a subcommands=(
            'create:Create a database service'
            'delete:Delete a database service'
            'list:List database services'
            'show:Show database service details'
            'update:Update a database service'
            'type:List database types'
            'migration:Manage database migrations'
          )
          _describe -t subcommands 'dbaas subcommand' subcommands
          ;;
        dns)
          local -a subcommands=(
            'create:Create a DNS domain'
            'delete:Delete a DNS domain'
            'list:List DNS domains'
            'show:Show DNS domain details'
            'add:Add a DNS record'
            'remove:Remove a DNS record'
            'update:Update a DNS record'
          )
          _describe -t subcommands 'dns subcommand' subcommands
          ;;
        storage)
          local -a subcommands=(
            'create:Create a storage bucket'
            'delete:Delete an object'
            'list:List storage buckets or objects'
            'show:Show bucket or object details'
            'upload:Upload a file'
            'download:Download a file'
            'rb:Remove bucket'
            'mb:Make bucket'
            'cors:CORS management'
            'headers:Object headers management'
            'metadata:Object metadata management'
            'presign:Generate presigned URL'
          )
          _describe -t subcommands 'storage subcommand' subcommands
          ;;
        iam)
          local -a subcommands=(
            'access-key:Manage access keys'
            'api-key:Manage API keys'
            'org-policy:Manage organization policy'
            'role:Manage IAM roles'
          )
          _describe -t subcommands 'iam subcommand' subcommands
          ;;
      esac
      ;;
  esac
}

_exo "$@"
