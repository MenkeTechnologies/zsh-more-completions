#compdef hass-cli
# Documentation: https://github.com/home-assistant-ecosystem/home-assistant-cli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for hass-cli - Home Assistant Command-line tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'area:manage areas'
  'config:retrieve configuration settings'
  'device:interact with registered devices'
  'discover:find Home Assistant instances on local network'
  'entity:get entity information'
  'event:subscribe to and monitor events'
  'ha:access Home Assistant OS features'
  'info:display CLI version and details'
  'integration:manage config entries and integrations'
  'map:display locations on a map'
  'raw:execute direct API calls'
  'service:invoke Home Assistant services'
  'state:query and modify entity states'
  'system:access system operations'
  'template:process Jinja2 templates'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --server)'{-s,--server}'=[server URL]:url:' \
  '--token=[bearer token]:token:' \
  '(-o --output)'{-o,--output}'=[output format]:format:(json yaml table auto ndjson)' \
  '--timeout=[network timeout (seconds)]:seconds:' \
  '--columns=[customize displayed table columns]:cols:' \
  '--sort-by=[order results by JSON path]:path:' \
  '--no-headers[suppress table headers]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--debug[debug mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'hass-cli command' commands && ret=0 ;;
esac

return ret
