#compdef konversation
# Documentation: https://man.archlinux.org/search?q=konversation
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help-all[show all options]' \
  '(--debug --no-debug)--debug[debug logging on]' \
  '(--debug --no-debug)--no-debug[debug logging off]' \
  '(--restart --no-restart)--restart[restart after crash]' \
  '(--restart --no-restart)--no-restart[do not restart after crash]' \
  '(--server)--server=+[connect to server URI]:uri:' \
  '(--port)--port=+[server port]:port:' \
  '(--password)--password=+[server password]:pw:' \
  '(--nick)--nick=+[nickname]:nick:' \
  '(--channel)--channel=+[autojoin channel]:chan:' \
  '(--ssl)--ssl[use SSL]' \
  '(--encoding)--encoding=+[connection encoding]:enc:' \
  '(--startupflags)--startupflags=+[startup flags]:flags:' \
  '(--quickconnect)--quickconnect[show quick connect dialog]' && ret=0

return ret
