#compdef konversation
# Documentation: https://manned.org/konversation/6cd09df7
# Reference accessed: 2026-05-19
# Verified: konversation(1) manpage.

# Removed invented flags not in the manpage: --debug/--no-debug,
# --restart/--no-restart, --encoding, --startupflags, --quickconnect.
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help about options]' \
  '--help-qt[show Qt specific options]' \
  '--help-kde[show KDE specific options]' \
  '--help-all[show all options]' \
  '--author[show author information]' \
  '(- *)'{-v,--version}'[show version information]' \
  '--license[show license information]' \
  '--server=[server to connect to]:server:' \
  '--port=[port to use]:port:' \
  '--channel=[channel to join after connection]:channel:' \
  '--nick=[nickname to use]:nick:' \
  '--password=[password for connection]:password:' \
  '--ssl[use SSL for connection]' && ret=0

return ret
