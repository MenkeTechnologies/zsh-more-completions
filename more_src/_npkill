#compdef npkill
# Documentation: https://github.com/voidcosmos/npkill
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for npkill (find and remove node_modules folders)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-p --profiles)'{-p,--profiles}'[select profile (set of targets) to use]:profile' \
  '--config[path to custom .npkillrc configuration file]:file:_files' \
  '(-d --directory)'{-d,--directory}'[set base directory to search]:directory:_files -/' \
  '(-D --delete-all)'{-D,--delete-all}'[automatically delete all found target folders]' \
  '(-e --hide-errors)'{-e,--hide-errors}'[hide errors if any]' \
  '(-E --exclude)'{-E,--exclude}'[exclude directories from search (quote list)]:patterns' \
  '(-f --full)'{-f,--full}'[start searching from the home of the user]' \
  '--size-unit=[unit for displaying folder sizes]:unit:(auto mb gb)' \
  '-nu[skip update check on startup]' \
  '--no-check-update[skip update check on startup]' \
  '(-s --sort)'{-s,--sort}'[sort results]:sort by:(size path age)' \
  '(-t --targets)'{-t,--targets}'[directory names to search for]:targets' \
  '(-x --exclude-sensitive)'{-x,--exclude-sensitive}'[exclude sensitive directories]' \
  '-y[skip warning before --delete-all]' \
  '--dry-run[do not actually delete (simulate with delay)]' \
  '--json[output results in JSON format at end of scan]' \
  '--json-stream[output results in streaming JSON format]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show npkill version]' && ret=0

return ret
