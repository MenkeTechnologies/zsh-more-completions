#compdef npkill

# Zsh completion for npkill (find and remove node_modules folders)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --directory)'{-d,--directory}'[set base directory to search]:directory:_files -/' \
  '(-D --delete-all)'{-D,--delete-all}'[automatically delete all found node_modules]' \
  '(-e --show-errors)'{-e,--show-errors}'[show error messages]' \
  '(-E --exclude)'{-E,--exclude}'[exclude directories matching pattern]:pattern' \
  '(-f --full)'{-f,--full}'[start searching from root of filesystem]' \
  '(-s --sort)'{-s,--sort}'[sort results]:sort by:(size path last-mod)' \
  '(-t --target)'{-t,--target}'[target folder name to search for]:folder name' \
  '(-c --bg-color)'{-c,--bg-color}'[change row highlight color]:color' \
  '--dry-run[do not actually delete, just simulate]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && ret=0

return ret
