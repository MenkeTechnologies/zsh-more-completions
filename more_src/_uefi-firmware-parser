#compdef uefi-firmware-parser

# uefi-firmware-parser: Python parser/extractor for UEFI firmware images
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --brand)'{-b,--brand=}'[brand-specific parser]:brand:(efi UEFI Apple Lenovo Dell)' \
  '(-q --quiet)'{-q,--quiet}'[suppress informational output]' \
  '(-o --output)'{-o,--output=}'[output directory for extraction]:dir:_files -/' \
  '(-O --outputfolder)'{-O,--outputfolder=}'[output folder]:dir:_files -/' \
  '(-e --extract)'{-e,--extract}'[extract files]' \
  '(-G --generate)'{-G,--generate}'[generate description tree]' \
  '(-T --test)'{-T,--test}'[test/parse without extracting]' \
  '(-u --unpack)'{-u,--unpack}'[unpack compression]' \
  '(-l --list)'{-l,--list}'[list contained UEFI structures]' \
  '(-s --superbrute)'{-s,--superbrute}'[try every known structure offset]' \
  '*:UEFI image file:_files -g "*.(rom|bin|fd|cap)"' && ret=0
return ret
