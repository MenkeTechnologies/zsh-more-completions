#compdef pvfs2-rmdir
# Documentation: https://man.archlinux.org/search?q=pvfs2-rmdir
# Reference accessed: 2026-05-16

# pvfs2-rmdir: remove a PVFS2 directory
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*:files:_files' && ret=0
return ret
