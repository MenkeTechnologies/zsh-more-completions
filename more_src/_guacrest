#compdef guacrest
# _guacrest — GUAC REST API server (guacsec/guac)
# upstream: https://github.com/guacsec/guac
# Flags from cmd/guacrest/cmd/root.go + pkg/cli/store.go (cobra).

_guacrest() {
    local -a args
    args=(
        '--gql-addr=[GraphQL server endpoint URL]:url:'
        '--header-file=[RFC-822 file of HTTP headers for the GQL server]:file:_files'
        '--rest-api-server-port=[port for the REST API server]:port:'
        '--rest-api-tls-cert-file=[TLS certificate (PEM)]:file:_files -g "*.pem"'
        '--rest-api-tls-key-file=[TLS key (PEM)]:file:_files -g "*.pem"'
        '--db-direct-connection[connect directly to the GQL backing DB (experimental)]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
    )
    _arguments -s $args
}

_guacrest "$@"
