#compdef teLeap
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools teLeap: non-graphical LEaP engine called by tleap

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '*-I[add directory to the search path]:directory:_directories' \
  '-f[take input from file (- for stdin)]:file:_files' \
  '-s[ignore the leaprc startup file]' \
  '*:file:_files' && ret=0

return ret
