#compdef nvidia-powerd
# Documentation: https://download.nvidia.com/XFree86/Linux-x86_64/570.86.16/README/dynamicboost.html
# Reference accessed: 2026-05-16
# Verified: NVIDIA Dynamic Boost README. nvidia-powerd is a daemon
# managed exclusively via systemd; the binary does not respond to
# --help/--version and has no documented CLI flags.
# Removed from prior file: fabricated -h/--help/-V/--version/-v/--verbose
# /-d/--no-detach flags and bogus man.archlinux.org search URL.

# nvidia-powerd: NVIDIA Dynamic Boost daemon (systemd-managed; no CLI)
local curcontext="$curcontext" ret=1
_arguments -C \
  ':no CLI flags (systemd-only daemon):' && ret=0
return ret
