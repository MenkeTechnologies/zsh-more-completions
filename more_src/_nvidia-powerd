#compdef nvidia-powerd
# Documentation: https://man.archlinux.org/search?q=nvidia-powerd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-d --no-detach)'{-d,--no-detach}'[do not detach]' && ret=0

return ret
