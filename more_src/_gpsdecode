#compdef gpsdecode
# _gpsdecode — gpsd project gpsdecode CLI decoder for raw NMEA AIVDM AIS sentences u-blox binary Garmin SiRF Trimble TSIP Skytraq Furuno proprietary packet formats translating to JSON or human-readable form for offline gpsd log analysis (Eric S. Raymond team, C); getopt
# upstream: https://gpsd.gitlab.io/gpsd/

_gpsdecode() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c[scaled mode]' \
        '-d[decode AIS]' \
        '-D+[debug level]:l:(0 1 2 3 4 5 6 7)' \
        '-e[encode mode]' \
        '-j[JSON output]' \
        '-m[minimum NMEA]' \
        '-n[NMEA mode]' \
        '-s[split AIS]' \
        '-t+[type list]:str:' \
        '-u[u-blox scaled]' \
        '-v[verbose]' \
        '-c[show scaled]' \
        '*:file:_files'
}

_gpsdecode "$@"
