#compdef wcsadd
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss202.html
# KAPPA: add a new coordinate Frame into the WCS component of an NDF

local ret=1

_arguments -s \
  'ATTRS=[attribute settings for the new Frame]:attrs' \
  'CENTRE=[centre for pincushion distortion]:centre' \
  'DIAG=[diagonal elements of the matrix]:diag' \
  'DISCO=[distortion coefficient]:disco' \
  'DOMAIN=[Domain attribute for the new Frame]:domain' \
  'EPOCH=[epoch for sky coordinate systems]:epoch' \
  'FOREXP=[forward transformation expressions]:forexp' \
  'FRAME=[basis Frame for the transformation]:frame' \
  'FRMTYPE=[type of Frame to add]:frmtype:(FRAME SKYFRAME SPECFRAME TIMEFRAME)' \
  'INVEXP=[inverse transformation expressions]:invexp' \
  'MAPIN=[file containing an AST Mapping]:file:_files' \
  'MAPOUT=[output text file for the Mapping]:file:_files' \
  'MAPTYPE=[type of Mapping connecting Frames]:maptype' \
  'NAXES=[number of input and output axes]:naxes' \
  'NDF=[NDF to store the new Frame]:NDF:_files' \
  'REFNDF=[reference NDF for Mapping and Frame]:NDF:_files' \
  'RETAIN=[retain original current Frame]:retain:(TRUE FALSE)' \
  'SHIFT=[displacement vector for translation]:shift' \
  'SIMPFI=[SimpFI attribute value]:simpfi' \
  'SIMPIF=[SimpIF attribute value]:simpif' \
  'TR=[linear transformation coefficients]:tr' \
  'TRANSFER=[transfer attributes from basis Frame]:transfer:(TRUE FALSE)' \
  'ZOOM=[uniform scaling factor]:zoom' \
  '*:NDF:_files' && ret=0

return ret
