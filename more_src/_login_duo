#compdef login_duo
# Documentation: https://man.archlinux.org/search?q=login_duo
# Reference accessed: 2026-05-16

_arguments -s \
  '-c[config file]:file:_files' \
  '-d[debug]' \
  '-f[Duo username override]:user:_users' \
  '-h[host override]:host:_hosts' \
  '(- *)-v[show version]' \
  '*::prog: _command_names'
