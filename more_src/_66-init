#compdef 66-init
# 66-init — initialize 66 service manager (Obarun/s6)

_arguments -s -S \
  '-h[show help]' \
  '-z[use color output]' \
  '-v[set verbosity level]:verbosity:(0 1 2 3 4)' \
  '-s[set skeleton directory]:skeleton directory:_files -/' \
  '-l[set live directory]:live directory:_files -/'
