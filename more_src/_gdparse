#compdef gdparse
# _gdparse — GDScript parser from gdtoolkit (Scony/godot-gdscript-toolkit)
# upstream: https://github.com/Scony/godot-gdscript-toolkit
# Flags from gdtoolkit/parser/__main__.py (docopt).

_gdparse() {
    local -a args
    args=(
        '(-p --pretty)'{-p,--pretty}'[print pretty parse tree]'
        '(-v --verbose)'{-v,--verbose}'[print parse tree]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '*:GDScript file:_files -g "*.gd"'
    )
    _arguments -s -S $args
}

_gdparse "$@"
