#compdef force-stack
# Documentation: https://force-eo.readthedocs.io/en/latest/components/auxilliary/stack.html
# FORCE: stack images (works with the 4D data model)

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-v)-v[show version]' \
  '(-i)-i[show program purpose]' \
  '(-o)-o[stacked output file (.vrt)]:file:_files' \
  '*:source file:_files' && ret=0

return ret
