#compdef plumber
# Documentation: https://github.com/streamdal/plumber
# Source: streamdal/plumber — Go CLI for inspecting/piping/redirecting messaging systems.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _pl_cmds
_pl_cmds=(
    'read:consume + inspect messages from a backend'
    'write:publish messages to a backend'
    'relay:relay messages between backends'
    'manage:manage resources via the plumber server API'
    'server:run plumber in server mode (HA cluster + gRPC)'
    'tunnel:act as a Streamdal replay destination'
    'help:show help'
)

local -a _pl_backends
_pl_backends=(
    kafka rabbit gcp-pubsub aws-sqs aws-sns nats nats-jetstream nats-streaming
    mqtt pulsar redis-streams redis-pubsub activemq azure-queue azure-eventhub
    rabbit-streams kubemq-queue rabbit-amqp10
)

_arguments -C \
    '--debug[enable debug logging]' \
    '--quiet[only show errors]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'plumber command' _pl_cmds && ret=0
        ;;
    args)
        case $line[1] in
            read|write|relay|tunnel)
                _arguments -s -S \
                    '1:backend:->backend' \
                    '*::positional:_default' && ret=0
                case $state in
                    backend) _describe -t backends 'backend' _pl_backends && ret=0 ;;
                esac
                ;;
        esac
        ;;
esac

return ret
