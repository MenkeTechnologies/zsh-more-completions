#compdef virt-firmware
# Documentation: https://man.archlinux.org/search?q=virt-firmware
# Reference accessed: 2026-05-16

# virt-firmware: tools to manage UEFI firmware images and variable stores
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'virt-fw-dump:dump UEFI variable store'
  'virt-fw-vars:edit UEFI variable store'
  'virt-fw-sigdb:edit signature database'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'virt-firmware command' commands && ret=0 ;;
esac
return ret
