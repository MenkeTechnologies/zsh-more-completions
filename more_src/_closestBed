#compdef closestBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/closest.html
# find the closest feature between two sets (bedtools closest)

local ret=1

_arguments -s -S \
  '-a[query file]:file:_files' \
  '*-b[database file(s)]:file:_files' \
  '-s[require same strandedness]' \
  '-S[require opposite strandedness]' \
  '-d[report distance to closest feature]' \
  '-D[report signed distances with orientation]:orientation:(ref a b)' \
  '-io[ignore features in B that overlap A]' \
  '-iu[ignore upstream features in B (requires -D)]' \
  '-id[ignore downstream features in B (requires -D)]' \
  '-fu[choose first upstream feature in B (requires -D)]' \
  '-fd[choose first downstream feature in B (requires -D)]' \
  '-t[tie-breaking for equally close features]:how:(all first last)' \
  '-mdb[resolve multiple databases]:how:(each all)' \
  '-k[report k closest hits]:k' \
  '-N[require query and closest hit have different names]' \
  '*-names[aliases for multiple database files]:name' \
  '-filenames[display complete filenames instead of file IDs]' \
  '-header[print the header from the A file before results]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
