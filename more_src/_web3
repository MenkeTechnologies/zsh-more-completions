#compdef web3
# Documentation: https://github.com/gochain/web3
# Reference accessed: 2026-05-21
# Verified: upstream README subcommand list (gochain/web3 CLI).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'block:show block info'
  'bl:alias for block'
  'transaction:show transaction details'
  'tx:alias for transaction'
  'receipt:show transaction receipt'
  'rc:alias for receipt'
  'address:show account details'
  'addr:alias for address'
  'id:show network/chain info'
  'balance:show GO/ETH balance'
  'myaddress:show address for WEB3_PRIVATE_KEY'
  'account:account commands'
  'a:alias for account'
  'transfer:transfer GO/ETH to an account'
  'send:alias for transfer'
  'contract:contract commands (deploy/call/build/verify/upgrade)'
  'c:alias for contract'
  'generate:generate ERC20/ERC721/etc. contract code'
  'g:alias for generate'
  'snapshot:show Clique snapshot data'
  'sn:alias for snapshot'
  'increasegas:bump gas on a pending tx'
  'replace:replace a pending transaction'
  'did:distributed identity operations'
  'claim:verifiable claims operations'
  'start:start a local GoChain dev node'
  'env:list relevant env variables'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --network)'{-n+,--network=}'[network name]:network:(gochain testnet ethereum sepolia goerli holesky localhost custom)' \
  '--testnet[shorthand for -n testnet]' \
  '--rpc-url=[custom RPC URL]:url:' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(json text yaml)' \
  '--verbose[verbose logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'web3 command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (transfer|send)
        _arguments \
          '*::amount_or_to:' && ret=0 ;;
      (contract|c)
        _arguments \
          '*::sub:(deploy call build flatten verify upgrade pause resume list)' \
          '--address=[contract address]:address:' \
          '--abi=[ABI file path]:file:_files -g "*.json"' \
          '--bin=[bytecode file]:file:_files -g "*.bin"' \
          '--function=[function name]:function:' \
          '--amount=[amount to send]:amount:' \
          '--gas-limit=[gas limit]:n:' \
          '--gas-price=[gas price (wei)]:n:' && ret=0 ;;
      (generate|g)
        _arguments \
          '*::type:(erc20 erc721 erc1155 multisig)' \
          '--name=[contract name]:name:' \
          '--symbol=[token symbol]:symbol:' && ret=0 ;;
      (account|a)
        _arguments '*::sub:(create list import export show transfer)' && ret=0 ;;
      (snapshot|sn)
        _arguments '*::sub:(latest history validators signers)' && ret=0 ;;
      (did)
        _arguments '*::sub:(create resolve update revoke)' && ret=0 ;;
      (claim)
        _arguments '*::sub:(create verify revoke list)' && ret=0 ;;
      (start)
        _arguments \
          '--datadir=[data directory]:dir:_files -/' \
          '--port=[node port]:port:' && ret=0 ;;
    esac ;;
esac

return ret
