#compdef aix
# Documentation: https://man.archlinux.org/search?q=aix
# Reference accessed: 2026-05-16

_arguments -s \
  '(-p -prompt)'{-p,-prompt}'=[prompt or file]:prompt:_files' \
  '(-g3 -gpt3)'{-g3,-gpt3}'[use GPT-3]' \
  '(-g4 -gpt4)'{-g4,-gpt4}'[use GPT-4]' \
  '(-m -model)'{-m,-model}'=[model name]:model:' \
  '(-lm -list-models)'{-lm,-list-models}'[list models]' \
  '(-ak -openai-api-key)'{-ak,-openai-api-key}'=[OpenAI API key]:key:' \
  '(-t -temperature)'{-t,-temperature}'=[temperature]:value:' \
  '(-tp -topp)'{-tp,-topp}'=[top-p]:value:' \
  '(-sc -system-context)'{-sc,-system-context}'=[system message]:context:_files' \
  '(-s -stream)'{-s,-stream}'[stream output]' \
  '(-up -update)'{-up,-update}'[update]' \
  '(-duc -disable-update-check)'{-duc,-disable-update-check}'[disable update check]' \
  '(-o -output)'{-o,-output}'=[output file]:file:_files' \
  '(-j -jsonl)'{-j,-jsonl}'[JSONL output]' \
  '(-v -verbose)'{-v,-verbose}'[verbose]' \
  '-silent[silent]' \
  '(-nc -no-color)'{-nc,-no-color}'[no color]' \
  '-version[show version]' \
  '(-nm -no-markdown)'{-nm,-no-markdown}'[disable markdown]'
