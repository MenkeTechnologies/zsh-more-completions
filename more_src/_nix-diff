#compdef nix-diff
# Documentation: https://github.com/Gabriella439/nix-diff
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--color[colorize output]:when:(always auto never)' \
  '--context[lines/words/chars of context]:count:' \
  '--character-oriented[character-oriented diff]' \
  '--line-oriented[line-oriented diff]' \
  '--word-oriented[word-oriented diff (default)]' \
  '--environment[force display of environment differences]' \
  '--skip-already-compared[fold subtrees changed only by already-compared input]' \
  '--squash-text-diff[squash text diffs into largest spans]' \
  '--json[output as JSON]' \
  '--help[show help]' \
  '1:left derivation:_files -g "*.drv"' \
  '2:right derivation:_files -g "*.drv"' && ret=0
return ret
