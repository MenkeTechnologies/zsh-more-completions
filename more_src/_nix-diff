#compdef nix-diff

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--character-oriented[character-oriented diff]' \
  '--color[colorize output]:when:(always never auto)' \
  '--context[lines of context]:lines' \
  '--environment[compare environment variables]' \
  '--json[output as JSON]' \
  '--line-oriented[line-oriented diff]' \
  '--skip-already-compared[skip already compared derivations]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:left derivation:_files -g "*.drv"' \
  '2:right derivation:_files -g "*.drv"' && ret=0
return ret
