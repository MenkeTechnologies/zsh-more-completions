#compdef kgomore
# Documentation: (none - apps.kde.org/kgomore returns HTTP 404)
# Reference accessed: 2026-05-16
# Verified: WebFetch of https://apps.kde.org/kgomore/ returned 404; this binary
# does not appear in the KDE applications catalog. The real KDE Go board game is
# 'kigo' (apps.kde.org/kigo). File kept per "do not delete files" directive;
# completion is conservative Qt+KAboutData standard set only.
# Removed from prior file: --help-qt, --help-kde (KDE3/4-era, not in KF6 Qt6).

# kgomore: not present in upstream KDE apps catalog
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' && ret=0
return ret
