#compdef kgomore
# Documentation: https://kde.org/applications/games/kgomore/
# Reference accessed: 2026-05-16

# KGoMore: legacy KDE Go variant (deprecated; replaced by kigo)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all help]' \
  '(- *)--help-qt[show Qt help]' \
  '(- *)--help-kde[show KDE help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '*::kgomore args:_files' && ret=0
return ret
