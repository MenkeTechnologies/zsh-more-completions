#compdef tsbitrate
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tsbitrate.cpp
# tsbitrate - evaluate the bitrate of a transport stream from PCR or DTS

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-a --all)'{-a,--all}'[analyze all packets in the input file]' \
  '(-d --dts)'{-d,--dts}'[use DTS from video PID instead of PCR]' \
  '(-f --full)'{-f,--full}'[full analysis with per-PID bitrate report]' \
  '(-i --ignore-errors)'{-i,--ignore-errors}'[ignore transport stream errors]' \
  '--min-pcr=[stop after this number of PCR read]:n:' \
  '--min-pid=[minimum number of PID to get PCR from]:n:' \
  '(-v --value-only)'{-v,--value-only}'[display only the bitrate value in bits/second]' \
  '*:ts file:_files -g "*.ts *.m2ts *.mpg"' && ret=0

return ret
