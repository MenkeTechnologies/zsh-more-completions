#compdef cedar

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'authorize:evaluate an authorization request'
  'evaluate:evaluate a Cedar expression'
  'validate:validate a Cedar policy'
  'format:format Cedar policies'
  'translate-policy:translate a policy to/from JSON'
  'translate-schema:translate a schema to/from JSON'
  'visualize:visualize policies'
  'new:create a new policy file'
  'check-parse:check if a policy parses'
  'link:link a template to create a policy'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'cedar command' commands && ret=0
    ;;
  args)
    case $line[1] in
      authorize)
        _arguments -s -S \
          '--policies[policy file]:file:_files -g "*.cedar"' \
          '--entities[entities file]:file:_files -g "*.json"' \
          '--schema[schema file]:file:_files -g "*.cedarschema(|.json)"' \
          '--principal[principal]:principal:' \
          '--action[action]:action:' \
          '--resource[resource]:resource:' \
          '--context[context JSON]:context:' \
          '--verbose[verbose output]' \
          '--help[show help]' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '--policies[policy file]:file:_files -g "*.cedar"' \
          '--schema[schema file]:file:_files -g "*.cedarschema(|.json)"' \
          '--help[show help]' && ret=0
        ;;
      format)
        _arguments -s -S \
          '--policies[policy file]:file:_files -g "*.cedar"' \
          '--write[write formatted output back]' \
          '--check[check formatting without modifying]' \
          '--help[show help]' && ret=0
        ;;
      translate-policy|translate-schema)
        _arguments -s -S \
          '--direction[translation direction]:direction:(cedar-to-json json-to-cedar)' \
          '1:file:_files' \
          '--help[show help]' && ret=0
        ;;
      check-parse)
        _arguments -s -S \
          '--policies[policy file]:file:_files -g "*.cedar"' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
