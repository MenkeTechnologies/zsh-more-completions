#compdef create-wagmi
# Documentation: https://www.npmjs.com/package/create-wagmi
# Reference accessed: 2026-05-23
# Verified: npx create-wagmi --help.

# Zsh completion for create-wagmi - scaffold a wagmi + viem project

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-t --template)'{-t,--template=}'[template]:template:(vite-react next vite-vue nuxt vite-vanilla)' \
  '--bun[use bun as package manager]' \
  '--npm[use npm as package manager]' \
  '--pnpm[use pnpm as package manager]' \
  '--yarn[use yarn as package manager]' \
  ':project directory:_directories' && ret=0

return ret
