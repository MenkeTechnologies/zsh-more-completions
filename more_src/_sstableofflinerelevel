#compdef sstableofflinerelevel
# Documentation: https://man.archlinux.org/search?q=sstableofflinerelevel
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '--dry-run[print actions without performing them]' \
  '1:keyspace:' \
  '2:column family:' && ret=0

return ret
