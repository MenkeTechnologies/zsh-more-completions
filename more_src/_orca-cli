#compdef orca-cli orcactl
# _orca-cli — Orca Security orca-cli CLI command-line frontend to the Orca Security cloud-native agentless application security platform CNAPP managing assets vulnerabilities misconfigurations malware secrets compliance attack-paths cloud-config-AWS-GCP-Azure-OCI-Kubernetes scanning sidescanning workload IaC-scanning (Orca Security team, Go); cobra
# upstream: https://orca.security/

_orca-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'project:project management'
        'asset:asset operations'
        'alert:alert operations'
        'incident:incident operations'
        'compliance:compliance operations'
        'attack-path:attack path operations'
        'image:image scanning'
        'iac:infrastructure-as-code scanning'
        'fs:filesystem scanning'
        'webhook:webhook management'
        'integration:integration management'
        'user:user operations'
        'role:role operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--api-token=+[token]:str:' \
        '--orca-project=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table sarif spdx cyclonedx)' \
        '--format=+[format]:f:(json yaml csv table sarif spdx cyclonedx)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'orca-cli subcommand' sub ;;
        args)
            case $words[1] in
                image|fs|iac) _arguments \
                    '--severity=+[s]:s:(critical high medium low informational)' \
                    '--exit-code-on=+[s]:s:(critical high medium low)' \
                    '--ignore-failed-image-scan[ignore failed image scan]' \
                    '*:target:_files' ;;
                project|asset|alert|incident|compliance|attack-path|webhook|integration|user|role) _arguments '1:op:(list get create update delete)' '*:id:' ;;
            esac
            ;;
    esac
}

_orca-cli "$@"
