#compdef saucectl
# Documentation: https://man.archlinux.org/search?q=saucectl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'run:execute test suite in Sauce Labs'
      'configure:interactive setup of credentials'
      'jobs:list or inspect jobs'
      'artifacts:fetch job assets'
      'inspect:dump resolved configuration'
      'completion:shell completion'
      'version:print version'
    )
    _describe -t commands 'saucectl command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-c --config)'{-c,--config}'=[config path]:file:_files' \
      '--region=[sauce region]:region' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
