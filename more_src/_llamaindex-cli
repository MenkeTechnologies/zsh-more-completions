#compdef llamaindex-cli llama-index

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'rag:index and query files via RAG'
  'upgrade:upgrade a directory recursively'
  'upgrade-file:upgrade a single file'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'llamaindex-cli subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (rag)
        _arguments \
          '(-q --question)'{-q,--question=}'[question to ask]:question:' \
          '*'{-f,--files=}'[files or glob]:files:_files' \
          '(-c --chat)'{-c,--chat}'[interactive chat mode]' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '--clear[clear cached index]' \
          '--create-llama[create a llama starter app]' && ret=0
        ;;
      (upgrade)
        _files -/
        ret=0
        ;;
      (upgrade-file)
        _files -g '*.(py|ipynb|md)'
        ret=0
        ;;
    esac
    ;;
esac

return ret
