#compdef rgsregions
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/rgsregions/node4.html
# Construct RGS event-selection regions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--srclist=[source definition list dataset with SRCLIST table]:file:_files' \
  '--evlist=[event list dataset with EVENTS table]:file:_files' \
  '--maxorder=[number of reflection orders to process per source]:n' \
  '--spatialres=[dispersion-axis spacing of vertices for image regions]:value' \
  '--orderres=[dispersion-axis spacing of vertices for order regions]:value' \
  '--xpsfbelow=[downward size of image regions as percentage of PSF]:value' \
  '--xpsfabove=[upward size of image regions as percentage of PSF]:value' \
  '--xpsfexcl=[size of exclusion regions as percentage of PSF]:value' \
  '--pdistincl=[size of order regions as percentage of pulse-height distribution]:value' \
  '--withpicutoff=[enable PI cutoff filtering]:bool:(yes no)' \
  '--picutoff=[minimum PI cutoff value to filter events]:value' \
  '--procsrcsexpr=[expression selecting sources to process]:expr' \
  '--exclsrcsexpr=[expression selecting sources to exclude]:expr' \
  '--setflags=[use selection expressions to set SRCLIST flag columns]:bool:(yes no)' \
  '--protect=[PROTECT attribute value for added/replaced regions]:value' \
  '--xdspregions=[cross-dispersion limits for source regions in arcmin]:value' \
  '--xdspbackground=[cross-dispersion background region limits in arcmin]:value' \
  '--spectrumbinning=[region binning type]:binning:(lambda beta)' \
  '*:param=value:_default' && ret=0

return ret
