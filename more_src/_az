#compdef az

# Zsh completion for Azure CLI

local curcontext="$curcontext" state line ret=1

local -a az_commands
az_commands=(
  'account:manage Azure subscription information'
  'acr:manage Azure Container Registries'
  'ad:manage Microsoft Entra ID (Azure Active Directory)'
  'advisor:manage Azure Advisor'
  'aks:manage Azure Kubernetes Services'
  'apim:manage Azure API Management services'
  'appconfig:manage App Configuration stores'
  'appservice:manage App Service plans'
  'backup:manage Azure Backups'
  'batch:manage Azure Batch'
  'bicep:manage Bicep CLI'
  'cdn:manage Azure Content Delivery Networks'
  'cloud:manage registered Azure clouds'
  'cognitiveservices:manage Azure Cognitive Services accounts'
  'configure:manage Azure CLI configuration'
  'container:manage Azure Container Instances'
  'cosmosdb:manage Azure Cosmos DB accounts'
  'deployment:manage ARM template deployments at subscription scope'
  'disk:manage Azure Managed Disks'
  'dla:manage Data Lake Analytics'
  'dls:manage Data Lake Store'
  'dms:manage Azure Data Migration Service'
  'eventgrid:manage Azure Event Grid'
  'eventhubs:manage Azure Event Hubs'
  'extension:manage and update CLI extensions'
  'feature:manage resource provider features'
  'find:find Azure CLI commands'
  'functionapp:manage function apps'
  'group:manage resource groups'
  'hdinsight:manage HDInsight resources'
  'identity:manage managed identities'
  'image:manage custom virtual machine images'
  'iot:manage IoT assets'
  'keyvault:manage KeyVault keys, secrets, and certificates'
  'lab:manage Azure DevTest Labs'
  'lock:manage Azure locks'
  'login:log in to Azure'
  'logout:log out to remove access to Azure subscriptions'
  'logicapp:manage logic apps'
  'managed-cassandra:manage Azure Managed Instance for Apache Cassandra'
  'managedapp:manage template solutions'
  'maps:manage Azure Maps'
  'mariadb:manage Azure Database for MariaDB'
  'monitor:manage Azure Monitor'
  'mysql:manage Azure Database for MySQL'
  'netappfiles:manage Azure NetApp Files'
  'network:manage Azure Network resources'
  'policy:manage resource policies'
  'postgres:manage Azure Database for PostgreSQL'
  'ppg:manage proximity placement groups'
  'provider:manage resource providers'
  'redis:manage dedicated Redis caches'
  'relay:manage Azure Relay'
  'resource:manage Azure resources'
  'rest:invoke a custom Azure REST API request'
  'role:manage user roles for access control'
  'search:manage Azure Search services'
  'security:manage security with Azure Security Center'
  'servicebus:manage Azure Service Bus'
  'sf:manage Azure Service Fabric'
  'sig:manage shared image galleries'
  'signalr:manage Azure SignalR Service'
  'snapshot:manage point-in-time copies of managed disks'
  'sql:manage Azure SQL Databases and Data Warehouses'
  'ssh:SSH into Azure resources'
  'sshkey:manage ssh public keys'
  'staticwebapp:manage static web apps'
  'storage:manage Azure Cloud Storage resources'
  'synapse:manage Azure Synapse Analytics'
  'tag:manage resource tags'
  'term:manage marketplace agreement'
  'ts:manage template specs at subscription scope'
  'upgrade:upgrade Azure CLI and extensions'
  'version:show version of Azure CLI modules and extensions'
  'vm:manage Linux or Windows virtual machines'
  'vmss:manage virtual machine scale sets'
  'webapp:manage web apps'
)

local -a az_global_flags
az_global_flags=(
  '(-h --help)'{-h,--help}'[show help message]'
  '--only-show-errors[only show errors, suppressing warnings]'
  '-o=[output format]:format:(json jsonc none table tsv yaml yamlc)'
  '--output=[output format]:format:(json jsonc none table tsv yaml yamlc)'
  '--query=[JMESPath query string]:query:'
  '--subscription=[name or ID of subscription]:subscription:'
  '--verbose[increase logging verbosity]'
  '--debug[increase logging verbosity to show all debug logs]'
)

_arguments -s -S \
  $az_global_flags \
  '--version[show version]' \
  '1:command:_describe -t commands command az_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      login)
        _arguments -s -S \
          $az_global_flags \
          '--allow-no-subscriptions[allow login without subscriptions]' \
          '--federated-token=[federated token]:token:' \
          '-i[log in using managed identity]' \
          '--identity[log in using managed identity]' \
          '-p=[credentials or a client secret]:password or secret:' \
          '--password=[credentials or a client secret]:password or secret:' \
          '--scope=[used in login with access token]:scope:' \
          '--service-principal[log in as a service principal]' \
          '-t=[the AAD tenant]:tenant id:' \
          '--tenant=[the AAD tenant]:tenant id:' \
          '-u=[user name or service principal client ID]:username:' \
          '--username=[user name or service principal client ID]:username:' \
          '--use-cert-sn-issuer[use subject name and issuer authentication]' \
          '--use-device-code[use device code flow]' && ret=0
        ;;
      group)
        local -a group_commands
        group_commands=(
          'create:create a new resource group'
          'delete:delete a resource group'
          'exists:check if a resource group exists'
          'export:export a resource group as a template'
          'list:list resource groups'
          'lock:manage resource group locks'
          'show:get details about a resource group'
          'update:update a resource group'
          'wait:wait for a resource group to meet a condition'
        )
        _arguments -s -S \
          $az_global_flags \
          '1:group command:_describe -t commands command group_commands' \
          '*::group args:->group_args' && ret=0
        case "$state" in
          group_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  $az_global_flags \
                  '-l=[location]:location:' \
                  '--location=[location]:location:' \
                  '-n=[resource group name]:name:' \
                  '--name=[resource group name]:name:' \
                  '--managed-by=[managed by resource id]:id:' \
                  '--tags=[space-separated tags]:tags:' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  $az_global_flags \
                  '-n=[resource group name]:name:' \
                  '--name=[resource group name]:name:' \
                  '-y[do not prompt for confirmation]' \
                  '--yes[do not prompt for confirmation]' \
                  '--no-wait[do not wait for long-running operation]' \
                  '--force-deletion-types=[resource types to force delete]:types:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $az_global_flags \
                  '--tag=[filter by tag]:tag:' && ret=0
                ;;
              show)
                _arguments -s -S \
                  $az_global_flags \
                  '-n=[resource group name]:name:' \
                  '--name=[resource group name]:name:' && ret=0
                ;;
              *)
                _arguments -s -S $az_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      aks)
        local -a aks_commands
        aks_commands=(
          'browse:open a Kubernetes dashboard'
          'create:create a managed Kubernetes cluster'
          'delete:delete a managed Kubernetes cluster'
          'disable-addons:disable Kubernetes addons'
          'enable-addons:enable Kubernetes addons'
          'get-credentials:get access credentials for a managed cluster'
          'get-upgrades:get upgrade versions'
          'get-versions:get available Kubernetes versions'
          'install-cli:download and install kubectl'
          'list:list managed Kubernetes clusters'
          'nodepool:manage node pools in a Kubernetes cluster'
          'rotate-certs:rotate certificates and keys'
          'scale:scale the agent pool in a managed cluster'
          'show:show details for a managed cluster'
          'start:start a managed cluster'
          'stop:stop a managed cluster'
          'update:update a managed cluster'
          'upgrade:upgrade a managed cluster'
          'wait:wait for a managed cluster to reach a state'
        )
        _arguments -s -S \
          $az_global_flags \
          '1:aks command:_describe -t commands command aks_commands' \
          '*::aks args:' && ret=0
        ;;
      vm)
        local -a vm_commands
        vm_commands=(
          'auto-shutdown:manage auto-shutdown for VM'
          'availability-set:group resources into availability sets'
          'create:create an Azure Virtual Machine'
          'deallocate:deallocate a VM'
          'delete:delete a VM'
          'disk:manage the managed data disks'
          'extension:manage extensions on VMs'
          'generalize:mark a VM as generalized'
          'get-instance-view:get instance information'
          'identity:manage service identities'
          'image:information on available images'
          'list:list details of Virtual Machines'
          'list-ip-addresses:list IP addresses'
          'list-sizes:list available VM sizes'
          'list-skus:get details for compute-related SKUs'
          'list-usage:list available usage resources'
          'nic:manage network interfaces'
          'open-port:open a VM to inbound traffic'
          'redeploy:redeploy an existing VM'
          'resize:update a VMs size'
          'restart:restart VMs'
          'run-command:manage run commands on a VM'
          'secret:manage VM secrets'
          'show:get details of a VM'
          'start:start a stopped VM'
          'stop:power off a VM'
          'unmanaged-disk:manage unmanaged data disks'
          'update:update a VM'
          'wait:wait until a condition is met'
        )
        _arguments -s -S \
          $az_global_flags \
          '1:vm command:_describe -t commands command vm_commands' \
          '*::vm args:' && ret=0
        ;;
      storage)
        local -a storage_commands
        storage_commands=(
          'account:manage storage accounts'
          'blob:manage object storage for unstructured data'
          'container:manage blob storage containers'
          'copy:manage storage copy operations'
          'cors:manage CORS rules'
          'directory:manage file storage directories'
          'entity:manage table storage entities'
          'file:manage file shares'
          'fs:manage file systems in Azure Data Lake Storage Gen2'
          'logging:manage storage service logging'
          'message:manage queue storage messages'
          'metrics:manage storage service metrics'
          'queue:manage storage queues'
          'share:manage file shares'
          'table:manage NoSQL key-value storage'
        )
        _arguments -s -S \
          $az_global_flags \
          '1:storage command:_describe -t commands command storage_commands' \
          '*::storage args:' && ret=0
        ;;
      webapp)
        local -a webapp_commands
        webapp_commands=(
          'browse:open a web app in a browser'
          'config:manage a web app configuration'
          'create:create a web app'
          'delete:delete a web app'
          'deleted:manage deleted web apps'
          'deployment:manage web app deployments'
          'identity:manage web app managed identities'
          'list:list web apps'
          'list-runtimes:list available built-in stacks'
          'log:manage web app logs'
          'restart:restart a web app'
          'show:get details of a web app'
          'ssh:open an SSH session to a web app container'
          'start:start a web app'
          'stop:stop a web app'
          'up:create and deploy a web app'
          'update:update a web app'
          'vnet-integration:manage virtual network integrations'
        )
        _arguments -s -S \
          $az_global_flags \
          '1:webapp command:_describe -t commands command webapp_commands' \
          '*::webapp args:' && ret=0
        ;;
      functionapp)
        local -a functionapp_commands
        functionapp_commands=(
          'config:manage function app configuration'
          'cors:manage CORS'
          'create:create a function app'
          'delete:delete a function app'
          'deployment:manage function app deployments'
          'devops-pipeline:manage Azure Function integration with Azure DevOps'
          'function:manage function app functions'
          'identity:manage identities'
          'keys:manage function app keys'
          'list:list function apps'
          'plan:manage App Service plans for function apps'
          'restart:restart a function app'
          'show:get details of a function app'
          'start:start a function app'
          'stop:stop a function app'
          'update:update a function app'
        )
        _arguments -s -S \
          $az_global_flags \
          '1:functionapp command:_describe -t commands command functionapp_commands' \
          '*::functionapp args:' && ret=0
        ;;
      acr)
        local -a acr_commands
        acr_commands=(
          'build:queue a quick build'
          'check-health:check the health of the environment'
          'create:create an Azure Container Registry'
          'credential:manage credentials for a container registry'
          'delete:delete a container registry'
          'import:import an image to a container registry'
          'list:list container registries'
          'login:log in to a container registry'
          'repository:manage repositories'
          'run:queue a quick run'
          'show:get the details of a container registry'
          'task:manage tasks'
          'update:update a container registry'
        )
        _arguments -s -S \
          $az_global_flags \
          '1:acr command:_describe -t commands command acr_commands' \
          '*::acr args:' && ret=0
        ;;
      network)
        local -a network_commands
        network_commands=(
          'application-gateway:manage application gateways'
          'dns:manage DNS domains'
          'express-route:manage ExpressRoute circuits'
          'firewall:manage Azure Firewalls'
          'lb:manage load balancers'
          'local-gateway:manage local gateways'
          'nat:manage NAT resources'
          'nic:manage network interfaces'
          'nsg:manage network security groups'
          'private-dns:manage private DNS domains'
          'private-endpoint:manage private endpoints'
          'private-link-service:manage private link services'
          'public-ip:manage public IP addresses'
          'route-table:manage route tables'
          'traffic-manager:manage Traffic Manager profiles'
          'vnet:manage virtual networks'
          'vnet-gateway:manage virtual network gateways'
          'vpn-connection:manage VPN connections'
          'watcher:manage Network Watcher'
        )
        _arguments -s -S \
          $az_global_flags \
          '1:network command:_describe -t commands command network_commands' \
          '*::network args:' && ret=0
        ;;
      keyvault)
        local -a keyvault_commands
        keyvault_commands=(
          'backup:back up a Key Vault'
          'certificate:manage certificates'
          'create:create a Key Vault'
          'delete:delete a Key Vault'
          'delete-policy:delete security policy settings'
          'key:manage keys'
          'list:list Key Vaults'
          'list-deleted:list deleted Key Vaults'
          'network-rule:manage network rules'
          'private-endpoint-connection:manage private endpoint connections'
          'private-link-resource:manage private link resources'
          'purge:permanently delete a Key Vault'
          'recover:recover a deleted Key Vault'
          'restore:restore a Key Vault'
          'secret:manage secrets'
          'set-policy:update security policy settings'
          'show:get details of a Key Vault'
          'update:update properties of a Key Vault'
        )
        _arguments -s -S \
          $az_global_flags \
          '1:keyvault command:_describe -t commands command keyvault_commands' \
          '*::keyvault args:' && ret=0
        ;;
      configure)
        _arguments -s -S \
          $az_global_flags \
          '-d=[set a default value]:default:' \
          '--defaults=[set default values]:defaults:' \
          '-l[list all available options]' \
          '--list-defaults[list all defaults]:scope:(global local)' \
          '--scope=[default scope]:scope:(global local)' && ret=0
        ;;
      account)
        local -a account_commands
        account_commands=(
          'clear:clear all subscriptions from the CLI cache'
          'get-access-token:get a token for Azure resources'
          'list:get a list of subscriptions'
          'management-group:manage Azure Management Groups'
          'set:set a subscription to be the current active subscription'
          'show:get the details of a subscription'
          'tenant:manage Azure tenants'
        )
        _arguments -s -S \
          $az_global_flags \
          '1:account command:_describe -t commands command account_commands' \
          '*::account args:' && ret=0
        ;;
      extension)
        local -a extension_commands
        extension_commands=(
          'add:add an extension'
          'list:list installed extensions'
          'list-available:list available extensions'
          'remove:remove an extension'
          'show:show details of an extension'
          'update:update an extension'
        )
        _arguments -s -S \
          $az_global_flags \
          '1:extension command:_describe -t commands command extension_commands' \
          '*::extension args:' && ret=0
        ;;
      *)
        _arguments -s -S $az_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
