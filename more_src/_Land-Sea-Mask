#compdef Land-Sea-Mask
# Documentation: https://raw.githubusercontent.com/senbox-org/snap-engine/master/snap-raster/src/main/java/org/esa/snap/raster/gpf/masks/CreateLandMaskOp.java
# ESA SNAP gpt Land-Sea-Mask operator - mask out land or sea pixels

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PsourceBands=[the list of source bands]:bands' \
  '-PlandMask=[mask out land instead of sea]:flag:(true false)' \
  '-PuseSRTM=[use SRTM to determine land and sea]:flag:(true false)' \
  '-Pgeometry=[vector geometry used as the mask]:geometry' \
  '-PinvertGeometry=[invert the geometry mask]:flag:(true false)' \
  '-PshorelineExtension=[extend the shoreline by pixels]:pixels' \
  '*:graph xml:_files' && ret=0

return ret
