#compdef smtp-cli
# _smtp-cli — michal-ludvig smtp-cli (Perl CLI for sending email with full SMTP scripting: --server host, --port, --user/--pass auth, --auth-mech, --ssl/--starttls, --from, --to, --cc, --bcc, --subject, --body, --body-html, --attach file, --replyto, --message-from-file, --hello, --add-header, --verbose, --version)
# upstream: https://github.com/mludvig/smtp-cli
# Flags from mludvig/smtp-cli on tip.

_smtp-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--server+[host]:host:_hosts' \
        '--port+[port]:port:' \
        '--user+[user]:user:_users' \
        '--pass+[password]:password:' \
        '--auth+[auth mech]:mech:(login plain cram-md5 digest-md5 ntlm)' \
        '--ssl[use SSL]' \
        '--starttls[use STARTTLS]' \
        '--from+[from address]:addr:' \
        '*--to+[to address]:addr:' \
        '*--cc+[cc address]:addr:' \
        '*--bcc+[bcc address]:addr:' \
        '--subject+[subject]:subject:' \
        '--body+[body]:body:' \
        '--body-html+[html body]:html:' \
        '--body-from-file+[file]:file:_files' \
        '--body-html-from-file+[file]:file:_files' \
        '*--attach+[attachment]:file:_files' \
        '*--attach-html+[html attachment]:file:_files' \
        '--replyto+[reply-to]:addr:' \
        '--message-from-file+[file]:file:_files' \
        '--hello+[EHLO/HELO host]:host:_hosts' \
        '*--add-header+[header]:header:' \
        '--verbose[verbose]'
}

_smtp-cli "$@"
