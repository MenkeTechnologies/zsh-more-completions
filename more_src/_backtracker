#compdef backtracker
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/spotter/backtracker.html
# Source: GenericMappingTools/gmt supplements/spotter — back/forward-track hotspot positions using rotation models.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E+[rotation (file / plate IDs / lon/lat/angle)]:opts:_default' \
    '-A+[age-range filter]:opts:_default' \
    '-D+[direction (b=backward, f=forward)]:dir:(b f)' \
    '-F+[hotspot drift history file]:file:_files' \
    '-L+[sampled paths (flowlines or hotspot tracks)]:opts:_default' \
    '-M+[opening-angle scale (default 0.5)]:factor:_default' \
    '-N+[extend oldest rotation to max age]:age:_default' \
    '-Q+[fixed age for all positions]:age:_default' \
    '-S+[per-track filestem]:stem:_default' \
    '-T+[current time reference (default 0 Ma)]:ma:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[confidence ellipse for rotated points]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-q+[row selection]:opts:_default' \
    '*:input table:_files' \
    && ret=0

return ret
