#compdef vcf2tsv
# Documentation: https://github.com/vcflib/vcflib/blob/master/src/vcf2tsv.cpp
# Reference accessed: 2026-05-27
# Verified: upstream getopt switch in src/vcf2tsv.cpp (vcflib/vcflib)

# vcf2tsv: convert VCF to a flat, tab-delimited table

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --null-value)'{-n+,--null-value=}'[replace empty values in the table with NULL_STRING]:string:' \
  '(-g --genotypes)'{-g,--genotypes}'[output one line per sample with genotype information]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz|bcf)"' && ret=0

return ret
