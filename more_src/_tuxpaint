#compdef tuxpaint
# Documentation: https://manpages.debian.org/bookworm/tuxpaint/tuxpaint.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm tuxpaint(1) manpage. Subset of ~100 flags
# covering the most common categories.
# Removed from prior file: bogus man.archlinux.org search URL.

# tuxpaint: drawing program for young children
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--verbose-version[show detailed version info]' \
  '--usage[show usage]' \
  '--copying[show copying info]' \
  '--fullscreen=[fullscreen mode]:mode:(yes native no)' \
  '--windowed[windowed mode]' \
  '--native[native fullscreen]' \
  '--orient=[orientation]:orient:(landscape portrait)' \
  '(--disablescreensaver)--allowscreensaver[allow screensaver]' \
  '(--allowscreensaver)--disablescreensaver[disable screensaver]' \
  '(--sound)--nosound[disable sound]' \
  '(--nosound)--sound[enable sound]' \
  '(--stereo)--nostereo[disable stereo]' \
  '(--nostereo)--stereo[enable stereo]' \
  '--buttonsize=[button size]:size:' \
  '--colorsrows=[color rows]:n:' \
  '(--complexshapes)--simpleshapes[simple shape tools only]' \
  '(--simpleshapes)--complexshapes[full shape tools]' \
  '(--outlines)--nooutlines[no outlines]' \
  '(--nooutlines)--outlines[show outlines]' \
  '(--mixedcase)--uppercase[uppercase only]' \
  '(--uppercase)--mixedcase[mixed case]' \
  '--stampsize=[stamp size]:size:' \
  '(--startlast)--startblank[start with blank canvas]' \
  '(--startblank)--startlast[start with last saved]' \
  '(--quit)--noquit[hide quit button]' \
  '(--noquit)--quit[show quit button]' \
  '--datadir=[data directory]:dir:_files -/' \
  '--colorfile=[color palette file]:file:_files' \
  '--locale=[locale]:locale:' \
  '--lang=[language]:lang:' \
  '--savedir=[save directory]:dir:_files -/' \
  '--exportdir=[export directory]:dir:_files -/' \
  '(--save)--nosave[disable save]' \
  '(--nosave)--save[enable save]' \
  '--onscreen-keyboard[show on-screen keyboard]' \
  '--onscreen-keyboard-layout=[keyboard layout]:layout:' \
  '--joystick-dev=[joystick device]:dev:' \
  '--noprint[disable print]' \
  '--printcommand=[print command]:cmd:' \
  '--papersize=[paper size]:size:' \
  '*:image file:_files -g "*.(png|jpg|svg)(-.)"' && ret=0
return ret
