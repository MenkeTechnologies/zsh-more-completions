#compdef airbyte-ci

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'connectors:connector-related pipelines'
  'metadata:metadata pipeline utilities'
  'tests:CI test pipelines'
  'format:formatter pipelines'
  'poetry:poetry helper pipelines'
  'update:self-update airbyte-ci'
  'version:print airbyte-ci version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--is-local[treat as local execution]' \
  '--is-ci[treat as CI execution]' \
  '--gha-workflow-run-id=[GitHub Actions workflow run id]:id:' \
  '--ci-job-key=[CI job key]:key:' \
  '--show-dagger-logs[show dagger logs]' \
  '--enable-update-check[allow auto-update]' \
  '--disable-update-check[skip auto-update]' \
  '--enable-report-auto-open[auto-open HTML report]' \
  '--ci-git-branch=[CI git branch]:branch:' \
  '--ci-git-revision=[CI git revision]:sha:' \
  '--ci-context=[CI context]:context:(pull_request manual master)' \
  '--ci-report-bucket-name=[GCS bucket for reports]:bucket:' \
  '--ci-gcp-credentials=[GCP service account JSON]:json:' \
  '--diffed-branch=[compare against branch]:branch:' \
  '--max-concurrency=[max concurrent pipelines]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'airbyte-ci command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (connectors)
        _arguments \
          '*::sub:(build test format upgrade-base-image migrate publish bump_version up-to-date pull-request)' \
          '*--name=[connector name]:name:' \
          '*--language=[connector language]:lang:(python low-code java manifest-only)' \
          '*--modified[only modified connectors]' \
          '*--metadata-change-only[only metadata-only changes]' \
          '--support-level=[support level]:level:(community certified custom)' \
          '*--use-local-cdk[use local CDK]' \
          '--pre-release[mark as pre-release]' \
          '--main-release[mark as main release]' \
          '--code-tests-only[only code-level tests]' \
          '*--report-output-prefix=[report output prefix]:prefix:' \
          '--release-candidate[release candidate]' \
          '--concurrency=[concurrency]:n:' && ret=0 ;;
      (metadata)
        _arguments \
          '*::sub:(validate upload deploy promote)' \
          '--bucket-name=[GCS bucket]:bucket:' \
          '--gcs-credentials=[GCS credentials JSON]:json:' && ret=0 ;;
      (tests)
        _arguments \
          '--pytest-options=[pytest options]:opts:' && ret=0 ;;
      (format)
        _arguments \
          '*::sub:(check fix)' && ret=0 ;;
      (poetry)
        _arguments \
          '*::sub:(install build publish)' && ret=0 ;;
    esac ;;
esac

return ret
