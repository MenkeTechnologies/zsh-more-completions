#compdef kafka-verifiable-consumer
# Documentation: https://kafka.apache.org/documentation/ (kafka-verifiable-consumer.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '(- *)'{-h,--help}'[Show this help message and exit]'
    '--topic[Consumes messages from this topic]:topic:'
    "--group-protocol[Group protocol]:protocol:(CLASSIC CONSUMER)"
    '--group-remote-assignor[Group remote assignor (only if group protocol is CONSUMER)]:assignor:'
    '--group-id[The group id of the consumer group]:group:'
    '--group-instance-id[A unique identifier of the consumer instance]:id:'
    '--max-messages[Consume this many messages (-1 to consume until killed)]:count:'
    '--session-timeout[Set the consumer session timeout in ms]:ms:'
    '--verbose[Log individual consumed records]'
    '--enable-autocommit[Enable offset auto-commit on consumer]'
    "--reset-policy[Set reset policy]:policy:(earliest latest none)"
    '--assignment-strategy[Set assignment strategy (only if group protocol is CLASSIC)]:strategy:'
    '--consumer.config[(DEPRECATED) Consumer config properties file]:file:_files'
    '--command-config[Config properties file]:file:_files'
    '--bootstrap-server[The server(s) to connect to]:host\:port:'
)

_arguments -s -S $arguments
