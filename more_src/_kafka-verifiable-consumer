#compdef kafka-verifiable-consumer

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--topic[Topic to consume from]:topic:'
    '--group-id[Consumer group ID]:group:'
    '--max-messages[Maximum number of messages to consume (-1 for unlimited)]:count:'
    '--session-timeout[Session timeout in ms]:ms:'
    '--verbose[Print verbose output]'
    '--enable-autocommit[Enable auto commit]'
    '--reset-policy[Offset reset policy]:policy:(earliest latest none)'
    '--assignment-strategy[Consumer partition assignment strategy]:strategy:'
    '--consumer.config[Consumer config properties file]:file:_files'
    '--group-instance-id[Static group instance ID]:id:'
)

_arguments -s -S $arguments
