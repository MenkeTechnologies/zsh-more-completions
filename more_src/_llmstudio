#compdef llmstudio
# _llmstudio — TensorOps llmstudio platform for prototyping monitoring evaluating and serving LLM applications (TensorOpsAI team, Python); typer
# upstream: https://github.com/TensorOpsAI/LLMstudio

_llmstudio() {
    local -a sub=(
        'server:start LLMstudio server'
        'ui:start LLMstudio web UI'
        'config:configuration subcommands'
        'providers:provider subcommands'
        'tracking:tracking subcommands'
        'sessions:session subcommands'
        'session:session alias'
        'logs:show logs'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.toml *.json"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.toml *.json"' \
        '--workspace=+[workspace dir]:dir:_files -/' \
        '--api-key=+[API key]:str:' \
        '--no-tracking[disable tracking]' \
        '--no-telemetry[disable telemetry]' \
        '--debug[debug logging]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--install-completion=+[shell]:s:(bash zsh fish)' \
        '--show-completion=+[shell]:s:(bash zsh fish)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'llmstudio subcommand' sub ;;
        args)
            case $words[1] in
                server) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--engine-port=+[port]:port:_ports' \
                    '--tracking-port=+[port]:port:_ports' \
                    '--ui-port=+[port]:port:_ports' \
                    '--workers=+[N]:n:' \
                    '--reload[reload on change]' ;;
                ui) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:_ports' ;;
                providers) _arguments '1:providers cmd:(list show test add remove)' ;;
                tracking) _arguments '1:tracking cmd:(list show clear export)' ;;
                sessions|session) _arguments '1:session cmd:(list show create delete)' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_llmstudio "$@"
