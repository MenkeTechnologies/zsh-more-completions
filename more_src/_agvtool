#compdef agvtool

local -a subcommands

subcommands=(
    'what-version:Print current project version'
    'what-marketing-version:Print current marketing version'
    'vers:Alias for what-version'
    'mvers:Alias for what-marketing-version'
    'new-version:Set the project version number'
    'new-marketing-version:Set the marketing version string'
    'next-version:Increment the project version number'
    'bump:Alias for next-version'
    'tag:Tag the project with its current version'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*:: :->args' && return

case $state in
    subcmd)
        _describe 'agvtool subcommand' subcommands
        ;;
    args)
        case $words[1] in
            new-version)
                _arguments \
                    '-all[Update all targets]' \
                    '1:version number'
                ;;
            new-marketing-version)
                _arguments \
                    '1:marketing version string'
                ;;
            next-version)
                _arguments \
                    '-all[Update all targets]'
                ;;
            what-version|vers)
                _arguments \
                    '-terse[Output version number only]'
                ;;
            what-marketing-version|mvers)
                _arguments \
                    '-terse[Output version string only]' \
                    '-terse1[Output first version string only]'
                ;;
        esac
        ;;
esac
