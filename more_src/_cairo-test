#compdef cairo-test
# Documentation: https://github.com/starkware-libs/cairo/tree/main/crates/bin/cairo-test
# Source: starkware-libs/cairo crates/bin/cairo-test/src/main.rs — Cairo test runner.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-s --single-file)'{-s,--single-file}'[treat path as a single file]' \
    '--allow-warnings[allow compilation to succeed with warnings]' \
    '(-f --filter)'{-f+,--filter=}'[run only tests containing this string]:filter:_default' \
    '--include-ignored[run ignored tests as well]' \
    '--ignored[run only the ignored tests]' \
    '--starknet[add the Starknet plugin to run the tests]' \
    '(-r --run-profiler)'{-r+,--run-profiler=}'[run the profiler]:mode:(none cairo sierra)' \
    '--gas-disabled[disable gas calculation]' \
    '--print-resource-usage[print resource usage after each test]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:path:_files' \
    && ret=0

return ret
