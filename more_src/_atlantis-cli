#compdef atlantis-cli atlantis
# _atlantis-cli — runatlantis/atlantis Terraform pull-request automation server (HashiCorp/runatlantis, Go); spf13/cobra CLI
# upstream: https://github.com/runatlantis/atlantis

_atlantis-cli() {
    local -a sub=(
        'server:start atlantis server'
        'testdrive:try atlantis with sample repo'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'atlantis subcommand' sub ;;
        args)
            case $words[1] in
                server) _arguments \
                    '--atlantis-url=+[atlantis url]:url:_urls' \
                    '--allow-commands=+[allow commands]:cmds:' \
                    '--allow-fork-prs[allow fork PRs]' \
                    '--allow-draft-prs[allow draft PRs]' \
                    '--api-secret=+[api secret]:str:' \
                    '--azuredevops-token=+[azure devops token]:str:' \
                    '--azuredevops-user=+[azure devops user]:str:_users' \
                    '--azuredevops-webhook-password=+[azure devops webhook password]:str:' \
                    '--azuredevops-webhook-user=+[azure devops webhook user]:str:_users' \
                    '--bitbucket-base-url=+[bitbucket base url]:url:_urls' \
                    '--bitbucket-token=+[bitbucket token]:str:' \
                    '--bitbucket-user=+[bitbucket user]:str:_users' \
                    '--bitbucket-webhook-secret=+[bitbucket webhook secret]:str:' \
                    '--checkout-strategy=+[checkout strategy]:strategy:(branch merge)' \
                    '--config=+[config file]:file:_files' \
                    '--data-dir=+[data dir]:dir:_files -/' \
                    '--default-tf-version=+[default tf version]:ver:' \
                    '--disable-apply-all[disable apply all]' \
                    '--disable-autoplan[disable autoplan]' \
                    '--disable-markdown-folding[disable markdown folding]' \
                    '--disable-repo-locking[disable repo locking]' \
                    '--enable-policy-checks[enable policy checks]' \
                    '--gh-app-id=+[github app id]:id:' \
                    '--gh-app-key=+[github app key]:str:' \
                    '--gh-app-key-file=+[github app key file]:file:_files' \
                    '--gh-hostname=+[github hostname]:host:_hosts' \
                    '--gh-token=+[github token]:str:' \
                    '--gh-user=+[github user]:str:_users' \
                    '--gh-webhook-secret=+[github webhook secret]:str:' \
                    '--gitlab-hostname=+[gitlab hostname]:host:_hosts' \
                    '--gitlab-token=+[gitlab token]:str:' \
                    '--gitlab-user=+[gitlab user]:str:_users' \
                    '--gitlab-webhook-secret=+[gitlab webhook secret]:str:' \
                    '--log-level=+[log level]:level:(debug info warn error)' \
                    '--port=+[port]:port:' \
                    '--repo-allowlist=+[repo allowlist]:list:' \
                    '--repo-config=+[repo config]:file:_files' \
                    '--repo-config-json=+[repo config json]:str:' \
                    '--silence-fork-pr-errors[silence fork PR errors]' \
                    '--silence-no-projects[silence no projects]' \
                    '--silence-vcs-status-no-plans[silence vcs status no plans]' \
                    '--ssl-cert-file=+[ssl cert]:file:_files' \
                    '--ssl-key-file=+[ssl key]:file:_files' \
                    '--tf-download-url=+[tf download url]:url:_urls' \
                    '--write-git-creds[write git creds]' ;;
                testdrive|version|help) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_atlantis-cli "$@"
