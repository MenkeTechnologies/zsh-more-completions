#compdef impacket-dacledit
# Documentation: https://github.com/fortra/impacket/blob/master/examples/dacledit.py
# Python editor for a principal's DACL

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-use-ldaps[use LDAPS instead of LDAP]' \
  '-ts[adds timestamp to every logging output]' \
  '-debug[turn DEBUG output ON]' \
  '-hashes=[NTLM hashes, format is LMHASH:NTHASH]:hashes' \
  '-no-pass[don'\''t ask for password (useful for -k)]' \
  '-k[use Kerberos authentication from ccache file]' \
  '-aesKey=[AES key to use for Kerberos authentication (128 or 256 bits)]:hexkey' \
  '-dc-ip=[IP address of the domain controller or KDC for Kerberos]:ip' \
  '-dc-host=[hostname of the domain controller or KDC for Kerberos]:hostname' \
  '-principal=[sAMAccountName]:name' \
  '-principal-sid=[security identifier]:sid' \
  '-principal-dn=[distinguished name]:dn' \
  '-target=[sAMAccountName]:name' \
  '-target-sid=[security identifier]:sid' \
  '-target-dn=[distinguished name]:dn' \
  '-action=[action to operate on the DACL]:action:(read write remove backup restore)' \
  '-file=[filename/path]:file:_files' \
  '-ace-type=[the ACE type to add or remove]:type:(allowed denied)' \
  '-rights=[rights to write/remove]:rights:(FullControl ResetPassword WriteMembers DCSync Custom)' \
  '-rights-guid=[manual GUID representing the right to write/remove]:guid' \
  '-mask=[force access mask]:mask' \
  '-inheritance[enable inheritance in ACE flags]' \
  '1:identity (domain.local/username\[:password\]):' && ret=0

return ret
