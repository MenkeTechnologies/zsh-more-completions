#compdef gitlab-ci-local

# Zsh completion for gitlab-ci-local - run GitLab CI pipelines locally

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--cwd=[working directory]:directory:_directories' \
  '--file=[gitlab-ci file]:file:_files -g "*.{yml,yaml}"' \
  '--home=[home directory]:directory:_directories' \
  '--shell-isolation[use shell isolation]' \
  '--no-shell-isolation[disable shell isolation]' \
  '--fetch-includes[fetch remote includes]' \
  '--no-fetch-includes[do not fetch remote includes]' \
  '--mount-cache[mount cache volumes]' \
  '--umask=[umask for created files]:umask' \
  '--needs[enable needs keyword]' \
  '--no-needs[disable needs keyword]' \
  '--variable=[set variable]:KEY=VALUE' \
  '--unset-variable=[unset a variable]:KEY' \
  '--remote-variables=[file with remote variables]:file:_files' \
  '--state-dir=[state directory]:directory:_directories' \
  '--artifacts-to-source[copy artifacts to source]' \
  '--cleanup[remove containers and volumes]' \
  '--preview[preview pipeline without running]' \
  '--list[list jobs]' \
  '--list-csv[list jobs as CSV]' \
  '--completion[generate completion script]' \
  '--container-executable=[container executable]:executable:(docker podman)' \
  '--extra-host=[extra /etc/hosts entries]:host' \
  '--network=[container network]:network' \
  '--volumes=[additional volumes]:volume' \
  '--privileged[run in privileged mode]' \
  '*:job name' && ret=0

return ret
