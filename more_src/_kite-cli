#compdef kite-cli kite
# _kite-cli — Zerodha Kite kite-cli CLI command-line frontend wrapping the Zerodha Kite Connect 3 REST WebSocket API for Indian stock retail brokerage running order placement portfolio fetching market quote LTP OHLC historical-candles charts modify-cancel-exit-bracket-cover-order GTT-orderbook tradebook holdings-positions-margin (Zerodha Kite team, Go); cobra
# upstream: https://kite.trade/

_kite-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'order:order operations'
        'trade:trade operations'
        'position:position operations'
        'holding:holding operations'
        'funds:funds operations'
        'margin:margin operations'
        'gtt:GTT operations'
        'instrument:instrument list'
        'quote:quote operations'
        'ohlc:OHLC data'
        'ltp:LTP last traded price'
        'historical:historical candles'
        'chart:chart operations'
        'postback:postback management'
        'tradebook:tradebook'
        'orderbook:orderbook'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--access-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kite-cli subcommand' sub ;;
        args)
            case $words[1] in
                order|trade|position|holding|funds|margin|gtt|tradebook|orderbook|postback) _arguments '1:op:(list get place cancel modify exit)' '*:id:' ;;
                instrument|quote|ohlc|ltp|historical|chart) _arguments '*:instrument token:' ;;
            esac
            ;;
    esac
}

_kite-cli "$@"
