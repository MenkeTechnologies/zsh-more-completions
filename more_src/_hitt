#compdef hitt
# Source: cargo binstall hitt@0.0.21
# Probed via: completions zsh
# Repository: https://github.com/hougesen/hitt

autoload -U is-at-least

_hitt() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_hitt_commands" \
"*::: :->hitt" \
&& ret=0
    case $state in
    (hitt)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:hitt-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
'--timeout=[Request timeout in milliseconds]:TIMEOUT_MS:_default' \
'*--var=[Variables to pass to request]:KEY>=<VALUE:_default' \
'-r[Enable to run directory recursively]' \
'--recursive[Enable to run directory recursively]' \
'--fail-fast[Exit on error response status code]' \
'--hide-body[Whether or not to show response body]' \
'--hide-headers[Whether or not to show response headers]' \
'--disable-formatting[Disable pretty printing of response body]' \
'--vim[]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'*::paths -- Path to .http files, or directories if supplied with the `--recursive` argument:_files' \
&& ret=0
;;
(sse)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':url:_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':shell:(bash elvish fish nushell powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_hitt__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:hitt-help-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(sse)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_hitt_commands] )) ||
_hitt_commands() {
    local commands; commands=(
'run:Send http requests' \
'sse:Listen to sse events' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'hitt commands' commands "$@"
}
(( $+functions[_hitt__completions_commands] )) ||
_hitt__completions_commands() {
    local commands; commands=()
    _describe -t commands 'hitt completions commands' commands "$@"
}
(( $+functions[_hitt__help_commands] )) ||
_hitt__help_commands() {
    local commands; commands=(
'run:Send http requests' \
'sse:Listen to sse events' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'hitt help commands' commands "$@"
}
(( $+functions[_hitt__help__completions_commands] )) ||
_hitt__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'hitt help completions commands' commands "$@"
}
(( $+functions[_hitt__help__help_commands] )) ||
_hitt__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'hitt help help commands' commands "$@"
}
(( $+functions[_hitt__help__run_commands] )) ||
_hitt__help__run_commands() {
    local commands; commands=()
    _describe -t commands 'hitt help run commands' commands "$@"
}
(( $+functions[_hitt__help__sse_commands] )) ||
_hitt__help__sse_commands() {
    local commands; commands=()
    _describe -t commands 'hitt help sse commands' commands "$@"
}
(( $+functions[_hitt__run_commands] )) ||
_hitt__run_commands() {
    local commands; commands=()
    _describe -t commands 'hitt run commands' commands "$@"
}
(( $+functions[_hitt__sse_commands] )) ||
_hitt__sse_commands() {
    local commands; commands=()
    _describe -t commands 'hitt sse commands' commands "$@"
}

if [ "$funcstack[1]" = "_hitt" ]; then
    _hitt "$@"
else
    compdef _hitt hitt
fi
