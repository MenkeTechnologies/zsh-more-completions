#compdef overlay
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/fslwiki/Miscvis
# FSL: overlay one or two statistical images on a background image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-a[automatically threshold background to make it transparent]' \
  '-A[use full background range and make transparent]' \
  '-c[output colour rendering of overlay]' \
  '*:image:_files' && ret=0

return ret
