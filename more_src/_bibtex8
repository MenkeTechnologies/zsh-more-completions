#compdef bibtex8 bibtexu
# Documentation: bibtex8 --help
# Source: TeX bibtex8 / bibtexu — 8-bit / Unicode BibTeX.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help}'[show help]' \
    '(-7 --traditional -8 --8bit)'{-7,--traditional}'[7-bit BibTeX mode]' \
    '(-7 --traditional -8 --8bit)'{-8,--8bit}'[8-bit mode (no CS file)]' \
    '(-c --csfile)'{-c,--csfile=}'[BibTeX character-set / sort file]:file:_files -g "*.csf"' \
    '(-d --debug)'{-d,--debug=}'[report debugging info]:type:(all csf io mem misc search)' \
    '(-s --statistics)'{-s,--statistics}'[report internal statistics]' \
    '(-t --trace)'{-t,--trace}'[report execution tracing]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-B --big -H --huge -W --wolfgang --mstrings)'{-B,--big}'[mstrings = 10000]' \
    '(-B --big -H --huge -W --wolfgang --mstrings)'{-H,--huge}'[mstrings = 19000]' \
    '(-B --big -H --huge -W --wolfgang --mstrings)'{-W,--wolfgang}'[mstrings = 30000]' \
    '(-M --min_crossrefs)'{-M,--min_crossrefs=}'[set min_crossrefs]:n:' \
    '(-B --big -H --huge -W --wolfgang --mstrings)--mstrings=[unique strings]:n:' \
    '1:aux file:_files -g "*.aux"' \
    && ret=0

return ret
