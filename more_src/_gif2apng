#compdef gif2apng
# Documentation: https://gif2apng.sourceforge.net/
# convert an animated GIF to an animated PNG (APNG) file

local ret=1

_arguments -s \
  '-z0[use zlib compression]' \
  '-z1[use 7zip compression (default)]' \
  '-z2[use Zopfli compression]' \
  '-i+[number of iterations for 7zip/Zopfli (default 15)]:iterations' \
  '-kp[keep palette from GIF as is, do not optimize it]' \
  '1:input gif:_files -g "*.(gif|GIF)"' \
  '2:output png:_files -g "*.(png|apng)"' && ret=0

return ret
