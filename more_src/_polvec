#compdef polvec
# Documentation: https://starlink.eao.hawaii.edu/docs/sun223.htx/sun223ss16.html
# POLPACK: calculates polarization vectors from supplied Stokes parameters.

local ret=1

_arguments -s -S \
  'IN=[input 3D/4D Stokes cube]:ndf:_files' \
  'CAT=[output catalogue]:cat:_files' \
  'I=[output NDF for total intensity]:ndf:_files' \
  'P=[output NDF for percentage polarization]:ndf:_files' \
  'IP=[output NDF for polarized intensity]:ndf:_files' \
  'ANG=[output NDF for polarization angle]:ndf:_files' \
  'Q=[output NDF for Q Stokes parameter]:ndf:_files' \
  'U=[output NDF for U Stokes parameter]:ndf:_files' \
  'V=[output NDF for V Stokes parameter]:ndf:_files' \
  'BOX=[bin sizes in pixels]:box:' \
  'METHOD=[binning method]:method:(MEAN MEDIAN SIGMA)' \
  'SIGMAS=[std devs for sigma-clipped rejection]:n:' \
  'DEBIAS=[apply statistical bias correction]:flag:(TRUE FALSE)' \
  'DEBIASTYPE=[bias estimator type]:type:(AS MAS)' \
  'RADEC=[include RA/DEC columns]:flag:(TRUE FALSE)' \
  'REFUPDATE=[update reference direction to north]:flag:(TRUE FALSE)' \
  'VARIANCE=[calculate output variances]:flag:(TRUE FALSE)' \
  'WLIM=[min fraction of good pixels per bin]:frac:' \
  '*:ndf:_files' && ret=0

return ret
