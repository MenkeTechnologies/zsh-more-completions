#compdef zimfw
# Documentation: https://man.archlinux.org/search?q=zimfw
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build init.zsh and login_init.zsh (also compile)'
  'clean:clean compiled and dumpfile'
  'clean-compiled:clean Zsh compiled files'
  'clean-dumpfile:clean completion dumpfile'
  'compile:compile Zsh files'
  'info:print zimfw and system info'
  'list:list all configured modules'
  'init:install (output tailored for terminal startup)'
  'install:install new modules (also builds + compiles)'
  'update:update current modules (also builds + compiles)'
  'reinstall:reinstall modules that failed check'
  'uninstall:delete unused modules'
  'check:check for module updates'
  'check-version:check if a new zimfw version is available'
  'upgrade:upgrade zimfw'
  'version:show zimfw version'
  'help:show help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-q[quiet mode (only errors)]' \
  '-v[verbose mode]' \
  '*::cmd:->cmd' && ret=0

case $state in
  (cmd) _describe -t cmds 'zimfw command' commands && ret=0 ;;
esac

return ret
