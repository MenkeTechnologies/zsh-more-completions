#compdef interactsh-client interactsh-server

# Zsh completion for ProjectDiscovery Interactsh

local curcontext="$curcontext" state line ret=1

case $service in
  interactsh-client)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '-s+[interactsh server URL]:server url' \
      '-token+[authentication token]:token' \
      '-n+[number of interactsh payloads to generate]:number' \
      '-o+[output file]:file:_files' \
      '-json[output as JSON]' \
      '-v[show verbose output]' \
      '-poll-interval+[poll interval in seconds]:seconds' \
      '-dns-only[show only DNS interactions]' \
      '-http-only[show only HTTP interactions]' \
      '-smtp-only[show only SMTP interactions]' \
      && ret=0
    ;;
  interactsh-server)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '-d+[domain to use for interactsh]:domain' \
      '-ip+[public IP address]:ip' \
      '-listen-ip+[IP to listen on]:ip' \
      '-http-port+[HTTP port]:port' \
      '-https-port+[HTTPS port]:port' \
      '-dns-port+[DNS port]:port' \
      '-smtp-port+[SMTP port]:port' \
      && ret=0
    ;;
esac

return ret
