#compdef atlod
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/atlod.html
# MIRIAD atlod - load ATCA RPFITS data into a Miriad dataset

local ret=1

_arguments -s -S \
  'in=[input RPFITS files]:in:_files' \
  'out=[output Miriad uv dataset]:out:_files' \
  'ifsel=[IF numbers to extract]:ifsel' \
  'restfreq=[rest frequency in GHz]:restfreq' \
  'options=[birdie,reweight,compress,noauto,nocross,relax,mmrelax,unflag,opcorr,samcorr,xycorr,hanning,bary,noif,nopflag,hires,pmps,single,caldata,nocacal,nopol,rfiflag,notsys,nopack,purpose]:options' \
  'nfiles=[number of files to skip then process]:nfiles' \
  'nscans=[number of scans to skip then process]:nscans' \
  'nopcorr=[frequencies per IF for opacity correction]:nopcorr' \
  'edge=[percent edge channels birdie flags]:edge' \
  '*:RPFITS file:_files' && ret=0

return ret
