#compdef zeitfetch
# Documentation: https://github.com/nidnogg/zeitfetch
# zeitfetch - instantaneous snapshots of system information

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display usage information]' \
  '--no-logo[omit logo]' \
  '--logo-only[omit sys info text]' \
  '--minimal[display logo and user prompt vertically]' && ret=0

return ret
