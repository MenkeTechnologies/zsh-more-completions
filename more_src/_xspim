#compdef xspim
# Documentation: https://manpages.debian.org/testing/spim/spim.1.en.html
# xspim X11 interface for the spim MIPS assembly language simulator

local ret=1

_arguments -s -S \
  '-asm[simulate the virtual MIPS machine provided by the assembler (default)]' \
  '-bare[simulate a bare MIPS machine without pseudo-instructions]' \
  '-exception[load the standard exception handler and startup code (default)]' \
  '-noexception[do not load the standard exception handler and startup code]' \
  '-quiet[print a message when an exception occurs (default)]' \
  '-noquiet[do not print a message at exceptions]' \
  '-mapped_io[enable the memory-mapped IO facility]' \
  '-nomapped_io[disable the memory-mapped IO facility]' \
  '-delayed_branches[simulate MIPS delayed control transfers]' \
  '-delayed_loads[simulate MIPS original non-interlocked load instructions]' \
  '-stext[set initial size of text segment in bytes]:size' \
  '-sdata[set initial size of data segment in bytes]:size' \
  '-sstack[set initial size of stack segment in bytes]:size' \
  '-sktext[set initial size of kernel text segment in bytes]:size' \
  '-skdata[set initial size of kernel data segment in bytes]:size' \
  '-ldata[set limit on data segment size in bytes]:size' \
  '-lstack[set limit on stack segment size in bytes]:size' \
  '-lkdata[set limit on kernel data segment size in bytes]:size' \
  '-file[load and execute assembly code in file with args]:file:_files' \
  '-execute[load and execute the MIPS executable (a.out) file with args]:file:_files' \
  '*:file:_files' && ret=0

return ret
