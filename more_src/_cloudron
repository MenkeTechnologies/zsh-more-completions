#compdef cloudron
# Documentation: https://man.archlinux.org/search?q=cloudron
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'appstore:app store ops'
  'backup:backup ops'
  'build:build app'
  'completion:shell completions'
  'cancel:cancel operation'
  'clone:clone app'
  'configure:configure app'
  'set-location:set app location'
  'debug:debug app'
  'env:env vars'
  'exec:exec in app'
  'export:export data'
  'import:import data'
  'inspect:inspect app'
  'init:init app project'
  'install:install app'
  'list:list apps'
  'login:login'
  'logout:logout'
  'logs:tail logs'
  'open:open app URL'
  'pull:pull files'
  'push:push files'
  'sync:sync files'
  'repair:repair app'
  'restore:restore app'
  'restart:restart app'
  'start:start app'
  'stop:stop app'
  'status:app status'
  'uninstall:uninstall app'
  'update:update app'
  'versions:list versions'
)

_arguments -C \
  '--server=[Cloudron domain]:domain:' \
  '--token=[token]:token:' \
  '(--allow-selfsigned --accept-selfsigned)'{--allow-selfsigned,--accept-selfsigned}'[accept self-signed TLS]' \
  '--no-wait[no wait]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'cloudron subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '--image=[docker image]:image:' \
          '(-p --port-bindings)'{-p,--port-bindings}'=[bindings]:bindings:' \
          '(-l --location)'{-l,--location}'=[domain]:domain:' \
          '(-s --secondary-domains)'{-s,--secondary-domains}'=[domains]:list:' \
          '(-a --alias-domains)'{-a,--alias-domains}'=[domains]:list:' \
          '(-m --memory-limit)'{-m,--memory-limit}'=[limit]:limit:' \
          '--appstore-id=[appid]:id:' \
          '--versions-url=[URL]:url:' \
          '--no-sso[no SSO]' \
          '--debug[debug]' \
          '--readonly[readonly]' \
          '*--env=[KEY=value]:env:' \
          '*--build-arg=[arg]:arg:' \
          '(-f --file)'{-f,--file}'=[Dockerfile]:file:_files' && ret=0 ;;
      (logs)
        _arguments \
          '(-f --tail)'{-f,--tail}'[tail]' \
          '(-l --lines)'{-l,--lines}'=[lines]:n:' \
          '--ndjson[NDJSON]' \
          '--app=[app]:app:' \
          '--system=[service]:service:' && ret=0 ;;
      (list) _arguments '(-q --quiet)'{-q,--quiet}'[quiet]' '(-t --tag)'{-t,--tag}'=[tag]:tag:' && ret=0 ;;
      (exec) _arguments '(-t --tty)'{-t,--tty}'[tty]' '--app=[app]:app:' && ret=0 ;;
    esac
    ;;
esac

return ret
