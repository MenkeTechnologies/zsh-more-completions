#compdef 3dBandpass
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dBandpass.html
# Bandpass time series, plus other processing for resting-state FMRI

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-despike[remove spikes from each time series first]' \
  '*-ort[orthogonalize input to columns in file]:file:_files' \
  '-dsort[orthogonalize each voxel to dataset time series]:dataset:_files' \
  '-nodetrend[skip quadratic detrending before FFT]' \
  '-dt[time step in seconds]:dt:' \
  '-nfft[FFT length]:n:' \
  '-norm[normalize output to L2 norm of 1]' \
  '-mask[apply a mask dataset]:dataset:_files' \
  '-automask[create mask automatically from input]' \
  '-blur[Gaussian blur FWHM in mm within mask]:fwhm:' \
  '-localPV[replace vectors with local principal vector]:rad:' \
  '-input[input dataset]:dataset:_files' \
  '-band[passband frequencies]:fbot: :ftop:' \
  '-prefix[output dataset prefix]:prefix:' \
  '-quiet[suppress informational messages]' \
  '-notrans[skip initial transient detection check]' \
  '-nosat[skip initial transient detection check]' \
  '*:dataset:_files' && ret=0

return ret
