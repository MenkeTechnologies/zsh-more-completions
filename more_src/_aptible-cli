#compdef aptible-cli aptible
# _aptible-cli — Aptible PaaS for HITRUST-certified deployments CLI alias (aptible team, Ruby); thor
# upstream: https://github.com/aptible/aptible-cli

_aptible-cli() {
    local -a sub=(
        'apps:list apps'
        'apps:create:create app'
        'apps:scale:scale services'
        'apps:deprovision:deprovision app'
        'apps:rename:rename app'
        'backup:operations'
        'backup:list:list backups'
        'backup:restore:restore backup'
        'backup:purge:purge backup'
        'backup_retention_policy:show:show retention'
        'backup_retention_policy:set:set retention'
        'config:get config'
        'config:add:add env var'
        'config:rm:remove env var'
        'config:set:set env vars'
        'config:unset:unset env vars'
        'db:create:create database'
        'db:clone:clone database'
        'db:list:list databases'
        'db:reload:reload database'
        'db:dump:dump database'
        'db:execute:execute SQL'
        'db:tunnel:open tunnel'
        'db:url:show URL'
        'db:credentials:show creds'
        'db:deprovision:deprovision'
        'db:restart:restart db'
        'db:replicate:replicate'
        'db:upgrade:upgrade db'
        'db:rename:rename db'
        'db:backup:create backup'
        'db:backups:list backups'
        'db:versions:list versions'
        'deploy:deploy app'
        'domains:list domains'
        'endpoints:list endpoints'
        'endpoints:database:create:create db endpoint'
        'endpoints:https:create:create https endpoint'
        'endpoints:tcp:create:create tcp endpoint'
        'endpoints:deprovision:deprovision endpoint'
        'endpoints:renew:renew SSL'
        'environment:rename:rename env'
        'environment:ca_cert:show CA cert'
        'environments:list envs'
        'environments:ca_cert:print CA cert'
        'environments:create:create env'
        'logout:logout'
        'login:login'
        'maintenance:apps:list apps in maintenance'
        'maintenance:dbs:list dbs in maintenance'
        'metric_drains:create:create metric drain'
        'metric_drains:list:list metric drains'
        'metric_drains:remove:remove metric drain'
        'log_drain:create:elasticsearch[create ES log drain]'
        'log_drain:create:syslog[create syslog log drain]'
        'log_drain:create:logdna[create LogDNA log drain]'
        'log_drain:create:papertrail[create papertrail]'
        'log_drains:list:list log drains'
        'log_drains:remove:remove log drain'
        'logs:show logs'
        'operation:cancel:cancel operation'
        'operation:follow:follow operation'
        'operation:logs:show operation logs'
        'ps:show running processes'
        'rebuild:rebuild app'
        'restart:restart app'
        'services:list services'
        'services:autoscaling_policy:show:show autoscaling policy'
        'services:autoscaling_policy:set:set autoscaling policy'
        'services:autoscaling_policy:remove:remove autoscaling policy'
        'services:settings:set CMD/PROCFILE'
        'ssh:ssh into app'
        'org:create:create org'
        'orgs:list:list orgs'
        'version:show version'
        'help:show help'
        'autocomplete:install autocomplete'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aptible subcommand' sub ;;
        args)
            case $words[1] in
                deploy) _arguments \
                    '--app=+[app]:str:' \
                    '--git-detach[detach git]' \
                    '--git-commitish=+[commit]:str:' \
                    '--docker-image=+[image]:str:' \
                    '--private-registry-email=+[email]:str:' \
                    '--private-registry-username=+[user]:_users' \
                    '--private-registry-password=+[pass]:str:' ;;
                autocomplete) _arguments '1:shell:(bash zsh)' ;;
            esac
            ;;
    esac
}

_aptible-cli "$@"
