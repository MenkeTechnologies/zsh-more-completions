#compdef spctl

_arguments -s \
  '(- *)-h[show help]' \
  '(-a --assess)'{-a,--assess}'[assess a file or bundle]' \
  '--status[show Gatekeeper status]' \
  '--global-enable[enable Gatekeeper globally]' \
  '--global-disable[disable Gatekeeper globally]' \
  '--disable-status[show whether Gatekeeper is disabled]' \
  '--continue[continue past errors]' \
  '--ignore-cache[ignore the cache]' \
  '--no-cache[do not cache]' \
  '--raw[output raw plist]' \
  '(-t --type)'{-t,--type=}'[assessment type]:type:(execute install open)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--add[add rule (deprecated)]' \
  '--remove[remove rule (deprecated)]' \
  '--enable[enable rule (deprecated)]' \
  '--disable[disable rule (deprecated)]' \
  '--reset-default[reset to default rules (deprecated)]' \
  '--anchor=[anchor name (deprecated)]:anchor:' \
  '--hash=[file hash (deprecated)]:hash:' \
  '--label=[rule label (deprecated)]:label:' \
  '--path[treat target as path (deprecated)]' \
  '--priority=[rule priority (deprecated)]:priority:' \
  '--requirement[treat as requirement (deprecated)]' \
  '--rule[show rule details (deprecated)]' \
  '*:target:_files'
