#compdef spctl
# Documentation: https://ss64.com/mac/spctl.html
# Reference accessed: 2026-05-21
# Verified: macOS spctl(8) Gatekeeper reference. Rule-management flags
# (--add/--remove/--enable/--disable/--reset-default/--anchor/--hash/
# --label/--path/--priority/--requirement/--rule/--list) marked
# "deprecated" — Apple deprecated them in macOS 15+ but they remain
# documented in the manpage.

_arguments -s \
  '(- *)-h[show help]' \
  '(-a --assess)'{-a,--assess}'[assess a file or bundle]' \
  '--status[show Gatekeeper status]' \
  '--global-enable[enable Gatekeeper globally]' \
  '--global-disable[disable Gatekeeper globally]' \
  '--continue[continue past errors]' \
  '--ignore-cache[ignore the cache]' \
  '--no-cache[do not cache]' \
  '--raw[output raw plist]' \
  '(-t --type)'{-t,--type=}'[assessment type]:type:(execute install open)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--add[add rule to assessment database (deprecated)]' \
  '--remove[remove rule from database (deprecated)]' \
  '--enable[enable rule (deprecated)]' \
  '--disable[disable rule (deprecated)]' \
  '--list[list all rules (deprecated)]' \
  '--reset-default[reset to default rules (deprecated)]' \
  '--anchor=[anchor certificate hash (deprecated)]:anchor:' \
  '--hash=[code directory hash (deprecated)]:hash:' \
  '--label=[rule label (deprecated)]:label:' \
  '--path[file path target (deprecated)]' \
  '--priority=[rule priority (deprecated)]:priority:' \
  '--requirement[code requirement source (deprecated)]' \
  '--rule[rule index (deprecated)]' \
  '*:target:_files'
