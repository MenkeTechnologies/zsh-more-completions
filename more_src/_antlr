#compdef antlr antlr4
# Documentation: https://github.com/antlr/antlr4/blob/master/doc/tool-options.md
# Reference accessed: 2026-05-16
# Verified: upstream antlr/antlr4 tool-options docs.
# Removed from prior file: bogus man.archlinux.org search URL.

# antlr: ANTLR 4 parser generator
local curcontext="$curcontext" ret=1
_arguments -C \
  '-o[output directory]:dir:_files -/' \
  '-lib[library directory for token files/imports]:dir:_files -/' \
  '-atn[generate rule ATN diagrams]' \
  '-encoding[grammar file encoding]:encoding:' \
  '-message-format[diagnostic message format]:format:(antlr gnu vs2005)' \
  '-long-messages[show exception details]' \
  '(-no-listener)-listener[generate parse tree listener (default)]' \
  '(-listener)-no-listener[do not generate listener]' \
  '(-no-visitor)-visitor[generate parse tree visitor]' \
  '(-visitor)-no-visitor[do not generate visitor (default)]' \
  '-package[namespace for generated code]:package:' \
  '-depend[print file dependency list]' \
  '*-D[override grammar option key=value]:key=value:' \
  '-Werror[treat warnings as errors]' \
  '-Xlog[enable trace logging]' \
  '-XdbgST[debug StringTemplate]' \
  '-XdbgSTWait[debug StringTemplate, wait]' \
  '-Xforce-atn[force ATN simulator]' \
  '-Xexact-output-dir[strict output directory]' \
  '*:grammar file:_files -g "*.g4(-.)"' && ret=0
return ret
