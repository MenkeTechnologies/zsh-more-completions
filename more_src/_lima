#compdef limactl

_limactl_commands() {
  local -a commands=(
    'start:Start an instance'
    'stop:Stop an instance'
    'delete:Delete an instance'
    'shell:Execute shell in an instance'
    'copy:Copy files between host and instance'
    'list:List instances'
    'edit:Edit an instance'
    'disk:Manage disks'
    'factory-reset:Factory reset an instance'
    'info:Show diagnostic info'
    'show-ssh:Show SSH config'
    'snapshot:Manage snapshots'
    'start-at-login:Register/unregister auto start'
    'sudoers:Generate sudoers file'
    'completion:Generate shell completion'
    'validate:Validate YAML config'
    'protect:Protect/unprotect an instance'
    'help:Help about any command'
  )
  _describe 'command' commands
}

_limactl_instances() {
  local -a instances
  instances=(${(f)"$(limactl list --quiet 2>/dev/null)"})
  _describe 'instance' instances
}

_limactl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--debug[debug mode]' \
    '--log-level=[log level]:level:(trace debug info warn error fatal)' \
    '(-h --help)'{-h,--help}'[help for limactl]' \
    '1:command:_limactl_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        start)
          _arguments \
            '--name=[instance name]:name' \
            '--cpus=[number of CPUs]:cpus' \
            '--memory=[memory size]:memory' \
            '--disk=[disk size]:disk' \
            '--vm-type=[VM type]:type:(qemu vz wsl2)' \
            '--mount-type=[mount type]:type:(reverse-sshfs 9p virtiofs)' \
            '--network=[network config]:config' \
            '--dns=[DNS addresses]:dns' \
            '--containerd=[containerd mode]:mode:(none system user)' \
            '--plain[plain mode]' \
            '--tty[enable TUI interactions]' \
            '--timeout=[timeout duration]:duration' \
            '--set=[override YAML fields]:override' \
            '(-h --help)'{-h,--help}'[help for start]' \
            '1:config or instance:_files'
          ;;
        stop)
          _arguments \
            '(-f --force)'{-f,--force}'[force stop]' \
            '(-h --help)'{-h,--help}'[help for stop]' \
            '1:instance:_limactl_instances'
          ;;
        delete)
          _arguments \
            '(-f --force)'{-f,--force}'[force delete]' \
            '(-h --help)'{-h,--help}'[help for delete]' \
            '*:instance:_limactl_instances'
          ;;
        shell)
          _arguments \
            '--workdir=[working directory]:directory' \
            '(-h --help)'{-h,--help}'[help for shell]' \
            '1:instance:_limactl_instances' \
            '*:command'
          ;;
        copy)
          _arguments \
            '(-r --recursive)'{-r,--recursive}'[recursive copy]' \
            '(-h --help)'{-h,--help}'[help for copy]' \
            '*:source:_files'
          ;;
        list)
          _arguments \
            '(-q --quiet)'{-q,--quiet}'[only show instance names]' \
            '--json[JSON output]' \
            '--format=[Go template format]:format' \
            '(-h --help)'{-h,--help}'[help for list]'
          ;;
        edit)
          _arguments \
            '--set=[override YAML fields]:override' \
            '--tty[enable TUI interactions]' \
            '(-h --help)'{-h,--help}'[help for edit]' \
            '1:instance:_limactl_instances'
          ;;
        snapshot)
          _arguments \
            '1:action:(create delete list apply)' \
            '(-h --help)'{-h,--help}'[help for snapshot]' \
            '2:instance:_limactl_instances'
          ;;
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[help for validate]' \
            '*:file:_files'
          ;;
        show-ssh)
          _arguments \
            '--format=[format]:format:(cmd args options uri config)' \
            '(-h --help)'{-h,--help}'[help for show-ssh]' \
            '1:instance:_limactl_instances'
          ;;
        completion)
          _arguments \
            '1:shell:(bash zsh fish powershell)'
          ;;
        disk)
          _arguments \
            '1:action:(create delete list resize)' \
            '(-h --help)'{-h,--help}'[help for disk]'
          ;;
      esac
      ;;
  esac
}

_limactl "$@"
