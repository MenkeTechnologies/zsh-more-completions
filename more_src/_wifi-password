#compdef wifi-password
# Documentation: https://man.archlinux.org/search?q=wifi-password
# Reference accessed: 2026-05-16

# completions for wifi-password - show WiFi password for current or specified network

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[only output the password, no network name]' \
  '1:network SSID'
