#compdef overtls
# Documentation: https://github.com/ssrlive/overtls
# overtls - SOCKS5 proxy transmitting data over TLS, supporting TCP and UDP forwarding

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'=[configuration file path]:file:_files' \
  '--url-of-node=[node URL (SSR format alternative to config file)]:url' \
  '--listen-addr=[local listening address]:addr' \
  '--advertise-ip=[IP to advertise in generated URLs]:ip' \
  '(-v --verbosity)'{-v,--verbosity}'=[log level]:level:(off error warn info debug trace)' \
  '--cache-dns[enable DNS caching]' \
  '--max-lifetime=[maximum connection lifetime]:duration' \
  '--pool-max-size=[client connection pool maximum size]:size' \
  '--generate-url[generate and output SSR URL from config]' \
  '--daemonize[run as daemon]' \
  '--c-api[use C API mode (client only)]' && ret=0

return ret
