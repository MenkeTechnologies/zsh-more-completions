#compdef springrts spring
# Documentation: https://springrts.com/wiki/Commandline
# Reference accessed: 2026-05-16

# Spring (RTS): 3D real-time strategy engine
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-s[run as headless server]' \
  '--server[run as headless server]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-w[force windowed]' \
  '--window[force windowed]' \
  '-f[force fullscreen]' \
  '--fullscreen[force fullscreen]' \
  '-x[width]:n:' \
  '--xresolution=[width]:n:' \
  '-y[height]:n:' \
  '--yresolution=[height]:n:' \
  '-m[minimise]' \
  '--minimise[minimise]' \
  '-g[name]:name:' \
  '--game=[game name]:name:' \
  '-m[map name]:map:' \
  '--map=[map name]:map:' \
  '--isolation[run isolated]' \
  '--write-dir=[write dir]:dir:_files -/' \
  '--data-dir=[data dir]:dir:_files -/' \
  '--name=[player name]:name:' \
  '--quit-test[exit after start]' \
  '--script-text=[script text]:text:' \
  '*:start script (.springreplay/.txt):_files -g "*.(springreplay|txt|sdf|sdz|sd7|smd|sdt|tdf)"' && ret=0
return ret
