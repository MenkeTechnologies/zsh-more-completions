#compdef springrts spring spring-dedicated spring-headless
# Documentation: https://github.com/spring/spring/blob/master/rts/System/SpringApp.cpp
# Reference accessed: 2026-05-16
# Verified: rts/System/SpringApp.cpp DEFINE_bool/DEFINE_string gflags definitions
# Removed from prior file: -h/-V/-s/-c/-w/-f/-x/-y/-m/-g (no short-form gflags
# aliases in source), --xresolution/--yresolution (not in source),
# --minimise (real is --hidden), --quit-test (not in source),
# --script-text= (not in source - positional script file is used).

# Spring (RTS): 3D real-time strategy engine
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show gflags help]' \
  '(- *)--version[show version]' \
  '--sync-version[display program sync version]' \
  '--gen-fontconfig[generate font-configuration database]' \
  '--fullscreen[run in fullscreen mode]' \
  '--window[run in windowed mode]' \
  '--hidden[start in background (minimised, no taskbar)]' \
  '--nocolor[disable colorized stdout]' \
  '--server=[set listening IP for server]:ip:' \
  '--textureatlas[dump finalized textureatlas]' \
  '--list-ai-interfaces[dump available AI interfaces]' \
  '--list-skirmish-ais[dump available skirmish AIs]' \
  '--list-config-vars[dump config vars and metadata]' \
  '--list-def-tags[dump unit/weapon def tags and metadata]' \
  '--list-ceg-classes[dump available projectile classes]' \
  '--test-creg[test CREG classes for completeness]' \
  '--safemode[disable risky features (low-end GPU mode)]' \
  '--config=[exclusive configuration file]:file:_files' \
  '--isolation[limit data-dir scanner to one directory]' \
  '--isolation-dir=[isolation-mode data dir]:dir:_files -/' \
  '--write-dir=[where spring writes to]:dir:_files -/' \
  '--game=[game to instantly load]:game:' \
  '--map=[map to instantly load]:map:' \
  '--menu=[lua menu archive]:archive:' \
  '--name=[player name]:name:' \
  '--oldmenu[start the old menu]' \
  '*:start script:_files -g "*.(springreplay|txt|sdf|sdz|sd7|smd|sdt|tdf)"' && ret=0
return ret
