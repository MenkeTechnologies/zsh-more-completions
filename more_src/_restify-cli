#compdef restify-cli
# _restify-cli — Mark Cavage restify Node.js REST server CLI alias (restify team, JavaScript); custom argparse
# upstream: https://github.com/restify/node-restify

_restify-cli() {
    local -a sub=(
        'init:initialize a restify project'
        'start:start restify server'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--log-level=+[level]:l:(trace debug info warn error fatal)' \
        '-l+[level]:l:(trace debug info warn error fatal)' \
        '--cors[enable CORS]' \
        '--ipv4[ipv4]' \
        '--ipv6[ipv6]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'restify subcommand' sub ;;
    esac
}

_restify-cli "$@"
