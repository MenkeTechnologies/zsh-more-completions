#compdef msort
# Documentation: https://man.archlinux.org/search?q=msort
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d[sort by date]' \
  '-f[sort by from]' \
  '-s[sort by subject]' \
  '-S[sort by size]' \
  '-r[reverse sort order]' \
  '*:message:_files' && ret=0

return ret
