#compdef msort
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/msort.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d[sort by date]' \
  '-f[sort by from]' \
  '-s[sort by subject]' \
  '-S[sort by size]' \
  '-r[reverse sort order]' \
  '*:message:_files' && ret=0

return ret
