#compdef msort
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/msort.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# msort: sort records in complex ways (Bill Poser's multi-key sort).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print usage message]' \
  '(- *)'{-v,--version}'[print version message]' \
  '(-D --defaults)'{-D,--defaults}'[list defaults]' \
  '(-F --general-options)'{-F,--general-options}'[list general command-line options]' \
  '(-G --gnu-equivalences)'{-G,--gnu-equivalences}'[list GNU sort equivalents]' \
  '(-H --informational-options)'{-H,--informational-options}'[list informational options]' \
  '(-K --key-specific-options)'{-K,--key-specific-options}'[list key-specific options]' \
  '(-L --limits)'{-L,--limits}'[list limits]' \
  '(-N --number-systems)'{-N,--number-systems}'[list supported number systems]' \
  '(-b --block)'{-b,--block}'[record terminated by two or more newlines]' \
  '(-l --line)'{-l,--line}'[record is a single line]' \
  '(-r --record-separator)'{-r,--record-separator}'[record separator character]:separator:' \
  '(-O --fixed-size-record)'{-O,--fixed-size-record}'[fixed-size record (bytes)]:bytes:' \
  '(-d --field-separators)'{-d,--field-separators}'[field separator characters]:chars:' \
  '(-w --whole)'{-w,--whole}'[sort on entire record]' \
  '(-a --algorithm)'{-a,--algorithm}'[sort algorithm]:algorithm:(I M Q S)' \
  '(-m --line-end-carriage-return)'{-m,--line-end-carriage-return}'[use CR instead of LF]' \
  '(-I --invert-globally)'{-I,--invert-globally}'[invert sense of comparisons globally]' \
  '(-B --BMP)'{-B,--BMP}'[no characters outside BMP]' \
  '(-Z --skip-first-record)'{-Z,--skip-first-record}'[copy first record unchanged]' \
  '(-Q --check-only)'{-Q,--check-only}'[check if input is already sorted]' \
  '(-1 --in)'{-1,--in}'[input file]:file:_files' \
  '(-2 --out)'{-2,--out}'[output file]:file:_files' \
  '(-j --suppress-log)'{-j,--suppress-log}'[suppress log output]' \
  '(-q --quiet)'{-q,--quiet}'[do not chat while working]' \
  '(-u --unicode-normalization)'{-u,--unicode-normalization}'[Unicode normalization mode]:mode:(c d C D n)' \
  '(-C --fold-case)'{-C,--fold-case}'[fold case]' \
  '(-c --comparison-type)'{-c,--comparison-type}'[comparison type]:type:(a l i t D d m n N s h r)' \
  '*:input file:_files' && ret=0

return ret
