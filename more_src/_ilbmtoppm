#compdef ilbmtoppm
# Documentation: man ilbmtoppm (Netpbm)
# Source: convert Amiga IFF ILBM (with HAM/EHB/Deep variants) to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-ignore+[chunk ID to ignore]:chunk:' \
    '(-isham -isnotham)-isham[input is HAM]' \
    '(-isham -isnotham)-isnotham[input is not HAM]' \
    '(-isehb -isnotehb)-isehb[input is EHB]' \
    '(-isehb -isnotehb)-isnotehb[input is not EHB]' \
    '(-isdeep -isnotdeep)-isdeep[input is Deep ILBM]' \
    '(-isdeep -isnotdeep)-isnotdeep[input is not Deep]' \
    '-cmaponly[output only the colormap]' \
    '-adjustcolors[adjust color levels]' \
    '-transparent+[transparent color]:color:' \
    '-maskfile+[write mask to this PBM]:file:_files' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ilbm file:_files -g "*.(ilbm|iff|lbm)"' \
    && ret=0

return ret
