#compdef yawast
# _yawast — Adam Caudill yawast Yet Another Web Application Security Tool CLI for TLS testing common-name discovery directory brute-force HTTP header analysis WordPress detection certificate scanning (adamcaudill team, Python); argparse
# upstream: https://github.com/adamcaudill/yawast

_yawast() {
    local -a sub=(
        'scan:run a full scan'
        'sslscan:scan TLS configuration'
        'sslscanall:scan all TLS endpoints'
        'sslinfo:show TLS info'
        'sslsessioncount:count TLS sessions'
        'check:perform single check'
        'dns:DNS lookup'
        'header:HTTP header check'
        'cookie:cookie inspection'
        'cors:CORS test'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--output=+[file]:file:_files -g "*.json *.html *.txt"' \
        '-o+[file]:file:_files -g "*.json *.html *.txt"' \
        '--proxy=+[url]:str:' \
        '--cookie=+[name=value]:str:' \
        '--header=+[name=value]:str:' \
        '--insecure[insecure TLS]' \
        '--no-color[no color]' \
        '--user-agent=+[ua]:str:' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yawast subcommand' sub ;;
        args)
            case $words[1] in
                scan) _arguments \
                    '--nodir[no directory brute force]' \
                    '--nofile[no file brute force]' \
                    '--nossl[no SSL/TLS]' \
                    '--vuln[run vuln scan]' \
                    '--dir[dir brute force]' \
                    '--dirrecursive[recursive dir brute force]' \
                    '--php[detect PHP]' \
                    '--internalssl[scan internal SSL services]' \
                    '*:URL:' ;;
                sslscan|sslscanall|sslinfo|sslsessioncount) _arguments '*:URL or host:' ;;
            esac
            ;;
    esac
}

_yawast "$@"
