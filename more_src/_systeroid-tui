_systeroid-tui() {
    _arguments -s \
        '(-h --help)'{-h,--help}'[display help and exit]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-t --tick-rate)'{-t+,--tick-rate=}'[set terminal tick rate (default 250)]:ms:' \
        '(-D --docs)'{-D+,--docs=}'[set path of kernel documentation]:docs path:_files -/' \
        '--save-path=[set path for saving changed parameters]:save path:_files' \
        '(-l --log-file)'{-l+,--log-file=}'[set file for saving logs]:log file:_files' \
        '(-s --section)'{-s+,--section=}'[filter by sysctl section]:section:(abi fs kernel net sunrpc user vm unknown)' \
        '(-q --query)'{-q+,--query=}'[startup search query]:query:' \
        '--bg-color=[set background colour (default reset)]:color:(reset black red green yellow blue magenta cyan white gray darkgray lightred lightgreen lightyellow lightblue lightmagenta lightcyan)' \
        '--fg-color=[set foreground colour (default white)]:color:(reset black red green yellow blue magenta cyan white gray darkgray lightred lightgreen lightyellow lightblue lightmagenta lightcyan)' \
        '(-n --no-docs)'{-n,--no-docs}'[do not parse/show kernel documentation]' \
        '--deprecated[include deprecated variables when listing]' \
        '(-c --config)'{-c+,--config=}'[set path of configuration file]:config file:_files'
}

_systeroid-tui "$@"
