#compdef scilab-cli
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/scilab.1.html
# Scilab command line interpreter (no advanced features)

local ret=1

_arguments -s -S \
  '-e[execute the given scilab instruction]:instruction' \
  '-f[execute the given scilab script]:file:_files' \
  '-quit[force exit after execution of -e or -f script]' \
  '-l[change the language (default en_US)]:lang' \
  '-nb[do not display Scilab loading on start]' \
  '-ns[do not execute etc/scilab.start]' \
  '-nouserstartup[do not execute the user startup files]' \
  '-noatomsautoload[do not load ATOMS installed module]' \
  '-nocolor[remove color in cli and adv-cli modes]' \
  '-display[use the given X server display]:display' \
  '-args[accept extra arguments via sciargs]:args' \
  '--timeout[kill the Scilab process after the given delay]:delay' && ret=0

return ret
