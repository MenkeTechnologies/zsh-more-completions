#compdef valkey-cli valkey-server

local curcontext="$curcontext" state line ret=1

case "$service" in
  valkey-cli)
    _arguments -s -S \
      '(- *)--help[Show help]' \
      '(- *)--version[Show version]' \
      '-h[Server hostname]:host' \
      '-p[Server port]:port' \
      '-s[Server socket]:socket:_files' \
      '-a[Password]:password' \
      '--user[Username for ACL auth]:username' \
      '-n[Database number]:database' \
      '-u[Server URI]:uri' \
      '--tls[Enable TLS]' \
      '--cert[Client certificate file]:file:_files' \
      '--key[Private key file]:file:_files' \
      '--cacert[CA certificate file]:file:_files' \
      '--cacertdir[CA certificate directory]:directory:_files -/' \
      '--insecure[Allow insecure TLS connection]' \
      '--pipe[Transfer raw protocol from stdin to server]' \
      '--pipe-timeout[Timeout for pipe mode]:seconds' \
      '--bigkeys[Sample keys looking for big keys]' \
      '--memkeys[Sample keys looking for keys consuming a lot of memory]' \
      '--hotkeys[Sample keys looking for hot keys]' \
      '--scan[List all keys using SCAN]' \
      '--pattern[Pattern for scan]:pattern' \
      '--count[Count for scan]:count' \
      '--quoted-pattern[Pattern with quoted input]:pattern' \
      '--intrinsic-latency[Run test to measure intrinsic system latency]:seconds' \
      '--latency[Enter latency mode]' \
      '--latency-history[Enter latency history mode]' \
      '--latency-dist[Show latency as spectrum]' \
      '--lru-test[Simulate cache workload with given number of keys]:keys' \
      '--slave[Simulate a slave showing commands received]' \
      '--replica[Simulate a replica showing commands received]' \
      '--rdb[Transfer RDB dump from remote to local file]:file:_files' \
      '--functions-rdb[Transfer functions from remote to local RDB file]:file:_files' \
      '--cluster[Enable cluster mode]' \
      '-c[Enable cluster mode]' \
      '--raw[Use raw output format for replies]' \
      '--no-raw[Force formatted output]' \
      '--csv[Output in CSV format]' \
      '--json[Output in JSON format]' \
      '--resp2[Use RESP2 protocol]' \
      '--resp3[Use RESP3 protocol]' \
      '--show-pushes[Show push messages]:when:(yes no)' \
      '--stat[Print rolling stats about server]' \
      '--verbose[Verbose mode]' \
      '*:command' \
      && ret=0
    ;;
  valkey-server)
    _arguments -s -S \
      '(- *)--help[Show help]' \
      '(- *)--version[Show version]' \
      '--port[Set port]:port' \
      '--bind[Bind address]:address' \
      '--requirepass[Set password]:password' \
      '--maxmemory[Set max memory]:bytes' \
      '--dbfilename[Set RDB filename]:filename' \
      '--dir[Set working directory]:directory:_files -/' \
      '--loglevel[Set log level]:level:(debug verbose notice warning)' \
      '--logfile[Set log file]:file:_files' \
      '--databases[Set number of databases]:number' \
      '--daemonize[Run as daemon]:yn:(yes no)' \
      '--timeout[Close idle connection timeout]:seconds' \
      '--tcp-keepalive[TCP keepalive]:seconds' \
      '--tcp-backlog[TCP backlog]:number' \
      '--hz[Server frequency]:hz' \
      '--save[Save schedule]:schedule' \
      '--appendonly[Enable append-only mode]:yn:(yes no)' \
      '--slaveof[Set master server]:host port' \
      '--replicaof[Set master server]:host port' \
      '--tls-port[TLS port]:port' \
      '--tls-cert-file[TLS certificate file]:file:_files' \
      '--tls-key-file[TLS key file]:file:_files' \
      '--tls-ca-cert-file[TLS CA certificate file]:file:_files' \
      '*:config file:_files' \
      && ret=0
    ;;
esac

return ret
