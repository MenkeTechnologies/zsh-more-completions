#compdef flytectl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'config:manage Flyte configuration'
  'create:create Flyte resources'
  'delete:delete Flyte resources'
  'get:get Flyte resources'
  'register:register Flyte resources'
  'sandbox:manage Flyte sandbox'
  'update:update Flyte resources'
  'version:display version'
  'compile:compile a workflow'
  'demo:manage Flyte demo environment'
  'completion:generate shell completion scripts'
  'help:show help'
)

_arguments -s -S \
  '--admin.endpoint=[admin endpoint]:endpoint' \
  '--admin.insecure[use insecure connection]' \
  '--admin.insecureSkipVerify[skip TLS verification]' \
  '--admin.caCertFilePath=[CA cert file]:cert file:_files' \
  '--admin.maxRetries=[max retries]:count' \
  '--admin.perRetryTimeout=[per retry timeout]:duration' \
  '--admin.clientId=[OAuth client ID]:client ID' \
  '--admin.clientSecretLocation=[OAuth client secret file]:secret file:_files' \
  '--logger.level=[log level]:level:(0 1 2 3 4 5)' \
  '--logger.show-source[show source in logs]' \
  '-o[output format]:format:(json yaml table)' \
  '(-p --project)'{-p,--project}'[project name]:project' \
  '(-d --domain)'{-d,--domain}'[domain name]:domain' \
  '(-h --help)'{-h,--help}'[display help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      get)
        local -a get_cmds=(
          'execution:get execution details'
          'launchplan:get launch plan details'
          'project:get project details'
          'task:get task details'
          'workflow:get workflow details'
        )
        _arguments '1:resource:->res' '*::args:' && ret=0
        [[ $state == res ]] && _describe -t commands 'resource' get_cmds && ret=0
        ;;
      create)
        local -a create_cmds=(
          'execution:create an execution'
          'project:create a project'
        )
        _arguments '1:resource:->res' '*::args:' && ret=0
        [[ $state == res ]] && _describe -t commands 'resource' create_cmds && ret=0
        ;;
      delete)
        local -a delete_cmds=(
          'execution:terminate an execution'
          'cluster-resource-attribute:delete cluster resource attributes'
          'execution-cluster-label:delete execution cluster label'
          'execution-queue-attribute:delete execution queue attributes'
          'plugin-override:delete plugin overrides'
          'task-resource-attribute:delete task resource attributes'
          'workflow-execution-config:delete workflow execution config'
        )
        _arguments '1:resource:->res' '*::args:' && ret=0
        [[ $state == res ]] && _describe -t commands 'resource' delete_cmds && ret=0
        ;;
      register)
        local -a register_cmds=(
          'files:register Flyte resource files'
          'examples:register Flyte examples'
        )
        _arguments '1:resource:->res' '*::args:' && ret=0
        [[ $state == res ]] && _describe -t commands 'resource' register_cmds && ret=0
        ;;
      sandbox)
        local -a sandbox_cmds=(
          'start:start a Flyte sandbox'
          'teardown:teardown the Flyte sandbox'
          'status:get sandbox status'
          'exec:execute command in sandbox'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'subcommand' sandbox_cmds && ret=0
        ;;
      demo)
        local -a demo_cmds=(
          'start:start a Flyte demo environment'
          'teardown:teardown the Flyte demo'
          'status:get demo status'
          'exec:execute command in demo'
          'reload:reload the demo environment'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'subcommand' demo_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
