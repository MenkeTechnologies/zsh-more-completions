#compdef badvpn-udpgw
# Documentation: https://github.com/ambrop72/badvpn/blob/master/udpgw/udpgw.c
# badvpn UDP forwarding gateway server for tun2socks

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--logger[logging destination]:dest:(stdout syslog)' \
  '--syslog-facility[set syslog facility]:facility:' \
  '--syslog-ident[set syslog identity]:ident:' \
  '--loglevel[logging verbosity level]:level:(0 1 2 3 4 5 none error warning notice info debug)' \
  '--channel-loglevel[per-channel loglevel]:channel:' \
  '--listen-addr[address to listen on]:addr:' \
  '--udp-mtu[UDP MTU in bytes]:bytes:' \
  '--max-clients[max number of clients]:number:' \
  '--max-connections-for-client[max connections per client]:number:' \
  '--client-socket-sndbuf[client socket send buffer bytes]:bytes:' \
  '--local-udp-addrs[local UDP address and port count]:addr:' \
  '--local-udp-ip6-addrs[local UDP IPv6 address and port count]:addr:' \
  '--unique-local-ports[use unique local ports]' && ret=0

return ret
