#compdef optic

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'api:manage API specifications'
      'capture:capture API traffic'
      'ci:run CI checks'
      'diff:diff two API specifications'
      'oas:OpenAPI operations'
      'lint:lint an API specification'
      'ruleset:manage rulesets'
      'run:run optic with a config'
      'login:authenticate with Optic'
      'update:update specifications'
      'completions:generate shell completions'
    )
    _describe -t commands 'optic command' commands && ret=0
    ;;
  args)
    case $line[1] in
      diff)
        _arguments \
          '--base[base specification]:file:_files' \
          '--check[run breaking change checks]' \
          '--web[open diff in web view]' \
          '--severity=[minimum severity]:severity:(info warn error)' \
          '*:spec:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      lint)
        _arguments \
          '--ruleset[ruleset to use]:ruleset' \
          '*:spec:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      capture)
        _arguments \
          '--proxy[proxy address]:address' \
          '--command[command to run]:command' \
          '*:spec:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
    esac
    ;;
esac

return ret
