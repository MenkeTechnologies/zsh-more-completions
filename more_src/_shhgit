#compdef shhgit
# _shhgit — Eternal Security shhgit CLI real-time secret scanner watching the public GitHub event stream Bitbucket repository GitLab project feed for newly-pushed commits scanning content with regex pattern signatures producing detected token API key credential alerts Slack webhook integration (Eternal Security team, Go); pflag
# upstream: https://github.com/eth0izzle/shhgit

_shhgit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--silent[silent]' \
        '--config-path=+[file]:file:_files -g "*.yaml *.yml"' \
        '--signatures-path=+[file]:file:_files -g "*.yaml *.yml"' \
        '--config-key=+[key]:str:' \
        '--clone-repository-timeout=+[sec]:n:' \
        '--entropy-threshold=+[N]:str:' \
        '--minimum-stars=+[N]:n:' \
        '--maximum-repository-size=+[KB]:n:' \
        '--maximum-file-size=+[KB]:n:' \
        '--csv-path=+[file]:file:_files -g "*.csv"' \
        '--local=+[path]:file:_files' \
        '--silent-mode[silent mode]' \
        '--no-fork[skip forks]' \
        '--temp-directory=+[dir]:dir:_files -/' \
        '--processing-queue-size=+[N]:n:' \
        '--download-queue-size=+[N]:n:' \
        '--processing-threads=+[N]:n:' \
        '--download-threads=+[N]:n:' \
        '--threads=+[N]:n:' \
        '--include-test-files[include test files]' \
        '--include-tests[include test files]' \
        '--no-color[disable color output]' \
        '--gist-quick-scan[quick scan gists]' \
        '*::'
}

_shhgit "$@"
