#compdef drainer
# _drainer — TiDB binlog drainer (sync binlog to downstream) (pingcap/tidb-binlog)
# upstream: https://github.com/pingcap/tidb-binlog
# Flags from drainer/config.go.

_drainer() {
    local -a args
    args=(
        '(- *)-V[print version and exit]'
        '-config[path to TOML configuration file]:file:_files -g "*.toml"'
        '-node-id[drainer node ID (auto-generated if empty)]:id:'
        '-addr[host:port to listen on for drainer connections]:addr:'
        '-advertise-addr[advertised host:port]:addr:'
        '-data-dir[drainer data directory path]:dir:_files -/'
        '-detect-interval[interval (s) of detecting pump status]:seconds:'
        '-pd-urls[comma-separated list of PD endpoints]:urls:'
        '-L[log level]:level:(debug info warn error fatal)'
        '-log-file[log file path]:file:_files'
        '-metrics-addr[prometheus pushgateway address]:addr:'
        '-metrics-interval[prometheus push interval (s, 0 disables)]:seconds:'
        '-compressor[wire compression (gzip or empty)]:type:(gzip)'
        '-txn-batch[binlog events per transaction batch]:n:'
        '-loopback-control[mark transactions for loopback control]'
        '-sync-ddl[sync DDL events]:bool:(true false)'
        '-ignore-schemas[schemas to ignore (comma-separated)]:schemas:'
        '-c[parallel worker count]:n:'
        '-dest-db-type[downstream type]:type:(mysql tidb file kafka)'
        '-relay-log-dir[path to relay log of syncer]:dir:_files -/'
        '-enable-dispatch[dispatch multiple statements in one binlog]:bool:(true false)'
        '-safe-mode[enable safe mode (reentrant syncer)]'
        '-enable-detect[enable causality detection]:bool:(true false)'
        '-load-schema-snapshot[init schema via PD meta interface]'
        '-cache-binlog-count[blurry count of binlogs cached]:n:'
        '-synced-check-time[minutes of idle to declare fully synced]:minutes:'
    )
    _arguments -s $args
}

_drainer "$@"
