#compdef pslToBigPsl
# UCSC kent: convert psl to bigPsl input (bed format with extra fields)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-cds=[tab file of qName and GenBank style CDS]:file:_files' \
  '-fa=[fasta sequence file]:file:_files' \
  ':psl:_files' \
  ':out:_files' && ret=0

return ret
