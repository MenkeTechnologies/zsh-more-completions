#compdef g2c_ng
# Documentation: https://docs.siesta-project.org/projects/siesta/en/5.4/analysis_visualization/utils/grid2cube.html
# SIESTA convert grid files (.RHO, .LDOS, ...) to Gaussian .cube format

local ret=1

_arguments -s -S \
  '-h[print help/usage information]' \
  '-d[debug mode]' \
  '-t[translate coordinates to [0,1)]' \
  '-n[stride in file (NSKIP)]:nskip:' \
  '-x[supercell factor along first lattice vector]:nx:' \
  '-y[supercell factor along second lattice vector]:ny:' \
  '-z[supercell factor along third lattice vector]:nz:' \
  '-s[structure file e.g. SystemLabel.STRUCT_OUT]:struct file:_files' \
  '-g[grid data file e.g. SystemLabel.RHO]:grid file:_files' && ret=0

return ret
