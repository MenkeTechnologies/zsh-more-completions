#compdef systemd-coredump
# Documentation: https://www.freedesktop.org/software/systemd/man/latest/systemd-coredump.html
# Reference accessed: 2026-05-16
# Verified: upstream systemd-coredump(8) manpage. Only --backtrace documented;
# tool is invoked by kernel core_pattern, not directly by users.

# systemd-coredump: collect, store, and process core dumps
local curcontext="$curcontext" ret=1
_arguments -C \
  '--backtrace[expect journal entry on stdin]' && ret=0
return ret
