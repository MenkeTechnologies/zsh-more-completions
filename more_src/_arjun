#compdef arjun

# Zsh completion for Arjun - HTTP parameter discovery

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-u+[target URL]:url' \
  '-m+[HTTP method]:method:(GET POST JSON XML)' \
  '-d+[delay between requests in seconds]:seconds' \
  '-t+[number of threads]:threads' \
  '*--headers=[custom header]:header' \
  '--stable[use stable mode for slow targets]' \
  '-oJ+[output to JSON file]:file:_files' \
  '-oT+[output to text file]:file:_files' \
  '-q[quiet mode]' \
  '--passive[use passive sources for parameter discovery]' \
  '-w+[custom wordlist]:file:_files' \
  '--include=[include a parameter in every request]:parameter' \
  '--disable-redirects[disable following redirects]' \
  '-c+[chunk size per request]:chunks' \
  && ret=0

return ret
