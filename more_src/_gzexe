#compdef gzexe
# Documentation: gzexe usage (GNU gzip)
# Source: create self-extracting compressed executables (or decompress with -d).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[decompress / restore original]' \
    '*:file:_files' \
    && ret=0

return ret
