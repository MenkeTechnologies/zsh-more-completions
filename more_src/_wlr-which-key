#compdef wlr-which-key
# Documentation: https://github.com/MaxVerevkin/wlr-which-key
# wlr-which-key: a which-key style keymap manager for wlroots compositors

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--initial-keys[navigate to a submenu or execute a command]:keys:_default' \
  '1::config name:_default' && ret=0

return ret
