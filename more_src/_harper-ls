#compdef harper-ls
# Documentation: https://github.com/Automattic/harper (harper-ls/src/main.rs)
# Reference accessed: 2026-05-29
# Harper grammar language server.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --stdio)'{-s,--stdio}'[listen on stdin/stdout rather than TCP (default 127.0.0.1\:4000)]' && ret=0

return ret
