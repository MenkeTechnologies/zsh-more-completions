#compdef spiffe-helper
# _spiffe-helper — SPIFFE workload sidecar (spiffe/spiffe-helper)
# upstream: https://github.com/spiffe/spiffe-helper
# Flags from cmd/spiffe-helper/main.go (flag).

_spiffe-helper() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-version[print version]' \
        '-config=[helper config file]:file:_files -g "*.(conf|hcl)"' \
        '-daemon-mode=[run as daemon (rotate certs) or fetch-and-exit]:bool:(true false)'
}

_spiffe-helper "$@"
