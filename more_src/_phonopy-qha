#compdef phonopy-qha
# Documentation: https://phonopy.github.io/phonopy/qha.html
# Quasi-harmonic approximation analysis from e-v.dat and thermal_properties.yaml

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-b[just show bulk modulus from v-e data]' \
  '--eos=[equation of state]:eos:(vinet birch_murnaghan murnaghan)' \
  '--exclude-imaginary[exclude volumes that show imaginary modes]' \
  '(-p --plot)'{-p,--plot}'[plot data]' \
  '--pressure=[pressure in GPa]:pressure' \
  '(--efe --electronic-free-energy)'{--efe,--electronic-free-energy}'=[read electronic free energies at temperatures and volumes]:file:_files' \
  '(-s --save)'{-s,--save}'[save plot data in pdf]' \
  '--sparse=[thin out F-V plots, value is divisor of temperature points]:n' \
  '--tmax=[maximum calculated temperature]:tmax' \
  '*:file:_files' && ret=0

return ret
