#compdef tex-fmt

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --check)'{-c,--check}'[check formatting only]' \
  '(-p --print)'{-p,--print}'[print to stdout]' \
  '(-f --fail-on-change)'{-f,--fail-on-change}'[fail if files modified]' \
  '(-r --recursive)'{-r,--recursive}'[recursive search]' \
  '(-n --nowrap)'{-n,--nowrap}'[do not wrap long lines]' \
  '(-l --wraplen)'{-l,--wraplen=}'[line wrap length]:n:' \
  '(-t --tabsize)'{-t,--tabsize=}'[tab size]:n:' \
  '--usetabs[use tabs for indentation]' \
  '--format-tables[format tables]' \
  '(-s --stdin)'{-s,--stdin}'[process stdin]' \
  '--config=[config file]:file:_files' \
  '--noconfig[ignore config files]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--trace[show trace messages]' \
  '--completion=[generate shell completion]:shell:(bash zsh fish elvish powershell)' \
  '--man[generate man page]' \
  '--args[show parsed arguments]' \
  '*:tex file:_files -g "*.(tex|sty|cls|bib)"'
