#compdef clipsafe
# Documentation: https://man.archlinux.org/search?q=clipsafe
# Reference accessed: 2026-05-16

# waxandwane.org/clipsafe (Password Safe v3 CLI); Homebrew: Formula/c/clipsafe.rb

local ret=1
_arguments -s \
  '(-h)'{-h,-help}'[show usage]' \
  '(-f)'{-f+}'[Password Safe database]:database file:_files' \
  '1::regex or path:_default' && ret=0
return ret
