#compdef clipsafe
# Documentation: https://waxandwane.org/clipsafe.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cliPSafe Password Safe v3 read-only CLI.

local ret=1
_arguments -s \
  '(-h)'{-h,-help}'[show usage]' \
  '-f+[Password Safe database]:database file:_files' \
  '-l[treat database as a flat list of entries]' \
  '1::entry name or regex:_default' && ret=0
return ret
