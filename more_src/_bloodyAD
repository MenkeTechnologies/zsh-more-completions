#compdef bloodyAD
# Documentation: https://man.archlinux.org/search?q=bloodyAD
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add:add object/ACE/record'
  'get:enumerate/read AD info'
  'remove:remove object/ACE/record'
  'set:modify object attribute'
)

_arguments -C \
  '(-d --domain)'{-d,--domain}'=[domain]:domain:' \
  '(-u --username)'{-u,--username}'=[username]:user:' \
  '(-p --password)'{-p,--password}'=[password or LM:NT]:pw:' \
  '*'{-k,--kerberos}'=[kerberos opt]:opt:' \
  '(-f --format)'{-f,--format}'=[format]:fmt:(b64 hex aes rc4 default)' \
  '(-c --certificate)'{-c,--certificate}'=[key:cert]:cert:' \
  '*'{-s,--secure}'[secure mode]' \
  '(-H --host)'{-H,--host}'=[host]:host:_hosts' \
  '(-i --dc-ip)'{-i,--dc-ip}'=[DC IP]:ip:' \
  '--dns=[DNS IP]:ip:' \
  '(-t --timeout)'{-t,--timeout}'=[timeout]:seconds:' \
  '--gc[Global Catalog]' \
  '(-v --verbose)'{-v,--verbose}'=[verbosity]:level:(QUIET INFO DEBUG TRACE)' \
  '--json[JSON output]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'bloodyAD action' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        local -a actions
        actions=(
          'badSuccessor:add badSuccessor'
          'computer:add computer'
          'dcsync:grant DCSync rights'
          'dnsRecord:add DNS record'
          'genericAll:grant GenericAll'
          'groupMember:add group member'
          'gmsaGroup:add gMSA member'
          'rbcd:configure RBCD'
          'shadowCredentials:add shadow credentials'
          'uac:set UAC flag'
          'user:add user'
        )
        _arguments '1:action:->action' '*:arg:' && ret=0
        [[ $state == action ]] && _describe -t actions 'add action' actions && ret=0 ;;
      (get)
        local -a actions
        actions=(
          'bloodhound:bloodhound dump'
          'children:list children'
          'dnsDump:dump DNS'
          'membership:show membership'
          'trusts:show trusts'
          'object:read object'
          'search:LDAP search'
          'writable:list writable'
        )
        _arguments '1:action:->action' '*:arg:' && ret=0
        [[ $state == action ]] && _describe -t actions 'get action' actions && ret=0 ;;
      (set)
        local -a actions
        actions=(
          'object:set attribute'
          'owner:set owner'
          'password:reset password'
          'restore:restore object'
        )
        _arguments '1:action:->action' '*:arg:' && ret=0
        [[ $state == action ]] && _describe -t actions 'set action' actions && ret=0 ;;
      (remove)
        local -a actions
        actions=(
          'dcsync:revoke DCSync'
          'dnsRecord:remove DNS record'
          'genericAll:revoke GenericAll'
          'groupMember:remove group member'
          'object:remove object'
          'rbcd:remove RBCD'
          'shadowCredentials:remove shadow creds'
          'uac:clear UAC flag'
        )
        _arguments '1:action:->action' '*:arg:' && ret=0
        [[ $state == action ]] && _describe -t actions 'remove action' actions && ret=0 ;;
    esac
    ;;
esac

return ret
