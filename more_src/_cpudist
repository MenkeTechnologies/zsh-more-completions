#compdef cpudist cpudist-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/cpudist.py argparse)
# Reference accessed: 2026-05-29
# cpudist — task on-CPU time (or off-CPU time with -O) as a histogram (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-O --offcpu)'{-O,--offcpu}'[measure off-CPU time]' \
  '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]' \
  '(-m --milliseconds)'{-m,--milliseconds}'[millisecond histogram]' \
  '(-P --pids)'{-P,--pids}'[print a histogram per process ID]' \
  '(-L --tids)'{-L,--tids}'[print a histogram per thread ID]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-I --include-idle)'{-I,--include-idle}'[include CPU idle time]' \
  '(-e --extension)'{-e,--extension}'[show extension summary (average/total/count)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:interval (seconds, default unlimited):' \
  '2:count (number of outputs, default unlimited):' \
  && ret=0

return ret
