#compdef simplescreenrecorder
# Documentation: https://man.archlinux.org/search?q=simplescreenrecorder
# Reference accessed: 2026-05-16

# SimpleScreenRecorder: feature-rich Qt screen recorder
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--logfile[log to file]' \
  '--no-systray[hide tray icon]' \
  '--statusicon[show status icon]' \
  '--start-hidden[start hidden]' \
  '--settingsfile=[settings file]:file:_files' \
  '--start-recording[start recording immediately]' \
  '*::simplescreenrecorder args:_files' && ret=0
return ret
