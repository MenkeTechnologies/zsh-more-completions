#compdef xfs_admin
# _xfs_admin (xfsprogs xfs_admin — change parameters of an unmounted XFS filesystem; -L set label, -U set UUID, -f write feature flags, -V show version, -e enable v5 features, -c project quota override, -j journal/logdev tweaks; positional argument is the unmounted block device)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Flags from xfsprogs db/xfs_admin.sh on tip.

_xfs_admin() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-L+[new label]:label:' \
        '-U+[new UUID (or generate|nil|restore)]:uuid:' \
        '-c+[v5 project inherit (0|1)]:val:' \
        '-e[enable v5 features]' \
        '-f[unsafe: force]' \
        '-j[update journal device]' \
        '-l+[external log device]:device:_files -g "/dev/*"' \
        '-r+[realtime device]:device:_files -g "/dev/*"' \
        '-O+[set on-disk option]:option:' \
        '-u[print uuid]' \
        '1:device:_files -g "/dev/*"'
}

_xfs_admin "$@"
