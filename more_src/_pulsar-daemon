#compdef pulsar-daemon
# Documentation: https://pulsar.apache.org/docs/2.10.x/reference-cli-tools/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pulsar-daemon: helper script to manage Pulsar processes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(start stop restart)' \
  '2:command:(broker bookie autorecovery zookeeper configuration-store proxy websocket standalone zookeeper-shell compact-topic initialize-cluster-metadata)' \
  '*::pulsar-daemon args:_files' && ret=0
return ret
