#compdef pulsar-daemon
# Documentation: https://man.archlinux.org/search?q=pulsar-daemon
# Reference accessed: 2026-05-16

# pulsar-daemon: helper script to manage Pulsar processes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(start stop restart status reload force-stop)' \
  '2:command:(broker bookie autorecovery zookeeper configuration-store proxy functions-worker websocket standalone)' \
  '*::pulsar-daemon args:_files' && ret=0
return ret
