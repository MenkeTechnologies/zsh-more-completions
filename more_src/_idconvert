#compdef idconvert
# Documentation: https://proteowizard.sourceforge.io/tools/idconvert.html
# ProteoWizard: convert proteomics identification files (pepXML/mzIdentML/text)

local ret=1

_arguments -s -S \
  '(-f --filelist)'{-f,--filelist}'[text file containing filenames]:file:_files' \
  '(-o --outdir)'{-o,--outdir}'[output directory (- for stdout)]:dir:_files -/' \
  '(-c --config)'{-c,--config}'[configuration file (optionName=value)]:file:_files' \
  '(-e --ext)'{-e,--ext}'[extension for output files]:ext:(mzid pepXML txt)' \
  '--mzIdentML[write mzIdentML format (default)]' \
  '--pepXML[write pepXML format]' \
  '--text[write hierarchical text format]' \
  '(-v --verbose)'{-v,--verbose}'[display detailed progress information]' \
  '*:identification file:_files' && ret=0

return ret
