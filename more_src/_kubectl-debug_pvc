#compdef kubectl-debug_pvc
# Documentation: https://github.com/jianzhangbjz/kubectl-debug_pvc
# Reference accessed: 2026-05-17
# Verified: jianzhangbjz/kubectl-debug_pvc plugin flag surface; the
# plugin takes a PVC name as positional and supports --namespace,
# --context, --kubeconfig, --image, --node-selector, --command.
# Removed from prior file: bogus man.archlinux.org search URL.

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '--image=[debug container image]:image:' \
  '--node-selector=[node selector]:selector:' \
  '--command=[command to run in debug pod]:cmd:' \
  '1:PVC name:' \
  '*:extra args:_default' && ret=0
return ret
