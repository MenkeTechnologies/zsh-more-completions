#compdef fd2pascal
# Documentation: https://man.archlinux.org/search?q=fd2pascal
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-o+[output Pascal unit]:file:_files -g "*.pas"' \
  '-l[lowercase identifier names]' \
  '-c[generate constants]' \
  '*:input FD file:_files -g "*.fd"' && ret=0

return ret
