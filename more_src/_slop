#compdef slop

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-x --xdisplay)'{-x+,--xdisplay=}'[X display]:display:' \
  '(-b --bordersize)'{-b+,--bordersize=}'[border thickness]:px:' \
  '(-p --padding)'{-p+,--padding=}'[selection padding]:px:' \
  '(-t --tolerance)'{-t+,--tolerance=}'[click vs drag pixel threshold]:px:' \
  '(-c --color)'{-c+,--color=}'[selection color RGB or RGBA]:color:' \
  '(-r --shader)'{-r+,--shader=}'[vertex/fragment shader pair]:shader:' \
  '(-f --format)'{-f+,--format=}'[output format string]:fmt:' \
  '(-n --nodecorations)'{-n+,--nodecorations=}'[strip window decorations]:level:(0 1 2)' \
  '(-l --highlight)'{-l,--highlight}'[fill selection instead of outlining]' \
  '(-D --nodrag)'{-D,--nodrag}'[two-click selection mode]' \
  '(-q --quiet)'{-q,--quiet}'[suppress warnings on stderr]' \
  '(-k --nokeyboard)'{-k,--nokeyboard}'[disable keyboard cancel]' \
  '(-o --noopengl)'{-o,--noopengl}'[disable OpenGL acceleration]' && ret=0

return ret
