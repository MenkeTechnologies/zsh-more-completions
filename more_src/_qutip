#compdef qutip qutip-cli qutip-cmd
# _qutip — Robert Johansson Paul Nation QuTiP Quantum Toolbox in Python open quantum dynamics master equation Monte Carlo (qutip team, Python); argparse
# upstream: https://github.com/qutip/qutip

_qutip() {
    local -a sub=(
        'simulate:run quantum dynamics simulation'
        'solve:solve quantum equations'
        'mesolve:master equation solver'
        'mcsolve:Monte Carlo solver'
        'sesolve:Schrödinger equation solver'
        'steady:steadystate solver'
        'eigenstates:compute eigenstates'
        'fidelity:compute fidelity'
        'tomography:run quantum tomography'
        'optimal-control:run optimal control'
        'visualize:visualize quantum states'
        'plot:plot results'
        'demo:run a demo example'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--num-cpus=+[N]:n:' \
        '--solver=+[solver]:s:(mesolve mcsolve sesolve smesolve smcsolve smesolve_steady steadystate brmesolve fmmesolve floquet propagator)' \
        '--method=+[method]:m:(adams bdf dop853 dopri5 lsoda rk45 rk23 cvode)' \
        '--atol=+[F]:f:' \
        '--rtol=+[F]:f:' \
        '--max-step=+[F]:f:' \
        '--first-step=+[F]:f:' \
        '--min-step=+[F]:f:' \
        '--nsteps=+[N]:n:' \
        '--store-states=+[bool]:b:(true false)' \
        '--store-final-state=+[bool]:b:(true false)' \
        '--seed=+[seed]:n:' \
        '--progress-bar[show progress bar]' \
        '--no-progress-bar[no progress bar]' \
        '--openmp=+[bool]:b:(true false)' \
        '--openmp-threshold=+[N]:n:' \
        '--use-openmp[use OpenMP]' \
        '--no-openmp[no OpenMP]' \
        '--debug[debug logging]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qutip subcommand' sub ;;
        args)
            case $words[1] in
                simulate|solve|mesolve|mcsolve|sesolve|steady) _arguments \
                    '--hamiltonian=+[file]:file:_files -g "*.py *.json"' \
                    '--initial-state=+[file]:file:_files -g "*.py *.json"' \
                    '--times=+[csv times]:str:' \
                    '--collapse-operators=+[csv]:str:' \
                    '--c-ops=+[csv]:str:' \
                    '--ntraj=+[N]:n:' \
                    '*:input:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_qutip "$@"
