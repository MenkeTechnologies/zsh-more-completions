#compdef seatd

# Zsh completion for seatd (minimal seat management daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-g+[Specify group with access to the seat socket]:group:_groups' \
  '-l+[Set log level]:level:(silent error info debug)' \
  '-n+[Set FD number for socket activation]:fd' \
  '-s+[Specify socket path]:socket path:_files' \
  '-v[Print version]' \
  '-h[Print help]' && ret=0

return ret
