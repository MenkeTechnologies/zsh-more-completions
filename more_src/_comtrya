#compdef comtrya

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[path to configuration file]:file:_files' \
  '(-d --manifest-directory)'{-d,--manifest-directory}'[path to manifest directory]:directory:_directories' \
  '--no-color[disable colored output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'apply:apply manifests'
      'contexts:list available contexts'
      'status:show status of manifests'
      'version:print version information'
    )
    _describe -t commands 'comtrya command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (apply)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-c --config)'{-c,--config}'[path to configuration file]:file:_files' \
          '(-d --manifest-directory)'{-d,--manifest-directory}'[path to manifest directory]:directory:_directories' \
          '--no-color[disable colored output]' \
          '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
          '*:manifest name' && ret=0
        ;;
      (contexts)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-c --config)'{-c,--config}'[path to configuration file]:file:_files' \
          '(-d --manifest-directory)'{-d,--manifest-directory}'[path to manifest directory]:directory:_directories' && ret=0
        ;;
      (status)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-c --config)'{-c,--config}'[path to configuration file]:file:_files' \
          '(-d --manifest-directory)'{-d,--manifest-directory}'[path to manifest directory]:directory:_directories' && ret=0
        ;;
      (version)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
