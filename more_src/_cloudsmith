#compdef cloudsmith

# Zsh completion for cloudsmith - package management CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:check the API status'
  'copy:copy a package to another repository'
  'delete:delete a package from a repository'
  'dependencies:list package dependencies'
  'docs:open Cloudsmith documentation'
  'entitlements:manage entitlements'
  'help:show help'
  'list:list packages, repos, etc.'
  'login:login to Cloudsmith'
  'logout:logout from Cloudsmith'
  'metrics:view metrics for a repository'
  'move:move a package to another repository'
  'policy:manage policies'
  'push:push a package to a repository'
  'quarantine:manage package quarantine'
  'quota:view quota usage'
  'resync:resync a package'
  'status:get synchronization status'
  'tags:manage package tags'
  'token:manage API tokens'
  'upstream:manage upstreams'
  'whoami:show current user'
)

_arguments -s -S \
  '(-k --api-key)'{-k+,--api-key=}'[API key]:key:' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-F --output-format)'{-F+,--output-format=}'[output format]:format:(json pretty_json table csv)' \
  '--profile=[use named profile]:profile:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'cloudsmith command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      push)
        _arguments \
          '1:format:(alpine cargo composer conan conda cran dart deb docker go helm hex luarocks maven npm nuget python raw rpm ruby swift terraform vagrant)' \
          '2:owner/repo:' \
          '3:package file:_files'
        ;;
      list)
        _arguments \
          '1:resource:(distros packages repos)' \
          '2:owner/repo:'
        ;;
    esac
    ;;
esac

return ret
