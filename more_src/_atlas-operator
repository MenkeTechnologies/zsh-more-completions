#compdef atlas-operator
# _atlas-operator — Ariga Atlas Operator (reconciles AtlasSchema + AtlasMigration CRs against managed databases using the atlas CLI)
# upstream: https://github.com/ariga/atlas-operator
# Flags from cmd/main.go on tip + controller-runtime zap.Options.

_atlas-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metric endpoint bind address]:addr:' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '--leader-elect[enable leader election]' \
        '--metrics-secure[serve metrics over HTTPS]' \
        '--enable-http2[enable HTTP/2 for the webhook + metrics servers]' \
        '--zap-devel[zap development-mode encoder]' \
        '--zap-encoder=[zap log encoder]:enc:(json console)' \
        '--zap-log-level=[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=[zap log level that triggers a stacktrace]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_atlas-operator "$@"
