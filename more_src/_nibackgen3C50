#compdef nibackgen3C50
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/nibackgen3C50.html
# Estimate NICER background spectra using the 3C50 background library model

local ret=1

_arguments -s -S \
  'rootdir=[input observation root directory]:rootdir:_files -/' \
  'obsid=[observation identifier]:obsid:' \
  'bkgidxdir=[directory of nibackgen3C50_info.fits index]:bkgidxdir:_files -/' \
  'bkglibdir=[directory of 3C50 library spectra]:bkglibdir:_files -/' \
  'gainepoch=[library version]:gainepoch:(2018 2019 2020 AUTO)' \
  'calevtdir=[directory with ufa and cl event files]:calevtdir:_files -/' \
  'totspec=[output root for total spectrum]:totspec:' \
  'bkgspec=[output root for background spectrum]:bkgspec:' \
  'ufafile=[master unfiltered event file]:ufafile:_files' \
  'clfile=[cleaned event file]:clfile:_files' \
  'fpmofflist=[list of FPMs to exclude]:fpmofflist:' \
  'dtmin=[minimum time interval seconds]:dtmin:' \
  'dtmax=[maximum time interval seconds]:dtmax:' \
  'hbgcut=[max net HBG 13-15 keV rate ct/s]:hbgcut:' \
  's0cut=[max net S0 0.2-0.3 keV rate ct/s]:s0cut:' \
  'minweight=[minimum weight threshold]:minweight:' \
  'cleanup=[remove temporary files]:cleanup:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
