#compdef git-instaweb

# Zsh completion for git-instaweb - instantly browse your working repository in gitweb

_arguments -s -S \
  '(-d --httpd)'{-d,--httpd}'[HTTP daemon command]:httpd:(lighttpd apache2 mongoose plackup webrick)' \
  '(-l --local)'{-l,--local}'[bind only to localhost]' \
  '(-m --module-path)'{-m,--module-path}'[set module path for Apache]:path:_directories' \
  '(-p --port)'{-p,--port}'[port to bind to]:port:' \
  '(-b --browser)'{-b,--browser}'[browser to launch]:browser:' \
  '--start[start the httpd]' \
  '--stop[stop the httpd]' \
  '--restart[restart the httpd]' \
  '(-h --help)'{-h,--help}'[show help]'
