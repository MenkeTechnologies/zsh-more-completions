#compdef sustaticB
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/statics/sustaticB.c
# elevation static corrections from headers or source/receiver statics file

local ret=1

_arguments -s -S \
  'v0=[weathering velocity]:v0' \
  'v1=[subweathering velocity]:v1' \
  'hdrs=[0 calc field statics, 1 read from headers, 2 from files, 3 from suresstat]:hdrs:(0 1 2 3)' \
  'sign=[1 apply static correction, -1 apply negative of tstat]:sign:(1 -1)' \
  'sou_file=[input file for source statics (ms)]:file:_files' \
  'rec_file=[input file for receiver statics (ms)]:file:_files' \
  'ns=[number of sources / max fldr]:ns' \
  'nr=[number of receivers]:nr' \
  'no=[number of offsets]:no' \
  '*:file:_files' && ret=0

return ret
