#compdef iowrf
# WRF utility to thin, de-stagger, or extract a box from WRF netCDF files

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-thina[thin data 1:X with averaging]:factor:' \
  '-thin[thin data 1:X without averaging]:factor:' \
  '-box[extract a box from the data]:box spec:' \
  '-A[de-stagger data without thinning]' \
  '-64bit[enable access to files larger than 2GB]' \
  '*:wrf netcdf file:_files -g "*.nc"' && ret=0

return ret
