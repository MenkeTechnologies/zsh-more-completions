#compdef scw
# Documentation: https://github.com/scaleway/scaleway-cli/tree/master/docs/commands
# Reference accessed: 2026-05-21
# Verified: docs/commands/ directory listing (top-level command .md files) plus
# docs/commands/help.md for global flag listing.
# Removed from prior file: applesilicon (real is apple-silicon), document-db
# (does not exist as a top-level command), `-D` short form for --debug (not
# documented), subcommand-level _arguments stanzas with guessed sub-subcommands
# (instance/k8s/rdb/etc.) — those guessed sub-sub lists are unverified against
# the per-command .md files and have been removed pending real verification.
# Added: alias, apple-silicon, audit-trail, billing, dedibox, datalab,
# datawarehouse, edge-services, file, fip, inference, interlink, keymanager,
# login, mongodb, s2s-vpn, sdb-sql, searchdb, shell, vpc-gw (verified from
# docs/commands directory listing).

local -a _scw_commands
_scw_commands=(
  'account:account management'
  'alias:alias management'
  'apple-silicon:Apple Silicon management'
  'audit-trail:audit trail'
  'autocomplete:autocomplete related commands'
  'baremetal:Elastic Metal management'
  'billing:billing'
  'block:Block Storage management'
  'cockpit:Cockpit management'
  'config:config management'
  'container:Serverless Containers'
  'datalab:data lab'
  'datawarehouse:data warehouse'
  'dedibox:dedibox'
  'dns:DNS management'
  'edge-services:edge services'
  'feedback:send feedback'
  'file:File Storage'
  'fip:flexible IP'
  'function:Serverless Functions'
  'help:show help'
  'iam:IAM management'
  'inference:inference'
  'info:display info'
  'init:initialize CLI'
  'instance:Instance management'
  'interlink:interlink'
  'iot:IoT Hub management'
  'ipam:IP Address management'
  'jobs:Serverless Jobs'
  'k8s:Kubernetes management'
  'keymanager:Key Manager'
  'lb:Load Balancer management'
  'login:login'
  'marketplace:Marketplace management'
  'mnq:Messaging and Queuing'
  'mongodb:Managed MongoDB'
  'object:Object Storage management'
  'rdb:Managed Database management'
  'redis:Managed Redis management'
  'registry:Container Registry management'
  's2s-vpn:site-to-site VPN'
  'sdb-sql:Serverless SQL DB'
  'searchdb:search DB'
  'secret:Secret Manager'
  'shell:interactive shell'
  'tem:Transactional Email'
  'version:show version'
  'vpc:VPC management'
  'vpc-gw:VPC Gateway'
  'webhosting:Web Hosting management'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debug[enable debug mode]' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(human wide json json=pretty yaml template)' \
  '(-p --profile)'{-p+,--profile=}'[profile to use]:profile:' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'scw commands' _scw_commands
    ;;
esac
