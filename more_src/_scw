#compdef scw

local -a _scw_commands
_scw_commands=(
  'autocomplete:autocomplete related commands'
  'account:account management'
  'applesilicon:Apple Silicon management'
  'baremetal:Elastic Metal management'
  'block:Block Storage management'
  'cockpit:Cockpit management'
  'config:config management'
  'container:Serverless Containers'
  'dns:DNS management'
  'document-db:Document DB management'
  'feedback:send feedback'
  'function:Serverless Functions'
  'iam:IAM management'
  'info:display info'
  'init:initialize CLI'
  'instance:Instance management'
  'iot:IoT Hub management'
  'ipam:IP Address management'
  'jobs:Serverless Jobs'
  'k8s:Kubernetes management'
  'lb:Load Balancer management'
  'marketplace:Marketplace management'
  'mnq:Messaging and Queuing'
  'object:Object Storage management'
  'rdb:Managed Database management'
  'redis:Managed Redis management'
  'registry:Container Registry management'
  'secret:Secret Manager'
  'tem:Transactional Email'
  'version:show version'
  'vpc:VPC management'
  'webhosting:Web Hosting management'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-D --debug)'{-D,--debug}'[enable debug mode]' \
  '(-o --output)'{-o,--output}'[output format]:format:(human json yaml template)' \
  '(-p --profile)'{-p,--profile}'[profile to use]:profile' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'scw commands' _scw_commands
    ;;
  args)
    case "$words[1]" in
      instance)
        _arguments -C '1:subcommand:(server image ip placement-group private-nic security-group snapshot user-data volume)' '*::arg:->iargs'
        ;;
      k8s)
        _arguments -C '1:subcommand:(cluster node pool kubeconfig version acl)' '*::arg:->kargs'
        ;;
      rdb)
        _arguments -C '1:subcommand:(instance engine backup endpoint user database privilege acl snapshot log)' '*::arg:->rargs'
        ;;
      lb)
        _arguments -C '1:subcommand:(lb backend frontend ip certificate subscriber private-network route)' '*::arg:->largs'
        ;;
      registry)
        _arguments -C '1:subcommand:(namespace image tag login logout)' '*::arg:->rgargs'
        ;;
      dns)
        _arguments -C '1:subcommand:(zone record version)' '*::arg:->dargs'
        ;;
      vpc)
        _arguments -C '1:subcommand:(vpc private-network gateway)' '*::arg:->vargs'
        ;;
      object)
        _arguments -C '1:subcommand:(config)' '*::arg:->oargs'
        ;;
      iam)
        _arguments -C '1:subcommand:(api-key application group permission-set policy ssh-key user)' '*::arg:->iamargs'
        ;;
      secret)
        _arguments -C '1:subcommand:(secret version)' '*::arg:->sargs'
        ;;
      config)
        _arguments '1:subcommand:(set get unset dump reset info init profile validate destroy send-telemetry)'
        ;;
      init)
        _arguments \
          '--secret-key[secret key]:key' \
          '--send-telemetry[send telemetry]' \
          '--with-ssh-key[SSH key path]:file:_files' \
          '--organization-id[organization ID]:id' \
          '--project-id[project ID]:id'
        ;;
    esac
    ;;
esac
