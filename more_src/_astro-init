#compdef astro-init
# _astro-init — Astro modern static site builder init CLI alias (withastro team, TypeScript); yargs-parser
# upstream: https://github.com/withastro/astro

_astro-init() {
    local -a sub=(
        'create:create new project'
        'add:add integration'
        'build:build production site'
        'check:type check'
        'dev:start dev server'
        'preview:preview production build'
        'sync:generate types'
        'telemetry:enable/disable telemetry'
        'docs:open docs'
        'info:show info'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--verbose[verbose]' \
        '--silent[silent]' \
        '--config=+[config file]:file:_files -g "astro.config*"' \
        '-c+[config file]:file:_files -g "astro.config*"' \
        '--root=+[project root]:dir:_files -/' \
        '--site=+[site URL]:url:_urls' \
        '--base=+[base path]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'astro subcommand' sub ;;
        args)
            case $words[1] in
                dev|preview) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '-H+[host]:host:_hosts' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--open=+[url]:str:' \
                    '--strict-port[strict port]' \
                    '--cors[cors]' \
                    '--force[force]' \
                    '--log-level=+[level]:l:(info warn error silent)' ;;
                build) _arguments \
                    '--site=+[site URL]:url:_urls' \
                    '--base=+[base path]:str:' \
                    '--mode=+[mode]:m:(development production)' \
                    '--config=+[config file]:file:_files' \
                    '--no-cleanup[no cleanup]' \
                    '--verbose[verbose]' ;;
                add) _arguments \
                    '*:integration:(react preact solid svelte vue mdx tailwind partytown sitemap alpinejs lit cloudflare deno netlify node vercel db prefetch markdoc starlight)' \
                    '--yes[skip confirmations]' \
                    '-y[skip confirmations]' ;;
                create) _arguments \
                    '1:project name:_files -/' \
                    '--template=+[template]:str:' \
                    '--no-install[no install]' \
                    '--no-git[no git init]' \
                    '--yes[skip prompts]' \
                    '-y[skip prompts]' ;;
                telemetry) _arguments '1:cmd:(enable disable status)' ;;
                check) _arguments '--watch[watch]' '--verbose[verbose]' '--noSync[no sync]' ;;
                sync) ;;
            esac
            ;;
    esac
}

_astro-init "$@"
