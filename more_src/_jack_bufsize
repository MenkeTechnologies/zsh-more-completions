#compdef jack_bufsize
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/jack_bufsize.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-s+[server name]:srv:' \
  '1:buffer frames:(32 64 128 256 512 1024 2048 4096)' && ret=0

return ret
