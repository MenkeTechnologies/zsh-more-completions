#compdef jack_bufsize
# Documentation: https://man.archlinux.org/search?q=jack_bufsize
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-s+[server name]:srv:' \
  '1:buffer frames:(32 64 128 256 512 1024 2048 4096)' && ret=0

return ret
