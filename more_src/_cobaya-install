#compdef cobaya-install
# Documentation: https://cobaya.readthedocs.io/en/latest/installation.html
# cobaya: installation tool for external packages

local ret=1

_arguments -s -S \
  '(-p --packages-path)'{-p,--packages-path}'=[desired path where to install external packages]:path:_files -/' \
  '--show-packages-path[show the current default install path and exit]' \
  '(-f --force)'{-f,--force}'[force re-installation of apparently installed packages]' \
  '--test[just check whether components are installed]' \
  '--upgrade[force upgrade of obsolete components]' \
  '--skip=[keywords of components that will be skipped during installation]:keyword' \
  '--skip-global[skip installation of already-available Python modules]' \
  '(-d --debug)'{-d,--debug}'[produce verbose debug output]' \
  '(-C --just-code -D --just-data)'{-C,--just-code}'[install code of the components]' \
  '(-D --just-data -C --just-code)'{-D,--just-data}'[install data of the components]' \
  '--no-progress-bars[no progress bars shown]' \
  '--no-set-global[do not store the installation path for later runs]' \
  '*:input file or component:_files -g "*.yaml"' && ret=0

return ret
