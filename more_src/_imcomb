#compdef imcomb
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imcomb.html
# MIRIAD: combine images by noise weighting

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image datasets]:in:_files' \
  'out=[output combined dataset]:out:_files' \
  'rms=[relative noise levels of inputs]:rms:' \
  'options=[nonormalise,relax,fqaver]:options:(nonormalise relax fqaver)' \
  '*:image:_files' && ret=0

return ret
