#compdef jwm
# Documentation: https://man.archlinux.org/search?q=jwm
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --reload)'{-c,--reload}'[reload menu without restarting]' \
  '(-display --display)'{-display,--display}'+[X display]:display:' \
  '(-exit --exit)'{-exit,--exit}'[exit JWM]' \
  '(-f --config)'{-f,--config}'+[config file]:file:_files' \
  '(-p --parse)'{-p,--parse}'[parse config and exit]' \
  '(-restart --restart)'{-restart,--restart}'[restart JWM]' \
  '(-reload --reload)'{-reload,--reload}'[reload config]' && ret=0

return ret
