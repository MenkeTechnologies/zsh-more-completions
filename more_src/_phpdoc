#compdef phpdoc
# Documentation: https://docs.phpdoc.org/3.0/guide/getting-started/configuration.html
# phpDocumentor API documentation generator

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --target)'{-t,--target}'=[path where to store generated output]:dir:_files -/' \
  '(-d --directory)'{-d,--directory}'=[source directory to parse]:dir:_files -/' \
  '(-f --filename)'{-f,--filename}'=[file to parse]:file:_files' \
  '(-c --config)'{-c,--config}'=[path to configuration file]:file:_files' \
  '--force[force re-parsing, ignore cache]' \
  '--cache-folder=[directory used to store cache files]:dir:_files -/' \
  '--title=[title for the generated documentation]:title' \
  '--template=[template/theme to use for output]:template' \
  '*:command:(run list help project:run)' && ret=0

return ret
