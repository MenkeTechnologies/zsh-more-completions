#compdef phpdoc
# _phpdoc — phpDocumentor generates PHP documentation (phpDocumentor/phpDocumentor)
# upstream: https://github.com/phpDocumentor/phpDocumentor

_phpdoc() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-q --quiet)'{-q,--quiet}'[do not output any message]' \
        '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'run:generate documentation'
                'list:list available commands'
                'project\:run:generate documentation (alias)'
                'project\:parse:parse source files'
                'project\:transform:transform parsed data into output'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                run|project:run)
                    _arguments -s -S \
                        '(-d --directory)'{-d,--directory}'=[source directory]:dir:_directories' \
                        '(-f --filename)'{-f,--filename}'=[specific file to parse]:file:_files' \
                        '(-t --target)'{-t,--target}'=[output directory]:dir:_directories' \
                        '--encoding=[file encoding]:encoding:' \
                        '--extensions=[file extensions to parse]:extensions:' \
                        '*--ignore=[patterns to ignore]:pattern:' \
                        '*--ignore-tags=[tags to ignore]:tag:' \
                        '--hidden[parse hidden files]' \
                        '--ignore-symlinks[ignore symlinks]' \
                        '*--markers=[markers to scan for]:marker:' \
                        '--title=[project title]:title:' \
                        '--template=[template to use]:template:' \
                        '*--setting=[custom settings]:setting:' \
                        '--parseprivate[parse private members]' \
                        '--defaultpackagename=[default package name]:name:' \
                        '--sourcecode[include source code in output]'
                    ;;
                project:parse)
                    _arguments -s -S \
                        '(-d --directory)'{-d,--directory}'=[source directory]:dir:_directories' \
                        '(-f --filename)'{-f,--filename}'=[specific file to parse]:file:_files' \
                        '--encoding=[file encoding]:encoding:' \
                        '--extensions=[file extensions]:extensions:'
                    ;;
                project:transform)
                    _arguments -s -S \
                        '(-t --target)'{-t,--target}'=[output directory]:dir:_directories' \
                        '--template=[template to use]:template:'
                    ;;
            esac
            ;;
    esac
}

_phpdoc "$@"
