#compdef motus
# Documentation: https://github.com/motu-tool/mOTUs/wiki
# Marker gene-based operational taxonomic unit metagenomic profiler

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '--version[show version]' \
  '--test[test dependencies and functionality]' \
  '--no_colour[disable colored output]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'motus command' \
      'profile[taxonomic profiling of one sample]' \
      'merge[merge profiles into a table]' \
      'map_tax[map reads to taxonomy]' \
      'calc_mgc[calculate marker gene clusters]' \
      'calc_motu[calculate mOTU abundances]' \
      'snv_call[call single nucleotide variants]' \
      'map_snv[map reads for SNV calling]' \
      'prep_long[prepare long reads]' \
      'downloadDB[download the mOTUs database]' && ret=0
    ;;
  args)
    case $line[1] in
      profile)
        _arguments -s \
          '-f[forward reads file]:reads:_files' \
          '-r[reverse reads file]:reads:_files' \
          '-s[single-end reads file]:reads:_files' \
          '-i[input SAM/BAM file(s)]:file:_files' \
          '-m[mOTU read counts file]:file:_files' \
          '-o[output file]:file:_files' \
          '-n[sample name]:name:' \
          '-t[number of threads]:threads:' \
          '-l[minimum alignment length]:len:' \
          '-g[minimum marker gene cutoff]:n:' \
          '-y[output count type]:type:(base.coverage insert.raw_counts insert.scaled_counts)' \
          '-k[taxonomic level]:level:(kingdom phylum class order family genus species mOTU)' \
          '-C[CAMI output format]:fmt:(precision recall parenthesis)' \
          '-e[profile only reference specI clusters]' \
          '-c[print counts instead of relative abundance]' \
          '-p[print NCBI taxonomy ids]' \
          '-q[print full taxonomic rank]' \
          '-u[print full species names]' \
          '-A[print all taxonomic levels together]' \
          '-B[BIOM format output]' \
          '-I[save intermediate BAM file]:file:_files' \
          '-M[save marker gene abundance table]:file:_files' \
          '-db[custom database directory]:dir:_files -/' \
          '-v[verbosity level]:level:(1 2 3)'
        ;;
      merge)
        _arguments -s \
          '-i[input profile files]:files:_files' \
          '-d[directory of profile files]:dir:_files -/' \
          '-o[output merged table]:file:_files' \
          '-B[BIOM format output]' \
          '-a[append external profile]:profile:_files'
        ;;
      downloadDB)
        _arguments -s \
          '-t[number of threads]:threads:' \
          '-v[verbosity level]:level:(1 2 3)'
        ;;
    esac
    ;;
esac

return ret
