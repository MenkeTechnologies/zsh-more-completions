#compdef agentwork
# Documentation: https://github.com/agentwork-ai/agentwork
# Reference accessed: 2026-05-22
# Verified: upstream README CLI command list.

# Zsh completion for agentwork - multi-agent orchestration daemon CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'agentwork command' \
      'start[start daemon]' \
      'restart[restart daemon]' \
      'stop[graceful shutdown]' \
      'update[install latest release and restart if running]' \
      'status[show PID, URL, active agents]' \
      'logs[tail server logs]' \
      'clean[clear temp files and logs]' \
      'task[manage tasks]' \
      'agent[manage agents]' && ret=0
    ;;
  args)
    case $line[1] in
      start|restart)
        _arguments \
          '(-p --port)'{-p,--port}'[listen port]:port:' \
          '(-f --foreground)'{-f,--foreground}'[run in foreground]' && ret=0
        ;;
      update)
        _arguments '--tag[release tag to install]:tag:' && ret=0
        ;;
      logs)
        _arguments \
          '-n[number of lines]:count:' \
          '(-f --follow)'{-f,--follow}'[follow log output]' && ret=0
        ;;
      task)
        if (( CURRENT == 3 )); then
          _values 'task command' list create && ret=0
        elif [[ $line[2] == list ]]; then
          _arguments '--status[filter by status]:status:' && ret=0
        elif [[ $line[2] == create ]]; then
          _arguments \
            '--description[task description]:text:' \
            '--priority[priority]:priority:' \
            '--agent[assign to agent]:agent:' \
            '1:title:' && ret=0
        fi
        ;;
      agent)
        if (( CURRENT == 3 )); then
          _values 'agent command' list && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
