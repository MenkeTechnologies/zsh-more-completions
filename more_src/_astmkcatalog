#compdef astmkcatalog
# astmkcatalog — GNU Astronomy Utilities catalog maker

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--cite[show citation info]' \
  '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '--hdu[HDU/extension name or number]:hdu:' \
  '--valuesfile[values (intensity) file]:file:_files -g "*.fits"' \
  '--valueshdu[values HDU]:hdu:' \
  '--clumpsfile[clumps labels file]:file:_files -g "*.fits"' \
  '--clumpshdu[clumps HDU]:hdu:' \
  '--objectsfile[objects labels file]:file:_files -g "*.fits"' \
  '--objectshdu[objects HDU]:hdu:' \
  '--ids[print object/clump IDs]' \
  '--hostobjid[print host object ID]' \
  '--numclumps[number of clumps in object]' \
  '--area[print area]' \
  '--clumpsarea[print clumps area]' \
  '--x[position in first FITS axis]' \
  '--y[position in second FITS axis]' \
  '--ra[right ascension]' \
  '--dec[declination]' \
  '--brightness[total brightness]' \
  '--clumpbrightness[clumps brightness]' \
  '--magnitude[total magnitude]' \
  '--magnitudeerr[magnitude error]' \
  '--sn[signal to noise ratio]' \
  '--upperlimit[upper limit value]' \
  '--upperlimitnum[upper limit random samples]:number:' \
  '--upperlimitsigma[upper limit sigma]:sigma:' \
  '--semimajor[semi-major axis]' \
  '--semiminor[semi-minor axis]' \
  '--axisratio[axis ratio]' \
  '--positionangle[position angle]' \
  '--geox[geometric center X]' \
  '--geoy[geometric center Y]' \
  '--clumpsx[clumps center X]' \
  '--clumpsy[clumps center Y]' \
  '--fracmax1[fraction of maximum 1]' \
  '--fracmax2[fraction of maximum 2]' \
  '--fwhm[full width at half maximum]' \
  '--halfmaxarea[half-max area]' \
  '--halfmaxsb[half-max surface brightness]' \
  '--halfmaxradius[half-max radius]' \
  '*:input file:_files -g "*.fits"'
