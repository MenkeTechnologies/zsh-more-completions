  '--clumps-z[brightness-weighted Z of clumps]' \
  '--clumps-geo-x[geometric center X of clumps]' \
  '--clumps-geo-y[geometric center Y of clumps]' \
  '--clumps-geo-z[geometric center Z of clumps]' \
  '(-r --ra)'{-r,--ra}'[right ascension (WCS)]' \
  '(-d --dec)'{-d,--dec}'[declination (WCS)]' \
  '--w1[WCS axis 1 coordinate]' \
  '--w2[WCS axis 2 coordinate]' \
  '--w3[WCS axis 3 coordinate]' \
  '--geo-w1[geometric center WCS axis 1]' \
  '--geo-w2[geometric center WCS axis 2]' \
  '--geo-w3[geometric center WCS axis 3]' \
  '--clumps-w1[WCS axis 1 of clumps]' \
  '--clumps-w2[WCS axis 2 of clumps]' \
  '--clumps-w3[WCS axis 3 of clumps]' \
  '--clumps-geo-w1[geometric center WCS 1 of clumps]' \
  '--clumps-geo-w2[geometric center WCS 2 of clumps]' \
  '--clumps-geo-w3[geometric center WCS 3 of clumps]' \
  '--num-clumps[number of clumps in object]' \
  '--area[area of object in pixels]' \
  '--area-arcsec2[area in arc-seconds squared]' \
  '--area-xy[area projected on XY plane]' \
  '--clumps-area[area of clumps]' \
  '--sum[sum of pixel values]' \
  '--sum-error[error in sum]' \
  '--clumps-sum[sum in clumps]' \
  '--sum-no-river[sum excluding rivers]' \
  '--mean[mean pixel value]' \
  '--mean-error[error in mean]' \
  '--std[standard deviation of pixel values]' \
  '--median[median pixel value]' \
  '--maximum[maximum pixel value]' \
  '(-m --magnitude)'{-m,--magnitude}'[magnitude]' \
  '--magnitude-error[error in magnitude]' \
  '--clumps-magnitude[magnitude of clumps]' \
  '--upperlimit[upper limit value]' \
