  '--upperlimit-onesigma[one-sigma upper limit]' \
  '--upperlimit-sigma[upper limit sigma]' \
  '--upperlimit-quantile[upper limit quantile]' \
  '--upperlimit-skew[upper limit skew]' \
  '--sn[signal to noise ratio]' \
  '--sky[sky value]' \
  '--sky-std[sky standard deviation]' \
  '--river-mean[mean of river pixels]' \
  '--river-num[number of river pixels]' \
  '--river-min[minimum river pixel value]' \
  '--river-max[maximum river pixel value]' \
  '--sb[surface brightness]' \
  '--sb-error[surface brightness error]' \
  '--upperlimit-sb[upper limit surface brightness]' \
  '--fwhm[full width at half maximum]' \
  '--half-max-radius[half maximum radius]' \
  '--half-max-sum[half maximum sum]' \
  '--half-max-sb[half maximum surface brightness]' \
  '--half-sum-radius[half sum radius]' \
  '--half-sum-sb[half sum surface brightness]' \
  '--semi-major[semi-major axis]' \
  '--semi-minor[semi-minor axis]' \
  '--axis-ratio[axis ratio]' \
  '--position-angle[position angle]' \
  '--geo-semi-major[geometric semi-major axis]' \
  '--geo-semi-minor[geometric semi-minor axis]' \
  '--geo-axis-ratio[geometric axis ratio]' \
  '--geo-position-angle[geometric position angle]' \
  '*:input labeled image:_files -g "*.fits(|.gz|.fz)(N)"'
