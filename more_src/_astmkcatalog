#compdef astmkcatalog
# astmkcatalog — create catalogs from labeled images

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress extra information]' \
  '--log[store program activity in a log file]' \
  '(-N --numthreads)'{-N,--numthreads}'[number of CPU threads]:number' \
  '--minmapsize[minimum bytes to use memory-mapped files]:size' \
  '--quietmmap[do not report memory-mapped file creation]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[output data type]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--tableformat[output table format]:format:(txt fits-ascii fits-binary)' \
  '(-h --hdu)'{-h,--hdu}'[extension name or number of input]:HDU' \
  '(-I --ignorecase)'{-I,--ignorecase}'[ignore case in matching column names]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and exit]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for current directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for current user]' \
  '--cite[show BibTeX citation for this program]' \
  '--config[configuration file to use]:file:_files' \
  '--checkconfig[print all config files and variables]' \
  '--onlyversion[only run if program version matches]:version' \
  '--searchin[search column metadata]:where:(name unit comment)' \
  '(-Z --tilesize)'{-Z,--tilesize}'[regular tile size on each dimension]:sizes' \
  '(-M --numchannels)'{-M,--numchannels}'[number of channels in each dimension]:channels' \
  '(-F --remainderfrac)'{-F,--remainderfrac}'[fraction of remainder to merge with tiles]:fraction' \
  '--interpnumngb[number of neighbors for interpolation]:number' \
  '--interpmetric[metric for nearest neighbor interpolation]:metric:(radial manhattan)' \
  '--interponlyblank[only interpolate over blank tiles]' \
  '(-l --clumpsfile)'{-l,--clumpsfile}'[dataset containing clump labels]:file:_files' \
  '--clumpshdu[clump labels extension name or number]:HDU' \
  '(-v --valuesfile)'{-v,--valuesfile}'[values/brightness dataset]:file:_files' \
  '--valueshdu[extension containing values]:HDU' \
  '(-s --insky)'{-s,--insky}'[input sky value or file]:value or file' \
  '--skyhdu[sky image extension name or number]:HDU' \
  '--subtractsky[subtract sky dataset from values]' \
  '(-t --instd)'{-t,--instd}'[sky standard deviation value or dataset]:value or file' \
  '--stdhdu[sky STD extension name or number]:HDU' \
  '--variance[STD input is actually variance]' \
  '--novalinerror[ignore pixel values when estimating errors]' \
  '--forcereadstd[read STD even if no columns need it]' \
  '--zeropoint[zeropoint magnitude of input]:magnitude' \
  '--sigmaclip[sigma-clip column multiple and tolerance]:multiple,tolerance' \
  '(-C --clumpscat)'{-C,--clumpscat}'[make a clumps catalog also]' \
  '--noclumpsort[do not sort clumps catalog by ID]' \
  '--sfmagnsigma[surface brightness multiple of sky STD]:multiple' \
  '--sfmagarea[surface brightness area in arcseconds^2]:area' \
  '--inbetweenints[keep rows with integer IDs with no labels]' \
  '--upmaskfile[mask image file only for upper limit]:file:_files' \
  '--upmaskhdu[mask image HDU only for upper limit]:HDU' \
  '--upnum[number of randomly positioned samples]:number' \
  '--uprange[range of random positions around target]:min,max' \
  '(-e --envseed)'{-e,--envseed}'[use GSL_RNG_SEED environment variable for seed]' \
  '--upsigmaclip[sigma multiple and tolerance for upper limit]:multiple,tolerance' \
  '--upnsigma[multiple of sigma to define upper limit]:multiple' \
  '--checkuplim[check random distribution for one label]:label' \
  '--frac-max[fractions for frac-max options]:fractions' \
  '--spatialresolution[spatial resolution for surface brightness error]:value' \
  '(-i --ids)'{-i,--ids}'[object ID column]' \
  '--obj-id[object ID]' \
  '--host-obj-id[host object ID]' \
  '--id-in-host-obj[ID of clump in host object]' \
  '(-x --x)'{-x,--x}'[pixel position in X]' \
  '(-y --y)'{-y,--y}'[pixel position in Y]' \
  '(-z --z)'{-z,--z}'[pixel position in Z]' \
  '--geo-x[geometric center X]' \
  '--geo-y[geometric center Y]' \
  '--geo-z[geometric center Z]' \
  '--min-val-x[X of minimum value pixel]' \
  '--min-val-y[Y of minimum value pixel]' \
  '--min-val-z[Z of minimum value pixel]' \
  '--max-val-x[X of maximum value pixel]' \
  '--max-val-y[Y of maximum value pixel]' \
  '--max-val-z[Z of maximum value pixel]' \
  '--min-x[minimum X pixel]' \
  '--min-y[minimum Y pixel]' \
  '--min-z[minimum Z pixel]' \
  '--max-x[maximum X pixel]' \
  '--max-y[maximum Y pixel]' \
  '--max-z[maximum Z pixel]' \
  '--clumps-x[brightness-weighted X of clumps]' \
