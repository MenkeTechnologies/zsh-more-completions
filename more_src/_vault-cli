#compdef vault-cli
# _vault-cli — HashiCorp Vault secrets management CLI alias (HashiCorp, Go); custom argparse
# upstream: https://github.com/hashicorp/vault

_vault-cli() {
    local -a sub=(
        'agent:start agent'
        'agent-generate-config:generate agent config'
        'audit:audit log commands'
        'auth:auth methods'
        'debug:capture diagnostic snapshot'
        'delete:delete secret/path'
        'events:read events'
        'fmt:format hcl'
        'kv:KV secret commands'
        'lease:lease commands'
        'list:list secrets/paths'
        'login:login'
        'logout:logout'
        'monitor:tail server log'
        'namespace:namespace commands (Enterprise)'
        'operator:operator commands'
        'patch:patch secret'
        'path-help:show path-specific help'
        'pki:PKI engine commands'
        'plugin:plugin commands'
        'policy:policy commands'
        'print:print env'
        'proxy:start proxy'
        'read:read data'
        'rotate:rotate commands'
        'secrets:secret engine commands'
        'server:start server'
        'ssh:SSH OTP/CA'
        'status:show server status'
        'token:token commands'
        'transform:transform engine'
        'transit:transit engine'
        'unwrap:unwrap response wrapping'
        'version:show version'
        'write:write data'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--address=+[vault address]:url:_urls' \
        '-address=+[vault address]:url:_urls' \
        '--token=+[vault token]:str:' \
        '--namespace=+[namespace]:str:' \
        '-namespace=+[namespace]:str:' \
        '-output-curl-string[output curl command]' \
        '--output-policy[output policy snippet]' \
        '--ca-cert=+[CA cert]:file:_files' \
        '--ca-path=+[CA dir]:dir:_files -/' \
        '--client-cert=+[client cert]:file:_files' \
        '--client-key=+[client key]:file:_files' \
        '--tls-skip-verify[skip TLS verify]' \
        '--tls-server-name=+[TLS server name]:str:' \
        '--mfa=+[mfa data]:str:' \
        '--wrap-ttl=+[wrap TTL]:str:' \
        '--policy-override[policy override]' \
        '--format=+[output format]:fmt:(table json yaml pretty raw)' \
        '-format=+[output format]:fmt:(table json yaml pretty raw)' \
        '--field=+[field]:str:' \
        '-field=+[field]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vault subcommand' sub ;;
        args)
            case $words[1] in
                kv) _arguments \
                    '1:cmd:(get put patch delete list metadata destroy enable-versioning rollback undelete)' \
                    '-mount=+[mount]:str:' \
                    '-output-curl-string[curl string]' \
                    '*:arg:' ;;
                auth) _arguments \
                    '1:cmd:(enable disable help list move tune)' \
                    '*:arg:' ;;
                secrets) _arguments \
                    '1:cmd:(enable disable list move tune)' \
                    '*:arg:' ;;
                policy) _arguments \
                    '1:cmd:(delete fmt list read write)' \
                    '*:arg:' ;;
                operator) _arguments \
                    '1:cmd:(generate-root init key-status migrate raft rekey rotate seal step-down unseal usage members diagnose)' \
                    '*:arg:' ;;
                lease) _arguments \
                    '1:cmd:(lookup renew revoke)' \
                    '*:arg:' ;;
                token) _arguments \
                    '1:cmd:(capabilities create lookup renew revoke)' \
                    '*:arg:' ;;
                plugin) _arguments \
                    '1:cmd:(deregister info list register reload)' \
                    '*:arg:' ;;
                debug) _arguments \
                    '-compress=+[compress]:b:(true false)' \
                    '-duration=+[duration]:dur:' \
                    '-interval=+[interval]:dur:' \
                    '-log-format=+[log format]:fmt:(standard json)' \
                    '-metrics-interval=+[metrics interval]:dur:' \
                    '-output=+[output file]:file:_files' \
                    '-targets=+[targets]:list:' ;;
                server) _arguments \
                    '-config=+[config file]:file:_files' \
                    '-dev[dev mode]' \
                    '-dev-root-token-id=+[dev root token]:str:' \
                    '-dev-listen-address=+[dev listen address]:str:' \
                    '-log-level=+[log level]:level:(trace debug info warn error)' ;;
            esac
            ;;
    esac
}

_vault-cli "$@"
