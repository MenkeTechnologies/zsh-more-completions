#compdef entwine
# entwine — index massive point cloud datasets

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'build:build an EPT index'
  'info:show information about an EPT dataset'
  'convert:convert EPT data'
  'merge:merge EPT datasets'
  'scan:scan input files'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'entwine subcommand' subcmds && ret=0
    ;;
  rest)
    case $line[1] in
      build)
        _arguments \
          {-i,--input}'=[input file or directory]:input:_files' \
          {-o,--output}'=[output directory]:output dir:_directories' \
          {-t,--threads}'=[number of threads]:threads:' \
          '--tmp=[temp directory]:temp dir:_directories' \
          {-r,--reprojection}'=[reprojection string]:reprojection:' \
          '--srs=[spatial reference system]:SRS:' \
          '--bounds=[processing bounds]:bounds:' \
          '--schema=[dimension schema]:schema:' \
          '--absolute[use absolute positioning]' \
          '--subset=[subset specification]:subset:' && ret=0
        ;;
      info)
        _arguments \
          ':EPT dataset path:_files -/' && ret=0
        ;;
      convert)
        _arguments \
          {-i,--input}'=[input EPT path]:input:_files -/' \
          {-o,--output}'=[output directory]:output dir:_directories' && ret=0
        ;;
      merge)
        _arguments \
          {-o,--output}'=[output directory]:output dir:_directories' \
          '*:EPT dataset path:_files -/' && ret=0
        ;;
      scan)
        _arguments \
          '*:input files:_files' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
