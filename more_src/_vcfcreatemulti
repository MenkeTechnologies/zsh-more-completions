#compdef vcfcreatemulti
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfcreatemulti.md
# vcflib: combine overlapping VCF records into a single multi-allelic record

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--quiet[suppress the progress bar during execution]' \
  '--legacy[use original C++ implementation (no genotype/INFO update)]' \
  '*:vcf file:_files' && ret=0

return ret
