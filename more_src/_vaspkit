#compdef vaspkit
# Documentation: https://vaspkit.com/tutorials.html
# User-friendly interface for high-throughput computing and analysis with VASP

local ret=1

_arguments -s \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-task[task number to run in command-line mode]:task:' \
  '-file[input structure file]:file:_files' \
  '-kpr[k-point resolution in reciprocal space]:kpr:' \
  '*:file:_files' && ret=0

return ret
