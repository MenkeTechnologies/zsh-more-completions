#compdef terraboard
# Documentation: https://github.com/camptocamp/terraboard
# terraboard - web dashboard to inspect Terraform states

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this help message]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-c --config-file)'{-c,--config-file}'=[config file path]:file:_files' \
  '--no-versioning[disable versioning support]' \
  '--no-locks[disable locks support]' \
  '(-l --log-level)'{-l,--log-level}'=[set logging severity level]:level' \
  '--log-format=[set log format]:format:(plain json)' \
  '--db-host=[database server hostname]:host' \
  '--db-port=[database server port]:port' \
  '--db-user=[database user]:user' \
  '--db-password=[database password]:password' \
  '--db-name=[database schema name]:name' \
  '--db-sslmode=[database SSL connection mode]:mode' \
  '--no-sync[do not sync database]' \
  '--sync-interval=[DB refresh frequency in minutes]:minutes' \
  '--aws-access-key=[AWS access key]:key' \
  '--aws-secret-access-key=[AWS secret key]:key' \
  '--aws-session-token=[AWS session token]:token' \
  '--dynamodb-table=[DynamoDB table for state locks]:table' \
  '--aws-endpoint=[AWS service endpoint URL]:url' \
  '--aws-region=[AWS region]:region' \
  '--aws-role-arn=[role ARN to assume]:arn' \
  '--aws-external-id=[external id for role assumption]:id' \
  '--s3-bucket=[S3 bucket name]:bucket' \
  '--key-prefix=[S3 key path prefix filter]:prefix' \
  '--file-extension=[file extension of state files]:ext' \
  '--force-path-style[enable path-style S3 addressing]' \
  '--tfe-address=[Terraform Enterprise address]:address' \
  '--tfe-token=[Terraform Enterprise token]:token' \
  '--tfe-organization=[Terraform Enterprise organization]:org' \
  '--gcs-bucket=[Google Cloud Storage bucket name]:bucket' \
  '--gcp-sa-key-path=[GCP service account key file path]:file:_files' \
  '--gitlab-address=[GitLab instance root URL]:url' \
  '--gitlab-token=[token to authenticate upon GitLab]:token' \
  '(-p --port)'{-p,--port}'=[port to listen on]:port' \
  '--base-url=[application URL routing path]:url' \
  '--logout-url=[logout URL]:url' && ret=0

return ret
