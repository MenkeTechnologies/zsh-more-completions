#compdef recoverpy
# Documentation: https://man.archlinux.org/search?q=recoverpy
# Reference accessed: 2026-05-16

# Zsh completion for recoverpy — file recovery TUI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-p --partition)'{-p,--partition}'[block device]:device:_files' && ret=0

return ret
