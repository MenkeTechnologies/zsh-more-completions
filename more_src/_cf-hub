#compdef cf-hub
# Documentation: https://docs.cfengine.com/docs/3.22/reference-components-cf-hub.html
# cf-hub - CFEngine Enterprise report collection daemon

local ret=1

_arguments -s -S \
  '(-c --continuous)'{-c,--continuous}'[continuous update mode of operation]' \
  '(-C --color)'{-C,--color}'+[enable colorized output]:when:(always auto never)' \
  '(-d --debug)'{-d,--debug}'[set debugging level 0,1,2,3]' \
  '(-f --file)'{-f,--file}'+[specify an alternative input file]:file:_files' \
  '(-F --no-fork)'{-F,--no-fork}'[run as a foreground process (do not fork)]' \
  '(-g --log-level)'{-g,--log-level}'+[how detailed logs should be]:level:(error warning notice info verbose debug)' \
  '(-h --help)'{-h,--help}'[print the help message]' \
  '(-H --query-host)'{-H,--query-host}'+[remote hosts to gather reports from]:host:_hosts' \
  '(-i --inject-hosts)'{-i,--inject-hosts}'+[inject and trust hosts from a hosts file]:file:_files' \
  '(-I --inform)'{-I,--inform}'[print basic information about actions taken]' \
  '(-K --no-lock)'{-K,--no-lock}'[ignore locking constraints during execution]' \
  '(-l --logging)'{-l,--logging}'[enable logging of report collection to hub_log]' \
  '(-L --show-license)'{-L,--show-license}'[show license information for this hub]' \
  '(-M --manpage)'{-M,--manpage}'[print the man page]' \
  '(-n --dry-run)'{-n,--dry-run}'[all talk and no action mode]' \
  '(-q --query)'{-q,--query}'+[collect reports from remote host]:mode:(rebase delta)' \
  '(-s --splay_updates)'{-s,--splay_updates}'[splay/load balance full-updates]' \
  '(-t --timestamp)'{-t,--timestamp}'[log timestamps on each line of log output]' \
  '(-T --query-timeout)'{-T,--query-timeout}'+[connection timeout for querying clients]:seconds:' \
  '(-v --verbose)'{-v,--verbose}'[output verbose information about behaviour]' \
  '(-V --version)'{-V,--version}'[output the version of the software]' \
  '--ignore-preferred-augments[ignore def_preferred.json in favor of def.json]' && ret=0

return ret
