#compdef 3dproject
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dproject.html
# AFNI projection along cardinal axes from a 3D dataset

local ret=1

_arguments -s -S \
  '(-sum -max -amax -smax)-sum[add dataset voxels along projection (default)]' \
  '(-sum -max -amax -smax)-max[take maximum of the voxels]' \
  '(-sum -max -amax -smax)-amax[take absolute maximum of the voxels]' \
  '(-sum -max -amax -smax)-smax[take signed maximum of the voxels]' \
  '-first[take first value greater than x]:x:' \
  '-nsize[scale output images to standard sizes]' \
  '-mirror[mirror axial and coronal projections]' \
  '-output[output filename root]:root:' \
  '-RL[project right-to-left (all or x1 x2)]:rl:' \
  '-AP[project anterior-to-posterior (all or y1 y2)]:ap:' \
  '-IS[project inferior-to-superior (all or z1 z2)]:is:' \
  '-ALL[equivalent to -RL all -AP all -IS all]' \
  '-1thtoin[project threshold data if available]' \
  '*:dataset:_files' && ret=0

return ret
