#compdef w3af_api
# Documentation: http://docs.w3af.org/en/latest/api/
# w3af REST API server

local ret=1

_arguments -s -S \
  '(-h)-h[show help message]' \
  '-p+[SHA512-hashed password for HTTP basic authentication]:hash' \
  '--no-ssl[disable HTTPS for the API service]' \
  '*:config file:_files' && ret=0

return ret
