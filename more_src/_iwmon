#compdef iwmon
# Documentation: https://man.archlinux.org/man/extra/iwd/iwmon.1.en
# iwmon — iwd Internet wireless monitor: monitor and log nl80211 wireless control messages

local ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version number and exit]' \
  '(-h --help)'{-h,--help}'[show help message and exit]' && ret=0

return ret
