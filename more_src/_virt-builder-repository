#compdef virt-builder-repository
# Documentation: https://libguestfs.org/virt-builder-repository.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# virt-builder-repository: create/maintain a virt-builder template repository
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--gpg=[alternate gpg binary or gpg parameters]:gpg:' \
  '(-K --gpg-key)'{-K+,--gpg-key=}'[GPG key id for signing the index]:keyid:' \
  '(-i --interactive)'{-i,--interactive}'[prompt for missing data]' \
  '--no-compression[do not compress template images]' \
  '--machine-readable[produce machine-friendly output]:format:' \
  '--colors[use ANSI color sequences]' \
  '--colours[use ANSI color sequences]' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress messages]' \
  '(-v --verbose)'{-v,--verbose}'[verbose debug messages]' \
  '--wrap[wrap error/warning/info messages]' \
  '-x[enable libguestfs API trace]' \
  '*:repository dir:_files -/' && ret=0
return ret
