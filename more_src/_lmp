#compdef lmp lmp_mpi lmp_serial lmp_gpu
# Documentation: https://docs.lammps.org/Run_options.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# LAMMPS: classical molecular dynamics with full CLI overrides
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help and built-in style list]' \
  '-help[show help and built-in style list]' \
  '-in[input script]:file:_files' \
  '-log[log file (none disables logging)]:file:_files' \
  '-screen[screen file (none silences)]:file:_files' \
  '-nocite[suppress citation reminders]' \
  '-restart[convert restart to data file]:args:' \
  '-restart2data[convert restart to data file]:args:' \
  '-restart2dump[convert restart to dump file]:args:' \
  '-package[modify package settings]:args:' \
  '-suffix[append suffix to styles]:suffix:(intel kk gpu omp opt)' \
  '-pk[package keyword settings]:args:' \
  '-sf[style suffix shortcut]:suffix:(intel kk gpu omp opt)' \
  '-cite[print citation reminder]' \
  '-echo[echo mode]:mode:(none screen log both)' \
  '-pscreen[partition screen output]:args:' \
  '-plog[partition log output]:args:' \
  '-partition[run partition spec]:spec:' \
  '-skiprun[skip the run command]' \
  '-var[set substitution variable]:name value:' \
  '-reorder[reorder MPI ranks]:args:' \
  '-mpicolor[MPI colour for multiple LAMMPS instances]:n:' \
  '-kokkos[enable Kokkos backend args]:args:' \
  '*::input script and args:_files' && ret=0
return ret
