#compdef chiro2dual
# Documentation: https://manpages.debian.org/experimental/topcom/topcom.7.en.html
# TOPCOM: compute the dual chirotope of a chirotope

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print a usage message]' \
  '-I+[read input from filename instead of stdin]:file:_files' \
  '-d[debug mode]' \
  '-v[verbose]' \
  '*:file:_files' && ret=0

return ret
