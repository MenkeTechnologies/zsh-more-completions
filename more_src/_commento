#compdef commento
# _commento — Adhityaa Chandrasekar commento privacy-focused comment platform CLI alias (commento team, Go); custom argparse
# upstream: https://gitlab.com/commento/commento

_commento() {
    local -a sub=(
        'server:run the commento server'
        'import:import comments'
        'export:export comments'
        'rebuild:rebuild static assets'
        'cleanup:cleanup data'
        'migrate:run db migrations'
        'reset:reset database'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files' \
        '--postgres=+[postgres connection string]:str:' \
        '--port=+[port]:port:' \
        '--bind-address=+[bind addr]:host:_hosts' \
        '--origin=+[origin]:url:_urls' \
        '--cdn-prefix=+[cdn prefix]:url:_urls' \
        '--smtp-host=+[smtp host]:host:_hosts' \
        '--smtp-port=+[smtp port]:port:' \
        '--smtp-username=+[smtp user]:user:_users' \
        '--smtp-password=+[smtp pass]:str:' \
        '--smtp-from-address=+[smtp from]:str:' \
        '--gzip-static[gzip static files]' \
        '--forbid-new-owners[disable new owner registration]' \
        '--google-key=+[google client id]:str:' \
        '--google-secret=+[google client secret]:str:' \
        '--github-key=+[github client id]:str:' \
        '--github-secret=+[github client secret]:str:' \
        '--gitlab-key=+[gitlab client id]:str:' \
        '--gitlab-secret=+[gitlab client secret]:str:' \
        '--twitter-key=+[twitter client id]:str:' \
        '--twitter-secret=+[twitter client secret]:str:' \
        '--max-idle-pg-connections=+[max idle pg conns]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'commento subcommand' sub ;;
        args)
            case $words[1] in
                import) _arguments \
                    '--type=+[source type]:t:(disqus commento)' \
                    '--file=+[input file]:file:_files' ;;
                export) _arguments \
                    '--out=+[output file]:file:_files' ;;
            esac
            ;;
    esac
}

_commento "$@"
