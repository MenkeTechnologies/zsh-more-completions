#compdef create-adonisjs
# Documentation: https://github.com/adonisjs/create-adonisjs#readme
# Reference accessed: 2026-05-24
# Verified: npm view create-adonisjs bin; GitHub README Options section at the URL above.

# Zsh completion for create-adonisjs - AdonisJS starter kit scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--kit=[starter kit repo URL or built-in kit]:kit:(api web slim inertia)' \
  '--token=[auth token for private starter kit repos]:token:' \
  '--pkg=[package manager]:manager:(npm yarn pnpm bun)' \
  '--auth-guard=[auth guard for api kit]:guard:(session access_tokens)' \
  '--db=[database dialect for Lucid]:db:(sqlite mysql mssql postgres)' \
  '--git-init[initialize git repository]' \
  '--verbose[enable verbose logging]' \
  ':destination directory:_directories' && ret=0

return ret
