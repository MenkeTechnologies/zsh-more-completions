#compdef snakedeploy
# Documentation: https://snakemake.readthedocs.io/en/stable/snakefiles/deployment.html
# Deploy and manage Snakemake workflows and conda environments

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version and exit]' \
  '--quiet[minimize output]' \
  '--verbose[enable verbose output]' \
  '--log-disable-color[disable colored logging]' \
  '1:command:((
    deploy-workflow\:"deploy a workflow from a git repository"
    collect-files\:"gather files into tabular structure from STDIN using glob patterns"
    pin-conda-envs\:"lock conda environments to specific package URLs with checksums"
    update-conda-envs\:"update conda environment files to latest package versions"
    update-snakemake-wrappers\:"update snakemake wrapper versions in Snakefiles"
    scaffold-snakemake-plugin\:"generate plugin scaffolding with dependencies"
  ))' \
  '*::arg:_files' && ret=0

return ret
