#compdef xmenu
# Documentation: https://github.com/phillbush/xmenu/blob/master/xmenu.1
# xmenu: an X11 menu utility reading entries from stdin

local ret=1

_arguments -s -S \
  '-f[enable file system navigation for slash-prefixed output]' \
  '-w[ask the window manager to draw a border (torn off)]' \
  '-N[application name for resource lookup]:name:_default' \
  '-p[position to spawn the menu]:position:_default' \
  '-t[make menus transient for the given window]:window:_default' \
  '-x[show menu on a button press on the root window]:button:_default' && ret=0

return ret
