#compdef wordgrinder

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--lua=[run a Lua script]:file:_files -g "*.lua"' \
  '--convert=[convert file format]:conversion' \
  '--import=[import file]:file:_files' \
  '--export=[export file]:file:_files' \
  '--config=[config file]:file:_files' \
  '1:document file:_files -g "*.wg"' && ret=0

return ret
