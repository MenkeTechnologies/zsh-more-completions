#compdef sliver-client sliver-server
# Documentation: https://man.archlinux.org/search?q=sliver-client
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'generate:generate a new implant binary'
  'profiles:manage implant generation profiles'
  'implants:list/stop generated implants'
  'sessions:manage active implant sessions'
  'beacons:manage beacon implants'
  'use:select an implant session/beacon to interact with'
  'background:return to root menu from a session'
  'info:show information about an implant'
  'ping:ping a session'
  'kill:terminate an implant'
  'mtls:start an mTLS listener'
  'http:start an HTTP listener'
  'https:start an HTTPS listener'
  'dns:start a DNS listener'
  'wg:start a WireGuard listener'
  'stage-listener:start a stager listener'
  'jobs:list/kill background jobs'
  'players:manage operator accounts'
  'multiplayer:start multiplayer mode'
  'monitor:show monitoring information'
  'armory:download/install community armory packages'
  'aliases:list/install aliases'
  'extensions:list/install extensions'
  'reaction:configure event reactions'
  'env:print client environment'
  'set:set a client setting'
  'settings:show client settings'
  'update:update sliver-client'
  'version:show version'
  'licenses:show third-party licenses'
  'exit:exit the console'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[client config file]:file:_files -g "*.cfg"' \
  '--unpack[unpack assets and exit]' \
  '--force-unpack[force re-unpack assets]' \
  '--no-update[disable update check]' \
  '--insecure[skip TLS verification]' \
  '--debug[debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sliver command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (generate)
        _arguments \
          '--os=[target OS]:os:(linux darwin windows)' \
          '--arch=[target architecture]:arch:(amd64 386 arm arm64 mips mipsle mips64 mips64le ppc64 ppc64le riscv64 s390x wasm)' \
          '--format=[output format]:format:(exe shared service shellcode)' \
          '--name=[implant name]:name:' \
          '--save=[output path]:path:_files' \
          '--mtls=[mTLS C2 URL]:url:' \
          '--http=[HTTP/HTTPS C2 URL]:url:' \
          '--wg=[WireGuard C2 URL]:url:' \
          '--dns=[DNS C2 URL]:url:' \
          '--named-pipe=[Named Pipe C2 URL]:url:' \
          '--tcp-pivot=[TCP Pivot C2 URL]:url:' \
          '--evasion[apply evasion techniques]' \
          '--debug[enable implant debug logging]' \
          '--debug-file=[implant debug log file]:file:_files' \
          '--canary=[DNS canary domain]:domain:' \
          '--max-errors=[max C2 errors before exit]:n:' \
          '--reconnect=[reconnect interval (s)]:n:' \
          '--limit-username=[restrict to username]:user:' \
          '--limit-hostname=[restrict to hostname]:host:' \
          '--limit-datetime=[restrict to date/time]:datetime:' \
          '--limit-domainjoined[require domain join]' \
          '--skip-symbols[strip symbols]' \
          '--strategy=[connection strategy]:strategy:(s r rd)' && ret=0 ;;
      (http|https|mtls|dns|wg)
        _arguments \
          '--lhost=[listen host]:host:_hosts' \
          '--lport=[listen port]:port:' \
          '--domain=[domain to use]:domain:' \
          '--persistent[persist after restart]' \
          '--no-acl[disable C2 ACL]' && ret=0 ;;
      (implants|sessions|beacons|jobs|players)
        _arguments \
          '*::sub:(list rm)' && ret=0 ;;
    esac ;;
esac

return ret
