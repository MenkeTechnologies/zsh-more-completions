#compdef lxqt-runner
# Documentation: https://man.archlinux.org/search?q=lxqt-runner
# Reference accessed: 2026-05-16

# lxqt-runner: keyboard-driven command launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '--show[show the launcher]' \
  '--hide[hide the launcher]' \
  '--reload-history[clear & reload history]' \
  '*::lxqt-runner args:_files' && ret=0
return ret
