#compdef vendir

_vendir_cmds() {
    local -a commands=(
        'sync:sync directories'
        'fetch:fetch a single directory'
        'version:print version'
        'help:print help information'
    )
    _describe -t commands 'vendir command' commands
}

_vendir() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '--column=[output columns]:columns' \
        '--json[output as JSON]' \
        '--tty[force TTY-like output]' \
        '--yes[assume yes for prompts]' \
        '--debug[enable debug output]' \
        '--dangerous-allow-all-symlink-destinations[allow all symlink destinations]' \
        '1:command:_vendir_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                sync)
                    _arguments \
                        '(-f --file)'{-f,--file}'=[vendir config file]:file:_files' \
                        '(-d --directory)'{-d,--directory}'=[sync specific directory]:dir' \
                        '--lock-file=[lock file path]:file:_files' \
                        '--lazy[skip fetching if lock matches]' \
                        '--locked[use only lock file]'
                    ;;
                fetch)
                    _arguments \
                        '(-f --file)'{-f,--file}'=[vendir config file]:file:_files' \
                        '(-d --directory)'{-d,--directory}'=[directory to fetch]:dir' \
                        '--lock-file=[lock file path]:file:_files' \
                        '--lazy[skip fetching if lock matches]'
                    ;;
            esac
            ;;
    esac
}

_vendir "$@"
