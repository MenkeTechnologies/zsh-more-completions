#compdef vendir
# Documentation: https://carvel.dev/vendir/ (source: github.com/carvel-dev/vendir pkg/vendir/cmd/)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_vendir_cmds() {
    local -a commands=(
        'sync:sync directories from configured sources'
        'version:print version'
        'tools:tools commands'
        'help:print help information'
    )
    _describe -t commands 'vendir command' commands
}

_vendir() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '--column=[output columns]:columns:' \
        '--color=[color output]:b:(true false)' \
        '--json[output as JSON]' \
        '--tty[force TTY-like output]' \
        '(-y --yes)'{-y,--yes}'[assume yes for prompts]' \
        '--debug[enable debug output]' \
        '1:command:_vendir_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                sync)
                    _arguments \
                        '*'{-f,--file=}'[vendir config file]:file:_files' \
                        '*'{-d,--directory=}'[sync specific directory (dir/sub[=local])]:dir:' \
                        '--lock-file=[lock file path]:file:_files' \
                        '(-l --locked)'{-l,--locked}'[consult lock file for exact refs]' \
                        '--lazy=[skip fetching if lock matches]:b:(true false)' \
                        '--chdir=[set current directory for process]:dir:_files -/' \
                        '--dangerous-allow-all-symlink-destinations[allow all symlink destinations]'
                    ;;
                tools)
                    _values 'tools subcommand' 'sort-semver:sort semvers'
                    ;;
            esac
            ;;
    esac
}

_vendir "$@"
