#compdef bearer-cli
# _bearer-cli — Bearer code/data privacy scanner CLI alias (Bearer / SmartBear, Go); spf13/cobra
# upstream: https://github.com/Bearer/bearer

_bearer-cli() {
    local -a sub=(
        'init:scaffold bearer config'
        'scan:scan codebase'
        'init-rule:scaffold a rule'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config-file=+[config file]:file:_files -g "bearer.yml *.yaml *.yml"' \
        '--debug[debug]' \
        '--debug-profile[debug profile]' \
        '--log-level=+[log level]:level:(debug info warn error)' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '--api-base-url=+[api base url]:url:_urls' \
        '--api-key=+[api key]:str:' \
        '--client-id=+[client id]:str:' \
        '--client-name=+[client name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bearer subcommand' sub ;;
        args)
            case $words[1] in
                scan) _arguments \
                    '--scanner=+[scanners]:list:(sast secrets)' \
                    '--format=+[output format]:fmt:(json yaml sarif gitlab-sast html jsonv2 rdjson)' \
                    '-f+[output format]:fmt:(json yaml sarif gitlab-sast html jsonv2 rdjson)' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--report=+[report type]:r:(security privacy summary saas dataflow stats)' \
                    '--severity=+[severity]:list:(critical high medium low warning)' \
                    '--skip-path=+[skip path]:list:_files -/' \
                    '--only-rule=+[only rule]:list:' \
                    '--skip-rule=+[skip rule]:list:' \
                    '--external-rule-dir=+[external rule dir]:dir:_files -/' \
                    '--rule-disabled=+[rule disabled]:list:' \
                    '--rule-enabled=+[rule enabled]:list:' \
                    '--rule-language=+[rule language]:list:' \
                    '--exit-code=+[exit code]:n:' \
                    '--quiet[quiet]' \
                    '--force[force re-scan]' \
                    '--parallel=+[parallel workers]:n:' \
                    '--no-progress-bar[no progress bar]' \
                    '--no-shorten-output[no shorten output]' \
                    '--data-subject-mapping=+[data subject mapping]:file:_files' \
                    '--existing-finding-skip-line=+[existing finding skip line]:b:(true false)' \
                    '--data-category-skip-list=+[data category skip list]:list:' \
                    '--data-subject-skip-list=+[data subject skip list]:list:' \
                    '--internal-domains=+[internal domains]:list:' \
                    '--scope=+[scope]:s:(all changed)' \
                    '--base-branch=+[base branch]:str:' \
                    '*:path:_files' ;;
                init|init-rule) _arguments '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_bearer-cli "$@"
