#compdef rsem-plot-transcript-wiggles
# Documentation: https://deweylab.github.io/RSEM/rsem-plot-transcript-wiggles.html
# RSEM: generate wiggle plots for transcripts or genes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--gene-list[input-list is a list of gene ids]' \
  '--transcript-list[input-list is a list of transcript ids]' \
  '--show-unique[show wiggle plots as stacked bar plots]' \
  '(-p --num-threads)'{-p,--num-threads}'=[number of threads]:int' \
  '--memory-per-thread=[max memory per thread (K/M/G)]:mem' \
  '*:sample name, input-list or output plot file:_files' && ret=0

return ret
