#compdef cordova
# _cordova-cli — Apache Cordova mobile hybrid framework CLI; build native iOS/Android/Windows wrappers around a webview app
# upstream: https://github.com/apache/cordova-cli

_cordova-cli() {
    local -a sub=(
        'create:create new project'
        'help:show help'
        'telemetry:telemetry opt-in/out'
        'requirements:print platform requirements'
        'info:print env info'
        'plugin:plugin commands'
        'platform:platform commands'
        'platforms:alias for platform'
        'prepare:prepare web assets'
        'compile:compile native binaries'
        'build:prepare + compile'
        'emulate:run on emulator'
        'run:run on device'
        'serve:serve www over browser-platform'
        'clean:clean build artifacts'
        'check:check installed platforms'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --verbose)'{-d,--verbose}'[verbose log]' \
        '--silent[silent]' \
        '--no-update-notifier[skip update notifier]' \
        '--nohooks+[skip hooks]:hooks:' \
        '--save[save changes]' \
        '--no-save[do not save]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cordova subcommand' sub ;;
        args)
            case $words[1] in
                platform|platforms) _arguments \
                    '1:platform cmd:(add remove rm ls list update save check)' \
                    '*:platform:(android ios browser electron windows osx)' ;;
                plugin) _arguments \
                    '1:plugin cmd:(add remove rm ls list save search)' \
                    '*:plugin:' ;;
                build|prepare|compile|emulate|run|clean) _arguments \
                    '--debug[debug build]' \
                    '--release[release build]' \
                    '--device[device build]' \
                    '--emulator[emulator build]' \
                    '--target+[device or emulator id]:target:' \
                    '--list[list targets]' \
                    '--buildConfig+[build config]:file:_files' \
                    '--archs+[architectures]:archs:' \
                    '*:platform:(android ios browser electron windows osx)' ;;
                create) _arguments \
                    '--copy-from+[copy from path]:path:' \
                    '--link-to+[link to path]:path:' \
                    '--template+[template]:template:' \
                    '1:dir:_files -/' \
                    '2:id:' \
                    '3:name:' ;;
            esac
            ;;
    esac
}

_cordova-cli "$@"
