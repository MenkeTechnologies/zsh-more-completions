#compdef cgoban
# Documentation: https://cgoban1.sourceforge.net/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '-fontHeight+[font / drawing size]:size:' \
  '-display+[X display]:display:' \
  '-nocolor[default black and white mode]' \
  '*:file:_files -g "*.sgf"' && ret=0

return ret
