#compdef tomopitch
# Documentation: https://bio3d.colorado.edu/imod/doc/man/tomopitch.html
# Determine tomogram shift and angles from models of section boundaries

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-model -m -ModelFile)'{-model,-m,-ModelFile}'[Model file with lines to analyze. If there are multiple...]:file:_files' \
  '(-extra -e -ExtraThickness)'{-extra,-e,-ExtraThickness}'[Additional pixels of thickness to add to both the top and...]:value' \
  '(-spacing -sp -SpacingInY)'{-spacing,-sp,-SpacingInY}'[Spacing between tomogram samples (distance in Y in tilted]:value' \
  '(-scale -sc -ScaleFactor)'{-scale,-sc,-ScaleFactor}'[Amount by which to scale the Z shift and thickness...]:value' \
  '(-angle -a -AngleOffsetOld)'{-angle,-a,-AngleOffsetOld}'[Angle offset in the alignment used to make the samples. If...]:value' \
  '(-zshift -z -ZShiftOld)'{-zshift,-z,-ZShiftOld}'[Z shift value in the alignment used to make the samples, in]:value' \
  '(-xtilt -x -XAxisTiltOld)'{-xtilt,-x,-XAxisTiltOld}'[X axis tilt applied when the samples were made. If this...]:value' \
  '(-noxtilt -n -NoXAxisTilt)'{-noxtilt,-n,-NoXAxisTilt}'[Do not solve for X axis tilt or changes in other values...]' \
  '(-param -p -ParameterFile)'{-param,-p,-ParameterFile}'[Parameter file]' \
  '-StandardInput[read parameters from standard input]' \
  '-usage[print usage]' \
  '*:file:_files' && ret=0

return ret
