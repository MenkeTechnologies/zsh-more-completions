#compdef impacket-rpcclient rpcclient.py rpcdump.py
# _impacket-rpcclient — Fortra SecureAuth Impacket impacket-rpcclient CLI python MSRPC client supporting connection to remote MS-RPC endpoints SAMR LSARPC MS-WMI MS-RPC-EPM SCMR enumeration of users groups domains shares aliases via NTLM Kerberos pass-the-hash pass-the-ticket for AD pentest enumeration (Fortra team, Python); argparse
# upstream: https://github.com/fortra/impacket

_impacket-rpcclient() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-debug[debug]' \
        '-target-ip+[ip]:_hosts' \
        '-port+[port]:n:(135 445)' \
        '-domain+[domain]:str:' \
        '-user+[user]:str:' \
        '-password+[password]:str:' \
        '-hashes+[lmhash:nthash]:str:' \
        '-no-pass[no password]' \
        '-k[use kerberos]' \
        '-aesKey+[key]:str:' \
        '-dc-ip+[dc ip]:_hosts' \
        '-ts[show timestamps]' \
        '-ifs[only list available interfaces]' \
        '-protocol+[p]:p:(ncacn_ip_tcp ncacn_np ncacn_http)' \
        '*:target user/domain:'
}

_impacket-rpcclient "$@"
