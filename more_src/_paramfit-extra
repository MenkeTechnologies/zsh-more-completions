#compdef paramfit-extra
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools paramfit: derive force field parameters by fitting to QM data

local ret=1

_arguments -s -S \
  '-i[job control input file]:file:_files' \
  '-p[molecular topology file (prmtop)]:file:_files' \
  '-c[coordinate file with many conformations]:file:_files' \
  '-q[file with quantum energies]:file:_files' \
  '-pf[list of topology files for multi-molecule fit]:file:_files' \
  '-cf[list of coordinate files for multi-molecule fit]:file:_files' \
  '-v[verbosity level]:level:(OFF MEDIUM HIGH)' \
  '--random-seed[random number generator seed]:seed:' \
  '*:file:_files' && ret=0

return ret
