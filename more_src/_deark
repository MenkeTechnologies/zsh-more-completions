#compdef deark
# Documentation: https://man.archlinux.org/search?q=deark
# Reference accessed: 2026-05-16

# Zsh completion for Deark file decoder / converter

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-d+[output directory]:dir:_directories' \
  '-id[identify files only]' \
  '-q[quiet]' \
  '-v[verbose diagnostics]' \
  '*:input:_files' && ret=0

return ret
