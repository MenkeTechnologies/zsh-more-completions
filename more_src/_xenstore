#compdef xenstore

# xenstore: command-line wrapper for xenstore-ls/xenstore-read/xenstore-write/etc.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'ls:list entries'
  'read:read value'
  'write:write value'
  'rm:remove entry'
  'exists:check if entry exists'
  'list:list entries'
  'chmod:change permissions'
  'watch:watch a path'
  'control:control xenstore daemon'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'xenstore command' commands && ret=0 ;;
esac
return ret
