#compdef daff

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'diff:compute the difference between two tables'
  'patch:apply a diff to a table'
  'merge:merge tables using three-way merge'
  'render:render a diff as HTML'
  'trim:trim unchanged rows from a diff'
  'copy:copy a table'
  'git:use as a git diff driver'
  'version:show version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--output[output file]:file:_files' \
  '--context[number of context rows]:rows:' \
  '--all[do not prune unchanged rows]' \
  '--act[act on column]:column:' \
  '--color[enable color output]' \
  '--no-color[disable color output]' \
  '--ordered[treat tables as ordered]' \
  '--unordered[treat tables as unordered]' \
  '--id[specify ID column]:column:' \
  '--ignore[ignore a column]:column:' \
  '--padding[add padding around differences]:padding:' \
  '--header[table has header row]' \
  '--no-header[table has no header row]' \
  '--separator[field separator]:separator:' \
  '1:command:->command' \
  '*:file:_files' && ret=0

case $state in
  (command)
    _describe -t commands 'daff command' commands && ret=0
    ;;
esac

return ret
