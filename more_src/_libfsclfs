#compdef fsclfsinfo
# _libfsclfs — libfsclfs tools (libyal Windows Common Log File System parser; fsclfsinfo prints CLFS container + log header + stream metadata so analysts can correlate operating-system-level transactional log activity; -h help, -V version, -v verbose, -o image offset, -X exclusive; positional argument is the .blf container file)
# upstream: https://github.com/libyal/libfsclfs
# Flags from libyal/libfsclfs fsclfstools/fsclfsinfo.c on tip.

_libfsclfs() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-X[exclusive]' \
        '*:CLFS file:_files -g "*.blf"'
}

_libfsclfs "$@"
