#compdef eg

# eg example viewer completion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--list[list all available topics]' \
  '--config-file=[path to config file]:config file:_files' \
  '--examples-dir=[path to examples directory]:directory:_directories' \
  '--custom-dir=[path to custom examples directory]:directory:_directories' \
  '--color[enable color output]' \
  '--pager-cmd=[pager command to use]:pager command' \
  '--squeeze[squeeze consecutive blank lines]' \
  '1:command name:' \
  && ret=0

return ret
