#compdef minisat

# Zsh completion for minisat - SAT solver

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-no-luby)-luby[use Luby restart strategy]' \
  '(-luby)-no-luby[do not use Luby restart strategy]' \
  '(-no-rnd-init)-rnd-init[randomize initial variable activity]' \
  '(-rnd-init)-no-rnd-init[do not randomize initial variable activity]' \
  '-gc-frac=[garbage collection fraction]:fraction' \
  '-rinc=[restart increment]:increment' \
  '-var-decay=[variable activity decay factor]:decay (0-1)' \
  '-cla-decay=[clause activity decay factor]:decay (0-1)' \
  '-rnd-freq=[frequency of random decisions]:frequency (0-1)' \
  '-rnd-seed=[random seed]:seed' \
  '-ccmin-mode=[conflict clause minimization mode]:mode:(0 1 2)' \
  '-phase-saving=[phase saving level]:level:(0 1 2)' \
  '-rnd-pol[random initial polarity]' \
  '(-no-pre)-pre[enable preprocessing]' \
  '(-pre)-no-pre[disable preprocessing]' \
  '-verb=[verbosity level]:level:(0 1 2)' \
  '-cpu-lim=[CPU time limit in seconds]:seconds' \
  '-mem-lim=[memory limit in MB]:megabytes' \
  '-dimacs=[write CNF to DIMACS file]:output file:_files' \
  '1:input CNF file:_files -g "*(#i).(cnf|dimacs)"' \
  '2:proof output file:_files' \
  && ret=0

return ret
