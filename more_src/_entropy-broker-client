#compdef entropy-broker-client
# Documentation: https://man.archlinux.org/search?q=entropy-broker-client
# Reference accessed: 2026-05-16

# entropy-broker-client: client to fetch entropy from broker
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-i[broker host]:host:_hosts' \
  '-o[output file]:file:_files' \
  '-p[port]:port:' \
  '-n[no fork]' \
  '-l[log file]:file:_files' \
  '-v[verbose]' \
  '*::entropy-broker-client args:_files' && ret=0
return ret
