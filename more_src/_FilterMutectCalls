#compdef FilterMutectCalls
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/mutect/filtering/FilterMutectCalls.java
# GATK4: filter somatic SNVs and indels called by Mutect2

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --variant)'{-V,--variant}'[input Mutect2 VCF file]:file:_files -g "*.(vcf|vcf.gz)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-O --output)'{-O,--output}'[output filtered VCF file]:file:_files' \
  '--mutect-stats[Mutect stats file output by Mutect2]:file:_files' \
  '--filtering-stats[output filtering stats file]:file:_files' \
  '*--contamination-table[table containing contamination information]:file:_files' \
  '--contamination-estimate[estimate of contamination]:val:' \
  '*--tumor-segmentation[table of tumor minor allele fractions for germline hets]:file:_files' \
  '*'{-ob-priors,--orientation-bias-artifact-priors}'[.tar.gz of read-orientation artifact priors]:file:_files -g "*.tar.gz"' \
  '--threshold-strategy[method for optimizing the posterior probability threshold]:strategy:(CONSTANT OPTIMAL_F_SCORE FALSE_DISCOVERY_RATE)' \
  '--f-score-beta[relative weight of recall to precision]:val:' \
  '--false-discovery-rate[maximum false discovery rate allowed]:val:' \
  '--min-allele-fraction[minimum allele fraction required]:val:' \
  '*:options:_files' && ret=0

return ret
