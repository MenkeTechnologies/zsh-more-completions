#compdef snort2
# Documentation: https://man.archlinux.org/search?q=snort2
# Reference accessed: 2026-05-16

# Snort 2: legacy IDS engine
local curcontext="$curcontext" ret=1
_arguments -C \
  '-A[alert mode]:mode:(fast full none unsock console cmg)' \
  '-b[log packets in tcpdump format]' \
  '-c[rules file]:file:_files -g "*.(conf|rules)"' \
  '-D[run as daemon]' \
  '-d[dump app layer]' \
  '-e[show 2nd layer headers]' \
  '-F[BPF filter from file]:file:_files' \
  '-G[generator ID]:n:' \
  '-h[home network]:cidr:' \
  '-i[interface]:iface:' \
  '-k[checksum mode]:mode:(all noip notcp noudp noicmp none)' \
  '-K[log format]:fmt:(pcap ascii none)' \
  '-l[log dir]:dir:_files -/' \
  '-L[log file name (alert log)]:name:' \
  '-N[turn off logging]' \
  '-o[order]' \
  '-p[disable promiscuous mode]' \
  '-P[snaplen]:n:' \
  '-q[quiet mode]' \
  '-r[read pcap]:file:_files -g "*.(pcap|cap|pcapng)"' \
  '-S[set variable]:var=value:' \
  '-t[chroot dir]:dir:_files -/' \
  '-T[test config and exit]' \
  '-u[run as user]:user:_users' \
  '-g[run as group]:group:_groups' \
  '-v[verbose]' \
  '-V[show version]' \
  '-w[show wireless packets]' \
  '-X[dump raw packet data]' \
  '-y[show year in output]' \
  '-Z[stop snort if rule reload fails]' \
  '*::snort2 args:_files' && ret=0
return ret
