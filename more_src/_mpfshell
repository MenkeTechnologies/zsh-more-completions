#compdef mpfshell
# Documentation: https://man.archlinux.org/search?q=mpfshell
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --command)'{-c,--command}'+[execute command(s)]:cmds:' \
  '(-s --script)'{-s,--script}'+[run script file]:file:_files' \
  '(-n --nocolor)'{-n,--nocolor}'[do not use colour output]' \
  '(--nocache)--nocache[disable autocomplete cache]' \
  '(--logfile)--logfile=+[log file]:file:_files' \
  '(--loglevel)--loglevel=+[log level]:level:(DEBUG INFO WARN ERROR CRITICAL)' \
  '(--reset)--reset[reset board on connect]' \
  '(-o --open)'{-o,--open}'+[open device on startup]:device:' \
  '*:device:' && ret=0

return ret
