#compdef openvsp-connect
# Documentation: https://man.archlinux.org/search?q=openvsp-connect
# Reference accessed: 2026-05-16

# openvsp-connect: connect to a running OpenVSP API server
local curcontext="$curcontext" ret=1
_arguments -C \
  '-port[OpenVSP API port]:port:' \
  '-host[host running OpenVSP]:host:' \
  '-help[show help]' \
  '*:script file:_files' && ret=0
return ret
