#compdef mullvad-daemon
# _mullvad-daemon — Mullvad VPN background daemon (mullvad/mullvadvpn-app)
# upstream: https://github.com/mullvad/mullvadvpn-app
# Flags from mullvad-daemon/src/cli.rs (clap).

_mullvad-daemon() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '*-v[increase log verbosity (repeat)]' \
        '--disable-log-to-file[do not log to file]' \
        '--disable-stdout-timestamps[do not log timestamps to stdout]' \
        '--initialize-early-boot-firewall[init early-boot firewall and exit (Linux)]' \
        '--launch-daemon-status[check launch daemon status and exit (macOS)]' \
        '--run-as-service[run as Windows system service]' \
        '--register-service[register Mullvad as Windows service]'
}

_mullvad-daemon "$@"
