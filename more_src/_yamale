#compdef yamale
# Documentation: https://github.com/23andMe/Yamale
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-s --schema)'{-s+,--schema=}'[schema filename (default: schema.yaml)]:file:_files -g "*.(yaml|yml)"' \
  '*'{-e+,--exclude=}'[Python regex to exclude files]:regex:' \
  '(-p --parser)'{-p+,--parser=}'[YAML library to use]:parser:(ruamel pyyaml)' \
  '(-n --cpu-num)'{-n+,--cpu-num=}'[number of child processes (default: 4 or auto)]:n:' \
  '(-x --no-strict)'{-x,--no-strict}'[disable strict mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:path:_files' && ret=0

return ret
