#compdef kaspad
# Documentation: https://man.archlinux.org/search?q=kaspad
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-V --version)'{-V,--version}'[Print version and exit]' \
  '(-C --configfile)'{-C,--configfile}'=[Configuration file path]:file:_files' \
  '(-b --appdir)'{-b,--appdir}'=[Data directory]:directory:_directories' \
  '--logdir=[Log directory]:directory:_directories' \
  '(-a --addpeer)'{-a,--addpeer}'=[Add peer host:port at startup]:peer' \
  '--connect=[Connect only to these peers]:peer' \
  '--nolisten[Disable inbound peer listening]' \
  '*--listen=[P2P listen address host:port]:addr' \
  '--outpeers=[Target outbound peer count]' \
  '--maxinpeers=[Max inbound peers]' \
  '--enablebanning[Enable peer banning]' \
  '--banduration=[Ban duration with time suffix]:duration' \
  '--banthreshold=[Ban score threshold before banning]' \
  '*--whitelist=[Never-ban IP or CIDR]:cidr' \
  '*--rpclisten=[JSON-RPC listen address]:addr' \
  '--rpccert=[RPC TLS certificate file]:file:_files' \
  '--rpckey=[RPC TLS key file]:file:_files' \
  '--rpcmaxclients=[Max standard RPC clients]' \
  '--rpcmaxwebsockets=[Max websocket RPC clients]' \
  '--rpcmaxconcurrentreqs=[Max concurrent RPC requests]' \
  '--norpc[Disable JSON-RPC server]' \
  '--saferpc[Disable state-changing RPC methods]' \
  '--nodnsseed[Disable DNS peer seeding]' \
  '--dnsseed=[Override DNS seed hostname]' \
  '--grpcseed=[gRPC peer seed hostname]' \
  '*--externalip=[Advertised external IP or host]:host' \
  '--proxy=[SOCKS5 proxy host:port]' \
  '--proxyuser=[Proxy username]' \
  '--proxypass=[Proxy password]' \
  '--dbtype=[Database backend name]:db' \
  '--profile=[Enable HTTP pprof on this port]:port' \
  '(-d --loglevel)'{-d,--loglevel}'=[Global or per-subsystem log level]:level' \
  '--upnp[Use UPnP to expose listen port]' \
  '--minrelaytxfee=[Minimum relay fee in KAS/kB]' \
  '--maxorphantx=[Max orphan transactions held in memory]' \
  '--blockmaxmass=[Max candidate block mass]' \
  '*--uacomment=[User agent comment]' \
  '--nopeerbloomfilters[Disable peer bloom filters]' \
  '--sigcachemaxsize=[Signature cache entry cap]' \
  '--blocksonly[Do not accept mempool transactions from peers]' \
  '--relaynonstd[Relay non-standard transactions]' \
  '--rejectnonstd[Reject non-standard transactions]' \
  '--reset-db[Delete blockchain data before startup]' \
  '--maxutxocachesize=[Max UTXO RAM cache size in bytes]' \
  '--utxoindex[Enable UTXO index]' \
  '--archival[Retain all historical blocks]' \
  '--allow-submit-block-when-not-synced[Accept blocks via RPC while syncing (testing)]' \
  '--enable-sanity-check-pruning-utxo[Verify UTXO set when advancing pruning point]' \
  '--protocol-version=[Override P2P protocol version]' \
  '--testnet[Use Kaspa test network]' \
  '--simnet[Use Kaspa simulation network]' \
  '--devnet[Use Kaspa dev network]' \
  '--override-dag-params-file=[JSON DAG params override (devnet only)]:file:_files' \
  '(-s --service)'{-s,--service}'=[Windows service command]:cmd:(install remove start stop)'
