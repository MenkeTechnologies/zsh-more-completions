#compdef svtplay-dl
# Documentation: https://man.archlinux.org/search?q=svtplay-dl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--debug[debug output including HTTP requests]' \
  '(-S --subtitle)'{-S,--subtitle}'[download subtitles]' \
  '(-s --silent)'{-s,--silent}'[less verbose]' \
  '(-q --quality)'{-q+,--quality=}'[quality (kbps)]:q:' \
  '--list-quality[list available qualities]' \
  '--flexible-quality=[allow quality to differ by N]:n:' \
  '(-o --output)'{-o+,--output=}'[output filename]:file:_files' \
  '(-f --force)'{-f,--force}'[force overwrite]' \
  '-r[resume download]' \
  '--resume[resume download]' \
  '--get-url[print URL and exit]' \
  '--get-only-episode-url[print only episode URLs]' \
  '--service=[force service]:service:(svtplay tv4play dr aftonbladet expressen oppetarkiv ruv urplay nrk pluto raw)' \
  '--all-episodes[download all episodes from series]' \
  '--all-last=[download N latest episodes]:n:' \
  '--include-clips[include clips with series download]' \
  '-A+[download last N episodes]:n:' \
  '--remux[remux to mp4]' \
  '--silent-semi[quieter still]' \
  '--cookies=[cookies file]:file:_files' \
  '-u+[username]:user:' \
  '-p+[password]:password:' \
  '--exclude=[exclude pattern]:pattern:' \
  '--filter-episodes=[only download matching pattern]:pattern:' \
  '--require-subtitle[only download if subtitles available]' \
  '--cipher-list=[OpenSSL cipher list]:ciphers:' \
  '--http-prefix=[HTTP prefix]:prefix:' \
  '--hls-time-stamp[use HLS timestamps]' \
  '--token=[API token]:token:' \
  '--captions[download closed captions]' \
  '--show-availability[show availability]' \
  '*::url:' && ret=0

return ret
