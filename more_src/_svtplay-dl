#compdef svtplay-dl
# Documentation: https://github.com/spaam/svtplay-dl (lib/svtplay_dl/utils/parser.py)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-S --subtitle)'{-S,--subtitle}'[download subtitles]' \
  '(-M --merge-subtitle)'{-M,--merge-subtitle}'[merge subtitles with media]' \
  '--force-subtitle[subtitle only]' \
  '--require-subtitle[only download if subtitles available]' \
  '--all-subtitles[download all available subtitles]' \
  '--raw-subtitles[download native format subtitles]' \
  '--convert-subtitle-colors[convert colors to font tags]' \
  '(-s --silent)'{-s,--silent}'[less verbose]' \
  '--silent-semi[quieter still]' \
  '(-q --quality)'{-q+,--quality=}'[quality (bitrate/resolution)]:q' \
  '(-Q --flexible-quality)'{-Q+,--flexible-quality=}'[allow quality variance]:n' \
  '--list-quality[list available qualities]' \
  '(-P --preferred)'{-P+,--preferred=}'[download method]:method:(dash hls http)' \
  '--stream-priority=[stream preference]:list' \
  '--format-preferred=[format preference]:format' \
  '--audio-language=[audio language]:lang' \
  '--video-role=[video role]:role' \
  '--resolution=[video resolution]:resolution' \
  '(-o --output)'{-o+,--output=}'[output filename/folder]:file:_files' \
  '--filename=[filename format]:format' \
  '--subfolder[create subfolder by show name]' \
  '--config=[config file]:file:_files' \
  '(-f --force)'{-f,--force}'[force overwrite]' \
  '(-l --live)'{-l,--live}'[enable for live streams]' \
  '(-c --capture_time)'{-c+,--capture_time=}'[capture time in minutes]:min' \
  '(-u --username)'{-u+,--username=}'[username]:user' \
  '(-p --password)'{-p+,--password=}'[password]:password' \
  '--token=[token]:token' \
  '(-t --thumbnail)'{-t,--thumbnail}'[download thumbnail]' \
  '(-g --get-url)'{-g,--get-url}'[print URL without downloading]' \
  '--get-only-episode-url[print only episode URLs]' \
  '--dont-verify-ssl-cert[skip SSL verification]' \
  '*--http-header=[add HTTP header]:header' \
  '--cookies=[cookies file]:file:_files' \
  '--exclude=[exclude videos by keywords]:pattern' \
  '--after-date=[filter by publication date yyyy-MM-dd]:date' \
  '--proxy=[HTTP/HTTPS/SOCKS proxy]:proxy' \
  '--nfo[create NFO file]' \
  '--force-nfo[download NFO only]' \
  '--only-audio[audio only]' \
  '--only-video[video only]' \
  '--socket-timeout=[connection timeout in seconds]:seconds' \
  '--max-retries=[failed download retry attempts]:n' \
  '(-A --all-episodes)'{-A,--all-episodes}'[download all episodes]' \
  '--all-last=[download N latest episodes]:n' \
  '--include-clips[include clips with series]' \
  '(-R --reverse)'{-R,--reverse}'[reverse download order]' \
  '--no-remux[skip MP4 remuxing]' \
  '--no-merge[skip merging video/audio/subtitles]' \
  '--no-postprocess[skip all post-processing]' \
  '--keep-original[retain original files after processing]' \
  '--output-format=[output format]:fmt:(mp4 mkv)' \
  '--chapters[extract and add chapters]' \
  '*::url:' && ret=0

return ret
