#compdef clairctl

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(report export manifest help version)' \
  '*::args:->args' && ret=0

case $state in
  (args)
    _arguments '*:arguments: _default' && ret=0
    ;;
esac

return ret
