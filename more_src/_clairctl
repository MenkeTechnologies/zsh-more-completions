#compdef clairctl
# Documentation: https://github.com/quay/clair/tree/main/cmd/clairctl
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-D --debug)'{-D,--debug}'[enable debug logging]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:(admin report manifest import export delete config help)' \
  '*::args:->args' && ret=0

case $state in
  (args)
    case $line[1] in
      report)
        _arguments \
          '--host=[Clair service network address]:host' \
          '--config=[config file path]:file:_files' \
          '*:image tag' && ret=0
        ;;
      manifest)
        _arguments '*:image tag' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
