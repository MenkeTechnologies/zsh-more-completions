#compdef zzuf

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-A --autoinc)'{-A,--autoinc}'[auto-increment seed]' \
  '(-a --allow)'{-a+,--allow=}'[allow file regex]:regex:' \
  '(-B --max-bytes)'{-B+,--max-bytes=}'[max bytes]:n:' \
  '(-b --bytes)'{-b+,--bytes=}'[byte ranges]:r:' \
  '(-C --max-crashes)'{-C+,--max-crashes=}'[max crashes]:n:' \
  '(-c --cmdline)'{-c,--cmdline}'[fuzz only command line]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-D --max-disk)'{-D+,--max-disk=}'[max disk]:n:' \
  '(-E --exclude)'{-E+,--exclude=}'[exclude regex]:regex:' \
  '(-F --max-forks)'{-F+,--max-forks=}'[max forks]:n:' \
  '(-f --fuzzing)'{-f+,--fuzzing=}'[fuzz mode]:mode:(xor set unset)' \
  '(-i --stdin)'{-i,--stdin}'[fuzz stdin]' \
  '(-I --include)'{-I+,--include=}'[include regex]:regex:' \
  '(-j --jobs)'{-j+,--jobs=}'[jobs]:n:' \
  '(-l --list)'{-l+,--list=}'[fd list]:list:' \
  '(-M --max-memory)'{-M+,--max-memory=}'[max memory]:n:' \
  '(-m --md5)'{-m,--md5}'[print MD5]' \
  '(-n --network)'{-n,--network}'[fuzz network input]' \
  '(-O --opmode)'{-O+,--opmode=}'[op mode]:m:(preload copy)' \
  '(-o --output)'{-o+,--output=}'[output dir]:dir:_files -/' \
  '(-P --protect)'{-P+,--protect=}'[protect string]:s:' \
  '(-p --ports)'{-p+,--ports=}'[port list]:list:' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-r --ratio)'{-r+,--ratio=}'[fuzz ratio]:r:' \
  '(-R --refuse)'{-R+,--refuse=}'[refuse string]:s:' \
  '(-s --seed)'{-s+,--seed=}'[seed]:n:' \
  '(-S --signal)'{-S,--signal}'[forward signals]' \
  '(-t --max-time)'{-t+,--max-time=}'[max time s]:s:' \
  '(-T --max-total-time)'{-T+,--max-total-time=}'[max total time]:s:' \
  '(-U --max-usertime)'{-U+,--max-usertime=}'[max user time]:s:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-x --check-exit)'{-x,--check-exit}'[check exit]' \
  '*: :_command_names -e' && ret=0

return ret
