#compdef mflgr
# Documentation: https://water.usgs.gov/ogw/modflow-lgr/MODFLOW-LGR-Guide/lgr_control_file.htm
# MODFLOW-LGR local grid refinement; reads an LGR control file or name file argument

local ret=1

_arguments -s \
  '1:LGR control or name file:_files -g "*.(lgr|nam)"' && ret=0

return ret
