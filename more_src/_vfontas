#compdef vfontas
# Documentation: https://manpages.debian.org/testing/hxtools/vfontas.1.en.html
# Bitmap font file transformation utility (read/write/transform glyphs)

local ret=1

_arguments -s -S \
  '-blankfnt[initialize buffer with 256 empty 8x16 glyphs]' \
  '-canvas[enlarge the glyph box to the given size]:xsize: :ysize' \
  '-clearmap[discard the in-memory glyph index to Unicode map]' \
  '-crop[remove an outer area from the glyph images]:xpos: :ypos: :width: :height' \
  '-fliph[mirror glyphs horizontally]' \
  '-flipv[flip glyphs vertically]' \
  '-invert[invert glyph pixels]' \
  '-lge[apply Line Graphics Enable transformation]' \
  '-lgeu[apply LGE on the cp437 graphic glyphs]' \
  '-lgeuf[apply LGE on all glyphs U+2500 thru U+25FF]' \
  '-loadbdf[read a BDF font file]:bdf file:_files -g "*.bdf"' \
  '-loadclt[read a directory of CLT glyph files]:dir:_files -/' \
  '-loadfnt[read a headerless bitmap font file]:fnt file:_files -g "*.fnt"' \
  '-loadhex[read a Unifont .hex file]:hex file:_files -g "*.hex"' \
  '-loadmap[read a glyphindex to Unicode mapping table]:map file:_files' \
  '-loadpsf[read a PC Screen Font PSF2 v0]:psf file:_files' \
  '-move[shift all glyphs by x/y offsets]:shiftx: :shifty' \
  '-savebdf[save the font to a BDF file]:bdf file:_files' \
  '-saveclt[save glyphs as multiple CLT files]:dir:_files -/' \
  '-savefnt[save glyphs in headerless format]:fnt file:_files' \
  '-saven1[vectorize with N1 algorithm to sfd]:sfd file:_files' \
  '-saven2[vectorize with N2 algorithm to sfd]:sfd file:_files' \
  '-savepbm[save glyphs as PBM files]:dir:_files -/' \
  '-savepsf[save glyphs as PC Screen Font PSF2.0]:psf file:_files' \
  '-savesfd[save the font to a Spline Font Database file]:sfd file:_files' \
  '-setbold[declare the font as being bold]' \
  '-setname[set a name for the font]:name' \
  '-setprop[set a property for SFD fonts]:key: :value' \
  '-upscale[linear upscale by an integral factor]:xscale: :yscale' \
  '-xcpi[extract a multi-font .cpi file as separate .fnt files]:cpi file:_files -g "*.cpi": :dir:_files -/' \
  '-xlat[move glyphs within their canvases]:xoffset: :yoffset' \
  '*::command:_default' && ret=0

return ret
