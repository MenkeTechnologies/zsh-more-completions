#compdef nix-alien

# Zsh completion for nix-alien - run unpatched binaries on NixOS

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-r --recreate)'{-r,--recreate}'[recreate FHS environment]' \
  '(-d --destination)'{-d,--destination}'[destination path]:path:_directories' \
  '--print-args[print arguments]' \
  '--silent[silent mode]' \
  '--flake[use flake]' \
  '(--)--[pass remaining args to the binary]' \
  '1:binary:_files -g "*(*)"' \
  '*:arguments:'
