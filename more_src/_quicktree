#compdef quicktree
# QuickTree: rapid neighbor-joining/UPGMA tree construction

local ret=1

_arguments -s -S \
  '-v[show version information]' \
  '-in[input file format (m=PHYLIP matrix, a=Stockholm alignment)]:format:(m a)' \
  '-out[output format (m=PHYLIP matrix, t=New Hampshire tree)]:format:(m t)' \
  '-upgma[use the UPGMA method for tree construction]' \
  '-kimura[use Kimura translation for pairwise distances]' \
  '-boot[generate bootstrap values using n iterations]:iterations:' \
  '*:input file:_files' && ret=0

return ret
