#compdef gtk-builder-tool
# Documentation: gtk-builder-tool (GTK)
# Source: validate / simplify / enumerate / preview GtkBuilder .ui files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'validate:validate the file'
    'simplify:simplify the file'
    'enumerate:list all named objects'
    'preview:preview the file'
)

_arguments -C -s \
    '(- *)--help[show help]' \
    '--replace[replace the file (simplify)]' \
    '--id=[preview only the named object]:id:' \
    '--css=[use style from CSS file]:file:_files -g "*.css"' \
    '1:command:->verbs' \
    '*:ui file:_files -g "*.ui"' \
    && ret=0

case $state in
    verbs) _describe -t verbs command verbs && ret=0 ;;
esac

return ret
