autoload -U is-at-least

_verg() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--path=[]:PATH:_files' \
'--parallel=[]:PARALLEL:_default' \
'--ssh-config=[Path to SSH config file]:SSH_CONFIG:_files' \
'--agent-dir=[Directory containing verg-agent binaries per architecture]:AGENT_DIR:_files' \
'--json[]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_verg_commands" \
"*::: :->verg" \
&& ret=0
    case $state in
    (verg)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:verg-command-$line[1]:"
        case $line[1] in
            (apply)
_arguments "${_arguments_options[@]}" : \
'-t+[]:TARGETS:_default' \
'--targets=[]:TARGETS:_default' \
'--path=[]:PATH:_files' \
'--parallel=[]:PARALLEL:_default' \
'--ssh-config=[Path to SSH config file]:SSH_CONFIG:_files' \
'--agent-dir=[Directory containing verg-agent binaries per architecture]:AGENT_DIR:_files' \
'--json[]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(diff)
_arguments "${_arguments_options[@]}" : \
'-t+[]:TARGETS:_default' \
'--targets=[]:TARGETS:_default' \
'--path=[]:PATH:_files' \
'--parallel=[]:PARALLEL:_default' \
'--ssh-config=[Path to SSH config file]:SSH_CONFIG:_files' \
'--agent-dir=[Directory containing verg-agent binaries per architecture]:AGENT_DIR:_files' \
'--json[]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
'-t+[]:TARGETS:_default' \
'--targets=[]:TARGETS:_default' \
'--path=[]:PATH:_files' \
'--parallel=[]:PARALLEL:_default' \
'--ssh-config=[Path to SSH config file]:SSH_CONFIG:_files' \
'--agent-dir=[Directory containing verg-agent binaries per architecture]:AGENT_DIR:_files' \
'--json[]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(schema)
_arguments "${_arguments_options[@]}" : \
'--path=[]:PATH:_files' \
'--parallel=[]:PARALLEL:_default' \
'--ssh-config=[Path to SSH config file]:SSH_CONFIG:_files' \
'--agent-dir=[Directory containing verg-agent binaries per architecture]:AGENT_DIR:_files' \
'--json[]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'--path=[]:PATH:_files' \
'--parallel=[]:PARALLEL:_default' \
'--ssh-config=[Path to SSH config file]:SSH_CONFIG:_files' \
'--agent-dir=[Directory containing verg-agent binaries per architecture]:AGENT_DIR:_files' \
'--json[]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--path=[]:PATH:_files' \
'--parallel=[]:PARALLEL:_default' \
'--ssh-config=[Path to SSH config file]:SSH_CONFIG:_files' \
'--agent-dir=[Directory containing verg-agent binaries per architecture]:AGENT_DIR:_files' \
'--json[]' \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_verg__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:verg-help-command-$line[1]:"
        case $line[1] in
            (apply)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(diff)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(schema)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_verg_commands] )) ||
_verg_commands() {
    local commands; commands=(
'apply:Converge targets to desired state' \
'diff:Show what would change without applying' \
'check:Verify targets match desired state (exit code only)' \
'schema:Print resource type schemas as JSON' \
'init:Scaffold a new verg project directory' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'verg commands' commands "$@"
}
