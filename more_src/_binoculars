#compdef binoculars
# _binoculars — Armada Binoculars (per-cluster gRPC service: pod logs / cordon ops; gateway between the API/UI and kubectl exec/logs)
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/binoculars/main.go on tip; runtime config from the YAML config file (./config/binoculars or --config).

_binoculars() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[application configuration file (repeatable; comma-separated paths also accepted)]:file:_files -g "*.yaml"'
}

_binoculars "$@"
