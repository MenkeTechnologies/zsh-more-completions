#compdef packer-validate
# _packer-validate — HashiCorp Packer validate-only wrapper (HashiCorp, Go); convenience for packer validate
# upstream: https://github.com/hashicorp/packer

_packer-validate() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-syntax-only[only check syntax]' \
        '-machine-readable[machine readable output]' \
        '-var+[set variable]:var:' \
        '-var-file=+[var file]:file:_files' \
        '-only=+[only build named items]:list:' \
        '-except=+[except named items]:list:' \
        '-evaluate-datasources[evaluate datasources]' \
        '-no-warn-undeclared-var[no warn undeclared var]' \
        '*:file:_files -g "*.(pkr.hcl|pkr.json|json)"'
}

_packer-validate "$@"
