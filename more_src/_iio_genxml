#compdef iio_genxml
# _iio_genxml — dump IIO context XML description (analogdevicesinc/libiio)
# upstream: https://github.com/analogdevicesinc/libiio
# Flags from utils/iio_genxml.c + utils/iio_common.c (getopt_long).

_iio_genxml() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-u --uri)'{-u+,--uri=}'[IIO context URI]:uri:' \
        '(-S --scan)'{-S+,--scan=}'[scan backends]:backends:' \
        '(-a --auto)'{-a+,--auto=}'[auto-detect context]:backends:' \
        '(-T --timeout)'{-T+,--timeout=}'[I/O timeout (ms)]:ms:' \
        '(-e --emulator)'{-e,--emulator}'[include attribute values in generated XML]'
}

_iio_genxml "$@"
