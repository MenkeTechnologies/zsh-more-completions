#compdef ocioconvert
# Documentation: https://opencolorio.readthedocs.io/
# load an image, apply a color transform, and save it to a new file

local ret=1

_arguments -s -S \
  '--help[information on available options]' \
  '--gpu[use the GPU renderer]' \
  '--gpuinfo[output the shader program used by the GPU renderer]' \
  '*:image / colorspace:_files' && ret=0

return ret
