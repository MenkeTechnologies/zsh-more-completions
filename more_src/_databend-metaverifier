#compdef databend-metaverifier
# Documentation: https://github.com/databendlabs/databend/blob/main/src/meta/binaries/metaverifier/main.rs
# Databend meta-service consistency verifier tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--prefix=[the prefix of keys to write]:prefix' \
  '--client=[number of clients]:count' \
  '--time=[duration in seconds to run]:seconds' \
  '--remove-percent=[percentage of operations that are removes]:percent' \
  '--number=[number of operations per client]:count' \
  '--log-level=[log level]:level' \
  '--grpc-api-address=[gRPC API address of the meta node]:address' && ret=0

return ret
