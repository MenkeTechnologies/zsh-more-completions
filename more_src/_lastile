#compdef lastile
# LAStools: tile large LAS/LAZ files into square tiles with optional buffer

local ret=1

_arguments -s -S \
  '-help[display help]' \
  '-version[report tool version]' \
  '-gui[start with GUI]' \
  '-tile_size+[tiling dimension n x n units (default 1000)]:size' \
  '-buffer+[expand each tile by n units]:units' \
  '-remove_buffer[strip buffer points after processing]' \
  '-full_bb[set header to full tile extent]' \
  '-reversible[enable reconstruction of original from tiles]' \
  '-reverse_tiling[recreate original file from tiles]' \
  '-refine+[refine tiling on density threshold]:n' \
  '-refine_tiles+[refine previously generated tiles]:n' \
  '-dont_delete_refined[preserve original tiles after refinement]' \
  '-flag_as_synthetic[mark buffer points as synthetic]' \
  '-flag_as_withheld[mark buffer points as withheld]' \
  '-keep_buffer_only_tiles[retain tiles with only buffer points]' \
  '-files_are_flightlines[treat input files as flight strips]' \
  '-tile_ll+[shift tiling origin by x y offset]:x' \
  '-extra_pass[additional read pass for point counting]' \
  '*-i+[input file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-lof+[read file list from text file]:file:_files' \
  '-o+[output base name]:output:_files' \
  '-odir+[output directory]:dir:_files -/' \
  '-olas[output uncompressed LAS]' \
  '-olaz[output compressed LAZ]' \
  '-cores+[process on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
