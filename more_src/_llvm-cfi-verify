#compdef llvm-cfi-verify
# _llvm-cfi-verify — LLVM CFI protection verifier (LLVM project, C++); verify CFI indirect call protection in binaries
# upstream: https://github.com/llvm/llvm-project

_llvm-cfi-verify() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--coverage-summary-output=+[summary output]:file:_files' \
        '--blacklist=+[blacklist]:file:_files' \
        '--ignore-dwarf[ignore DWARF]' \
        '--print-graphs[print graphs]' \
        '*:file:_files'
}

_llvm-cfi-verify "$@"
