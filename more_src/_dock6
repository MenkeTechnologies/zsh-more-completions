#compdef dock6
# Documentation: https://wiki.docking.org/index.php/Command_line_arguments_in_DOCK6
# dock6 - UCSF DOCK6 ligand docking driver.

local ret=1

_arguments -s -S \
  '-help[show usage]' \
  '-i+[input file with user-defined parameters]:file:_files' \
  '-o+[output file]:file:_files' \
  '-v[verbosity: extra info and scoring warnings]' \
  '*:file:_files' && ret=0

return ret
