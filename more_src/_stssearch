#compdef stssearch
# Documentation: https://man.archlinux.org/search?q=stssearch
# Reference accessed: 2026-05-16

# EMBOSS stssearch: search a DNA sequence for sequence-tagged-site (STS)
# primer pairs. STS file gives forward/reverse primer pairs and product
# size for each marker.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s) to search]:DNA USA:_files' \
  '-infile=[primer pair input file (STS format)]:file:_files' \
  '-outfile=[report output file]:file:_files' \
  '*:DNA USA:_files' && ret=0

return ret
