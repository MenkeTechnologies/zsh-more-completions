#compdef fission
# Documentation: https://man.archlinux.org/search?q=fission
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'function:function commands (alias: fn)'
  'fn:function commands'
  'environment:environment commands (alias: env)'
  'env:environment commands'
  'package:package commands (alias: pkg)'
  'pkg:package commands'
  'httptrigger:HTTP trigger commands (alias: route, ht)'
  'route:HTTP trigger commands'
  'ht:HTTP trigger commands'
  'timetrigger:time trigger commands (alias: tt, timer)'
  'tt:time trigger commands'
  'timer:time trigger commands'
  'mqtrigger:message queue trigger commands (alias: mqt)'
  'mqt:message queue trigger commands'
  'kubewatch:KubeWatcher trigger commands'
  'recorder:execution recorder commands'
  'replay:execution replay commands'
  'archive:archive commands'
  'spec:declarative spec commands'
  'support:diagnose installation'
  'check:check Fission installation'
  'token:manage authentication tokens'
  'canary:manage canary configurations'
  'version:print version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbosity)'{-v+,--verbosity=}'[verbosity level]:n:(0 1 2)' \
  '--server=[Fission API server URL]:url:' \
  '--kube-context=[kube context]:ctx:' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:ns:' \
  '--plugin=[plugin path]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'fission command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (fn|function)
        _arguments \
          '*::sub:(create get update delete list logs test pods)' \
          '--name=[function name]:name:' \
          '--env=[environment name]:env:' \
          '--code=[source file]:file:_files' \
          '--src=[archive path or URL]:path:_files' \
          '--pkg=[package name]:package:' \
          '--entrypoint=[entrypoint]:entrypoint:' \
          '--executortype=[executor type]:type:(newdeploy poolmgr container knative)' \
          '--minscale=[min replicas]:n:' \
          '--maxscale=[max replicas]:n:' \
          '--targetcpu=[target CPU %]:n:' \
          '--specializationtimeout=[specialization timeout]:n:' \
          '--mincpu=[min CPU request]:n:' \
          '--maxcpu=[max CPU limit]:n:' \
          '--minmemory=[min memory request]:n:' \
          '--maxmemory=[max memory limit]:n:' \
          '--secret=[secret name]:secret:' \
          '--configmap=[configmap name]:cm:' \
          '--idletimeout=[idle timeout]:n:' \
          '--concurrency=[concurrency limit]:n:' \
          '--requestsperpod=[requests per pod]:n:' \
          '--ondemand[on-demand executor]' && ret=0 ;;
      (env|environment)
        _arguments \
          '*::sub:(create get update delete list pods)' \
          '--name=[environment name]:name:' \
          '--image=[runtime image]:image:' \
          '--builder=[builder image]:image:' \
          '--keeparchive[keep archive content]' \
          '--version=[fission env spec version]:n:' \
          '--graceperiod=[grace period]:n:' \
          '--idletimeout=[idle timeout]:n:' \
          '--mincpu=[min CPU]:n:' \
          '--maxcpu=[max CPU]:n:' \
          '--minmemory=[min memory]:n:' \
          '--maxmemory=[max memory]:n:' \
          '--poolsize=[pool size]:n:' \
          '--imagepullsecret=[image pull secret]:secret:' \
          '--terminationGracePeriod=[termination grace period]:n:' && ret=0 ;;
      (ht|httptrigger|route)
        _arguments \
          '*::sub:(create get update delete list)' \
          '--name=[trigger name]:name:' \
          '--url=[URL path]:url:' \
          '--method=[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS CONNECT TRACE ANY)' \
          '--function=[target function]:fn:' \
          '--ingress=[create ingress]:bool:(true false)' \
          '--ingressrule=[ingress rule]:rule:' && ret=0 ;;
      (tt|timer|timetrigger)
        _arguments \
          '*::sub:(create get update delete list)' \
          '--name=[trigger name]:name:' \
          '--cron=[cron expression]:cron:' \
          '--function=[target function]:fn:' && ret=0 ;;
      (mqt)
        _arguments \
          '*::sub:(create get update delete list)' \
          '--name=[trigger name]:name:' \
          '--mqtype=[mq type]:type:(nats-streaming kafka azure-storage-queue rabbitmq)' \
          '--topic=[topic]:topic:' \
          '--resptopic=[response topic]:topic:' \
          '--function=[target function]:fn:' && ret=0 ;;
      (pkg|package)
        _arguments \
          '*::sub:(create get update delete list info getsrc getdeploy)' \
          '--name=[package name]:name:' \
          '--env=[environment name]:env:' \
          '--code=[source code]:file:_files' \
          '--src=[source archive]:file:_files' \
          '--deploy=[deploy archive]:file:_files' \
          '--buildcmd=[build command]:cmd:' && ret=0 ;;
      (spec)
        _arguments \
          '*::sub:(init validate apply destroy list deploy)' \
          '--specdir=[specs directory]:dir:_files -/' \
          '--name=[spec name]:name:' && ret=0 ;;
      (support)
        _arguments \
          '*::sub:(dump)' \
          '--output=[output dir]:dir:_files -/' && ret=0 ;;
      (token)
        _arguments \
          '*::sub:(create list delete)' && ret=0 ;;
    esac ;;
esac

return ret
