#compdef vnstat
# Documentation: https://manpages.debian.org/bookworm/vnstat/vnstat.1.en.html
# Reference accessed: 2026-05-30
# vnstat — Teemu Toivola's network statistics monitor (interface-level
# byte/packet counters persisted to a local SQLite-style db).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-\?,--help}'[show command option summary]' \
  '(- *)--longhelp[show complete options list]' \
  '(- *)'{-v,--version}'[show current version]' \
  '-D[show additional debug output]' \
  '--debug[show additional debug output]' \
  '(-i --iface)'{-i,--iface=}'[select interface to act on]:interface:_net_interfaces' \
  '(-q --query)'{-q,--query}'[force database query mode]' \
  '(-s --short)'{-s,--short}'[use short output mode]' \
  '(-5 --fiveminutes)'{-5,--fiveminutes=-}'[5-minute resolution stats for last N hours]:limit:' \
  '(-h --hours)'{-h,--hours=-}'[hourly stats for last N hours]:limit:' \
  '(-hg --hoursgraph)'{-hg,--hoursgraph}'[hourly bar graph for last 24h]' \
  '(-d --days)'{-d,--days=-}'[daily stats for last N days]:limit:' \
  '(-m --months)'{-m,--months=-}'[monthly stats for last N months]:limit:' \
  '(-y --years)'{-y,--years=-}'[yearly stats for last N years]:limit:' \
  '(-t --top)'{-t,--top=-}'[all-time top traffic days]:limit:' \
  '(-b --begin)'{-b,--begin=}'[begin list output at date/time]:date:' \
  '(-e --end)'{-e,--end=}'[end list output at date/time]:date:' \
  '(-l --live)'{-l,--live=-}'[live transfer rate for selected interface]:mode:(0 1 2)' \
  '(-tr --traffic)'{-tr,--traffic=-}'[total traffic over the next N seconds]:seconds:' \
  '(-ru --rateunit)'{-ru,--rateunit=-}'[swap configured rate unit]:mode:(0 1)' \
  '--add[create database entry for interface]' \
  '--remove[delete database entry, stop monitoring]' \
  '--rename=[rename interface in the database]:new-name:' \
  '--setalias=[set alias for selected interface]:alias:' \
  '--dbiflist=-[list interfaces in the database]:mode:(0 1)' \
  '--iflist=-[list currently available interfaces]:mode:(0 1)' \
  '--config=[use FILE as configuration file]:file:_files' \
  '--dbdir=[use DIR as database directory]:dir:_files -/' \
  '--showconfig[show current configuration]' \
  '--style=[modify output content/style]:N:(0 1 2 3 4 5)' \
  '--locale=[locale override (e.g. C, en_US.UTF-8)]:locale:' \
  '--limit=[max entries in list outputs]:N:' \
  '--oneline=-[summary in parsable one-line format]:mode:(b)' \
  '--json=-[output db content as JSON]:mode:(a d f h m s t y)' \
  '--xml=-[output db content as XML]:mode:(a d f h m s t y)' \
  '--alert=[output exit type condition limit unit]:alert spec:' \
  && ret=0

return ret
