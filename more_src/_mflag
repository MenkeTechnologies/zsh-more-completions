#compdef mflag

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-D[mark as draft]' \
  '-F[mark as flagged]' \
  '-P[mark as passed/forwarded]' \
  '-R[mark as replied]' \
  '-S[mark as seen]' \
  '-T[mark as trashed]' \
  '-d[unmark as draft]' \
  '-f[unmark as flagged]' \
  '-p[unmark as passed/forwarded]' \
  '-r[unmark as replied]' \
  '-s[unmark as seen]' \
  '-t[unmark as trashed]' \
  '-v[print verbose output]' \
  '*:message:_files' && ret=0

return ret
