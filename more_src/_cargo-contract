#compdef cargo-contract

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'new:create a new smart contract project'
      'build:compile the smart contract'
      'check:check the smart contract for errors'
      'test:run tests for the smart contract'
      'upload:upload a contract to the chain'
      'instantiate:instantiate a deployed contract'
      'call:call a contract message'
      'decode:decode contract data'
      'remove:remove a contract from the chain'
      'info:display contract information'
      'verify:verify a contract on-chain'
      'schema:generate contract schema'
    )
    _describe -t commands 'cargo-contract command' commands && ret=0
    ;;
  args)
    local -a common_flags=(
      '(- *)'{-h,--help}'[show help]'
      '--manifest-path=[path to Cargo.toml]:file:_files'
      '(-v --verbose)'{-v,--verbose}'[enable verbose output]'
    )

    case ${words[1]} in
      (new)
        _arguments -s -S \
          $common_flags \
          '--name=[contract name]:name' \
          '1:project name or path:_files -/' && ret=0
        ;;
      (build)
        _arguments -s -S \
          $common_flags \
          '--release[build in release mode]' \
          '--features=[features to activate]:features' \
          '--generate-all[generate all build artifacts]' \
          '--skip-wasm-validation[skip Wasm validation]' \
          '--output-json[output build results as JSON]' \
          '--keep-debug-symbols[keep debug symbols in the Wasm]' && ret=0
        ;;
      (check)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      (test)
        _arguments -s -S \
          $common_flags \
          '--release[test in release mode]' \
          '--features=[features to activate]:features' && ret=0
        ;;
      (upload)
        _arguments -s -S \
          $common_flags \
          '--suri=[secret URI for signing]:suri' \
          '--url=[websocket URL of the node]:url' \
          '--gas=[maximum gas]:gas' \
          '--storage-deposit-limit=[maximum storage deposit]:limit' \
          '--dry-run[perform a dry run]' \
          '--skip-confirm[skip confirmation prompt]' \
          '*:contract file:_files -g "*.wasm"' && ret=0
        ;;
      (instantiate)
        _arguments -s -S \
          $common_flags \
          '--constructor=[constructor to call]:constructor' \
          '--args=[arguments to pass]:args' \
          '--suri=[secret URI for signing]:suri' \
          '--url=[websocket URL of the node]:url' \
          '--gas=[maximum gas]:gas' \
          '--value=[value to transfer]:value' \
          '--storage-deposit-limit=[maximum storage deposit]:limit' \
          '--salt=[salt for address derivation]:salt' \
          '--dry-run[perform a dry run]' \
          '--skip-confirm[skip confirmation prompt]' && ret=0
        ;;
      (call)
        _arguments -s -S \
          $common_flags \
          '--contract=[contract address]:address' \
          '--message=[message to call]:message' \
          '--args=[arguments to pass]:args' \
          '--suri=[secret URI for signing]:suri' \
          '--url=[websocket URL of the node]:url' \
          '--gas=[maximum gas]:gas' \
          '--value=[value to transfer]:value' \
          '--storage-deposit-limit=[maximum storage deposit]:limit' \
          '--dry-run[perform a dry run]' \
          '--skip-confirm[skip confirmation prompt]' \
          '--output-json[output results as JSON]' && ret=0
        ;;
      (decode)
        _arguments -s -S \
          $common_flags \
          '--data=[hex-encoded data to decode]:data' \
          '--type=[type to decode]:type:(message constructor event)' && ret=0
        ;;
      (remove)
        _arguments -s -S \
          $common_flags \
          '--suri=[secret URI for signing]:suri' \
          '--url=[websocket URL of the node]:url' \
          '--skip-confirm[skip confirmation prompt]' \
          '1:code hash' && ret=0
        ;;
      (info)
        _arguments -s -S \
          $common_flags \
          '--url=[websocket URL of the node]:url' \
          '--output-json[output as JSON]' \
          '1:contract address' && ret=0
        ;;
      (verify)
        _arguments -s -S \
          $common_flags \
          '--url=[websocket URL of the node]:url' \
          '1:contract address' && ret=0
        ;;
      (schema)
        _arguments -s -S \
          $common_flags \
          '--output=[output file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
