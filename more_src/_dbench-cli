#compdef dbench tbench tbench_srv
# Documentation: https://man.archlinux.org/search?q=dbench
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (dbench|tbench)
    _arguments -C \
      '(- *)-h[show help]' \
      '(-V --version)-V[show version]' \
      '-c+[client load file]:file:_files' \
      '-D+[run directory]:dir:_files -/' \
      '-T+[run time s]:s:' \
      '-t+[run time s]:s:' \
      '-R+[targetload]:load:' \
      '-s+[sync writes]:b:' \
      '-S[sync writes]' \
      '-x[exit on error]' \
      '-z+[zip file]:file:_files' \
      '-B+[input variant]:v:(SCRIPTED FILEIO POSIX)' \
      '-w+[warmup s]:s:' \
      '-r+[run iterations]:n:' \
      '-1[run one client per host]' \
      '*: :' && ret=0 ;;
  (tbench_srv)
    _arguments -C \
      '-h[help]' \
      '-V[version]' \
      '-p+[port]:port:' \
      '-x[exit on disconnect]' \
      '*: :' && ret=0 ;;
esac

return ret
