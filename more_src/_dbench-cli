#compdef dbench tbench tbench_srv
# Documentation: https://www.samba.org/ftp/tridge/dbench/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Repo: https://github.com/sahlberg/dbench

local curcontext="$curcontext" state line ret=1

case $service in
  (dbench|tbench)
    _arguments -C \
      '-c+[client load file]:file:_files' \
      '-D+[base directory for filesystem operations]:dir:_files -/' \
      '-t+[benchmark runtime seconds (default 600)]:secs:' \
      '-T+[(tbench) socket options csv]:opts:' \
      '-s[synchronous file I/O for all file operations]' \
      '-S[synchronous I/O for directory operations]' \
      '-x[exercise xattrs (simulate Samba4 xattr load)]' \
      '*:number of clients:' && ret=0 ;;
  (tbench_srv)
    _arguments -C \
      '-t+[socket options csv]:opts:' \
      '*:port:' && ret=0 ;;
esac

return ret
