#compdef bdsup2sub BDSup2Sub
# Documentation: https://github.com/mjuhasz/BDSup2Sub/wiki/Command-line-Interface
# Subtitle (SUP/IDX/SUB) converter and editor. Flags from upstream CLI wiki.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage information and exit]' \
  '(-L --load-settings)'{-L,--load-settings}'[load settings from config file in CLI mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose console output mode]' \
  '(-V --version)'{-V,--version}'[show version information and exit]' \
  '(-o --output)'{-o+,--output=}'[specify output file]:output:_files' \
  '(-r --resolution)'{-r+,--resolution=}'[set resolution]:res:(keep ntsc=480 pal=576 720p=720 1080p=1080 1440x1080)' \
  '(-T --fps-target)'{-T+,--fps-target=}'[synchronize target frame rate]:fps:' \
  '(-C --convert-fps)'{-C+,--convert-fps=}'[convert frame rate from src to trg]:src,trg:' \
  '(-d --delay)'{-d+,--delay=}'[set delay in ms]:ms:' \
  '(-m --minimum-time)'{-m+,--minimum-time=}'[set minimum display time in ms]:ms:' \
  '(-x --merge-time)'{-x+,--merge-time=}'[max time difference for merging subtitles in ms]:ms:' \
  '(-I --move-in)'{-I+,--move-in=}'[move captions inside screen ratio +/- offset]:ratio,offset:' \
  '(-O --move-out)'{-O+,--move-out=}'[move captions outside screen ratio +/- offset]:ratio,offset:' \
  '(-X --move-x)'{-X+,--move-x=}'[move captions horizontally from position]:pos:' \
  '(-c --crop-y)'{-c+,--crop-y=}'[crop the upper/lower n lines]:n:' \
  '(-S --scale)'{-S+,--scale=}'[scale captions horizontally and vertically]:x,y:' \
  '(-f --filter)'{-f+,--filter=}'[set the filter to use for scaling]:filter:(bilinear triangle bicubic bell b-spline hermite lanczos3 mitchell)' \
  '(-a --alpha-crop)'{-a+,--alpha-crop=}'[set the alpha cropping threshold]:thr:' \
  '(-p --palette-mode)'{-p+,--palette-mode=}'[set palette mode]:mode:(keep create dither)' \
  '(-P --export-palette)'{-P,--export-palette}'[export target palette in PGCEdit format]' \
  '(-t --palette-file)'{-t+,--palette-file=}'[load palette file for SUB/IDX conversion]:file:_files' \
  '(-A --alpha-thr)'{-A+,--alpha-thr=}'[set alpha threshold 0..255 for SUB/IDX]:thr:' \
  '(-M --lum-low-med-thr)'{-M+,--lum-low-med-thr=}'[luminance lo/med threshold 0..255]:thr:' \
  '(-H --lum-med-hi-thr)'{-H+,--lum-med-hi-thr=}'[luminance med/hi threshold 0..255]:thr:' \
  '(-l --language)'{-l+,--language=}'[set language for SUB/IDX export]:lang:' \
  '(-D --forced-only)'{-D,--forced-only}'[export only forced subtitles]' \
  '(-F --force-all)'{-F+,--force-all=}'[set or clear forced flag for all subtitles]:flag:(set clear)' \
  '(-w --swap)'{-w,--swap}'[swap Cr/Cb when loading a BD/HD-DVD sup file]' \
  '(-i --fix-invisible)'{-i,--fix-invisible}'[fix zero alpha frame palette for SUB/IDX and SUP/IFO]' \
  '*:subtitle file:_files' && ret=0

return ret
