#compdef wmiquery wmiquery.py

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-namespace[WMI namespace]:namespace:' \
  '-file[file with WMI query]:file:_files' \
  '-ts[add timestamp to output]' \
  '-debug[enable debug output]' \
  '-hashes[NTLM hashes (LMHASH\:NTHASH)]:hashes:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos authentication]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[domain controller IP]:ip:_hosts' \
  '-target-ip[target IP]:ip:_hosts' \
  '-rpc-auth-level[RPC auth level]:level:(connect call pkt integrity privacy)' \
  '1:target (domain/username\:password@host):' \
  && ret=0

return ret
