#compdef scil_sh_to_sf
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_sh_to_sf.html
# Scilpy: convert spherical harmonics (SH) to spherical functions (SF)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--sphere --in_bvec)--sphere=[sphere for projection]:sphere:(repulsion100 repulsion200 repulsion724 symmetric362 symmetric642 symmetric724)' \
  '(--sphere --in_bvec)--in_bvec=[b-vector file to project onto]:file:_files' \
  '--dtype=[output data type]:dtype:(float32 float64)' \
  '--in_bval=[input b-value file]:file:_files' \
  '--in_b0=[input b0 file]:file:_files' \
  '--out_bval=[output b-value file]:file:_files' \
  '--out_bvec=[output b-vector file]:file:_files' \
  '--b0_scaling[scale by the b0 image]' \
  '--sh_basis=[SH basis]:basis:(descoteaux07 tournier07 descoteaux07_legacy tournier07_legacy)' \
  '--full_basis[use full SH basis]' \
  '--b0_threshold=[b0 threshold]:thr' \
  '--processes=[number of sub-processes]:nbr' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_sh:_files' \
  '2:out_sf:_files' && ret=0

return ret
