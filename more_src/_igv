#compdef igv
# Documentation: https://igv.org/doc/desktop/
# Documentation: https://github.com/igvteam/igv/blob/master/scripts/igv.sh
# Reference accessed: 2026-05-27
# Verified: upstream scripts/igv.sh launcher and IGV CommandLineParser (igvteam/igv)

# Zsh completion for igv (Integrative Genomics Viewer)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-g --genome)'{-g+,--genome=}'[specify genome id or fasta file]:genome:_files -g "*.(fa|fasta|fna|genome)"' \
  '(-p --port)'{-p+,--port=}'[command port (default 60151)]:port:' \
  '(-b --batch)'{-b+,--batch=}'[batch script file to run on startup]:batch file:_files' \
  '--igvDirectory=[IGV user directory]:directory:_files -/' \
  '--vmoptions=[JVM options file]:vmoptions:_files' \
  '*:session or data file:_files -g "*.(xml|bam|sam|cram|vcf|vcf.gz|bed|gff|gff3|gtf|wig|bigWig|bw|bigBed|bb|seg|tdf)"' && ret=0

return ret
