#compdef vfsstat vfsstat-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/vfsstat.py argparse)
# Reference accessed: 2026-05-29
# vfsstat — VFS-level operation counters (READ/WRITE/FSYNC/OPEN/CREATE) per interval (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:interval (seconds, default 1):' \
  '2:count (number of outputs, default unlimited):' \
  && ret=0

return ret
