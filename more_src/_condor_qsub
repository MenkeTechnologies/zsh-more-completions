#compdef condor_qsub
# Documentation: https://man.archlinux.org/search?q=condor_qsub
# Reference accessed: 2026-05-16

# condor_qsub: PBS qsub-compatible front-end for HTCondor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-A[account]:account:' \
  '-a[start time]:datetime:' \
  '-c[copy script]' \
  '-d[working dir]:dir:_files -/' \
  '-D[working dir]:dir:_files -/' \
  '-e[stderr file]:file:_files' \
  '-h[hold job]' \
  '-I[interactive]' \
  '-j[join out/err]:val:(eo oe)' \
  '-l[resource]:resource:' \
  '-m[mail events]:events:(a b e n)' \
  '-M[mail addresses]:list:' \
  '-N[job name]:name:' \
  '-o[stdout file]:file:_files' \
  '-p[priority]:n:' \
  '-q[queue]:queue:' \
  '-r[restartable]:val:(y n)' \
  '-S[shell]:shell:_command_names' \
  '-t[task array]:range:' \
  '-V[export all env vars]' \
  '-v[export var]:vars:' \
  '-W[attribute]:attr=value:' \
  '*:script:_files' && ret=0
return ret
