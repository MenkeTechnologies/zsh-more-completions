#compdef condor_qsub
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_qsub.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_qsub: PBS qsub-compatible front-end for HTCondor.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-A[account string]:account:' \
  '-a[deferred start time]:datetime:' \
  '-b[script parses as condor submit file]:y/n:(y n)' \
  '-condor-keep-files[preserve temporary files]' \
  '-cwd[use current working directory]' \
  '-d[initial working dir]:dir:_files -/' \
  '-wd[initial working dir]:dir:_files -/' \
  '-e[stderr output file]:file:_files' \
  '-f[parse qsub file]:file:_files' \
  '-h[hold job]' \
  '-hold_jid[job dependency]:jobid:' \
  '-i[stdin input file]:file:_files' \
  '-j[join out/err streams]:val:(eo oe)' \
  '-l[resource specifications]:resource:' \
  '-m[mail event timing]:events:(a b e n)' \
  '-M[mail addresses]:list:' \
  '-N[job name]:name:' \
  '-o[stdout output file]:file:_files' \
  '-p[job priority]:n:' \
  '-print[print submit file to stdout]' \
  '-r[rerunnable]:y/n:(y n)' \
  '-S[shell]:shell:_command_names' \
  '-t[task array range]:range:' \
  '-test[test submission without executing]' \
  '-V[inherit all environment variables]' \
  '-v[export named variables]:vars:' \
  '-W[stagein/stageout/attributes]:attr=value:' \
  '*:script:_files' && ret=0
return ret
