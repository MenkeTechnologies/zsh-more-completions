#compdef makemap
# _makemap — OpenSMTPD makemap (build per-key database maps from a plaintext source file; used by smtpd.conf table directives)
# upstream: https://github.com/OpenSMTPD/OpenSMTPD
# Flags from usr.sbin/smtpd/makemap.8 on tip.

_makemap() {
    _arguments \
        '-U[input is in u-flag (newaliases) mode]' \
        '-d+[database format]:dbtype:(hash btree)' \
        '-o+[output database file]:file:_files' \
        '-t+[map type]:type:(set aliases virtuals)' \
        '1:source-file:_files'
}

_makemap "$@"
