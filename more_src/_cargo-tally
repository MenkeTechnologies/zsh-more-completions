#compdef cargo-tally
# Documentation: https://man.archlinux.org/search?q=cargo-tally
# Reference accessed: 2026-05-16

_arguments -s \
  '--db=[crates.io DB dump]:file:_files' \
  '(-j --jobs)'{-j,--jobs}'=[threads]:n:' \
  '--relative[fraction of total]' \
  '--transitive[transitive deps]' \
  '*--exclude=[regex]:regex:' \
  '--title=[graph title]:title:' \
  '*:query:'
