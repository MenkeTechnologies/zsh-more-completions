#compdef cargo-tally
# Documentation: https://github.com/dtolnay/cargo-tally
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '--db=[crates.io DB dump path (default: ./db-dump.tar.gz)]:file:_files' \
  '(-j --jobs)'{-j,--jobs}'=[threads for differential dataflow]:n:' \
  '--relative[display as fraction of total crates, not absolute number]' \
  '--transitive[count transitive dependencies, not just direct]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:query:'
