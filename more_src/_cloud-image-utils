#compdef cloud-image-utils

# cloud-image-utils umbrella: cloud-localds, cloud-publish-tarball, growpart, etc.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'cloud-localds:create a CIDATA seed disk for cloud-init'
  'cloud-publish-image:upload image to a cloud'
  'cloud-publish-tarball:upload tarball to a cloud'
  'cloud-publish-ubuntu:publish Ubuntu cloud images'
  'growpart:resize a partition to fill its device'
  'mount-image-callback:mount an image and run callback on it'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'cloud-image-utils command' commands && ret=0 ;;
esac
return ret
