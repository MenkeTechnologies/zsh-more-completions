#compdef cloud-image-utils
# Documentation: https://github.com/canonical/cloud-utils
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (the cloud-utils package umbrella).

# cloud-image-utils / cloud-utils umbrella: cloud-localds, ec2metadata,
# growpart, mount-image-callback, resize-part-image, ubuntu-cloudimage-query,
# vcs-run, write-mime-multipart.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'cloud-localds:create a CIDATA seed disk for cloud-init'
  'ec2metadata:query and display EC2 metadata'
  'growpart:resize a partition to fill its device'
  'mount-image-callback:mount an image and run callback on it'
  'resize-part-image:resize partition images and contained filesystems'
  'ubuntu-cloudimage-query:retrieve latest Ubuntu AWS AMIs by criteria'
  'vcs-run:obtain repositories and execute commands'
  'write-mime-multipart:create MIME-multipart user-data files for cloud-init'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'cloud-image-utils command' commands && ret=0 ;;
esac
return ret
