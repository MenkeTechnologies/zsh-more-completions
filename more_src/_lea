#compdef lea
# Documentation: https://github.com/carbonfact/lea
# lea - minimalist SQL orchestrator / dbt alternative (run)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--select=[select scripts to run]:selector' \
  '--unselect=[exclude scripts from the run]:selector' \
  '--production[run against the production environment]' \
  '--env=[path to a custom .env file]:file:_files' \
  '--dry-run[compile and resolve without executing]' \
  '--print[print resolved SQL]' \
  '--restart[restart from scratch instead of resuming]' \
  '--fresh[ignore caches and recompute]' \
  '--threads=[number of threads]:n' \
  '--raise-exceptions[raise on first error instead of continuing]' \
  '--quack[use DuckDB backend]' \
  '--quack-push[push DuckDB results to the warehouse]' \
  '1:command:(run quack-ui)' \
  '*::arg:->args' && ret=0

return ret
