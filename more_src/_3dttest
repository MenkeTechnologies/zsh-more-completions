#compdef 3dttest
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dttest.html
# AFNI: Student's t-test for groups of 3D datasets (older program)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-set1[first set of datasets]:dataset:_files' \
  '*-set2[second set of datasets]:dataset:_files' \
  '-base1[constant base value for set1]:bval:' \
  '-base1_dset[per-voxel base from dataset]:dataset:_files' \
  '-sdn1[base sd and n1 for set1]:sd:' \
  '-paired[use paired-sample t-test]' \
  '-unpooled[use unpooled variance estimate]' \
  '-dof_prefix[save degrees-of-freedom to dataset]:prefix:_files' \
  '-voxel[print t-test for given voxel]:voxel:' \
  '-session[output directory]:dir:_files -/' \
  '-prefix[output dataset prefix]:prefix:_files' \
  '-datum[output data type]:type:(short float)' \
  '*:dataset:_files' && ret=0

return ret
