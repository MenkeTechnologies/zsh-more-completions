# ============================================================================
# _pipefish — zsh completion for the Pipefish programming language hub/REPL
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/tim-hardcastle/Pipefish
#   Author     : Tim Hardcastle
#   License    : MIT
#   Language   : Go (interpreter) / Pipefish (.pf source files)
#   Module     : github.com/tim-hardcastle/pipefish  (Go 1.25)
#   Binary     : pipefish  (built from root main.go)
#   Version    : 0.6.8
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   Pipefish is a hub/REPL-first programming language inspired by
#   r/programminglanguages community feedback and Thorsten Ball's
#   "Writing An Interpreter In Go".  It is a small, dynamic language
#   centered around a "hub" model — every Pipefish session loads a hub
#   directory of `.pf` scripts under `~/.pipefish/user/hub`, exposing
#   the interactive REPL plus a TUI (text user interface) mode and a
#   one-shot script runner.  Source files use the `.pf` extension.
#
# CLI ARGUMENT GRAMMAR  (verbatim from main.go switch-on-os.Args[1] +
#                       source/hub/hub.go const HELP)
#   pipefish [-v | --version | version]
#   pipefish [-h | --help    | help]
#   pipefish [-r | --run     | run] <file.pf>
#   pipefish [-t | --tui     | tui]
#   pipefish                                  (no args → REPL with logo)
#
#   Commands & flags:
#     -v, --version, version    Print "Pipefish version <X.Y.Z>." and exit
#     -h, --help,    help       Print Usage / Commands help and exit
#     -r, --run,     run        Run a Pipefish script (expects a .pf file
#                               with a `main` command)
#     -t, --tui,     tui        Start the Pipefish TUI (text user
#                               interface)
#
#   File arguments default to the `.pf` extension if no suffix is given
#   (hub.MakeFilepath appends `.pf` when neither `.pf` nor `.hub` is
#   present on the filename).
#
# LANGUAGE-CORPUS POSITION
#   Pipefish is the 148th programming language entry in this completion
#   corpus, closing the 3+1 micro-cycle that began at R861 (_triage-bot /
#   slack-morphism v2 Rust=123 OPENS Axis 68 Slack SDK Library) and
#   continued through R862 (_kubewatch / slack-go/slack v0.6.5 Go=123)
#   and R863 (_agent-slack / @slack/web-api ^7.13.0 TS-Node=123 CLOSES
#   Axis 68 at 1/1/1 three-language symmetry — triple-123 landmark and
#   61st axis closed).  Pipefish joins the roster of language entries
#   in the corpus including Mochi (R860 147th), Oden (R856 146th), Hop
#   (R852 145th), Lustre via Kind 2 (R848 144th), Ravi (R844 143rd),
#   ZetZ (R840 142nd), Granule (R836 141st), Sixten (R832 140th —
#   round-number language milestone), Imba (R828 139th), Tao (R824
#   138th), Dada (R820 137th), Acton (R816 136th), Stanza (R812 135th),
#   Rune, Egel, Mlatu, Gwion, Silq (quantum), Mirth, Lawvere/bill,
#   Cognac/Cognate, and Scrapscript.
#
#   No completion for `pipefish` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_pipefish() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-v,--version,version}'[print Pipefish version and exit]' \
        '(- *)'{-h,--help,help}'[print usage help and exit]' \
        '(-t --tui tui)'{-t,--tui,tui}'[start the Pipefish TUI (text user interface)]' \
        '(-r --run run)'{-r,--run,run}'[run a Pipefish script (.pf with main command)]:script:_files -g "*.pf"' \
        '1: :_pipefish_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                run)  _arguments ':script:_files -g "*.pf"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_pipefish_commands] )) ||
_pipefish_commands() {
    local -a commands
    commands=(
        'run:run a Pipefish .pf script that defines a main command'
        'tui:start the Pipefish TUI (text user interface)'
        'help:print usage help and exit'
        'version:print Pipefish version and exit'
    )
    _describe -t commands 'pipefish command' commands
}

_pipefish "$@"
