#compdef cinder-rtstool
# Documentation: https://docs.openstack.org/cinder/latest/contributor/api/cinder.cmd.rtstool.html
# Reference accessed: 2026-05-17
# Verified: upstream docs and source at the URL above.

# cinder-rtstool: targetcli helper for the Cinder LIO iSCSI target
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create an iSCSI target'
  'add-initiator:add an initiator to an existing target'
  'delete-initiator:remove an initiator from a target'
  'get-targets:list all configured iSCSI targets'
  'delete:delete a target and its storage object'
  'verify:verify rtslib_fb is available'
  'save:persist current LIO configuration'
  'restore:load LIO configuration from file'
)
_arguments -C \
  "(- *)"{-h,--help}"[show help]" \
  "--version[show version]" \
  "--config-file=[config file]:file:_files" \
  "--config-dir=[config dir]:dir:_files -/" \
  "--debug[set log level to debug]" \
  "-d[set log level to debug]" \
  "--log-config-append=[log config file]:file:_files" \
  "--log-date-format=[log date format]:fmt:" \
  "--log-dir=[log directory]:dir:_files -/" \
  "--log-file=[log file]:file:_files" \
  "--nodebug[do not set log level to debug]" \
  "--syslog-log-facility=[syslog facility]:facility:" \
  "--use-journal[log to systemd journal]" \
  "--use-json[log as JSON]" \
  "--use-syslog[log via syslog]" \
  "--watch-log-file[watch log file]" \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'cinder-rtstool command' commands && ret=0 ;;
esac
return ret
