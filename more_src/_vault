#compdef vault

# Zsh completion for HashiCorp Vault

local curcontext="$curcontext" state line ret=1

local -a vault_commands
vault_commands=(
  'agent:start a Vault agent'
  'audit:interact with audit devices'
  'auth:interact with auth methods'
  'debug:runs the debug command'
  'delete:delete secrets and configuration'
  'events:interact with Vault events'
  'kv:interact with the key-value secrets engine'
  'lease:interact with leases'
  'list:list data or secrets'
  'login:authenticate locally'
  'monitor:stream Vault server logs'
  'namespace:interact with namespaces'
  'operator:perform operator-specific tasks'
  'patch:patch data or configuration'
  'path-help:retrieve API help for paths'
  'pki:interact with the PKI secrets engine'
  'plugin:interact with Vault plugins'
  'policy:interact with policies'
  'print:prints runtime configurations'
  'proxy:start a Vault proxy'
  'read:read data and secrets'
  'secrets:interact with secrets engines'
  'server:start a Vault server'
  'ssh:initiate an SSH session'
  'status:print seal and HA status'
  'token:interact with tokens'
  'transit:interact with the transit secrets engine'
  'unwrap:unwrap a wrapped secret'
  'version:print Vault version'
  'write:write data, configuration, and secrets'
)

local -a vault_global_flags
vault_global_flags=(
  '-address=[address of the Vault server]:address:_urls'
  '-agent-address=[address of the Vault agent]:address:_urls'
  '-ca-cert=[path to a CA cert file]:ca cert:_files'
  '-ca-path=[path to a directory of CA cert files]:ca path:_directories'
  '-client-cert=[path to a client cert file]:client cert:_files'
  '-client-key=[path to a client key file]:client key:_files'
  '-header=[header to include in requests]:key=value:'
  '-mfa=[MFA credentials]:mfa:'
  '-namespace=[the namespace to use]:namespace:'
  '-non-interactive[when set, avoids prompting the user for input]'
  '-output-curl-string[output an equivalent cURL command]'
  '-output-policy[output an example policy HCL]'
  '-policy-override[override soft-mandatory Sentinel policies]'
  '-tls-server-name=[name to use as the SNI host]:server name:'
  '-tls-skip-verify[disable TLS verification]'
  '-unlock-key=[unlock key when sealed]:unlock key:'
  '-wrap-ttl=[wrap response in a cubbyhole token]:ttl:'
  '-format=[output format]:format:(table json yaml pretty)'
  '-field=[print only the field with the given name]:field name:'
  '-help[show help]'
  '-h[show help]'
  '-version[show version]'
  '-v[show version]'
)

_arguments -s -S \
  $vault_global_flags \
  '1:command:_describe -t commands command vault_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      kv)
        local -a kv_commands
        kv_commands=(
          'delete:delete versions of secrets stored in KV'
          'destroy:permanently remove versions of secrets'
          'enable-versioning:enable versioning on a KV v1 store'
          'get:retrieves data from the KV store'
          'list:list data or secrets'
          'metadata:interact with KV secret metadata'
          'patch:set or update data in the KV store without overwriting'
          'put:set or update secrets in the KV store'
          'rollback:rolls back to a previous version of secrets'
          'undelete:undeletes versions of secrets in the KV store'
        )
        _arguments -s -S \
          $vault_global_flags \
          '1:kv command:_describe -t commands command kv_commands' \
          '*:path:' && ret=0
        ;;
      auth)
        local -a auth_commands
        auth_commands=(
          'disable:disables an auth method'
          'enable:enables a new auth method'
          'help:prints usage for an auth method'
          'list:lists enabled auth methods'
          'move:move an existing auth method to a new path'
          'tune:tunes an auth method configuration'
        )
        _arguments -s -S \
          $vault_global_flags \
          '1:auth command:_describe -t commands command auth_commands' \
          '*:path:' && ret=0
        ;;
      secrets)
        local -a secrets_commands
        secrets_commands=(
          'disable:disable a secrets engine'
          'enable:enable a secrets engine'
          'list:list enabled secrets engines'
          'move:move a secrets engine to a new path'
          'tune:tune a secrets engine configuration'
        )
        _arguments -s -S \
          $vault_global_flags \
          '1:secrets command:_describe -t commands command secrets_commands' \
          '*:path:' && ret=0
        ;;
      operator)
        local -a operator_commands
        operator_commands=(
          'diagnose:run diagnostics on a Vault server'
          'generate-root:generates a new root token'
          'init:initializes a server'
          'key-status:provides info about the active encryption key'
          'members:show the raft cluster membership'
          'migrate:migrates Vault data between storage backends'
          'raft:interact with the raft storage backend'
          'rekey:generates new unseal keys'
          'rotate:rotates the encryption key'
          'seal:seals the Vault server'
          'step-down:forces a node to relinquish active duty'
          'unseal:unseals the Vault server'
          'usage:provides cluster usage information'
        )
        _arguments -s -S \
          $vault_global_flags \
          '1:operator command:_describe -t commands command operator_commands' \
          '*:args:' && ret=0
        ;;
      token)
        local -a token_commands
        token_commands=(
          'capabilities:print capabilities of a token on a path'
          'create:create a new token'
          'lookup:display information about a token'
          'renew:renew a token lease'
          'revoke:revoke a token and its children'
        )
        _arguments -s -S \
          $vault_global_flags \
          '1:token command:_describe -t commands command token_commands' \
          '*:args:' && ret=0
        ;;
      policy)
        local -a policy_commands
        policy_commands=(
          'delete:deletes a policy by name'
          'fmt:formats a policy'
          'list:lists the installed policies'
          'read:prints a policy by name'
          'write:uploads a named policy'
        )
        _arguments -s -S \
          $vault_global_flags \
          '1:policy command:_describe -t commands command policy_commands' \
          '*:args:' && ret=0
        ;;
      lease)
        local -a lease_commands
        lease_commands=(
          'lookup:lookup the lease of a secret'
          'renew:renew the lease of a secret'
          'revoke:revoke leases and secrets'
        )
        _arguments -s -S \
          $vault_global_flags \
          '1:lease command:_describe -t commands command lease_commands' \
          '*:args:' && ret=0
        ;;
      audit)
        local -a audit_commands
        audit_commands=(
          'disable:disables an audit device'
          'enable:enables an audit device'
          'list:lists enabled audit devices'
        )
        _arguments -s -S \
          $vault_global_flags \
          '1:audit command:_describe -t commands command audit_commands' \
          '*:args:' && ret=0
        ;;
      plugin)
        local -a plugin_commands
        plugin_commands=(
          'deregister:deregister an existing plugin'
          'info:read information about a plugin'
          'list:lists available plugins'
          'register:register a new plugin'
          'reload:reload installed plugin backend'
        )
        _arguments -s -S \
          $vault_global_flags \
          '1:plugin command:_describe -t commands command plugin_commands' \
          '*:args:' && ret=0
        ;;
      server)
        _arguments -s -S \
          '-config=[path to a configuration file or directory]:config:_files' \
          '-dev[enable development mode]' \
          '-dev-ha[enable development mode with HA]' \
          '-dev-listen-address=[address to bind in dev mode]:address:' \
          '-dev-no-store-token[do not persist the dev root token]' \
          '-dev-root-token-id=[initial root token]:token:' \
          '-dev-tls[enable TLS in development mode]' \
          '-dev-tls-cert-dir=[directory for TLS certificate files]:directory:_directories' \
          '-log-file=[path to the log file]:log file:_files' \
          '-log-level=[log verbosity level]:level:(trace debug info warn error)' \
          '-log-format=[log output format]:format:(standard json)' \
          '-recovery[enable recovery mode]' && ret=0
        ;;
      login)
        _arguments -s -S \
          $vault_global_flags \
          '-method=[auth method type]:method:(token userpass ldap github aws azure gcp oidc cert approle radius okta)' \
          '-path=[remote path of the auth method]:path:' \
          '-no-print[do not display the token]' \
          '-no-store[do not persist the token]' \
          '-token-only[output only the token]' \
          '*:auth args:' && ret=0
        ;;
      read)
        _arguments -s -S \
          $vault_global_flags \
          '1:path:' \
          '*:key=value:' && ret=0
        ;;
      write)
        _arguments -s -S \
          $vault_global_flags \
          '-force[allow the operation even with no key=value pairs]' \
          '-f[allow the operation even with no key=value pairs]' \
          '1:path:' \
          '*:key=value:' && ret=0
        ;;
      delete)
        _arguments -s -S \
          $vault_global_flags \
          '1:path:' && ret=0
        ;;
      list)
        _arguments -s -S \
          $vault_global_flags \
          '1:path:' && ret=0
        ;;
      ssh)
        _arguments -s -S \
          $vault_global_flags \
          '-mode=[type of credential to request]:mode:(ca dynamic otp)' \
          '-mount-point=[mount point of the SSH secrets engine]:mount point:' \
          '-role=[name of the role to use]:role:' \
          '-no-exec[do not execute the SSH command]' \
          '-strict-host-key-checking=[control host key checking]:mode:(ask no yes)' \
          '-ssh-executable=[path to ssh executable]:ssh:_files' \
          '-valid-principals=[valid principals for the certificate]:principals:' \
          '1:user@host:_hosts' && ret=0
        ;;
      status)
        _arguments -s -S \
          $vault_global_flags && ret=0
        ;;
      *)
        _arguments -s -S \
          $vault_global_flags \
          '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
