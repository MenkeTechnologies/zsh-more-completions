#compdef saf
# Documentation: https://github.com/mitre/saf
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# MITRE SAF CLI (Security Automation Framework)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'attest:create and apply attestations to findings'
  'convert:translate security data between formats (to/from HDF)'
  'emasser:access eMASS REST API'
  'generate:create profiles, templates, and reports'
  'supplement:enhance HDF data with additional info'
  'validate:check compliance thresholds'
  'view:visualize findings and summaries'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-L --logLevel)'{-L+,--logLevel=}'[log level]:level:(info warn debug verbose)' \
  '--interactive[enable interactive input mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'saf command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
return ret
