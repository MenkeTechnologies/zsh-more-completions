#compdef sustack
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/stacking/sustack.c
# SUSTACK - stack adjacent traces having the same key header word

local ret=1

_arguments -s -S \
  'key=[header key word to stack on]:k:' \
  'normpow=[exponent for sample division (0 = none)]:n:' \
  'repeat=[=1 repeats the stack trace nrepeat times]:r:(0 1)' \
  'nrepeat=[repeats stack trace nrepeat times]:n:' \
  'verbose=[=1 echoes information]:v:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
