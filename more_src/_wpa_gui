#compdef wpa_gui
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man8/wpa_gui.8.html
# wpa_gui — Qt graphical frontend for wpa_supplicant

local ret=1

_arguments -s -S \
  '-p+[path where control sockets should be found]:path:_files -/' \
  '-i+[interface being configured]:ifname:_net_interfaces' \
  '-m+[signal strength meter update interval in seconds]:seconds:' \
  '-t[start program in the system tray only]' \
  '-q[run program in quiet mode (no tray pop-up messages)]' && ret=0

return ret
