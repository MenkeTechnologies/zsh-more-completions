#compdef mirrord
# Documentation: https://github.com/metalbear-co/mirrord
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'exec:execute a binary using mirrord'
  'container:create and run a container with mirrord loaded'
  'dump:print incoming tcp traffic of specific ports from remote target'
  'extract:extract mirrord-layer lib'
  'ls:list available mirrord targets in the cluster'
  'verify-config:verify mirrord config'
  'completions:generate shell completions for the provided shell'
  'ext:IDE extension support'
  'container-ext:IDE container extension support'
  'intproxy:internal proxy for mirrord-layer instances'
  'extproxy:external proxy between containers and agent'
  'operator:execute a command related to the mirrord operator'
  'port-forward:forward local ports to hosts available from the cluster'
  'newsletter:subscribe to the mirrord newsletter'
  'teams:try out mirrord for Teams'
  'diagnose:diagnose mirrord setup'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mirrord command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (exec)
        _arguments \
          '(-t --target)'{-t+,--target=}'[name of the target to mirror]:target:' \
          '(-n --target-namespace)'{-n+,--target-namespace=}'[namespace of the pod to mirror]:namespace:' \
          '(-a --agent-namespace)'{-a+,--agent-namespace=}'[agent pod namespace]:namespace:' \
          '(-l --agent-log-level)'{-l+,--agent-log-level=}'[agent log level]:level:(trace debug info warn error)' \
          '(-i --agent-image)'{-i+,--agent-image=}'[agent container image]:image:' \
          '--agent-ttl=[agent pod TTL in seconds]:seconds:' \
          '--agent-startup-timeout=[agent startup timeout in seconds]:seconds:' \
          '(-e --ephemeral-container)'{-e,--ephemeral-container}'[spawn the agent in an ephemeral container]' \
          '--fs-mode=[filesystem behavior]:mode:(read write local)' \
          '*'{-x+,--override-env-vars-exclude=}'[env vars to filter out]:vars:' \
          '*'{-s+,--override-env-vars-include=}'[env vars to select]:vars:' \
          '--no-remote-dns[disable resolving remote DNS]' \
          '*--skip-processes=[processes to run locally]:procs:' \
          '(-c --accept-invalid-certificates)'{-c,--accept-invalid-certificates}'[accept invalid certificates]' \
          '--steal[steal TCP instead of mirroring]' \
          '--no-outgoing[disable TCP/UDP outgoing traffic]' \
          '--no-tcp-outgoing[disable TCP outgoing feature]' \
          '--no-udp-outgoing[disable UDP outgoing feature]' \
          '--no-telemetry[disable telemetry]' \
          '--disable-version-check[disable version check on startup]' \
          '(-f --config-file)'{-f+,--config-file=}'[load config from file]:file:_files -g "*.{toml,json,yaml,yml}"' \
          '--context=[kube context from kubeconfig]:context:' \
          '--env-file=[path to env file]:file:_files' \
          '--key=[session identifier]:key:' \
          '*: :_command_names -e' && ret=0 ;;
      (extract)
        _arguments \
          '*: :_files -/' && ret=0 ;;
      (verify-config)
        _arguments \
          '--ide[output for IDE consumers]' \
          '--path=[config path]:file:_files -g "*.{toml,json,yaml,yml}"' && ret=0 ;;
      (completions)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
      (operator)
        _arguments \
          '1:subcommand:(setup status session)' \
          '*: :' && ret=0 ;;
      (diagnose)
        _arguments \
          '1:subcommand:(latency license)' \
          '*: :' && ret=0 ;;
      (ls)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output format]:format:(json yaml)' \
          '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
          '(-f --config-file)'{-f+,--config-file=}'[config file]:file:_files' \
          '(-t --target-type)'{-t+,--target-type=}'[target type]:type:' && ret=0 ;;
      (port-forward)
        _arguments \
          '(-c --accept-invalid-certificates)'{-c,--accept-invalid-certificates}'[accept invalid certificates]' \
          '--no-telemetry[disable telemetry]' \
          '--disable-version-check[disable version check]' \
          '(-f --config-file)'{-f+,--config-file=}'[config file]:file:_files' \
          '--context=[kube context]:context:' \
          '*-L+[forward local port to host]:mapping:' \
          '*-R+[reverse port mapping]:mapping:' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
