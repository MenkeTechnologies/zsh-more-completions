#compdef mirrord

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'exec:execute a command in mirrored env'
  'extract:extract bundled binaries'
  'login:login to mirrord cloud'
  'verify-config:verify mirrord config'
  'completions:generate shell completions'
  'ext:extension proxy'
  'internal-proxy:internal proxy'
  'external-proxy:external proxy'
  'container:run container in mirrord context'
  'container-ext:container extension'
  'operator:operator commands'
  'newsletter:newsletter management'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mirrord command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (exec)
        _arguments \
          '(-t --target)'{-t+,--target=}'[target pod]:t:' \
          '(-n --target-namespace)'{-n+,--target-namespace=}'[namespace]:ns:' \
          '(-a --agent-namespace)'{-a+,--agent-namespace=}'[agent ns]:ns:' \
          '(-l --agent-log-level)'{-l+,--agent-log-level=}'[agent log level]:l:(trace debug info warn error)' \
          '(-i --agent-image)'{-i+,--agent-image=}'[agent image]:img:' \
          '(--agent-startup-timeout)--agent-startup-timeout=[startup timeout s]:s:' \
          '(--agent-communication-timeout)--agent-communication-timeout=[comm timeout s]:s:' \
          '(-f --config-file)'{-f+,--config-file=}'[config file]:file:_files -g "*.toml *.json *.yaml *.yml"' \
          '(-c --enable-fs-ro)--fs-mode=[fs mode]:m:(read write local localwithoverrides)' \
          '(--ephemeral-container)--ephemeral-container[use ephemeral container]' \
          '(--accept-invalid-certificates)--accept-invalid-certificates[accept invalid certs]' \
          '(--steal)--steal[steal traffic]' \
          '(--no-tcp)--no-tcp[disable TCP]' \
          '(--no-udp)--no-udp[disable UDP]' \
          '(--no-remote-dns)--no-remote-dns[disable remote DNS]' \
          '(--context)--context=[k8s context]:ctx:' \
          '(--no-telemetry)--no-telemetry[disable telemetry]' \
          '*-e+[env var]:e:' \
          '*--params=[params]:p:' \
          '*: :' && ret=0 ;;
      (extract)
        _arguments \
          '*: :_files -/' && ret=0 ;;
      (verify-config)
        _arguments \
          '(--ide)--ide[IDE format]' \
          '*--path=[path]:file:_files' \
          '*: :' && ret=0 ;;
      (completions)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
      (operator)
        _arguments \
          '1:subcommand:(setup status)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
