#compdef ng

# Zsh completion for Angular CLI

_angular-cli() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'add:add support for an external library to your project'
    'analytics:configure Angular CLI usage metrics'
    'build:compile an Angular application into an output directory'
    'cache:configure persistent disk cache and retrieve cache statistics'
    'completion:set up Angular CLI autocompletion for your terminal'
    'config:retrieve or set Angular configuration values'
    'deploy:invoke the deploy builder for a specified project'
    'doc:open official Angular documentation'
    'e2e:build and serve an Angular application, then run end-to-end tests'
    'extract-i18n:extract i18n messages from source code'
    'generate:generate and/or modify files based on a schematic'
    'lint:run linting tools on Angular application code'
    'new:create a new Angular workspace'
    'run:run an Architect target with an optional custom builder configuration'
    'serve:build and serve an Angular application'
    'test:run unit tests in a project'
    'update:update your application and its dependencies'
    'version:output Angular CLI version'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'ng command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        new|n)
          _arguments -s -S \
            '--collection=[schematics collection]:collection:' \
            '--commit[commit initial git repo]' \
            '--create-application[create a new initial application]' \
            '--directory=[directory name]:directory:' \
            '--dry-run[run through and report without writing]' \
            '--force[force overwriting]' \
            '--inline-style[include styles inline]' \
            '--inline-template[include template inline]' \
            '--minimal[create a workspace without testing frameworks]' \
            '--new-project-root=[new projects root dir]:directory:' \
            '--package-manager=[package manager]:manager:(npm yarn pnpm cnpm)' \
            '--prefix=[prefix for components]:prefix:' \
            '--routing[generate a routing module]' \
            '--skip-git[do not initialize git repo]' \
            '--skip-install[do not install dependency packages]' \
            '--skip-tests[do not generate test files]' \
            '--ssr[create server-side rendered application]' \
            '--standalone[create an application based on standalone API]' \
            '--strict[strict mode]' \
            '--style=[file extension for style files]:style:(css scss sass less)' \
            '--view-encapsulation=[view encapsulation strategy]:encapsulation:(Emulated None ShadowDom)' \
            '1:name:' \
            && ret=0
          ;;
        generate|g)
          local -a schematics=(
            'application:generate an application'
            'class:generate a class'
            'component:generate a component'
            'directive:generate a directive'
            'enum:generate an enum'
            'guard:generate a guard'
            'interceptor:generate an interceptor'
            'interface:generate an interface'
            'library:generate a library'
            'module:generate a module'
            'pipe:generate a pipe'
            'resolver:generate a resolver'
            'service:generate a service'
            'service-worker:generate a service worker'
            'web-worker:generate a web worker'
            'environments:generate environment files'
            'config:generate a config'
          )
          _arguments -s -S \
            '1:schematic:->schematic' \
            '2:name:' \
            '--dry-run[report without writing]' \
            '--force[force overwriting]' \
            '--project=[project name]:project:' \
            '--flat[create files at top level]' \
            '--skip-import[do not import into owning module]' \
            '--skip-tests[do not generate test files]' \
            '--standalone[generate standalone component]' \
            && ret=0

          case $state in
            (schematic)
              _describe -t schematics 'schematic' schematics && ret=0
              ;;
          esac
          ;;
        build|b)
          _arguments -s -S \
            '--configuration=[build configuration]:config:(production development)' \
            '-c+[build configuration]:config:(production development)' \
            '--aot[build with ahead-of-time compilation]' \
            '--base-href=[base URL for the application]:URL:' \
            '--output-path=[output directory]:directory:_files -/' \
            '--output-hashing=[output file name cache-busting hashing]:mode:(none all media bundles)' \
            '--source-map[output source maps]' \
            '--watch[rebuild on changes]' \
            '--poll=[enable and set the file watching poll time in ms]:ms:' \
            '--progress[log progress to console]' \
            '--stats-json[generate a stats.json file]' \
            '--verbose[add more details to output]' \
            '1:project name:' \
            && ret=0
          ;;
        serve|s)
          _arguments -s -S \
            '--configuration=[build configuration]:config:(production development)' \
            '-c+[build configuration]:config:(production development)' \
            '--host=[host to listen on]:host:_hosts' \
            '--port=[port to listen on]:port:' \
            '--open[open URL in default browser]' \
            '-o[open URL in default browser]' \
            '--ssl[serve using HTTPS]' \
            '--ssl-key=[SSL key file]:file:_files' \
            '--ssl-cert=[SSL certificate file]:file:_files' \
            '--proxy-config=[proxy configuration file]:file:_files -g "*.json"' \
            '--hmr[enable hot module replacement]' \
            '--watch[rebuild on changes]' \
            '--poll=[poll time in ms]:ms:' \
            '--live-reload[enable live reload]' \
            '--verbose[add more details to output]' \
            '1:project name:' \
            && ret=0
          ;;
        test|t)
          _arguments -s -S \
            '--configuration=[build configuration]:config:' \
            '--code-coverage[output code coverage report]' \
            '--browsers=[browsers to use]:browsers:' \
            '--karma-config=[Karma config file]:file:_files' \
            '--progress[log progress to console]' \
            '--watch[rebuild on changes]' \
            '--source-map[output source maps]' \
            '--include=[glob patterns of files to include]:pattern:' \
            '1:project name:' \
            && ret=0
          ;;
        lint)
          _arguments -s -S \
            '--configuration=[build configuration]:config:' \
            '--fix[apply lint fixes]' \
            '--force[succeed even if there are lint errors]' \
            '--format=[output format]:format:(prose json stylish verbose compact)' \
            '--silent[show output text]' \
            '1:project name:' \
            && ret=0
          ;;
        update)
          _arguments -s -S \
            '--all[update all packages]' \
            '--allow-dirty[allow update with uncommitted changes]' \
            '--create-commits[create a git commit for each migration]' \
            '--force[ignore peer dependency version mismatches]' \
            '--from=[version from which to migrate]:version:' \
            '--migrate-only[only perform migration]' \
            '--name=[migration name]:name:' \
            '--next[use the prerelease version]' \
            '--packages=[packages to update]:packages:' \
            '--to=[version to which to migrate]:version:' \
            '--verbose[verbose output]' \
            '*:packages:' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_angular-cli "$@"
