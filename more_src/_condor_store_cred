#compdef condor_store_cred
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_store_cred.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Modes: add/delete/query (optionally with -pwd/-krb/-oauth suffix).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-pwd[password credential (default)]' \
  '-krb[Kerberos/AFS credential]' \
  '-oauth[OAuth2/Scitoken credential]' \
  '-c[pool password for PASSWORD authentication]' \
  '-f[generate pool password file]:file:_files' \
  '-i[read credential from file or stdin]:file:_files' \
  '-s[OAuth2 service name]:service:' \
  '-H[OAuth2 handle]:handle:' \
  '-S[OAuth2 scopes]:scopes:' \
  '-A[OAuth2 audience]:audience:' \
  '-P[token is an access token]' \
  '-n[target specific machine]:machine:_hosts' \
  '-p[password]:password:' \
  '-u[username]:user:_users' \
  '*::mode:(add delete query add-pwd delete-pwd query-pwd add-krb delete-krb query-krb add-oauth delete-oauth query-oauth)' && ret=0
return ret
