#compdef condor_store_cred
# Documentation: https://man.archlinux.org/search?q=condor_store_cred
# Reference accessed: 2026-05-16

# condor_store_cred: store/query/delete user credentials in HTCondor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-add[add credential]' \
  '-delete[delete credential]' \
  '-query[query credential]' \
  '-c[run as Condor pool user]' \
  '-u[user]:user:_users' \
  '-p[password]:pass:' \
  '-i[input file]:file:_files' \
  '-pool[pool]:pool:' \
  '-name[schedd/daemon]:name:' \
  '-debug[debug]' \
  '-f[from file]:file:_files' \
  '*::condor_store_cred args:_files' && ret=0
return ret
