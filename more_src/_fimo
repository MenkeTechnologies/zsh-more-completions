#compdef fimo
# Documentation: https://meme-suite.org/meme/doc/fimo.html
# MEME Suite: scan sequences for individual motif occurrences

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--o=[output directory (default fimo_out), fail if exists]:dir:_files -/' \
  '--oc=[output directory (default fimo_out), overwrite if exists]:dir:_files -/' \
  '--text[output tab-delimited text to stdout, no other files]' \
  '--skip-matched-sequence[do not output matched sequence (faster)]' \
  '--best-site[output best site per sequence-motif pair]' \
  '*--motif=[only use the motif with the given id]:id:' \
  '--motif-pseudo=[pseudocount added to motif counts]:count:' \
  '--thresh=[p-value (or q-value) threshold]:num:' \
  '--qv-thresh[use q-values for the threshold]' \
  '--no-qvalue[do not compute q-values]' \
  '--norc[do not score the reverse complement strand]' \
  '--max-strand[report only the best strand match]' \
  '--max-stored-scores=[maximum number of scores to store]:max:' \
  '--psp=[position-specific priors file]:file:_files' \
  '--prior-dist=[binned distribution of priors file]:file:_files' \
  '*:motif/sequence file:_files' && ret=0

return ret
