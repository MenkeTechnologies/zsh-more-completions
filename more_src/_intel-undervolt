#compdef intel-undervolt

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'read:read and display current values'
  'apply:apply values from config'
  'measure:measure power consumption'
  'daemon:run in daemon mode'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c+[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'intel-undervolt command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (read|apply)
        _arguments \
          '(-r --no-color)'{-r,--no-color}'[no color]' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' && ret=0 ;;
      (measure)
        _arguments \
          '(-f --format)'{-f+,--format=}'[output format]:fmt:(terminal csv)' \
          '(-s --sleep)'{-s+,--sleep=}'[sleep interval seconds]:secs:' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' && ret=0 ;;
      (daemon)
        _arguments \
          '(-f --foreground)'{-f,--foreground}'[run foreground]' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' && ret=0 ;;
    esac ;;
esac

return ret
