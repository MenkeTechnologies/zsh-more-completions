#compdef llvm-libtool-darwin
# _llvm-libtool-darwin — LLVM Darwin libtool (LLVM project, C++); create static/dynamic Mach-O libraries
# upstream: https://github.com/llvm/llvm-project

_llvm-libtool-darwin() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--static[create static library]' \
        '-static[create static library]' \
        '--dynamic[create dynamic library]' \
        '-dynamic[create dynamic library]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--filelist=+[input files list]:file:_files' \
        '-arch_only=+[only this arch]:arch:' \
        '--arch_only=+[only this arch]:arch:' \
        '-D[deterministic mode]' \
        '-no_warning_for_no_symbols[no warning for no symbols]' \
        '-warnings_as_errors[warnings as errors]' \
        '-V[verbose]' \
        '-v[verbose]' \
        '*:file:_files'
}

_llvm-libtool-darwin "$@"
