#compdef max
# _max — Modular MAX AI inference engine CLI for serving and benchmarking models (modular team, Python/Mojo); typer
# upstream: https://docs.modular.com/max/

_max() {
    local -a sub=(
        'serve:start inference server'
        'generate:run text generation'
        'benchmark:benchmark a model'
        'list-models:list available models'
        'pipelines:pipeline subcommands'
        'config:show configuration'
        'list:list pipelines'
        'install:install models'
        'docs:open docs'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--install-completion=+[shell]:s:(bash zsh fish)' \
        '--show-completion=+[shell]:s:(bash zsh fish)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'max subcommand' sub ;;
        args)
            case $words[1] in
                serve|generate|benchmark) _arguments \
                    '--model-path=+[path or hf repo]:path:' \
                    '--huggingface-revision=+[revision]:str:' \
                    '--max-length=+[max seq len]:n:' \
                    '--max-new-tokens=+[max new tokens]:n:' \
                    '--max-batch-size=+[batch size]:n:' \
                    '--max-num-steps=+[num steps]:n:' \
                    '--max-cache-batch-size=+[cache batch]:n:' \
                    '--device=+[device]:d:(cpu gpu auto)' \
                    '--devices=+[device list]:str:' \
                    '--quantization-encoding=+[encoding]:e:(bfloat16 float32 q4_0 q4_k q6_k gptq)' \
                    '--weight-path=+[weights]:file:_files' \
                    '--cache-strategy=+[strategy]:s:(continuous naive paged)' \
                    '--kv-cache-page-size=+[page size]:n:' \
                    '--enable-prefix-caching[enable prefix cache]' \
                    '--port=+[port]:port:_ports' \
                    '--host=+[host]:host:_hosts' \
                    '--task=+[task]:t:(generation embedding classification)' \
                    '--temperature=+[sampling temp]:f:' \
                    '--top-k=+[top k]:n:' \
                    '--top-p=+[top p]:f:' \
                    '--seed=+[random seed]:n:' \
                    '--use-experimental-kernels[experimental kernels]' \
                    '--prompt=+[prompt]:str:' \
                    '*:prompt:' ;;
                pipelines) _arguments '1:pipelines cmd:(list run benchmark serve install)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_max "$@"
