#compdef fga
# Documentation: https://man.archlinux.org/search?q=fga
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'store:manage stores'
  'model:manage authorization models'
  'tuple:manage relationship tuples'
  'query:run queries against the API'
  'version:print version'
  'completion:generate shell completion'
)

_arguments -C \
  '--api-url=[OpenFGA API URL]:url:' \
  '--api-token=[API token]:token:' \
  '--client-id=[OAuth client id]:id:' \
  '--client-secret=[OAuth client secret]:secret:' \
  '*--api-scopes=[OAuth scope]:scope:' \
  '--api-token-issuer=[token issuer]:issuer:' \
  '--api-audience=[token audience]:audience:' \
  '--store-id=[store id]:id:' \
  '--model-id=[authorization model id]:id:' \
  '*--custom-headers=[custom header]:KEY=VALUE:' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'fga subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (store)
        _values 'store action' list create get delete import export && ret=0
        ;;
      (model)
        _values 'model action' list get write validate test transform && ret=0
        ;;
      (tuple)
        _values 'tuple action' write delete read changes && ret=0
        ;;
      (query)
        _values 'query action' check list-objects list-relations expand list-users && ret=0
        ;;
    esac
    ;;
esac

return ret
