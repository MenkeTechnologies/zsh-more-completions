#compdef geekbench6

local curcontext="$curcontext" state line ret=1

_arguments \
  '--cpu[Run CPU benchmark]' \
  '--gpu[Run GPU benchmark]' \
  '--compute[Run compute benchmark with specified API]:api:(OpenCL Vulkan Metal CUDA)' \
  '--upload[Upload results to Geekbench Browser]' \
  '--no-upload[Do not upload results]' \
  '--save[Save results to file]:file:_files' \
  '--export-html[Export results as HTML]:file:_files' \
  '--export-json[Export results as JSON]:file:_files' \
  '--export-text[Export results as text]:file:_files' \
  '--export-pdf[Export results as PDF]:file:_files' \
  '--sysinfo[Show system information]' \
  '--unlock[Unlock Geekbench with license code]:code:' \
  '(- *)--help[Show help message]' \
  '(- *)--version[Show version information]' \
  && ret=0

return ret
