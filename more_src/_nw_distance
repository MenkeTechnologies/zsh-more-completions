#compdef nw_distance
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: print distances between nodes.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-m+[distance method: root/lca/parent/matrix]:method:(root lca parent matrix)' \
  '-n[include node labels in output]' \
  '-s+[node selection: all/labeled/inner/leaves]:sel:(all labeled inner leaves)' \
  '-t[alternative formatting (triangular/tab)]' \
  '*:newick file:_files' && ret=0

return ret
