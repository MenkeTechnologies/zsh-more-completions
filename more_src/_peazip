#compdef peazip
# Documentation: https://peazip.github.io/peazip-command-line.html
# peazip - cross-platform file and archive manager, command-line / batch switches

local ret=1

_arguments -s \
  '-add2archive[add input to a new archive, opening GUI for type and options]' \
  '-add2archive-add[add to an existing archive if found]' \
  '-add2archive-update[update only older files in the archive]' \
  '-add27z[create a new .7z archive]' \
  '-add2separate7z[add each input to a separate .7z archive]' \
  '-add2sfx7z[create a self-extracting .7z (.exe)]' \
  '-add2zip[create a new .zip archive]' \
  '-add2separatezip[add each input to a separate .zip archive]' \
  '-add2pea[create a new .pea archive]' \
  '-add2crypt[create an encrypted .pea archive]' \
  '-add2split[raw split of a single input file]' \
  '-add2brotli[create a .brotli archive]' \
  '-add2bzip2[create a .bzip2 archive]' \
  '-add2gzip[create a .gzip archive]' \
  '-add2tar[create a .tar archive]' \
  '-add2wim[create a .wim archive]' \
  '-add2xz[create a .xz archive]' \
  '-add2zstd[create a .zstd archive]' \
  '-add2zpaq[create a .zpaq archive]' \
  '-add2preset[use the Nth preset settings (0-15)]:preset number' \
  '-add2custom[use custom compression settings]' \
  '-add2wipe[securely delete the selected file(s)]' \
  '-add2compare[byte-to-byte compare two files]' \
  '-setcomment[set text as comment for archives]:comment' \
  '-setcommentf[load comment text from file]:file:_files' \
  '-removecomment[remove comment from archives]' \
  '-ext2browse[open archive in the file/archive manager GUI]' \
  '-ext2main[open the extraction interface for interactive extraction]' \
  '-ext2here[extract archive to its containing directory]' \
  '-ext2folder[extract to a new folder with smart naming]' \
  '-ext2newfolder[always extract to a fresh uniquely-named folder]' \
  '-ext2neutral[extract using the configured new-folder policy]' \
  '-ext2to[extract interactively, asking for output directory]' \
  '-ext2simple[specify output path as first parameter]:output path:_files -/' \
  '-ext2list[list archive contents]' \
  '-ext2test[test archive contents]' \
  '-peaziplanguage[change GUI language (e.g. it.txt)]:language file' \
  '-peazipreset[reset PeaZip configuration to factory settings]' \
  '-i[ignore "delete original archives after extraction"]' \
  '-o[declare output path]:output path:_files -/' \
  '-p[declare password]:password' \
  '*:file:_files' && ret=0

return ret
