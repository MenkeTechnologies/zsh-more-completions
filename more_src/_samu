#compdef samu

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-C+[change to directory before building]:directory:_directories' \
  '-f+[specify build file]:build file:_files' \
  '-j+[number of parallel jobs]:jobs' \
  '-k+[keep going until N failures]:failures' \
  '-n[dry run, do not execute commands]' \
  '-t+[run a subtool]:tool:(clean compdb list targets commands deps missingdeps inputs query recompact restat)' \
  '-v[verbose output, show full commands]' \
  '-d+[debug mode]:mode:(explain keepdepfile keeprsp)' \
  '-w+[warning flag]:warning:(dupbuild=err dupbuild=warn phonycycle=err phonycycle=warn)' \
  '-l+[load average limit]:load' \
  '*:target' && ret=0

return ret
