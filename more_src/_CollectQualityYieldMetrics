#compdef CollectQualityYieldMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectQualityYieldMetrics
# Picard: collect metrics quantifying the quality-yield of sequencing data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM or BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output metrics file]:file:_files' \
  '--USE_ORIGINAL_QUALITIES=[use original quality scores from the OQ tag]:bool:(true false)' \
  '--INCLUDE_SECONDARY_ALIGNMENTS=[include bases from secondary alignments]:bool:(true false)' \
  '--INCLUDE_SUPPLEMENTAL_ALIGNMENTS=[include bases from supplemental alignments]:bool:(true false)' \
  '--ASSUME_SORTED=[assume input is coordinate sorted]:bool:(true false)' \
  '--STOP_AFTER=[stop after processing N reads]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
