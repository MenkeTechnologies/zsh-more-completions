#compdef crowdstrike-falcon-cli falcon-cli falconctl2
# _crowdstrike-falcon-cli — CrowdStrike Falcon crowdstrike-falcon-cli CLI command-line frontend wrapping the CrowdStrike Falcon endpoint-detection-and-response cloud-native-EDR XDR identity-protection threat-intelligence cybersecurity platform CLI providing login logout whoami host detection incident vulnerability custom-ioa ioc spotlight rtr real-time-response cloud-workload-protection-CWP intel-actor-indicator-campaign-report mssp-flight-control discover-zero-trust falcon-go falcon-py (CrowdStrike team George Kurtz, Go); cobra
# upstream: https://www.crowdstrike.com/

_crowdstrike-falcon-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'host:host operations'
        'detection:detection operations'
        'incident:incident operations'
        'vulnerability:vulnerability operations'
        'custom-ioa:custom IOA operations'
        'ioc:IOC operations'
        'spotlight:Spotlight operations'
        'rtr:real-time response operations'
        'cwp:cloud workload protection ops'
        'intel:intelligence operations'
        'actor:threat actor operations'
        'indicator:indicator operations'
        'campaign:campaign operations'
        'report:intel report operations'
        'mssp:MSSP operations'
        'discover:Falcon Discover operations'
        'identity:identity protection operations'
        'falcon-x:Falcon X sandbox operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--client-id=+[id]:str:' \
        '--client-secret=+[secret]:str:' \
        '--member-cid=+[cid]:str:' \
        '--cloud=+[c]:c:(us-1 us-2 eu-1 us-gov-1)' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table csv)' \
        '--output=+[format]:f:(json yaml table csv)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'falcon subcommand' sub ;;
        args)
            case $words[1] in
                host|detection|incident|vulnerability|custom-ioa|ioc|spotlight|intel|actor|indicator|campaign|report|mssp|discover|identity) _arguments '1:op:(list get create update delete contain lift-containment hide unhide assign resolve in-progress)' '*:id:' ;;
                rtr) _arguments '1:op:(batch session command upload-script list-scripts)' '*:arg:' ;;
            esac
            ;;
    esac
}

_crowdstrike-falcon-cli "$@"
