#compdef mpris-proxy
# Documentation: https://github.com/bluez/bluez/blob/master/tools/mpris-proxy.c
# Source: BlueZ tools/mpris-proxy.c — bridge MPRIS media-player D-Bus interface to BlueZ AVRCP.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-v,--version}'[show version]' \
    '(-e --export)'{-e,--export}'[export remote players]' \
    '(-i --index)'{-i+,--index=}'[controller index]:idx:' \
    && ret=0

return ret
