#compdef cortextool
# Documentation: https://man.archlinux.org/search?q=cortextool
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'rules:lint Prometheus rules'
  'alertmanager:Alertmanager config management'
  'block:TSDB block inspection'
  'bucket:bucket operations'
  'analyze:analysis helpers'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cortextool command' commands && ret=0
    ;;
  (args)
    _arguments '*:args: _default' && ret=0
    ;;
esac

return ret
