#compdef cortextool
# Documentation: https://github.com/grafana/cortex-tools
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cortextool - Grafana's CLI for Cortex / Mimir / Loki rules and alertmanager.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'alertmanager:manage alertmanager configs and templates'
  'rules:interact with ruler configurations'
  'remote-read:access stored series via Remote Read API'
  'overrides-exporter:export per-tenant overrides as metrics'
  'acl:generate ACL headers for tenant separation'
  'analyse:extract metrics used by dashboards/rules'
  'analyze:alias for analyse'
  'commands:show available commands'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cortextool command' commands && ret=0
    ;;
  (args)
    _arguments '*:args: _default' && ret=0
    ;;
esac

return ret
