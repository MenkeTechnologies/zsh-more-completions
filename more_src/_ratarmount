#compdef ratarmount
# Documentation: https://github.com/mxmlnkn/ratarmount
# ratarmount - random access read-only tar mount via FUSE

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-u --unmount)'{-u,--unmount}'[unmount the given mount point]' \
  '--commit-overlay[apply modifications in the write overlay back to archive]' \
  '--oss-attributions[show open source attributions]' \
  '--oss-attributions-short[show short open source attributions]' \
  '(-P --parallelization)'{-P,--parallelization}'=[number of cores to use, 0 for all]:cores' \
  '(-r --recursive)'{-r,--recursive}'[mount archives inside archives recursively]' \
  '--no-recursive[disable recursive mounting]' \
  '(-w --write-overlay)'{-w,--write-overlay}'=[mount writable with overlay folder]:folder:_files -/' \
  '--password=[password to decrypt the archive]:password' \
  '--password-file=[file containing the password]:file:_files' \
  '(-c --recreate-index)'{-c,--recreate-index}'[force recreation of the index]' \
  '--no-recreate-index[do not recreate the index]' \
  '--recreate-index-on-errors[recreate index if loading errors occur]' \
  '--verify-mtime[verify modification times match the index]' \
  '--no-verify-mtime[do not verify modification times]' \
  '--index-file=[explicit index file location]:file:_files' \
  '--index-folders=[fallback folders for the index file]:folders' \
  '--force-folder-index[force using a folder index]' \
  '--no-force-folder-index[do not force a folder index]' \
  '--hashes=[hash algorithms to compute]:hashes' \
  '--mount[mount the source]' \
  '--no-mount[do not mount the source]' \
  '--recursion-depth=[maximum recursion depth]:depth' \
  '--recursive-extensions=[file extensions to recurse into]:extensions' \
  '--transform-recursive-mount-point[regex transform for recursive mount points]:regex:replacement' \
  '(-l --lazy)'{-l,--lazy}'[only read archives when accessed]' \
  '--no-lazy[disable lazy mounting]' \
  '(-s --strip-recursive-tar-extension)'{-s,--strip-recursive-tar-extension}'[strip tar extension on recursive mounts]' \
  '--no-strip-recursive-tar-extension[do not strip tar extension]' \
  '(-e --encoding)'{-e,--encoding}'=[tar file name encoding]:encoding' \
  '(-i --ignore-zeros)'{-i,--ignore-zeros}'[ignore zeroed blocks in the archive]' \
  '--no-ignore-zeros[do not ignore zeroed blocks]' \
  '--gnu-incremental[treat archive as GNU incremental backup]' \
  '--no-gnu-incremental[do not treat as GNU incremental]' \
  '--detect-gnu-incremental[auto-detect GNU incremental backups]' \
  '(-d --debug)'{-d,--debug}'=[debug output verbosity level]:level' \
  '--log-file=[log file location]:file:_files' \
  '--color[enable colored output]' \
  '--no-color[disable colored output]' \
  '(-f --foreground)'{-f,--foreground}'[keep FUSE process in foreground]' \
  '--no-foreground[run FUSE in background]' \
  '(-gs --gzip-seek-point-spacing)'{-gs,--gzip-seek-point-spacing}'=[gzip seek point spacing in MiB]:spacing' \
  '(-o --fuse)'{-o,--fuse}'=[comma separated FUSE options]:options' \
  '(-p --prefix)'{-p,--prefix}'=[prefix path to strip inside archive]:prefix' \
  '--use-backend=[backend to use for an archive type]:backend' \
  '--disable-union-mount[disable union mounting of multiple sources]' \
  '--file-versions[show all versions of files]' \
  '--no-file-versions[show only the latest file versions]' \
  '--union-mount-cache-max-depth=[union mount cache max depth]:depth' \
  '--union-mount-cache-max-entries=[union mount cache max entries]:entries' \
  '--union-mount-cache-timeout=[union mount cache timeout]:timeout' \
  '--index-minimum-file-count=[minimum file count to write an index]:count' \
  '--transform[regex transform for file paths]:regex:replacement' \
  '--control-interface[enable the mount point control interface]' \
  '--no-control-interface[disable the control interface]' \
  '*:path:_files' && ret=0

return ret
