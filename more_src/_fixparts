#compdef fixparts
# Documentation: https://www.rodsbooks.com/gdisk/fixparts.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fixparts: interactive utility from gptfdisk; supports no flags other than device specification.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:device:_files -g "/dev/*(-%)" -W /' && ret=0

return ret
