#compdef fixparts
# Documentation: https://man.archlinux.org/search?q=fixparts
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:device:_files -g "/dev/*(-%)" -W /' && ret=0

return ret
