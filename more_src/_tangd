#compdef tangd
# Documentation: https://github.com/latchset/tang/blob/master/src/tangd.c
# Reference accessed: 2026-05-16
# Verified: upstream src/tangd.c getopt_long "lp:e:vh".

# tangd: Tang network presence key server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --port)'{-p,--port=}'[listening port]:port:' \
  '(-e --endpoint)'{-e,--endpoint=}'[endpoint to listen on]:endpoint:' \
  '(-l --listen)'{-l,--listen}'[standalone mode: accept multiple connections]' \
  '*:JWK directory:_files -/' && ret=0
return ret
