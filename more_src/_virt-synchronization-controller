#compdef virt-synchronization-controller
# _virt-synchronization-controller — KubeVirt cross-cluster live-migration synchronization controller
# upstream: https://github.com/kubevirt/kubevirt
# Flags from cmd/synchronization-controller/synchronization-controller.go on tip.

_virt-synchronization-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--ca-configmap-name=[name of the CA configmap]:name:' \
        '--client-cert-file=[client TLS certificate file]:file:_files' \
        '--client-key-file=[client TLS private key file]:file:_files' \
        '--tls-cert-file=[server TLS certificate file]:file:_files' \
        '--tls-key-file=[server TLS private key file]:file:_files' \
        '--externally-managed[do not manage TLS certs internally]' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[log to stderr and files]' \
        '--stderrthreshold=[stderr threshold level]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:' \
        '--log-file=[log file destination]:file:_files'
}

_virt-synchronization-controller "$@"
