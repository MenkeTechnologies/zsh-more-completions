#compdef sonar-scanner

# Zsh completion for sonar-scanner - SonarQube/SonarCloud scanner

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)--version[display version]' \
  '-D+[define property]:property (key=value):' \
  '-Dsonar.projectKey=[project key]:key:' \
  '-Dsonar.sources=[source directories]:dirs:_directories' \
  '-Dsonar.host.url=[SonarQube server URL]:url:' \
  '-Dsonar.login=[authentication token]:token:' \
  '-Dsonar.token=[authentication token]:token:' \
  '-Dsonar.projectBaseDir=[project base directory]:dir:_directories' \
  '-Dsonar.java.binaries=[Java binaries directory]:dir:_directories' \
  '-Dsonar.exclusions=[file exclusion patterns]:patterns:' \
  '-Dsonar.test.inclusions=[test inclusion patterns]:patterns:' \
  '-Dsonar.coverage.exclusions=[coverage exclusion patterns]:patterns:' \
  '-Dsonar.language=[project language]:language:(java js ts py cs go php ruby kotlin swift)' \
  '-Dsonar.sourceEncoding=[source encoding]:encoding:(UTF-8 ISO-8859-1 US-ASCII)' \
  '-Dsonar.verbose=[enable verbose]:bool:(true false)' \
  '-Dsonar.scm.disabled=[disable SCM]:bool:(true false)' \
  '-X[produce execution debug output]' \
  '--debug[produce execution debug output]' \
  '-e[produce execution error output]' \
  '*:project directory:_directories'
