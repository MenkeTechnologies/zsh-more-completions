#compdef sequoia-sq sq
# Documentation: https://sequoia-pgp.gitlab.io/sequoia-sq/man/sq.1.html
# Reference accessed: 2026-05-21
# Verified: upstream sq(1) man page at the URL above.
# Removed from prior file: fabricated subcommands wkd, wot, autocrypt,
# dane, keyserver, completions; fake --force (real is --overwrite);
# fake --no-cert-store; fake --output as a global (it is per-subcommand).
# Added real globals: --batch, --home, --key-store, --overwrite,
# --password-file, --quiet/-q, --verbose/-v.

# sq: Sequoia OpenPGP command-line tool (Rust)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'encrypt:encrypt a message for any number of recipients/passwords'
  'decrypt:decrypt messages using supplied keys or passwords'
  'sign:create signed messages or detached signatures'
  'verify:verify signed messages or detached signatures'
  'download:download and authenticate the data'
  'inspect:inspect data, like file(1)'
  'cert:manage OpenPGP certificates (keys without secrets)'
  'key:manage OpenPGP keys (containing secret material)'
  'pki:authenticate certs using the Web of Trust'
  'network:retrieve and publish certificates over the network'
  'keyring:manage collections of keys or certs'
  'packet:low-level packet manipulation tools'
  'config:query, inspect, and create the configuration file'
  'toc:recursively list all commands'
  'version:detailed version and output version information'
)
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--batch[batch mode (no prompts)]' \
  '--cli-version=[CLI compatibility version]:ver:' \
  '--home=[home directory]:dir:_files -/' \
  '--cert-store=[cert store directory]:dir:_files -/' \
  '--key-store=[key store server location]:loc:' \
  '*--keyring=[additional keyring]:file:_files' \
  '*--known-notation=[allow unknown notation]:notation:' \
  '--overwrite[overwrite existing files]' \
  '--password-file=[seed password cache]:file:_files' \
  '--policy-as-of=[cryptographic policy as of time]:time:' \
  '(-q --quiet)'{-q,--quiet}'[reduce verbosity]' \
  '--time=[reference time (ISO 8601)]:time:' \
  '*--trust-root=[trust root fingerprint or keyid]:fpr:' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'sq command' commands && ret=0 ;;
esac
return ret
