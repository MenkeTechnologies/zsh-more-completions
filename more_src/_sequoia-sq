#compdef sequoia-sq sq
# Documentation: https://man.archlinux.org/search?q=sequoia-sq
# Reference accessed: 2026-05-16

# sq: Sequoia OpenPGP command-line tool (Rust)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'encrypt:encrypt a file'
  'decrypt:decrypt a file'
  'sign:create a signature'
  'verify:verify signatures'
  'inspect:inspect OpenPGP data'
  'key:manage keys (generate/import/export/...)'
  'cert:manage certificates'
  'pki:manage PKI / WoT (web of trust)'
  'wkd:manage Web Key Directory'
  'wot:Web of Trust commands'
  'autocrypt:Autocrypt header tool'
  'dane:DANE OPENPGPKEY tool'
  'keyring:manipulate keyrings'
  'keyserver:talk to keyserver'
  'packet:low-level packet utilities'
  'network:network commands'
  'completions:emit shell completions'
  'config:show or edit configuration'
  'version:show version'
)
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--cli-version=[CLI compatibility version]:ver:' \
  '--force[overwrite existing files]' \
  '--no-cert-store[do not use cert store]' \
  '--cert-store=[cert store directory]:dir:_files -/' \
  '--keyring=[additional keyring]:file:_files' \
  '--known-notation=[allow unknown notation]:notation:' \
  '--output=[output file]:file:_files' \
  '--policy-as-of=[policy as of date]:date:' \
  '--time=[time to use for validity]:date:' \
  '--trust-root=[trust root certificate]:fingerprint:' \
  '--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'sq command' commands && ret=0 ;;
esac
return ret
