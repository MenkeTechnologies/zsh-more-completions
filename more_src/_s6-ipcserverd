#compdef s6-ipcserverd
# _s6-ipcserverd — s6 conn-tools s6-ipcserverd (per-connection dispatcher used inside s6-ipcserver; not invoked directly — reads a bound socket on fd 0 and forks `prog` for each accepted connection)
# upstream: https://github.com/skarnet/s6
# Flags from src/conn-tools/s6-ipcserverd.c on tip.

_s6-ipcserverd() {
    _arguments \
        '-v+[verbosity]:n:' \
        '-1[print bound socket info on fd 1]' \
        '(-p -P)-p[look up uid/gid for peers]' \
        '(-p -P)-P[skip peer uid/gid lookup]' \
        '-c+[max simultaneous connections]:n:' \
        '-C+[max simultaneous connections per local uid]:n:' \
        '*::program:_command_names -e'
}

_s6-ipcserverd "$@"
