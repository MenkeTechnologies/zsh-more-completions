#compdef clearml-param-search
# Documentation: https://github.com/clearml/clearml
# Reference accessed: 2026-05-23
# Verified: clearml-param-search --help (ClearML HPO CLI).

# Zsh completion for clearml-param-search - ClearML hyperparameter optimization CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--project-name[project name]:project:' \
  '--task-name[task name]:name:' \
  '--task-id[base task ID]:id:' \
  '--script[script path]:file:_files' \
  '--queue[execution queue]:queue:' \
  '--params-search[search space params]:params:' \
  '--params-override[parameter overrides]:params:' \
  '--objective-metric-title[objective metric title]:metric:' \
  '--objective-metric-series[objective metric series]:series:' \
  '--objective-metric-sign[optimization direction]:sign:(min max min_global max_global)' \
  '--optimizer-class[optimizer]:class:(OptimizerOptuna OptimizerBOHB GridSearch RandomSearch)' \
  '--optimization-time-limit[optimization time limit seconds]:seconds:' \
  '--compute-time-limit[compute time limit seconds]:seconds:' \
  '--pool-period-min[pool period minutes]:minutes:' \
  '--total-max-jobs[max total jobs]:n:' \
  '--max-number-of-concurrent-tasks[max concurrent tasks]:n:' \
  '--args[extra arguments]:args:' \
  '--local[run locally]' && ret=0

return ret
