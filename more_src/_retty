#compdef retty
# Documentation: https://man.archlinux.org/search?q=retty
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-l[list ttys]' \
  '1:pid:_pids' \
  '*:tty:_files -g "/dev/{tty,pts/*}"' && ret=0

return ret
