#compdef retty
# Documentation: http://pasky.or.cz/dev/retty/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. STUB - canonical CLI undocumented.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-l[list ttys]' \
  '1:pid:_pids' \
  '*:tty:_files -g "/dev/{tty,pts/*}"' && ret=0

return ret
