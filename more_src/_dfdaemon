#compdef dfdaemon
# _dfdaemon — Dragonfly high-performance P2P download daemon (dragonflyoss/client)
# upstream: https://github.com/dragonflyoss/client
# Flags from dragonfly-client/src/bin/dfdaemon/main.rs (clap).

_dfdaemon() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.(yml|yaml)"' \
        '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(trace debug info warn error)' \
        '--log-dir=[log directory]:dir:_files -/' \
        '--log-max-files=[max number of log files]:n:' \
        '--console=[print log to console]:bool:(true false)'
}

_dfdaemon "$@"
