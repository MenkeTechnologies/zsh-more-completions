#compdef gitea tea
# Documentation: https://man.archlinux.org/search?q=gitea
# Reference accessed: 2026-05-16

# go-gitea/gitea cmd/main.go (urfave/cli v3): global -w/--work-path, -c/--config, -C/--custom-path.
# Subcommands include web (default), serv, hook, keys, dump, admin, migrate, doctor, manager,
# embedded, migrate-storage, dump-repo, restore-repo, actions, config, cert, generate, docs.

local curcontext="$curcontext" state line ret=1
local -a giteasub

giteasub=(
  'web:start HTTP(S) service'
  'serv:git smart HTTP'
  'hook:git hook helpers'
  'keys:key management'
  'dump:dump data'
  'admin:CLI admin tasks'
  'migrate:database migrations'
  'doctor:diagnostics'
  'manager:process manager'
  'embedded:embedded assets'
  'migrate-storage:relocate binary storage'
  'dump-repo:dump single repository'
  'restore-repo:restore repository dump'
  'actions:Gitea Actions helpers'
  'config:config helpers'
  'cert:certificate helpers'
  'generate:secret generation'
  'docs:dump CLI docs'
)

case $service in
  tea)
    _arguments -s -S -C \
	  '(- *)'{-h,--help}'[show help]' \
	  '(- *)'{-v,--version}'[show version]' \
	  '--login=[use a different login]:login' \
	  '--repo=[repository slug]:owner/repo' \
	  '--remote=[remote name]:remote' \
	  '--output=[output format]:format:(simple table csv tsv yaml json)' \
	  '1:command:->commands' \
	  '*::arg:->args' && ret=0

    case $state in
      commands)
	local -a commands=(
	  'comment:manage issue/PR comments'
	  'issues:manage issues'
	  'labels:manage labels'
	  'login:manage Gitea logins'
	  'milestones:manage milestones'
	  'notifications:manage notifications'
	  'open:open repo in browser'
	  'organizations:manage organizations'
	  'pulls:manage pull requests'
	  'releases:manage releases'
	  'repos:manage repositories'
	  'times:manage tracked times'
	)
	_describe -t commands 'tea command' commands && ret=0
	;;
      args)
	case $line[1] in
	  issues)
	    _arguments -s -S \
	      '(- *)'{-h,--help}'[show help]' \
	      '1:subcommand:(list create close reopen edit)' && ret=0
	    ;;
	  pulls)
	    _arguments -s -S \
	      '(- *)'{-h,--help}'[show help]' \
	      '1:subcommand:(list create close checkout approve reject merge review)' && ret=0
	    ;;
	  repos)
	    _arguments -s -S \
	      '(- *)'{-h,--help}'[show help]' \
	      '1:subcommand:(list create delete fork migrate search)' && ret=0
	    ;;
	  releases)
	    _arguments -s -S \
	      '(- *)'{-h,--help}'[show help]' \
	      '1:subcommand:(list create delete edit)' && ret=0
	    ;;
	  login)
	    _arguments -s -S \
	      '(- *)'{-h,--help}'[show help]' \
	      '1:subcommand:(add default delete edit list)' && ret=0
	    ;;
	  labels)
	    _arguments -s -S \
	      '(- *)'{-h,--help}'[show help]' \
	      '1:subcommand:(list create delete update)' && ret=0
	    ;;
	  milestones)
	    _arguments -s -S \
	      '(- *)'{-h,--help}'[show help]' \
	      '1:subcommand:(list create close delete reopen issues)' && ret=0
	    ;;
	  organizations)
	    _arguments -s -S \
	      '(- *)'{-h,--help}'[show help]' \
	      '1:subcommand:(list create delete)' && ret=0
	    ;;
	esac
	;;
    esac
    ;;
  gitea)
    _arguments -s -S -C \
      '(-w --work-path)'{-w,--work-path}"=[Gitea work path]:dir:_files -/" \
      '(-c --config)'{-c,--config}"=[app.ini path]:file:_files" \
      '(-C --custom-path)'{-C,--custom-path}"=[custom path]:dir:_files -/" \
      '1: :->gsub' \
      '*:: :->grest' && ret=0
    case $state in
      gsub)
	_describe -t commands 'gitea command' giteasub && ret=0
	;;
      grest)
	case $line[1] in
	  web)
	    _arguments -s -S \
	      '(-p --port)'{-p,--port}"=[temporary HTTP port]:port" \
	      '--install-port=[installer UI port]:port' \
	      '(-P --pid)'{-P,--pid}"=[pid file path]:file:_files" \
	      '(-q --quiet)'{-q,--quiet}'[quiet until logging ready]' \
	      '--verbose[trace logging until ready]' && ret=0
	    ;;
	  migrate-storage)
	    _arguments -s -S \
	      '(-t --type)'{-t,--type}"=[storage kind]:type:(attachments lfs avatars repo-avatars repo-archivers packages actions-log actions-artifacts)" \
	      '(-s --storage)'{-s,--storage}"=[destination backend]:dest:(local minio azureblob)" \
	      '(-p --path)'{-p,--path}"=[local path]:dir:_files -/" \
	      '--minio-endpoint=[endpoint]' \
	      '--minio-access-key-id=[key]' \
	      '--minio-secret-access-key=[secret]' \
	      '--minio-bucket=[bucket]' \
	      '--minio-location=[location]' \
	      '--minio-base-path=[prefix]' \
	      '--minio-use-ssl[use TLS]' \
	      '--minio-insecure-skip-verify[skip TLS verify]' \
	      '--azureblob-endpoint=[endpoint]' \
	      '--azureblob-account-name=[account]' \
	      '--azureblob-account-key=[key]' \
	      '--azureblob-container=[container]' \
	      '--azureblob-base-path=[prefix]' && ret=0
	    ;;
	  *)
	    _normal && ret=0
	    ;;
	esac
	;;
    esac
    ;;
esac

return ret
