#compdef scrttv
# Documentation: https://docs.gempa.de/seiscomp/current/apps/scrttv.html
# SeisComP scrttv: real-time trace view (GUI)

local ret=1

_arguments -s -S \
'(-h --help)'{-h,--help}'[show help message]' \
  '(-V --version)'{-V,--version}'[show version information]' \
  '--config-file=[alternative configuration file]:file:_files' \
  '--plugins=[load named plugins]:plugins:' \
  '(-D --daemon)'{-D,--daemon}'[run as daemon]' \
  '--auto-shutdown=[enable self-shutdown on master shutdown]:arg:' \
  '--verbosity=[verbosity level 0..4]:level:(0 1 2 3 4)' \
  '*'{-v,--v}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[suppress logging output]' \
  '--component=[limit logging to component]:component:' \
  '(-s --syslog)'{-s,--syslog}'[log to syslog]' \
  '(-l --lockfile)'{-l+,--lockfile=}'[lock file path]:file:_files' \
  '--console=[direct log output to stdout]:arg:' \
  '--debug[run in debug mode]' \
  '--log-file=[alternative log file]:file:_files' \
  '(-u --user)'{-u+,--user=}'[override connection username]:user:' \
  '(-H --host)'{-H+,--host=}'[override connection server]:host:_hosts' \
  '(-t --timeout)'{-t+,--timeout=}'[override connection timeout]:seconds:' \
  '(-g --primary-group)'{-g+,--primary-group=}'[override primary group]:group:' \
  '*'{-S,--subscribe-group=}'[subscribe to group]:group:' \
  '--db-driver-list[list supported database drivers]' \
  '(-d --database)'{-d+,--database=}'[database connection string]:db:' \
  '--config-module=[configuration module]:module:' \
  '--inventory-db=[load inventory from database or file]:db:' \
  '--db-disable[disable database usage]' \
  '--record-driver-list[list supported record stream drivers]' \
  '(-I --record-url)'{-I+,--record-url=}'[RecordStream source URL]:url:' \
  '--record-file=[file as record source]:file:_files' \
  '--record-type=[record type]:type:' \
  '--offline[run in offline mode without messaging]' && ret=0

return ret
