#compdef agentql
# Documentation: https://github.com/tinyfish-io/agentql
# Reference accessed: 2026-05-23
# Verified: agentql --help (Typer CLI).

# Zsh completion for agentql - AgentQL browser automation CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--install-completion[install shell completion]' \
  '--show-completion[show shell completion script]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'agentql command' \
      'init[initialize AgentQL project]' \
      'doctor[check system before running AgentQL]' \
      'new-script[download template script]' && ret=0
    ;;
esac

return ret
