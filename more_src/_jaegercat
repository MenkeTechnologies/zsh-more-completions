#compdef jaegercat
# Documentation: https://github.com/sile/jaegercat
# jaegercat - command line tool showing traces emitted by Jaeger clients

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--binary-thrift-port=[binary Thrift protocol port]:port:' \
  '--compact-thrift-port=[compact Thrift protocol port]:port:' \
  '(-f --format)'{-f,--format}'=[output format]:format:(raw json json-pretty)' \
  '--log-level=[logging verbosity]:level:(debug info error)' \
  '(-b --udp-buffer-size)'{-b,--udp-buffer-size}'=[UDP buffer size in bytes]:bytes:' && ret=0

return ret
