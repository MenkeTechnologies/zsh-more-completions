#compdef bedpostx
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/diffusion/fdt/index.html
# bedpostx - Bayesian estimation of diffusion parameters with crossing fibres

local ret=1

_arguments -s -S \
  '-n[number of fibres per voxel (default 3)]:n:' \
  '-w[ARD weight, more weight means fewer secondary fibres]:w:' \
  '-b[burn-in period]:b:' \
  '-j[number of jumps]:j:' \
  '-s[sample every]:s:' \
  '-model[deconvolution model (1=mono,2=multi,3=zeppelins)]:model:(1 2 3)' \
  '-g[gradient nonlinearity tensor file]:file:_files' \
  '--noard[turn ARD off on all fibres]' \
  '--allard[turn ARD on on all fibres]' \
  '--nospat[use initial flat priors (non-spatial)]' \
  '--nonlinear[nonlinear orientation model]' \
  '--cnonlinear[constrained nonlinear orientation model]' \
  '--rician[use Rician noise modelling]' \
  '--f0[add to model an unattenuated signal compartment]' \
  '--seed[seed for pseudo random number generator]:seed:' \
  '--forcedir[use the actual directory name given]' \
  '1:subject directory:_files -/' && ret=0

return ret
