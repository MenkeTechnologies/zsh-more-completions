#compdef ogr2ogr

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--long-usage[show long usage]' \
  '(- *)--version[show version]' \
  '-f+[output format]:format:(GeoJSON "ESRI Shapefile" GPKG PostgreSQL CSV KML GML SQLite MapInfo\ File DXF FlatGeobuf GeoJSONSeq MVT PMTiles Parquet Arrow)' \
  '-append[append to existing layer]' \
  '-overwrite[overwrite existing layer]' \
  '-update[open existing output datasource in update mode]' \
  '-select+[select fields]:field list' \
  '-where+[attribute query]:WHERE clause' \
  '-sql+[SQL statement]:SQL' \
  '-dialect+[SQL dialect]:dialect:(OGRSQL SQLITE)' \
  '-spat+[spatial filter extent]:xmin ymin xmax ymax' \
  '-geomfield+[geometry field for spatial filter]:field name' \
  '-dsco+[dataset creation option]:NAME=VALUE' \
  '-lco+[layer creation option]:NAME=VALUE' \
  '-nln+[new layer name]:name' \
  '-nlt+[new layer type]:type:(NONE GEOMETRY POINT LINESTRING POLYGON MULTIPOINT MULTILINESTRING MULTIPOLYGON GEOMETRYCOLLECTION PROMOTE_TO_MULTI CONVERT_TO_LINEAR CONVERT_TO_CURVE)' \
  '-dim+[coordinate dimension]:dimension:(2 3 XY XYZ XYM XYZM layer_dim)' \
  '-a_srs+[assign output SRS]:SRS:(EPSG\:4326 EPSG\:3857)' \
  '-t_srs+[reproject to SRS]:SRS:(EPSG\:4326 EPSG\:3857)' \
  '-s_srs+[source SRS override]:SRS:(EPSG\:4326 EPSG\:3857)' \
  '-ct+[coordinate transformation pipeline]:pipeline' \
  '-preserve_fid[preserve feature IDs]' \
  '-fid+[only fetch feature with this FID]:FID' \
  '-limit+[limit number of features]:count' \
  '-oo+[open option]:NAME=VALUE' \
  '-doo+[destination open option]:NAME=VALUE' \
  '-gt+[group N features per transaction]:count' \
  '-ds_transaction[use dataset transactions]' \
  '-clipsrc+[clip geometries to source area]:xmin ymin xmax ymax' \
  '-clipsrcsql+[SQL for clip source]:SQL' \
  '-clipsrclayer+[layer for clip source]:layer name' \
  '-clipsrcwhere+[WHERE for clip source]:WHERE clause' \
  '-clipdst+[clip geometries to destination area]:xmin ymin xmax ymax' \
  '-clipdstsql+[SQL for clip destination]:SQL' \
  '-clipdstlayer+[layer for clip destination]:layer name' \
  '-clipdstwhere+[WHERE for clip destination]:WHERE clause' \
  '-wrapdateline[wrap geometries across dateline]' \
  '-datelineoffset+[dateline offset]:offset' \
  '-simplify+[simplify geometries]:tolerance' \
  '-segmentize+[maximum segment length]:length' \
  '-makevalid[attempt to fix invalid geometries]' \
  '-fieldTypeToString+[convert field type to string]:type:(Integer Integer64 Real String Date Time DateTime Binary IntegerList Integer64List RealList StringList)' \
  '-mapFieldType+[map field type]:src_type=dst_type' \
  '-unsetFieldWidth[unset field width]' \
  '-splitlistfields[split list fields]' \
  '-maxsubfields+[max subfields for splitting]:count' \
  '-explodecollections[produce one feature for each geometry in a collection]' \
  '-zfield+[use field as Z component]:field name' \
  '-gcp+[ground control point]:pixel line easting northing' \
  '-order+[polynomial order for GCP transformation]:order:(1 2 3)' \
  '-tps[use thin plate spline transformer]' \
  '-fieldmap+[field map]:field indices' \
  '-addfields[add new fields to existing layer]' \
  '-relaxedFieldNameMatch[match field names case-insensitively]' \
  '-forceNullable[allow null values]' \
  '-unsetDefault[unset default field values]' \
  '-unsetFid[unset FID field]' \
  '-nomd[do not copy metadata]' \
  '-mo+[metadata option]:NAME=VALUE' \
  '-noNativeData[do not copy native data]' \
  '-progress[display progress]' \
  '-q[quiet mode]' \
  '-skipfailures[continue after failures]' \
  '1:destination datasource:_files' \
  '2:source datasource:_files' \
  '3:layer name:'
