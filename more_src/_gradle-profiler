#compdef gradle-profiler
# Documentation: https://github.com/gradle/gradle-profiler#readme
# Gradle Profiler - profile and benchmark Gradle builds

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--project-dir=[directory containing the build to run]:dir:_files -/' \
  '--benchmark[benchmark the build with multiple runs and statistics]' \
  '--profile=[profile using the named profiler]:profiler:(buildscan async-profiler jfr jprofiler yourkit heap-dump chrome-trace)' \
  '*--scenario-file=[path to scenario configuration file]:file:_files' \
  '--output-dir=[directory for results]:dir:_files -/' \
  '--dump-scenarios[output resolved scenario configuration without running]' \
  '*--gradle-version=[Gradle version to use]:version:' \
  '--gradle-user-home=[Gradle user home directory]:dir:_files -/' \
  '--no-daemon[run builds without the daemon]' \
  '--cold-daemon[use a freshly started daemon instead of a warm one]' \
  '--cli[use the command-line client instead of the tooling API]' \
  '--single-shot[run a single measured build with no warm-ups]' \
  '--warmups=[number of warm-up builds]:count:' \
  '--iterations=[number of builds to measure]:count:' \
  '*--group=[run scenarios from the named group]:group:' \
  '--bazel[benchmark using Bazel instead of Gradle]' \
  '--buck[benchmark using Buck instead of Gradle]' \
  '--maven[benchmark using Maven instead of Gradle]' \
  '*--measure-build-op=[measure the named build operation]:op:' \
  '--measure-config-time[capture configuration timing details]' \
  '--measure-gc[measure garbage collection time]' \
  '--measure-local-build-cache[track local build cache size]' \
  '--build-ops-trace[generate build operations trace files]' \
  '--csv-format=[CSV output format]:format:(wide long)' \
  '--no-diffs[skip differential flame graph generation]' \
  '--async-profiler-event=[event to sample]:event:(cpu wall lock alloc)' \
  '--async-profiler-count=[aggregation type]:count:(samples total)' \
  '--async-profiler-interval=[sampling interval in nanoseconds]:ns:' \
  '--async-profiler-alloc-interval=[allocation sampling interval]:bytes:' \
  '--async-profiler-lock-threshold=[lock sampling threshold]:ns:' \
  '--async-profiler-wall-interval=[wall-clock sampling interval]:ns:' \
  '--async-profiler-stackdepth=[maximum stack depth]:depth:' \
  '--async-profiler-system-threads[include system threads in profiles]' \
  '--async-profiler-home=[async-profiler installation directory]:dir:_files -/' \
  '--jprofiler-config=[JProfiler configuration]:config:(sampling-all instrumentation)' \
  '--jprofiler-session=[JProfiler session id]:id:' \
  '--jprofiler-home=[JProfiler installation directory]:dir:_files -/' \
  '--jfr-settings=[JFR configuration file or template name]:settings:_files' \
  '--idea-install-dir=[IntelliJ IDEA installation directory]:dir:_files -/' \
  '--idea-sandbox-dir=[IDE sandbox directory]:dir:_files -/' \
  '--no-idea-sandbox[use default IDE folders]' \
  '--studio-install-dir=[Android Studio installation directory]:dir:_files -/' \
  '--studio-sandbox-dir=[Studio sandbox directory]:dir:_files -/' \
  '--no-studio-sandbox[use default Studio folders]' \
  '*-D-[define a system property for builds]:property:' \
  '*:task:' && ret=0

return ret
