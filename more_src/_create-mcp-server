#compdef create-mcp-server
# Documentation: https://www.npmjs.com/package/@modelcontextprotocol/create-server
# Reference accessed: 2026-05-24
# Verified: npx create-mcp-server --help.

# Zsh completion for create-mcp-server - MCP server scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-n --name)'{-n,--name=}'[server name]:name:' \
  '(-d --description)'{-d,--description=}'[server description]:description:' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':directory:_directories' && ret=0

return ret
