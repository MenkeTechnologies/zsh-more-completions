#compdef viztracer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-o+[output file]:output file:_files -g "*.(json|html)"' \
  '--output_file=[output file]:output file:_files -g "*.(json|html)"' \
  '-p+[port for web server]:port' \
  '--port=[port for web server]:port' \
  '--open[open report in browser after generation]' \
  '-m+[run library module as script]:module' \
  '--tracer_entries=[number of tracer entries]:count' \
  '--max_stack_depth=[max stack depth]:depth' \
  '--min_duration=[minimum event duration in ns]:nanoseconds' \
  '--ignore_c_function[ignore C functions]' \
  '--ignore_frozen[ignore frozen modules]' \
  '--log_func_retval[log function return values]' \
  '--log_func_args[log function arguments]' \
  '--log_print[log print statements]' \
  '--log_gc[log garbage collection]' \
  '--log_sparse[log sparse mode]' \
  '--log_async[log async functions]' \
  '--log_audit[log audit events]' \
  '--log_exception[log exceptions]' \
  '--include_files=[include files matching pattern]:pattern' \
  '--exclude_files=[exclude files matching pattern]:pattern' \
  '--ignore_c_function[ignore C functions]' \
  '--vdb[open VizViewer in VDB mode]' \
  '--pid_suffix[add PID suffix to output file]' \
  '--save_flamegraph[save flamegraph data]' \
  '--generate_flamegraph=[generate flamegraph HTML]:file:_files -g "*.html"' \
  '--combine=[combine multiple traces]:files:_files -g "*.json"' \
  '--align_combine[align combined traces]' \
  '*:script:_files -g "*.py"' && ret=0

return ret
