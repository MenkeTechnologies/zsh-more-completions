#compdef viztracer
# Documentation: https://viztracer.readthedocs.io/en/stable/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o --output_file)'{-o+,--output_file=}'[output file]:output file:_files -g "*.(json|html|json.gz)"' \
  '(-u --unique_output_file)'{-u,--unique_output_file}'[generate unique output filename]' \
  '--output_dir=[directory for output files]:dir:_directories' \
  '--rcfile=[configuration file]:file:_files' \
  '(-p --port)'{-p+,--port=}'[port for web server]:port:' \
  '--server_only[host HTTP server without opening browser]' \
  '--once[server shuts down after serving the file]' \
  '--open[open report in browser after generation]' \
  '-m+[run library module as script]:module:' \
  '--tracer_entries=[circular buffer size]:count:' \
  '--max_stack_depth=[max stack depth]:depth:' \
  '--min_duration=[minimum event duration]:duration:' \
  '--ignore_c_function[ignore C functions]' \
  '--ignore_frozen[ignore frozen modules]' \
  '--log_func_retval[log function return values]' \
  '--log_func_args[log function arguments]' \
  '--log_func_with_objprint[log arguments and return values using objprint]' \
  '--log_func_entry=[log function call as instant event]:pattern:' \
  '--log_func_exec=[log function execution details]:pattern:' \
  '--log_print[log print statements]' \
  '--log_gc[log garbage collection]' \
  '--log_sparse[log sparse mode]' \
  '--log_async[log asyncio tasks as separate threads]' \
  '--log_audit=[log Python audit events]:pattern:' \
  '--log_exception[log raised exceptions]' \
  '--log_exit[log atexit/exit hooks]' \
  '--log_var=[log matching variables]:pattern:' \
  '--log_number=[log numeric Counter events]:pattern:' \
  '--log_attr=[log attribute assignments]:pattern:' \
  '--log_torch[log PyTorch native calls and GPU events]' \
  '--include_files=[include files matching pattern]:pattern:' \
  '--exclude_files=[exclude files matching pattern]:pattern:' \
  '--pid_suffix[append PID suffix to output files]' \
  '--combine=[combine multiple JSON traces]:files:_files -g "*.json"' \
  '--align_combine=[align combined traces]:files:_files -g "*.json"' \
  '--compress=[compress JSON report]:file:_files' \
  '--decompress=[decompress JSON report]:file:_files' \
  '*:script:_files -g "*.py"' && ret=0

return ret
