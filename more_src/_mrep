#compdef mrep
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-group[reply to all recipients]' \
  '-from[set From header]:address:' \
  '-to[set To header]:address:' \
  '-cc[set Cc header]:address:' \
  '-bcc[set Bcc header]:address:' \
  '-attach[attach a file]:file:_files' \
  '*:message:_files' && ret=0

return ret
