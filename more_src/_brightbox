#compdef brightbox
# Documentation: https://www.brightbox.com/docs/guides/cli/
# Brightbox Cloud CLI for managing Brightbox API resources

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:command:((login\:"log in with user credentials" config\:"manage CLI configuration and API clients" accounts\:"manage accounts" servers\:"manage cloud servers" images\:"manage images" server-groups\:"manage server groups" cloud-ips\:"manage cloud IPs" firewall-policies\:"manage firewall policies" load-balancers\:"manage load balancers" help\:"show help"))' && ret=0

return ret
