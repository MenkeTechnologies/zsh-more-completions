#compdef licensecheck

_licensecheck() {
  _arguments \
    '(-c --check)'{-c,--check}'=[check header against template]:template:_files' \
    '(-f --format)'{-f,--format}'=[output format]:format:(text csv json)' \
    '(-l --license)'{-l,--license}'=[specify license type]:license:(Apache-2.0 MIT BSD-2-Clause BSD-3-Clause GPL-2.0 GPL-3.0 LGPL-2.1 LGPL-3.0 MPL-2.0 ISC)' \
    '(-r --recurse)'{-r,--recurse}'[recurse into subdirectories]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-i --ignore)'{-i,--ignore}'=[ignore files matching pattern]:pattern' \
    '--copyright=[copyright holder name]:name' \
    '--year=[copyright year]:year' \
    '--skip-dirs=[directories to skip]:dirs' \
    '--skip-files=[files to skip]:files' \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '*:file or directory:_files'
}

_licensecheck "$@"
