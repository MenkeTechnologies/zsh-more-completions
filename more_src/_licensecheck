#compdef licensecheck
# Documentation: https://manpages.debian.org/testing/devscripts/licensecheck.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# licensecheck (devscripts) - simple license checker for source files

_licensecheck() {
  _arguments \
    '--help[show help]' \
    '--version[show version]' \
    '--no-conf[do not read devscripts config files]' \
    '--noconf[do not read devscripts config files]' \
    '--verbose[verbose output]' \
    '--no-verbose[suppress verbose output]' \
    '(-l --lines)'{-l+,--lines=}'[number of lines to check]:N:' \
    '(-i --ignore)'{-i+,--ignore=}'[ignore files matching regex]:regex:' \
    '(-c --check)'{-c+,--check=}'[only check files matching regex]:regex:' \
    '(-m --machine)'{-m,--machine}'[machine-readable output]' \
    '(-r --recursive)'{-r,--recursive}'[recurse into directories]' \
    '--copyright[output detected copyright statement]' \
    '*:file or directory:_files'
}

_licensecheck "$@"
