#compdef mrsk kamal

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'deploy:deploy the app to servers'
  'redeploy:deploy the app without running the pre-deploy hook'
  'rollback:rollback the app to a previous version'
  'details:show details about the app'
  'audit:show audit log'
  'config:show configuration'
  'init:create config stub and deploy scripts'
  'envify:create .env file from secrets'
  'remove:remove application from servers'
  'version:show version'
  'accessory:manage accessories'
  'app:manage the application'
  'build:manage Docker builds'
  'env:manage environment variables'
  'healthcheck:manage healthchecks'
  'lock:manage deploy lock'
  'prune:prune old images and containers'
  'registry:login/logout container registry'
  'server:bootstrap servers with Docker'
  'traefik:manage Traefik proxy'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[configuration file]:config file:_files -g "*.yml"' \
  '--config-file=[configuration file]:config file:_files -g "*.yml"' \
  '-d+[destination]:destination' \
  '--destination=[destination]:destination' \
  '-H+[run on specific hosts]:hosts' \
  '--hosts=[run on specific hosts]:hosts' \
  '-R+[roles to apply to]:roles' \
  '--roles=[roles to apply to]:roles' \
  '-p[use primary host only]' \
  '--primary[use primary host only]' \
  '-P[print raw output without pretty formatting]' \
  '--skip-hooks[skip deploy hooks]' \
  '-q[suppress informational messages]' \
  '--quiet[suppress informational messages]' \
  '-V+[version to deploy]:version' \
  '--version=[version to deploy]:version' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'kamal command' commands && ret=0
    ;;
esac

return ret
