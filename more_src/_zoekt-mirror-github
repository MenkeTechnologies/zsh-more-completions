#compdef zoekt-mirror-github
# _zoekt-mirror-github — Zoekt GitHub repository mirror
# upstream: https://github.com/sourcegraph/zoekt
# Flags from cmd/zoekt-mirror-github/main.go on tip.

_zoekt-mirror-github() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-dest=[destination directory]:dir:_files -/' \
        '-url=[GitHub Enterprise URL (default github.com)]:url:_urls' \
        '-org=[organization to mirror]:org:' \
        '-user=[user to mirror]:user:' \
        '-token=[file holding API token]:file:_files' \
        '-forks=[also mirror forks]:bool:(true false)' \
        '-delete=[delete missing repos]:bool:(true false)' \
        '-name=[regex of repo names to clone]:regex:' \
        '-exclude=[regex of repo names to skip]:regex:' \
        '*-topic=[only clone repos with this topic (repeatable)]:topic:' \
        '*-exclude_topic=[skip repos with this topic (repeatable)]:topic:' \
        '-no_archived=[mirror only non-archived repos]:bool:(true false)' \
        '*-visibility=[repo visibility filter (repeatable)]:vis:(public private internal)'
}

_zoekt-mirror-github "$@"
