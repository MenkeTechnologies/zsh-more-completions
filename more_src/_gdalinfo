#compdef gdalinfo

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-json[output in JSON format]' \
  '-mm[report min/max values]' \
  '-stats[report statistics]' \
  '-approx_stats[report approximate statistics]' \
  '-hist[report histogram]' \
  '-nogcp[suppress GCP info]' \
  '-nomd[suppress metadata]' \
  '-norat[suppress raster attribute table]' \
  '-noct[suppress color table]' \
  '-nofl[suppress file list]' \
  '-checksum[report checksums]' \
  '-listmdd[list metadata domains]' \
  '-mdd+[report metadata for domain]:domain' \
  '-proj4[report SRS in PROJ.4 format]' \
  '-wkt_format+[WKT format]:format:(WKT1 WKT2 WKT2_2015 WKT2_2019)' \
  '-sd+[subdataset number]:number' \
  '-oo+[open option]:NAME=VALUE' \
  '-if+[input format]:format' \
  '1:dataset:_files'
