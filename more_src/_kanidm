#compdef kanidm

# Zsh completion for kanidm (identity management CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-H --url)'{-H,--url}'[server URL]:URL' \
  '(-D --name)'{-D,--name}'[authenticate as name]:name' \
  '(-C --ca)'{-C,--ca}'[CA certificate path]:ca cert:_files' \
  '--output-mode[output mode]:mode:(text json)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'login:authenticate to the server'
      'logout:destroy current session'
      'self:manage your own account'
      'person:manage person accounts'
      'group:manage groups'
      'service-account:manage service accounts'
      'oauth2:manage OAuth2 resource servers'
      'system:system configuration'
      'domain:manage domain settings'
      'recycle-bin:manage recycle bin'
      'raw:raw LDAP-like operations'
      'version:show version'
      'help:show help for a subcommand'
    )
    _describe -t commands 'kanidm subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      person|group|service-account)
        local -a entity_subcmds=(
          'create:create a new entry'
          'delete:delete an entry'
          'get:get entry details'
          'list:list entries'
          'update:update an entry'
        )
        _describe -t commands 'subcommand' entity_subcmds && ret=0
        ;;
      help)
        local -a subcmds=(login logout self person group service-account oauth2 system domain recycle-bin raw version)
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
