#compdef grpcdebug
# =============================================================================
# grpcdebug — grpc-ecosystem/grpcdebug's
#   OFFICIAL gRPC admin-services CLI for
#   debugging running gRPC applications.
#   Connects to a target application's
#   gRPC admin port and inspects the
#   library's INTERNAL STATE via three
#   standard admin services:
#     - Channelz   (RPC + channel + socket
#                  + server-side counters)
#     - Health     (gRPC Health protocol
#                  probe + reflection)
#     - CSDS       (Client Status Discovery
#                  Service — xDS config
#                  dump for Envoy /
#                  Istio / Linkerd
#                  dataplane debugging)
#   Built on direct `google.golang.org/grpc
#   v1.70.0` — the OFFICIAL Google-
#   maintained Go gRPC framework.  Lives
#   under the `grpc-ecosystem` GitHub org
#   alongside grpc-gateway, go-grpc-
#   middleware, and other officially-
#   blessed grpc-go extensions.  Go=110
#   leader bump continuing Axis 55 (gRPC
#   Framework) at the Go pole, opened by
#   R809 `_aer` (Rust=110, tonic).
#
# AXIS 55 — gRPC FRAMEWORK — GO POLE
# ===================================
# `google.golang.org/grpc` is the OFFICIAL
# Google-maintained Go gRPC client +
# server framework.  ~22k stars across
# the umbrella grpc/grpc-go repository.
# Apache 2.0.  Reference implementation
# alongside grpc-java, grpc-c-core, grpc-
# python, grpc-node.  Bedrock dep of
# Kubernetes (kube-apiserver gRPC),
# etcd, Vitess, CockroachDB, TiDB,
# CoreDNS, Caddy, Hashicorp's Vault +
# Consul + Nomad, Buf, Connect, Linkerd,
# Istio Pilot, Cloud Run, App Engine,
# and ~every-other-Go-microservices-
# framework.  Distinguishes from sibling
# Go gRPC variants:
#   - bufbuild/connect-go        Connect
#                                 protocol
#                                 (HTTP/1.1
#                                 + JSON +
#                                 streaming);
#                                 cross-
#                                 compatible
#                                 with
#                                 grpc-web
#   - cloudwego/kitex            ByteDance's
#                                 alternative
#                                 Go RPC
#                                 framework
#                                 (faster
#                                 than
#                                 grpc-go
#                                 per
#                                 benchmarks)
#   - go-kratos/kratos           Bilibili's
#                                 framework
#   - hertz                      ByteDance's
#                                 HTTP
#                                 sibling
#                                 of kitex
#
# Other Axis 55 implementations across the
# corpus:
#   * Rust       (R809): tonic
#                — bundled in `aer` (Aurae
#                  distributed-systems
#                  runtime client)
#   * Go         (R810, THIS ROUND):
#                google.golang.org/grpc
#                v1.70.0 — bundled in this
#                round's `grpcdebug` (gRPC
#                admin-services debug CLI)
#   * TS-Node    (R811 will close):
#                @grpc/grpc-js — official
#                pure-JS Google client +
#                server
#
# Distinguishing grpcdebug from sibling
# corpus gRPC tooling:
#   - GRPCURL (`_grpcurl`, in corpus):
#     a postman-like tool for INVOKING
#     gRPC methods.  Sends request,
#     prints response.  grpcdebug is
#     about INTROSPECTING the running
#     gRPC library — channelz / health /
#     xDS state — not invoking arbitrary
#     methods
#   - GRPCUI (`_grpcui`, in corpus):
#     web UI for interactive gRPC method
#     calls.  Like grpcurl but with a
#     browser frontend
#   - EVANS (`_evans`, in corpus):
#     "more expressive universal gRPC
#     client" — REPL-style interactive
#     gRPC client.  Also invocation-
#     focused
#   - GHZ (`_ghz`, in corpus): gRPC
#     load testing tool.  Benchmarking
#     focus
#   - BUF (`_buf`, in corpus): Protobuf
#     schema management + lint +
#     breaking-change detection.
#     Different stage of the lifecycle
#     (compile-time vs runtime)
#   - PROTOTOOL (`_prototool`, in corpus):
#     older Uber Protobuf tooling.
#     Superseded by buf
#   - GRPCDEBUG fills the unique slot of
#     "look INSIDE a running gRPC library":
#     count active channels, list open
#     subchannels, inspect socket-level
#     transport state, dump xDS config
#     (for service-mesh debugging on
#     Envoy/Istio/Linkerd-managed
#     workloads)
#
# THREE ADMIN-SERVICE SURFACES:
#
# CHANNELZ — gRPC's built-in introspection
# service for runtime channel/socket state.
# Enable in your gRPC server via
# `channelz.Register*`.  Exposes:
#   - All client channels created by the
#     process
#   - Per-channel statistics (RPCs
#     attempted, succeeded, failed,
#     calls-started timestamps, etc.)
#   - All subchannels under each channel
#     with address resolution results
#   - All sockets (transport-level)
#   - All servers (server-side
#     equivalent)
# Reference impl in grpc-go, grpc-java,
# grpc-c-core.  Sometimes available via
# `localhost:<admin-port>`
#
# HEALTH — the official gRPC Health
# Checking protocol (grpc.health.v1.
# Health).  Returns the SERVING /
# NOT_SERVING / UNKNOWN status of a
# service name (empty service name = the
# whole server)
#
# CSDS — Client Status Discovery Service.
# Defined by Envoy/xDS for dumping the
# xDS config that the gRPC library has
# accepted from the management server.
# Used to debug service-mesh routing
# misconfigurations (which route a
# request resolves to, what cluster
# Envoy chose, etc.)
#
# TOP-LEVEL SUBCOMMANDS:
#   * channelz <action>      Inspect gRPC
#                            channels +
#                            subchannels +
#                            sockets +
#                            servers
#       channels             list client
#                            channels
#       channel <id|URL>     inspect a
#                            specific
#                            channel
#       subchannel <id>      inspect a
#                            specific
#                            subchannel
#       socket <id>          inspect a
#                            socket
#       servers              list servers
#       server <id>          inspect a
#                            server
#   * health [service]       probe the
#                            standard gRPC
#                            health
#                            protocol;
#                            multiple
#                            service
#                            names
#                            accepted +
#                            empty-string
#                            "" check
#                            always added
#   * xds <action>           dump CSDS xDS
#                            config from
#                            the running
#                            client
#       config               raw xDS
#                            config dump
#       status               sync status
#                            of the xDS
#                            client
#       (resource-type
#       filters may follow
#       config, e.g.
#       `xds config rds`)
#   * help                   help about
#                            any command
#
# GLOBAL FLAGS:
#   * `--credential_file <PATH>`   path
#                                  to TLS
#                                  cert
#                                  bundle
#                                  (TLS
#                                  mode
#                                  only)
#   * `--security <MODE>`          tls |
#                                  google-
#                                  default
#                                  | insecure
#                                  (default
#                                  insecure)
#   * `--server_name_override`     SNI
#                                  override
#                                  (TLS
#                                  mode
#                                  only)
#   * `-t / --timestamp`           emit
#                                  timestamps
#                                  as
#                                  RFC3339
#                                  (default
#                                  human-
#                                  readable)
#   * `-v / --verbose`             debug-
#                                  level
#                                  logging
#   * `-h / --help`                show
#                                  help
#
# REQUIRED POSITIONAL:
# `<target address>` is always the FIRST
# positional argument (e.g. `localhost:
# 8080`, `dns:///my-app:50051`).  Comes
# BEFORE the subcommand
#
# CRITICAL DIRECT DEPENDENCIES (from
# go.mod):
#   - google.golang.org/grpc v1.70.0
#                              — official Go
#                                gRPC
#                                framework
#                                [AXIS 55 LIBRARY]
#   - google.golang.org/protobuf v1.36.4
#                              — Protobuf
#                                runtime
#   - github.com/envoyproxy/go-control-plane/{contrib,envoy} v1.32.4
#                              — Envoy
#                                xDS
#                                proto
#                                definitions
#                                (for
#                                CSDS
#                                config
#                                decoding)
#   - github.com/spf13/cobra v1.8.1
#                              — CLI
#                                framework
#   - github.com/golang/protobuf v1.5.4
#                              — older
#                                Protobuf
#                                runtime
#                                (for
#                                compatibility
#                                with
#                                Channelz
#                                v1
#                                wire
#                                schema)
#   - github.com/dustin/go-humanize v1.0.1
#                              — human-
#                                readable
#                                byte
#                                sizes +
#                                durations
#                                (for
#                                non-
#                                timestamp
#                                output
#                                mode)
#   - gopkg.in/yaml.v2 v2.4.0   — YAML
#                                output
#                                formatting
#
# Go 1.23.0+ MSRV per go.mod.  Apache-2.0.
# `grpc-ecosystem` GitHub org membership
# means this tool is officially blessed
# by the gRPC team — distinct from
# random third-party CLIs.
#
# UPSTREAM:
#   * Source             : https://github.com/grpc-ecosystem/grpcdebug
#   * Channelz spec      : https://github.com/grpc/proposal/blob/master/A14-channelz.md
#   * Health protocol    : https://github.com/grpc/grpc-proto/blob/master/grpc/health/v1/health.proto
#   * CSDS spec          : https://www.envoyproxy.io/docs/envoy/latest/api-v3/service/status/v3/csds.proto
#   * License            : Apache-2.0
#   * Maintainer         : grpc-ecosystem (gRPC team-blessed)
#
# INSTALL:
#   # Pre-compiled binary
#   # https://github.com/grpc-ecosystem/grpcdebug/releases
#
#   # From source
#   go install github.com/grpc-ecosystem/grpcdebug@latest
#
# USAGE EXAMPLES:
#
#   # Health probe (default empty service +
#   # any explicit names)
#   grpcdebug localhost:50051 health
#   grpcdebug localhost:50051 health my.service
#
#   # List client channels in the running
#   # process
#   grpcdebug localhost:50051 channelz channels
#
#   # Inspect a specific channel by ID
#   grpcdebug localhost:50051 channelz channel 1
#
#   # Inspect a subchannel
#   grpcdebug localhost:50051 channelz subchannel 5
#
#   # Inspect a socket
#   grpcdebug localhost:50051 channelz socket 12
#
#   # List servers + inspect a specific server
#   grpcdebug localhost:50051 channelz servers
#   grpcdebug localhost:50051 channelz server 1
#
#   # Dump xDS config (full)
#   grpcdebug localhost:50051 xds config
#
#   # Dump only Route configs
#   grpcdebug localhost:50051 xds config rds
#
#   # Dump xDS sync status
#   grpcdebug localhost:50051 xds status
#
#   # TLS connection
#   grpcdebug myhost.example.com:443 \
#       --security tls \
#       --credential_file ./ca.pem \
#       health
#
#   # TLS with server-name override
#   grpcdebug envoy-egress:9901 \
#       --security tls \
#       --credential_file /etc/ssl/certs/ca.pem \
#       --server_name_override real-service.example.com \
#       channelz channels
#
#   # GCP environment defaults
#   grpcdebug myhost.example.com:443 \
#       --security google-default \
#       channelz channels
#
#   # RFC3339 timestamps + verbose output
#   grpcdebug localhost:50051 \
#       --timestamp --verbose \
#       channelz server 1
#
#   # Help (cobra default)
#   grpcdebug --help
#   grpcdebug channelz --help
#   grpcdebug xds config --help
#
# OPTIONS (sourced directly from
# https://github.com/grpc-ecosystem/grpcdebug/blob/main/cmd/{root,channelz,health,xds}.go cobra commands):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _grpcdebug_commands
_grpcdebug_commands=(
    'channelz:Display gRPC channel/subchannel/socket/server state in a human-readable way'
    'health:Check health status of the target service'
    'xds:Fetch xDS-related information (CSDS)'
    'help:Print help for a command'
)

local -a _grpcdebug_channelz_actions
_grpcdebug_channelz_actions=(
    'channels:List client channels for the target application'
    'channel:Display a specific channel by ID or URL'
    'subchannel:Display a subchannel by ID'
    'socket:Display a socket by ID'
    'servers:List servers in a human-readable way'
    'server:Display a server by ID'
)

local -a _grpcdebug_xds_actions
_grpcdebug_xds_actions=(
    'config:Dump the operating xDS configs'
    'status:Print the xDS config-sync status'
)

local -a _grpcdebug_security_modes
_grpcdebug_security_modes=(
    'tls:Mutual or one-way TLS with --credential_file'
    'google-default:Google Application Default Credentials (GCP environments)'
    'insecure:Plaintext connection (default)'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '--credential_file=[path to TLS credential bundle (tls mode only)]:file:_files -g "*.(pem|crt|cer|key)"' \
    '--security=[connection security mode (default insecure)]:mode:->security' \
    '--server_name_override=[override peer server name (tls mode SNI)]:server name: ' \
    '(-t --timestamp)'{-t,--timestamp}'[emit RFC3339 timestamps instead of human-readable]' \
    '(-v --verbose)'{-v,--verbose}'[verbose debug logging]' \
    '1:target address (host:port):' \
    '2: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    security)
        _describe -t modes 'security mode' _grpcdebug_security_modes && ret=0 ;;
    command)
        _describe -t commands 'grpcdebug command' _grpcdebug_commands && ret=0
        ;;
    args)
        case $line[2] in
            channelz)
                _arguments -C \
                    '(- *)'{-h,--help}'[show help for channelz]' \
                    '1::action:->czaction' \
                    '*:: :->czargs' \
                    && ret=0
                case $state in
                    czaction)
                        _describe -t actions 'channelz action' _grpcdebug_channelz_actions && ret=0 ;;
                    czargs)
                        case $line[1] in
                            channel|subchannel|socket|server)
                                _arguments \
                                    '1:numeric id (or URL for channel):' \
                                    && ret=0 ;;
                        esac
                        ;;
                esac
                ;;
            xds)
                _arguments -C \
                    '(- *)'{-h,--help}'[show help for xds]' \
                    '1::action:->xdsaction' \
                    '*:: :->xdsargs' \
                    && ret=0
                case $state in
                    xdsaction)
                        _describe -t actions 'xds action' _grpcdebug_xds_actions && ret=0 ;;
                    xdsargs)
                        case $line[1] in
                            config)
                                _arguments \
                                    '*:xDS resource type (e.g. lds rds cds eds; empty = all):' \
                                    && ret=0 ;;
                        esac
                        ;;
                esac
                ;;
            health)
                _arguments \
                    '(- *)'{-h,--help}'[show help for health]' \
                    '*:service name (empty string always probed):' \
                    && ret=0
                ;;
            help)
                _arguments \
                    '1:command:(channelz health xds)' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
