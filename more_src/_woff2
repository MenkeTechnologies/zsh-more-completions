#compdef woff2_compress woff2_decompress woff2_info
# Documentation: https://man.archlinux.org/search?q=woff2_compress
# Reference accessed: 2026-05-16

local ret=1

case $service in
  woff2_compress)
    _arguments -s -S '1:TTF/OTF font:_files -g "*.(ttf|otf)(-.)"' && ret=0
    ;;
  woff2_decompress|woff2_info)
    _arguments -s -S '1:WOFF2 font:_files -g "*.woff2(-.)"' && ret=0
    ;;
  *)
    return 1
    ;;
esac

return ret
