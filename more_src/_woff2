#compdef woff2_compress woff2_decompress woff2_info

local curcontext="$curcontext" state line ret=1

case ${words[1]:t} in
  (woff2_compress)
    _arguments \
      '1:TTF/OTF font file:_files -g "*.(ttf|otf)"' && ret=0
    ;;
  (woff2_decompress)
    _arguments \
      '1:WOFF2 font file:_files -g "*.woff2"' && ret=0
    ;;
  (woff2_info)
    _arguments \
      '1:WOFF2 font file:_files -g "*.woff2"' && ret=0
    ;;
esac

return ret
