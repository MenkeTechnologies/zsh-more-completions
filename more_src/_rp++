#compdef rp++ rp-lin rp-osx rp-win
# Documentation: https://github.com/0vercl0k/rp
# rp++ - fast C++ ROP gadget finder for PE/ELF/Mach-O x86/x64/ARM/ARM64

local ret=1

_arguments -s -S \
  '(-f --file)'{-f,--file}'=[binary file to analyze]:file:_files' \
  '(-i --info)'{-i,--info}'=[display info level]:level:(1 2 3)' \
  '(-r --rop)'{-r,--rop}'=[max instructions per gadget]:n' \
  '--raw=[analyze a raw code dump for architecture]:arch:(x86 x64 arm arm64)' \
  '--va=[set the base virtual address]:address' \
  '--bad-bytes=[exclude gadgets containing these bad bytes]:bytes' \
  '--search-hexa=[find pointers to a hex string]:hex' \
  '--search-int=[find pointers to an integer value]:int' \
  '--atsyntax[use AT&T assembly syntax]' \
  '--unique[display only unique gadgets]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && ret=0

return ret
