#compdef maketime
# Create Good Time Interval (GTI) FITS file from a Housekeeping data FITS file

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input HK file name and extension]:input file:_files' \
  'outfile=[name of the created GTI FITS file]:output file:_files' \
  'expr=[boolean expression to calculate time intervals]:expression:' \
  'name=[column name containing housekeeping parameter names]:column:' \
  'value=[column name containing housekeeping parameter values]:column:' \
  'time=[column name containing parameter time stamp]:column:' \
  'start=[output GTI start times column name]:column:' \
  'stop=[output GTI stop times column name]:column:' \
  'compact=[input uses compact ASCA housekeeping format]:flag:(yes no)' \
  'histkw=[add history records to output headers]:flag:(yes no)' \
  'prefr=[fraction of previous time interval to include]:fraction:' \
  'postfr=[fraction of following time interval to include]:fraction:' \
  '*:file:_files' && ret=0

return ret
