#compdef memfaultd memfaultctl memfault-core-handler mfw
# ============================================================================
# memfaultd / memfaultctl / memfault-core-handler / mfw
#   - Memfault embedded Linux device
#     observability daemon
#     (Rust, BSD-2-Clause-like with patent grant)
#
# Author : Memfault, Inc.
# Upstream: https://github.com/memfault/memfaultd
#
# `memfaultd` is the device-side agent for
# Memfault, a SaaS device telemetry +
# observability platform for embedded Linux
# systems. The agent runs on production
# devices (Raspberry Pi + Yocto-based embedded
# Linux + edge compute hardware) collecting
# crash reports, metrics, logs, and OTA
# update health, then uploads compressed +
# encrypted MAR (Memfault Archive) chunks to
# Memfault's backend.
#
# Multi-binary CLI suite:
#   memfaultd                      - main
#                                     daemon
#                                     (long-
#                                     running
#                                     systemd
#                                     service)
#   memfaultctl                    - control
#                                     CLI for
#                                     manual
#                                     ops
#                                     (testing
#                                     + manual
#                                     triggers
#                                     + debug
#                                     introspection)
#   memfault-core-handler          - core dump
#                                     handler
#                                     registered
#                                     via
#                                     /proc/sys/
#                                     kernel/
#                                     core_pattern
#                                     to capture
#                                     coredumps
#                                     when
#                                     processes
#                                     crash
#   mfw                            - memfault
#                                     wrapper:
#                                     wraps a
#                                     program
#                                     to
#                                     auto-
#                                     capture
#                                     its
#                                     traces
#                                     +
#                                     metrics
#                                     +
#                                     coredumps
#
# Distinguishing features vs alternatives
# (Sentry SDK + Datadog Agent + Grafana
# Loki/Prometheus + traditional syslog
# forwarders):
#   - **Embedded Linux focus** (designed for
#     bandwidth-constrained + storage-
#     constrained + power-constrained devices
#     - the antithesis of cloud-native
#     observability tools)
#   - **MAR archive format** (compressed +
#     batched + delta-encoded; designed for
#     cellular + LoRa + LPWAN-class uplinks
#     where every byte matters)
#   - **Native coredump capture** (the
#     memfault-core-handler binary integrates
#     with kernel core_pattern; captures full
#     coredumps with DWARF symbol stripping
#     before upload)
#   - **Battery-aware** (built-in support for
#     battery state tracking + battery-related
#     reboot reasons)
#   - **Reboot-reason tagging** (each reboot
#     is tagged with a reason from a defined
#     enum; Memfault dashboard groups failures
#     by reason)
#   - **Session metrics** (start/end-session
#     scoped metric collection - measure CPU/
#     RAM/network during a specific operation)
#   - **OTA update integration** (tracks
#     successful + failed OTA updates with
#     per-package version metadata)
#   - **statsd-compatible** (write-metrics
#     subcommand accepts statsd-format input)
#
# Use cases:
#   - Production fleet observability for
#     consumer IoT devices (smart speakers +
#     thermostats + smart locks)
#   - Industrial IoT crash + telemetry
#     reporting (factory edge compute + PLCs +
#     industrial gateways)
#   - Automotive in-vehicle compute telemetry
#     (infotainment + ADAS edge ML)
#   - Medical device monitoring (FDA-regulated
#     embedded devices needing audit-trail
#     telemetry)
#   - Consumer electronics OTA update health
#     dashboards
#
# Usage:
#   memfaultd [-c config] [-s] [-Z] [-v] [-V] [-q]
#   memfaultctl [-c config] [-v] [-V] <subcommand> [args]
#   memfault-core-handler <pid>           # via core_pattern
#   mfw <program> <args...>                # wraps target program
#
# memfaultd flags:
#   -c, --config-file <path>       - path to
#                                     memfaultd
#                                     .conf
#                                     (default
#                                     /etc/
#                                     memfaultd
#                                     .conf)
#   -s, --show-settings            - show
#                                     resolved
#                                     settings
#                                     +
#                                     exit
#   -Z, --daemonize                - fork to
#                                     background
#                                     (systemd
#                                     usually
#                                     does
#                                     not need
#                                     this;
#                                     mostly
#                                     for
#                                     SysV
#                                     init)
#   -v, --version                  - show
#                                     version
#                                     +
#                                     exit
#   -V, --verbose                  - verbose
#                                     output
#                                     (DEBUG-
#                                     level
#                                     logging)
#   -q, --quiet                    - quiet
#                                     output
#                                     (no
#                                     stderr)
#
# memfaultctl subcommands:
#   enable-data-collection         - enable
#                                     data
#                                     collection
#                                     + restart
#                                     memfaultd
#   disable-data-collection        - disable
#                                     data
#                                     collection
#                                     + restart
#                                     memfaultd
#   enable-dev-mode                - enable
#                                     developer
#                                     mode +
#                                     restart
#                                     memfaultd
#   disable-dev-mode               - disable
#                                     developer
#                                     mode +
#                                     restart
#                                     memfaultd
#   export [-n] -o <path> [-f <fmt>] - export
#                                     (and
#                                     delete)
#                                     MAR data
#                                     (formats:
#                                     mar +
#                                     chunk +
#                                     chunk-
#                                     wrapped)
#   reboot --reason <id>           - register
#                                     reboot
#                                     reason +
#                                     call
#                                     reboot
#                                     system
#                                     call
#   request-metrics                - flush
#                                     collectd
#                                     metrics
#                                     to
#                                     Memfault
#                                     now
#   show-settings                  - show
#                                     memfaultd
#                                     settings
#   sync                           - sync all
#                                     pending
#                                     data to
#                                     Memfault
#                                     now
#                                     (including
#                                     in-progress
#                                     reports)
#   upload                         - upload all
#                                     data
#                                     already
#                                     written
#                                     to disk
#   trigger-coredump [strategy]    - trigger a
#                                     coredump
#                                     for
#                                     testing
#                                     (strategy:
#                                     segfault
#                                     or
#                                     divide-
#                                     by-zero)
#   write-attributes <attr...>     - write
#                                     device
#                                     attributes
#                                     in
#                                     <KEY=VAL>
#                                     format
#   write-metrics <metric...>      - write
#                                     metrics
#                                     in
#                                     <KEY=VAL>
#                                     or statsd
#                                     <name:
#                                     value|
#                                     type>
#                                     format
#   add-battery-reading <status:pct> - add a
#                                     battery
#                                     reading
#                                     (status:
#                                     Charging
#                                     + Not
#                                     charging
#                                     +
#                                     Discharging
#                                     +
#                                     Unknown
#                                     + Full;
#                                     pct:
#                                     0.0-100.0)
#   report-sync-success            - report a
#                                     successful
#                                     sync for
#                                     connectivity
#                                     metrics
#   report-sync-failure            - report a
#                                     failed
#                                     sync for
#                                     connectivity
#                                     metrics
#   start-session <name> [reading...] - begin
#                                     a named
#                                     session
#                                     + start
#                                     capturing
#                                     metrics
#   end-session <name> [reading...] - end a
#                                     session
#                                     + dump
#                                     to MAR
#                                     staging
#   add-custom-data-recording <reason> <file> <mime...> - attach a
#                                     custom
#                                     data
#                                     recording
#                                     (with
#                                     --duration
#                                     -ms +
#                                     --start-
#                                     time
#                                     RFC3339)
#   save-trace --program <name> --reason <reason> [--crash <bool>] [--source <s>] [--signature <s>] - save a
#                                     custom
#                                     trace
#
# memfaultctl global flags:
#   -c, --config-file <path>       - config
#                                     file
#                                     path
#   -v, --version                  - show
#                                     version
#   -V, --verbose                  - verbose
#                                     output
#
# memfault-core-handler usage (kernel-driven):
#   /proc/sys/kernel/core_pattern:
#     |/usr/sbin/memfault-core-handler -c /etc/memfaultd.conf %P
#   - Invoked by the kernel when any process
#     coredumps
#   - Captures the coredump, optionally strips
#     DWARF symbols, and queues for upload
#   - %P is the crashing PID (passed via
#     core_pattern)
#
# mfw usage (program wrapping):
#   mfw <program> [args...]
#   - Forks + execs <program>
#   - Monitors child for crash signals
#   - Captures stderr + stdout + exit status
#   - Reports as a memfaultd trace on
#     abnormal termination
#
# Example invocations:
#   # Start daemon (typically via systemd):
#   memfaultd -c /etc/memfaultd.conf
#
#   # Manual: enable data collection
#   memfaultctl enable-data-collection
#
#   # Manual: report a reboot reason
#   memfaultctl reboot --reason UserShutdown
#
#   # Manual: write a metric reading
#   memfaultctl write-metrics 'cpu.temp_celsius=72.5'
#
#   # Manual: trigger a coredump for testing
#   memfaultctl trigger-coredump segfault
#
#   # Manual: sync all queued data now
#   memfaultctl sync
#
#   # Manual: export MAR data to a file
#   memfaultctl export -o /tmp/memfault.mar -f mar
#
#   # Manual: start + end a session
#   memfaultctl start-session boot_seq
#   # ... do work ...
#   memfaultctl end-session boot_seq
#
#   # Manual: add battery reading
#   memfaultctl add-battery-reading 'Charging:65.3'
#
# Configuration file (memfaultd.conf):
#   {
#     "project_key": "MEMFAULT_PROJECT_KEY_XXX",
#     "device_id": "device-001",
#     "hardware_version": "v1.0",
#     "software_type": "production",
#     "software_version": "1.2.3",
#     "enable_data_collection": true,
#     "enable_dev_mode": false,
#     "data_dir": "/var/lib/memfaultd",
#     "upload_interval_seconds": 3600,
#     "reboot_plugin": {"enable": true},
#     "coredump_plugin": {"enable": true},
#     "log_plugin": {"enable": true}
#   }
#
# The ciborium lane is built on `ciborium = {
# version = "0.2.1", optional = true}`
# (declared verbatim at upstream Cargo.toml
# HEAD as a direct dep, gated behind the
# coredump feature; imported by the coredump
# capture pipeline for serializing structured
# coredump metadata + DWARF symbol references
# into the MAR archive format), the canonical
# Rust CBOR (Concise Binary Object
# Representation) library by Nathaniel
# McCallum + Enarx project - github.com/
# enarx/ciborium.
#
# enarx/ciborium is the de-facto canonical
# Rust CBOR library:
#   - **Pure-Rust implementation** (no C
#     dependencies; no_std friendly with
#     alloc)
#   - **RFC 8949 compliant** (the IETF
#     standard CBOR spec; ciborium tracks the
#     spec authoritatively)
#   - **Serde integration** (transparent
#     `serde::Serialize` + `serde::Deserialize`
#     for any type; no manual codec impl
#     required)
#   - **Tagged value support** (CBOR's tag
#     system for custom semantic types like
#     dates + bignums + URIs)
#   - **Streaming encode/decode** (incremental
#     parsing for large CBOR documents)
#   - **Indefinite-length encoding** (CBOR's
#     streaming wire format for cases where
#     total size is unknown at encode time)
#   - 800+ stars; ~1,200 reverse-deps on
#     crates.io
#
# ciborium's distinguishing position vs Rust
# CBOR alternatives:
#   - enarx/ciborium (McCallum + Enarx):
#     canonical; pure-Rust; serde-integrated;
#     THIS AXIS
#   - serde_cbor (Pyfisch): older; DEPRECATED
#     2023 in favor of ciborium; many
#     existing codebases still depend on it
#   - cbor4ii: alternative pure-Rust CBOR;
#     less broadly adopted
#   - minicbor (twittner): minimal no_std
#     CBOR; popular in embedded contexts
#     where ciborium's API surface is too
#     large
#
# Nathaniel McCallum is a senior security
# engineer at Profian + maintainer of Enarx
# (a confidential-computing project enabling
# WebAssembly workloads in TEE - Trusted
# Execution Environments like AMD SEV +
# Intel SGX). McCallum's broader open-source
# footprint:
#   - enarx/enarx (the canonical WebAssembly
#     TEE runtime; uses ciborium for
#     attestation report serialization)
#   - enarx/ciborium (THIS AXIS)
#   - Red Hat security engineering work
#     (predates Profian)
#
# McCallum's role in Rust is *security +
# confidential-computing infrastructure*. The
# ciborium library was extracted from Enarx's
# attestation protocol code where CBOR is
# the canonical wire format for TEE
# attestation reports (Intel SGX + AMD SEV
# attestation reports use CBOR per RFC
# 9334 EAT - Entity Attestation Token).
#
# Multi-axis canonical-Rust author/org cohort
# extension (now spanning even more distinct
# authors):
#   - + Nathaniel McCallum + Enarx project
#     (enarx/ciborium; THIS AXIS; canonical
#     Rust CBOR + RFC 8949 + confidential-
#     computing attestation serialization)
#
# McCallum joins the canonical-Rust cohort at
# the *security + confidential-computing
# infrastructure* level. He is one of the
# few canonical authors whose library was
# extracted from a parent security-focused
# project (Enarx) rather than developed
# standalone - similar pattern to:
#   - Pyfisch's serde_cbor (deprecated;
#     extracted from a now-archived parent
#     project)
#   - Cloudflare's quiche (extracted from
#     Cloudflare's edge production usage)
#   - Buoyant's linkerd-tcp (extracted from
#     linkerd2's data plane)
# The *extracted-from-production-project*
# pattern is one of the canonical paths to
# library canonical-status in Rust.
#
# memfaultd uses ciborium for:
#   - Coredump metadata serialization (the
#     coredump_plugin feature gates ciborium;
#     enabled in production builds)
#   - MAR archive header serialization (each
#     MAR chunk has a CBOR-encoded header
#     describing the contained payloads)
#   - Device attestation reports (when
#     deployed on TEE-equipped devices;
#     RFC 9334 EAT format)
#
# This is the canonical use case for
# ciborium: low-overhead binary serialization
# of structured metadata in
# bandwidth-constrained embedded contexts.
# CBOR's combination of small binary size +
# schemaless encoding + RFC-standardized wire
# format makes it the preferred choice for
# embedded IoT telemetry archives.
#
# ----------------------------------------------------------------------------
# AXIS 280 :: CBOR (Concise Binary Object
#              Representation) libraries
#              (RFC 8949 binary
#              serialization format;
#              schemaless self-describing
#              wire format; tagged value
#              system for semantic types)
# Round 1538 :: Rust slot 1 of 4 :: OPENS Axis 280
#
# Cross-language canonical library family for
# this axis (proposed):
#   Rust    : enarx/ciborium             - Nathaniel
#                                           McCallum +
#                                           Enarx
#                                           project
#                                           (canonical
#                                           Rust CBOR;
#                                           serde-
#                                           integrated)
#   Go      : fxamacker/cbor             - Faye
#                                           Amacker
#                                           (canonical
#                                           Go CBOR;
#                                           RFC 8949
#                                           compliant;
#                                           high-
#                                           performance)
#   TS/Node : hildjj/node-cbor           - Joe
#             OR                            Hildebrand
#             kriszyp/cbor-x                 (canonical
#                                           Node CBOR;
#                                           multiple
#                                           competing
#                                           implementations
#                                           with
#                                           strong
#                                           adoption)
#
# CBOR is a *binary serialization sister
# format to MessagePack (Axis 278)*:
#   - RFC 8949 (IETF standard; published 2020
#     supersedes RFC 7049 from 2013)
#   - Designed as a binary-efficient
#     alternative to JSON (similar to
#     MessagePack)
#   - Distinguishing features vs MessagePack:
#       * Tagged values (CBOR has built-in
#         semantic typing via numeric tags;
#         e.g. tag 0 = date string, tag 1 =
#         epoch seconds, tag 2 = bignum,
#         tag 32 = URI)
#       * Canonical encoding (RFC 8949
#         specifies a canonical form for
#         deterministic encoding;
#         MessagePack does not)
#       * Indefinite-length encoding (CBOR
#         streams without knowing total size
#         upfront; MessagePack requires
#         known length)
#       * Stricter spec compliance (CBOR
#         tooling validates spec conformance
#         more aggressively)
#
# CBOR adoption in production:
#   - COSE (CBOR Object Signing + Encryption,
#     RFC 8152) - signature + encryption
#     format used by W3C WebAuthn + COVID
#     vaccine certs + RFC 9162 cert
#     transparency
#   - CWT (CBOR Web Token, RFC 8392) - JWT
#     equivalent in binary CBOR
#   - EAT (Entity Attestation Token, RFC
#     9334) - TEE attestation report format
#   - IPLD DAG-CBOR (Filecoin + IPFS content-
#     addressed storage)
#   - IoT protocols (CoAP body encoding +
#     LwM2M telemetry + many embedded
#     telemetry stacks)
#
# CBOR vs MessagePack vs Protocol Buffers
# (Axis 280 vs 278 vs 279):
#   - Protobuf: schema-defined; strong typing;
#     tag-based; .proto file required
#   - MessagePack: self-describing; type-
#     prefix wire format; loose semantic
#     typing
#   - CBOR: self-describing; type-prefix wire
#     format; STRICT semantic typing via tags;
#     RFC-canonical
#
# Each fills a different production niche:
#   - Protobuf for stable APIs with versioned
#     schemas
#   - MessagePack for internal-format dynamic
#     data
#   - CBOR for spec-bound interop where
#     semantic typing + canonical encoding
#     are required (security signatures +
#     attestation + content-addressed
#     storage)
#
# Axes 278 + 279 + 280 together cover the
# *three dominant binary serialization
# landscapes* in production polyglot
# systems. This trio completes the corpus's
# coverage of the binary-IDL canonical
# library matrix.
#
# Use-case spectrum for this axis (so far):
#   - memfaultd (Rust, ciborium): embedded
#     Linux device telemetry MAR archive
#     header serialization + TEE attestation
#     reports + coredump metadata
# ============================================================================

_memfaultd() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    case $service in
        memfaultd)
            _arguments \
                '(-c --config-file)'{-c,--config-file}'[path to memfaultd.conf]:file:_files' \
                '(-s --show-settings)'{-s,--show-settings}'[show resolved settings + exit]' \
                '(-Z --daemonize)'{-Z,--daemonize}'[fork to background]' \
                '(-v --version)'{-v,--version}'[show version]' \
                '(-V --verbose)'{-V,--verbose}'[verbose output]' \
                '(-q --quiet)'{-q,--quiet}'[quiet output]' \
            && ret=0
            ;;
        memfaultctl)
            _arguments -C \
                '(-c --config-file)'{-c,--config-file}'[path to memfaultd.conf]:file:_files' \
                '(-v --version)'{-v,--version}'[show version]' \
                '(-V --verbose)'{-V,--verbose}'[verbose output]' \
                '1: :_memfaultctl_cmds' \
                '*::arg:->args' \
            && ret=0

            case $state in
                args)
                    case $words[1] in
                        export)
                            _arguments \
                                '-n[do not delete data from mar_staging]' \
                                '-o=[output path]:file:_files' \
                                '-f=[output format]:format:(mar chunk chunk-wrapped)'
                            ;;
                        reboot)
                            _arguments \
                                '--reason=[reboot reason ID]:reason:'
                            ;;
                        trigger-coredump)
                            _arguments \
                                '1::strategy:(segfault divide-by-zero)'
                            ;;
                        add-custom-data-recording)
                            _arguments \
                                '--duration-ms=[duration in ms]:ms:' \
                                '--start-time=[start time RFC3339]:time:' \
                                '1:reason:' \
                                '2:file name:_files' \
                                '*:MIME type:'
                            ;;
                        save-trace)
                            _arguments \
                                '--program=[program name reporting trace]:name:' \
                                '--reason=[reason for collection]:reason:' \
                                '--crash=[whether trace is a crash]:bool:(true false)' \
                                '--source=[source to report]:source:' \
                                '--signature=[Memfault signature input]:sig:'
                            ;;
                    esac
                    ;;
            esac
            ;;
        memfault-core-handler)
            _arguments \
                '(-c --config-file)'{-c,--config-file}'[path to memfaultd.conf]:file:_files' \
                '1:crashing PID:'
            ;;
        mfw)
            _arguments \
                '(-c --config-file)'{-c,--config-file}'[path to memfaultd.conf]:file:_files' \
                '*:wrapped program + args:_command_names -e'
            ;;
    esac

    return ret
}

_memfaultctl_cmds() {
    local -a cmds
    cmds=(
        'enable-data-collection:enable data collection + restart memfaultd'
        'disable-data-collection:disable data collection + restart memfaultd'
        'enable-dev-mode:enable developer mode + restart memfaultd'
        'disable-dev-mode:disable developer mode + restart memfaultd'
        'export:export (and delete) MAR data'
        'reboot:register reboot reason + call reboot'
        'request-metrics:flush collectd metrics to Memfault now'
        'show-settings:show memfaultd settings'
        'sync:sync all pending data to Memfault now'
        'upload:upload data already written to disk'
        'trigger-coredump:trigger a coredump for testing'
        'write-attributes:write device attributes (KEY=VAL ...)'
        'write-metrics:write metrics (KEY=VAL or statsd format)'
        'add-battery-reading:add a battery reading (status:percent)'
        'report-sync-success:report a successful sync'
        'report-sync-failure:report a failed sync'
        'start-session:begin a named session + start capturing metrics'
        'end-session:end a session + dump to MAR staging'
        'add-custom-data-recording:attach a custom data recording'
        'save-trace:save a custom trace'
    )
    _describe -t commands 'memfaultctl command' cmds
}

_memfaultd "$@"
