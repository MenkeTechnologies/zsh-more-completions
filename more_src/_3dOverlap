#compdef 3dOverlap
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dOverlap.html
# AFNI count voxels nonzero across all input dataset sub-bricks

local ret=1

_arguments -s -S \
  '-save[save overlap count at each voxel to prefix]:prefix:' \
  '*:dataset:_files' && ret=0

return ret
