#compdef pkascii2img
# Documentation: https://pktools.nongnu.org/html/pkascii2img.html
# convert ASCII matrix to raster image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[input ASCII file]:file:_files' \
  '(-o --output)'{-o,--output}'[Output image file]:file:_files' \
  '(-ot --otype)'{-ot,--otype}'[Data type for output image ({Byte/Int16/UInt16/UInt32/Int32/Float32/Fl]:value:' \
  '(-of --oformat)'{-of,--oformat}'[image type string (see also gdal_translate)]:value:' \
  '(-co --co)'{-co,--co}'[Creation option for output file. Multiple options can be specified.]:value:' \
  '(-ulx --ulx)'{-ulx,--ulx}'[Upper left x value bounding box (in geocoordinates if georef is true)]:value:' \
  '(-uly --uly)'{-uly,--uly}'[Upper left y value bounding box (in geocoordinates if georef is true)]:value:' \
  '(-dx --dx)'{-dx,--dx}'[Output resolution in x (in meter)]:value:' \
  '(-dy --dy)'{-dy,--dy}'[Output resolution in y (in meter)]:value:' \
  '(-ct --ct)'{-ct,--ct}'[color table (file with 5 columns\: id R G B ALFA (0\: transparent, 255\:]:file:_files' \
  '(-a_srs --a_srs)'{-a_srs,--a_srs}'[Override the projection for the output file]:value:' \
  '(-d --description)'{-d,--description}'[Set image description]:value:' \
  '*:file:_files' && ret=0

return ret
