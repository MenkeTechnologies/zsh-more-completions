#compdef funzzy

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[specify config file]:config file:_files' \
  '--config=[specify config file]:config file:_files' \
  '-t+[specify target to run]:target' \
  '--target=[specify target to run]:target' \
  '-w+[specify files or directories to watch]:path:_files' \
  '--watch=[specify files or directories to watch]:path:_files' \
  '-n[non-block mode]' \
  '--non-block[non-block mode]' \
  '1:command:' \
  '*:args:' && return 0
