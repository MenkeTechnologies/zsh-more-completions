#compdef s6-applyuidgid
# Documentation: https://skarnet.org/software/s6/s6-applyuidgid.html
# Reference accessed: 2026-05-30
# s6-applyuidgid — drop privileges then exec a program. Part of skarnet s6 process supervision.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-u+[set process UID to UID]:uid:_users' \
  '-g+[set process GID to GID]:gid:_groups' \
  '-G+[supplementary group list (CSV of numeric GIDs, no spaces)]:gidlist:' \
  '-U[read UID/GID/GIDLIST from environment variables (cmdline overrides env)]' \
  '-z[unexport (remove UID/GID/GIDLIST from process environment)]' \
  '*:program + args:_command_names -e' \
  && ret=0

return ret
