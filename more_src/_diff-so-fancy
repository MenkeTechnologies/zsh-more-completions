#compdef diff-so-fancy
# Documentation: https://man.archlinux.org/search?q=diff-so-fancy
# Reference accessed: 2026-05-16

# Zsh completion for diff-so-fancy (human readable diff prettifier)

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--patch[output in patch format]' \
  '--colors[show configured colors]' \
  '--set-defaults[set recommended git config defaults]'
