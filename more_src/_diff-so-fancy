#compdef diff-so-fancy
# Documentation: https://github.com/so-fancy/diff-so-fancy
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for diff-so-fancy (human readable diff prettifier)

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--patch[output in patch format (no pager)]' \
  '--colors[show configured colors]' \
  '--set-defaults[set recommended git config defaults]'
