#compdef osintgram
# Documentation: https://github.com/Datalux/Osintgram
# OSINT: gather information from an Instagram account target.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-C --cookies)'{-C,--cookies}'[clear previous cookies]' \
  '(-j --json)'{-j,--json}'[save commands output as JSON file]' \
  '(-f --file)'{-f,--file}'[save output in a file]' \
  '(-c --command)'{-c+,--command=}'[run in single command mode and execute command]:command:' \
  '(-o --output)'{-o+,--output=}'[where to store photos]:dir:_files -/' \
  '1:username:' && ret=0

return ret
