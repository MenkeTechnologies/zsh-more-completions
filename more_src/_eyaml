#compdef eyaml

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'createkeys:create a key pair'
  'edit:edit an EYAML file (decrypt, edit in $EDITOR, re-encrypt)'
  'encrypt:encrypt a value or file'
  'decrypt:decrypt a value or file'
  'recrypt:re-encrypt a file'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--pkcs7-recipients=[recipients (comma-separated)]:recipients:' \
  '--pkcs7-private-key=[private key]:file:_files -g "*.pem"' \
  '--pkcs7-public-key=[public key]:file:_files -g "*.pem"' \
  '--pkcs7-keysize=[RSA key size]:n:' \
  '--pkcs7-cert-validity=[cert validity in days]:n:' \
  '-n+[encryption scheme]:scheme:(pkcs7 gpg)' \
  '--gpg-always-trust[always trust GPG keys]' \
  '*--gpg-recipients=[GPG recipients]:recipients:' \
  '--gpg-recipients-file=[GPG recipients file]:file:_files' \
  '--gpg-gnupghome=[GPG home directory]:dir:_files -/' \
  '-l+[label]:label:' \
  '--label=[label]:label:' \
  '-s+[string to encrypt/decrypt]:string:' \
  '--string=[string]:string:' \
  '-f+[file]:file:_files' \
  '--file=[file]:file:_files' \
  '--password[prompt for password]' \
  '-e+[output format]:format:(string block examples)' \
  '--output=[output format]:format:(string block examples)' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '--trace[show stack trace]' \
  '--debug[debug mode]' \
  '--encrypt-method=[encrypt method]:method:(pkcs7 gpg)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'eyaml subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (edit|encrypt|decrypt|recrypt)
        _files -g "*.(yaml|yml|eyaml)" && ret=0
        ;;
    esac
    ;;
esac

return ret
