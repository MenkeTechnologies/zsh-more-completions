#compdef geeqie
# Documentation: https://man.archlinux.org/search?q=geeqie
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-all[all help options]' \
  '--help-gtk[GTK options]' \
  '--version[show version]' \
  '(-r --remote)'{-r,--remote}'[control already-running instance]' \
  '(-rh --remote-help)'{-rh,--remote-help}'[show remote command help]' \
  '--blank[blank window]' \
  '--cache-maintenance=[run cache maintenance]:path:_files -/' \
  '+t[force toolbox shown]' \
  '-t[force toolbox hidden]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start fullscreen]' \
  '+w[force log window shown]' \
  '-w[force log window hidden]' \
  '--debug=[debug verbosity level]:level:(0 1 2 3 4)' \
  '--grep=[filter debug log]:pattern:' \
  '--log-file=[redirect log to file]:file:_files' \
  '--disable-clutter[disable Clutter video output]' \
  '--action=[execute keyboard action]:action:' \
  '--action-list[list available actions]' \
  '--cache-metadata[clean metadata cache]' \
  '--cache-render=[render thumbnails]:folder:_files -/' \
  '--cache-render-recurse=[render thumbnails recursive]:folder:_files -/' \
  '--cache-render-shared=[render thumbs shared]:folder:_files -/' \
  '--cache-render-shared-recurse=[shared recursive]:folder:_files -/' \
  '--cache-shared=[clear|clean]:op:(clear clean)' \
  '--cache-thumbs=[clear|clean]:op:(clear clean)' \
  '--config-load=[load configuration file]:file:_files' \
  '--file=[open file and raise window]:file:_files' \
  '--File=[open file without raising]:file:_files' \
  '--file-extensions[list known file extensions]' \
  '--first[show first image]' \
  '--last[show last image]' \
  '(-n --next)'{-n,--next}'[next image]' \
  '(-b --back)'{-b,--back}'[previous image]' \
  '--new-window[open new window]' \
  '--close-window[close current window]' \
  '--quit[quit]' \
  '--id=[remote instance id]:id:' \
  '--list[start in list mode]' \
  '--lua=[run lua script]:file:_files' \
  '--pwd=[print working directory]:dir:_files -/' \
  '--raise[raise window]' \
  '--selection-add=[add to selection]:file:_files' \
  '--selection-clear[clear selection]' \
  '--selection-list[list selection]' \
  '--selection-remove=[remove from selection]:file:_files' \
  '--show-log-window[show log window]' \
  '(-s --slideshow)'{-s,--slideshow}'[toggle slideshow]' \
  '--slideshow-recurse=[slideshow recursive]:folder:_files -/' \
  '--slideshow-start[start slideshow]' \
  '--slideshow-stop[stop slideshow]' \
  '(-d --delay)'{-d+,--delay=}'[slideshow delay seconds]:secs:' \
  '--tell[print current filename]' \
  '--dupes=[find duplicates folder]:folder:_files -/' \
  '--dupes-export=[export duplicates results]:file:_files' \
  '--dupes-recurse=[duplicates recursive]:folder:_files -/' \
  '--geometry=[set window geometry]:WxH:' \
  '*:path:_files' && ret=0

return ret
