#compdef nix-collect-garbage
# Documentation: https://nix.dev/manual/nix/stable/command-ref/nix-collect-garbage
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-d --delete-old)'{-d,--delete-old}'[delete all old generations of profiles]' \
  '--delete-older-than[delete generations older than period]:period:' \
  '--max-freed[stop after freeing N bytes]:bytes:' \
  '--dry-run[show what would be done without doing it]' && ret=0

return ret
