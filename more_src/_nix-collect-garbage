#compdef nix-collect-garbage

# Zsh completion for nix-collect-garbage - delete unreachable store paths

_arguments \
  '(- *)--help[show help]' \
  '(-d --delete-old)'{-d,--delete-old}'[delete all old generations of all profiles]' \
  '--delete-older-than[delete generations older than]:period (e.g. 30d)' \
  '--max-freed[stop after freeing this amount]:bytes' \
  '--dry-run[show what would be done]'
