#compdef nix-collect-garbage
# Documentation: https://manpages.debian.org/testing/nix-bin/nix-collect-garbage.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-d[delete old generations]' \
  '--delete-old[delete old generations]' \
  '--delete-older-than=[delete generations older than]:period' \
  '--max-freed=[stop after freeing N bytes]:bytes' \
  '--dry-run[show what would be done]' && ret=0

return ret
