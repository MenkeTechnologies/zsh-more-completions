#compdef picard
# _picard-cli — MusicBrainz Picard audio file tagger (Python, Qt); cross-platform tagger with acoustic fingerprinting (AcoustID) and MusicBrainz lookup
# upstream: https://github.com/metabrainz/picard

_picard-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --debug)'{-d,--debug}'[debug log]' \
        '(-c --config-file)'{-c,--config-file}'+[config file]:file:_files' \
        '(-e --exec)'{-e,--exec}'+[script]:file:_files' \
        '(-M --no-player)'{-M,--no-player}'[disable player]' \
        '(-N --no-restore)'{-N,--no-restore}'[skip window state restore]' \
        '(-P --no-plugins)'{-P,--no-plugins}'[disable plugins]' \
        '(-s --stand-alone-instance)'{-s,--stand-alone-instance}'[force new instance]' \
        '(-T --no-translation)'{-T,--no-translation}'[disable translation]' \
        '(--audit)--audit+[audit syscalls]:syscalls:' \
        '*:music file:_files'
}

_picard-cli "$@"
