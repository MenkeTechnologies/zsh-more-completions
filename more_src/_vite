#compdef vite
# Documentation: https://vite.dev/guide/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_vite_log_levels=(info warn error silent)

_vite() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a _vite_cmds
  _vite_cmds=(
    'dev:start development server (alias: serve)'
    'serve:alias of dev'
    'build:build for production'
    'preview:preview production build'
    'optimize:pre-bundle dependencies'
  )

  _arguments -C \
    '--help[show help]' \
    '--version[show version]' \
    '1:command:->cmds' \
    '*::arg:->args'

  case "$state" in
    cmds)
      _describe -t commands 'vite command' _vite_cmds
      ;;
    args)
      local -a common_args
      common_args=(
        {-c,--config}'[config file]:file:_files'
        '--base[public base path]:path:'
        {-l,--logLevel}'[log level]:level:('"${_vite_log_levels[*]}"')'
        '--clearScreen[clear screen on rebuild]'
        '--configLoader[config processing method]:loader:(bundle runner)'
        '--profile[enable Node.js inspector]'
        {-d,--debug}'[show debug output]:feat:'
        {-f,--filter}'[debug log filter]:filter:'
        {-m,--mode}'[mode]:mode:'
      )

      case $line[1] in
        dev|serve)
          _arguments \
            '--host[specify host]:host:_hosts' \
            '--port[specify port]:port:' \
            '--open[open browser on startup]:path:' \
            '--strictPort[exit if port is already in use]' \
            '--cors[enable CORS]' \
            '--force[force dependency re-bundling]' \
            $common_args
          ;;
        build)
          _arguments \
            '--target[transpile target]:target:' \
            '--outDir[output directory]:dir:_directories' \
            '--assetsDir[assets directory]:dir:' \
            '--assetsInlineLimit[inline limit for assets]:number:' \
            '--ssr[SSR entry point]:entry:_files' \
            '--sourcemap[generate source maps]:mode:(true false inline hidden)' \
            '--minify[minifier to use]:minifier:(oxc terser esbuild false)' \
            '--manifest[emit manifest file]:name:' \
            '--ssrManifest[emit SSR manifest]:name:' \
            '--emptyOutDir[empty output directory before build]' \
            {-w,--watch}'[watch mode]' \
            '--app[build all environments (experimental)]' \
            $common_args
          ;;
        preview)
          _arguments \
            '--host[specify host]:host:_hosts' \
            '--port[specify port]:port:' \
            '--strictPort[exit if port is already in use]' \
            '--open[open browser on startup]:path:' \
            '--outDir[output directory]:dir:_directories' \
            $common_args
          ;;
        optimize)
          _arguments \
            '--force[force dependency re-bundling]' \
            $common_args
          ;;
      esac
      ;;
  esac
}

_vite "$@"
