#compdef jackminimix
# simple JACK mixer with an OSC control interface

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose mode]' \
  '-q[quiet mode]' \
  '-a[automatically connect output JACK ports]' \
  '-l+[connect left output to named input port]:port' \
  '-r+[connect right output to named input port]:port' \
  '-c+[number of input channels]:count' \
  '-n+[JACK client name]:name' \
  '-p+[UDP port number for OSC]:port' && ret=0

return ret
