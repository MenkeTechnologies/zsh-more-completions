#compdef goderive

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-prefix)'-prefix+'[Generated file prefix]:prefix:' \
  '(-package)'-package+'[Target package name]:name:' \
  '(-output)'-output+'[Custom output filename]:file:_files' \
  '-exported[Only derive exported types]' \
  '-plugin=[Use only named plugin]:plugin:' \
  '*:packages or files:_default'
