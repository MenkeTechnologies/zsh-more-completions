  '(- *)'{-h,--help}'[show help]' \
  '-c+[path to config file]:config:_files -g "*.yml(-.)"' \
  '--conf=[path to config file]:config:_files -g "*.yml(-.)"' \
  '-l+[log level]:level:(0 1 2 3)' \
  '--log-level=[log level]:level:(0 1 2 3)' \
  '-s[skip external link checks]' \
  '--skip-external[skip external link checks]' \
  '1:directory:_directories' && return 0
