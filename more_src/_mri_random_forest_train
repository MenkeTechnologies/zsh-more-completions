#compdef mri_random_forest_train
# Documentation: https://github.com/freesurfer/freesurfer/blob/dev/mri_rf_train/mri_rf_train.cpp
# Train a random forest classifier for segmentation

local ret=1

_arguments -s -S \
  '-GRADIENT[add gradient components]' \
  '-MAX_RATIO[max WM/WMSA ratio for training samples]:ratio:' \
  '-CONFORM[input volumes are conformed]' \
  '-MAKE_UCHAR[convert segmentation to UCHAR]' \
  '-TRAINING_FRACTION[fraction of data used per tree]:frac:' \
  '-WMSA[read white matter signal abnormalities from file]:file:_files' \
  '*-INPUT[training data volume]:vol:_files' \
  '-SPACING[node spacing in mm]:mm:' \
  '-BINARIZE[binarize segmentation values]' \
  '-MASK[apply mask volume to inputs]:file:_files' \
  '-DEBUG_NODE[debug specific atlas node]:x:y:z:' \
  '-DEBUG_VOXEL[debug specific voxel]:x:y:z:' \
  '-DEBUG_LABEL[debug specific label]:label:' \
  '-INSERT[insert non-zero values as specific label]:label:' \
  '-ctab[read and embed color table]:file:_files' \
  '-T1[T1 data directory]:dir:_files -/' \
  '-SEG_DIR[segmentation directory]:dir:_files -/' \
  '-PARC_DIR[parcellation directory]:dir:_files -/' \
  '-XFORM[atlas transform file]:file:_files' \
  '-NOXFORM[disable transform application]' \
  '-check[conduct label sanity checks]' \
  '-check_and_fix[sanity check and write corrected volume]' \
  '-SDIR[subjects directory]:dir:_files -/' \
  '-NTREES[number of trees in forest]:n:' \
  '-MAX_DEPTH[maximum tree depth]:depth:' \
  '-WMSA_WHALF[examine voxels within distance of WMSA]:dist:' \
  '-SMOOTH[smoothing parameter]:val:' \
  '-NBRS[train using border voxels only]' \
  '-W[window size]:size:' \
  '-U[display usage]' \
  '*:arg:_files' && ret=0

return ret
