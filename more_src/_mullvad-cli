#compdef mullvad
# _mullvad-cli — Mullvad VPN command-line client (mullvad/mullvadvpn-app)
# upstream: https://github.com/mullvad/mullvadvpn-app
# Subcommands from mullvad-cli/src/main.rs (clap).

_mullvad-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'account:account info & management'
                'auto-connect:control daemon auto-connect'
                'beta-program:enable beta updates'
                'lockdown-mode:block network access when disconnected'
                'dns:configure DNS servers'
                'lan:allow local network sharing'
                'connect:connect to a VPN relay'
                'disconnect:disconnect from the VPN'
                'reconnect:reconnect to any matching relay'
                'relay:manage relay/tunnel constraints'
                'api-access:manage API access methods'
                'anti-censorship:manage WireGuard anti-censorship'
                'split-tunnel:manage split tunneling'
                'status:show tunnel state'
                'tunnel:manage tunnel options'
                'version:show version info'
                'factory-reset:reset settings, caches, logs'
                'reset-settings:reset only settings'
                'custom-list:manage custom lists'
                'import-settings:apply JSON patch from file'
                'export-settings:export current settings as JSON patch'
                'log:manage logs & tracing'
                'shell-completions:generate shell completion scripts'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                connect|disconnect|reconnect) _arguments '(-w --wait)'{-w,--wait}'[wait until done]' ;;
                factory-reset|reset-settings) _arguments '(-y --assume-yes)'{-y,--assume-yes}'[assume yes]' ;;
                import-settings|export-settings) _arguments '1:file:_files' ;;
                shell-completions) _arguments '1:shell:(bash elvish fish powershell zsh)' '2:output dir:_files -/' ;;
            esac
            ;;
    esac
}

_mullvad-cli "$@"
