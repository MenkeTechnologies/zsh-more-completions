#compdef dtsroll
# Documentation: https://man.archlinux.org/search?q=dtsroll
# Reference accessed: 2026-05-16

# https://github.com/privatenumber/dtsroll — bundle .d.ts outputs (Node CLI)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '*::entry .d.ts files:_files -g "*.d.ts"'
