#compdef meltano-cli meltano2
# _meltano-cli — Meltano meltano-cli CLI command-line frontend wrapping the Meltano open-source ELT extract-load-transform DataOps platform managing extractors loaders transformers orchestrators add install remove discover invoke schedule elt environment project init pipeline plugin manage docs (Meltano team, Python); click
# upstream: https://meltano.com/

_meltano-cli() {
    local -a sub=(
        'init:initialize a new project'
        'install:install plugins'
        'add:add a plugin'
        'remove:remove a plugin'
        'discover:discover plugins'
        'invoke:invoke a plugin'
        'elt:run an ELT pipeline'
        'run:run a job'
        'schedule:schedule operations'
        'job:job management'
        'project:project operations'
        'environment:environment management'
        'config:configuration'
        'state:state management'
        'select:select streams'
        'lock:lock plugin definitions'
        'upgrade:upgrade Meltano'
        'docs:open docs'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--log-level=+[l]:l:(debug info warning error critical)' \
        '--log-config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '--cwd=+[dir]:dir:_files -/' \
        '-e+[env]:str:' \
        '--environment=+[name]:str:' \
        '--no-environment[no environment]' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'meltano-cli subcommand' sub ;;
        args)
            case $words[1] in
                add|install|remove|invoke|discover) _arguments '*:plugin name:' ;;
                elt|run) _arguments '*:job arg:' ;;
                schedule) _arguments '1:op:(list add remove run)' '*:name:' ;;
            esac
            ;;
    esac
}

_meltano-cli "$@"
