#compdef summa summa.exe
# Documentation: https://summa.readthedocs.io/en/latest/installation/SUMMA_installation/
# SUMMA: Structure for Unifying Multiple Modeling Alternatives

local ret=1

_arguments -s -S \
  '(-m --master)'{-m,--master}'[path/name of master file (required)]:master file:_files' \
  '(-s --suffix)'{-s,--suffix}'[add fileSuffix to the output files]:suffix:' \
  '(-g --gru)'{-g,--gru}'[run countGRU GRUs starting at index startGRU]:startGRU:' \
  '(-h --hru)'{-h,--hru}'[run a single HRU with index iHRU]:iHRU:' \
  '(-r --restart)'{-r,--restart}'[frequency to write restart files]:freq:(y m d never)' \
  '(-p --progress)'{-p,--progress}'[frequency to print progress]:freq:(m d h never)' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '*:file:_files' && ret=0

return ret
