#compdef nss-systemd
# _nss-systemd — systemd nss-systemd libnss_systemd GNU C library NSS Name Service Switch module CLI helper providing dynamic UID GID user group records for systemd transient DynamicUser= services systemd-homed home directories systemd-machined containers via the org.freedesktop.systemd1.UserDatabase varlink interface (systemd team, C); getopt
# upstream: https://www.freedesktop.org/wiki/Software/systemd/userdb/

_nss-systemd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--user[query user records]' \
        '--group[query group records]' \
        '--all[query all entries]' \
        '--source=+[src]:s:(io.systemd.UserDatabase io.systemd.NameServiceSwitch io.systemd.DropIn)' \
        '*:user or group:_users'
}

_nss-systemd "$@"
