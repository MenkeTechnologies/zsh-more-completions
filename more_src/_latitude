#compdef latitude lsh
# Documentation: https://github.com/latitudesh/lsh/blob/main/cli/cli.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for the Latitude.sh CLI (lsh, cobra-based). Subcommand list
# is taken from cli.MakeRootCmd in cli/cli.go; global flags from cmd/root.go.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:Authenticate the CLI with an API key'
  'update:Update lsh to the latest release'
  'api_keys:Manage account API keys'
  'plans:List plans, bandwidth plans, and availability'
  'projects:Manage projects'
  'servers:Manage servers'
  'ssh_keys:Manage project SSH keys'
  'virtual_networks:Manage virtual networks and assignments'
  'volume:Manage volumes'
  'gen-completion:Generate shell completion scripts'
  'help:Show help for any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--dry-run[do not send the request to the server]' \
  '--debug[output debug logs]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'lsh subcommand' commands && ret=0
    ;;
esac

return ret
