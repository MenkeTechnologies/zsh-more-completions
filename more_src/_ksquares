#compdef ksquares
# Documentation: https://apps.kde.org/ksquares/
# Reference accessed: 2026-05-16
# Verified: upstream KDE ksquares. --demo enables autoplay mode.
# Removed from prior file: bogus man.archlinux.org search URL.

# ksquares: KDE dots-and-boxes game
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' \
  '--demo[autoplay demonstration mode]' && ret=0
return ret
