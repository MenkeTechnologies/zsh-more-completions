#compdef ksquares
# Documentation: https://invent.kde.org/games/ksquares/-/blob/master/src/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream ksquares src/main.cpp QCommandLineParser - one custom
# option (--demo). Removed KDE4-era --author/--license (not added by
# modern QCommandLineParser).

# ksquares: KDE dots-and-boxes game
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--demo[run game in demo (autoplay) mode]' && ret=0
return ret
