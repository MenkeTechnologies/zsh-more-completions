#compdef reckon
# _reckon — convert bank CSV to ledger format (cantino/reckon)
# upstream: https://github.com/cantino/reckon
# Flags from lib/reckon/options.rb.

_reckon() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-f --file)'{-f+,--file=}'[CSV file to parse]:file:_files -g "*.csv"' \
        '(-a --account)'{-a+,--account=}'[ledger account name]:name:' \
        '(-v --verbose)'{-v,--verbose}'[verbose info log messages]' \
        '--vv[debug log messages]' \
        '(-i --inverse)'{-i,--inverse}'[use negative of each amount]' \
        '(-p --print-table)'{-p,--print-table}'[print parsed CSV in table form]' \
        '(-o --output-file)'{-o+,--output-file=}'[ledger file to append to]:file:_files' \
        '(-l --learn-from)'{-l+,--learn-from=}'[learn from existing ledger file]:file:_files' \
        '--ignore-columns=[comma-separated column indices to ignore]:cols:' \
        '--money-column=[money column index]:n:' \
        '--money-columns=[two money column indices (debit,credit)]:csv:' \
        '--raw-money[do not reformat money column]' \
        '--sort=[sort by]:field:(DATE DESC AMT)' \
        '--date-column=[date column index]:n:' \
        '--contains-header=[number of header lines]:n:' \
        '--contains-footer=[number of footer lines]:n:' \
        '--csv-separator=[CSV separator (default ,)]:sep:' \
        '--comma-separates-cents[treat comma as decimal separator]' \
        '--encoding=[CSV file encoding]:encoding:(UTF-8 ISO-8859-1 CP1252)' \
        '(-c --currency)'{-c+,--currency=}'[currency symbol]:symbol:' \
        '--date-format=[input date format]:format:' \
        '--ledger-date-format=[output ledger date format]:format:' \
        '(-u --unattended)'{-u,--unattended}'[unattended/non-interactive mode]' \
        '(-t --account-tokens)'{-t+,--account-tokens=}'[account tokens file]:file:_files' \
        '--table-output-file=[file for table output]:file:_files' \
        '--default-into-account=[default into account]:account:' \
        '--default-outof-account=[default out-of account]:account:' \
        '--fail-on-unknown-account[fail rather than prompt for unknown account]' \
        '--suffixed[append currency symbol as suffix]'
}

_reckon "$@"
