#compdef rst
# Documentation: https://github.com/flying-sheep/rust-rst
# Reference accessed: 2026-05-21
# Verified: source at https://raw.githubusercontent.com/flying-sheep/rust-rst/main/rst/src/main.rs

# Zsh completion for rst reStructuredText CLI (flying-sheep/rust-rst). Args from rst/src/main.rs (clap derive).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --format)'{-f,--format=}'[output format]:format:(html json xml)' \
  '--schema=-[emit JSON schema instead of converting]:version:(draft7 2019-09 2020-12 openapi3)' \
  '*'{-v,--verbose}'[increase log verbosity]' \
  '*'{-q,--quiet}'[decrease log verbosity]' \
  '*::input file:_files'
