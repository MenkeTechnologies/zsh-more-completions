#compdef cargo-smart-release
# Documentation: https://github.com/Byron/cargo-smart-release
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# cargo-smart-release: release workspace crates with auto-detected dependencies
# and changelog generation. Disarmed by default — pass --execute to actually
# perform the release.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--help[display available options and usage]' \
  '--execute[perform the actual release operation]' \
  '--dry-run-cargo-publish[run thorough but error-prone simulation before publishing]' \
  '--target=[target triple forwarded to every cargo publish]:triple:' \
  '*::crate name:_default' && ret=0

return ret
