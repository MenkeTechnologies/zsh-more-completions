#compdef whiffle
# Documentation: source-direct extraction from upstream
# wingo/whiffle bin/whiffle
# (**Guile Scheme**; uses **`(ice-9 getopt-long)`**
# — Guile's stdlib CLI library, a port-and-extension
# of the GNU getopt_long convention.  Corpus's
# **first documented Guile Scheme CLI library**.
# Pivots from R310 _iapws (Fortran M_CLI2) into the
# Guile Scheme ecosystem.  Note: this is the first
# CLI library entry in a SCHEME dialect other than
# Racket (R290 racket/cmdline) — Guile is GNU's
# extension/scripting Scheme):
#   bin/whiffle line 23
#     (`(use-modules (ice-9 format) (ice-9 getopt-
#       long) (ice-9 match) ...)` — Guile USE-
#     MODULES form imports modules at top level.
#     `(ice-9 getopt-long)` is the module path —
#     `ice-9` is Guile's stdlib module namespace
#     (named after the eponymous Vonnegut concept
#     of "structure that arranges water molecules
#     in a particular way", reflecting Guile's
#     view that ice-9 modules "structure the
#     standard interface").  Distinct from R290
#     Racket `racket/cmdline` (Racket module form),
#     R302 Clojure babashka.cli (Clojure `:require`
#     vector), R303 Gleam Glint (`import glint`),
#     R308 Hare `use getopt;`, R309 SML structure
#     reference.  Guile's USE-MODULES with PATH-
#     AS-LIST is the Scheme/Lisp module convention
#     — sister to Racket's `(require racket/
#     cmdline)`)
#   bin/whiffle lines 56-69
#     (the SPEC is a QUOTED ASSOCIATION LIST:
#       `(getopt-long args
#         '((expr (single-char #\e) (value #t))
#           (help (single-char #\h) (value #f))
#           (assemble (single-char #\S) (value #f))
#           (preserve-builddir (value #f))
#           (no-tracepoints (value #f))
#           (optimize (single-char #\O) (value #t))
#           (warn (single-char #\W) (value #t))
#           (gc (value #t))
#           (heap-size (value #t))
#           (heap-size-policy (value #t))
#           (parallelism (value #t))
#           (print-stats (value #f))
#           (output (single-char #\o) (value #t))
#           (timeout (value #t))
#           (check-heap-consistency (value #f))))`
#     Each ENTRY is a list: `(NAME OPTION ...)`
#     where NAME is the long flag (symbol), and
#     each OPTION is a 2-element list:
#       `(single-char #\X)` ← short-flag alias
#                              (Scheme `#\X` char
#                              literal — same as
#                              Common Lisp's `#\X`)
#       `(value #t)`        ← takes a REQUIRED arg
#       `(value #f)`        ← BOOLEAN flag, no arg
#       `(value optional)`  ← OPTIONAL arg (third
#                              valid form, not used
#                              here)
#       `(required? #t)`    ← REQUIRED flag (must
#                              be passed)
#       `(predicate FUNC)`  ← VALIDATOR closure
#     Distinct from R290 Racket `command-line`
#     macro (s-expression DSL inside a hygienic
#     macro), R272 C POSIX getopt (option string),
#     R287 Nim parseopt (token iterator), R307
#     Vala GLib (OptionEntry struct table), R308
#     Hare getopt (tagged-union array), R310
#     Fortran M_CLI2 (single-string-packed spec).
#     Guile's approach: QUOTED ASSOCIATION LIST
#     as the spec — pure Scheme data, manipulated
#     like any other list.  Closest analog: R302
#     Clojure babashka.cli (vector-of-maps data
#     spec) — but Guile's data is QUOTED LISTS
#     of LISTS rather than maps.  Corpus's **first
#     documented quoted-assoc-list-as-spec CLI
#     pattern**)
#   bin/whiffle line 56
#     (`(getopt-long args SPEC)` — the PARSER
#     ENTRY POINT.  Returns an ASSOCIATION LIST
#     `((NAME . VALUE) ...)` of parsed options.
#     `args` here is the FULL argv (including
#     argv[0] program name; getopt-long handles
#     skipping it).  Distinct from R304 Ada
#     Getopt(Config) (mutates aliased variables),
#     R307 Vala GLib `oc.parse(ref args)` (mutates
#     argv), R310 Fortran M_CLI2 set_args (global-
#     module-state side effect).  Guile's
#     approach: PURE FUNCTIONAL RETURN — getopt-
#     long returns the parsed alist as a value,
#     never mutates anything.  Corpus's **first
#     documented pure-functional-parsed-alist
#     CLI pattern**)
#   bin/whiffle lines 71, 74-78, 169
#     (`(option-ref options 'NAME DEFAULT)` — the
#     ACCESSOR.  Looks up the symbol-keyed entry
#     in the parsed alist; returns DEFAULT if
#     missing.  `(option-ref options 'help #f)` is
#     a common pattern for boolean flags — returns
#     `#t` if `--help` was passed, `#f` otherwise.
#     The empty-list key `(option-ref options '()
#     #f)` retrieves POSITIONAL ARGS — Guile
#     getopt-long's UNIQUE convention: positionals
#     are stored under the EMPTY-LIST KEY.
#     Distinct from R302 Clojure babashka.cli
#     `:args->opts [:name]` (positional bound to
#     named option), R308 Hare `cmd.args` (field
#     access on parsed struct), R310 Fortran
#     M_CLI2 `args=>unnamed` (rename-on-import).
#     Guile's approach: POSITIONALS-UNDER-EMPTY-
#     LIST-KEY — the alist association is
#     `('() . positionals-list)`.  Corpus's **first
#     documented empty-list-key-as-positional
#     CLI pattern**)
# Reference accessed: 2026-05-31 via gh api.
#
# CLI surface (decoded source-direct from
# getopt-long spec at whiffle:56-69):
#   --expr/-e EXPR              input is EXPR instead of a file
#   --help/-h                   print help message
#   --output/-o FILE            just compile the input, write to FILE
#   --timeout=NSECS             kill process if running after NSECS
#   --assemble/-S               only produce C file; don't make executable
#   --gc=GC                     choose gc implementation (--gc=help)
#   --heap-size=SZ              specify initial heap size
#   --heap-size-policy=P        how to size heap: fixed, growable, adaptive
#   --parallelism=N             limit number of GC threads
#   --print-stats               print statistics after the run
#   --preserve-builddir         keep the build directory around
#   --no-tracepoints            omit support for user-space LTTNG tracepoints
#   --optimize/-O LEVEL         optimize at level LEVEL (default: 2)
#   --warn/-W LEVEL             warn at level LEVEL (default: 2)
#   --check-heap-consistency    enable redundant self-checks in compiled program
#
# Positional: [INPUT-FILE] ARG... (Scheme expressions
# passed as positional args; or stdin/--expr alternative).
#
# whiffle is a **lightweight Scheme compiler that
# emits C** — Andy Wingo's experimental compiler
# from Scheme to C, demonstrating various garbage-
# collector designs (fixed-size, growable,
# adaptive; mark-and-sweep, semi-space copying,
# parallel marker) and warmup/JIT strategies.
# Used as a research vehicle for GC implementation
# in Guile and similar Schemes.  Authored by Andy
# Wingo (Igalia; core Guile developer & GCC GIMPLE
# backend designer).  75 GH stars.  Sister tools:
# guile (Guile Scheme interpreter, in corpus as
# `_guile`), gcc (GNU C compiler, in corpus), but
# also closer kin to Andy's other work like
# Whippet GC.
#
# Critical extraction note: whiffle uses **Guile
# Scheme stdlib `(ice-9 getopt-long)` module** at
# bin/whiffle:23 — corpus's **first documented
# Guile Scheme CLI library** + corpus's **first
# Scheme-dialect CLI library other than Racket**
# (R290 racket/cmdline).  Guile's `(ice-9 getopt-
# long)` ships with the Guile interpreter (no
# external dep); implementation at `module/ice-9/
# getopt-long.scm` in the Guile source tree.
# Originally based on Bash's getopt_long
# conventions but adapted to Scheme idiom (alist
# spec, alist return).  Distinct from R290 Racket
# `racket/cmdline` (hygienic macro generating
# parser at expansion time), R272 C POSIX getopt
# (option string), R287 Nim parseopt (token
# iterator).  Guile's `getopt-long` is FUNCTIONAL-
# DESIGN: takes data, returns data.  Extends
# cross-language CLI taxonomy to FIFTY library
# variants: Rust (6), Go (4), Python (3),
# Crystal 1 OptionParser (R269), Haskell (R270),
# OCaml (R271), C (R272), Java (R276),
# Kotlin (R277), Scala (R278), Dart (R279),
# Ruby (R280), Perl (R281), PHP (R282),
# Swift (R283), F# (R284), Lua (R285), C# (R286),
# Nim 1 parseopt (R287), Zig (R288), D (R289),
# Racket (R290), Common Lisp 1 (R291),
# Erlang (R292), Tcl (R293), Pharo Smalltalk (R294),
# Common Lisp 2 clingon (R295), Julia (R296),
# SWI-Prolog optparse (R297), Pony stdlib cli (R298),
# Crystal 2 Admiral (R299), V stdlib `flag` (R300),
# Nim 2 cligen (R301), Clojure babashka.cli (R302),
# Gleam Glint (R303), Ada GNAT.Command_Line (R304),
# C++ CLI11 (R305), Elixir Optimus (R306), Vala
# GLib.OptionContext (R307), Hare stdlib getopt
# (R308), Standard ML stdlib GetOpt (R309),
# Fortran M_CLI2 (R310), **Guile (ice-9 getopt-
# long)** (R311 — NEW).  **MAJOR MILESTONE**: 50
# CROSS-LANGUAGE CLI LIBRARY VARIANTS — the corpus
# has now documented FIFTY DISTINCT CLI LIBRARIES
# across 50 different language ecosystems.
#
# Critical extraction note: whiffle uses **Guile
# quoted-assoc-list as CLI spec** at whiffle:57-69
# — `'((NAME (single-char #\X) (value #t/#f))
# ...)` is the CANONICAL getopt-long spec form.
# Each entry is a NESTED LIST with NAME-and-
# property-pairs.  Pure Scheme data — manipulated
# like any other list.  Sister to R302 Clojure
# babashka.cli (vector-of-maps) but Guile uses
# LISTS rather than maps.  Distinct from R290
# Racket `command-line` (hygienic macro DSL),
# R287 Nim parseopt (token iterator with caller-
# written loop), R307 Vala GLib (C struct-literal
# table), R310 Fortran M_CLI2 (single-string-
# packed spec).  Corpus's **first documented
# quoted-assoc-list-as-spec CLI pattern**.
#
# Critical extraction note: whiffle uses **Scheme
# `#\X` char-literal for short-flag binding** at
# whiffle:57 et seq — `(single-char #\e)` uses
# Scheme's `#\X` CHARACTER-LITERAL syntax for the
# short-flag name.  Sister to R291 CL `#\h`, R292
# Erlang `$h`, R295 CL clingon `#\A`, R298 Pony
# `'p'`, R300 V `` `n` ``, R308 Hare `'1'`.
# **SEVENTH character-literal CLI cluster language**
# now: CL `#\X` (R291, R295), Erlang `$X` (R292),
# Pony `'X'` (R298), V `` `X` `` (R300), Hare
# `'X'` (R308), **Guile `#\X`** (R311 — Scheme
# variant of the Lisp `#\` convention).  Guile
# shares the `#\X` form with Common Lisp via the
# Lisp family lineage — Scheme R5RS/R6RS/R7RS all
# spec the `#\X` char-literal.  Corpus's **second
# documented `#\X`-pattern language (Scheme
# dialect — joins CL)**.
#
# Critical extraction note: whiffle uses **Guile
# `(value #t/#f/optional)` arg-shape spec** at
# whiffle:57-69 — within each option entry, the
# `(value ...)` clause specifies whether the
# option takes an arg.  Three valid forms:
#   `(value #t)`        ← REQUIRED arg
#   `(value #f)`        ← BOOLEAN flag (no arg)
#   `(value optional)`  ← OPTIONAL arg (third
#                          form, not used in
#                          whiffle but supported)
# Sister to R270 Haskell System.Console.GetOpt
# (`ReqArg`/`NoArg`/`OptArg` constructors —
# discriminated union), R309 SML stdlib GetOpt
# (`NoArg`/`ReqArg`/`OptArg` variants ported from
# Haskell), R304 Ada postfix-markers (`-X:` /
# `-X?`), R307 Vala GLib (OptionArg enum).  Guile's
# approach: SYMBOL-IN-INNER-CLAUSE — `(value SYM)`
# where SYM is one of `#t`/`#f`/`optional`.
# Distinct because the discriminator is at the
# SCHEME-DATUM level (boolean or symbol) rather
# than at the type-system level.  Corpus's
# **first documented value-clause-with-boolean-
# or-symbol arg-shape CLI pattern**.
#
# Critical extraction note: whiffle uses **Guile
# `(option-ref options '() #f)` for positionals**
# at whiffle:75 — the EMPTY-LIST KEY `'()` is
# Guile getopt-long's CONVENTION for retrieving
# the POSITIONAL ARGS list.  The parsed alist has
# entries `((NAME . VALUE) ...)` for flags AND a
# single `('() . positional-list)` entry for
# leftover args.  Distinct from R302 Clojure
# babashka.cli `:args->opts [:name]` (positional
# bound to named option), R303 Gleam Glint
# `named_arg` (typed-name positional), R304 Ada
# `Get_Argument` (stateful iterator), R307 Vala
# GLib empty-string-name OptionEntry sentinel,
# R308 Hare `cmd.args` (field access on parsed
# struct), R310 Fortran M_CLI2 `args=>unnamed`
# (rename-on-import).  Guile's approach:
# POSITIONALS-UNDER-EMPTY-LIST-KEY — the alist
# association is `('() . positionals-list)`.
# Corpus's **first documented empty-list-key-as-
# positional CLI pattern**.
#
# Critical extraction note: whiffle uses **Guile
# `(getopt-long args SPEC)` pure-functional
# parser** at whiffle:56 — `getopt-long` is a
# PURE FUNCTION that takes `args` (full argv as a
# Scheme list) plus the spec, and RETURNS the
# parsed alist.  No mutation, no side effect, no
# global state.  Distinct from R304 Ada Getopt
# (mutates aliased variables via Access pointers),
# R307 Vala GLib `oc.parse(ref args)` (mutates
# argv), R310 Fortran M_CLI2 `set_args` (global-
# module-state side effect).  Sister to R302
# Clojure babashka.cli `cli/parse-opts` (also
# pure functional), R306 Elixir Optimus `Optimus.
# parse` (functional version of the bang variant),
# R303 Gleam Glint `glint.execute` (returns
# Result discriminated union).  Guile's approach:
# DATA-IN-DATA-OUT — corpus's **second
# documented pure-functional-parsed-alist CLI
# pattern** (joining the Lisp family with R290
# Racket and R302 Clojure babashka.cli).
#
# Hunt-skip notes: skipped `_guile` (Guile
# interpreter, already in corpus), `_mu` (1699
# stars, in corpus already), `_cat` / `_hello`
# (in corpus / OS dups), `_unison` (DUP with
# stock zsh).  Probed `lepton-eda/lepton-netlist`
# (260 stars — uses Guile getopt-long but spec
# lives in shared lepton/ scheme module, not
# in a single self-contained file), `artyom-
# poptsov/guile-ssh sssh` (74 stars — Guile SSH
# bindings example, small surface), `Pingus/
# pingus-level` (210 stars — but uses ad-hoc
# argument loop, not full getopt-long), `isamert/
# jaro` (89 stars — bash wrapper around a small
# Guile core, harder to extract), `yawaramin/
# ggspec` (27 stars — testing framework, not
# user CLI), `git-for-windows/git-sdk-64 frisk.
# scm` (0 stars, niche), `Distrotech/mailutils
# guimb` (mailutils internals), `spk121/guile100
# cat.scm` (CAT EXAMPLE, would dup with OS cat).
# Chose whiffle: 75 stars (Andy Wingo, core Guile
# dev), 14 FLAGS + 1 positional in a single
# 201-line bin/whiffle (Guile-shebang Scheme
# script), exercises EVERY MAJOR `(ice-9 getopt-
# long)` PATTERN (quoted-assoc-list spec,
# (single-char #\X) char-literal short flags,
# (value #t/#f) arg-shape, option-ref for
# retrieval, option-ref with '() for positionals),
# real binary in Andy Wingo's research-grade
# Whiffle Scheme-to-C compiler project.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 15 flags decoded source-direct from getopt-long
# spec at whiffle:57-69.  Plus help/print-stats
# both auto-exposed.
_arguments -s -S \
  '(-e --expr)'{-e+,--expr=}'[input is EXPR instead of a file]:scheme expr:' \
  '(- *)'{-h,--help}'[print help message]' \
  '(-S --assemble)'{-S,--assemble}'[only produce C file; do not make an executable]' \
  '--preserve-builddir[keep the build directory around]' \
  '--no-tracepoints[omit support for user-space LTTNG tracepoints]' \
  '(-O --optimize)'{-O+,--optimize=}'[optimize at LEVEL (default: 2)]:level:(0 1 2 3)' \
  '(-W --warn)'{-W+,--warn=}'[warn at LEVEL (default: 2)]:level:(0 1 2 3)' \
  '--gc=[choose gc implementation; see --gc=help]:gc:(help bdw mmc parallel-mmc generational-mmc semi pcc)' \
  '--heap-size=[specify initial heap size]:size:' \
  '--heap-size-policy=[how to size heap]:policy:(fixed growable adaptive)' \
  '--parallelism=[limit to number of GC threads]:threads:' \
  '--print-stats[print statistics after the run]' \
  '(-o --output)'{-o+,--output=}'[compile the input only, write to FILE]:output file:_files' \
  '--timeout=[kill the process if still running after NSECS]:seconds:' \
  '--check-heap-consistency[enable redundant self-checks in compiled program]' \
  '1:input scheme file:_files -g "*.scm"' \
  '*::scheme arg:' && ret=0

return ret
