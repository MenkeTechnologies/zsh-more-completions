#compdef bill
# =============================================================================
# bill — jameshaydon/lawvere's "Lawvere"
#   programming language compiler/interpreter
#   executable (named after the category-
#   theorist WILLIAM LAWVERE).  Lawvere is a
#   CATEGORICAL programming language with
#   effects — programs are written as
#   COMPOSABLE ARROWS in a category that has
#   structures (cartesian closed, distributive,
#   etc.) corresponding to the language
#   features used.  Source code is POINT-FREE
#   (NO LAMBDAS); programs are concatenations
#   of arrows.  Effect system is based on
#   FREE EFFECT CATEGORIES.  Compiles to FOUR
#   different targets: Haskell evaluator (the
#   default), JavaScript source, "VM code"
#   (Categorical Abstract Machine instructions),
#   or the embedded CAM VM itself.  132nd
#   language entry — ROUND 800 round-number
#   landmark.
#
# 132ND LANGUAGE ENTRY + R800 LANDMARK —
# Lawvere closes the 3+1 micro-cycle started
# after Axis 52 (SSH Client/Server Library)
# closed at 1/1/1 three-language symmetry in
# R799 (TS-Node=107 `_preevy` on ssh2 ^1.12
# + R798 Go=107 `_ts-ssh` on golang.org/x/
# crypto/ssh + R797 Rust=107 `_termirs` on
# russh 0.57.0).
#
# Distinguishing Lawvere from the 131 prior
# corpus languages — closest neighbours and
# their differences:
#   - CONCATENATIVE FAMILY (`_factor`, `_joy`,
#     `_mirth` R796, `_mlatu` R784, `_cognate`,
#     `_forth` family):
#       most concatenative langs are STACK-
#       BASED — composition is implicit via
#       juxtaposition + a shared stack.
#       Lawvere is ARROW-COMPOSITION-BASED —
#       composition is `.` between Hom(A, B)
#       and Hom(B, C) yielding Hom(A, C).
#       NOT stack-based.  Closer to "point-
#       free Haskell with category theory
#       primitives"
#   - HASKELL (`_ghc`, `_runghc`): also
#     supports point-free style via `.` +
#     `flip` + curry tricks, BUT Haskell
#     allows lambdas and lets you DROP IN AND
#     OUT of point-free.  Lawvere forbids
#     lambdas — point-free is the ONLY style
#   - ARROW NOTATION IN HASKELL: `proc/(-<)`
#     in Haskell's `Control.Arrow` extends
#     Haskell with arrow do-notation.
#     Lawvere is the natural home — no
#     wrapping or extension needed
#   - COQ / AGDA / LEAN / IDRIS: theorem
#     provers with type theory.  Lawvere is
#     more of a PROGRAMMING language with
#     categorical foundations than a proof
#     assistant; runtime evaluation is the
#     primary use-case
#   - CATEGORY-THEORY-FOUNDED LITERATURE:
#     Lawvere is the only RUNNABLE LANGUAGE
#     in the corpus that DIRECTLY surfaces
#     concepts like "compile this to ANY
#     cartesian-closed category" as a CLI
#     flag.  Closest theoretical neighbour
#     is Conal Elliott's `concat` Haskell
#     library (not a separate language)
#
# KEY LAWVERE LANGUAGE FEATURES:
#   - ARROWS AS PRIMARY ABSTRACTION — every
#     value is an "arrow" between objects in
#     a category.  Even constants — `42` is
#     the constant arrow `1 → Int` mapping
#     the terminal object to 42
#   - CATEGORICAL SKETCH DECLARATIONS —
#     `sketch Foo { obs: A, B, ars: f: A
#     → B }` declares a finite categorical
#     structure
#   - CATEGORY DECLARATIONS — `category Foo
#     { ... }` introduces a target category
#     for compilation
#   - INTERP DECLARATIONS — `interp J : Foo →
#     Bar { ... }` declares a functor between
#     two categories.  Used to MAP a Lawvere
#     program in source category `Foo` to a
#     target category `Bar`
#   - FREE EFFECT CATEGORIES — effects are
#     modelled as free monoidal categories
#     extending the program category.
#     Allows "compile this effectful program
#     to a pure category by interpreting
#     each effect arrow"
#   - JS COMPILATION — `--target js` emits
#     readable JavaScript source.  Useful
#     for shipping Lawvere logic to the
#     browser
#   - CAM BYTECODE — `--target vmcode`
#     emits a stream of instructions for
#     the Categorical Abstract Machine
#     (CAM) — a stack-based VM whose
#     instruction set corresponds to
#     category-theory operations (`comp`,
#     `pair`, `fst`, `snd`, `inl`, `inr`,
#     `case`, etc.).  Bytecode is human-
#     readable
#   - CAM VM EXECUTION — `--target vm`
#     compiles to CAM bytecode AND
#     executes it on the embedded CAM VM.
#     Useful for distinct evaluation
#     semantics vs the Haskell evaluator
#   - HASKELL EVALUATOR — `--target hs`
#     (the default) directly evaluates
#     the program by translating each
#     arrow to a Haskell function.
#     Fastest path for interactive
#     development
#   - INTERACTIVE REPL — `bill -i`
#     starts a read-eval-print loop with
#     history at `.lawvere-repl`.  `:r`
#     reloads, `:q` quits.  Supports
#     auto-completion on loaded names
#   - LITERATE LAWVERE — README.md and
#     example files double as runnable
#     Lawvere programs.  `bill -i README.md`
#     loads the embedded code blocks
#   - WARNINGS — emitted by default for
#     suspicious-looking code; suppressible
#     via `-w / --no-warnings`
#
# CLI ARGUMENT PARSER — Haskell `optparse-
# applicative`.  All flags use GNU-style
# `--long` + short `-x` form.  No
# subcommands — the binary's behaviour is
# controlled by `--interactive` (REPL vs
# batch) and `--target` (which compiler
# backend to invoke).
#
# COMPILE TARGETS (`-t / --target`):
#   * `hs` (DEFAULT)  Haskell evaluator —
#                     directly evaluates the
#                     main arrow on the
#                     terminal-object input
#                     and prints the result
#   * `js`            JavaScript source —
#                     emits readable JS to
#                     stdout
#   * `vmcode`        CAM bytecode (text) —
#                     prints the CAM
#                     instruction stream to
#                     stdout
#   * `vm`            CAM VM — compiles to
#                     bytecode AND runs it on
#                     the embedded VM
#
# SOURCE FILE EXTENSION: `*.law`
#
# REPL COMMANDS (interactive mode):
#   * `<expr>`        evaluate an expression
#   * `:r`            reload the loaded file
#   * `:q`            quit
#
# CRITICAL DEPENDENCIES (from
# `lawvere.cabal`):
#   - lens                     — record /
#                                state
#                                manipulation
#   - protolude                — alternative
#                                Haskell
#                                prelude
#   - megaparsec               — parser
#                                combinator
#                                library
#   - optparse-applicative     — CLI parser
#   - haskeline                — REPL line-
#                                editor
#                                primitives
#   - transformers + mtl       — monad
#                                transformers
#   - containers               — Set/Map
#                                types
#   - ghc-extras / generic-data
#                              — generic
#                                deriving
#                                helpers
#
# Build via cabal or stack.  GHC 9.x.
# Cross-platform; runs anywhere GHC runs.
#
# UPSTREAM:
#   * Source             : https://github.com/jameshaydon/lawvere
#   * License            : MIT
#   * Maintainer         : James Haydon (jameshaydon)
#   * Named after        : https://en.wikipedia.org/wiki/William_Lawvere
#   * Categorical
#     foundations
#     reference          : https://ncatlab.org/nlab/show/cartesian+closed+category
#
# INSTALL:
#   # Cabal
#   git clone https://github.com/jameshaydon/lawvere
#   cd lawvere
#   cabal install
#
#   # Stack
#   stack install
#
#   # Nix flake (shell.nix shipped)
#   nix-shell
#
# USAGE EXAMPLES:
#
#   # Run a Lawvere program with the Haskell
#   # evaluator (default target)
#   bill main.law
#
#   # Interactive REPL
#   bill -i
#   bill --interactive
#
#   # Load a file into the REPL
#   bill -i main.law
#
#   # Run README.md as a literate Lawvere
#   # program
#   bill -i README.md
#
#   # Compile to JavaScript source
#   bill --target js main.law > main.js
#   bill -t js main.law > main.js
#
#   # Emit CAM bytecode to stdout
#   bill --target vmcode main.law
#   bill -t vmcode main.law
#
#   # Run on the embedded Categorical Abstract
#   # Machine VM (instead of the Haskell
#   # evaluator)
#   bill --target vm main.law
#   bill -t vm main.law
#
#   # Suppress warnings
#   bill -w main.law
#   bill --no-warnings main.law
#
#   # Combine interactive + JS target + no
#   # warnings
#   bill -i -t js -w main.law
#
#   # Help (optparse-applicative default)
#   bill --help
#   bill -h
#
# SAMPLE PROGRAM (verbatim from upstream
# README):
#
#   # tennis-score.law
#   (.playerA .points - .playerB .points)
#   { leader = (> 0) [ true = "A", false = "B"],
#     delta  = abs show }
#   "Player {.leader} is winning by {.delta} points!"
#
# OPTIONS (sourced directly from
# https://github.com/jameshaydon/lawvere/blob/main/bill/Main.hs `optsParser`):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _bill_targets
_bill_targets=(
    'hs:Haskell evaluator (default; direct evaluation)'
    'js:JavaScript source (emits readable JS to stdout)'
    'vmcode:Categorical Abstract Machine bytecode (text instruction stream)'
    'vm:Run on the embedded CAM VM (compile + execute on the categorical abstract machine)'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-i --interactive)'{-i,--interactive}'[interactive REPL mode (read-eval-print loop with history at .lawvere-repl)]' \
    '(-t --target)'{-t+,--target=}'[compiler target (default hs)]:target:->target' \
    '(-w --no-warnings)'{-w,--no-warnings}'[turn off warnings]' \
    '*:Lawvere source file:_files -g "*.(law|md)"' \
    && ret=0

case $state in
    target)
        _describe -t targets 'compiler target' _bill_targets && ret=0 ;;
esac

return ret
