#compdef cdrdao
# Documentation: man cdrdao(1)
# Source: cdrdao/cdrdao dao/main.cc (master) — disk-at-once CD/DVD recorder (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'show-toc:print TOC and exit'
    'toc-info:print short TOC summary'
    'toc-size:print total number of blocks for TOC'
    'read-toc:create TOC from audio CD'
    'read-cd:create TOC and rip audio data from CD'
    'read-cddb:contact CDDB and add CD-TEXT to TOC'
    'show-data:print audio data and exit'
    'read-test:read all audio files and exit'
    'disk-info:show information about inserted medium'
    'discid:print CDDB information'
    'msinfo:show multi-session info (script-friendly)'
    'drive-info:show drive information'
    'cdtext:show CD-TEXT content'
    'unlock:unlock drive after failed write'
    'blank:blank a CD-RW'
    'scanbus:scan for devices'
    'simulate:shortcut for write --simulate'
    'write:write CD'
    'copy:copy CD'
)

_arguments -s -C \
    '1:command:->cmd' \
    '*::cmd args:->cmdargs' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'cdrdao command' cmds && ret=0
        ;;
    cmdargs)
        _arguments \
            '-v+[verbose level]:level:_default' \
            '-n[suppress 10-second startup pause]' \
            '--device+[SCSI device]:device:_files' \
            '--driver+[driver id]:driver:_default' \
            '--source-device+[source SCSI device]:device:_files' \
            '--source-driver+[source driver id]:driver:_default' \
            '--simulate[write simulation only]' \
            '--speed+[writing speed]:speed:_default' \
            '--rspeed+[reading speed]:speed:_default' \
            '--multi[do not close session]' \
            '--eject[eject CD when done]' \
            '--reload[reload disk if needed]' \
            '--force[force operation]' \
            '--swap[swap audio byte order]' \
            '--session+[select session]:n:_default' \
            '--fast-toc[do not extract pre-gaps and index marks]' \
            '--read-raw[read raw sectors]' \
            '--read-subchan+[sub-channel mode]:mode:(rw rw_raw)' \
            '--tao-source[source CD written TAO]' \
            '--tao-source-adjust+[link blocks for TAO source]:n:_default' \
            '--paranoia-mode+[DAE paranoia mode 0-3]:mode:(0 1 2 3)' \
            '--query-string[print CDDB query only]' \
            '--cddb-servers+[CDDB server list]:servers:_default' \
            '--cddb-directory+[local CDDB directory]:dir:_files -/' \
            '--cddb-timeout+[CDDB timeout (seconds)]:seconds:_default' \
            '--datafile+[data filename in TOC]:file:_files' \
            '--tmpdir+[temp dir for wav files]:dir:_files -/' \
            '--keep[keep temp wav files]' \
            '--blank-mode+[blank mode]:mode:(full minimal)' \
            '--buffer-under-run-protection+[BURN-Proof flag]:n:(0 1)' \
            '--write-speed-control+[write speed control]:n:(0 1)' \
            '--buffers+[fifo buffer size (min 10)]:n:_default' \
            '--capacity+[disk capacity minutes for --full-burn]:minutes:_default' \
            '--full-burn[burn to outer disk edge]' \
            '--no-mode2-mixed[do not switch to mode2_mixed]' \
            '--overburn[allow overburning]' \
            '--with-cddb[fetch CDDB CD-TEXT while copying]' \
            '--no-utf8[do not show CD-TEXT as UTF-8]' \
            '*:toc-file:_files -g "*.toc"' \
            && ret=0
        ;;
esac

return ret
