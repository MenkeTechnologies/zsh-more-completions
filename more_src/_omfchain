#compdef omfchain
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/omfchain/node9.html
# Extract light curves from OM Fast mode observations (Optical Monitor fast chain)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--inpdirectory=[location of input files directory]:dir:_files -/' \
  '--outdirectory=[location of output files directory]:dir:_files -/' \
  '--boxscale=[sliding box size for detection by omdetect]:value' \
  '--contrast=[threshold parameter for source detection]:value' \
  '--maxscale=[maximum power of 2 to search to by omdetect]:value' \
  '--nsigma=[standard deviations required for source detection]:value' \
  '--smoothsize=[smooth size in pixels for image and background]:value' \
  '--srcradius=[radius of the source extraction circle]:value' \
  '--bkginner=[inner radius of background annulus]:value' \
  '--bkgouter=[outer radius of background annulus]:value' \
  '--timebinsize=[size of the time bins in seconds]:seconds' \
  '--bkgfromimage=[use background from accompanying imaging data]:bool:(yes no)' \
  '--psfphotometryenabled=[enable PSF-fitting for source photometry]:bool:(yes no)' \
  '--maxrawcountrate=[count-rate threshold limiting PSF-photometry]:value' \
  '--ignoremod8noise=[ignore modulo-8 noise around source]:bool:(yes no)' \
  '--subtractbkg=[enable background subtraction]:bool:(yes no)' \
  '--rawattitude=[attitude data usage by omprep task]:value:(0 1 2)' \
  '*:param=value:_default' && ret=0

return ret
