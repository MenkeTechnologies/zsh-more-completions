#compdef setools

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'sediff:semantic policy diff'
  'sedta:domain transition analysis'
  'seinfo:policy info'
  'seinfoflow:information flow analysis'
  'sesearch:search policy'
  'apol:GUI policy analyzer'
  'rules:list policy rules'
  'audit:audit log policy analyzer'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'setools command' commands && ret=0 ;;
esac

return ret
