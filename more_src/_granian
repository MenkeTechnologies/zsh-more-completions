#compdef granian

# Zsh completion for granian - Rust HTTP server for Python ASGI/WSGI/RSGI

_arguments -s -S \
  '--host[bind socket to this host]:host:' \
  '--port[bind socket to this port]:port:' \
  '--interface[application interface type]:type:(asgi asginl wsgi rsgi)' \
  '--http[HTTP version]:version:(auto 1 2)' \
  '--ws[enable WebSocket support]:mode:(auto)' \
  '--workers[number of worker processes]:count:' \
  '--threads[number of threads per worker]:count:' \
  '--blocking-threads[number of blocking threads]:count:' \
  '--threading-mode[threading mode]:mode:(runtime workers)' \
  '--loop[event loop implementation]:loop:(auto asyncio uvloop)' \
  '--backlog[maximum number of pending connections]:count:' \
  '--backpressure[maximum number of concurrent requests]:count:' \
  '--http1-buffer-size[HTTP/1 buffer size]:bytes:' \
  '--http1-keep-alive[enable HTTP/1 keep-alive]' \
  '--http1-pipeline-flush[flush pipeline on each response]' \
  '--http2-adaptive-window[enable adaptive window]' \
  '--http2-initial-connection-window-size[initial window size]:bytes:' \
  '--http2-initial-stream-window-size[initial stream window size]:bytes:' \
  '--http2-keep-alive-interval[keep-alive ping interval]:seconds:' \
  '--http2-keep-alive-timeout[keep-alive ping timeout]:seconds:' \
  '--http2-max-concurrent-streams[max concurrent HTTP/2 streams]:count:' \
  '--http2-max-frame-size[max HTTP/2 frame size]:bytes:' \
  '--http2-max-headers-size[max headers size]:bytes:' \
  '--http2-max-send-buffer-size[max send buffer size]:bytes:' \
  '--log[enable logging]' \
  '--no-log[disable logging]' \
  '--log-level[log level]:level:(critical error warning warn info debug)' \
  '--log-config[logging configuration file]:file:_files -g "*.json *.ini *.yaml *.yml"' \
  '--access-log[enable access logging]' \
  '--no-access-log[disable access logging]' \
  '--access-log-fmt[access log format]:format:' \
  '--ssl-keyfile[SSL key file]:file:_files' \
  '--ssl-certificate[SSL certificate file]:file:_files' \
  '--url-path-prefix[URL path prefix]:prefix:' \
  '--respawn-failed-workers[respawn failed workers]' \
  '--respawn-interval[respawn interval]:seconds:' \
  '--reload[enable auto-reload on code changes]' \
  '--process-name[set process name]:name:' \
  '--pid-file[write PID to file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:application (module\:app):' && return 0
