#compdef auditd
# _auditd — Linux audit auditd daemon (kernel-audit consumer that writes /var/log/audit/audit.log and pipes events to dispatchers; -f stay foreground, -l allow boot-time queueing, -n no boot mode, -s enable|disable|nochange set initial enable state, -c config file dir, -v version, -h help; reads /etc/audit/auditd.conf for log targets + rotation)
# upstream: https://github.com/linux-audit/audit-userspace
# Flags from linux-audit/audit-userspace src/auditd.c on tip.

_auditd() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-f[foreground]' \
        '-l[allow boot-time queueing]' \
        '-n[no boot mode]' \
        '-s+[initial state]:state:(enable disable nochange)' \
        '-c+[config dir]:dir:_files -/'
}

_auditd "$@"
