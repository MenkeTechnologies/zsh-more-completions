#compdef goolabs
# Documentation: https://github.com/tell-k/goolabs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for goolabs — Japanese morphological analysis CLI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-a --app-id)'{-a,--app-id}'[Goo Labs application ID]:id' \
  '1:mode:(sentence hiragana roman romaji entity keyword)' && ret=0

return ret
