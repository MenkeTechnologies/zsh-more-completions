#compdef goolabs

# Zsh completion for goolabs — Japanese morphological analysis CLI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-a --app-id)'{-a,--app-id}'[Goo Labs application ID]:id' \
  '1:mode:(sentence hiragana roman romaji entity keyword)' && ret=0

return ret
