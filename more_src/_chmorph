#compdef chmorph
# Documentation: https://github.com/hunspell/hunspell/blob/master/src/tools/chmorph.cxx
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

# chmorph affix_file dictionary_file file_to_convert STRING1 STRING2
_arguments \
  '1:affix file:_files -g "*.aff"' \
  '2:dictionary file:_files -g "*.dic"' \
  '3:input text:_files' \
  '4:source pattern:' \
  '5:target pattern:' && ret=0

return ret
