#compdef 66-update
# 66-update — update a 66 service after frontend file changes (Obarun/s6)

_arguments -s -S \
  '-h[show help]' \
  '-z[use color output]' \
  '-v[set verbosity level]:verbosity:(0 1 2 3 4)' \
  '-t[set tree name]:tree name:' \
  '-f[force update even if unchanged]' \
  '*:service name:'
