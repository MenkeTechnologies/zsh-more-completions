#compdef 1password
# Documentation: https://man.archlinux.org/search?q=1password
# Reference accessed: 2026-05-16

# Zsh completion for 1Password CLI (desktop app launcher)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--silent[start silently]' \
  '--enable-updater[enable auto-updater]' \
  '--disable-updater[disable auto-updater]' && ret=0

return ret
