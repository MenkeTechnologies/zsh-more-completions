#compdef frida-join
# Documentation: https://github.com/frida/frida-tools/blob/main/frida_tools/join.py
# Make a running process join a Frida portal

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[output version information and exit]' \
  '(-D --device)'{-D,--device}'=[connect to device with the given ID]:device ID' \
  '(-U --usb)'{-U,--usb}'[connect to USB device]' \
  '(-R --remote)'{-R,--remote}'[connect to remote frida-server]' \
  '(-H --host)'{-H,--host}'=[connect to remote frida-server on HOST]:host' \
  '--certificate=[speak TLS with HOST, expecting CERTIFICATE]:certificate:_files' \
  '--origin=[connect to remote server with Origin header set to ORIGIN]:origin' \
  '--token=[authenticate with HOST using TOKEN]:token' \
  '(-f --file)'{-f,--file}'=[spawn FILE]:file:_files' \
  '(-F --attach-frontmost)'{-F,--attach-frontmost}'[attach to frontmost application]' \
  '(-n --attach-name)'{-n,--attach-name}'=[attach to NAME]:name' \
  '(-N --attach-identifier)'{-N,--attach-identifier}'=[attach to IDENTIFIER]:identifier' \
  '(-p --attach-pid)'{-p,--attach-pid}'=[attach to PID]:pid' \
  '--portal-location=[join portal at LOCATION]:location' \
  '--portal-certificate=[speak TLS with portal, expecting CERTIFICATE]:certificate:_files' \
  '--portal-token=[authenticate with portal using TOKEN]:token' \
  '*--portal-acl-allow=[limit portal access to control channels with TAG]:tag' && ret=0

return ret
