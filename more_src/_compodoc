#compdef compodoc
# =============================================================================
# compodoc — compodoc/compodoc's documentation
#   generator for ANGULAR applications + plain
#   TypeScript projects.  Scans an Angular
#   workspace via `ts-morph`, builds a typed
#   intermediate model of every component /
#   module / directive / pipe / service /
#   guard / interceptor / class / interface,
#   and emits a static HTML site with
#   integrated full-text search powered by the
#   client-side `lunr` v2 index built at site-
#   generation time.  Also emits dependency
#   graphs, routing diagrams, documentation
#   coverage reports, and an optional dev
#   server with watch mode.  Direct dep on
#   `lunr ^2.3.9` for the search index +
#   `commander ^14.0.3` for CLI parsing.
#   TS-Node=105 leader bump CLOSING Axis 50
#   (Full-Text Search Engine) at 1/1/1 three-
#   language symmetry.
#
# AXIS 50 — FULL-TEXT SEARCH ENGINE — CLOSES @ R791
# =================================================
# Closes the three-language Full-Text Search
# Engine axis at 1/1/1 symmetry — the half-
# century axis landmark.
#   * Rust       (R789): tantivy ^0.19
#                — bundled in `toshi` (Toshi
#                  HTTP daemon, Elasticsearch-
#                  shaped API)
#   * Go         (R790): blevesearch/bleve
#                v0.7.0 — bundled in `srchx`
#                  (standalone HTTP daemon,
#                  Elasticsearch-shaped API)
#   * TS-Node    (R791, THIS ROUND): lunr
#                ^2.3.9 — bundled in
#                `compodoc` as the CLIENT-SIDE
#                search index that ships in the
#                generated documentation site
#
# Lunr (olivernn/lunr.js, 9k+ stars on
# GitHub, MIT) is the canonical pure-JS
# full-text search library.  Builds an
# inverted index in memory or from a
# serialised JSON snapshot.  Used heavily by
# static-site generators (Jekyll, Hugo,
# Docusaurus, VuePress, MkDocs, Compodoc)
# that need client-side search without a
# server.  Distinguishes from sibling JS
# search libs:
#   - elasticlunr — fork of lunr v0.7 with
#     additional features (boosting, fields,
#     filtering).  Older API
#   - @orama/orama — newer (2023) JS search
#     engine with typed fields, vector
#     search, and a serializable index.
#     Different design point: build-time
#     and query-time tunables
#   - flexsearch / minisearch / mark.js —
#     other contemporary JS search libs.
#     Each makes different size-vs-accuracy
#     tradeoffs
#
# Compodoc's lunr usage:
#   At documentation-generation time the
#   compiler walks the typed Angular model
#   and serialises each named item (Module,
#   Component, Directive, Pipe, Service,
#   Guard, Interceptor, Class, Interface,
#   Enum, Function, miscellaneous) into a
#   lunr-indexable document with fields:
#       name, body, type, file
#   The serialised index is shipped as
#   `js/search/search_index.js` in the
#   output site.  The browser-side search
#   widget loads the index once, then
#   answers queries entirely client-side
#   via lunr's `Index.search()` API.
#
# Distinguishing compodoc from other corpus
# documentation generators:
#   - TYPEDOC (`_typedoc`, already in corpus):
#     general TypeScript documentation
#     generator, NOT Angular-aware.  Both
#     use lunr for search but typedoc indexes
#     plain TS symbols; compodoc indexes
#     ANGULAR-specific concepts (modules,
#     components-with-templates, decorators,
#     DI tokens, routes)
#   - JSDOC (`_jsdoc`): JavaScript-first.
#     No TS or Angular awareness
#   - DOCUSAURUS (`_docusaurus`): general-
#     purpose documentation site framework.
#     Markdown-driven content, not Angular-
#     code-driven
#   - STORYBOOK (`_storybook`): component-
#     story browser, not API documentation
#   - NG-MORPH / NG-PACKAGR: Angular library
#     build tooling, not documentation
#
# DOCUMENTATION COVERAGE:
# A compodoc-specific feature is per-class /
# per-property documentation coverage checks
# in CI.  Use `--coverageTest <THRESHOLD>`
# to fail builds where global coverage
# drops below threshold.  Use
# `--coverageMinimumPerFile <N>` to enforce
# per-file minimums.  Use `--coverageExclude
# <PATTERNS>` to scope the check.
# `--coverageTestThresholdFail false` turns
# the failure into a warning.  Used widely
# in Angular CI pipelines
#
# THEME SUPPORT:
# Eight built-in HTML themes (`--theme`):
#   gitbook (default) / laravel / original /
#   material / postmark / readthedocs /
#   stripe / vagrant
# Plus `--extTheme <FILE>` for an external
# stylesheet override and a hidden
# `--templates <FOLDER>` for Handlebars
# template overrides
#
# LOCALES:
# 17 built-in UI translations (`--language`):
#   bg-BG, de-DE, en-US, es-ES, fr-FR,
#   hu-HU, it-IT, ja-JP, ka-GE, ko-KR,
#   nl-NL, pl-PL, pt-BR, ru-RU, sk-SK,
#   zh-CN, zh-TW
#
# CRITICAL DIRECT DEPENDENCIES (from
# package.json):
#   - lunr ^2.3.9              — client-side
#                                full-text
#                                search index
#                                [AXIS 50 LIBRARY]
#   - commander ^14.0.3        — CLI parser
#   - fs-extra ^11.3.5         — async-aware
#                                fs wrapper
#   - ts-morph                 — TypeScript
#                                compiler API
#                                wrapper for
#                                AST walking
#   - cosmiconfig              — config file
#                                discovery
#                                (.compodocrc /
#                                .compodocrc.json
#                                / .compodocrc.yaml
#                                / package.json
#                                key)
#   - fast-glob                — file
#                                discovery
#
# Node 20+ MSRV per upstream package.json
# `engines.node` block.  TypeScript 5.x.
#
# UPSTREAM:
#   * Source             : https://github.com/compodoc/compodoc
#   * Site               : https://compodoc.app
#   * lunr.js            : https://github.com/olivernn/lunr.js
#   * License            : MIT
#   * Maintainer         : Vincent Ogloblinsky (vogloblinsky)
#
# INSTALL:
#   # Global npm install
#   npm install -g @compodoc/compodoc
#
#   # Project-local (preferred for CI
#   # version pinning)
#   npm install --save-dev @compodoc/compodoc
#
#   # Or npx
#   npx @compodoc/compodoc -p tsconfig.json
#
# USAGE EXAMPLES:
#
#   # Run with auto-discovered tsconfig.json
#   compodoc -p tsconfig.json
#
#   # Output to a custom folder
#   compodoc -p tsconfig.json -d docs/api
#
#   # Set documentation title
#   compodoc -p tsconfig.json -n "My App API"
#
#   # Generate + serve on default port
#   # http://localhost:8080
#   compodoc -p tsconfig.json -s
#
#   # Generate + serve on custom port
#   compodoc -p tsconfig.json -s -r 4200
#
#   # Generate + serve + watch for source
#   # changes (live rebuild)
#   compodoc -p tsconfig.json -s -w
#
#   # Open in browser after generation
#   compodoc -p tsconfig.json -s -o
#
#   # Use the readthedocs theme
#   compodoc -p tsconfig.json --theme readthedocs
#
#   # Use French UI
#   compodoc -p tsconfig.json --language fr-FR
#
#   # Custom favicon + logo
#   compodoc -p tsconfig.json \
#       --customFavicon ./favicon.ico \
#       --customLogo ./logo.svg
#
#   # Export to JSON (machine-readable model)
#   compodoc -p tsconfig.json -e json
#
#   # Minimal mode (no search, no graph,
#   # no coverage)
#   compodoc -p tsconfig.json --minimal
#
#   # Disable specific tabs / pages
#   compodoc -p tsconfig.json \
#       --disableSourceCode \
#       --disableTemplateTab \
#       --disableStyleTab \
#       --disableDomTree
#
#   # Documentation coverage gate
#   compodoc -p tsconfig.json --coverageTest 80
#   compodoc -p tsconfig.json \
#       --coverageTest 80 \
#       --coverageMinimumPerFile 50 \
#       --coverageExclude "**/*.spec.ts,**/main.ts"
#
#   # Include external markdown pages
#   compodoc -p tsconfig.json \
#       --includes ./docs-md \
#       --includesName "Guides"
#
#   # Public-API-only documentation
#   # (only exports from dist/*.d.ts)
#   compodoc -p tsconfig.json \
#       --publicApiOnly ./dist
#
#   # Tune search result limit
#   compodoc -p tsconfig.json --maxSearchResults 50
#
#   # Help + version (commander default)
#   compodoc --help
#   compodoc -h
#   compodoc --version
#   compodoc -V
#
# CONFIG FILE (auto-discovered via
# cosmiconfig):
#   * `.compodocrc`
#   * `.compodocrc.json`
#   * `.compodocrc.yaml`
#   * `compodoc` key inside `package.json`
#
#   {
#     "tsconfig": "tsconfig.json",
#     "output": "docs/api",
#     "name":   "My App",
#     "theme":  "material",
#     "language": "en-US",
#     "disableSourceCode": false,
#     "coverageTest": 70,
#     "maxSearchResults": 100
#   }
#
# OPTIONS (sourced directly from
# https://github.com/compodoc/compodoc/blob/main/src/index-cli.ts program.option chain):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _compodoc_themes
_compodoc_themes=(
    'gitbook:GitBook theme (default)'
    'laravel:Laravel docs theme'
    'original:Compodoc original theme'
    'material:Material Design theme'
    'postmark:Postmark-inspired theme'
    'readthedocs:ReadTheDocs theme'
    'stripe:Stripe-inspired theme'
    'vagrant:Vagrant theme'
)

local -a _compodoc_languages
_compodoc_languages=(
    'bg-BG:Bulgarian'
    'de-DE:German'
    'en-US:English (default)'
    'es-ES:Spanish'
    'fr-FR:French'
    'hu-HU:Hungarian'
    'it-IT:Italian'
    'ja-JP:Japanese'
    'ka-GE:Georgian'
    'ko-KR:Korean'
    'nl-NL:Dutch'
    'pl-PL:Polish'
    'pt-BR:Portuguese (Brazil)'
    'ru-RU:Russian'
    'sk-SK:Slovak'
    'zh-CN:Chinese (Simplified)'
    'zh-TW:Chinese (Traditional)'
)

local -a _compodoc_export_formats
_compodoc_export_formats=(
    'html:Static HTML site (default)'
    'json:Machine-readable JSON model'
)

local -a _compodoc_bool
_compodoc_bool=(
    'true:enable'
    'false:disable'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-c --config)'{-c+,--config=}'[config file (.compodocrc, .compodocrc.json, .compodocrc.yaml, or package.json compodoc key)]:config:_files -g "*.(json|yaml|yml|compodocrc)"' \
    '(-p --tsconfig)'{-p+,--tsconfig=}'[tsconfig.json file]:tsconfig:_files -g "*.json"' \
    '(-d --output)'{-d+,--output=}'[output documentation directory]:dir:_files -/' \
    '(-y --extTheme)'{-y+,--extTheme=}'[external styling theme file]:file:_files -g "*.(css|scss|less)"' \
    '(-n --name)'{-n+,--name=}'[documentation title]:title: ' \
    '(-a --assetsFolder)'{-a+,--assetsFolder=}'[external assets folder to copy into generated docs]:dir:_files -/' \
    '(-o --open)'{-o,--open}'[open the generated documentation in the browser]' \
    '(-t --silent)'{-t,--silent}'[silent mode (no console logs)]' \
    '(-s --serve)'{-s,--serve}'[serve generated documentation (default http://localhost:8080)]' \
    '--host=[change default host address]:host: ' \
    '(-r --port)'{-r+,--port=}'[change default serving port (default 8080)]:port: ' \
    '(-w --watch)'{-w,--watch}'[watch source files after serve and rebuild on change]' \
    '(-e --exportFormat)'{-e+,--exportFormat=}'[export format]:format:->expfmt' \
    '--files=[files provided by external tool (for coverage test)]:files: ' \
    '--language=[UI language]:language:->lang' \
    '--theme=[built-in theme name]:theme:->theme' \
    '--hideGenerator[do not print Compodoc link at bottom of page]' \
    '--hideDarkModeToggle[do not show dark mode toggle button]' \
    '--toggleMenuItems=[close-by-default menu items (csv)]:items: ' \
    '--navTabConfig=[nav tab configs (csv JSON objects)]:config: ' \
    '--templates=[Handlebars template override directory]:dir:_files -/' \
    '--includes=[external markdown files to include]:path:_files -/' \
    '--includesName=[menu item name for the external markdown set]:name: ' \
    '--coverageTest=[documentation coverage threshold (default 70)]:threshold: ' \
    '--coverageMinimumPerFile=[per-file documentation coverage minimum (default 0)]:minimum: ' \
    '--coverageExclude=[exclude files from documentation coverage (csv globs)]:patterns: ' \
    '--coverageTestThresholdFail=[fail (true) vs warn (false) on coverage threshold]:bool:->bool' \
    '--coverageTestShowOnlyFailed[display only failed files for coverage test]' \
    '--unitTestCoverage=[istanbul JSON coverage summary file]:file:_files -g "*.json"' \
    '--disableSourceCode[do not add source code tab and links]' \
    '--disableDomTree[do not add DOM tree tab]' \
    '--disableTemplateTab[do not add template tab]' \
    '--disableStyleTab[do not add style tab]' \
    '--disableGraph[do not add the dependency graph]' \
    '--disableCoverage[do not add the documentation coverage report]' \
    '--disablePrivate[do not show private members in generated docs]' \
    '--disableProtected[do not show protected members in generated docs]' \
    '--disableInternal[do not show @internal members in generated docs]' \
    '--disableLifeCycleHooks[do not show Angular lifecycle hooks]' \
    '--disableConstructors[do not show constructors]' \
    '--disableRoutesGraph[do not add the routes graph]' \
    '--disableSearch[do not add the search input]' \
    '--disableDependencies[do not add the dependencies list]' \
    '--disableProperties[do not add the properties list]' \
    '--disableFilePath[do not add the file path]' \
    '--disableOverview[do not add the overview page]' \
    '--templatePlayground[generate template playground page]' \
    '--minimal[minimal mode: no search, no graph, no coverage]' \
    '--customFavicon=[custom favicon path]:file:_files' \
    '--customLogo=[custom logo path]:file:_files' \
    '--gaID=[Google Analytics tracking ID]:id: ' \
    '--gaSite=[Google Analytics site name]:site: ' \
    '--publicApiOnly=[document only symbols exported from index.d.ts in this dist folder]:dir:_files -/' \
    '--maxSearchResults=[max search results on the results page (0 = all, default 15)]:n: ' \
    '*:source directory:_files -/' \
    && ret=0

case $state in
    expfmt)
        _describe -t formats 'export format' _compodoc_export_formats && ret=0 ;;
    lang)
        _describe -t languages 'UI language' _compodoc_languages && ret=0 ;;
    theme)
        _describe -t themes 'built-in theme' _compodoc_themes && ret=0 ;;
    bool)
        _describe -t bools 'boolean' _compodoc_bool && ret=0 ;;
esac

return ret
