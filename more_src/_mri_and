#compdef mri_and
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_and
# Perform a logical voxel-wise AND on a series of volumes

local ret=1

_arguments -s -S \
  '-help[display help]' \
  '-T[threshold value applied before the AND]:thresh:' \
  '-V[display version]' \
  '-U[display usage]' \
  '*:volume:_files' && ret=0

return ret
