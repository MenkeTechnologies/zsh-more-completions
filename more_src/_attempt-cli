#compdef attempt-cli
# Documentation: https://github.com/MaxBondABE/attempt
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a __att_pol=(
  '(-F --retry-failing-status)'{-F,--retry-failing-status}'[retry on non-zero exit]'
  '(-S --retry-if-status)'{-S+,--retry-if-status=}'[retry when exit status matches pattern]:status pattern:'
  '(-s --retry-if-contains)'{-s+,--retry-if-contains=}'[retry when combined output contains string]:string:'
  '(-r --retry-if-matches)'{-r+,--retry-if-matches=}'[retry when combined output matches regex]:regex:'
  '--retry-if-stdout-contains=[retry when stdout contains string]:string:'
  '--retry-if-stdout-matches=[retry when stdout matches regex]:regex:'
  '--retry-if-stderr-contains=[retry when stderr contains string]:string:'
  '--retry-if-stderr-matches=[retry when stderr matches regex]:regex:'
  '--retry-always[always retry regardless of success]'
  '--retry-if-killed[retry when the child is killed by a signal]'
  '--retry-if-signal=[retry when killed by signal pattern]:signal pattern:'
  '--retry-if-timeout[retry when an attempt times out]'
  '--stop-if-status=[stop when exit status matches pattern]:status pattern:'
  '--stop-if-contains=[stop when combined output contains string]:string:'
  '--stop-if-matches=[stop when combined output matches regex]:regex:'
  '--stop-if-stdout-contains=[stop when stdout contains string]:string:'
  '--stop-if-stdout-matches=[stop when stdout matches regex]:regex:'
  '--stop-if-stderr-contains=[stop when stderr contains string]:string:'
  '--stop-if-stderr-matches=[stop when stderr matches regex]:regex:'
  '--stop-if-killed[stop when the child is killed by a signal]'
  '--stop-if-signal=[stop when killed by this signal pattern]:signal pattern:'
  '--stop-if-timeout[stop when an attempt times out]'
)

local -a __att_wait=(
  '--stagger=[random startup delay upper bound]:duration:'
  '(-j --jitter)'{-j+,--jitter=}'[random jitter added to wait]:duration:'
  '(-m --wait-min)'{-m+,--wait-min=}'[minimum wait between attempts]:duration:'
  '(-M --wait-max)'{-M+,--wait-max=}'[maximum wait between attempts]:duration:'
)

local -a __att_glob=(
  '(-a --attempts)'{-a+,--attempts=}'[maximum attempts]:attempts:'
  '(-t --timeout)'{-t+,--timeout=}'[per-attempt timeout]:duration:'
  '(-R --expected-runtime)'{-R+,--expected-runtime=}'[expected child runtime hint]:duration:'
  '*'{-v,--verbose}'[increase logging; repeat]'
  '*'{-q,--quiet}'[decrease logging; repeat]'
  '(-U --unlimited-attempts)'{-U,--unlimited-attempts}'[retry until success]'
  '(-Y --forever)'{-Y,--forever}'[retry forever (long-running children)]'
  '(- *)'{-V,--version}'[print version and exit]'
  $__att_wait $__att_pol
)

_arguments -C \
  $__att_glob \
  '1: :->first' \
  '*::rest:->rest' && ret=0

case $state in
  (first)
    _alternative \
      'schedule:backoff mode:(fixed exponential exp linear)' \
      'commands:command name:_command_names -e' && ret=0
    ;;
  (rest)
    case $line[1] in
      (fixed)
        _arguments -s -S \
          $__att_glob \
          '(-w --wait)'{-w+,--wait=}'[wait between attempts]:duration:' \
          '*::command:_default' && ret=0
        ;;
      (exponential|exp)
        _arguments -s -S \
          $__att_glob \
          '(-b --base)'{-b+,--base=}'[exponential base]:float:' \
          '(-x --multiplier)'{-x+,--multiplier=}'[multiplier duration]:duration:' \
          '*::command:_default' && ret=0
        ;;
      (linear)
        _arguments -s -S \
          $__att_glob \
          '(-x --multiplier)'{-x+,--multiplier=}'[linear multiplier duration]:duration:' \
          '(-w --starting-wait)'{-w+,--starting-wait=}'[starting wait duration]:duration:' \
          '*::command:_default' && ret=0
        ;;
      (*)
        _arguments -s -S \
          $__att_glob \
          '(-w --wait)'{-w+,--wait=}'[implicit fixed schedule wait]:duration:' \
          '*::command:_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
