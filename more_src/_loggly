#compdef loggly loggly-cli
# _loggly — Loggly (SolarWinds) log management CLI (SolarWinds Loggly, Python); argparse
# upstream: https://github.com/loggly/loggly-python-handler

_loggly() {
    local -a sub=(
        'send:send single log event'
        'send-bulk:send bulk events'
        'configure:configure CLI credentials'
        'search:search recent events'
        'events:fetch events'
        'tail:tail live events'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--token=+[customer token]:str:' \
        '-t+[customer token]:str:' \
        '--subdomain=+[loggly subdomain]:str:' \
        '-s+[loggly subdomain]:str:' \
        '--username=+[username]:str:_users' \
        '-u+[username]:str:_users' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--tag=+[tag]:list:' \
        '--format=+[format]:fmt:(json plain)' \
        '--output=+[output format]:fmt:(table json yaml)' \
        '-o+[output format]:fmt:(table json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'loggly subcommand' sub ;;
        args)
            case $words[1] in
                send) _arguments \
                    '--message=+[message]:str:' \
                    '-m+[message]:str:' \
                    '--tag=+[tag]:list:' ;;
                send-bulk) _arguments \
                    '--file=+[bulk file]:file:_files' \
                    '-f+[bulk file]:file:_files' ;;
                search|events|tail) _arguments \
                    '--query=+[search query]:str:' \
                    '-q+[search query]:str:' \
                    '--from=+[from]:str:' \
                    '--until=+[until]:str:' \
                    '--limit=+[limit]:n:' \
                    '--order=+[order]:o:(asc desc)' ;;
                configure) _arguments \
                    '--subdomain=+[subdomain]:str:' \
                    '--token=+[customer token]:str:' \
                    '--username=+[username]:str:_users' \
                    '--password=+[password]:str:' ;;
            esac
            ;;
    esac
}

_loggly "$@"
