#compdef chibi-scheme chibi-ffi chibi-genstatic chibi-doc
# Documentation: https://github.com/ashinn/chibi-scheme/blob/master/doc/chibi-scheme.1
# Reference accessed: 2026-05-17
# Verified: upstream man page at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (chibi-scheme)
    _arguments -C \
      '-V[show version]' \
      '-q[quick load (shortcut for -xchibi)]' \
      '-Q[extra quick load (shortcut for -xchibi.primitive)]' \
      '-r[run main procedure when script finishes]' \
      '-R+[load module and run its main procedure]:module:' \
      '-s[strict mode (escalate warnings to errors)]' \
      '-f[enable R5RS-style case-folding for symbols]' \
      '-T[disable tail-call optimization]' \
      '-b[make stdio nonblocking]' \
      '-h+[heap size with optional /max_size]:size:' \
      '-I+[prepend path to load path]:dir:_files -/' \
      '-A+[append path to load path]:dir:_files -/' \
      '-D+[add feature to feature list]:feature:' \
      '-m+[import module into current environment]:mod:' \
      '-x+[replace environment with module]:mod:' \
      '-l+[load Scheme source file]:file:_files -g "*.scm *.sld"' \
      '-e+[evaluate expression]:expr:' \
      '-p+[evaluate and print expression]:expr:' \
      '-t+[enable tracing for module.identifier]:id:' \
      '-d+[dump heap to image file]:file:_files' \
      '-i+[load heap from image file]:file:_files' \
      '*: :_files -g "*.scm *.sld"' && ret=0 ;;
  (chibi-ffi)
    _arguments -C \
      '-h[help]' \
      '-c[generate C only]' \
      '-f+[FFI options]:opts:' \
      '-cc+[C compiler]:cc:_command_names -e' \
      '*: :_files -g "*.stub *.scm"' && ret=0 ;;
  (chibi-genstatic)
    _arguments -C \
      '-h[help]' \
      '*: :_files -g "*.scm *.sld"' && ret=0 ;;
  (chibi-doc)
    _arguments -C \
      '-h[help]' \
      '-d+[output dir]:dir:_files -/' \
      '-t+[template]:file:_files' \
      '*: :_files -g "*.scm *.sld *.scrbl"' && ret=0 ;;
esac

return ret
