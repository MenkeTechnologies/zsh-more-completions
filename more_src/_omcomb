#compdef omcomb
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/omcomb/node4.html
# Combine 4 full-frame low resolution mode image segments into a single image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--imagesets=[list of input image datasets to be combined]:files:_files' \
  '--outset=[name of output full-frame image dataset]:file:_files' \
  '*:param=value:_default' && ret=0

return ret
