#compdef pgmoneta-mcp-inspector
# _pgmoneta-mcp-inspector — MCP inspector for pgmoneta (pgmoneta/pgmoneta_mcp)
# upstream: https://github.com/pgmoneta/pgmoneta_mcp
# Subcommands from src/bin/inspector/main.rs (clap derive).

_pgmoneta-mcp-inspector() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'inspector:connect to MCP server and run inspector ops'
                'interactive:launch the interactive wizard'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                inspector)
                    _arguments \
                        '(-c --conf)'{-c+,--conf=}'[inspector configuration file]:file:_files -g "*.conf"' \
                        '1:subcommand:(tool)' \
                        '*::tool-args:->tool'
                    case $state in
                        tool)
                            case $words[1] in
                                tool)
                                    _arguments \
                                        '1:action:(list call)' \
                                        '(-o --output)'{-o+,--output=}'[output format]:fmt:(tree json)' \
                                        '(-f --file)'{-f+,--file=}'[JSON args file]:file:_files -g "*.json"' \
                                        ':tool name:' \
                                        ':JSON args:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

_pgmoneta-mcp-inspector "$@"
