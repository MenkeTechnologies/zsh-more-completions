#compdef create-dmg
# Documentation: https://man.archlinux.org/search?q=create-dmg
# Reference accessed: 2026-05-16

# sindresorhus/create-dmg — cli.js (meow) v2025
# Usage: create-dmg <app> [destination]

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '--overwrite[overwrite existing DMG of same name]' \
  '--no-version-in-filename[DMG filename without app version]' \
  '--identity=[codesign identity]:identity:' \
  '--dmg-title=[volume title ≤27 chars]:title:' \
  '--no-code-sign[skip codesigning the DMG]' \
  '1:macOS .app bundle:_path_files -g "*.app"' \
  '2:output directory:_files -/'
