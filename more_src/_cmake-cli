#compdef cmake
# _cmake-cli — CMake cross-platform build configurator (Kitware, C++); generate build files for many backends
# upstream: https://github.com/Kitware/CMake

_cmake-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-S+[source dir]:dir:_files -/' \
        '-B+[build dir]:dir:_files -/' \
        '-C+[initial cache]:file:_files' \
        '-D+[cache entry]:KEY=VAL:' \
        '-U+[remove cache entry]:str:' \
        '-G+[generator]:generator:(Ninja Unix\\ Makefiles MSYS\\ Makefiles MinGW\\ Makefiles NMake\\ Makefiles NMake\\ Makefiles\\ JOM Watcom\\ WMake Visual\\ Studio\\ 17\\ 2022 Visual\\ Studio\\ 16\\ 2019 Visual\\ Studio\\ 15\\ 2017 Xcode CodeBlocks Eclipse\\ CDT4 Kate Sublime\\ Text\\ 2)' \
        '-T+[toolset]:str:' \
        '-A+[platform]:str:' \
        '--toolchain+[toolchain]:file:_files' \
        '--install-prefix+[install prefix]:dir:_files -/' \
        '-Wdev[enable dev warnings]' \
        '-Wno-dev[disable dev warnings]' \
        '-Werror=+[error category]:cat:(dev deprecated)' \
        '-Wno-error=+[no error category]:cat:(dev deprecated)' \
        '-Wdeprecated[enable deprecated warnings]' \
        '-Wno-deprecated[disable deprecated warnings]' \
        '-L[list cache vars]' \
        '-LA[list cache vars including advanced]' \
        '-LH[list cache vars including help]' \
        '-N[view-mode only]' \
        '-P+[script mode]:file:_files' \
        '--find-package[find-package mode]' \
        '--build+[build tree]:dir:_files -/' \
        '--install+[install tree]:dir:_files -/' \
        '--open+[open project]:dir:_files -/' \
        '--preset+[preset]:str:' \
        '--list-presets[list presets]' \
        '--config+[config]:cfg:(Debug Release RelWithDebInfo MinSizeRel)' \
        '--clean-first[clean first]' \
        '-j+[parallel jobs]:n:' \
        '--parallel+[parallel jobs]:n:' \
        '-t+[target]:target:' \
        '--target+[target]:target:' \
        '--workflow+[workflow]:str:' \
        '--graphviz+[graphviz output]:file:_files' \
        '--system-information+[system info]:file:_files' \
        '--debug-trycompile[debug try_compile]' \
        '--debug-output[debug output]' \
        '--debug-find[debug find]' \
        '--trace[trace]' \
        '--trace-expand[trace expand]' \
        '--trace-format+[trace format]:fmt:(human json-v1)' \
        '--trace-source+[trace source]:str:' \
        '--trace-redirect+[trace redirect]:file:_files' \
        '--warn-uninitialized[warn uninitialized]' \
        '--warn-unused-vars[warn unused vars]' \
        '--no-warn-unused-cli[no warn unused CLI]' \
        '--check-system-vars[check system vars]' \
        '--compile-no-warning-as-error[no warning as error]' \
        '*:path:_files'
}

_cmake-cli "$@"
