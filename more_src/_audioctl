#compdef audioctl
# Documentation: man audioctl(1)
# Source: netbsd/src usr.bin/audio/ctl — audio device parameter control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-n[suppress variable names in output]' \
    '-d+[alternative audio control device]:device:_files' \
    '(- *)-a[print all variables for the device]' \
    '-w[set variables (name=value)]' \
    '*:variable:_default' \
    && ret=0

return ret
