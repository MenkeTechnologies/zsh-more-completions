#compdef privoxy
# Documentation: https://manpages.debian.org/bookworm/privoxy/privoxy.8.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--no-daemon[do not become a daemon]' \
  '--pidfile+[specify PID file]:pid file:_files' \
  '--user+[run as specified user]:user:_users' \
  '--chroot[run in chroot jail]' \
  '--pre-chroot-nslookup+[resolve hostname before chroot]:hostname:_hosts' \
  '--config-test[check config and exit]' \
  '1:config file:_files' && return 0
