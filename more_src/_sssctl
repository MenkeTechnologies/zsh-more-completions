#compdef sssctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'domain-list:list available domains'
  'domain-status:print info about domain'
  'user-checks:check user authentication'
  'access-report:generate access report'
  'user-show:info about cached user'
  'group-show:info about cached group'
  'netgroup-show:info about cached netgroup'
  'client-data-backup:backup local data'
  'client-data-restore:restore local data'
  'cache-remove:remove cached content'
  'cache-expire:invalidate cached objects'
  'cache-index:manage cache indexes'
  'logs-remove:remove SSSD log files'
  'logs-fetch:archive SSSD log files'
  'debug-level:change/print debug level'
  'analyze:analyze logged data'
  'config-check:static config analysis'
  'cert-show:print certificate info'
  'cert-map:show users mapped to certificate'
  'cert-eval-rule:evaluate mapping rule'
  'gpo-show:info about cached GPO'
  'gpo-list:enumerate cached GPOs'
  'gpo-remove:remove cached GPO'
  'gpo-purge:remove all cached GPOs'
  'passkey-register:perform passkey registration'
)

_arguments -C \
  '--debug=[debug level]:level:' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sssctl subcommand' subcommands && ret=0
    ;;
esac

return ret
