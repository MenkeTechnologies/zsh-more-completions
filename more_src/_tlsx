#compdef tlsx

# Zsh completion for tlsx - fast and configurable TLS grabber

_arguments -s -S \
  '(-u --url)'{-u,--url}'[target host to scan]:host:' \
  '(-l --list)'{-l,--list}'[file containing list of target hosts]:file:_files' \
  '(-p --port)'{-p,--port}'[target port to scan (default 443)]:port:' \
  '(-pl --port-list)'{-pl,--port-list}'[file containing ports to scan]:file:_files' \
  '(-ps --pre-handshake)'{-ps,--pre-handshake}'[enable pre-handshake TLS connection]' \
  '-san[display subject alternative names]' \
  '--san[display subject alternative names]' \
  '-cn[display subject common name]' \
  '--cn[display subject common name]' \
  '-so[display subject organization name]' \
  '--so[display subject organization name]' \
  '-tv[display TLS version]' \
  '--tls-version[display TLS version]' \
  '-cipher[display negotiated cipher]' \
  '--cipher[display negotiated cipher]' \
  '-hash[display certificate hash]:algo:(md5 sha1 sha256)' \
  '--hash[display certificate hash]:algo:(md5 sha1 sha256)' \
  '-jarm[perform JARM fingerprinting]' \
  '--jarm[perform JARM fingerprinting]' \
  '-ja3[collect JA3 fingerprint]' \
  '--ja3[collect JA3 fingerprint]' \
  '-ja3s[collect JA3S fingerprint]' \
  '--ja3s[collect JA3S fingerprint]' \
  '-wo[display without expired certs]' \
  '--without-expired[display without expired certs]' \
  '-ve[filter for expired certs]' \
  '--valid-expired[filter for expired certs]' \
  '-ss[display tls issuer]' \
  '--serial[display tls issuer]' \
  '-nc --no-color[disable output content coloring]' \
  '--no-color[disable output content coloring]' \
  '(-o --output)'{-o,--output}'[output file to write results]:file:_files' \
  '--json[write output in JSON format]' \
  '--csv[write output in CSV format]' \
  '-r[use custom resolvers]:resolver:' \
  '--resolver[use custom resolvers]:resolver:' \
  '-ct --concurrency[number of concurrent threads]:N:' \
  '--concurrency[number of concurrent threads]:N:' \
  '-timeout[TLS handshake timeout]:seconds:' \
  '--timeout[TLS handshake timeout]:seconds:' \
  '-min-version[minimum TLS version]:version:(ssl30 tls10 tls11 tls12 tls13)' \
  '--min-version[minimum TLS version]:version:(ssl30 tls10 tls11 tls12 tls13)' \
  '-max-version[maximum TLS version]:version:(ssl30 tls10 tls11 tls12 tls13)' \
  '--max-version[maximum TLS version]:version:(ssl30 tls10 tls11 tls12 tls13)' \
  '-cert[include certificate in JSON output]' \
  '--cert[include certificate in JSON output]' \
  '-silent[display results only]' \
  '--silent[display results only]' \
  '-version[show version]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
