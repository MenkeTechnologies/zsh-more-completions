#compdef gerbil

_gerbil_commands() {
  local -a commands=(
    'build:build a Gerbil package'
    'clean:clean build artifacts'
    'env:display Gerbil environment'
    'help:display help for a command'
    'install:install a Gerbil package'
    'new:create a new Gerbil project'
    'pkg:package management'
    'repl:start a Gerbil REPL'
    'run:run a Gerbil script'
    'shell:start a Gerbil interactive shell'
    'test:run tests'
  )
  _describe 'command' commands
}

_gerbil() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '-h[display help]' \
    '-v[display version]' \
    '1:command:_gerbil_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        build|clean|test)
          _arguments '*:file:_files'
          ;;
        run)
          _arguments '1:script:_files -g "*.ss"'
          ;;
        install)
          _arguments '1:package:_files'
          ;;
        pkg)
          local -a subcmds=(
            'install:install a package'
            'uninstall:uninstall a package'
            'update:update packages'
            'list:list installed packages'
            'search:search for packages'
          )
          _describe 'subcommand' subcmds
          ;;
      esac
      ;;
  esac
}

_gerbil "$@"
