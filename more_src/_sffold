#compdef sffold
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mfold.c
# Madagascar: make a seismic foldplot/stacking chart

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'verbose=[0 terse, 1 informative, 2 chatty, 3 debug]:level:(0 1 2 3)' \
  'o1=[minimum label1, usually min offset]:value' \
  'o2=[minimum label2, usually min xline]:value' \
  'o3=[minimum label3, usually min iline]:value' \
  'n1=[number label1, usually number offset]:count' \
  'n2=[number label2, usually number xline]:count' \
  'n3=[number label3, usually number iline]:count' \
  'd1=[delta label1, usually delta offset]:value' \
  'd2=[delta label2, usually delta xline]:value' \
  'd3=[delta label3, usually delta iline]:value' \
  'label1=[header for axis1, usually offset]:header' \
  'label2=[header for axis2, usually xline or cdp]:header' \
  'label3=[header for axis3, usually iline]:header' \
  '*:RSF file:_files' && ret=0

return ret
