#compdef bencher

_bencher_subcommands() {
  local -a subcmds=(
    'auth:Manage authentication'
    'organization:Manage organizations'
    'project:Manage projects'
    'branch:Manage branches'
    'testbed:Manage testbeds'
    'threshold:Manage thresholds'
    'metric-kind:Manage metric kinds'
    'run:Run benchmarks'
    'alert:Manage alerts'
    'report:Manage reports'
    'mock:Generate mock benchmark data'
    'archive:Archive a resource'
    'completions:Generate shell completions'
  )
  _describe -t commands 'bencher subcommand' subcmds
}

_bencher() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-V,--version}'[Show version]' \
    '--host[Bencher API server host]:url:' \
    '--token[API token]:token:' \
    '1:subcommand:_bencher_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        run)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--project[Project slug or UUID]:project:' \
            '--branch[Branch slug or UUID]:branch:' \
            '--testbed[Testbed slug or UUID]:testbed:' \
            '--adapter[Benchmark harness adapter]:adapter:(magic json csv c_sharp c_sharp_dot_net cpp cpp_catch2 cpp_google go go_bench java java_jmh js js_benchmark js_time python python_asv python_pytest ruby ruby_benchmark rust rust_bench rust_criterion rust_iai shell_hyperfine)' \
            '--threshold-measure[Threshold measure]:measure:' \
            '--threshold-test[Threshold test]:test:(z t log_normal iqr percentage)' \
            '--err[Error on alert]' \
            '--iter[Number of iterations]:count:' \
            '--fold[Fold results]:fold:(min max mean median)' \
            '--if-branch[Branch if exists]:branch:' \
            '--else-if-branch[Else-if branch]:branch:' \
            '--else-branch[Create branch if not exists]' \
            '--endif-branch[End branch conditional]' \
            '--ci-only-on-alert[Only post CI comment on alert]' \
            '--ci-id[CI comment ID]:id:' \
            '--github-actions[GitHub Actions token]:token:' \
            '*:command:'
          ;;
        project)
          _arguments \
            '1:action:(create list view update delete)' \
            '--name[Project name]:name:' \
            '--slug[Project slug]:slug:' \
            '--url[Project URL]:url:' \
            '--visibility[Visibility]:visibility:(public private)'
          ;;
      esac
      ;;
  esac
}

_bencher "$@"
