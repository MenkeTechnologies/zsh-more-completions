# Source: cargo binstall humble-cli@0.20.0
# Probed via: completion zsh
# Repository: https://github.com/smbl64/humble-cli
#compdef humble-cli

autoload -U is-at-least

_humble-cli() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
'-V[Print version information]' \
'--version[Print version information]' \
":: :_humble-cli_commands" \
"*::: :->humble-cli" \
&& ret=0
    case $state in
    (humble-cli)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:humble-cli-command-$line[1]:"
        case $line[1] in
            (auth)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
':SESSION-KEY -- Session key that'\''s copied from your web browser:' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" \
'*--field=[Print bundle with the specified fields only]: : ' \
'--claimed=[Show claimed or unclaimed bundles only]:value:(all yes no)' \
'-h[Print help information]' \
'--help[Print help information]' \
&& ret=0
;;
(list-choices)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
'::period -- The month and the year to use for search. For example\: '\''january-2023'\''.
Use '\''current'\'' for the current month.:' \
&& ret=0
;;
(details)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
':BUNDLE-KEY -- The key for the bundle which must be shown:' \
&& ret=0
;;
(download)
_arguments "${_arguments_options[@]}" \
'-i+[Download only specified items]: : ' \
'--item-numbers=[Download only specified items]: : ' \
'*-f+[Filter downloaded items by their format]: : ' \
'*--format=[Filter downloaded items by their format]: : ' \
'-s+[Filter downloaded items by their maximum size]: : ' \
'--max-size=[Filter downloaded items by their maximum size]: : ' \
'-t[Download only .torrent files for items]' \
'--torrents[Download only .torrent files for items]' \
'-c[Download into current dir]' \
'--cur-dir[Download into current dir]' \
'-h[Print help information]' \
'--help[Print help information]' \
':BUNDLE-KEY -- The key for the bundle which must be downloaded:' \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" \
'--mode=[Whether all or any of the keywords should match the name]:mode:(all any)' \
'-h[Print help information]' \
'--help[Print help information]' \
'*::KEYWORDS -- Search keywords:' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
':SHELL -- Shell type to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(bulk-download)
_arguments "${_arguments_options[@]}" \
'*-f+[Filter downloaded items by their format]: : ' \
'*--format=[Filter downloaded items by their format]: : ' \
'-s+[Filter downloaded items by their maximum size]: : ' \
'--max-size=[Filter downloaded items by their maximum size]: : ' \
'-t[Download only .torrent files for items]' \
'--torrents[Download only .torrent files for items]' \
'-c[Download into current dir]' \
'--cur-dir[Download into current dir]' \
'-h[Print help information]' \
'--help[Print help information]' \
':INPUT-FILE -- Takes a list input file:' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
'*::subcommand -- The subcommand whose help message to display:' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_humble-cli_commands] )) ||
_humble-cli_commands() {
    local commands; commands=(
'auth:Set the authentication session key' \
'list:List all your purchased bundles' \
'ls:List all your purchased bundles' \
'list-choices:List your current Humble Choices' \
'details:Print details of a certain bundle' \
'info:Print details of a certain bundle' \
'download:Selectively download items from a bundle' \
'd:Selectively download items from a bundle' \
'search:Search through all bundle products for keywords' \
'completion:Generate shell completions' \
'bulk-download:Selectively download items from a bundle' \
'b:Selectively download items from a bundle' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'humble-cli commands' commands "$@"
}
(( $+functions[_humble-cli__auth_commands] )) ||
_humble-cli__auth_commands() {
    local commands; commands=()
    _describe -t commands 'humble-cli auth commands' commands "$@"
}
(( $+functions[_humble-cli__bulk-download_commands] )) ||
_humble-cli__bulk-download_commands() {
    local commands; commands=()
    _describe -t commands 'humble-cli bulk-download commands' commands "$@"
}
(( $+functions[_humble-cli__completion_commands] )) ||
_humble-cli__completion_commands() {
    local commands; commands=()
    _describe -t commands 'humble-cli completion commands' commands "$@"
}
(( $+functions[_humble-cli__details_commands] )) ||
_humble-cli__details_commands() {
    local commands; commands=()
    _describe -t commands 'humble-cli details commands' commands "$@"
}
(( $+functions[_humble-cli__download_commands] )) ||
_humble-cli__download_commands() {
    local commands; commands=()
    _describe -t commands 'humble-cli download commands' commands "$@"
}
(( $+functions[_humble-cli__help_commands] )) ||
_humble-cli__help_commands() {
    local commands; commands=()
    _describe -t commands 'humble-cli help commands' commands "$@"
}
(( $+functions[_humble-cli__list_commands] )) ||
_humble-cli__list_commands() {
    local commands; commands=()
    _describe -t commands 'humble-cli list commands' commands "$@"
}
(( $+functions[_humble-cli__list-choices_commands] )) ||
_humble-cli__list-choices_commands() {
    local commands; commands=()
    _describe -t commands 'humble-cli list-choices commands' commands "$@"
}
(( $+functions[_humble-cli__search_commands] )) ||
_humble-cli__search_commands() {
    local commands; commands=()
    _describe -t commands 'humble-cli search commands' commands "$@"
}

_humble-cli "$@"
