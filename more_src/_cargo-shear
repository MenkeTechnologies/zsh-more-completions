#compdef cargo-shear

# Zsh completion for cargo-shear - detect and remove unused Rust dependencies

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-V --version)'{-V,--version}'[show cargo-shear version]'
  '--fix[apply suggested fixes by removing unused dependencies]'
  '--path[path to the Cargo workspace root]:path:_files -/'
  '--expand[expand macros before analysis]'
  '--ignore-package[packages to ignore]:packages:'
  '1:cargo subcommand:(shear)'
)

_arguments -s $arguments
