#compdef cargo-shear
# Documentation: https://github.com/Boshen/cargo-shear
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Zsh completion for cargo-shear - detect and remove unused Rust dependencies

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-V --version)'{-V,--version}'[show cargo-shear version]'
  '--fix[apply suggested fixes by removing unused dependencies]'
  '--path=[path to the Cargo workspace root]:path:_files -/'
  '--expand[expand macros before analysis (nightly only, slow)]'
  '--deny-warnings[treat warnings as errors]'
  '--check-test-targets[detect [lib] target mismatches with source]'
  '--format=[output format]:format:(default json)'
  '1:cargo subcommand:(shear)'
)

_arguments -s $arguments
