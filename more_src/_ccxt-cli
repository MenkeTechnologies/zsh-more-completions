#compdef ccxt-cli ccxt
# _ccxt-cli — CCXT ccxt-cli CLI command-line frontend wrapping the CCXT CryptoCurrency eXchange Trading library Python JavaScript PHP unified API for 100+ crypto exchanges Binance Coinbase Kraken Huobi OKX Bitfinex KuCoin Bybit ByBit Gate.io FTX HitBTC BitMEX providing market data trades orders balance ticker depth (CCXT team, Python); click
# upstream: https://github.com/ccxt/ccxt

_ccxt-cli() {
    local -a sub=(
        'exchanges:list supported exchanges'
        'markets:list markets for an exchange'
        'ticker:fetch ticker'
        'tickers:fetch all tickers'
        'orderbook:fetch order book'
        'trades:fetch trades'
        'ohlcv:fetch OHLCV candles'
        'balance:fetch balance'
        'order:order operations'
        'open-orders:fetch open orders'
        'closed-orders:fetch closed orders'
        'my-trades:fetch your trades'
        'deposit:deposit operations'
        'withdrawal:withdrawal operations'
        'transfer:transfer between accounts'
        'positions:fetch positions'
        'funding-rate:fetch funding rates'
        'currencies:list currencies'
        'fees:fetch trading fees'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-e+[exchange]:str:' \
        '--exchange=+[name]:str:' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--password=+[password]:str:' \
        '--uid=+[uid]:str:' \
        '--api-url=+[url]:str:' \
        '--sandbox[use sandbox]' \
        '--symbol=+[ticker]:str:' \
        '-s+[symbol]:str:' \
        '--timeframe=+[t]:t:(1m 3m 5m 15m 30m 1h 2h 4h 6h 8h 12h 1d 3d 1w 1M)' \
        '--limit=+[N]:n:' \
        '--since=+[timestamp]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ccxt-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list create cancel cancel-all status fetch)' \
                    '--side=+[s]:s:(buy sell)' \
                    '--type=+[t]:t:(limit market stop)' \
                    '--amount=+[N]:str:' \
                    '--price=+[N]:str:' \
                    '*:order id:' ;;
                ticker|tickers|orderbook|trades|ohlcv|positions|funding-rate) _arguments '*:symbol:' ;;
            esac
            ;;
    esac
}

_ccxt-cli "$@"
