#compdef starch
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/file-management/compression/starch.html
# Documentation: https://github.com/bedops/bedops/blob/master/applications/bed/starch/src/starch.c
# Documentation: https://github.com/bedops/bedops/blob/master/applications/bed/starch/src/starch.h
# Reference accessed: 2026-05-27
# Verified: upstream starch_client_long_options getopt_long table

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-v --version)'{-v,--version}'[show program version and citation info]' \
  '(-n --note)'{-n+,--note=}'[append note to output archive metadata]:note:' \
  '(-b --bzip2 -g --gzip)'{-b,--bzip2}'[use bzip2 backend compression (default)]' \
  '(-b --bzip2 -g --gzip)'{-g,--gzip}'[use gzip backend compression]' \
  '(-o --omit-signature)'{-o,--omit-signature}'[skip generating per-chromosome data integrity signature]' \
  '(-r --report-progress)'{-r+,--report-progress=}'[report compression progress every N elements per chromosome to stderr]:N:' \
  '(-e --header)'{-e,--header}'[accept BED input with UCSC track, SAM or VCF headers, or generic comments]' \
  '*:bed file:_files -g "*.(bed|bed.gz)(-.)"' && ret=0

return ret
