#compdef oddt_cli
# Documentation: https://github.com/oddt/oddt
# Open Drug Discovery Toolkit command-line interface

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  '--toolkit=[toolkit used for calculations]:toolkit:(ob rdkit)' \
  '(-n --n_cpu)'{-n,--n_cpu}'=[number of parallel processes]:n:' \
  '(-c --chunksize)'{-c,--chunksize}'=[molecules to process in a chunk]:n:' \
  '-i+[input file format]:format:' \
  '-o+[output file format]:format:' \
  '(-O --output)'{-O,--output}'=[output file]:file:_files' \
  '--filter=[built-in filters to use]:filter:(ro5 ro3 pains)' \
  '--similarity=[similarity method]:method:(ifp sifp usr usr_cat electroshape)' \
  '--cutoff=[similarity cutoff below which molecules are ignored]:value:' \
  '--query=[query molecules for similarity searching]:file:_files' \
  '--dock=[docking software]:software:(autodock_vina)' \
  '--receptor=[protein file]:file:_files' \
  '--auto_ligand=[docking box determined on this ligand]:file:_files' \
  '--center=[docking box center x,y,z]:center:' \
  '--size=[docking box dimensions x,y,z]:size:' \
  '--exhaustiveness=[exhaustiveness of docking]:n:' \
  '--seed=[random seed]:n:' \
  '--score=[built-in scoring function to use]:function:' \
  '--score_file=[ODDT scoring function saved to file]:file:_files' \
  '*--field=[field to save]:field:' \
  '*:input file:_files' && ret=0

return ret
