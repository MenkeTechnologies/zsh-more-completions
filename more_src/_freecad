#compdef freecad FreeCAD FreeCADCmd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)--version[Show version]' \
  {-c,--console}'[Run in console mode without GUI]' \
  '--log-file[Log to file]:file:_files' \
  '--user-cfg[User configuration file]:file:_files' \
  '--system-cfg[System configuration file]:file:_files' \
  '--run-test[Run the given test case]:test' \
  '--module-path[Additional module path]:path:_files -/' \
  '--single-instance[Use single instance mode]' \
  '--dump-config[Dump configuration]' \
  '--get-config[Get a configuration value]:key' \
  '--write-log[Write a log file]' \
  '--hidden[Start hidden]' \
  '--pass[Ignore the rest of the options]:pass' \
  '*:file:_files' && ret=0

return ret
