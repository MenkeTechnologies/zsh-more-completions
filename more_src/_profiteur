#compdef profiteur
# _profiteur — visual .prof file viewer for GHC profiling (jaspervdj/profiteur)
# upstream: https://github.com/jaspervdj/profiteur
# Usage from lib/Profiteur/Main.hs.

_profiteur() {
    _arguments \
        '(- *)--version[show version]' \
        '1:prof file:_files -g "*.prof"' \
        '2:output html (- for stdout):_files -g "*.html"'
}

_profiteur "$@"
