#compdef Planimeter
# Documentation: https://geographiclib.sourceforge.io/C++/doc/Planimeter.1.html
# GeographicLib: compute the area of geodesic polygons

local ret=1

_arguments -s -S \
  '-r[toggle counter-clockwise positive/negative result]' \
  '-s[toggle signed result]' \
  '-l[toggle polygon vs polyline interpretation]' \
  '-e[specify ellipsoid via equatorial radius and flattening]:a:' \
  '-w[toggle longitude-first flag]' \
  '-p[set output precision]:prec:' \
  '-G[edges joining vertices are geodesics (default)]' \
  '-Q[map points to authalic sphere]' \
  '-R[edges joining vertices are rhumb lines]' \
  '-E[use exact equations]' \
  '--geoconvert-input[interpret input lines like GeoConvert]' \
  '--comment-delimiter[set comment delimiter]:delim:' \
  '--version[print version and exit]' \
  '(-h --help)-h[print usage and exit]' \
  '(-h --help)--help[print full documentation and exit]' \
  '--input-file[read input from file]:infile:_files' \
  '--input-string[read input from string]:string:' \
  '--line-separator[set line separator character]:linesep:' \
  '--output-file[write output to file]:outfile:_files' && ret=0

return ret
