#compdef druid

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'broker:run query broker process'
  'coordinator:run coordinator process'
  'overlord:run overlord process (real-time ingestion controller)'
  'coordinator-overlord:run combined coordinator+overlord'
  'historical:run historical (queryable storage) process'
  'middleManager:run middle manager (task launcher) process'
  'indexer:run indexer process'
  'router:run router (API gateway) process'
  'help:show help'
  'version:show version'
  'tools:Druid utility commands'
  'server:run a Druid server (with configurable role)'
  'internal:internal commands'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'druid subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (broker|coordinator|overlord|coordinator-overlord|historical|middleManager|indexer|router|server)
        _arguments \
          '*--config-path=[config directory]:dir:_files -/' \
          '*-c+[config directory]:dir:_files -/' \
          '*--props=[properties file]:file:_files -g "*.properties"' \
          '*-D+[system property]:key=value:' && ret=0
        ;;
      (tools)
        _values 'tool' \
          'metadata-init' 'pull-deps' 'validate-segments' 'dump-segment' \
          'index' 'index-task' 'reset-cluster' 'compact-segments' \
          'metadata-update' 'jdbc-bridge' 'config-helper' \
          'export-metadata' 'log-search' 'segment-helper' && ret=0
        ;;
    esac
    ;;
esac

return ret
