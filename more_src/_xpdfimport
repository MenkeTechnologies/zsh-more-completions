#compdef xpdfimport
# Documentation: none found
# Reference accessed: 2026-05-21
# Verified: no public manpage for xpdfimport (LibreOffice bundled helper).
# STUB: usage takes input PDF and output file path; no enumerated flags.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input PDF:_files -g "*.pdf"' \
  '2:output (e.g. .draw):_files' && ret=0

return ret
