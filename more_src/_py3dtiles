#compdef py3dtiles
# Documentation: https://py3dtiles.org/v11.1.0/cli.html
# py3dtiles - convert point clouds and geometries to 3D Tiles tilesets

local ret=1
local curcontext="$curcontext" state line

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'py3dtiles command' \
      'convert[convert las/xyz/ply point clouds to a 3dtiles tileset]' \
      'info[output information from a pnts or b3dm file]' \
      'merge[generate a meta-tileset from existing tilesets]' \
      'export[export geometries from a directory or database to a tileset]' && ret=0
    ;;
  args)
    case $line[1] in
      convert)
        _arguments -s \
          '--out=[destination directory]:dir:_files -/' \
          '--overwrite[overwrite the output directory if it exists]' \
          '--jobs=[number of parallel jobs]:n' \
          '--cache_size=[cache size in MB]:mb' \
          '--srs_in=[input CRS (EPSG code)]:srs' \
          '--srs_out=[output CRS (EPSG code)]:srs' \
          '--benchmark=[benchmark name]:name' \
          '--no-rgb[do not export RGB color]' \
          '*--extra-fields=[extra point fields to export]:field' \
          '--color_scale=[scale factor for color values]:scale' \
          '--force-srs-in[force the input CRS even if metadata differs]' \
          '--disable-processpool[disable the process pool]' \
          '--pyproj-always-xy[force pyproj always_xy axis order]' \
          '*:file:_files' && ret=0
        ;;
      export)
        _arguments -s \
          '-d[directory of geometries to export]:dir:_files -/' \
          '-o[offset coordinates (x y z)]:offset' \
          '-D[database connection info string]:conn' \
          '-t[table name]:table' \
          '-c[geometry column name]:column' \
          '-i[id column name]:column' && ret=0
        ;;
      *)
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
