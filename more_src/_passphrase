#compdef passphrase
# Documentation: https://man.archlinux.org/search?q=passphrase
# Reference accessed: 2026-05-16

# passphrase: generate diceware-style passphrases
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-w[number of words]:n:' \
  '--words=[number of words]:n:' \
  '-s[word separator]:char:' \
  '--separator=[word separator]:char:' \
  '-n[number of passphrases]:n:' \
  '--num=[number of passphrases]:n:' \
  '-d[wordlist file]:file:_files' \
  '--dictionary=[wordlist file]:file:_files' \
  '*::passphrase args:_files' && ret=0
return ret
