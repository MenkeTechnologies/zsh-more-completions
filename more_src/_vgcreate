#compdef vgcreate
# _vgcreate — create volume group (LVM2); group physical volumes into a vg
# upstream: https://gitlab.com/lvmteam/lvm2

_vgcreate() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-A --autobackup)'{-A,--autobackup}'+[autobackup]:bool:(y n)' \
        '(-c --clustered)'{-c,--clustered}'+[clustered]:bool:(y n)' \
        '(-l --maxlogicalvolumes)'{-l,--maxlogicalvolumes}'+[max lvs]:n:' \
        '(-M --metadatatype)'{-M,--metadatatype}'+[metadata type]:type:(lvm1 lvm2)' \
        '(-p --maxphysicalvolumes)'{-p,--maxphysicalvolumes}'+[max pvs]:n:' \
        '(-s --physicalextentsize)'{-s,--physicalextentsize}'+[extent size]:size:' \
        '(-y --yes)'{-y,--yes}'[no prompts]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-Z --zero)'{-Z,--zero}'+[zero first sector]:bool:(y n)' \
        '--addtag+[add tag]:tag:' \
        '--alloc+[allocation policy]:policy:(contiguous cling normal anywhere inherit)' \
        '--shared[shared vg]' \
        '--systemid+[system id]:str:' \
        '--vgmetadatacopies+[metadata copies]:n:' \
        '--dataalignment+[data alignment]:size:' \
        '--dataalignmentoffset+[data alignment offset]:size:' \
        '--profile+[config profile]:profile:' \
        '1:vg name:' \
        '*:pv device:_files'
}

_vgcreate "$@"
