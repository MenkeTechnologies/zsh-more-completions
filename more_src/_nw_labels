#compdef nw_labels
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: print node labels.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-I[exclude inner node labels]' \
  '-L[exclude leaf labels]' \
  '-r[print only the root label]' \
  '-t[output labels tab-separated on one line]' \
  '*:newick file:_files' && ret=0

return ret
