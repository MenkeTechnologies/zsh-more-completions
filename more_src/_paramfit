#compdef paramfit
# Documentation: https://ambermd.org/AmberTools.php
# optimize force-field parameters by fitting to QM data

local ret=1

_arguments -s -S \
  '(- *)'{-h,-help,--help}'[show help]' \
  '-i[job control input file]:file:_files' \
  '-p[single topology (prmtop) file]:file:_files' \
  '-pf[file listing multiple topology files]:file:_files' \
  '-c[single coordinate (mdcrd) file]:file:_files' \
  '-cf[file listing multiple coordinate files]:file:_files' \
  '-q[quantum data/energy file]:file:_files' \
  '-v[verbosity level]:level:(HIGH MEDIUM LOW)' \
  '--random-seed[set the random seed]:integer:' && ret=0

return ret
