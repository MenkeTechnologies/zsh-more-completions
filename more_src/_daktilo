#compdef daktilo

# Zsh completion for daktilo (turn keyboard into a typewriter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-p --preset)'{-p,--preset}'[sound preset]:preset:(default typewriter drumkit musicbox bubbles)' \
  '(-l --list-presets)'{-l,--list-presets}'[list available presets]' \
  '(-d --list-devices)'{-d,--list-devices}'[list available sound devices]' \
  '--device[select sound device]:device' \
  '(-v --volume)'{-v,--volume}'[set volume]:volume' \
  '(-c --config)'{-c,--config}'[config file]:file:_files -g "*.toml"' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
