#compdef daktilo
# Documentation: https://github.com/orhun/daktilo
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# daktilo: turn keyboard into a typewriter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '*'{-p,--preset=}'[sound preset name]:preset:(default basic musicbox ducktilo drumkit spark)' \
  '(-l --list-presets)'{-l,--list-presets}'[list available presets]' \
  '--list-devices[list available output devices]' \
  '(-d --device)'{-d,--device=}'[device for playback]:device:' \
  '(-c --config)'{-c,--config=}'[config file path]:file:_files -g "*.toml"' \
  '(-i --init)'{-i,--init}'[write default configuration file]' \
  '--variate-volume=[variate volume +/- percent]:percent:' \
  '--variate-tempo=[variate tempo +/- percent]:percent:' \
  '--no-surprises[disable easter eggs]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
