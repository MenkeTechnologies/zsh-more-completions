#compdef zfs-hold
# _zfs-hold — OpenZFS zfs hold add reference hold to a snapshot CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-hold() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-r[recursive]' \
        '*:tag snapshot:'
}

_zfs-hold "$@"
