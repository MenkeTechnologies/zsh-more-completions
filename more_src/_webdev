#compdef webdev
# Documentation: https://pub.dev/packages/webdev
# webdev - build and serve Dart web apps

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
  '(-h --help)'{-h,--help}'[print usage information]' \
  '(-o --output)'{-o+,--output=}'[directory for build output]:dir:_files -/' \
  '(-r --release)'{-r,--release}'[build with release mode defaults]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--offline[disable fetching from pub.dev]' \
  '--auto=[action to perform after builds]:action:(restart refresh)' \
  '--debug[enable DevTools launching]' \
  '--debug-extension[enable Dart Debug Extension backend]' \
  '--launch-in-chrome[auto-launch app in Chrome]' \
  '--chrome-debug-port=[Chrome debugger port]:port:' \
  '--hostname=[server hostname]:host:' \
  '--log-requests[enable request logging]' \
  '--tls-cert-chain=[TLS certificate chain file]:file:_files' \
  '--tls-cert-key=[TLS certificate key file]:file:_files' \
  '1:command:(serve build)' \
  '*::args:' && ret=0

return ret
