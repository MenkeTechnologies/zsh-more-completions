#compdef cairosvg
# Documentation: https://cairosvg.org/documentation/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# CairoSVG: SVG to PDF/PNG/PS/SVG converter (Kozea/CairoSVG).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(pdf png ps svg)' \
  '(-d --dpi)'{-d+,--dpi=}'[inches-to-pixels ratio]:dpi:' \
  '(-W --width)'{-W+,--width=}'[parent container width in pixels]:px:' \
  '(-H --height)'{-H+,--height=}'[parent container height in pixels]:px:' \
  '--output-width=[output width in pixels]:px:' \
  '--output-height=[output height in pixels]:px:' \
  '(-s --scale)'{-s+,--scale=}'[scale factor]:factor:' \
  '(-u --unsafe)'{-u,--unsafe}'[resolve XML entities and allow very large files]' \
  '(-o --output)'{-o+,--output=}'[output filename]:file:_files' \
  ':input SVG file or URL:_files -g "*.svg"' && ret=0

return ret
