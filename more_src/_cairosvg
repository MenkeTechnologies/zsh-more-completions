#compdef cairosvg

# Zsh completion for cairosvg (SVG converter using Cairo)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --format)'{-f,--format}'=[Output format]:format:(pdf png ps svg)' \
  '(-d --dpi)'{-d,--dpi}'=[Set the DPI for the output]:dpi' \
  '(-W --width)'{-W,--width}'=[Set the output width in pixels]:width' \
  '(-H --height)'{-H,--height}'=[Set the output height in pixels]:height' \
  '(-s --scale)'{-s,--scale}'=[Scale the output]:scale factor' \
  '(-o --output)'{-o,--output}'=[Output filename]:file:_files' \
  '--background=[Set background color]:color' \
  '--negate-colors[Negate output colors]' \
  '--unsafe[Allow fetching external files]' \
  '(-u --url-fetcher)'{-u,--url-fetcher}'=[Custom URL fetcher]:fetcher' \
  '(-v --version)'{-v,--version}'[Print version]' \
  '(-h --help)'{-h,--help}'[Print help]' \
  ':input SVG file:_files -g "*.svg"' && ret=0

return ret
