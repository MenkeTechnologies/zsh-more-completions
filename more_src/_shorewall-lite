#compdef shorewall-lite
# Documentation: https://shorewall.org/manpages/shorewall-lite.html
# Reference accessed: 2026-05-21
# Verified: shorewall-lite is a symlink to shorewall(8) executed with -l;
# commands are a subset of shorewall (no compile/check/try/update).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add to zone' 'allow:allow host' 'clear:clear firewall' 'delete:delete from zone'
  'disable:disable' 'drop:drop host' 'dump:debug dump' 'enable:enable'
  'forget:forget saved state' 'help:show help' 'hits:show hits' 'iprange:ip range'
  'ipcalc:ip calc' 'iptrace:trace' 'load:load remote' 'logdrop:log drop'
  'logreject:log reject' 'logwatch:watch logs' 'noiptrace:stop trace' 'reenable:reenable'
  'refresh:refresh blacklist' 'reject:reject host' 'reload:reload' 'reset:reset counters'
  'restart:restart' 'restore:restore' 'safe-restart:safe restart' 'safe-start:safe start'
  'save:save' 'show:show info' 'start:start' 'stop:stop' 'status:status' 'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose]' \
  '-q[quiet]' \
  '-V+[verbosity]:level:(0 1 2)' \
  '-c+[config dir]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'shorewall-lite command' commands && ret=0 ;;
esac

return ret
