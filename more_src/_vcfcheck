#compdef vcfcheck
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfcheck.md
# Verify that VCF REF alleles match a FASTA reference

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-f --fasta-reference)'{-f,--fasta-reference}'[FASTA reference file to use to obtain primer sequences]:FASTA file:_files' \
  '(-x --exclude-failures)'{-x,--exclude-failures}'[if a record fails, do not print it]' \
  '(-k --keep-failures)'{-k,--keep-failures}'[print only records that fail]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[ignore case differences between FASTA reference and VCF]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
