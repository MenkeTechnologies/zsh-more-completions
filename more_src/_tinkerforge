#compdef tinkerforge

# tinkerforge: CLI client for Brick Daemon (brickd)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'enumerate:list connected bricks/bricklets'
  'call:invoke a function'
  'dispatch:dispatch callback'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--host=[brickd host]:host:_hosts' \
  '--port=[brickd port]:port:' \
  '--secret=[authentication secret]:secret:' \
  '--no-callback-output[skip callback output]' \
  '--execute=[execute (shell command on event)]:cmd:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'tinkerforge command' commands && ret=0 ;;
esac
return ret
