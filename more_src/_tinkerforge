#compdef tinkerforge
# Documentation: https://www.tinkerforge.com/en/doc/Software/API_Bindings_Shell.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Only --host and --port are documented on the linked page; full subcommand
# matrix is not enumerated in upstream documentation accessible without
# downloading the bindings zip.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--host=[connect to host (default localhost)]:host:_hosts' \
  '--port=[connect to port (default 4223)]:port:' \
  '*:arg:_files' && ret=0
return ret
