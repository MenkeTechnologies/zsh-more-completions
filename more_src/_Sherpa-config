#compdef Sherpa-config
# Documentation: https://gitlab.com/sherpa-team/sherpa/-/blob/master/SHERPA/Run/Sherpa-config.in
# Sherpa-config - report build-time Sherpa configuration

local ret=1

_arguments -s -S \
  '--version[returns Sherpa version]' \
  '--prefix[returns the installation path]' \
  '--incdir[returns the path of Sherpa headers]' \
  '--libs[returns the linker line to link with Sherpa]' \
  '--libdir[returns the path of Sherpa libraries]' \
  '--datadir[returns the path of Sherpa data (Decaydata, PDFs)]' \
  '--ldflags[returns the LDFLAGS used for Sherpa]' \
  '--cppflags[returns the preprocessor FLAGS needed for Sherpa headers]' \
  '--cxx[returns the C++ compiler used]' \
  '--fc[returns the FORTRAN compiler used]' \
  '--python-libs[returns the installation path of python libraries]' \
  '--load-mpi4py[returns whether MPI is loaded for python]' && ret=0

return ret
