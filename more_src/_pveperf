#compdef pveperf
# _pveperf — Proxmox Server Solutions pveperf Proxmox VE system performance benchmark CPU memory disk and network (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pve-manager.git

_pveperf() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '*:path:_files -/'
}

_pveperf "$@"
