#compdef binvox
# Documentation: https://www.patrickmin.com/binvox/wiki/doku.php?id=usage_summary
# binvox - 3D mesh voxelizer

local ret=1

_arguments -s -S \
  '-d[specify voxel grid size (default 256, max 4096)]:dimension:' \
  '-t[specify voxel file type]:type:(binvox hips mira vtk raw schematic msh nrrd)' \
  '-c[z-buffer based carving method only]' \
  '-v[z-buffer based parity voting method only]' \
  '-e[exact voxelization (any voxel intersecting a convex polygon)]' \
  '-dc[dilated carving mode]' \
  '-dilate[dilate voxel model n times]:count:' \
  '-rotx[rotate object 90 degrees ccw around x-axis]' \
  '-rotz[rotate object 90 degrees cw around z-axis]' \
  '-bb[force input model bounding box]:minx:' \
  '-ri[remove internal voxels]' \
  '-cb[center model inside unit cube]' \
  '-fit[crop model to bounding box]' \
  '-gpl[print full GNU GPL text and exit]' \
  '*:model file:_files -g "*.{obj,off,dxf,ply,stl,wrl}"' && ret=0

return ret
