#compdef devist
# Documentation: https://github.com/WebchemistCorp/devist
# Reference accessed: 2026-05-22
# Verified: src/main.rs and commands/*.rs clap definitions.

# Zsh completion for devist - project bootstrap CLI for AI-assisted development

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'devist command' \
      'doctor[check environment dependencies]' \
      'about[show devist info]' \
      'setup[initialize Asurada and devist workspace]' \
      'config[show or set devist and Asurada config]' \
      'template[manage project templates]' \
      'project[manage registered projects]' \
      'init[create project from template]' \
      'start[start project backend]' \
      'stop[stop active backend]' \
      'bundle[manage bundled intents]' \
      'worker[background file observer daemon]' && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _values 'config action' show path set && ret=0
        case $line[2] in
          set)
            _arguments '1:key:' '2:value:' && ret=0
            ;;
        esac
        ;;
      template)
        _values 'template action' list add sync remove && ret=0
        case $line[2] in
          add)
            _arguments '1:git-url:' '--name[template name override]:name:' && ret=0
            ;;
          remove)
            _arguments '1:name:' && ret=0
            ;;
        esac
        ;;
      project)
        _values 'project action' list add forget remove && ret=0
        case $line[2] in
          add)
            _arguments \
              '1:path:directory:_directories' \
              '--name[project name]:name:' \
              '--template[source template]:template:' && ret=0
            ;;
          forget|remove)
            _arguments '1:name:' && ret=0
            case $line[2] in
              remove)
                _arguments '(-y)--yes[skip confirmation]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      init)
        _arguments \
          '1:name:' \
          '(-t --template)'{-t,--template}'[template name]:template:' \
          '--path[target directory]:directory:_directories' \
          '--var[template variable KEY=VALUE]:var:' && ret=0
        ;;
      start)
        _arguments '1:name:' '--dev[also run dev server]' && ret=0
        ;;
      stop)
        _arguments '1:name:' && ret=0
        ;;
      worker)
        _values 'worker action' start stop status watch config && ret=0
        case $line[2] in
          watch)
            _arguments \
              '--tail[lines to show]:n:' \
              '--interval-ms[poll interval ms]:ms:' && ret=0
            ;;
          config)
            _values 'worker config' show get set path && ret=0
            case $line[3] in
              get|set)
                _arguments '1:key:' '2:value:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
