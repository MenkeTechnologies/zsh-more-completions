#compdef palapeli
# Documentation: https://apps.kde.org/palapeli/
# Reference accessed: 2026-05-16
# Verified: upstream KDE palapeli. Has -i/--import flag for headless
# puzzle import.
# Removed from prior file: bogus man.archlinux.org search URL.

# palapeli: KDE jigsaw puzzle game
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' \
  '(-i --import)'{-i+,--import=}'[import puzzle into local collection (no main window)]:file:_files -g "*.puzzle(-.)"' && ret=0
return ret
