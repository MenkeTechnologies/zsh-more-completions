#compdef imageslice
# Documentation: https://casacore.github.io/casacore/
# casacore: extract a region slice from a casacore image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage]' \
  'in=[input image name]:image:_files' \
  'out=[output image name]:image:_files' \
  'outregion=[output image region: start/end pairs per axis, -1 to use input shape]:region' \
  'debug=[debug level]:level' \
  '*:argument: ' && ret=0

return ret
