#compdef sqoop

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'import:transfer individual table from RDBMS to HDFS'
  'import-all-tables:import multiple tables from a database'
  'import-mainframe:import mainframe datasets to HDFS'
  'export:move HDFS data back to a database table'
  'codegen:generate Java classes for database records'
  'eval:execute SQL statements and view results'
  'list-databases:display available database schemas'
  'list-tables:show tables within a schema'
  'create-hive-table:generate Hive table definitions'
  'job:manage saved import/export jobs'
  'metastore:operate the Sqoop metastore'
  'merge:combine result datasets'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sqoop subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (import|export|import-all-tables|import-mainframe|create-hive-table|codegen|eval|list-databases|list-tables)
        _arguments \
          '--connect=[JDBC connection URI]:uri:' \
          '--username=[database username]:user:_users' \
          '--password=[database password]:password:' \
          '-P[read password from console]' \
          '--password-file=[password file]:file:_files' \
          '--driver=[JDBC driver class]:class:' \
          '--connection-manager=[connection manager class]:class:' \
          '--connection-param-file=[connection params file]:file:_files' \
          '--table=[table name]:name:' \
          '--target-dir=[HDFS destination dir]:dir:' \
          '--warehouse-dir=[parent dir for tables]:dir:' \
          '--split-by=[column for parallel split]:column:' \
          '--where=[WHERE clause]:expr:' \
          '--columns=[columns list]:cols:' \
          '--query=[SQL query]:sql:' \
          {-m+,--num-mappers=}'[parallel mappers]:n:' \
          '--as-avrodatafile[Avro file output]' \
          '--as-parquetfile[Parquet file output]' \
          '--as-sequencefile[SequenceFile output]' \
          '--as-textfile[plain text output]' \
          '--compress[enable compression]' \
          '--compression-codec=[compression codec]:codec:' \
          '--direct[use direct mode]' \
          '--fields-terminated-by=[field delimiter]:char:' \
          '--lines-terminated-by=[line delimiter]:char:' \
          '--escaped-by=[escape character]:char:' \
          '--enclosed-by=[enclosing character]:char:' \
          '--null-string=[null string]:string:' \
          '--null-non-string=[null non-string]:string:' \
          '--hive-import[import to Hive]' \
          '--hive-overwrite[overwrite Hive table]' \
          '--hive-database=[Hive database]:db:' \
          '--hive-table=[Hive table]:table:' \
          '--hbase-table=[HBase table]:table:' \
          '--hbase-row-key=[HBase row key]:key:' \
          '--check-column=[incremental check column]:col:' \
          '--incremental=[incremental mode]:mode:(append lastmodified)' \
          '--last-value=[last value for incremental]:value:' \
          '--verbose[verbose output]' \
          '--help[show help]' \
          '--export-dir=[HDFS export source dir]:dir:' \
          '--update-key=[update key columns]:cols:' \
          '--update-mode=[update mode]:mode:(updateonly allowinsert)' \
          '--input-fields-terminated-by=[input field delim]:char:' \
          '*:input file:_files' && ret=0
        ;;
      (job)
        _arguments \
          '--create=[create a new job]:name:' \
          '--delete=[delete a job]:name:' \
          '--exec=[run a job]:name:' \
          '--list[list saved jobs]' \
          '--meta-connect=[metastore JDBC URI]:uri:' \
          '--show=[show job details]:name:' && ret=0
        ;;
      (metastore)
        _arguments \
          '--shutdown[shut down metastore]' && ret=0
        ;;
      (merge)
        _arguments \
          '--class-name=[class name]:class:' \
          '--jar-file=[jar file]:file:_files -g "*.jar"' \
          '--merge-key=[merge column]:col:' \
          '--new-data=[newer dataset]:dir:' \
          '--onto=[older dataset]:dir:' \
          '--target-dir=[merged output]:dir:' && ret=0
        ;;
    esac
    ;;
esac

return ret
