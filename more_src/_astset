#compdef astset
# Documentation: http://www.starlink.ac.uk/docs/sun211.htx/sun211.html
# ATOOLS: sets an attribute value for an AST Object

local ret=1

_arguments -s \
  'THIS=[input AST Object]:object:_files' \
  'ATTRIB=[name of the attribute to set]:attribute' \
  'VALUE=[new value for the attribute]:value' \
  'RESULT=[output Object with the attribute set]:result:_files' \
  'FMT=[output format for the result]:fmt' \
  '*:object:_files' && ret=0

return ret
