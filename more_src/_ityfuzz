#compdef ityfuzz
# Documentation: https://docs.ityfuzz.rs/quickstart
# ityfuzz - bytecode-level hybrid fuzzer for EVM/Move smart contracts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --target)'{-t,--target}'=[target contract address(es) or build directory glob]:target:' \
  '(-c --chain-type)'{-c,--chain-type}'=[chain type for onchain fuzzing]:chain:(ETH BSC POLYGON MUMBAI)' \
  '(-f --flashloan)'{-f,--flashloan}'[allow attack to obtain flashloan]' \
  '(-o --work-dir)'{-o,--work-dir}'=[output/work directory]:dir:_files -/' \
  '(-i --replay-file)'{-i,--replay-file}'=[replay saved test cases]:file:_files' \
  '--onchain-block-number=[fork chain at block number]:block:' \
  '--onchain-etherscan-api-key=[Etherscan API key]:key:' \
  '--concolic[enable concolic execution]' \
  '--concolic-caller[enable concolic execution to change caller]' \
  '1:command:(evm move)' \
  '*::args:_files' && ret=0

return ret
