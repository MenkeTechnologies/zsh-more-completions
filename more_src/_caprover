#compdef caprover

local curcontext="$curcontext" state line ret=1

_caprover_commands() {
  local -a commands=(
    'login:Login to a CapRover server'
    'list:List apps on a CapRover server'
    'deploy:Deploy an application'
    'logout:Logout from a CapRover server'
    'serversetup:Setup a CapRover server'
    'api:Call a CapRover API endpoint'
  )
  _describe -t commands 'caprover command' commands
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)'{-V,--version}'[Show version]' \
  '1:command:_caprover_commands' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    case "$words[1]" in
      login)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--caproverUrl[CapRover server URL]:url' \
          '--caproverPassword[CapRover password]:password' \
          '--caproverName[CapRover server name]:name' \
          && ret=0
        ;;
      list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--caproverName[CapRover server name]:name' \
          && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--caproverUrl[CapRover server URL]:url' \
          '--caproverPassword[CapRover password]:password' \
          '--caproverName[CapRover server name]:name' \
          '--appName[Application name]:name' \
          '--tarFile[Tar file to deploy]:file:_files' \
          '--imageName[Docker image name]:image' \
          '--branch[Git branch to deploy]:branch' \
          && ret=0
        ;;
      logout)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--caproverName[CapRover server name]:name' \
          && ret=0
        ;;
      serversetup)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--caproverUrl[CapRover server URL]:url' \
          '--caproverPassword[CapRover password]:password' \
          '--caproverName[CapRover server name]:name' \
          && ret=0
        ;;
      api)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--caproverUrl[CapRover server URL]:url' \
          '--caproverPassword[CapRover password]:password' \
          '--caproverName[CapRover server name]:name' \
          '--path[API path]:path' \
          '--method[HTTP method]:method:(GET POST)' \
          '--data[Data to send]:data' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
