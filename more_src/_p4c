#compdef p4c
# Documentation: https://p4lang.github.io/p4c/getting_started.html
# P4_16 reference compiler driver

local ret=1

_arguments -s -S \
  '--help[show documentation of supported command line options]' \
  '--version[show compiler version information]' \
  '--target-help[show the supported target, arch pairs]' \
  '(-b)-b+[specify the compilation backend]:backend:(bmv2 dpdk ebpf ubpf psa tc)' \
  '--target=[set the target device]:target:(bmv2 dpdk ebpf ubpf)' \
  '--arch=[specify the architecture model]:arch:(v1model psa pna ubpf)' \
  '--std=[set the language standard]:std:(p4-14 p4-16)' \
  '*-I+[add directory to include search path]:dir:_files -/' \
  '*-D+[define preprocessor macro]:macro' \
  '*-U+[undefine preprocessor macro]:macro' \
  '-E[run the preprocessor only]' \
  '(-o)-o+[specify the output file name]:file:_files' \
  '--pp=[write preprocessor output to file]:file:_files' \
  '--p4runtime-files=[write P4Info description of tables and objects]:file:_files' \
  '--p4runtime-format=[specify P4Runtime output format]:format:(binary text json)' \
  '-g[generate debug symbols]' \
  '--ndebug[disable debug output]' \
  '--Wdisable=-[disable warnings]::warning' \
  '--Werror=-[treat warnings as errors]::warning' \
  '*:P4 source:_files -g "*.p4"' && ret=0

return ret
