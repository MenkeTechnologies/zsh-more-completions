#compdef zoneserver maradns-zoneserver
# _maradns-zoneserver — MaraDNS zoneserver (per-zone slave companion to maradns(8); -f config file, -t test config + exit, -p port, -i interface, -v verbose, -q quiet; reads mararc syntax to learn its master server and zones it should be authoritative for)
# upstream: https://github.com/samboy/MaraDNS
# Flags from MaraDNS server/MaraDns_zone.c on tip.

_maradns-zoneserver() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-f+[config file]:file:_files -g "*.conf"' \
        '-t[test config + exit]' \
        '-p+[port]:port:' \
        '-i+[interface]:interface:_net_interfaces' \
        '-v[verbose]' \
        '-q[quiet]'
}

_maradns-zoneserver "$@"
