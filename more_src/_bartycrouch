#compdef bartycrouch
# Documentation: https://man.archlinux.org/search?q=bartycrouch
# Reference accessed: 2026-05-16

# Zsh completion for bartycrouch
# Upstream: Incrementally update/translate your Strings files
# Conservative fallback — run `bartycrouch --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
