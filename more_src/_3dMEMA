#compdef 3dMEMA
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dMEMA.html
# AFNI mixed-effects multilevel analysis (group t-tests with effect+stat)

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-cio[use AFNI C io functions]' \
  '-Rio[use R io functions]' \
  '-conditions[name 1 or 2 conditions/tasks/GLTs]:cond' \
  '-covariates[text file with covariate table]:file:_files' \
  '-covariates_center[same or different intercepts per covariate]:spec' \
  '-covariates_model[center/slope different or same across groups]:spec' \
  '-covariates_name[assign names to covariates]:names' \
  '-dbgArgs[save parameters for debugging]' \
  '-equal_variance[assume same cross-subject variability (default)]' \
  '-unequal_variance[model variability differences]' \
  '-groups[name 1 or 2 groups for comparison]:groups' \
  '-HKtest[Hartung-Knapp adjustment for t-statistic]' \
  '-no_HKtest[disable Hartung-Knapp adjustment]' \
  '-jobs[enable parallel computing]:njobs' \
  '-mask[process voxels inside mask only]:dataset:_files' \
  '-max_zeros[skip voxels with more than MM zero coefficients]:mm' \
  '-missing_data[handle missing data at incomplete voxels]:spec' \
  '-model_outliers[model outlier betas with Laplace distribution]' \
  '-no_model_outliers[no outlier modeling (default)]' \
  '-n_nonzero[skip voxels with fewer than NN non-zero betas]:nn' \
  '-residual_Z[output residuals and Z values]' \
  '-no_residual_Z[do not output residuals and Z (default)]' \
  '-prefix[output prefix]:prefix' \
  '*-set[data for one test variable with subject info]:setname' \
  '-show_allowed_options[list allowed options]' \
  '-verb[verbosity level]:verb' \
  '*:dataset:_files' && ret=0

return ret
