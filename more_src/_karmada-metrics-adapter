#compdef karmada-metrics-adapter
# Documentation: https://man.archlinux.org/search?q=karmada-metrics-adapter
# Reference accessed: 2026-05-16

# karmada-metrics-adapter: Karmada multi-cluster component
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--karmada-kubeconfig=[Karmada kubeconfig]:file:_files' \
  '--master=[master URL]:url:' \
  '--leader-elect[enable leader election]' \
  '--leader-elect-lease-duration=[lease duration]:duration:' \
  '--leader-elect-renew-deadline=[renew deadline]:duration:' \
  '--leader-elect-retry-period=[retry period]:duration:' \
  '--leader-elect-resource-name=[resource name]:name:' \
  '--leader-elect-resource-namespace=[resource namespace]:ns:' \
  '--metrics-bind-address=[metrics bind address]:addr:' \
  '--health-probe-bind-address=[health probe bind address]:addr:' \
  '--bind-address=[bind address]:addr:' \
  '--secure-port=[secure port]:port:' \
  '--cert-dir=[cert directory]:dir:_files -/' \
  '--tls-cert-file=[TLS cert file]:file:_files' \
  '--tls-private-key-file=[TLS key file]:file:_files' \
  '--feature-gates=[feature gates]:gates:' \
  '--v=[log level]:n:' \
  '--logtostderr[log to stderr]' \
  '*::karmada-metrics-adapter args:_files' && ret=0
return ret
