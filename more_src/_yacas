#compdef yacas
# Documentation: https://man.archlinux.org/search?q=yacas
# Reference accessed: 2026-05-16

_arguments -s \
  '-c[no prompts]' \
  '-f[stdin as one statement]' \
  '-p[no terminal capabilities]' \
  '-t[history recall]' \
  '-v[show version]' \
  '-d[show library path]' \
  '*:file:_files'
