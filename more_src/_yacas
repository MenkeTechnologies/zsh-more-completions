#compdef yacas
# Documentation: https://manpages.org/yacas
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '-c[no prompts]' \
  '-f[stdin as one statement]' \
  '-p[no terminal capabilities]' \
  '-t[history recall]' \
  '-v[show version]' \
  '-d[show library path]' \
  '*:file:_files'
