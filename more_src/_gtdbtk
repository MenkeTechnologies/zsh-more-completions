#compdef gtdbtk
# Documentation: https://github.com/Ecogenomics/GTDBTk
# GTDB-Tk: taxonomic classifications of bacterial and archaeal genomes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'gtdbtk subcommand' \
      'classify_wf[full classify workflow: identify, align, classify]' \
      'de_novo_wf[de novo workflow: identify, align, infer, root, decorate]' \
      'identify[identify marker genes in genomes]' \
      'align[create a multiple sequence alignment]' \
      'classify[determine taxonomic classification of genomes]' \
      'infer[infer a tree from a MSA]' \
      'root[root a tree using an outgroup]' \
      'decorate[decorate a tree with GTDB taxonomy]' \
      'ani_rep[calculate ANI to GTDB representative genomes]' \
      'check_install[verify third-party programs and database]' \
      'trim_msa[trim an untrimmed MSA with a mask]' \
      'export_msa[export the untrimmed archaeal or bacterial MSA]' \
      'test[test the installation on a small set of genomes]' && ret=0
    _files
    ;;
esac

return ret
