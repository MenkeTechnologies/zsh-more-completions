#compdef cargo-loom
# Documentation: https://man.archlinux.org/search?q=cargo-loom
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)*'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--release)--release[release]' \
  '(--lib --bin --example --test --bench)--lib[lib]' \
  '(--bin)--bin=[binary]:b:' \
  '(--test)*--test=[test]:t:' \
  '(--bench)--bench=[bench]:b:' \
  '(--example)--example=[example]:e:' \
  '(--features)--features=[features csv]:list:' \
  '(--all-features)--all-features[all features]' \
  '(--no-default-features)--no-default-features[no default]' \
  '(-p --package)*'{-p+,--package=}'[package]:p:' \
  '(--target)--target=[target]:t:' \
  '(--target-dir)--target-dir=[target dir]:dir:_files -/' \
  '(--manifest-path)--manifest-path=[manifest]:file:_files -g "*.toml"' \
  '(--checkpoint-file)--checkpoint-file=[checkpoint]:file:_files' \
  '(--checkpoint-interval)--checkpoint-interval=[interval]:n:' \
  '(--max-branches)--max-branches=[max branches]:n:' \
  '(--max-duration)--max-duration=[max duration s]:s:' \
  '(--max-permutations)--max-permutations=[max permutations]:n:' \
  '(--max-preemptions)--max-preemptions=[max preemptions]:n:' \
  '(--max-threads)--max-threads=[max threads]:n:' \
  '(--no-failfast)--no-failfast[do not stop on failure]' \
  '(--no-run)--no-run[compile only]' \
  '(--show-output)--show-output[show stdout/stderr]' \
  '*: :_files' && ret=0

return ret
