#compdef spotatui
# Documentation: https://github.com/LargeModGames/spotatui
# Reference accessed: 2026-05-21
# Verified: upstream LargeModGames/spotatui README.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'playback:control playback'
  'play:start playing content'
  'list:display library content'
  'search:find content'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--completions=[generate shell completions]:shell:(zsh bash powershell)' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'spotatui command' commands && ret=0 ;;
  args)
    case $line[1] in
      playback)
        _arguments \
          '--toggle[play/pause]' \
          '--like[like current song]' \
          '--shuffle[toggle shuffle]' && ret=0
        ;;
      play)
        _arguments \
          '--name=[playlist or track name]:name:' \
          '--playlist[search playlists]' \
          '--track[search tracks]' \
          '--random[shuffle mode]' && ret=0
        ;;
      list)
        _arguments \
          '--liked[show saved songs]' \
          '--limit=[cap results (max 50)]:n:' && ret=0
        ;;
      search)
        _arguments \
          '--tracks[search tracks]' \
          '--format=[customize output format]:format:' \
          '--limit=[result count]:n:' && ret=0
        ;;
    esac
    ;;
esac

return ret
