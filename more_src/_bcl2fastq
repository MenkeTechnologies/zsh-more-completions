#compdef bcl2fastq bcl2fastq2 bclconvert bcl-convert
# _bcl2fastq — Illumina bcl2fastq base call BCL to FASTQ converter for NextSeq HiSeq NovaSeq sequencer raw output (illumina team, C++); custom argparse
# upstream: https://support.illumina.com/sequencing/sequencing_software/bcl2fastq-conversion-software.html

_bcl2fastq() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-R+[run folder]:dir:_files -/' \
        '--runfolder-dir=+[run folder]:dir:_files -/' \
        '-i+[input dir]:dir:_files -/' \
        '--input-dir=+[input dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '--intensities-dir=+[intensities dir]:dir:_files -/' \
        '--interop-dir=+[interop dir]:dir:_files -/' \
        '--stats-dir=+[stats dir]:dir:_files -/' \
        '--reports-dir=+[reports dir]:dir:_files -/' \
        '--sample-sheet=+[sample sheet csv]:file:_files -g "SampleSheet.csv *.csv"' \
        '-r+[loading threads]:n:' \
        '--loading-threads=+[loading threads]:n:' \
        '-w+[writing threads]:n:' \
        '--writing-threads=+[writing threads]:n:' \
        '-p+[processing threads]:n:' \
        '--processing-threads=+[processing threads]:n:' \
        '-d+[demultiplexing threads]:n:' \
        '--demultiplexing-threads=+[demultiplexing threads]:n:' \
        '--barcode-mismatches=+[N]:n:' \
        '--mask-short-adapter-reads=+[N]:n:' \
        '--minimum-trimmed-read-length=+[N]:n:' \
        '--ignore-missing-bcls[ignore missing BCLs]' \
        '--ignore-missing-filter[ignore missing filter]' \
        '--ignore-missing-positions[ignore missing positions]' \
        '--ignore-missing-controls[ignore missing controls]' \
        '--write-fastq-reverse-complement[write reverse complement FASTQ]' \
        '--with-failed-reads[include failed reads]' \
        '--create-fastq-for-index-reads[create FASTQ for index reads]' \
        '--no-bgzf-compression[no BGZF compression]' \
        '--fastq-compression-level=+[level]:n:' \
        '--no-lane-splitting[no lane splitting]' \
        '--find-adapters-with-sliding-window[find adapters with sliding window]' \
        '--use-bases-mask=+[mask]:str:' \
        '--tiles=+[tiles regex]:str:' \
        '--adapter-stringency=+[F]:f:' \
        '--aggregated-tiles=+[mode]:m:(AUTO YES NO)' \
        '--first-tile-only[first tile only]' \
        '-l+[log level]:l:(INFO WARNING DEBUG ERROR FATAL)' \
        '--min-log-level=+[log level]:l:(INFO WARNING DEBUG ERROR FATAL)'
}

_bcl2fastq "$@"
