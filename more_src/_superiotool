#compdef superiotool
# Documentation: https://github.com/coreboot/coreboot/blob/master/util/superiotool/superiotool.c
# coreboot Super I/O detection and register dump tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '(-d --dump)'{-d,--dump}'[dump Super I/O registers]' \
  '(-e --extra-dump)'{-e,--extra-dump}'[dump extra registers]' \
  '(-a --alternate-dump)'{-a,--alternate-dump}'[use alternate dump format]' \
  '(-l --list-supported)'{-l,--list-supported}'[print list of supported chips]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' && ret=0

return ret
