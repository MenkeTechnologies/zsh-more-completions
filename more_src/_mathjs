_mathjs() {
    _arguments -s -S \
        '(- *)'{-v,--version}'[show application version]' \
        '(- *)'{-h,--help}'[show help message]' \
        '(--string --tex)--tex[generate LaTeX instead of evaluating]' \
        '(--string --tex)--string[generate string instead of evaluating]' \
        '--parenthesis=[set parenthesis option]:option:(keep auto all)' \
        '*:script file(s) (or expression args, or omit for REPL):_files'
}

_mathjs "$@"
