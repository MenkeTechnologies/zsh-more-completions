#compdef dep

# Zsh completion for dep (Go dependency management tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:Set up a new Go project, or migrate an existing one'
  'status:Report the status of the project dependencies'
  'ensure:Ensure a dependency is safely vendored in the project'
  'prune:Prune the vendor tree of unused packages'
  'version:Show the dep version information'
)

_arguments -s -S -C \
  '(-v --verbose)'{-v,--verbose}'[Enable verbose logging]' \
  '--gopath=[Set GOPATH]:gopath:_files -/' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'dep command' commands && ret=0
    ;;
  args)
    case $words[1] in
      init)
        _arguments -s -S \
          '--no-examples[Do not include example in Gopkg.toml]' \
          '--skip-tools[Skip importing tool dependencies]' \
          '--gopath=[Set GOPATH]:gopath:_files -/' \
          ':path:_files -/' && ret=0
        ;;
      ensure)
        _arguments -s -S \
          '-add[Add new dependencies]' \
          '-no-vendor[Update Gopkg.lock without updating vendor]' \
          '-update[Update the named packages]' \
          '-v[Enable verbose logging]' \
          '--vendor-only[Populate vendor from Gopkg.lock without updating it]' \
          '*:package' && ret=0
        ;;
      status)
        _arguments -s -S \
          '-detail[Include more detail in the chosen format]' \
          '-dot[Output a graphviz dot graph of the dependency tree]' \
          '-f+[Output in text/template format]:template' \
          '-json[Output in JSON format]' \
          '-lock[Output basic Gopkg.lock data]' \
          '-missing[Output only missing packages]' \
          '-old[Output only out-of-date packages]' \
          '-v[Enable verbose logging]' \
          '*:package' && ret=0
        ;;
      prune)
        _arguments -s -S \
          '-v[Enable verbose logging]' && ret=0
        ;;
      version)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
