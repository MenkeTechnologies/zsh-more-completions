#compdef shikanectl
# _shikanectl — control client for the shikane display daemon (hw0lff/shikane)
# upstream: https://github.com/hw0lff/shikane
# Subcommands + flags from src/client/args.rs (clap).

_shikanectl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-s --socket)'{-s+,--socket=}'[connect to the specified IPC socket]:file:_files' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_shikanectl_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                switch)
                    _arguments '1:profile name:'
                    ;;
                reload)
                    _arguments '1:config file:_files -g "*.toml"'
                    ;;
                export)
                    _arguments \
                        '(-d --description)'{-d,--description}'[include the description in searches]' \
                        '(-n --name)'{-n,--name}'[include the name in searches]' \
                        '(-m --model)'{-m,--model}'[include the model in searches (default on)]' \
                        '(-s --serial)'{-s,--serial}'[include the serial number in searches (default on)]' \
                        '(-v --vendor)'{-v,--vendor}'[include the vendor in searches (default on)]' \
                        '1:profile name:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_shikanectl_commands] )) ||
_shikanectl_commands() {
    local -a commands
    commands=(
        'switch:temporarily switch to a named profile'
        'reload:reload the configuration file (optionally from a path)'
        'export:export the current display setup as a shikane config'
    )
    _describe -t commands 'shikanectl command' commands
}

_shikanectl "$@"
