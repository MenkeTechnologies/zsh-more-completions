#compdef cargo-udeps
# Documentation: https://github.com/est31/cargo-udeps
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '(-q --quiet)'{-q,--quiet}'[Suppress output]' \
  '(-p --package)'{-p+,--package=}'[Package to check]:package:' \
  '--all[Alias for --workspace (deprecated)]' \
  '--workspace[Check all workspace members]' \
  '*--exclude=[Exclude packages]:package:' \
  '--lib[Check only library target]' \
  '--bin=[Check only specified binary]:binary:' \
  '--bins[Check all binaries]' \
  '--example=[Check only specified example]:example:' \
  '--examples[Check all examples]' \
  '--test=[Check only specified test]:test:' \
  '--tests[Check all tests]' \
  '--bench=[Check only specified benchmark]:bench:' \
  '--benches[Check all benchmarks]' \
  '--all-targets[Check all targets]' \
  '--release[Check in release mode]' \
  '--profile=[Build profile]:profile:' \
  '*--features=[Space-separated features list]:features:' \
  '--all-features[Enable all features]' \
  '--no-default-features[Disable default features]' \
  '--target=[Target triple]:target:' \
  '--target-dir=[Artifact directory]:dir:_directories' \
  '(-j --jobs)'{-j+,--jobs=}'[Parallel jobs]:n:' \
  '--manifest-path=[Path to Cargo.toml]:file:_files -g "*.toml"' \
  '--output=[Output format]:format:(human json)' \
  '--message-format=[Error format]:format:(human json short)' \
  '--color=[Coloring]:when:(auto always never)' \
  '--backend=[Backend]:backend:(depinfo save-analysis)' \
  '--frozen[Require Cargo.lock and cache up to date]' \
  '--locked[Require Cargo.lock up to date]' \
  '--offline[Run without network]' \
  '*'{-v,--verbose}'[Verbose output]' \
  '--keep-going[Internal cargo compatibility]' && return 0
