#compdef git-standup
# Documentation: https://github.com/kamranahmedse/git-standup
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git standup (recall what you did)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-a[specify author to restrict search to]:author:' \
  '-b[specify branch to restrict search to]:branch:' \
  '-B[show commits before the given date]:date:' \
  '-d[number of days back to include]:days:' \
  '-D[date format for git log]:format:(relative iso iso-strict rfc short raw human unix)' \
  '-A[show commits until the given date]:date:' \
  '-f[fetch the latest commits beforehand]' \
  '-g[show GPG signed info]' \
  '-h[display the help screen]' \
  '-L[toggle inclusion of symbolic links in directory search]' \
  '-m[depth of recursive directory search]:depth:' \
  '-F[force to use git log instead of git rev-list]' \
  '-w[specify week start and end days]:days:' \
  '-r[display the standup review]' && ret=0

return ret
