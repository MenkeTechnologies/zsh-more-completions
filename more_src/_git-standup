#compdef git-standup

# Zsh completion for git standup (recall what you did)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-a[specify author]:author:' \
  '-d[number of days back to look]:days:' \
  '-D[date format for output]:date format:' \
  '-f[fetch first before showing standup]' \
  '-g[show GPG signed info]' \
  '-h[show help]' \
  '-L[local commits only (no fetch)]' \
  '-m[max number of commits]:count:' \
  '-B[specify branch]:branch:' \
  '-w[show author email instead of name]' && ret=0

return ret
