#compdef tsocks
# Documentation: https://man.archlinux.org/man/tsocks.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tsocks(1) is a shell wrapper. It accepts no traditional flags; instead it
# takes one of three positional forms:
#   tsocks <application> [args...]   - run application with libtsocks preloaded
#   tsocks on|off|show|sh            - manipulate LD_PRELOAD (must be sourced)
#   tsocks                           - spawn new shell with tsocks preloaded

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:action:->first' \
  '*::: :->rest' && ret=0

case $state in
  (first)
    local -a actions=(
      'on:enable tsocks (modify LD_PRELOAD; must be sourced)'
      'off:disable tsocks (modify LD_PRELOAD; must be sourced)'
      'show:show current LD_PRELOAD value'
      'sh:show current LD_PRELOAD value'
    )
    _alternative \
      'actions:action:_describe -t actions action actions' \
      'commands:command:_command_names -e' && ret=0
    ;;
  (rest)
    _normal && ret=0
    ;;
esac

return ret
