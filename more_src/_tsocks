#compdef tsocks
# Documentation: https://man.archlinux.org/search?q=tsocks
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-on[enable tsocks]' \
  '-off[disable tsocks]' \
  '-show[show current status]' \
  '-v[verbose mode]' \
  '-d+[debug level]:level:(0 1 2)' \
  '*:command:_command_names' && ret=0

return ret
