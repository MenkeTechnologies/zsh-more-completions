#compdef premake5

# Zsh completion for premake5 - build configuration tool

local curcontext="$curcontext" state line ret=1

local -a actions=(
  'vs2022:generate Visual Studio 2022 project files'
  'vs2019:generate Visual Studio 2019 project files'
  'vs2017:generate Visual Studio 2017 project files'
  'vs2015:generate Visual Studio 2015 project files'
  'gmake2:generate GNU Makefiles (gmake2)'
  'gmake:generate GNU Makefiles'
  'codelite:generate CodeLite project files'
  'xcode4:generate Xcode project files'
  'clean:remove all generated files'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help information]' \
  '--version[show version information]' \
  '--file[read the specified file]:file:_files' \
  '--os[generate files for a different operating system]:os:(bsd linux macosx solaris windows)' \
  '--cc[choose a C/C++ compiler set]:compiler:(gcc clang msc)' \
  '--dc[choose a D compiler]:compiler:(dmd gdc ldc)' \
  '--dotnet[choose a .NET compiler set]:compiler:(msnet mono pnet)' \
  '--fatal[treat warnings from project scripts as errors]' \
  '--insecure[forgo SSL certification checks]' \
  '--interactive[interactive command prompt]' \
  '--scripts[search for additional scripts on the given path]:dir:_files -/' \
  '--systemscript[override the default system script]:file:_files' \
  '--verbose[generate extra debug text output]' \
  '1:action:->action' && ret=0

case $state in
  (action)
    _describe -t actions 'premake5 action' actions && ret=0
    ;;
esac

return ret
