#compdef lux

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-i[information only (no download)]' \
  '-j[print extracted data in JSON]' \
  '-f+[select specific stream by format]:format:' \
  '-p[download playlist]' \
  '-n+[set thread count for download]:threads:' \
  '-c+[cookie file or string]:cookie:_files' \
  '-o+[output directory]:directory:_files -/' \
  '-O+[output filename]:filename:' \
  '-r+[use specified referrer URL]:referrer:' \
  '-s+[minimum file size filter]:size:' \
  '-e+[file extension filter]:extension:' \
  '-d[debug mode]' \
  '-v[show version]' \
  '-h[show help]' \
  '-F+[specify stream to download]:stream ID:' \
  '-m[use multi-thread download]' \
  '-C[resume interrupted download]' \
  '-R+[retry count]:retries:' \
  '--aria2[use aria2 for downloading]' \
  '--you-get[use you-get for downloading]' \
  '--ytdl[use youtube-dl for downloading]' \
  '*:URL:_urls' && ret=0

return ret
