#compdef openapicmd openapi
# Documentation: https://github.com/openapistack/openapicmd
# The CLI for all things OpenAPI and Swagger (openapistack)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--json[output as JSON]' \
  '--yaml[output as YAML]' \
  '--dereference[resolve $ref pointers]' \
  '--bundle[bundle external $ref pointers]' \
  '(-H --header)'{-H,--header}'=[add request header]:header' \
  '--apiroot=[override API root for requests]:apiroot' \
  '(-p --port)'{-p,--port}'=[port to listen on]:port' \
  '--strip-extensions[strip x- extension properties]' \
  '1:command:(init read swagger2openapi info load call mock typegen swagger-ui redoc swagger-editor auth help)' \
  '*:spec:_files' && ret=0

return ret
