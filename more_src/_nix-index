#compdef nix-index nix-locate
# Documentation: https://github.com/nix-community/nix-index
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nix-index (index nix packages) and nix-locate (locate files in nix packages)

local curcontext="$curcontext" state line ret=1

case ${service} in
  (nix-index)
    _arguments -s -S \
      '(-r --requests)'{-r,--requests}'[number of parallel HTTP requests]:count:' \
      '(-d --db)'{-d,--db}'[directory where the index is stored]:directory:_files -/' \
      '(-f --nixpkgs)'{-f,--nixpkgs}'[path to nixpkgs to index]:path:' \
      '(-s --system)'{-s,--system}'[system platform to index]:system:' \
      '(-c --compression)'{-c,--compression}'[zstandard compression level]:level:' \
      '--show-trace[show a stack trace on Nix evaluation error]' \
      '--filter-prefix[only add paths starting with PREFIX]:prefix:' \
      '--path-cache[store and load fetch results in paths.cache]' \
      '--extra-scopes[additional package sets to include]:scopes:' \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' && ret=0
    ;;
  (nix-locate)
    _arguments -s -S \
      '(-d --db)'{-d,--db}'[directory where the index is stored]:directory:_files -/' \
      '(-r --regex)'{-r,--regex}'[treat pattern as regex]' \
      '(-p --package)'{-p,--package}'[filter matches by package name pattern]:pattern:' \
      '--hash[only show matches from packages with given hash]:hash:' \
      '--all[print all matches, including non-toplevel packages]' \
      '(-t --type)'{-t,--type}'[filter by file type]:type:(r x d s)' \
      '--no-group[disable grouping of paths by matching component]' \
      '--color[color output control]:when:(auto always never)' \
      '(-w --whole-name)'{-w,--whole-name}'[match pattern exactly against basename]' \
      '--at-root[treat pattern as absolute package-root path]' \
      '--minimal[print only attribute names]' \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '1:pattern:' && ret=0
    ;;
esac

return ret
