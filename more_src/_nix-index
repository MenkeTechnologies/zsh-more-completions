#compdef nix-index nix-locate

# Zsh completion for nix-index (index nix packages) and nix-locate (locate files in nix packages)

local curcontext="$curcontext" state line ret=1

case ${service} in
  (nix-index)
    _arguments -s -S \
      '(-f --db)'{-f,--db}'[database directory]:directory:_files -/' \
      '(-r --requests)'{-r,--requests}'[number of parallel requests]:count' \
      '(-c --channel-url)'{-c,--channel-url}'[channel URL]:url' \
      '--compression[compression type]:type:(xz bzip2 zstd)' \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' && ret=0
    ;;
  (nix-locate)
    _arguments -s -S \
      '(-f --db)'{-f,--db}'[database directory]:directory:_files -/' \
      '(-w --whole-name)'{-w,--whole-name}'[match whole file name]' \
      '(-t --type)'{-t,--type}'[filter by file type]:type:(d r s x)' \
      '--top-level[show only top-level packages]' \
      '--minimal[minimal output]' \
      '--at-root[match only at nix store root]' \
      '(-1 --first-match)'{-1,--first-match}'[show only first match]' \
      '(-p --package)'{-p,--package}'[filter by package name regex]:regex' \
      '(-r --regex)'{-r,--regex}'[use regex for pattern]' \
      '--hash[filter by hash]:hash' \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '1:pattern' && ret=0
    ;;
esac

return ret
