#compdef nixpkgs-lint
# Documentation: https://github.com/NixOS/nixpkgs/blob/master/maintainers/scripts/nixpkgs-lint.pl
# check Nixpkgs for common errors and problems

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --package)'{-p,--package}'[filter packages by name (default *)]:package:' \
  '(-m --maintainer)'{-m,--maintainer}'[filter packages by maintainer (case-insensitive regexp)]:maintainer:' \
  '(-f --file)'{-f,--file}'[path to Nixpkgs (default <nixpkgs>)]:path:_files -/' && ret=0

return ret
