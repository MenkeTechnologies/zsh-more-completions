#compdef beesd
# Documentation: source-direct extraction from upstream
# Zygo/bees scripts/beesd.in — the shell-script wrapper that
# the systemd `beesd@<UUID>.service` unit invokes.
# Reference accessed: 2026-05-30 via gh api.
#
# beesd is the per-filesystem wrapper around R214's `bees` —
# takes a btrfs filesystem UUID, looks up
# `/etc/bees/<UUID>.conf` (or the configured CONFIG_DIR), mounts
# the filesystem at `/run/bees/mnt/<UUID>` with the
# `subvolid=5,nodev,noexec` mount options, sources BEESHOME +
# BEESSTATUS + DB_SIZE from the config, and then exec's the
# bees binary on the mountpoint.  Designed for the
# `beesd@.service` systemd template unit: one instance per
# UUID.  MUST be run as root (UID check at beesd.in:91).
#
# Critical extraction note: beesd has a UNIQUE flag-forwarding
# pattern — it does NOT hard-code the supported flag list.
# Instead at beesd.in:42 it RUNS `bees --help` AT WRAPPER START
# and parses the output to build the `SUPPORTED_ARGS` array:
#   for i in $("$bees_bin" --help 2>&1 | grep -E " --" | \
#              sed -e "s/^[^-]*-/-/" -e "s/,[^-]*--/ --/" \
#                  -e "s/ [^-]*$//")
# This means beesd auto-tracks any new flags added to bees
# without requiring a wrapper edit.  Completion mirrors the
# bees flag set (decoded source-direct in R214's _bees file)
# since that's what `bees --help` would produce.

local -a bees_scan_modes_desc=(
  '0:LOCKSTEP'
  '1:INDEPENDENT'
  '2:SEQUENTIAL'
  '3:RECENT'
  '4:EXTENT'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help (delegates to `bees --help`) and exit]' \
  '--version[print version information and exit]' \
  '(-c --thread-count)'{-c+,--thread-count=}'[worker thread count (passed through to bees)]:count:' \
  '(-C --thread-factor)'{-C+,--thread-factor=}'[worker thread factor (passed through to bees)]:factor:' \
  '(-G --thread-min)'{-G+,--thread-min=}'[minimum worker thread count (passed through to bees)]:min:' \
  '(-g --loadavg-target)'{-g+,--loadavg-target=}'[target system load average (passed through to bees)]:target:' \
  '--throttle-factor=[idle time between operations (passed through to bees)]:factor:' \
  '(-m --scan-mode)'{-m+,--scan-mode=}'[btrfs scan mode (passed through to bees)]:mode:((0\:LOCKSTEP 1\:INDEPENDENT 2\:SEQUENTIAL 3\:RECENT 4\:EXTENT))' \
  '(-a --workaround-btrfs-send)'{-a,--workaround-btrfs-send}'[workaround for btrfs send]' \
  '(-t --timestamps -T --no-timestamps)'{-t,--timestamps}'[show timestamps in log output]' \
  '(-t --timestamps -T --no-timestamps)'{-T,--no-timestamps}'[omit timestamps in log output]' \
  '(-p --absolute-paths -P --strip-paths)'{-p,--absolute-paths}'[show absolute paths in log]' \
  '(-p --absolute-paths -P --strip-paths)'{-P,--strip-paths}'[strip $CWD from all log paths]' \
  '(-v --verbose)'{-v+,--verbose=}'[log level 0..8 (passed through to bees)]:level:(0 1 2 3 4 5 6 7 8)' \
  '1:btrfs filesystem UUID (matches a file under /etc/bees/<UUID>.conf):'
