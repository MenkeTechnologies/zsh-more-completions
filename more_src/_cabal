#compdef cabal
# Documentation: https://cabal.readthedocs.io/
# Source: haskell/cabal — Haskell Common Architecture for Building Apps.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _cabal_cmds
_cabal_cmds=(
    'user-config:display and update global Cabal configuration'
    'update:refresh the package index'
    'list:search for packages matching criteria'
    'info:display detailed package information'
    'init:create a new Cabal package'
    'fetch:download packages for later use'
    'get:retrieve and extract package source code'
    'configure:set project configuration options'
    'freeze:lock dependency versions'
    'gen-bounds:generate PVP-compliant dependency bounds'
    'outdated:check for outdated dependencies'
    'path:query Cabal paths and settings'
    'target:discover available build targets'
    'build:compile project targets'
    'install:build and install executables'
    'haddock:generate API documentation'
    'haddock-project:build docs for all local packages'
    'clean:remove build artifacts'
    'list-bin:show path to a compiled executable'
    'repl:open interactive GHCi session'
    'run:execute a compiled program'
    'bench:run benchmarks'
    'test:execute test suites'
    'exec:run commands within the project environment'
    'check:validate package for common issues'
    'sdist:create source distribution archive'
    'upload:publish to Hackage'
    'report:submit build reports'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--numeric-version[print just the numeric version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'cabal command' _cabal_cmds && ret=0
        ;;
esac

return ret
