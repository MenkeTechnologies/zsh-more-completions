#compdef cabal
# _cabal — Haskell Cabal build/package manager CLI (Haskell Foundation / cabal team, Haskell); custom argparse
# upstream: https://github.com/haskell/cabal

_cabal() {
    local -a sub=(
        'bench:run benchmarks'
        'build:build a target'
        'check:check a package'
        'clean:clean build'
        'configure:configure project options'
        'exec:run executable in build env'
        'fetch:fetch a package'
        'format:format a package'
        'freeze:freeze dependencies'
        'gen-bounds:generate bounds'
        'get:get a package source'
        'haddock:generate docs'
        'haddock-project:generate docs project'
        'help:show help'
        'hscolour:colour Haskell source'
        'init:scaffold a Cabal project'
        'info:show package info'
        'install:install package'
        'list:list packages'
        'list-bin:print binary path'
        'man:show man'
        'new-bench:run benchmarks (new-style)'
        'new-build:build (new-style)'
        'new-clean:clean (new-style)'
        'new-configure:configure (new-style)'
        'new-exec:run executable (new-style)'
        'new-freeze:freeze (new-style)'
        'new-haddock:generate docs (new-style)'
        'new-install:install (new-style)'
        'new-list-bin:print binary path (new-style)'
        'new-repl:open repl (new-style)'
        'new-run:run (new-style)'
        'new-sdist:build sdist (new-style)'
        'new-test:run tests (new-style)'
        'new-update:update package index (new-style)'
        'outdated:show outdated packages'
        'path:print install path'
        'register:register installed packages'
        'repl:open ghci with project context'
        'report:upload Hackage report'
        'run:run executable'
        'sandbox:legacy sandbox cmds'
        'sdist:build source distribution'
        'show-build-info:show build info'
        'target:identify a Cabal target'
        'test:run tests'
        'unpack:unpack a package'
        'update:update package index'
        'upload:upload to Hackage'
        'user-config:user config commands'
        'v1-build:legacy build'
        'v1-install:legacy install'
        'v1-test:legacy test'
        'v2-build:new-style build'
        'version:show version'
        'completion:generate completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--numeric-version[print numeric version]' \
        '--project-file=+[project file]:file:_files -g "cabal.project *.project"' \
        '--config-file=+[config file]:file:_files' \
        '--no-config-file[no config file]' \
        '--ignore-project[ignore project]' \
        '--verbose=+[verbosity]:n:(0 1 2 3)' \
        '-v+[verbosity]:n:(0 1 2 3)' \
        '--http-transport=+[http transport]:t:(curl wget plain-http powershell)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cabal subcommand' sub ;;
        args)
            case $words[1] in
                build|test|bench|repl|run|install|haddock) _arguments \
                    '--enable-tests[enable tests]' \
                    '--disable-tests[disable tests]' \
                    '--enable-benchmarks[enable benchmarks]' \
                    '--disable-benchmarks[disable benchmarks]' \
                    '--enable-documentation[enable docs]' \
                    '--disable-documentation[disable docs]' \
                    '--enable-coverage[enable coverage]' \
                    '--disable-coverage[disable coverage]' \
                    '--enable-shared[enable shared]' \
                    '--enable-static[enable static]' \
                    '--enable-executable-dynamic[enable executable dynamic]' \
                    '--enable-executable-stripping[enable executable stripping]' \
                    '--enable-library-stripping[enable library stripping]' \
                    '--enable-profiling[enable profiling]' \
                    '--enable-library-profiling[enable library profiling]' \
                    '--enable-executable-profiling[enable executable profiling]' \
                    '--enable-debug-info[enable debug info]' \
                    '--enable-split-objs[enable split objs]' \
                    '--enable-split-sections[enable split sections]' \
                    '--enable-library-coverage[enable library coverage]' \
                    '--ghc-options=+[ghc options]:str:' \
                    '--with-ghc=+[ghc binary]:file:_files' \
                    '--with-compiler=+[compiler]:file:_files' \
                    '--with-hc-pkg=+[hc-pkg binary]:file:_files' \
                    '--prefix=+[prefix]:dir:_files -/' \
                    '--builddir=+[builddir]:dir:_files -/' \
                    '--jobs=+[parallel jobs]:n:' \
                    '-j+[parallel jobs]:n:' \
                    '*:target:' ;;
                init) _arguments \
                    '-n[non-interactive]' \
                    '--non-interactive[non-interactive]' \
                    '-i[interactive]' \
                    '--interactive[interactive]' \
                    '--minimal[minimal]' \
                    '--main-is=+[main file]:str:' \
                    '--cabal-version=+[cabal-version]:str:' \
                    '--package-name=+[package name]:str:' \
                    '--language=+[language]:l:(Haskell98 Haskell2010 GHC2021)' \
                    '--license=+[license]:str:' \
                    '--source-dir=+[source dir]:dir:_files -/' ;;
                update|fetch|get|unpack|info|list|outdated) _arguments '*:package:' ;;
                user-config) _arguments \
                    '1:cmd:(init update diff)' \
                    '*:arg:' ;;
                sandbox) _arguments \
                    '1:cmd:(init delete add-source delete-source list-sources hc-pkg)' \
                    '*:arg:' ;;
                exec) _arguments '*:cmd:_command_names -e' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_cabal "$@"
