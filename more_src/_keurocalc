#compdef keurocalc
# Documentation: https://man.archlinux.org/search?q=keurocalc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--display=+[X display]:disp:' && ret=0

return ret
