#compdef diff-pdf-visually
# Documentation: diff-pdf-visually
# Source: bgeron/diff-pdf-visually diff_pdf_visually/__main__.py (master) — visual PDF comparison (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-q --silent)*'{-q,--silent}'[silence output]' \
    '(-v --verbose)*'{-v,--verbose}'[verbose (stackable)]' \
    '--threshold=[PSNR significance threshold]:val:_default' \
    '--dpi=[rasterization resolution]:dpi:_default' \
    '--outdir=[output directory for intermediate files]:dir:_files -/' \
    '--time=[seconds before discarding intermediates]:seconds:_default' \
    '--version[show version]' \
    '1:first PDF:_files -g "*.pdf"' \
    '2:second PDF:_files -g "*.pdf"' \
    && ret=0

return ret
