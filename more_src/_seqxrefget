#compdef seqxrefget
# Documentation: https://man.archlinux.org/search?q=seqxrefget
# Reference accessed: 2026-05-16

# EMBOSS seqxrefget: retrieve sequence entries via their cross-references
# - converts xref identifiers back to full sequence records.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s) with xref data]:sequence USA:_files' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output sequence format]:format:(fasta embl genbank gff swiss gcg pir nbrf raw msf ace text staden)' \
  '*:sequence USA:_files' && ret=0

return ret
