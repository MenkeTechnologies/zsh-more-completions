#compdef seqxrefget
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/seqxrefget.html
# Reference accessed: 2026-05-21
# Verified: upstream EMBOSS docs at the URL above.
# Prior file used a speculative -osformat value list; the docs show
# only -sequence and -outfile as standard qualifiers, so output is
# routed via -outfile (default *.seqxrefget).

# EMBOSS seqxrefget: retrieve sequence entries via cross-references
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s) with xref data]:sequence USA:_files' \
  '-outfile=[output file (default *.seqxrefget)]:file:_files' \
  '-odirectory2=[output directory]:dir:_files -/' \
  '*:sequence USA:_files' && ret=0

return ret
