#compdef transmission-cli
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/transmission-cli.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --blocklist)'{-b,--blocklist}'[enable peer blocklist]' \
  '(-B --no-blocklist)'{-B,--no-blocklist}'[disable peer blocklist]' \
  '(-d --downlimit)'{-d,--downlimit}'+[max download rate in KB/s]:rate (KB/s):' \
  '(-D --no-downlimit)'{-D,--no-downlimit}'[disable download rate limit]' \
  '-er[encryption required]' \
  '-ep[encryption preferred]' \
  '-et[encryption tolerated]' \
  '(-f --finish)'{-f,--finish}'+[script to run on torrent completion]:script:_files' \
  '(-g --config-dir)'{-g,--config-dir}'+[config directory]:directory:_files -/' \
  '(-m --portmap)'{-m,--portmap}'[enable portmapping via NAT-PMP or UPnP]' \
  '(-M --no-portmap)'{-M,--no-portmap}'[disable portmapping]' \
  '(-n --new)'{-n,--new}'+[create torrent from source file or directory]:file:_files' \
  '(-p --port)'{-p,--port}'+[port for incoming peers]:port:' \
  '(-t --tos)'{-t,--tos}'+[set peer socket TOS]:TOS:' \
  '(-u --uplimit)'{-u,--uplimit}'+[max upload rate in KB/s]:rate (KB/s):' \
  '(-U --no-uplimit)'{-U,--no-uplimit}'[disable upload rate limit]' \
  '(-v --verify)'{-v,--verify}'[verify downloaded torrent data]' \
  '(-w --download-dir)'{-w,--download-dir}'+[download directory]:directory:_files -/' \
  '*:torrent file or magnet link:_files -g "*.torrent(-.)"' && ret=0

return ret
