#compdef transmission-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-b[enable blocklist]' \
  '-B[disable blocklist]' \
  '-d+[max download rate in KB/s (-1 for no limit)]:rate (KB/s):' \
  '-D[disable download rate limit]' \
  '-er[encryption required]' \
  '-ep[encryption preferred]' \
  '-et[encryption tolerated]' \
  '-f+[script to run on torrent completion]:script:_files' \
  '-g+[config directory]:directory:_files -/' \
  '-m[enable portmapping]' \
  '-M[disable portmapping]' \
  '-p+[port for incoming peers]:port:' \
  '-t+[set peer socket TOS]:TOS:' \
  '-u+[max upload rate in KB/s (-1 for no limit)]:rate (KB/s):' \
  '-U[disable upload rate limit]' \
  '-v[verbose output]' \
  '-w+[download directory]:directory:_files -/' \
  '*:torrent file or magnet link:_files -g "*.torrent(-.)"' && ret=0

return ret
