#compdef serf

# Zsh completion for HashiCorp Serf

local curcontext="$curcontext" state line ret=1

local -a serf_commands
serf_commands=(
  'agent:runs a Serf agent'
  'event:dispatch a custom user event'
  'force-leave:force a member into the left state'
  'info:provides debugging information'
  'join:tell Serf agent to join cluster'
  'keygen:generates a new encryption key'
  'leave:gracefully leave the Serf cluster'
  'members:lists the members of a Serf cluster'
  'monitor:stream logs from a Serf agent'
  'query:dispatch a query and gather responses'
  'reachability:test network reachability'
  'tags:modify tags of a running agent'
  'version:prints the Serf version'
  'rtt:estimates network round trip time'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:_describe -t commands command serf_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      agent)
        _arguments -s -S \
          '-bind=[address to bind on]:address:' \
          '-iface=[network interface to bind on]:interface:' \
          '-advertise=[advertise address]:address:' \
          '-config-file=[path to config file]:config file:_files' \
          '-config-dir=[path to config directory]:directory:_directories' \
          '-encrypt=[encryption key]:key:' \
          '*-event-handler=[event handler command]:handler:' \
          '*-join=[address to join]:address:' \
          '-log-level=[log level]:level:(trace debug info warn err)' \
          '-node=[node name]:name:' \
          '-profile=[timing profile]:profile:(lan wan local)' \
          '-protocol=[protocol version]:version:' \
          '-retry-interval=[retry join interval]:interval:' \
          '*-retry-join=[address to retry joining]:address:' \
          '-retry-max=[maximum retry join attempts]:count:' \
          '-role=[role of this node]:role:' \
          '-rpc-addr=[RPC address]:address:' \
          '-snapshot=[path to snapshot file]:file:_files' \
          '*-tag=[tag key=value pair]:tag (key=value):' \
          '-syslog[enable syslog logging]' && ret=0
        ;;
      members)
        _arguments -s -S \
          '-detailed[show detailed member info]' \
          '-format=[output format]:format:(json table)' \
          '-name=[filter by node name]:name:' \
          '-role=[filter by role]:role:' \
          '-status=[filter by status]:status:(alive leaving left failed)' \
          '*-tag=[filter by tag]:tag (key=value):' \
          '-rpc-addr=[RPC address]:address:' && ret=0
        ;;
      join)
        _arguments -s -S \
          '-replay[replay old user events]' \
          '-rpc-addr=[RPC address]:address:' \
          '*:address to join:' && ret=0
        ;;
      event)
        _arguments -s -S \
          '-coalesce=[coalesce events]:coalesce:(true false)' \
          '-rpc-addr=[RPC address]:address:' \
          '1:event name:' \
          '2:event payload:' && ret=0
        ;;
      force-leave)
        _arguments -s -S \
          '-rpc-addr=[RPC address]:address:' \
          '1:node name:' && ret=0
        ;;
      monitor)
        _arguments -s -S \
          '-log-level=[log level]:level:(trace debug info warn err)' \
          '-rpc-addr=[RPC address]:address:' && ret=0
        ;;
      query)
        _arguments -s -S \
          '-format=[output format]:format:(json table)' \
          '-node=[filter by node name]:name:' \
          '*-tag=[filter by tag]:tag (key=value):' \
          '-timeout=[query timeout]:timeout:' \
          '-no-ack[do not require acknowledgement]' \
          '-rpc-addr=[RPC address]:address:' \
          '1:query name:' \
          '2:query payload:' && ret=0
        ;;
      tags)
        _arguments -s -S \
          '*-set=[set a tag]:tag (key=value):' \
          '*-delete=[delete a tag]:tag key:' \
          '-rpc-addr=[RPC address]:address:' && ret=0
        ;;
      rtt)
        _arguments -s -S \
          '-rpc-addr=[RPC address]:address:' \
          '1:node A:' \
          '2:node B:' && ret=0
        ;;
      info|reachability|keygen|leave|version)
        _arguments -s -S \
          '-rpc-addr=[RPC address]:address:' && ret=0
        ;;
    esac
    ;;
esac

return ret
