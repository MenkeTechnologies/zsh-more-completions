#compdef fastp

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-i --in1)'{-i,--in1}'[read1 input file]:file:_files -g "*.{fq,fastq,fq.gz,fastq.gz}"' \
  '(-I --in2)'{-I,--in2}'[read2 input file]:file:_files -g "*.{fq,fastq,fq.gz,fastq.gz}"' \
  '(-o --out1)'{-o,--out1}'[read1 output file]:file:_files' \
  '(-O --out2)'{-O,--out2}'[read2 output file]:file:_files' \
  '--unpaired1=[unpaired reads from read1]:file:_files' \
  '--unpaired2=[unpaired reads from read2]:file:_files' \
  '--failed_out=[failed reads output]:file:_files' \
  '--merge[merge overlapping paired-end reads]' \
  '--merged_out=[merged reads output]:file:_files' \
  '--overlapped_out=[overlapped reads output]:file:_files' \
  '(-j --json)'{-j,--json}'[JSON report file]:file:_files' \
  '(-R --report_title)'{-R,--report_title}'[report title]:title' \
  '(-w --thread)'{-w,--thread}'[number of threads]:threads' \
  '(-q --qualified_quality_phred)'{-q,--qualified_quality_phred}'[quality value]:quality' \
  '(-u --unqualified_percent_limit)'{-u,--unqualified_percent_limit}'[percent limit]:percent' \
  '(-n --n_base_limit)'{-n,--n_base_limit}'[N base limit]:limit' \
  '(-l --length_required)'{-l,--length_required}'[minimum read length]:length' \
  '--length_limit=[maximum read length]:length' \
  '(-5 --cut_front)'{-5,--cut_front}'[move a sliding window from front]' \
  '(-3 --cut_tail)'{-3,--cut_tail}'[move a sliding window from tail]' \
  '-W[window size for sliding window]:size' \
  '--cut_window_size=[window size]:size' \
  '-M[mean quality for sliding window]:quality' \
  '--cut_mean_quality=[mean quality]:quality' \
  '--adapter_sequence=[adapter for read1]:sequence' \
  '--adapter_sequence_r2=[adapter for read2]:sequence' \
  '--adapter_fasta=[adapter FASTA file]:file:_files -g "*.{fa,fasta}"' \
  '-A[disable adapter trimming]' \
  '--disable_adapter_trimming[disable adapter trimming]' \
  '-Q[disable quality filtering]' \
  '--disable_quality_filtering[disable quality filtering]' \
  '-L[disable length filtering]' \
  '--disable_length_filtering[disable length filtering]' \
  '-G[disable trim poly-G]' \
  '--disable_trim_poly_g[disable trim poly-G]' \
  '-x[enable poly-X trimming]' \
  '--trim_poly_x[enable poly-X trimming]' \
  '-c[enable base correction for PE data]' \
  '--correction[enable base correction for PE data]' \
  '--umi[enable UMI preprocessing]' \
  '--umi_loc=[UMI location]:location:(index1 index2 read1 read2 per_index per_read)' \
  '--umi_len=[UMI length]:length' \
  '--umi_prefix=[UMI prefix]:prefix' \
  '--umi_skip=[skip bases after UMI]:bases' \
  '-D[enable deduplication]' \
  '--dedup[enable deduplication]' \
  '-f[trim N bases from front of read1]:bases' \
  '--trim_front1=[trim N bases from front of read1]:bases' \
  '-t[trim N bases from tail of read1]:bases' \
  '--trim_tail1=[trim N bases from tail of read1]:bases' \
  '-F[trim N bases from front of read2]:bases' \
  '--trim_front2=[trim N bases from front of read2]:bases' \
  '-T[trim N bases from tail of read2]:bases' \
  '--trim_tail2=[trim N bases from tail of read2]:bases' \
  '-s[split output by lines]:lines' \
  '--split=[split output by lines]:lines' \
  '-S[split output by file number]:number' \
  '--split_by_lines=[lines per file]:lines' \
  '-d[digits for split file numbering]:digits' && ret=0

return ret
