#compdef cargo-leptos

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new:create a new Leptos project'
  'build:build the project'
  'serve:serve the project'
  'test:run tests'
  'watch:watch for changes and rebuild'
  'end2end:run end-to-end tests'
  'init:initialize Leptos in existing project'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    _describe -t commands 'cargo-leptos command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (new)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--git[git repository to use as template]:url:' \
          '--path[template subdirectory]:path:' \
          '1:project name:' && ret=0
        ;;
      (build)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          {-r,--release}'[build in release mode]' \
          '--precompress[precompress static files]' \
          {-p,--project-path}'[project path]:path:_directories' \
          '--bin-features[binary features]:features:' \
          '--lib-features[library features]:features:' \
          {-v,--verbose}'[verbose output]' && ret=0
        ;;
      (serve)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          {-r,--release}'[serve in release mode]' \
          '--hot-reload[enable hot reload]' \
          {-p,--project-path}'[project path]:path:_directories' \
          '--bin-features[binary features]:features:' \
          '--lib-features[library features]:features:' \
          {-v,--verbose}'[verbose output]' && ret=0
        ;;
      (watch)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          {-r,--release}'[build in release mode]' \
          '--hot-reload[enable hot reload]' \
          {-p,--project-path}'[project path]:path:_directories' \
          {-v,--verbose}'[verbose output]' && ret=0
        ;;
      (*)
        _arguments '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
