#compdef cargo-leptos
# Documentation: https://github.com/leptos-rs/cargo-leptos
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new:create a new Leptos project from a template'
  'build:build the server and client (WASM)'
  'serve:build and run the server'
  'test:run tests for lib and bin packages'
  'end-to-end:build, run server, and execute end-to-end shell hook'
  'watch:rebuild on changes with browser live-reload'
  'completions:generate shell completions'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    _describe -t commands 'cargo-leptos command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (new)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--git=[git repository to use as template]:url:' \
          '--path=[template subdirectory]:path:_files -/' \
          '1:project name:' && ret=0
        ;;
      (build|serve|watch|end-to-end|test)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '(-r --release)'{-r,--release}'[build in release mode]' \
          '(-P --precompress)'{-P,--precompress}'[precompress static files]' \
          '(-p --project)'{-p,--project}'=[project name from Cargo.toml]:project:' \
          '--bin-features=[binary cargo features]:features:' \
          '--lib-features=[library cargo features]:features:' \
          '--bin-cargo-args=[args forwarded to cargo for the bin]:args:' \
          '--lib-cargo-args=[args forwarded to cargo for the lib]:args:' \
          '(-v --verbose)*'{-v,--verbose}'[verbose output]' && ret=0
        ;;
      (completions)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      (*)
        _arguments '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
