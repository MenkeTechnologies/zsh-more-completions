#compdef circonus-cli circonus circonusctl
# _circonus-cli — Circonus circonus-cli CLI command-line frontend wrapping the Circonus IRONdb time-series database monitoring analytics anomaly-detection platform CLI providing login logout whoami check broker rule-set contact-group alert account metric annotation maintenance graph dashboard worksheet template user role IRONdb-cluster CAQL-query histogram CAQL (Circonus team Theo Schlossnagle, Go); cobra
# upstream: https://www.circonus.com/

_circonus-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'check:check operations'
        'check-bundle:check bundle operations'
        'broker:broker operations'
        'rule-set:rule set operations'
        'rule-set-group:rule set group ops'
        'contact-group:contact group operations'
        'alert:alert operations'
        'account:account operations'
        'metric:metric operations'
        'annotation:annotation operations'
        'maintenance:maintenance window ops'
        'graph:graph operations'
        'dashboard:dashboard operations'
        'worksheet:worksheet operations'
        'template:template operations'
        'user:user operations'
        'role:role operations'
        'caql:run CAQL query'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--api-app=+[name]:str:' \
        '--api-url=+[url]:str:' \
        '--account=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'circonus subcommand' sub ;;
        args)
            case $words[1] in
                check|check-bundle|broker|rule-set|rule-set-group|contact-group|alert|account|metric|annotation|maintenance|graph|dashboard|worksheet|template|user|role) _arguments '1:op:(list get create update delete enable disable acknowledge)' '*:id:' ;;
                caql) _arguments '*:expression:' ;;
            esac
            ;;
    esac
}

_circonus-cli "$@"
