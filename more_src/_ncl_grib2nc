#compdef ncl_grib2nc
# Documentation: https://www.cpc.ncep.noaa.gov/products/wesley/wgrib2/
# NCL tool to convert GRIB to netCDF (deprecated; use ncl_convert2nc)

local ret=1

_arguments -s -S \
  '-h[show usage message]' \
  '-i[location of input file]:input directory:_files -/' \
  '-o[location of output file]:output directory:_files -/' \
  '-u[name of NCL time dimension to be UNLIMITED]:time name:' \
  '-U[new name of UNLIMITED dimension (requires -u)]:new time name:' \
  '-v[subset of variables to convert]:vars:' \
  '-L[support writing large (>2Gb) netCDF files]' \
  '-c[comment to add as netCDF file attribute]:comment:' \
  '-d[print netCDF file contents on exit]' \
  '-B[suppress informational messages]:file:_files' \
  '*:grib file:_files -g "*.(grb|grb2|grib|grib2)"' && ret=0

return ret
