#compdef ANTSUseLandmarkImagesToGetBSplineDisplacementField
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ANTSUseLandmarkImagesToGetBSplineDisplacementField.cxx — BSpline warp from labeled landmarks (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:fixedImageWithLabeledLandmarks:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:movingImageWithLabeledLandmarks:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outputDisplacementField:_files' \
    '4:meshSize (e.g. 4x4x4):_default' \
    '5:numberOfLevels:_default' \
    '6::order (default 3):_default' \
    '7::enforceStationaryBoundaries (default 1):(0 1)' \
    '8::landmarkWeights:_default' \
    && ret=0

return ret
