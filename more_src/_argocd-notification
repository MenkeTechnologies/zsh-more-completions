#compdef argocd-notification
# _argocd-notification — Argo CD notifications controller (argoproj/argo-cd)
# upstream: https://github.com/argoproj/argo-cd
# Flags from cmd/argocd-notification/commands/argocd_notification.go (cobra).

_argocd-notification() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--processors-count=[number of processors]:n:' \
        '--app-label-selector=[application label selector]:selector:' \
        '--loglevel=[log level]:level:(debug info warn error)' \
        '--logformat=[log format]:format:(json text)' \
        '--metrics-port=[metrics port]:port:' \
        '--argocd-repo-server=[Argo CD repo server address]:host\:port:' \
        '--argocd-repo-server-plaintext[use non-TLS client to connect to repo server]' \
        '--argocd-repo-server-strict-tls[strict TLS certificate validation]' \
        '--config-map-name=[notifications ConfigMap name]:name:' \
        '--secret-name=[notifications Secret name]:name:' \
        '--application-namespaces=[comma-separated additional namespaces]:list:' \
        '--self-service-notification-enabled[allow per-namespace notification config]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--context=[kubeconfig context]:context:' \
        '--namespace=[kubernetes namespace]:namespace:' \
        '--server=[kubernetes API server]:url:_urls'
}

_argocd-notification "$@"
