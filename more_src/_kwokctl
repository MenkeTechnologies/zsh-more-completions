#compdef kwokctl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create cluster or nodes'
  'delete:delete cluster or nodes'
  'get:list cluster resources'
  'logs:dump component logs'
  'snapshot:cluster snapshot helpers'
  'etcdctl:run etcdctl in cluster context'
  'kubectl:run kubectl with kubeconfig'
  'exec:exec into node shell'
  'stop:stop cluster processes'
  'start:start cluster processes'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--name=[cluster name]:name:' \
  '--kubeconfig=[kubeconfig output path]:file:_files' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'kwokctl command' commands && ret=0
    ;;
  (args)
    _arguments '*:kwokctl args: _default' && ret=0
    ;;
esac

return ret
