#compdef syft
# Documentation: https://github.com/anchore/syft
# Reference accessed: 2026-05-21
# Verified: upstream commands listing
# (gh api repos/anchore/syft/contents/cmd/syft/internal/commands).
# Removed: fabricated login/logout subcommands (no login.go/logout.go in
# upstream); fabricated singularity source value.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'attest:attest an SBOM (deprecated)'
  'cataloger:show available catalogers'
  'completion:generate completion'
  'convert:convert SBOM format'
  'help:show help'
  'packages:scan for packages (deprecated)'
  'scan:generate an SBOM'
  'update:check for newer versions'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)*'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '*-c+[config file]:file:_files' \
  '*--config=[config file]:file:_files' \
  '*--exclude=[exclude pattern]:p:' \
  '*--file=[output file]:file:_files' \
  '*-o+[output format]:f:(syft-json cyclonedx-json cyclonedx-xml github spdx-json spdx-tag-value syft-table syft-text template purls)' \
  '*--output=[output format]:f:' \
  '*--platform=[platform]:p:' \
  '*-s+[scope]:s:(squashed all-layers)' \
  '*--scope=[scope]:s:(squashed all-layers)' \
  '*--source-name=[source name]:n:' \
  '*--source-version=[source version]:v:' \
  '*--from=[source provider]:list:(registry oci-dir oci-archive docker docker-archive directory file)' \
  '*--catalogers=[catalogers csv (deprecated)]:list:' \
  '*--override-default-catalogers=[catalogers csv]:list:' \
  '*--select-catalogers=[catalogers csv]:list:' \
  '*--enrich=[enrichment csv]:list:' \
  '*--base-path=[base path]:dir:_files -/' \
  '--parallelism=[number of cataloger workers]:n:' \
  '--source-supplier=[component supplier]:supplier:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t cmds 'syft command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (convert)
        _arguments \
          '*-o+[format]:f:' \
          '*--output=[format]:f:' \
          '*: :_files' && ret=0 ;;
      (cataloger)
        _arguments '1:subcommand:(list info)' '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
