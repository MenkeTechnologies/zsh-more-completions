#compdef syft

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'attest:attest an SBOM (deprecated)'
  'cataloger:show available catalogers'
  'completion:generate completion'
  'convert:convert SBOM format'
  'help:show help'
  'login:login to OCI registry'
  'logout:logout'
  'packages:scan for packages (deprecated)'
  'scan:generate an SBOM'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)*'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '*-c+[config file]:file:_files' \
  '*--config=[config file]:file:_files' \
  '*--exclude=[exclude pattern]:p:' \
  '*--file=[output file]:file:_files' \
  '*-o+[output format]:f:(syft-json cyclonedx-json cyclonedx-xml github-json spdx-json spdx-tag-value syft-table syft-text template)' \
  '*--output=[output format]:f:' \
  '*--platform=[platform]:p:' \
  '*-s+[scope]:s:(squashed all-layers)' \
  '*--scope=[scope]:s:(squashed all-layers)' \
  '*-t+[template]:file:_files' \
  '*--template=[template]:file:_files' \
  '*--source-name=[source name]:n:' \
  '*--source-version=[source version]:v:' \
  '*--from=[source from csv]:list:(registry oci-dir oci-archive docker docker-archive directory file singularity)' \
  '*--catalogers=[catalogers csv]:list:' \
  '*--override-default-catalogers=[catalogers csv]:list:' \
  '*--select-catalogers=[catalogers csv]:list:' \
  '*--enrich=[enrichment csv]:list:' \
  '*--base-path=[base path]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _alternative \
      'commands:command:_describe -t cmds "syft command" commands' \
      'sources:source:( )' && ret=0 ;;
  (args)
    case $line[1] in
      (convert)
        _arguments \
          '*-o+[format]:f:' \
          '*--output=[format]:f:' \
          '*: :_files' && ret=0 ;;
      (cataloger)
        _arguments '1:subcommand:(list)' '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
