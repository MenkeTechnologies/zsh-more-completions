#compdef helm-gcs
# Documentation: https://github.com/hayorov/helm-gcs
# Helm plugin to manage chart repositories on Google Cloud Storage

local ret=1
local -a subcmds

subcmds=(
  'init:initialize a new repository in GCS'
  'push:upload a chart to a repository'
  'remove:delete a chart from a repository'
)

_arguments -s -C \
  '--debug[enable detailed logging]' \
  '--version[display version information]' \
  '--help[display command help information]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'helm gcs command' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      push)
        _arguments -s \
          '--retry[retry automatically on concurrent updates]' \
          '--force[overwrite existing chart]' \
          '--public[make chart publicly accessible]' \
          '--metadata=[add custom metadata as key=value]:metadata' \
          '--bucketPath=[organize charts within bucket structure]:path' \
          '--publicURL=[use custom domain or CDN]:url' \
          '*:file:_files' && ret=0
        ;;
      remove)
        _arguments -s \
          '--version=[chart version to remove]:version' \
          '*:arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
