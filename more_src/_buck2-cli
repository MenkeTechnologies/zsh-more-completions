#compdef buck2-cli
# _buck2-cli — Meta Buck2 Rust polyglot build system CLI alias (facebook/buck2 team, Rust); clap-rs
# upstream: https://github.com/facebook/buck2

_buck2-cli() {
    local -a sub=(
        'aquery:action-graph queries'
        'audit:audit commands'
        'build:build targets'
        'bxl:run buck extension language script'
        'clean:delete build outputs'
        'completion:emit shell completion'
        'configured-targets:show configured targets'
        'ctargets:show configured targets (alias)'
        'cquery:configured-target queries'
        'debug:debugging commands'
        'docs:documentation commands'
        'expand-external-cell:expand external cells'
        'explain:explain build action'
        'export:export build artifacts'
        'help:show help'
        'help-env:show env variables'
        'init:initialize a new buck2 project'
        'install:install build outputs'
        'kill:terminate buckd'
        'killall:kill all buck2 processes'
        'log:log commands'
        'lsp:run LSP'
        'profile:profile build'
        'project:project commands'
        'rage:troubleshoot rage report'
        'root:show project root'
        'run:run binary target'
        'server:server commands'
        'starlark:starlark linter/typechecker'
        'status:show daemon status'
        'targets:resolve target patterns'
        'test:run test targets'
        'uquery:unconfigured-target queries'
        'verify-caches:verify caches'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose=+[verbose level]:n:' \
        '-v+[verbose level]:n:' \
        '--isolation-dir=+[isolation dir]:str:' \
        '--no-buckd[no daemon]' \
        '--write-build-id=+[file]:file:_files' \
        '--command-report-path=+[file]:file:_files' \
        '--config=+[config override]:str:' \
        '-c+[config override]:str:' \
        '--config-file=+[config file]:file:_files' \
        '--fake-host=+[fake host]:str:' \
        '--fake-exec-platform=+[fake exec platform]:str:' \
        '--reuse-current-config[reuse current config]' \
        '--exit-when-different-state[exit when different state]' \
        '--preemptible=+[mode]:m:(never always-low always-high)' \
        '--no-interactive-console[no interactive console]' \
        '--client-metadata=+[key=value]:str:' \
        '--target-platforms=+[platforms]:str:' \
        '--build-report=+[file]:file:_files' \
        '--build-report-options=+[options]:str:' \
        '--client-metadata=+[meta]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'buck2 subcommand' sub ;;
        args)
            case $words[1] in
                build|test|run|install) _arguments \
                    '*:target pattern:' \
                    '--show-output[show output paths]' \
                    '--show-full-output[show full output paths]' \
                    '--show-json-output[json output paths]' \
                    '--show-simple-output[simple output paths]' \
                    '--keep-going[keep going on failure]' \
                    '-k[keep going on failure]' \
                    '--print-build-report[print build report]' \
                    '--materializations=+[mode]:m:(all default skip)' ;;
                clean) _arguments \
                    '--keep-cache[keep cache]' \
                    '--dry-run[dry run]' \
                    '--stale[only clean stale]' ;;
                targets) _arguments \
                    '*:target pattern:' \
                    '--json[json output]' \
                    '--show-output[show output]' \
                    '--show-target-hash[show target hash]' \
                    '--package-values[include package values]' \
                    '--keep-going[keep going on failure]' \
                    '--streaming[streaming output]' \
                    '--no-cache[no cache]' \
                    '--resolve-alias[resolve alias]' ;;
                uquery|cquery|aquery) _arguments \
                    '1:query:' \
                    '*:targets:' \
                    '--output-attribute=+[attribute regex]:str:' \
                    '--json[json output]' \
                    '--dot[dot output]' \
                    '--dot-compact[compact dot]' ;;
                init) _arguments '1:project dir:_files -/' '--git[git init]' '--allow-overwrite[allow overwrite]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_buck2-cli "$@"
