#compdef bd_splice
# Documentation: https://man.archlinux.org/search?q=bd_splice
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-t+[title number]:title:' \
  '-p+[playlist number]:playlist:' \
  '-c+[chapter range (first[-last])]:range:' \
  '-k+[key file]:file:_files' \
  '-a+[angle]:angle:' \
  '*:Blu-Ray path / dest:_files -/' && ret=0

return ret
