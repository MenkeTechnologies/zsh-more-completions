#compdef bd_splice
# Documentation: https://manpages.debian.org/testing/libbluray-bin/bd_splice.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bd_splice: libbluray utility to splice titles/playlists from a Blu-Ray

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-t+[title number to splice (first title is 1)]:title:' \
  '-p+[playlist number]:playlist:' \
  '-c+[chapter or chapter range (N or N-M)]:range:' \
  '-k+[AACS key file]:file:_files' \
  '-a+[angle (first angle is 1)]:angle:' \
  '-v[verbose mode]' \
  '*:Blu-Ray path / destination:_files -/' && ret=0

return ret
