#compdef spamo
# Documentation: https://meme-suite.org/meme/doc/spamo.html
# MEME Suite: find motifs with preferred spacing (spaced motif analysis)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output directory (default spamo_out), fail if exists]:dir:_files -/' \
  '-oc[output directory (default spamo_out), overwrite if exists]:dir:_files -/' \
  '-text[output TSV only, no HTML]' \
  '-eps[output histograms in EPS format]' \
  '-png[output histograms in PNG format]' \
  '-dumpseqs[write TSV files with motif match details]' \
  '-dumpsigs[write TSV files for significant bins only]' \
  '-norc[do not scan the reverse complement strand]' \
  '-minscore[minimum match score threshold]:value:' \
  '-margin[distance around primary motif to search]:size:' \
  '-range[distance from primary motif for p-values]:size:' \
  '-bin[histogram bin size]:size:' \
  '-usebestsec[use only the best secondary motif match]' \
  '-numgen[random seed for tie-breaking]:seed:' \
  '-shared[redundant sequence removal threshold]:fraction:' \
  '-odds[odds-ratio speed optimization for redundancy]:odds ratio:' \
  '-cutoff[p-value threshold for significant bins]:p-value:' \
  '-evalue[minimum secondary motif E-value]:E-value:' \
  '-overlap[minimum overlap for motif redundancy]:size:' \
  '-joint[joint sequence fraction for redundancy]:fraction:' \
  '-pseudo[pseudocount added to motifs]:count:' \
  '-trim[information content threshold for edge trimming]:bits:' \
  '-primary[select the primary motif by name]:name:' \
  '-primaryi[select the primary motif by index]:num:' \
  '-keepprimary[retain the primary motif in secondary searches]' \
  '*:sequence/motif file:_files' && ret=0

return ret
