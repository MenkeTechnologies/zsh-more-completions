#compdef ndf2gif
# Documentation: https://starlink.eao.hawaii.edu/docs/sun55.htx/sun55ss16.html
# CONVERT NDF2GIF - convert a 2-d NDF into a GIF file

local ret=1

_arguments -C \
  'IN=[input NDF]:NDF file:_files' \
  'OUT=[output GIF file]:GIF file:_files -g "*.gif"' \
  'SCALE=[scaling method]:scale:(Range Faint Percentiles Scale Sigmas)' \
  'LOW=[array value scaling to 0]:low:' \
  'HIGH=[array value scaling to 255]:high:' \
  'PERCENTILES=[two percentile scaling limits]:percentiles:' \
  'NUMBIN=[histogram bins for percentiles]:bins:' \
  'SIGMAS=[standard-deviation scaling bounds]:sigmas:' \
  'MSG_FILTER=[message filtering level]:level:(QUIET NORMAL VERBOSE)' \
  '*:NDF file:_files' && ret=0

return ret
