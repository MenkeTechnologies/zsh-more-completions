#compdef virt-who

# virt-who: Red Hat Satellite virt-who agent (hypervisor inventory reporter)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-o --one-shot)'{-o,--one-shot}'[run once, do not daemonise]' \
  '(-i --interval)'{-i,--interval=}'[poll interval (seconds)]:n:' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-p --print)'{-p,--print}'[print associations to stdout]' \
  '(-j --json)'{-j,--json}'[JSON output (used with -p)]' \
  '(-r --reporter-id)'{-r,--reporter-id=}'[reporter ID]:id:' \
  '--log-file=[log to file]:file:_files' \
  '--log-dir=[log directory]:dir:_files -/' \
  '--log-per-config[separate log per config]' \
  '--status[show status only]' \
  '--esx[use VMware ESX backend]' \
  '--rhevm[use RHEV-M backend]' \
  '--xen[use Citrix XenServer backend]' \
  '--hyperv[use Microsoft Hyper-V backend]' \
  '--libvirt[use libvirt backend]' \
  '--ahv[use Nutanix AHV backend]' \
  '--kubevirt[use KubeVirt backend]' \
  '--owner=[Satellite organisation]:org:' \
  '--env=[lifecycle environment]:env:' \
  '*::virt-who args:_files' && ret=0
return ret
