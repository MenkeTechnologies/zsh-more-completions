#compdef virt-who
# Documentation: https://github.com/candlepin/virt-who/blob/main/virt-who.8
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# virt-who: reports virtual guest IDs to subscription-manager / Satellite
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '-d[debug output]' \
  '--debug[debug output]' \
  '-o[one-shot run, exit immediately]' \
  '--one-shot[one-shot run, exit immediately]' \
  '-i[run interval in seconds]:seconds:' \
  '--interval=[run interval in seconds]:seconds:' \
  '-p[print report only, no upload]' \
  '--print[print report only, no upload]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-l[log destination]:dest:' \
  '--log-dir=[log directory]:dir:_files -/' \
  '--log-file=[log file]:file:_files' \
  '--log-per-config[separate log file per config]' \
  '--reporter-id=[reporter id]:id:' \
  '*::virt-who args:_files' && ret=0
return ret
