#compdef croc

# Zsh completion for croc - Easily and securely send things from one computer to another

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'send:send file(s) or folder(s) or pipe'
  'relay:start a croc relay'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--remember[save these settings for next time]' \
  '--debug[toggle debug mode]' \
  '--yes[automatically accept all prompts]' \
  '--stdout[redirect file to stdout]' \
  '--no-compress[disable compression]' \
  '--ask[make sure sender and receiver agree before transfer]' \
  '--ip=[set sender ip address]:ip address:' \
  '--relay=[address of the relay]:relay address:' \
  '--relay6=[ipv6 address of the relay]:relay address:' \
  '--out=[specify output directory]:output directory:_files -/' \
  '--pass=[password for relay]:password:' \
  '--socks5=[add a SOCKS5 proxy]:proxy address:' \
  '--connect=[add a connect proxy]:proxy address:' \
  '--throttle=[throttle the upload speed]:speed:' \
  '--curve=[choose elliptic curve]:curve:(p256 p348 p521 siec)' \
  '--hash=[choose hash algorithm]:hash:(xxhash imohash)' \
  '--classic[toggle classic mode]' \
  '--overwrite[do not prompt to overwrite]' \
  '1:command:->command' \
  '*:file:_files' && ret=0

case $state in
  (command)
    _describe -t commands 'croc command' commands && ret=0
    ;;
esac

return ret
