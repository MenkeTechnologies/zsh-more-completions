#compdef dnsc
# Documentation: https://github.com/atc0005/dnsc
# Run a DNS query concurrently against all servers in a list

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show application version and exit]' \
  '*'{-ds,--dns-server}'[DNS server IP address to query]:server' \
  '(-cf --config-file)'{-cf,--config-file}'[path to TOML configuration file]:file:_files' \
  '(-q --query)'{-q,--query}'[fully-qualified domain name to look up]:fqdn' \
  '*'{-t,--type}'[DNS record type (A, AAAA, CNAME, MX, NS, PTR, SRV)]:type:(A AAAA CNAME MX NS PTR SRV)' \
  '*'{-sp,--srv-protocol}'[SRV protocol keyword]:protocol:(msdcs kerberos xmppsrv xmppclient sip)' \
  '(-to --timeout)'{-to,--timeout}'[maximum seconds allowed for DNS query]:seconds' \
  '(-ll --log-level)'{-ll,--log-level}'[message priority filter]:level:(fatal error warn info debug)' \
  '(-lf --log-format)'{-lf,--log-format}'[output format]:format:(cli json logfmt text discard)' \
  '(-ro --results-output)'{-ro,--results-output}'[results format]:format:(multi-line single-line)' \
  '(-ot --omit-timestamp)'{-ot,--omit-timestamp}'[exclude date/time from output]' \
  '(-def --dns-errors-fatal)'{-def,--dns-errors-fatal}'[exit immediately on DNS errors]' && ret=0

return ret
