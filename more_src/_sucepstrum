#compdef sucepstrum
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/sucepstrum.c
# transform to the CEPSTRal domain

local ret=1

_arguments -s -S \
  'sign1=[sign1]:sign1:' \
  'sign2=[sign2]:sign2:' \
  'dt=[dt]:dt:' \
  'verbose=[verbose]:verbose:' \
  'mode=[mode]:mode:' \
  'unwrap=[unwrap]:unwrap:' \
  'trend=[trend]:trend:' \
  'zeromean=[zeromean]:zeromean:' \
  'smooth=[smooth]:smooth:' \
  'r=[r]:r:' \
  '*:file:_files' && ret=0

return ret
