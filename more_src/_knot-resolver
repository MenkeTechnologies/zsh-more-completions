#compdef knot-resolver kresd5 kresd-cache-gc
# _knot-resolver — CZ.NIC Labs Knot Resolver kresd modern caching full DNS resolver with Lua scripting and DNSSEC validation (CZNIC team, C); getopt
# upstream: https://gitlab.nic.cz/knot/knot-resolver

_knot-resolver() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a+[address[#port]]:str:' \
        '--addr=+[address[#port]]:str:' \
        '-t+[tls address]:str:' \
        '--tls=+[tls address]:str:' \
        '-q+[doq address]:str:' \
        '--quic=+[doq address]:str:' \
        '-S+[fd]:n:' \
        '--fd=+[fd]:n:' \
        '-T+[tls fd]:n:' \
        '--tlsfd=+[tls fd]:n:' \
        '-c+[control socket]:file:_files' \
        '--config=+[config file]:file:_files -g "*.conf *.lua"' \
        '-n[no interactive]' \
        '--noninteractive[no interactive]' \
        '-f+[forks]:n:' \
        '--forks=+[forks]:n:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-i[print configuration]' \
        '--info[print configuration]' \
        '-K+[tty]:str:' \
        '--keyfile=+[trust anchor file]:file:_files' \
        '*:rundir:_files -/'
}

_knot-resolver "$@"
