#compdef flux-config
# Documentation: https://flux-framework.readthedocs.io/projects/flux-core/en/latest/man1/flux-config.html
# query and manage Flux configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --default)'{-d,--default=}'[substitute value if name not set]:value' \
  '(-q --quiet)'{-q,--quiet}'[suppress errors if name not set]' \
  '(-t --type)'{-t,--type=}'[require value of specified type]:type' \
  '(-c --config-path)'{-c,--config-path=}'[read from path instead of broker]:path:_files' \
  '--intree[force return of in-tree paths]' \
  '--installed[force return of installed paths]' \
  '--follower-noop[do nothing if invoked on follower broker]' \
  '1:subcommand:(get set unset builtin load reload)' \
  '*::args:_default' && ret=0

return ret
