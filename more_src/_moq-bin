#compdef moq
# _moq-bin — Moq Go interface mock generator (Mat Ryer, Go); generate idiomatic Go mocks from interfaces
# upstream: https://github.com/matryer/moq

_moq-bin() {
    _arguments \
        '-out+[output file]:file:_files' \
        '-pkg+[mock package name]:name:' \
        '-fmt+[formatter]:fmt:(gofmt goimports noop)' \
        '-rm[remove generated file before running]' \
        '-skip-ensure[skip moq ensure-impl marker]' \
        '-stub[generate stub instead of mock]' \
        '-with-resets[include reset funcs]' \
        '-version[show version]' \
        '1:src dir:_files -/' \
        '*:interface name:'
}

_moq-bin "$@"
