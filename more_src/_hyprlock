#compdef hyprlock

# Zsh completion for hyprlock (Hyprland screen locker)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
  '--immediate[lock immediately without fade]' \
  '--immediate-render[render immediately]' \
  '--no-fade-in[disable fade-in animation]' \
  '--no-fade-out[disable fade-out animation]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
