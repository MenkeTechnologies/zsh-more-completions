#compdef swaks
# _swaks — John Jetmore swaks (Swiss-Army-Knife SMTP/ESMTP/LMTP test tool; Perl client for verifying SMTP servers, TLS, AUTH, PROXY/XCLIENT, PIPELINING, PRDR)
# upstream: https://github.com/jetmore/swaks
# Flags from get_option_struct in swaks on tip (Perl); 100+ flags — common subset enumerated.

_swaks() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--version[show version and exit]' \
        '(- *)--support[show compiled-in feature support]' \
        '--config=[config file]:file:_files' \
        '(-f --from)'{-f+,--from=}'[envelope MAIL FROM]:from:_email_addresses' \
        '(-t --to)'{-t+,--to=}'[envelope RCPT TO]:to:_email_addresses' \
        '--cc=[Cc: recipients (header + envelope)]:cc:_email_addresses' \
        '--bcc=[Bcc: recipients (envelope only)]:bcc:_email_addresses' \
        '(-h --helo --ehlo --lhlo)'{-h+,--helo=,--ehlo=,--lhlo=}'[HELO/EHLO/LHLO string]:host:_hosts' \
        '(-s --server)'{-s+,--server=}'[target server (host[:port])]:host:_hosts' \
        '-4[force IPv4]' \
        '-6[force IPv6]' \
        '--copy-routing=[copy MX routing from another domain]:domain:' \
        '(-p --port)'{-p+,--port=}'[target port]:port:' \
        '--protocol=[protocol]:proto:(SMTP ESMTP LMTP SSMTP SMTPS LMTPS)' \
        '(-d --data)'{-d+,--data=}'[message data (- = stdin, @file = file)]:data:' \
        '--dump-as-body=[use --dump text as default body]:text:' \
        '--dump-as-body-shows-password[do not hide passwords in --dump-as-body]' \
        '--timeout=[per-transaction timeout]:dur:' \
        '(-q --quit-after --quit)'{-q+,--quit-after=}'[force-quit after stage]:stage:(CONNECT BANNER FIRST-HELO HELO STARTTLS TLS XCLIENT AUTH MAIL RCPT DATA DOT)' \
        '--drop-after=[disconnect after stage (no QUIT)]:stage:(CONNECT BANNER FIRST-HELO HELO STARTTLS TLS XCLIENT AUTH MAIL RCPT DATA DOT)' \
        '--drop-after-send[disconnect after data send]' \
        '--dump[dump effective config and exit]' \
        '--dump-mail[dump constructed mail and exit]' \
        '--silent=[output level (0-3)]:n:(0 1 2 3)' \
        '*--add-header=[add a header (repeatable)]:hdr:' \
        '*--header=[set a header]:hdr:' \
        '--body=[message body (- = stdin, @file = file)]:body:' \
        '*'{-a+,--attach=}'[MIME attach (repeatable; - = stdin, @file = file)]:file:_files' \
        '--attach-body=[body of message when --attach is used]:body:' \
        '--attach-name=[filename for the next --attach]:name:' \
        '--attach-type=[Content-Type for the next --attach]:mime:' \
        '*--auth=[AUTH mechanism (CRAM-MD5 LOGIN PLAIN DIGEST-MD5 NTLM SPA SCRAM-SHA-1 SCRAM-SHA-256 SCRAM-SHA-512 EXTERNAL XOAUTH2)]:mech:(CRAM-MD5 LOGIN PLAIN DIGEST-MD5 NTLM SPA SCRAM-SHA-1 SCRAM-SHA-256 SCRAM-SHA-512 EXTERNAL XOAUTH2)' \
        '(-au --auth-user)'{-au+,--auth-user=}'[AUTH user]:user:' \
        '(-ap --auth-password)'{-ap+,--auth-password=}'[AUTH password]:pwd:' \
        '--auth-extra=[extra AUTH data]:str:' \
        '--auth-hide-password[mask password in transcript]' \
        '--auth-optional[try AUTH but allow failure]' \
        '--auth-optional-strict[as --auth-optional, fail on non-soft errors]' \
        '--auth-plaintext[allow PLAIN/LOGIN on cleartext]' \
        '--auth-map=[file mapping AUTH mech overrides]:file:_files' \
        '(-tls --tls)'{-tls,--tls}'[require STARTTLS]' \
        '--tls-on-connect[implicit TLS (smtps)]' \
        '(-tlso --tls-optional)'{-tlso,--tls-optional}'[try STARTTLS but allow failure]' \
        '(-tlsos --tls-optional-strict)'{-tlsos,--tls-optional-strict}'[as --tls-optional, fail on non-soft errors]' \
        '--tls-cert=[client cert file (PEM)]:file:_files' \
        '--tls-chain=[client cert+chain file]:file:_files' \
        '--tls-key=[client key file]:file:_files' \
        '--tls-cipher=[OpenSSL cipher string]:str:' \
        '--tls-ca-path=[CA bundle directory]:dir:_files -/' \
        '--tls-verify[verify peer cert + hostname]' \
        '--tls-verify-ca[verify peer cert chain]' \
        '--tls-verify-host[verify cert host]' \
        '--tls-verify-target=[expected SAN/CN]:name:' \
        '--tls-protocol=[TLS protocol]:proto:(SSLv3 TLSv1 TLSv1.1 TLSv1.2 TLSv1.3)' \
        '--tls-sni=[TLS SNI hostname]:sni:' \
        '--tls-get-peer-cert[show server cert]' \
        '--tls-get-peer-chain[show server cert chain]' \
        '(-li --local-interface)'{-li+,--local-interface=}'[bind local interface]:iface:_net_interfaces' \
        '(-lp --local-port --lport)'{-lp+,--local-port=,--lport=}'[bind local port]:port:' \
        '--socket=[connect via this Unix socket]:file:_files' \
        '--pipe=[pipe to this command instead of network]:cmd:' \
        '--pipeline[use PIPELINING]' \
        '--prdr[use PRDR]' \
        '--protect-prompt[mask interactively-prompted sensitive values]' \
        '--proxy=[proxy host[:port]]:host:_hosts' \
        '--proxy-command=[proxy command]:cmd:' \
        '--proxy-protocol=[PROXY protocol version]:proto:(1 2)' \
        '--proxy-version=[PROXY header version]:n:(1 2)' \
        '--proxy-family=[address family]:family:(inet inet6 unix)' \
        '--proxy-source=[PROXY source addr]:ip:' \
        '--proxy-source-port=[PROXY source port]:port:' \
        '--proxy-dest=[PROXY dest addr]:ip:' \
        '--proxy-dest-port=[PROXY dest port]:port:' \
        '--xclient[send XCLIENT command]' \
        '--xclient-after=[stage after which to send XCLIENT]:stage:' \
        '--xclient-before-starttls[send XCLIENT before STARTTLS]' \
        '--xclient-delim=[XCLIENT pair delimiter]:char:' \
        '--xclient-helo=[XCLIENT HELO]:host:_hosts' \
        '--xclient-name=[XCLIENT NAME]:host:_hosts' \
        '--xclient-reverse-name=[XCLIENT REVERSE_NAME]:host:_hosts' \
        '--xclient-addr=[XCLIENT ADDR]:ip:' \
        '--xclient-port=[XCLIENT PORT]:port:' \
        '--xclient-destaddr=[XCLIENT DESTADDR]:ip:' \
        '--xclient-destport=[XCLIENT DESTPORT]:port:' \
        '--xclient-login=[XCLIENT LOGIN]:user:' \
        '--xclient-proto=[XCLIENT PROTO]:str:' \
        '--xclient-no-verify[do not verify XCLIENT result]' \
        '--xclient-optional[allow XCLIENT to fail]' \
        '--xclient-optional-strict[as --xclient-optional, fail on non-soft]' \
        '--raw[no automatic header generation]' \
        '--show-raw-text[show raw text of session]' \
        '--show-time-lapse[show timing between stages]' \
        '--suppress-data[show DATA but suppress message body]' \
        '--no-data-fixup[do not auto-fix dot-stuffing]' \
        '--no-hints[suppress hint messages]' \
        '--no-info-hints[suppress info-level hints]' \
        '--no-receive-hints[suppress receive-side hints]' \
        '--no-send-hints[suppress send-side hints]' \
        '--no-strip-from[do not strip mbox From_ line from --data]' \
        '--output=[output mode]:mode:' \
        '--output-file=[mirror output to file]:file:_files' \
        '--output-file-stdout=[mirror stdout to file]:file:_files' \
        '--output-file-stderr=[mirror stderr to file]:file:_files' \
        '--hide-all[suppress all output]' \
        '--hide-informational[suppress info output]' \
        '--hide-receive[suppress receive output]' \
        '--hide-send[suppress send output]' \
        '--force-getpwuid[force getpwuid() lookup for sender]'
}

_swaks "$@"
