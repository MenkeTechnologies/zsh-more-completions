#compdef zstd-cli unzstd-cli zstdcat-cli
# _zstd-cli — Facebook Zstandard fast lossless compression CLI alias (facebook team, C); custom argparse
# upstream: https://github.com/facebook/zstd

_zstd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-H[full help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-d[decompression]' \
        '--decompress[decompression]' \
        '-z[force compression]' \
        '--compress[force compression]' \
        '-f[force overwrite]' \
        '--force[force overwrite]' \
        '-k[keep input files]' \
        '--keep[keep input files]' \
        '--rm[remove input after success]' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '-c[output to stdout]' \
        '--stdout[output to stdout]' \
        '-o+[output file]:file:_files' \
        '-l[print info]' \
        '--list[print info]' \
        '-q[suppress warnings]' \
        '--quiet[suppress warnings]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--ultra[allow level 20+]' \
        '--long=+[window log]:n:' \
        '--single-thread[single thread]' \
        '-T+[threads]:n:' \
        '--threads=+[threads]:n:' \
        '-M+[memory limit]:str:' \
        '--memory=+[memory limit]:str:' \
        '-B+[block size]:str:' \
        '--block-size=+[block size]:str:' \
        '--adapt[adaptive compression]' \
        '--adapt=+[min,max]:str:' \
        '--rsyncable[rsyncable]' \
        '-D+[dictionary]:file:_files' \
        '--train[train dictionary]' \
        '--maxdict=+[size]:n:' \
        '--dictID=+[id]:n:' \
        '--no-dictID[no dict ID]' \
        '--check[integrity check]' \
        '--no-check[no integrity check]' \
        '-t[test]' \
        '--test[test]' \
        '--no-progress[no progress]' \
        '-1[level 1]' \
        '-2[level 2]' \
        '-3[level 3]' \
        '-4[level 4]' \
        '-5[level 5]' \
        '-6[level 6]' \
        '-7[level 7]' \
        '-8[level 8]' \
        '-9[level 9]' \
        '-10[level 10]' \
        '-15[level 15]' \
        '-19[level 19]' \
        '-22[level 22]' \
        '--fast=+[neg level]:n:' \
        '--format=+[format]:f:(zstd gzip lzma xz lz4)' \
        '*:files:_files'
}

_zstd-cli "$@"
