#compdef shellspec

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--banner[show banner]' \
  '--no-banner[hide banner]' \
  '(-c --chdir)'{-c,--chdir}'[change directory]:directory:_directories' \
  '--color[enable color output]' \
  '--no-color[disable color output]' \
  '--covdir[coverage directory]:directory:_directories' \
  '--count[count examples]' \
  '--dryrun[dry run without executing]' \
  '(-e --env)'{-e,--env}'[set environment variable]:var=value' \
  '(-E --example)'{-E,--example}'[filter by example name]:pattern' \
  '--fail-fast[stop on first failure]:count' \
  '--failure-exit-code[exit code on failure]:code' \
  '(-f --format)'{-f,--format}'[output format]:format:(progress documentation tap junit)' \
  '--gen-bin[generate helper scripts]' \
  '--init[initialize project]' \
  '--jobs[number of parallel jobs]:jobs' \
  '--keep-tempdir[keep temporary directory]' \
  '--kcov[enable kcov coverage]' \
  '--kcov-options[kcov options]:options' \
  '--log-file[log file]:file:_files' \
  '--no-kcov[disable kcov coverage]' \
  '--output-fd[output file descriptor]:fd' \
  '(-P --pattern)'{-P,--pattern}'[file pattern]:pattern' \
  '--path[add to PATH]:directory:_directories' \
  '--prefix[filter by prefix]:prefix' \
  '--profile[enable profiling]' \
  '(-q --quick)'{-q,--quick}'[quick mode]' \
  '(-r --require)'{-r,--require}'[require helper]:helper' \
  '--random[randomize order]:seed' \
  '--reportdir[report directory]:directory:_directories' \
  '--seed[set random seed]:seed' \
  '--shell[shell to use]:shell:_command_names' \
  '--skip-message[show skip messages]:mode:(verbose moderate quiet)' \
  '(-t --tag)'{-t,--tag}'[filter by tag]:tag' \
  '--task[run a task]:task:(fixture:setup fixture:cleanup)' \
  '--tmpdir[temporary directory]:directory:_directories' \
  '--warning-as-failure[treat warnings as failures]' \
  '(-x --xtrace)'{-x,--xtrace}'[enable xtrace]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:spec file:_files' && ret=0
return ret
