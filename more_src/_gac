#compdef gac
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/gac.1.html
# GAP compiler: compile GAP/C source to loadable object files or a new kernel

local ret=1

_arguments -s -S \
  '(-c -d -C)-c[compile to statically loadable object files]' \
  '(-c -d -C)-d[compile to dynamically loadable object files]' \
  '(-c -d -C)-C[only compile to C code]' \
  '-r[treat statically compiled files as relative to GAP root]' \
  '-o[name the output file]:output file:_files' \
  '-ffast-int-arith[emit faster code when both operands are small integers]' \
  '-ffast-plain-lists[emit faster list access for plain lists]' \
  '-ffast-list-funcs[inline the functions Add and Length]' \
  '-fno-check-types[emit no error checks for list access]' \
  '*-p[pass option to the C compiler]:cc option' \
  '*-P[pass option to the C linker]:linker option' \
  '*:input file:_files -g "*.(g|gap|c|o)"' && ret=0

return ret
