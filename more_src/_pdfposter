#compdef pdfposter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-v,--verbose}'[verbose output]' \
  {-n,--dry-run}'[do not write output]' \
  {-i+,--media-size=}'[input page size]:size:' \
  {-m+,--media-size-out=}'[output page size]:size:' \
  {-p+,--poster-size=}'[poster size]:size:' \
  {-s+,--scale=}'[scale factor]:factor:' \
  '*:PDF file:_files -g "*.pdf"' && ret=0

return ret
