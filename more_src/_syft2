#compdef syft2
# _syft2 — Anchore syft2 CLI command-line frontend wrapping the Syft CLI tool and Go library for generating a Software Bill of Materials SBOM from container images and filesystems open-source written in Go SBOM generates SBOMs for container images filesystems archives and more to discover packages and dependencies output in SPDX SPDX-JSON CycloneDX CycloneDX-JSON GitHub-JSON Syft-JSON Syft-table Syft-text formats catalogers configurable scope override exclude packages dirs OCI-image-tar OCI-dir docker-archive docker-daemon file file-dir-mode (Anchore team, Go); cobra
# upstream: https://github.com/anchore/syft

_syft2() {
    local -a sub=(
        'attest:generate signed SBOM attestation'
        'config:show config'
        'completion:generate shell completion'
        'convert:convert SBOM format'
        'login:login to registry'
        'packages:scan packages'
        'scan:scan an image'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g ".syft.yaml *.yaml *.yml"' \
        '--config=+[file]:file:_files -g ".syft.yaml *.yaml *.yml"' \
        '-o+[output format]:f:(syft-json syft-text syft-table github-json cyclonedx-xml cyclonedx-xml@1.4 cyclonedx-xml@1.5 cyclonedx-xml@1.6 cyclonedx-json cyclonedx-json@1.4 cyclonedx-json@1.5 cyclonedx-json@1.6 spdx-json spdx-tag-value spdx-tv spdx-tv@2.1 spdx-tv@2.2 spdx-tv@2.3 spdx-json@2.2 spdx-json@2.3 template)' \
        '--output=+[fmt]:str:' \
        '*-o+[output format]:str:' \
        '-s+[scope]:s:(squashed all-layers)' \
        '--scope=+[s]:s:(squashed all-layers)' \
        '-t+[template]:file:_files -g "*.tmpl"' \
        '--template=+[t]:file:_files -g "*.tmpl"' \
        '--file=+[file]:file:_files' \
        '--exclude=+[paths]:str:' \
        '*--exclude=+[paths]:str:' \
        '--name=+[name]:str:' \
        '--source-name=+[name]:str:' \
        '--source-version=+[v]:str:' \
        '--source-supplier=+[s]:str:' \
        '--catalogers=+[mods]:str:' \
        '--select-catalogers=+[mods]:str:' \
        '--default-catalogers=+[mods]:str:' \
        '--override-default-catalogers=+[mods]:str:' \
        '--platform=+[os/arch]:str:' \
        '--from=+[s]:s:(docker oci-archive oci-dir docker-archive registry file dir podman containerd singularity)' \
        '--base-path=+[path]:_files' \
        '--enrich=+[e]:e:(all java javascript ruby python all none)' \
        '*--enrich=+[e]:e:(all java javascript ruby python)' \
        '--key=+[key]:str:' \
        '--key-password=+[password]:str:' \
        '--registry-token=+[token]:str:' \
        '--registry-auth=+[u:p]:str:' \
        '*--registry-auth=+[u:p]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'syft subcommand' sub ;;
        args)
            case $words[1] in
                scan|packages|attest) _arguments '*:image:' ;;
                convert) _arguments '*:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_syft2 "$@"
