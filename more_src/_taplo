#compdef taplo
# Zsh completion for Taplo
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--colors[colorize output]:mode:(auto always never)' \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'format:format TOML files'
      'fmt:format TOML files'
      'lint:lint TOML files'
      'check:check TOML files for syntax errors'
      'get:get a value from a TOML file'
      'lsp:start the language server'
    )
    _describe -t commands 'taplo command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      format|fmt)
        _arguments -s -S \
          '*'{-o,--option}'[formatter option]:key=value:' \
          '(-c --config)'{-c,--config}'[config file]:file:_files' \
          '--cache-path[cache directory]:dir:_directories' \
          '--check[check formatting without modifying files]' \
          '--force[force formatting even if ignored]' \
          '--diff[show diff of formatting changes]' \
          '--stdin-filepath[file path for stdin input]:path:_files' \
          '--colors[colorize output]:mode:(auto always never)' \
          '(- *)'{-h,--help}'[show help message]' \
          '*:file:_files' && ret=0
        ;;
      lint)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[config file]:file:_files' \
          '--cache-path[cache directory]:dir:_directories' \
          '--default-schema-catalogs[use default schema catalogs]' \
          '--no-schema[disable schema validation]' \
          '--schema[schema URL]:url:_urls' \
          '--colors[colorize output]:mode:(auto always never)' \
          '(- *)'{-h,--help}'[show help message]' \
          '*:file:_files' && ret=0
        ;;
      check)
        _arguments -s -S \
          '--colors[colorize output]:mode:(auto always never)' \
          '(- *)'{-h,--help}'[show help message]' \
          '*:file:_files' && ret=0
        ;;
      get)
        _arguments -s -S \
          '(-f --file-path)'{-f,--file-path}'[TOML file path]:file:_files' \
          '(-o --output-format)'{-o,--output-format}'[output format]:format:(value json toml)' \
          '--colors[colorize output]:mode:(auto always never)' \
          '(- *)'{-h,--help}'[show help message]' \
          '1:key:' && ret=0
        ;;
      lsp)
        _arguments -s -S \
          '--colors[colorize output]:mode:(auto always never)' \
          '(- *)'{-h,--help}'[show help message]' && ret=0
        ;;
    esac
    ;;
esac
return ret
