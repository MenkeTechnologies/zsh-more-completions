#compdef mysql-router-passwd mysqlrouter_passwd
# Documentation: https://dev.mysql.com/doc/mysql-router/8.4/en/mysqlrouter_passwd.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mysqlrouter_passwd: manage MySQL Router REST API passwd accounts
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'delete:delete username from passwd file'
  'list:list accounts in passwd file'
  'set:add or overwrite account'
  'verify:verify password against credentials'
)
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--kdf=[Key Derivation Function for set]:kdf:(pbkdf2-sha256 pbkdf2-sha512 sha256-crypt sha512-crypt)' \
  '--work-factor=[KDF work-factor hint]:n:' \
  '1: :->cmd' \
  '2:passwd file:_files' \
  '3:username:' && ret=0
case $state in
  cmd) _describe -t commands 'mysqlrouter_passwd command' commands && ret=0 ;;
esac
return ret
