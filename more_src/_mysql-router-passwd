#compdef mysql-router-passwd

# mysql-router-passwd: manage MySQL Router credentials/keyring
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'get:get a password'
  'set:set a password'
  'delete:delete a password'
  'list:list stored credentials'
  'verify:verify a password'
  'export:export keyring'
  'rotate:rotate master key'
)
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '--master-key-reader=[master key reader]:cmd:' \
  '--master-key-writer=[master key writer]:cmd:' \
  '--keyring-file=[keyring file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mysql-router-passwd command' commands && ret=0 ;;
esac
return ret
