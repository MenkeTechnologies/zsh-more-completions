#compdef gauplus
# _gauplus — bp0lr gauplus rewrite of gau in Go pulls URLs from Wayback Common Crawl Otx URLScan (bp0lr team, Go); standard flag package
# upstream: https://github.com/bp0lr/gauplus

_gauplus() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-v[verbose]' \
        '-providers+[providers csv]:str:' \
        '-blacklist+[extensions blacklist]:str:' \
        '-subs[include subdomains]' \
        '-fp[fetch parameters]' \
        '-o+[output file]:file:_files' \
        '-output+[output file]:file:_files' \
        '-from+[from date YYYYMM]:str:' \
        '-to+[to date YYYYMM]:str:' \
        '-t+[threads]:n:' \
        '-threads+[threads]:n:' \
        '-random-agent[random user agent]' \
        '-p+[proxy URL]:url:_urls' \
        '-proxy+[proxy URL]:url:_urls' \
        '-r+[max retries]:n:' \
        '-retries+[max retries]:n:' \
        '-timeout+[timeout sec]:n:' \
        '-mc+[match codes csv]:str:' \
        '-json[output json]' \
        '-config+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '-o-l+[limit output urls]:n:' \
        '-limit+[limit output urls]:n:' \
        '-silent[silent]' \
        '*:domain:_hosts'
}

_gauplus "$@"
