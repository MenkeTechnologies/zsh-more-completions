#compdef cbonsai

# Zsh completion for cbonsai (terminal bonsai tree generator)

_arguments -s -S \
  '-h[Show help]' \
  '--help[Show help]' \
  '-v[Show version]' \
  '--version[Show version]' \
  '-l[Enable live mode (watch tree grow)]' \
  '--live[Enable live mode (watch tree grow)]' \
  '-t+[Set time step for live mode (seconds)]:time:' \
  '--time=[Set time step for live mode (seconds)]:time:' \
  '-i[Enable infinite mode (keep growing)]' \
  '--infinite[Enable infinite mode (keep growing)]' \
  '-w+[Wait time between trees in infinite mode]:seconds:' \
  '--wait=[Wait time between trees in infinite mode]:seconds:' \
  '-S+[Set initial RNG seed]:seed:' \
  '--seed=[Set initial RNG seed]:seed:' \
  '-W+[Set window width for base]:width:' \
  '--base-width=[Set window width for base]:width:' \
  '-m+[Set message to display]:message:' \
  '--message=[Set message to display]:message:' \
  '-b+[Set base type]:type:(0 1 2)' \
  '--base=[Set base type]:type:(0 1 2)' \
  '-c+[Set leaf character]:character:' \
  '--leaf=[Set leaf character]:character:' \
  '-M+[Set multiplier for branch growth]:multiplier:' \
  '--multiplier=[Set multiplier for branch growth]:multiplier:' \
  '-L+[Set number of life cycles]:life:' \
  '--life=[Set number of life cycles]:life:' \
  '-p[Print tree to stdout then exit]' \
  '--print[Print tree to stdout then exit]' \
  '-s[Enable screensaver mode]' \
  '--screensaver[Enable screensaver mode]' && return 0
