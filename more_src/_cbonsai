#compdef cbonsai
# Documentation: https://gitlab.com/jallbrit/cbonsai
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for cbonsai (terminal bonsai tree generator)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-l --live)'{-l,--live}'[live mode: show growth animation]' \
  '(-t --time)'{-t+,--time=}'[seconds between growth steps]:seconds:' \
  '(-i --infinite)'{-i,--infinite}'[infinite mode: keep generating trees]' \
  '(-w --wait)'{-w+,--wait=}'[seconds between trees in infinite mode]:seconds:' \
  '(-s --seed)'{-s+,--seed=}'[random seed]:seed:' \
  '(-S --screensaver)'{-S,--screensaver}'[screensaver mode (live + infinite)]' \
  '(-m --message)'{-m+,--message=}'[message displayed next to the tree]:text:' \
  '(-b --base)'{-b+,--base=}'[base style]:type:(0 1 2)' \
  '(-c --leaf)'{-c+,--leaf=}'[leaf characters (comma-separated)]:chars:' \
  '(-M --multiplier)'{-M+,--multiplier=}'[branch multiplier (0-20, default 5)]:n:' \
  '(-L --life)'{-L+,--life=}'[life (0-200, default 32)]:n:' \
  '(-p --print)'{-p,--print}'[print tree once then exit]' \
  '(-W --save)'{-W+,--save=}'[save progress to file]:file:_files' \
  '(-C --load)'{-C+,--load=}'[load progress from file]:file:_files' \
  && return 0
