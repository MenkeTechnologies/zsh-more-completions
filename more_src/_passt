#compdef passt pasta
# _passt — Stefano Brivio passt user-mode TCP/IP virtualization CLI for unprivileged hypervisor-bypass network connectivity passt for VMs pasta for namespaces forwarding all traffic over UNIX-domain socket (KVMforum team, C); getopt
# upstream: https://passt.top/

_passt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-l+[log file]:file:_files' \
        '--log-file=+[log file]:file:_files' \
        '-i+[ifname]:str:' \
        '--interface=+[ifname]:str:' \
        '-s+[unix socket]:file:_files' \
        '--socket=+[unix socket]:file:_files' \
        '-p+[pcap file]:file:_files -g "*.pcap *.cap *.pcapng"' \
        '--pcap=+[pcap file]:file:_files -g "*.pcap *.cap *.pcapng"' \
        '-P+[pid file]:file:_files' \
        '--pid=+[pid file]:file:_files' \
        '-F+[fd]:n:' \
        '--fd=+[fd]:n:' \
        '-t+[tcp ports]:str:' \
        '--tcp-ports=+[tcp ports]:str:' \
        '-u+[udp ports]:str:' \
        '--udp-ports=+[udp ports]:str:' \
        '-T+[tcp ports]:str:' \
        '--tcp-ns=+[tcp ports]:str:' \
        '-U+[udp ports]:str:' \
        '--udp-ns=+[udp ports]:str:' \
        '-D+[DNS server csv]:str:' \
        '--dns=+[DNS server csv]:str:' \
        '-N+[NS server csv]:str:' \
        '--nameserver=+[NS server csv]:str:' \
        '-S+[search domain csv]:str:' \
        '--search=+[search domain csv]:str:' \
        '-M+[MTU]:n:' \
        '--mtu=+[MTU]:n:' \
        '-a+[gateway IPv4]:str:' \
        '--gateway4=+[gateway IPv4]:str:' \
        '-6+[gateway IPv6]:str:' \
        '--gateway6=+[gateway IPv6]:str:' \
        '-4[IPv4 only]' \
        '--ipv4-only[IPv4 only]' \
        '--ipv6-only[IPv6 only]' \
        '-n[no map gateway]' \
        '--no-map-gw[no map gateway]' \
        '-Q+[mapped TCP ports]:str:' \
        '--quiet[quiet]' \
        '--config-net[configure netns]' \
        '--ns-mac-addr=+[mac]:str:' \
        '--ns-conf=+[conf]:str:' \
        '--no-ndp[no NDP]' \
        '--no-tcp[no TCP]' \
        '--no-udp[no UDP]' \
        '--no-icmp[no ICMP]' \
        '--no-dhcp[no DHCP]' \
        '--no-dhcpv6[no DHCPv6]' \
        '--no-ra[no RA]' \
        '--foreground[foreground]' \
        '-f[foreground]' \
        '--trace[trace]'
}

_passt "$@"
