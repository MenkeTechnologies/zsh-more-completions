#compdef advcp advmv
# Documentation: https://github.com/jarun/advcpmv
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_advcp() {
    local -a args
    args=(
        '(-g --progress)'{-g,--progress}'[Show progress bar]'
        '(-a --archive)'{-a,--archive}'[Archive mode]'
        '(-b --backup)'{-b,--backup}'[Make backups]'
        '(-f --force)'{-f,--force}'[Force overwrite]'
        '(-i --interactive)'{-i,--interactive}'[Prompt before overwrite]'
        '(-l --link)'{-l,--link}'[Link files instead of copying]'
        '(-p --preserve)'{-p,--preserve}'[Preserve attributes]'
        '(-R -r --recursive)'{-R,-r,--recursive}'[Copy directories recursively]'
        '(-s --symbolic-link)'{-s,--symbolic-link}'[Make symbolic links instead of copying]'
        '(-u --update)'{-u,--update}'[Copy only when the SOURCE file is newer]'
        '(-v --verbose)'{-v,--verbose}'[Explain what is being done]'
        '--help[Display help]'
        '--version[Output version info]'
        '*:files:_files'
    )

    _arguments -s -S $args
}

_advcp "$@"
