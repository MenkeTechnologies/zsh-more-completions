#compdef crunch-attack
# _crunch-attack — crunch wordlist generator CLI alias (crunch-wordlist team, C); custom argparse
# upstream: https://github.com/crunchsec/crunch

_crunch-attack() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-b+[break output by size]:str:' \
        '-c+[break by line count]:n:' \
        '-d+[delimiter]:str:' \
        '-e+[end string]:str:' \
        '-f+[char file:set]:str:' \
        '-i[invert output]' \
        '-l+[literal chars]:str:' \
        '-m[multiply]' \
        '-o+[output file]:file:_files' \
        '-p+[permutation]:str:' \
        '-q+[wordlist file]:file:_files' \
        '-r[resume]' \
        '-s+[start string]:str:' \
        '-t+[pattern]:str:' \
        '-u[uppercase mode disabled]' \
        '-z+[compression]:c:(gzip bzip2 lzma 7z)' \
        '1:min length:' \
        '2:max length:' \
        '3:character set:'
}

_crunch-attack "$@"
