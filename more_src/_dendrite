#compdef dendrite
# Documentation: https://man.archlinux.org/search?q=dendrite
# Reference accessed: 2026-05-16

_arguments -s \
  '--config=[config file]:file:_files -g "*.(yaml|yml)"' \
  '--really-enable-open-registration[enable open registration (dangerous)]' \
  '--http-bind-address=[HTTP bind address]:addr:' \
  '--https-bind-address=[HTTPS bind address]:addr:' \
  '--tls-cert=[TLS certificate]:file:_files' \
  '--tls-key=[TLS private key]:file:_files' \
  '--unix-socket=[unix socket path]:file:_files' \
  '--unix-socket-permission=[unix socket perms]:perm:' \
  '(- *)--version[show version]'
