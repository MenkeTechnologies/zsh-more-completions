#compdef exifcom
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/exifcom.1.html
# Display or set the UserComment tag contained in a JPEG Exif section

local ret=1

_arguments -s -S \
  '-b[blank the UserComment tag]' \
  '-f[overwrite/blank without prompting]' \
  '-i[prompt before overwriting/blanking (default)]' \
  '-n[do not overwrite/blank existing comments]' \
  '-s+[field/value separator string]:delim' \
  '-v[verbose output of UserComment contents]' \
  '-w+[set UserComment to ASCII string]:comment' \
  '*:JPEG file:_files -g "*.(jpg|jpeg|JPG|JPEG)"' && ret=0

return ret
