#compdef chef-client
# Documentation: https://docs.chef.io/ctl_chef_client/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (chef-web-docs content/client/19/reference/ctl_chef_client.md).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-A --fatal-windows-admin-check)'{-A,--fatal-windows-admin-check}'[fail if chef-client lacks Windows admin privileges]' \
  '(-c --config)'{-c,--config}'+[config file path]:config:_files -g "*.rb(-.)"' \
  '*--config-option+[override a single config option]:option:' \
  '--chef-zero-host+[host for chef-zero local mode]:host:_hosts' \
  '--chef-zero-port+[port for chef-zero local mode]:port:' \
  '(-d --daemonize)'{-d,--daemonize}'+[run as a daemon with optional wait seconds]:seconds:' \
  '--delete-entire-chef-repo[delete entire repo (local-mode + recipe-url only)]' \
  '--disable-config[run with default settings, ignore client.rb]' \
  '(-E --environment)'{-E,--environment}'+[set the Chef environment]:environment:' \
  '(-f --fork --no-fork)'{-f,--fork,--no-fork}'[fork (or do not fork) into a secondary process]' \
  '(-F --format)'{-F,--format}'+[output format]:format:(doc text min summary null)' \
  '--force-formatter[show formatter output instead of logger]' \
  '--force-logger[show logger output instead of formatter]' \
  '(-g --group)'{-g,--group}'+[group to set privilege to]:group:_groups' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --interval)'{-i,--interval}'+[run interval in seconds]:seconds:' \
  '(-j --json-attributes)'{-j,--json-attributes}'+[JSON file with first-run attributes]:file:_files -g "*.json(-.)"' \
  '(-k --client_key)'{-k,--client_key}'+[client key file]:key file:_files -g "*.pem(-.)"' \
  '(-K --validation_key)'{-K,--validation_key}'+[validation key file]:key file:_files -g "*.pem(-.)"' \
  '(-l --log_level)'{-l,--log_level}'+[log level]:level:(auto trace debug info warn error fatal)' \
  '(-L --logfile)'{-L,--logfile}'+[log file location]:file:_files' \
  '--lockfile+[lockfile location]:file:_files' \
  '--minimal-ohai[run only minimum Ohai plugins]' \
  '(--color --no-color)--color[colored output]' \
  '(--color --no-color)--no-color[disable colored output]' \
  '(--fips --no-fips)--fips[enforce FIPS-validated security]' \
  '(--fips --no-fips)--no-fips[disable FIPS]' \
  '(--listen --no-listen)--listen[run chef-zero with socket]' \
  '(--listen --no-listen)--no-listen[run chef-zero socketless (default 13.1+)]' \
  '(--skip-cookbook-sync --no-skip-cookbook-sync)--skip-cookbook-sync[use cached cookbooks without sync]' \
  '(--skip-cookbook-sync --no-skip-cookbook-sync)--no-skip-cookbook-sync[sync cookbooks normally]' \
  '(-n --named-run-list)'{-n,--named-run-list}'+[named run list from Policyfile]:run list:' \
  '(-N --node-name)'{-N,--node-name}'+[node name]:name:' \
  '(-o --override-runlist)'{-o,--override-runlist}'+[replace run list for this run only]:run list:' \
  '--once[run once and cancel interval/splay]' \
  '(-P --pid)'{-P,--pid}'+[PID file location]:file:_files' \
  '--profile-ruby[dump complete Ruby call graph]' \
  '--recipe-url+[URL to fetch recipes from (local-mode only)]:URL:_urls' \
  '--run-lock-timeout+[seconds to wait for lock file deletion]:seconds:' \
  '(-r --runlist)'{-r,--runlist}'+[permanently replace run list]:run list:' \
  '(-R --enable-reporting)'{-R,--enable-reporting}'[enable reporting data collection]' \
  '(-s --splay)'{-s,--splay}'+[random splay seconds added to interval]:seconds:' \
  '(-S --server)'{-S,--server}'+[Chef Infra Server URL]:URL:_urls' \
  '(-u --user)'{-u,--user}'+[user to set privilege to]:user:_users' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-W --why-run)'{-W,--why-run}'[run in why-run mode]' \
  '(-z --local-mode)'{-z,--local-mode}'[run in local mode]' && ret=0

return ret
