#compdef chef-client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-A --fatal-windows-admin-check)'{-A,--fatal-windows-admin-check}'[fail if not elevated on Windows]' \
  '(-c --config)'{-c,--config}'+[config file path]:config:_files -g "*.rb(-.)"' \
  '(-d --daemonize)'{-d,--daemonize}'[run as a daemon]' \
  '(-E --environment)'{-E,--environment}'+[set the Chef environment]:environment:' \
  '(-f --fork)'{-f,--fork}'[fork a child process for the chef-client run]' \
  '(-F --format)'{-F,--format}'+[output format]:format:(summary text doc min)' \
  '--force-formatter[use formatter output instead of logger]' \
  '--force-logger[use logger output instead of formatter]' \
  '(-g --group)'{-g,--group}'+[group to set privilege to]:group:_groups' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --interval)'{-i,--interval}'+[run interval in seconds]:seconds:' \
  '(-j --json-attributes)'{-j,--json-attributes}'+[JSON file with first-run attributes]:file:_files -g "*.json(-.)"' \
  '(-k --client_key)'{-k,--client_key}'+[client key file]:key file:_files -g "*.pem(-.)"' \
  '(-K --validation_key)'{-K,--validation_key}'+[validation key file]:key file:_files -g "*.pem(-.)"' \
  '(-l --log_level)'{-l,--log_level}'+[log level]:level:(auto trace debug info warn error fatal)' \
  '(-L --logfile)'{-L,--logfile}'+[log file location]:file:_files' \
  '--lockfile+[lockfile location]:file:_files' \
  '--minimal-ohai[only run minimum Ohai plugins]' \
  '--named-run-list+[run specific named run list]:run list:' \
  '--no-color[disable color output]' \
  '(-N --node-name)'{-N,--node-name}'+[node name]:name:' \
  '(-o --override-runlist)'{-o,--override-runlist}'+[replace run list]:run list:' \
  '--once[run chef-client once and exit]' \
  '(-P --pid)'{-P,--pid}'+[PID file location]:file:_files' \
  '--profile-ruby[dump complete Ruby call graph]' \
  '(-r --runlist)'{-r,--runlist}'+[replace run list]:run list:' \
  '-R+[number of times to retry]:count:' \
  '(-s --splay)'{-s,--splay}'+[random splay time added to interval]:seconds:' \
  '(-S --server)'{-S,--server}'+[Chef Infra Server URL]:URL:_urls' \
  '(-u --user)'{-u,--user}'+[user to set privilege to]:user:_users' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-W[run in why-run mode]' \
  '(-z --local-mode)'{-z,--local-mode}'[run chef-client in local mode]' \
  '--chef-zero-host+[host for local mode]:host:_hosts' \
  '--chef-zero-port+[port for local mode]:port:' \
  '--recipe-url+[URL to fetch recipes from]:URL:_urls' \
  '--chef-license+[accept license]:action:(accept accept-no-persist accept-silent)' && ret=0

return ret
