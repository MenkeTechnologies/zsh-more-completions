#compdef urxvtc urxvtcd
# _urxvtc — rxvt-unicode client (asks urxvtd to spawn a new terminal frame; forwards almost all urxvt X-resource flags (font/colors/title/geometry/-e command) to the daemon; -k tells the daemon to exit; urxvtcd auto-starts urxvtd if missing)
# upstream: https://sources.debian.org/src/rxvt-unicode (urxvtc.C)
# Flags from rxvt-unicode src/urxvtc.C on tip.

_urxvtc() {
    _arguments \
        '-help[show help]' \
        '-k[ask daemon to exit]' \
        '-display+[X display]:display:' \
        '-fn+[font]:font:' \
        '-fb+[bold font]:font:' \
        '-fi+[italic font]:font:' \
        '-fbi+[bold italic font]:font:' \
        '-name+[window name]:name:' \
        '-title+[window title]:title:' \
        '-geometry+[WxH+X+Y]:geom:' \
        '-bg+[background color]:color:' \
        '-fg+[foreground color]:color:' \
        '-cr+[cursor color]:color:' \
        '-pe+[Perl extensions]:exts:' \
        '-keysym.+[key=binding]:binding:' \
        '-e[run command]' \
        '*::command:_command_names -e'
}

_urxvtc "$@"
