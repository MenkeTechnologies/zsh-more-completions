#compdef recce
# Documentation: https://docs.reccehq.com/using-recce/cli-commands/
# Recce - data-validation toolkit for dbt PR review (server, run, summary, debug)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--session-id=[session identifier]:id' \
  '--review=[launch review mode from a state file]:file:_files' \
  '--port=[server port]:port' \
  '--api-token=[Recce Cloud API token]:token' \
  '--state-file=[recce state file]:file:_files' \
  '--github-pull-request-url=[GitHub pull request URL]:url' \
  '--cloud[use Recce Cloud]' \
  '1:command:(server run summary debug)' \
  '*::arg:->args' && ret=0

return ret
