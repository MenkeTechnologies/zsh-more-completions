#compdef alinea
# ============================================================================
#  _alinea — Alinea CMS: TypeScript-first content management system
#            (alineacms/alinea)
#
#  Source-direct extraction from
#    https://github.com/alineacms/alinea/blob/main/src/cli/bin.ts
#    https://github.com/alineacms/alinea/blob/main/dev.js
#    https://github.com/lukeed/sade (the sade CLI library by Luke
#    Edwards)
#
#  Maintained by the Alinea CMS team (alineacms/alinea).  849 GH
#  stars.  Alinea is a TypeScript-FIRST headless content management
#  system — defines content schemas in TypeScript, provides a real-
#  time collaborative dashboard, generates type-safe content APIs,
#  and integrates with Next.js / SvelteKit / Astro / Vite SPAs.
#  Stores content in JSON files in your repo (Git-versioned content)
#  with optional Postgres/SQLite backend for collaborative editing.
#  Sister tools: Sanity (commercial headless CMS), Strapi (Node.js
#  CMS, IN CORPUS via _strapi-cli), Contentful (commercial), Payload
#  CMS, Tina CMS, Decap CMS (formerly Netlify CMS), Hygraph.
#
#  CLI library taxonomy update: 6th TypeScript-Node CLI library —
#  Luke Edwards's **sade** (lukeed/sade).  TypeScript-Node ecosystem
#  now has 6 documented CLI libraries (R340 oclif + R341 yargs + R343
#  tj/commander.js + R393 meow + R395 node:util.parseArgs + R396
#  sade) — TIED FOR SECOND-MOST-DOCUMENTED CLI LANGUAGE with Python
#  (6), Crystal (6), and OCaml (6), behind Rust/Go (9).
#
#  sade (lukeed/sade) is Luke Edwards's "smooth (CLI) operator" —
#  TINY (~5KB minified, no deps) Node.js CLI framework with
#  commander.js-style fluent builder API.  Designed for small CLI
#  tools that need subcommands + option parsing + help generation
#  without commander's 30KB footprint.  Used by SvelteKit
#  (sveltejs/kit 20546 stars — uses sade for `svelte-package`),
#  Alinea CMS (849 stars), microbundle (developit/microbundle 8135
#  stars, IN CORPUS via _microbundle — Jason Miller's tiny bundler),
#  web3-storage/web3.storage (503 stars — IPFS/Filecoin storage),
#  nft.storage (NFT Storage), w3 CLI (web3.storage CLI), pail
#  storage, gfmjs, cardex, brode, evidence-dev, cloudflare privacypass,
#  plone volto, and many smaller Node.js CLI tools that want a
#  COMMANDER-LIKE API in a smaller package.
#
#  sade API:
#    import sade from 'sade';
#
#    const prog = sade('mytool');  // multi-command mode
#    // or: sade('mytool [src] [dest]', true);  // single-command mode
#
#    prog
#      .version('1.0.0')
#      .describe('My CLI tool')
#
#      .command('build [output]')
#      .alias('bundle')
#      .describe('Build the project')
#      .example('build dist/')
#      .option('-w, --watch', 'Watch for changes', false)
#      .option('-c, --config', 'Config file', 'config.json')
#      .option('--mode', 'Build mode', 'production')
#      .action((output, opts) => {
#        console.log(output, opts.watch, opts.config);
#      })
#
#      .command('serve <port>')
#      .describe('Start server')
#      .option('-h, --host', 'Bind hostname', 'localhost')
#      .action((port, opts) => {
#        console.log(`Serving on ${opts.host}:${port}`);
#      });
#
#    prog.parse(process.argv);
#
#  sade distinctive features:
#    - TINY ~5KB MINIFIED — zero npm dependencies (vs commander's ~30KB,
#      yargs's much larger)
#    - COMMANDER.JS-LIKE API — fluent chained builder pattern
#    - `sade('name')` — create program (multi-command mode)
#    - `sade('name [arg]', true)` — single-command mode (second arg
#      `true`); arg pattern with `[optional]` and `<required>` syntax
#    - `.version(STR)` — set --version output (auto-adds `--version`/`-v`)
#    - `.describe(STR)` — set program description (for --help)
#    - `.command(PATTERN)` — define SUBCOMMAND; PATTERN can include
#      `<required>` and `[optional]` positional args (e.g.
#      `'build [output]'` accepts an optional output arg)
#    - `.alias(NAME[, NAME])` — define subcommand alias (multi-arg)
#    - `.describe(STR)` — describe current subcommand
#    - `.example(STR)` — add example to current subcommand
#    - `.option('-s, --long', 'description', defaultValue)` — define
#      option for current subcommand (or top-level when no .command()
#      yet called)
#    - `.action(callback)` — define handler for current subcommand;
#      callback receives positional args followed by an options object
#      (e.g. for `build [output]`: `(output, opts) => { ... }`)
#    - `.parse(process.argv, OPTS?)` — PARSE ENTRY; OPTS can include
#      `{ unknown: callback }` for unknown-option handler, `{ lazy:
#      true }` for return-but-not-call mode
#    - POSITIONAL ARG PATTERNS — `<required>` for required positionals,
#      `[optional]` for optional; first positional matches first arg,
#      etc. (mirror of commander.js convention)
#    - AUTO-GENERATED `--help`/`-h` — sade auto-generates help text
#      from .describe/.example/.option declarations
#    - AUTO-GENERATED `--version`/`-v` — when .version() called
#    - AUTOMATIC kebab-to-camel — `--my-flag` → `opts.myFlag`
#      automatically (CamelCase result keys)
#    - PROCESS EXIT model — sade calls process.exit on unknown
#      subcommands and help/version output; caller controls in
#      handlers via their own process.exit
#    - DEFAULT EXPORT — `import sade from 'sade'` (ESM); also
#      `const sade = require('sade')` (CommonJS)
#    - ZERO DEPENDENCIES — pure JS implementation, no transitive npm
#      packages
#  Distinct from R340 TypeScript-Node oclif (Salesforce's CLI
#  framework with plugin system + `@Command` class + `flags = {}`
#  static prop — much heavier framework), R341 TypeScript-Node yargs
#  (Node.js fluent builder via `.option('name', {})` / `.command('cmd',
#  desc, builder, handler)` chains — different chaining style and
#  heavier than sade), R343 TypeScript-Node tj/commander.js (Node.js
#  fluent builder by TJ Holowaychuk — CLOSEST concept analog with
#  similar `.command(pattern)` / `.option('-s, --long', 'desc')` /
#  `.action(handler)` API; sade is essentially a TINY commander.js
#  alternative), R393 TypeScript-Node meow (Sindre Sorhus's CLI
#  helper — different USAGE-STRING-AS-HELP-TEXT philosophy + flags
#  schema), R395 node:util.parseArgs (Node.js stdlib — much lower-level,
#  no subcommands, no fluent API).  sade's approach: TINY (~5KB)
#  zero-dependency Node.js CLI framework + COMMANDER.JS-LIKE fluent
#  builder API + `sade('name')` for multi-command / `sade('name', true)`
#  for single-command + `.version`/`.describe`/`.command(pattern)`/
#  `.alias`/`.option('-s, --long', 'desc', default)`/`.action(handler)`
#  CHAINED BUILDER + POSITIONAL ARG PATTERNS `<required>` and `[optional]`
#  + AUTO-GENERATED `--help`/`--version` + AUTOMATIC kebab-to-camel
#  conversion + ZERO DEPENDENCIES — corpus's **first documented tiny-
#  commander-alternative Node.js CLI library**.  Brings cross-language
#  CLI library taxonomy variant count to 135; TypeScript-Node
#  ecosystem now has 6 documented CLI libraries — TIED FOR SECOND-
#  MOST-DOCUMENTED CLI LANGUAGE with Python (6), Crystal (6), and
#  OCaml (6), behind Rust/Go (9).
#
#  Surface (verbatim from `src/cli/bin.ts` sade chained builder):
#
#  Global:
#    -v, --version                  Print version
#
#  Subcommands:
#    init                           Initialize new Alinea project in
#                                   current directory
#
#    dev / serve                    Start development dashboard
#      -c, --config FILE            Config file location
#      -d, --dir DIR                Root directory of project
#      -p, --port PORT              Port to listen on
#      -b, --base URL               Base URL for previews
#          --production             Use production backend
#          --dev                    Watch alinea sources
#
#    build / generate               Generate types and content cache
#      -c, --config FILE            Config file location
#      -d, --dir DIR                Root directory of project
#      -w, --watch                  Watch for changes to source files
#          --fix                    Overwrite missing/incorrect
#                                   properties with defaults
#
#  Auto-injected by sade:
#    -h, --help                     Show help (auto-added)
#
#  Configuration:
#    cms.ts / cms.tsx               Alinea config file (typical convention)
#    .alinea/                       Generated types and content cache
#    Content/                       Content directory (configurable)
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also sade users):
#    - microbundle (IN CORPUS via _microbundle — Jason Miller's
#      8135 stars zero-config bundler; uses sade)
#    - sveltekit / svelte-package (sveltejs/kit 20546 stars, IN
#      CORPUS via _sveltekit; uses sade for svelte-package CLI)
#    - web3-storage / w3 CLI (web3-storage/web3.storage 503 stars
#      DEPRECATED; w3-cli FUTURE candidate via newer web3.storage
#      iteration)
#    - nftstorage / nft.storage (CLI, smaller community)
#    - alanshaw/cardex / builds-dev/gfmjs / saibotsivad/mongodb-local-
#      data-api / geut/brode / evidence-dev / cloudflare-privacypass /
#      plone/volto (smaller community Node.js CLI tools)
# ============================================================================

_alinea() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-v --version)'{-v,--version}'[print version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs=(
        'init:initialize new Alinea project in current directory'
        'dev:start development dashboard'
        'serve:start development dashboard (alias for dev)'
        'build:generate types and content cache'
        'generate:generate types and content cache (alias for build)'
      )
      _describe -t commands 'alinea subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        dev|serve)
          _arguments -s -S \
            '(-c --config)'{-c,--config}'=[config file location]:file:_files' \
            '(-d --dir)'{-d,--dir}'=[root directory of project]:dir:_directories' \
            '(-p --port)'{-p,--port}'=[port to listen on]:port' \
            '(-b --base)'{-b,--base}'=[base URL for previews]:url' \
            '--production[use production backend]' \
            '--dev[watch alinea sources]' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        build|generate)
          _arguments -s -S \
            '(-c --config)'{-c,--config}'=[config file location]:file:_files' \
            '(-d --dir)'{-d,--dir}'=[root directory of project]:dir:_directories' \
            '(-w --watch)'{-w,--watch}'[watch for changes to source files]' \
            '--fix[overwrite missing/incorrect properties with defaults]' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        init)
          _arguments '(-h --help)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_alinea "$@"
