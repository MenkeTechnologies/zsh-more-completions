#compdef cri-dockerd
# CRI implementation for Docker Engine

local ret=1

_arguments -s -S \
  '--cni-bin-dir=[CNI binary directory]:directory:_files -/' \
  '--cni-cache-dir=[CNI cache directory]:directory:_files -/' \
  '--cni-conf-dir=[CNI configuration directory]:directory:_files -/' \
  '--container-runtime-endpoint=[endpoint]:endpoint:' \
  '--docker-endpoint=[Docker endpoint]:endpoint:' \
  '--image-pull-progress-deadline=[deadline for image pull]:duration:' \
  '--network-plugin=[network plugin]:plugin:(cni)' \
  '--pod-cidr=[pod CIDR]:CIDR:' \
  '--pod-infra-container-image=[pod infra image]:image:' \
  '--runtime-cgroups=[cgroup driver]:driver:' \
  '--log-level=[log level]:level:(debug info warn error fatal)' \
  '-v[log verbosity level]:level:' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
