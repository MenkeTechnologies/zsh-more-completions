#compdef lttng-sessiond
# Documentation: https://lttng.org/man/8/lttng-sessiond/v2.13/
# Reference accessed: 2026-05-30
# lttng-sessiond — LTTng session daemon. Manages tracing sessions and coordinates kernel/userspace consumers.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)--list-options[list available command options]' \
  '(-b --background -d --daemonize)'{-b,--background}'[start as Unix daemon, keep file descriptors (console) open]' \
  '(-b --background -d --daemonize)'{-d,--daemonize}'[start as Unix daemon, close file descriptors (console)]' \
  '(-f --config)'{-f,--config=}'[use INI configuration file at PATH]:file:_files -g "*.ini"' \
  '(-g --group)'{-g,--group=}'[Unix tracing group (default: tracing)]:group:_groups' \
  '(-l --load)'{-l,--load=}'[load recording session configurations from directory or file]:path:_files' \
  '(-S --sig-parent)'{-S,--sig-parent}'[send USR1 to parent process when ready]' \
  '--no-kernel[disable Linux kernel tracing]' \
  '--kmod-probes=[load only these LTTng kernel probe modules (CSV)]:probes:' \
  '--extra-kmod-probes=[load additional LTTng kernel probe modules (CSV)]:probes:' \
  '--agent-tcp-port=[TCP port for agent registration]:port:' \
  '(-a --apps-sock)'{-a,--apps-sock=}'[application Unix socket path]:path:_files' \
  '(-c --client-sock)'{-c,--client-sock=}'[client Unix socket path]:path:_files' \
  '--consumerd32-path=[32-bit consumer daemon binary path]:file:_files' \
  '--consumerd32-libdir=[32-bit consumer daemon library directory]:dir:_directories' \
  '--consumerd64-path=[64-bit consumer daemon binary path]:file:_files' \
  '--consumerd64-libdir=[64-bit consumer daemon library directory]:dir:_directories' \
  '--kconsumerd-cmd-sock=[kernel consumer daemon command socket]:path:_files' \
  '--kconsumerd-err-sock=[kernel consumer daemon error socket]:path:_files' \
  '--ustconsumerd32-cmd-sock=[32-bit userspace consumer command socket]:path:_files' \
  '--ustconsumerd32-err-sock=[32-bit userspace consumer error socket]:path:_files' \
  '--ustconsumerd64-cmd-sock=[64-bit userspace consumer command socket]:path:_files' \
  '--ustconsumerd64-err-sock=[64-bit userspace consumer error socket]:path:_files' \
  '--event-notifier-error-buffer-size-kernel=[kernel event notifier buffer size]:slots:' \
  '--event-notifier-error-buffer-size-userspace=[userspace event notifier buffer size]:slots:' \
  '(-q --quiet)'{-q,--quiet}'[suppress all messages (incompatible with --verbose)]' \
  '*'{-v,--verbose}'[increase verbosity (up to 3 times: -v, -vv, -vvv)]' \
  '--verbose-consumer[increase consumer daemon verbosity]' \
  && ret=0

return ret
