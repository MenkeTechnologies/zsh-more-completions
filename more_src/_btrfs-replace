#compdef btrfs-replace
# _btrfs-replace — btrfs-progs btrfs replace (online btrfs device replacement; start swaps a source device with target while live, status shows progress, cancel aborts an in-progress replace; -B blocking foreground mode, -r read source only, -f force)
# upstream: https://github.com/kdave/btrfs-progs
# Subcommands from btrfs-progs cmds/replace.c on tip.

_btrfs-replace() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'replace command' '(start status cancel)' ;;
        args)
            case $line[1] in
                start) _arguments \
                    '-B[blocking foreground]' \
                    '-r[read source only]' \
                    '-f[force]' \
                    '1:source device or devid:_files -g "/dev/*"' \
                    '2:target device:_files -g "/dev/*"' \
                    '3:mountpoint:_files -/' ;;
                status) _arguments '-1[one-shot]' '*:mountpoint:_files -/' ;;
                cancel) _arguments '*:mountpoint:_files -/' ;;
            esac
            ;;
    esac
}

_btrfs-replace "$@"
