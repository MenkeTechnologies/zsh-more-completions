#compdef dreme
# Documentation: https://meme-suite.org/meme/doc/dreme.html
# MEME Suite: discover short regular-expression motifs (legacy; see STREME)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output directory (default dreme_out), fail if exists]:dir:_files -/' \
  '-oc[output directory (default dreme_out), overwrite if exists]:dir:_files -/' \
  '-p[primary sequence file]:file:_files' \
  '-n[control sequence file]:file:_files' \
  '-png[create PNG logo images]' \
  '-eps[create EPS logo images]' \
  '-norc[do not search the reverse complement strand]' \
  '-g[number of REs to generalize]:ngen:' \
  '-s[random number seed]:seed:' \
  '-e[stop if motif E-value exceeds this]:e:' \
  '-m[stop after finding this many motifs]:m:' \
  '-t[stop after this many seconds]:t:' \
  '-mink[minimum motif width]:mink:' \
  '-maxk[maximum motif width]:maxk:' \
  '-k[exact motif width (sets mink and maxk)]:k:' \
  '-desc[description text for the output]:description:' \
  '-dfile[file containing the description text]:file:_files' \
  '-l[print list of enrichment ratios (experimental)]' \
  '*:sequence file:_files' && ret=0

return ret
