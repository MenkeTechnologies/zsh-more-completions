#compdef hyprshutdown
# _hyprshutdown — graceful Hyprland session shutdown UI (hyprwm/hyprshutdown)
# upstream: https://github.com/hyprwm/hyprshutdown
# Flags from src/main.cpp (Hyprutils::CLI::CArgumentParser).

_hyprshutdown() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show the help menu]'
        '--dry-run[do not exit apps, only show the shutdown UI]'
        '--no-exit[do not exit Hyprland after apps close]'
        '(-t --top-label)'{-t+,--top-label=}'[label shown at the top (default "Shutting down...")]:label:'
        '(-p --post-cmd)'{-p+,--post-cmd=}'[command to run after all apps + Hyprland have exited]:cmd:'
        '--verbose[enable verbose logging]'
        '--no-fork[run in the foreground (do not daemonize)]'
        '--vt=[switch to VT N after Hyprland exits (NVIDIA+SDDM workaround)]:n:'
    )
    _arguments -s $args
}

_hyprshutdown "$@"
