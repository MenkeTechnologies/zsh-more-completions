#compdef gowrap
# Documentation: https://github.com/hexdigest/gowrap
# gowrap: generate decorators for Go interfaces using templates

local ret=1
local -a commands

commands=(
  'gen:generate a decorator for an interface'
  'template:manage templates'
)

_arguments -C \
  '(-h -help)'{-h,-help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'gowrap command' commands && ret=0
    ;;
  args)
    case $line[1] in
      gen)
        _arguments -s \
          '-p=[source package import path]:package' \
          '-i=[source interface name]:interface' \
          '-t=[template to use]:template' \
          '-o=[output file name]:file:_files' \
          '*-v=[key-value pair to parametrize the template]:var' \
          '-g[omit the go:generate instruction from generated code]' && ret=0
        ;;
      template)
        _values 'action' 'copy[copy a template into the project]' && ret=0
        ;;
    esac
    ;;
esac

return ret
