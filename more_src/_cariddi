#compdef cariddi
# Documentation: https://github.com/edoardottt/cariddi
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Take a list of domains, crawl URLs and search for endpoints, secrets, API keys, file extensions, tokens.

local -a arguments

arguments=(
  '-version[print version]'
  '-h[print help]'
  '-examples[print examples]'
  '-intensive[crawl resources matching 2nd-level domain]'
  '-s[hunt for secrets]'
  '-err[hunt for errors in websites]'
  '-e[hunt for juicy endpoints]'
  '-info[hunt for useful information]'
  '-ext[hunt for juicy file extensions (1-7)]:level:(1 2 3 4 5 6 7)'
  '-ef[custom endpoints file]:file:_files'
  '-sf[custom secrets regexes file]:file:_files'
  '-ie[ignored extensions csv]:exts:'
  '-proxy[proxy URL (http/socks5)]:url:'
  '-d[delay between page crawls]:seconds:'
  '-c[concurrency level (default 20)]:n:'
  '-i[ignore URLs containing words]:csv:'
  '-it[ignore URLs from file]:file:_files'
  '-cache[use .cariddi_cache folder]'
  '-t[request timeout (default 10)]:seconds:'
  '-headers[custom headers (json/string)]:headers:'
  '-headersfile[custom headers from file]:file:_files'
  '-ua[custom User-Agent]:ua:'
  '-rua[random browser UA per request]'
  '-md[maximum depth]:depth:'
  '-plain[print only results]'
  '-ot[output text file]:file:_files'
  '-oh[output HTML file]:file:_files'
  '-json[JSON output to stdout]'
  '-sr[store HTTP responses]'
  '-debug[print debug information]'
)

_arguments -s -S $arguments
