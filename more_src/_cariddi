#compdef cariddi

local -a arguments

arguments=(
  '-u[target URL]:url:'
  '-d[crawl depth]:depth:'
  '-c[concurrency level]:concurrency:'
  '-t[timeout in seconds]:seconds:'
  '-s[search for secrets]'
  '-e[file extensions to search]:extensions:'
  '-plain[plain output without colors]'
  '-cache[use cache]'
  '-json[JSON output]'
  '-err[show errors]'
  '-info[show info messages]'
  '-debug[show debug messages]'
  '-headers[custom headers]:headers:'
  '-proxy[proxy URL]:proxy:'
  '-intensive[intensive mode - crawl everything]'
  '-rua[use random User-Agent]'
  '-ef[extension file]:file:_files'
  '-sf[secrets file]:file:_files'
  '-ot[output target file]:file:_files'
  '-oh[output host file]:file:_files'
  '-h[show help message]'
)

_arguments -s -S $arguments
