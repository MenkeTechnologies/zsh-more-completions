#compdef aterm
# Documentation: http://www.afterstep.org/aterm.php
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-display+[X display]:display:' \
  '-geometry+[WxH+X+Y]:geom:' \
  '-fg+[foreground]:color:' \
  '-bg+[background]:color:' \
  '-fn+[font]:font:' \
  '-name+[application name]:name:' \
  '-title+[window title]:title:' \
  '-T+[icon title]:title:' \
  '-n+[icon name]:name:' \
  '-iconic[start iconified]' \
  '-bw+[border width]:px:' \
  '-rv[reverse video]' \
  '-bl[borderless]' \
  '-sb[scrollbar]' \
  '+sb[no scrollbar]' \
  '-sl+[saveLines]:n:' \
  '-tn+[term name]:term:' \
  '-e[exec command]:cmd:_command_names' \
  '*::arg:_files' && ret=0

return ret
