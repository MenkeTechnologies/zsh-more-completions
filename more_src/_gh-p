#compdef gh-p gh-project-item-move gh-repo-activity-costs gh-skillview
# Documentation: upstream READMEs at github.com/{wyf9/gh-p,daniel-leinweber/gh-project-item-move,NewAlexandria/gh-repo-activity-costs,harder/gh-skillview}
# Reference accessed: 2026-05-30
# gh-extension family round 14. Cross-language harvest (Python + C#).
# Hunt-skip log this round:
#   gh-ca (rockwotj/gh-ca) — README only mentions `gh ca --help`; no flag
#     enumeration. Defer per the gh-grep precedent.
#   gh-sponsors (devlooped/gh-sponsors) — ARCHIVED 2024-06-14; surface
#     well-documented (6 subcommands) but archived per upstream signaling
#     long-term direction is finished. Skip per archived-with-direction
#     precedent.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-p)
    # wyf9/gh-p — gh CLI PR enhancement (passthrough wrapper).
    # Documented subcommands: checkout, push, list.
    # All other `gh pr` commands pass through unchanged.
    local -a _subcmds
    _subcmds=(
      'checkout:create local branch gh-pull-N from PR number'
      'push:push to PR branch (auto-detects PR from current branch)'
      'list:passthrough to gh pr list'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-p subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          checkout)
            _arguments '1:PR number:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-project-item-move)
    # daniel-leinweber/gh-project-item-move — move project items to columns.
    # Bare `gh project-item-move` enters interactive mode.
    _arguments -s -S \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '(-o --owner)-o+[project owner]:owner:' \
      '(-o --owner)--owner=[project owner]:owner:' \
      '(-p --project)-p+[project name]:project:' \
      '(-p --project)--project=[project name]:project:' \
      '(-i --issue)-i+[issue ID to move]:issue:' \
      '(-i --issue)--issue=[issue ID to move]:issue:' \
      '(-c --column)-c+[target column name]:column:' \
      '(-c --column)--column=[target column name]:column:' \
      && ret=0
    ;;

  gh-repo-activity-costs)
    # NewAlexandria/gh-repo-activity-costs — gather PR + CI runtime metrics.
    _arguments -s -S \
      '--repo=[owner/repo to analyze]:repo:' \
      '--limit=[number of PRs to fetch]:N:' \
      && ret=0
    ;;

  gh-skillview)
    # harder/gh-skillview — TUI + CLI for managing AI agent skills.
    # Bare invocation launches the 3-tab TUI (Discover/Installed/Changes).
    local -a _subcmds
    _subcmds=(
      'doctor:environment + capability inspection'
      'list:display installed skills'
      'search:find public skills'
      'preview:preview a skill without installing'
      'install:install a skill with safety wrappers'
      'update:manage skill updates (batch with --dry-run support)'
      'remove:remove a skill with validation'
      'cleanup:handle maintenance tasks (duplicates, broken symlinks)'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-skillview subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          search)
            _arguments '1:search query:' && ret=0
            ;;
          preview|install)
            _arguments \
              '1:OWNER/REPO:' \
              '2:skill name (optional):' && ret=0
            ;;
          remove)
            _arguments '1:installed skill:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
