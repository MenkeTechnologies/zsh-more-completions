#compdef nanofilt NanoFilt
# Documentation: https://github.com/wdecoster/nanofilt
# NanoFilt - filtering and trimming of long-read sequencing data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--logfile=[path for log output]:file:_files' \
  '(-l --length)'{-l,--length}'=[minimum read length]:length' \
  '--maxlength=[maximum read length]:length' \
  '(-q --quality)'{-q,--quality}'=[minimum average read quality]:quality' \
  '--minGC=[minimum GC content]:gc' \
  '--maxGC=[maximum GC content]:gc' \
  '--headcrop=[trim n nucleotides from start]:n' \
  '--tailcrop=[trim n nucleotides from end]:n' \
  '(-s --summary)'{-s,--summary}'=[albacore/guppy summary file]:file:_files' \
  '--readtype=[read type from summary]:type:(1D 2D 1D2)' \
  '*:input:_files' && ret=0

return ret
