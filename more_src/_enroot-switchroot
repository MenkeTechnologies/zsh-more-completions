#compdef enroot-switchroot
# Documentation: https://github.com/NVIDIA/enroot/blob/main/bin/enroot-switchroot.c
# enroot helper: switch to a new root filesystem and exec a command.

local ret=1

_arguments -s -S \
  '--norc[do not source shell rc files]' \
  '--login[start the shell as a login shell]' \
  '--rcfile[source FILE instead of the default rc file]:file:_files' \
  '--envfile[read environment from FILE]:file:_files' \
  '--workdir[set the working directory]:dir:_files -/' \
  '1:rootfs:_files -/' \
  '*:::command:_command_names -e' && ret=0

return ret
