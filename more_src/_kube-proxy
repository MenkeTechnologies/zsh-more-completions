#compdef kube-proxy

# kube-proxy: Kubernetes network proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--bind-address=[bind address]:addr:' \
  '--bind-address-hard-fail=[fail on bind error]:bool:(true false)' \
  '--cleanup[cleanup iptables/ipvs rules and exit]' \
  '--cluster-cidr=[cluster CIDR]:cidr:' \
  '--config=[config file]:file:_files' \
  '--config-sync-period=[config sync period]:duration:' \
  '--conntrack-max-per-core=[conntrack max per core]:n:' \
  '--conntrack-min=[conntrack min]:n:' \
  '--conntrack-tcp-be-liberal[liberal TCP conntrack]' \
  '--conntrack-tcp-timeout-close-wait=[CLOSE_WAIT timeout]:duration:' \
  '--conntrack-tcp-timeout-established=[ESTABLISHED timeout]:duration:' \
  '--feature-gates=[feature gates]:gates:' \
  '--healthz-bind-address=[healthz bind address]:addr:' \
  '--healthz-port=[healthz port]:port:' \
  '--hostname-override=[hostname override]:host:' \
  '--iptables-localhost-nodeports=[localhost nodeports]:bool:(true false)' \
  '--iptables-masquerade-bit=[masquerade bit]:n:' \
  '--iptables-min-sync-period=[min sync period]:duration:' \
  '--iptables-sync-period=[sync period]:duration:' \
  '--ipvs-exclude-cidrs=[ipvs exclude CIDRs]:list:' \
  '--ipvs-min-sync-period=[ipvs min sync period]:duration:' \
  '--ipvs-scheduler=[ipvs scheduler]:scheduler:(rr lc dh sh sed nq mh)' \
  '--ipvs-strict-arp[ipvs strict arp]' \
  '--ipvs-sync-period=[ipvs sync period]:duration:' \
  '--ipvs-tcp-timeout=[ipvs tcp timeout]:duration:' \
  '--ipvs-tcpfin-timeout=[ipvs tcpfin timeout]:duration:' \
  '--ipvs-udp-timeout=[ipvs udp timeout]:duration:' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--kube-api-burst=[kube API burst]:n:' \
  '--kube-api-content-type=[kube API content type]:ct:' \
  '--kube-api-qps=[kube API QPS]:n:' \
  '--master=[k8s API URL]:url:' \
  '--masquerade-all[masquerade all traffic]' \
  '--metrics-bind-address=[metrics bind address]:addr:' \
  '--metrics-port=[metrics port]:port:' \
  '--nodeport-addresses=[nodeport addresses]:list:' \
  '--oom-score-adj=[OOM score adj]:n:' \
  '--profiling=[enable profiling]:bool:(true false)' \
  '--proxy-mode=[proxy mode]:mode:(userspace iptables ipvs kernelspace)' \
  '--proxy-port-range=[proxy port range]:range:' \
  '--show-hidden-metrics-for-version=[show hidden metrics for version]:ver:' \
  '--udp-timeout=[udp timeout]:duration:' \
  '--v=[log level]:n:' \
  '--write-config-to=[write config and exit]:file:_files' \
  '*::kube-proxy args:_files' && ret=0
return ret
