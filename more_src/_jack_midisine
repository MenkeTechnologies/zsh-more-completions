#compdef jack_midisine
# Documentation: https://man.archlinux.org/search?q=jack_midisine
# Reference accessed: 2026-05-16

# jack_midisine: simple JACK midi sine-wave synth
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-n[JACK client name]:name:' \
  '--name=[JACK client name]:name:' \
  '-s[JACK server name]:name:' \
  '--server=[JACK server name]:name:' \
  '*::jack_midisine args:_files' && ret=0
return ret
