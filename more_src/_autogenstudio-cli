#compdef autogenstudio-cli
# Documentation: https://github.com/microsoft/autogen/tree/main/python/packages/autogen-studio
# Reference accessed: 2026-05-23
# Verified: autogenstudio --help (see also _autogenstudio).

# Zsh completion for autogenstudio-cli - AutoGen Studio CLI package name

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'autogenstudio command' \
      'ui[launch web interface]' \
      'lite[lightweight prototyping mode]' \
      'version[show version]' && ret=0
    ;;
  args)
    case $line[1] in
      ui)
        _arguments \
          '--host[host address]:host:' \
          '--port[port]:port:' \
          '--appdir[app directory]:directory:_directories' \
          '--reload[auto-reload]' \
          '--database-uri[database URI]:uri:' \
          '--upgrade-database[upgrade schema]' && ret=0
        ;;
      lite)
        _arguments \
          '--team[team file]:file:_files' \
          '--host[host]:host:' \
          '--port[port]:port:' && ret=0
        ;;
    esac
    ;;
esac

return ret
