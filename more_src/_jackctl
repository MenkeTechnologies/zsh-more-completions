#compdef jackctl
# Documentation: https://linux.die.net/man/1/qjackctl
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# jackctl: control / probe JACK D-Bus interface
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'start:start the JACK server'
  'stop:stop the JACK server'
  'isstarted:report whether JACK is running'
  'status:show JACK status'
  'sr:show/set sample rate'
  'cpu:show DSP load'
  'sm:set internal client'
  'reset:reset XRUN counter'
  'connect:connect ports'
  'disconnect:disconnect ports'
  'getXRuns:show XRun count'
  'help:show help'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'jackctl command' commands && ret=0 ;;
esac
return ret
