#compdef jackctl
# Documentation: https://manpages.org/jackctl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jack.ctl: JACK session manager. The only commands accepted are
# start, stop, restart (config is via /etc/jackrc and ~/.jackrc).
# Removed fabricated D-Bus subcommand list (isstarted/status/sr/cpu/
# sm/reset/connect/disconnect/getXRuns) and -h flag (not documented).
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'start:start the JACK daemon and any secondary daemons'
  'stop:stop the JACK daemon and any secondary daemons'
  'restart:restart the JACK daemon and any secondary daemons'
)
_arguments -C \
  '1: :->cmd' && ret=0
case $state in
  cmd) _describe -t commands 'jack.ctl command' commands && ret=0 ;;
esac
return ret
