#compdef tflint

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--init[install plugins]' \
  '--langserver[start LSP]' \
  '-f+[output format]:f:(default json checkstyle junit compact sarif)' \
  '--format=[output format]:f:(default json checkstyle junit compact sarif)' \
  '*--config=[config file]:file:_files -g "*.tflint.hcl *.hcl"' \
  '-c+[config file]:file:_files -g "*.tflint.hcl *.hcl"' \
  '*--ignore-module=[ignore module source]:s:' \
  '*--enable-rule=[enable rule]:r:' \
  '*--disable-rule=[disable rule]:r:' \
  '--only=[only enable rules csv]:list:' \
  '*--enable-plugin=[enable plugin]:p:' \
  '*--var-file=[var file]:file:_files -g "*.tfvars *.tfvars.json"' \
  '*--var=[k=v variable]:v:' \
  '--module[load modules]' \
  '--no-module[disable module loading]' \
  '--call-module-type=[call module type]:t:(all local none)' \
  '--chdir=[chdir]:dir:_files -/' \
  '--recursive[recursive]' \
  '--filter=[filter file]:f:' \
  '--force[force exit 0]' \
  '--minimum-failure-severity=[severity]:s:(error warning notice)' \
  '--color[color]' \
  '--no-color[no color]' \
  '--fix[apply auto fixes]' \
  '--actas-bundled-plugin[acts as bundled plugin]' \
  '*: :_files -/' && ret=0

return ret
