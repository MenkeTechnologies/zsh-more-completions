#compdef tflint
# Documentation: https://github.com/terraform-linters/tflint
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--init[install plugins]' \
  '--langserver[start language server]' \
  '(-f --format)'{-f,--format}'=[output format]:f:(default json checkstyle junit compact sarif)' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files -g "*.tflint.hcl *.hcl"' \
  '*--ignore-module=[ignore module source]:s:' \
  '*--enable-rule=[enable rule]:r:' \
  '*--disable-rule=[disable rule]:r:' \
  '*--only=[enable only specified rule]:r:' \
  '*--enable-plugin=[enable plugin]:p:' \
  '*--var-file=[var file]:file:_files -g "*.tfvars *.tfvars.json"' \
  '*--var=[k=v variable]:v:' \
  '--call-module-type=[call module type]:t:(all local none)' \
  '--chdir=[chdir]:dir:_files -/' \
  '--recursive[recursive]' \
  '--filter=[filter file]:f:' \
  '--force[force exit 0]' \
  '--minimum-failure-severity=[severity]:s:(error warning notice)' \
  '--color[color]' \
  '--no-color[no color]' \
  '--fix[apply auto fixes]' \
  '--no-parallel-runners[disable per-runner parallelism]' \
  '--max-workers=[maximum workers]:n:' \
  '*: :_files -/' && ret=0

return ret
