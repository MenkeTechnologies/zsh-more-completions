#compdef cobaya-doc
# Documentation: https://cobaya.readthedocs.io/en/latest/cosmo_basic_runs.html
# cobaya: show defaults for a component

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --python)'{-p,--python}'[request Python instead of YAML]' \
  '(-e --expand)'{-e,--expand}'[expand YAML defaults]' \
  '1:component:(sampler theory likelihood)' && ret=0

return ret
