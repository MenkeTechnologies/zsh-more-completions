#compdef pdb_delchain
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Deletes all atoms matching specific chains in the PDB file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[chain id(s) to delete, e.g. -A or -A,B]:chain id' \
  '*:PDB file:_files' && ret=0

return ret
