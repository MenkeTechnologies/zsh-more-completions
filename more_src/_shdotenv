#compdef shdotenv
# Documentation: https://github.com/ko1nksm/shdotenv
# shdotenv - dotenv for shells with POSIX-compliant and multiple .env file syntax

local ret=1

_arguments -s -S \
  '(-d --dialect)'{-d,--dialect}'[specify the .env dialect]:dialect:(posix ruby node python php go rust docker)' \
  '(-f --format)'{-f,--format}'[output in the specified format]:format:(sh csh fish json jsonl yaml)' \
  '*'{-e,--env}'[location of the .env file]:env path:_files' \
  '(-i --ignore-environment)'{-i,--ignore-environment}'[ignore the current environment variables]' \
  '--overload[overload predefined variables]' \
  '--no-allexport[disable all variable export]' \
  '--no-nounset[allow references to undefined variables]' \
  '--grep[output only names matching the regexp pattern]:pattern:' \
  '(-s --sort)'{-s,--sort}'[sort variable names]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all output]' \
  '--version[show version and exit]' \
  '--help[show help message and exit]' \
  '*::command:_command_names -e' && ret=0

return ret
