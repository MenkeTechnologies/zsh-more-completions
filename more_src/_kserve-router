#compdef kserve-router
# _kserve-router — KServe Inference-Graph orchestrator sidecar (kserve/kserve)
# upstream: https://github.com/kserve/kserve
# Flags from cmd/router/main.go on tip.

_kserve-router() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--graph-json=[serialized JSON InferenceGraph spec]:json:'
}

_kserve-router "$@"
