#compdef fixel2tsf
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/fixel2tsf.html
# map fixel values to a track scalar file based on an input tractogram

local ret=1

_arguments -s -S \
  '-angle=[max angular threshold for fixel-tangent correspondence (deg)]:value' \
  '-info[display information messages]' \
  '-quiet[suppress information and progress messages]' \
  '-debug[display debugging messages]' \
  '-force[force overwrite of output files]' \
  '-nthreads=[number of threads]:number' \
  '-config=[temporarily set a config entry]:key:_default:value' \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[display version information]' \
  '1:fixel_in:_files' \
  '2:tracks:_files' \
  '3:tsf:_files' && ret=0

return ret
