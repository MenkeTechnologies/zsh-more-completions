#compdef pdfly
# Documentation: https://github.com/py-pdf/pdfly
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  '2-up:create booklet-style PDF from single input'
  'booklet:reorder and two-up PDF pages for booklet printing'
  'cat:extract and concatenate pages from PDFs'
  'check-sign:verify the signature of a signed PDF'
  'compress:compress a PDF'
  'extract-annotated-pages:extract only the annotated pages from a PDF'
  'extract-images:extract images from PDF without resampling'
  'extract-text:extract text from a PDF file'
  'meta:show metadata of a PDF file'
  'pagemeta:give details about a single page'
  'rm:remove pages from PDF files'
  'rotate:rotate specified pages by the specified amount'
  'sign:create a signed PDF from an existing PDF'
  'uncompress:uncompress PDF content streams'
  'update-offsets:update offsets and lengths in a PDF file'
  'x2pdf:convert one or more files to PDF'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--install-completion[install completion for the current shell]' \
  '--show-completion[show completion for the current shell]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'pdfly command' commands && ret=0 ;;
  (args) _arguments '*:file:_files -g "*.pdf"' && ret=0 ;;
esac

return ret
