#compdef vspviewer
# Documentation: https://github.com/OpenVSP/OpenVSP/blob/main/src/vsp_aero/Viewer/vspaero_viewer.C
# VSPVIEWER - OpenVSP VSPAERO solution / geometry OpenGL viewer

local ret=1

_arguments -s \
  '-calculix[set CalculiX file name]:calculix file:_files' \
  '-forceview[force a fixed view box size]' \
  '-timestamp[set a time stamp label]' \
  '*:filename:_files' && ret=0

return ret
