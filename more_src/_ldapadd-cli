#compdef ldapadd-cli ldapmodify-cli
# _ldapadd-cli — OpenLDAP ldapadd/ldapmodify LDAP add/modify tool CLI alias (openldap team, C); custom argparse
# upstream: https://git.openldap.org/openldap/openldap

_ldapadd-cli() {
    _arguments \
        '--help[show help]' \
        '-a[add entries]' \
        '-c[continuous mode]' \
        '-S+[reject file]:file:_files' \
        '-n[show what would be done]' \
        '-v[verbose]' \
        '-M[manage DSA IT]' \
        '-MM[manage DSA IT (critical)]' \
        '-d+[debug level]:n:' \
        '-D+[bind DN]:str:' \
        '-w+[bind password]:str:' \
        '-W[prompt for password]' \
        '-y+[password file]:file:_files' \
        '-x[simple authentication]' \
        '-O+[SASL security props]:str:' \
        '-Y+[SASL mechanism]:str:' \
        '-U+[SASL authcid]:str:' \
        '-X+[SASL authzid]:str:' \
        '-R+[SASL realm]:str:' \
        '-I[interactive SASL]' \
        '-N[no canonical resolution]' \
        '-Q[quiet SASL]' \
        '-Z[StartTLS]' \
        '-ZZ[StartTLS required]' \
        '-f+[file with input]:file:_files' \
        '-h+[ldap host]:host:_hosts' \
        '-H+[URI]:url:_urls' \
        '-p+[port]:port:' \
        '-V[show version]' \
        '-e+[ext]:str:' \
        '-o+[option]:str:' \
        '-r[replace]' \
        '*:file:_files'
}

_ldapadd-cli "$@"
