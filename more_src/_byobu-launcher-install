#compdef byobu-launcher-install
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/byobu-launcher-install.1.html
# byobu: install the byobu launcher into a shell profile file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --no-logout)'{-n,--no-logout}'[do not log out on detach]' \
  '*:profile file:_files' && ret=0

return ret
