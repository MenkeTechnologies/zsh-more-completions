#compdef acpi-call
# Documentation: https://man.archlinux.org/search?q=acpi-call
# Reference accessed: 2026-05-16

# acpi-call: shell helper to invoke ACPI methods via /proc/acpi/call
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:ACPI method (e.g. \_SB.PCI0.GFX0._DOS):' && ret=0
return ret
