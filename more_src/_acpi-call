#compdef acpi-call
# Documentation: https://github.com/mkottman/acpi_call
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# acpi-call: shell helper to invoke ACPI methods via /proc/acpi/call
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:ACPI method (e.g. \_SB.PCI0.GFX0._DOS):' && ret=0
return ret
