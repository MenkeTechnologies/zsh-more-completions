#compdef cfn-format
# Documentation: https://github.com/awslabs/aws-cloudformation-template-formatter
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# aws-cloudformation-template-formatter standalone cfn-format binary.
# rain ships an equivalent `rain fmt` command in aws-cloudformation/rain.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --compact)'{-c,--compact}'[produce more compact output]' \
  '(-j --json)'{-j,--json}'[write JSON instead of YAML]' \
  '(-v --verify)'{-v,--verify}'[verify template already formatted]' \
  '(-w --write)'{-w,--write}'[write result back to source file]' \
  '*:template file:_files'
