#compdef cfn-format
# Documentation: https://man.archlinux.org/search?q=cfn-format
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --compact)'{-c,--compact}'[produce more compact output]' \
  '(-j --json)'{-j,--json}'[write JSON instead of YAML]' \
  '(-v --verify)'{-v,--verify}'[verify template already formatted]' \
  '(-w --write)'{-w,--write}'[write result back to source file]' \
  '*:template file:_files'
