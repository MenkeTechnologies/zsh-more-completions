#compdef verovio
# Documentation: https://book.verovio.org/installing-or-building-from-sources/command-line.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (only basic flags documented; full list is behind `verovio -h full`).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help (use -h full for all options)]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-r --resource-path)'{-r+,--resource-path=}'[path to Verovio resources directory]:dir:_files -/' \
  '*:input file:_files' && ret=0

return ret
