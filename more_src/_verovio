#compdef verovio
# Documentation: https://man.archlinux.org/search?q=verovio
# Reference accessed: 2026-05-16

# Zsh completion for verovio MEI/MusicXML engraver CLI

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-t --to)'{-t,--to}'[output format]:fmt' \
  '*:MEI/MusicXML input:_files' && ret=0

return ret
