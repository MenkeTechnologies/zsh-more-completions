#compdef termshot

# Zsh completion for termshot (terminal screenshot tool)
# https://github.com/homeport/termshot

_arguments \
  '(-e --edit)'{-e,--edit}'[edit content before creating screenshot]' \
  '(-c --show-cmd)'{-c,--show-cmd}'[include command in screenshot]' \
  '(-C --columns)'{-C,--columns}'[force fixed number of columns in screenshot]:columns' \
  '(-m --margin)'{-m,--margin}'[set margin around the window (default 48)]:margin' \
  '(-p --padding)'{-p,--padding}'[set padding around the content inside window (default 24)]:padding' \
  '--no-decoration[do not draw window decorations]' \
  '--no-shadow[do not draw window shadow]' \
  '(-s --clip-canvas)'{-s,--clip-canvas}'[clip canvas to visible image area (no margin)]' \
  '(-f --filename)'{-f,--filename}'[filename of the screenshot (default "out.png")]:filename:_files' \
  '--raw-write[write raw output to file instead of creating a screenshot]:file:_files' \
  '--raw-read[read raw input from file instead of executing a command]:file:_files' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-b --clipboard)'{-b,--clipboard}'[copy termshot to clipboard, overrules filename option]' \
  '(- *)'{-h,--help}'[help for termshot]' \
  '(-):command:_command_names' \
  '*::arguments:_normal'
