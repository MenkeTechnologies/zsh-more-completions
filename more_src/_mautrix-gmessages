#compdef mautrix-gmessages
# _mautrix-gmessages — Matrix-Google Messages bridge (mautrix/gmessages)
# upstream: https://github.com/mautrix/gmessages
# Flags from mautrix-go bridgev2/matrix/mxmain/main.go.

_mautrix-gmessages() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show bridge version]' \
        '(- *)--version-json[print JSON-encoded version and quit]' \
        '(-c --config)'{-c+,--config=}'[config file path]:file:_files -g "*.(yml|yaml)"' \
        '(-e --generate-example-config)'{-e,--generate-example-config}'[save example config and quit]' \
        '(-n --no-update)'{-n,--no-update}'[do not save updated config to disk]' \
        '(-r --registration)'{-r+,--registration=}'[appservice registration save path]:file:_files -g "*.(yml|yaml)"' \
        '(-g --generate-registration)'{-g,--generate-registration}'[generate registration and quit]' \
        '--ignore-unsupported-database[run even if DB schema is too new]' \
        '--ignore-foreign-tables[run even if DB has foreign tables]' \
        '--ignore-unsupported-server[run even if homeserver is outdated]'
}

_mautrix-gmessages "$@"
