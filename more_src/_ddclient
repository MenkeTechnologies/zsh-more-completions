#compdef ddclient

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--daemon=[daemon interval seconds]:secs:' \
  '--foreground[run in foreground]' \
  '--proxy=[HTTP proxy]:proxy:' \
  '--server=[DDNS server]:server:' \
  '--protocol=[protocol]:protocol:' \
  '--list-protocols[list supported protocols]' \
  '--file=[config file]:file:_files' \
  '--cache=[cache file]:file:_files' \
  '--pid=[PID file]:file:_files' \
  '--use=[IP detection method]:method:' \
  '--usev4=[IPv4 detection method]:method:' \
  '--usev6=[IPv6 detection method]:method:' \
  '--ip=[IP address]:ip:' \
  '--ipv4=[IPv4 address]:ip:' \
  '--ipv6=[IPv6 address]:ip:' \
  '--if=[network interface]:iface:' \
  '--ifv4=[IPv4 interface]:iface:' \
  '--ifv6=[IPv6 interface]:iface:' \
  '--web=[web IP service]:url:' \
  '--web-skip=[skip pattern]:pattern:' \
  '--webv4=[IPv4 web service]:url:' \
  '--webv6=[IPv6 web service]:url:' \
  '--list-web-services[list web services]' \
  '--fw=[firewall device]:device:' \
  '--fw-skip=[firewall skip pattern]:pattern:' \
  '--fw-login=[firewall login]:user:' \
  '--fw-password=[firewall password]:password:' \
  '--list-devices[list firewall devices]' \
  '--cmd=[command IP source]:cmd:' \
  '--login=[DDNS login]:user:' \
  '--password=[DDNS password]:password:' \
  '--host=[host name]:host:' \
  '--options=[key=value options]:options:' \
  '--ssl[enable SSL]' \
  '--no-ssl[disable SSL]' \
  '--ssl_ca_dir=[CA dir]:dir:_files -/' \
  '--ssl_ca_file=[CA file]:file:_files' \
  '--fw-ssl-validate[validate firewall TLS]' \
  '--no-fw-ssl-validate[no firewall TLS validate]' \
  '--web-ssl-validate[validate web TLS]' \
  '--no-web-ssl-validate[no web TLS validate]' \
  '--force[force update]' \
  '--no-force[do not force]' \
  '--timeout=[network timeout]:secs:' \
  '--syslog[log to syslog]' \
  '--no-syslog[do not log to syslog]' \
  '--facility=[syslog facility]:facility:' \
  '--priority=[syslog priority]:priority:' \
  '--max-warn=[max warning emails]:n:' \
  '--mail=[email recipient]:email:' \
  '--mail-failure=[email on failure]:email:' \
  '--mail-from=[email from]:email:' \
  '--exec[execute updates]' \
  '--no-exec[do not execute]' \
  '--debug[debug output]' \
  '--no-debug[no debug]' \
  '--verbose[verbose output]' \
  '--no-verbose[no verbose]' \
  '--quiet[quiet output]' \
  '--no-quiet[no quiet]' \
  '--postscript=[script to run after update]:cmd:' \
  '--query[print current address]' \
  '--no-query[no query]' \
  '--redirect=[follow redirects]:flag:'
