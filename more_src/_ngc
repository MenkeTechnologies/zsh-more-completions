#compdef ngc
# Documentation: https://docs.ngc.nvidia.com/cli/cmd.html
# NVIDIA NGC CLI: manage NGC registry models, resources, and jobs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show CLI version]' \
  '--debug[enable debug mode]' \
  '--format_type=[output format]:format:(ascii csv json)' \
  '--org=[organization name]:org:' \
  '--team=[team name]:team:' \
  '1:command:((
    alert\:"manage alerts"
    audit\:"audit logs"
    cloud-function\:"manage cloud functions"
    config\:"manage CLI configuration"
    diag\:"print diagnostic information"
    fleet-command\:"manage Fleet Command"
    forge\:"manage Forge resources"
    org\:"manage organizations"
    registry\:"manage registry images, models, and resources"
    team\:"manage teams"
    user\:"manage user information"
    version\:"show version"
  ))' \
  '*::arg:->args' && ret=0

return ret
