#compdef infection

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--threads=[number of threads]:count' \
  '-j+[number of threads]:count' \
  '--test-framework=[test framework to use]:framework:(phpunit phpspec codeception pest)' \
  '--filter=[filter which files to mutate]:filter' \
  '--configuration=[configuration file path]:config file:_files -g "*.json"' \
  '--coverage=[code coverage directory]:directory:_directories' \
  '--mutators=[list of mutators to use]:mutators' \
  '--only-covered[mutate only covered by tests code]' \
  '--show-mutations[show escaped mutants in output]' \
  '--no-progress[suppress progress bars]' \
  '--force-progress[force progress bars]' \
  '--min-msi=[minimum Mutation Score Indicator]:percentage' \
  '--min-covered-msi=[minimum covered code MSI]:percentage' \
  '--log-verbosity=[log verbosity level]:level:(default per-mutator all none)' \
  '--initial-tests-php-options=[extra PHP options for initial tests]:options' \
  '--skip-initial-tests[skip initial test run]' \
  '--ignore-msi-with-no-mutations[ignore MSI when no mutations]' \
  '--debug[enable debug mode]' \
  '--dry-run[do not actually run mutations]' \
  '--formatter=[output formatter]:formatter:(dot progress)' \
  '--git-diff-filter=[git diff filter]:filter' \
  '--git-diff-base=[git diff base branch]:branch' \
  '--git-diff-lines[only mutate changed lines]' \
  '--logger-html=[save HTML report]:file:_files -g "*.html"' \
  '--logger-json=[save JSON log]:file:_files -g "*.json"' \
  '--logger-text=[save text log]:file:_files' \
  '--logger-gitlab=[save GitLab report]:file:_files -g "*.json"' \
  '--logger-github[use GitHub Actions logger]' \
  '--use-noop-mutators[use noop mutators]' \
  '--no-interaction[do not ask interactive questions]' && ret=0

return ret
