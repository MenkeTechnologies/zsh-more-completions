#compdef bcnm-waitif
# _bcnm-waitif — skarnet bcnm bcnm-waitif (block until one or more network interfaces match a desired link-state mask; -d waits for down; common boot-time gating idiom in s6-based init)
# upstream: https://github.com/skarnet/bcnm
# Flags from src/utils/bcnm-waitif.c on tip.

_bcnm-waitif() {
    _arguments \
        '(-u -d)-u[wait until interfaces are up (default)]' \
        '(-u -d)-d[wait until interfaces are down]' \
        '-t+[timeout (ms)]:ms:' \
        '-k+[kernel netlink socket buffer size]:bytes:' \
        '1:mask:' \
        '*:interface:_net_interfaces'
}

_bcnm-waitif "$@"
