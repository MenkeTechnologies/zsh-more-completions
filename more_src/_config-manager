#compdef config-manager
# _config-manager — NVIDIA k8s device-plugin config-manager (selects device-plugin config from a node label and signals the plugin to reload)
# upstream: https://github.com/NVIDIA/k8s-device-plugin
# Flags from cmd/config-manager/main.go on tip (urfave/cli/v2); env vars also bind to each flag.

_config-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--oneshot[check and update config once then exit]' \
        '--kubeconfig=[absolute path to the kubeconfig file]:file:_files' \
        '--node-name=[node to watch for label changes]:name:' \
        '--node-label=[node label name used to select a config]:label:' \
        '--config-file-srcdir=[directory of available device-config files]:dir:_files -/' \
        '--config-file-dst=[destination device-config file]:file:_files' \
        '--default-config=[default config when no label is set]:name:' \
        '--fallback-strategies=[ordered csv of fallback strategies]:csv:' \
        '--send-signal[send a signal to <process-to-signal> on config change]' \
        '--signal=[signal number to send]:n:' \
        '--process-to-signal=[name of the process to signal]:proc:'
}

_config-manager "$@"
