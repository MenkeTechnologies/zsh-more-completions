#compdef nestopia
# Documentation: https://github.com/0ldsk00l/nestopia
# Reference accessed: 2026-05-19
# Verified: source/fltkui/fltkui.cpp argv parsing only honors --help,
# -v/--version, -f/--fullscreen, -m/--mute. All other CLI options
# omitted as unverified.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start fullscreen with loaded ROM]' \
  '(-m --mute)'{-m,--mute}'[start muted]' \
  '*:rom:_files -g "*.(nes|fds|unif|unf|nsf)"' && ret=0

return ret
