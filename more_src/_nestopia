#compdef nestopia
# Documentation: https://man.archlinux.org/search?q=nestopia
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --conf)'{-c,--conf}'+[config file]:file:_files' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen]' \
  '(-w --window)'{-w,--window}'[windowed]' \
  '(-r --reset)'{-r,--reset}'[reset config to defaults]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '*:rom:_files -g "*.{nes,fds,unf,unif,zip}"' && ret=0

return ret
