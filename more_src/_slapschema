#compdef slapschema
# _slapschema — OpenLDAP slapschema (offline schema validation of every entry in the database against the slapd schema; -F config dir, -f slapd.conf, -b suffix, -n database number, -d debug, -v verbose, -V version, -s subtree, -a filter; reports schema violations without altering the database)
# upstream: https://git.openldap.org/openldap/openldap (servers/slapd/slapschema)
# Flags from OpenLDAP servers/slapd/slapcommon.c on tip.

_slapschema() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-F+[config dir]:dir:_files -/' \
        '-f+[slapd.conf]:file:_files' \
        '-b+[suffix]:dn:' \
        '-n+[database number]:n:' \
        '-d+[debug level]:level:' \
        '-v[verbose]' \
        '-s+[subtree DN]:dn:' \
        '-a+[search filter]:filter:'
}

_slapschema "$@"
