#compdef pip-compile

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-o,--output-file}'=[output file]:output file:_files' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '*'{-q,--quiet}'[decrease verbosity]' \
  {-n,--dry-run}'[do not write output file]' \
  '--no-header[do not include header comment]' \
  '--no-annotate[do not annotate results]' \
  '--no-emit-index-url[do not emit index URL]' \
  '--emit-index-url[emit index URL]' \
  '--no-emit-find-links[do not emit find-links]' \
  '--no-emit-options[do not emit options]' \
  '--emit-options[emit options]' \
  '--generate-hashes[generate hashes in output]' \
  '--allow-unsafe[allow unsafe packages]' \
  '--strip-extras[strip extras from output]' \
  '*--extra=[name of an extras_require group to install]:extra' \
  '--all-extras[install all extras_require groups]' \
  '--no-all-extras[do not install all extras]' \
  {-i,--index-url}'=[base URL of the Python Package Index]:url' \
  '*--extra-index-url=[extra index URLs]:url' \
  '*'{-f,--find-links}'=[look for archives at URL or path]:url or path:_files' \
  '--no-index[ignore package index]' \
  '--pre[include pre-release versions]' \
  '--rebuild[clear caches and rebuild from scratch]' \
  '--resolver=[choose dependency resolver]:resolver:(backtracking legacy)' \
  {-U,--upgrade}'[try to upgrade all dependencies]' \
  '*'{-P,--upgrade-package}'=[specify packages to upgrade]:package' \
  '--emit-trusted-host[emit trusted host options]' \
  '--pip-args=[additional pip arguments]:args' \
  '--config=[pip config file]:config file:_files' \
  '--max-rounds=[maximum number of rounds]:rounds' \
  '--build-isolation[enable build isolation]' \
  '--no-build-isolation[disable build isolation]' \
  '--cert=[path to alternate CA bundle]:cert file:_files' \
  '--client-cert=[path to SSL client certificate]:cert file:_files' \
  '*--trusted-host=[mark host as trusted]:host:_hosts' \
  '--cache-dir=[directory for caching]:cache dir:_directories' \
  '--no-cache-dir[disable the cache]' \
  '*'{-c,--constraint}'=[constraint file]:constraint file:_files' \
  '*:input file:_files -g "*.in *.txt *.cfg setup.py pyproject.toml"' && ret=0

return ret
