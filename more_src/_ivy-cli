#compdef ivy-cli
# _ivy-cli — Apache Ivy dependency manager CLI alias (Apache Software Foundation, Java); custom argparse
# upstream: https://github.com/apache/ant-ivy

_ivy-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-help[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-settings+[settings file]:file:_files -g "ivysettings.xml *.xml"' \
        '-cache+[cache dir]:dir:_files -/' \
        '-novalidate[no validation]' \
        '-ivy+[ivy file]:file:_files -g "ivy.xml *.xml"' \
        '-dependency+[dependency org name rev]:list:' \
        '-confs+[configurations csv]:str:' \
        '-retrieve+[retrieve pattern]:str:' \
        '-cachepath+[cachepath file]:file:_files' \
        '-cacheartifact+[cache artifact pattern]:str:' \
        '-deliverto+[deliver pattern]:str:' \
        '-publish+[resolver name]:str:' \
        '-publishpattern+[publish pattern]:str:' \
        '-publishrevision+[publish revision]:str:' \
        '-status+[status]:str:' \
        '-deliverstatus+[deliver status]:str:' \
        '-revision+[revision]:str:' \
        '-pubdate+[pub date]:str:' \
        '-cleancache[clean cache]' \
        '-cleancachebut+[clean cache but]:str:' \
        '-namespace+[namespace]:str:' \
        '-types+[artifact types]:list:' \
        '-error[error log level]' \
        '-warn[warn log level]' \
        '-debug[debug log level]' \
        '-verbose[verbose log level]' \
        '-overwrite[overwrite]' \
        '-validate[validate]' \
        '-checktimestamps[check timestamps]' \
        '*:arg:'
}

_ivy-cli "$@"
