#compdef pdftohtml
# Documentation: https://manpages.debian.org/pdftohtml.1
# Source: poppler-utils — PDF → HTML / XML converter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show summary]' \
    '-f[first page to print]:n:' \
    '-l[last page to print]:n:' \
    '-q[suppress messages and errors]' \
    '(- *)-v[print copyright + version]' \
    '-p[exchange .pdf links with .html]' \
    '-c[generate complex output]' \
    '-s[single HTML with all pages]' \
    '-dataurls[use data: URLs for images]' \
    '-i[ignore images]' \
    '-noframes[do not generate frames]' \
    '-stdout[write to standard output]' \
    '-zoom[zoom factor (default 1.5)]:factor:' \
    '-xml[output for XML post-processing]' \
    '-noroundcoord[do not round coordinates (XML only)]' \
    '-enc[output text encoding]:encoding:(UTF-8 UTF-16 ISO-8859-1 ASCII Latin1)' \
    '-opw[owner password]:password:' \
    '-upw[user password]:password:' \
    '-hidden[force hidden-text extraction]' \
    '-fmt[Splash image format]:fmt:(png jpg)' \
    '-nomerge[do not merge paragraphs]' \
    '-nodrm[override DRM settings]' \
    '-wbt[word-break threshold percent]:pct:' \
    '-fontfullname[output font name without substitution]' \
    '*:PDF file then output prefix:_files -g "*.pdf"' \
    && ret=0

return ret
