#compdef urless
# Documentation: https://github.com/xnl-h4ck3r/urless
# tool to de-clutter a list of URLs by removing redundant and uninteresting entries

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'+[a file of URLs to de-clutter]:file:_files' \
  '(-o --output)'{-o,--output}'+[output file for de-cluttered URLs]:file:_files' \
  '(-fk --filter-keywords)'{-fk,--filter-keywords}'+[keywords to exclude links without parameters]:keywords' \
  '(-fe --filter-extensions)'{-fe,--filter-extensions}'+[file extensions to exclude]:ext' \
  '(-rp --remove-params)'{-rp,--remove-params}'+[case-sensitive parameters to remove]:params' \
  '(-ks --keep-slash)'{-ks,--keep-slash}'[preserve trailing slashes at URL ends]' \
  '(-khw --keep-human-written)'{-khw,--keep-human-written}'[keep URLs with 3+ dashes in path]' \
  '(-kym --keep-yyyymm)'{-kym,--keep-yyyymm}'[keep URLs containing /YYYY/MM date patterns]' \
  '(-rcid --regex-custom-id)'{-rcid,--regex-custom-id}'+[regex for custom ID format matching]:regex' \
  '(-iq --ignore-querystring)'{-iq,--ignore-querystring}'[output unique paths only]' \
  '(-fnp --fragment-not-param)'{-fnp,--fragment-not-param}'[treat URL fragments differently from parameters]' \
  '(-lang --language)'{-lang,--language}'+[output single version when multiple language codes exist]:lang' \
  '(-c --config)'{-c,--config}'+[path to YML configuration file]:file:_files' \
  '(-dp --disregard-params)'{-dp,--disregard-params}'[apply filtering regardless of parameter presence]' \
  '(-nb --no-banner)'{-nb,--no-banner}'[hide tool banner]' \
  '--version[display current version number]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' && ret=0

return ret
