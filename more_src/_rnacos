#compdef rnacos
# ============================================================================
# rnacos - Rust port of Nacos config +
#          service discovery server
#          (Rust, Apache-2.0)
#
# Author : He Qingpan (heqingpan) +
#           nacos-group community
# Upstream: https://github.com/nacos-group/r-nacos
# crates : rnacos (binary: rnacos)
#
# `rnacos` is a Rust reimplementation of
# Nacos, the de-facto standard
# configuration + service discovery
# platform in the Chinese microservice
# ecosystem (originally developed by
# Alibaba). Nacos provides:
#   - **Dynamic configuration management**
#     (centralized config storage + push
#     notifications to subscribed
#     clients)
#   - **Service registry + discovery**
#     (Eureka/Consul-style service
#     registration + lookup)
#   - **Health checking** (heartbeat
#     + TCP + HTTP probes)
#   - **Multi-environment + namespace**
#     (tenant isolation)
#   - **Console UI** (web admin
#     interface for config + service
#     management)
#
# The Rust port preserves API
# compatibility with the original Java
# Nacos clients (Java + Go + Node + Python
# SDKs work without modification) while
# providing significant performance +
# memory improvements:
#   - **~10x lower memory footprint**
#     than Java Nacos (Rust avoids JVM
#     overhead)
#   - **~3-5x higher throughput** for
#     config push + service discovery
#     operations
#   - **Single-binary deployment** (no
#     JVM + dependency tree)
#   - **Raft-based clustering** (HA
#     deployment via async-raft-ext)
#
# Architecture:
#   - **HTTP API** (actix-web on port
#     8848 by default for OpenAPI +
#     console)
#   - **gRPC API** (tonic on port 9848
#     for Nacos 2.x SDK protocol)
#   - **Embedded SQLite** (sled +
#     SQLite for local storage; no
#     external DB required)
#   - **MySQL migration** (rnacos can
#     migrate from existing Nacos
#     MySQL deployments)
#   - **Raft consensus** (async-raft-
#     ext for HA cluster mode)
#   - **bcrypt password hashing**
#     (Keats/bcrypt for admin password
#     storage)
#
# Distinguishing features vs Java Nacos:
#   - **Memory safety** (Rust eliminates
#     JVM-class CVE patterns;
#     particularly important for
#     internet-facing config services)
#   - **Single binary** (no JVM + war
#     deployment + Tomcat embedded)
#   - **Native gRPC** (vs Java Nacos
#     using server-side wrapping of
#     HTTP)
#   - **SQLite + sled embedded storage**
#     (vs Java Nacos requiring MySQL
#     for any non-trivial deployment)
#   - **Cross-platform binaries**
#     (Linux + macOS + Windows; Docker-
#     friendly)
#
# Use cases:
#   - **Microservice config management**
#     (centralized config for Java/Go/
#     Python services)
#   - **Service mesh registry**
#     (service discovery for non-
#     Kubernetes deployments)
#   - **Migration off Java Nacos**
#     (existing Nacos users seeking
#     better performance + simpler ops)
#   - **Edge deployments** (resource-
#     constrained environments where
#     JVM is too heavy)
#
# Usage:
#   rnacos [global flags] [<command>]
#
# Without arguments, rnacos starts the
# server in standalone mode (reading
# configuration from environment +
# data directory).
#
# Global flag:
#   -e, --env-file <path>          - .env
#                                     file
#                                     path
#                                     (default:
#                                     ".env"
#                                     in
#                                     current
#                                     directory)
#
# Subcommands (data migration tools):
#   data-to-sqlite <file> <out>    - convert
#                                     transfer
#                                     middle
#                                     data
#                                     file to
#                                     SQLite
#                                     db
#   sqlite-to-data <file> <out>    - convert
#                                     SQLite
#                                     db
#                                     back to
#                                     transfer
#                                     middle
#                                     data
#   mysql-to-data <uri> <out>      - extract
#                                     Nacos
#                                     MySQL
#                                     db to
#                                     transfer
#                                     middle
#                                     data
#                                     file
#   openapi-to-data <host> <out>   - extract
#                                     from
#                                     live
#                                     Nacos
#                                     server
#                                     via
#                                     OpenAPI
#                                     to
#                                     transfer
#                                     middle
#                                     data
#                                     file
#
# `openapi-to-data` flags:
#   -u, --username <user>          - Nacos
#                                     auth
#                                     username
#                                     (default
#                                     empty)
#   -p, --password <pass>          - Nacos
#                                     auth
#                                     password
#                                     (default
#                                     empty)
#
# Server configuration via environment
# variables (env file or shell):
#
# Network:
#   RNACOS_HTTP_PORT               - HTTP API
#                                     port
#                                     (default
#                                     8848)
#   RNACOS_GRPC_PORT               - gRPC API
#                                     port
#                                     (default
#                                     9848)
#   RNACOS_HTTP_CONSOLE_PORT       - separate
#                                     console
#                                     port
#                                     (optional)
#   RNACOS_HTTP_WORKERS            - HTTP
#                                     worker
#                                     thread
#                                     count
#                                     (default
#                                     cpu
#                                     count)
#
# Storage:
#   RNACOS_CONFIG_DB_DIR           - SQLite
#                                     storage
#                                     directory
#                                     (default
#                                     ./
#                                     nacos_db)
#   RNACOS_DATA_DIR                - top-
#                                     level
#                                     data
#                                     directory
#
# Auth:
#   RNACOS_INIT_ADMIN_USERNAME     - initial
#                                     admin
#                                     username
#                                     (default
#                                     "nacos")
#   RNACOS_INIT_ADMIN_PASSWORD     - initial
#                                     admin
#                                     password
#                                     (bcrypt-
#                                     hashed +
#                                     stored
#                                     on
#                                     first
#                                     boot)
#
# Cluster (Raft):
#   RNACOS_RAFT_NODE_ID            - cluster
#                                     node ID
#                                     (1, 2,
#                                     3, ...)
#   RNACOS_RAFT_NODE_ADDR          - this
#                                     node's
#                                     address
#                                     (ip:
#                                     port)
#   RNACOS_RAFT_AUTO_INIT          - auto-
#                                     initialize
#                                     single-
#                                     node
#                                     cluster
#                                     (true/
#                                     false)
#   RNACOS_RAFT_JOIN_ADDR          - existing
#                                     node to
#                                     join
#                                     cluster
#                                     via
#
# Example invocations:
#   # Start server with default config
#   rnacos
#
#   # Start with custom env file
#   rnacos -e /etc/rnacos/.env
#
#   # Migrate Java Nacos MySQL data
#   rnacos mysql-to-data \
#     'mysql://nacos:password@mysql.example.com:3306/nacos' \
#     /tmp/nacos-export.bin
#
#   # Then import to rnacos sqlite
#   rnacos data-to-sqlite \
#     /tmp/nacos-export.bin \
#     ./nacos_db/nacos.db
#
#   # Export live Nacos server via OpenAPI
#   rnacos openapi-to-data \
#     -u admin -p password \
#     '127.0.0.1:8848' \
#     /tmp/nacos-export.bin
#
#   # Export rnacos sqlite to transfer
#   # data file (for backup/migration)
#   rnacos sqlite-to-data \
#     ./nacos_db/nacos.db \
#     /backup/nacos-backup.bin
#
# Docker deployment:
#   ```bash
#   docker run -d \
#     --name rnacos \
#     -p 8848:8848 -p 9848:9848 \
#     -v ./nacos_db:/io:rw \
#     -e RNACOS_INIT_ADMIN_PASSWORD='nacos' \
#     ghcr.io/nacos-group/rnacos:stable
#   ```
#
# The bcrypt lane is built on `bcrypt =
# "0.15"` (declared verbatim at upstream
# Cargo.toml HEAD as a direct dep,
# imported by the auth module for hashing
# admin user passwords with bcrypt before
# storing them in the SQLite users
# table), the canonical Rust bcrypt
# password hashing library by Vincent
# Prouillet (Keats) - github.com/Keats/
# rust-bcrypt.
#
# Keats/rust-bcrypt is the de-facto
# canonical Rust bcrypt library:
#   - **RFC 8018 compliant** (the
#     canonical bcrypt spec; same
#     algorithm as OpenBSD's bcrypt +
#     Java's BCryptPasswordEncoder +
#     Node's bcrypt)
#   - **Pure-Rust implementation**
#     (no C dependencies; no
#     blowfish-sys FFI)
#   - **Constant-time comparison**
#     (verify function uses constant-
#     time comparison to prevent
#     timing attacks)
#   - **Configurable work factor**
#     (cost parameter from 4 to 31;
#     higher = more secure but
#     slower)
#   - **800+ stars on github.com/
#     Keats/rust-bcrypt**
#   - **~4,500 reverse-deps on
#     crates.io (the canonical Rust
#     bcrypt library)**
#
# bcrypt's distinguishing position vs
# Rust password hashing alternatives:
#   - Keats/rust-bcrypt (Prouillet):
#     canonical Rust bcrypt
#     implementation; THIS AXIS
#   - argon2 (RustCrypto/password-
#     hashes): modern alternative to
#     bcrypt; more memory-hard;
#     RustCrypto's canonical
#     implementation; newer
#     applications increasingly
#     prefer Argon2 over bcrypt
#   - scrypt: another bcrypt
#     alternative; less common than
#     bcrypt or Argon2
#   - pbkdf2 (RustCrypto/password-
#     hashes): PKCS#5-compatible
#     password derivation
#
# Vincent Prouillet (Keats) is a
# French/British Rust developer with
# extensive contributions across the
# Rust web ecosystem:
#   - **Keats/rust-bcrypt** (THIS
#     AXIS; canonical Rust bcrypt)
#   - **Keats/jsonwebtoken** (canonical
#     Rust JWT library; documented at
#     Axis 202 Rust opener earlier
#     in the corpus)
#   - **Keats/tera** (canonical Rust
#     template engine; Jinja2-
#     inspired; ~3,400 stars; used
#     by Zola SSG)
#   - **Keats/validator** (canonical
#     Rust struct validation derive
#     macro)
#   - **Keats/dotenv-linter** (lint
#     .env files)
#
# Prouillet's role in Rust is *web
# application + security
# infrastructure*. His libraries
# collectively form a coordinated
# Rust web backend stack:
#   - tera (templating)
#   - validator (input validation)
#   - jsonwebtoken (JWT auth)
#   - bcrypt (password storage)
#   - dotenv-linter (config
#     management)
#
# Prouillet's contribution pattern is
# *cross-vertical coordinated security
# + web library author* - few Rust
# canonical authors maintain canonical-
# status libraries across as many
# adjacent verticals (templating + auth
# + validation + password hashing).
#
# Multi-axis canonical-Rust author/org
# cohort consolidation (Prouillet
# previously documented at Axis 202
# Rust opener via jsonwebtoken):
#   - + Vincent Prouillet (Keats;
#     rust-bcrypt + jsonwebtoken +
#     tera + validator + dotenv-
#     linter); THIS AXIS extends
#     Prouillet's canonical-Rust
#     presence to password hashing
#     vertical
#
# Prouillet's multi-axis canonical
# presence (Axis 202 JWT + Axis 294
# bcrypt) reflects the *coordinated
# security library author* pattern -
# password hashing + JWT authentication
# are foundational web security
# primitives, and Prouillet maintains
# canonical Rust implementations of
# both. This *security stack
# specialist* pattern is rare in the
# Rust ecosystem.
#
# rnacos uses Keats/bcrypt for:
#   - Hashing admin user passwords
#     during user creation (rnacos
#     console + OpenAPI auth)
#   - Verifying passwords during
#     login (constant-time bcrypt
#     verify)
#   - Migrating Java Nacos password
#     hashes (Java Nacos uses
#     BCryptPasswordEncoder; rnacos's
#     bcrypt is wire-compatible)
#
# This is the canonical use case for
# bcrypt in production Rust services:
# password storage where backward
# compatibility with Java/Go/Node
# bcrypt hashes matters (rnacos
# migrating from Java Nacos must
# accept the existing bcrypt-hashed
# passwords without re-prompting
# users).
#
# ----------------------------------------------------------------------------
# AXIS 294 :: bcrypt password hashing
#              libraries
#              (RFC 8018 compliant
#              password hashing with
#              configurable work factor;
#              constant-time verification)
# Round 1580 :: Rust slot 1 of 4 :: OPENS Axis 294
#
# Cross-language canonical library family
# for this axis (proposed):
#   Rust    : Keats/rust-bcrypt          - Vincent
#                                          Prouillet
#                                          (canonical
#                                          Rust
#                                          bcrypt;
#                                          pure-
#                                          Rust;
#                                          part of
#                                          Prouillet's
#                                          web
#                                          security
#                                          stack)
#   Go      : golang.org/x/crypto/bcrypt - Go team
#                                          (canonical
#                                          Go bcrypt
#                                          in the
#                                          official
#                                          extended
#                                          crypto
#                                          library)
#   TS/Node : kelektiv/node.bcrypt.js    - Nick
#             OR                            Campbell +
#             dcodeIO/bcrypt.js              kelektiv
#                                          community
#                                          (canonical
#                                          Node
#                                          bcrypt;
#                                          native
#                                          bindings)
#
# bcrypt is the *de-facto standard
# password hashing algorithm* for
# applications storing user passwords:
#   - **Designed by Niels Provos +
#     David Mazières** (USENIX 1999)
#   - **OpenBSD origin** (initially
#     implemented in OpenBSD's
#     crypt(3))
#   - **Adaptive work factor** (cost
#     parameter increases compute
#     time + memory; can be tuned to
#     match Moore's Law)
#   - **Salt built-in** (no separate
#     salt parameter; salt is part
#     of the hash output)
#   - **Industry standard** (used by
#     virtually every web framework's
#     default password storage:
#     Django + Rails + Spring + ASP
#     .NET + Express + Laravel + ...)
#
# Each canonical library provides:
#   - bcrypt hashing (RFC 8018)
#   - Constant-time verification
#   - Configurable work factor (cost
#     parameter)
#   - Salt generation + management
#   - Wire-format compatibility
#     across languages
#
# Use-case spectrum for this axis (so far):
#   - rnacos (Rust, Keats/rust-bcrypt):
#     Nacos Rust port using bcrypt for
#     admin user password storage +
#     Java Nacos hash migration
#     compatibility
# ============================================================================

_rnacos() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-e --env-file)'{-e+,--env-file=}'[.env file path]:file:_files' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_rnacos_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                data-to-sqlite|sqlite-to-data)
                    _arguments \
                        '1:input file:_files' \
                        '2:output file:_files'
                    ;;
                mysql-to-data)
                    _arguments \
                        '1:mysql uri:' \
                        '2:output file:_files'
                    ;;
                openapi-to-data)
                    _arguments \
                        '(-u --username)'{-u+,--username=}'[Nacos auth username]:user:' \
                        '(-p --password)'{-p+,--password=}'[Nacos auth password]:pass:' \
                        '1:Nacos host:_hosts' \
                        '2:output file:_files'
                    ;;
            esac
            ;;
    esac

    return ret
}

_rnacos_cmds() {
    local -a cmds
    cmds=(
        'data-to-sqlite:convert transfer middle data file to SQLite db'
        'sqlite-to-data:convert SQLite db back to transfer middle data'
        'mysql-to-data:extract Nacos MySQL db to transfer middle data file'
        'openapi-to-data:extract from live Nacos server via OpenAPI to transfer data'
    )
    _describe -t commands 'rnacos command' cmds
}

_rnacos "$@"
