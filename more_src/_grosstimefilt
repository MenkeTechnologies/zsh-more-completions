#compdef grosstimefilt
# Filters an input file so only data from within given time ranges is written out

local ret=1

_arguments -s \
  '-i[input filename to be processed]:input file:_files' \
  '-f[output filename for filtered data]:output file:_files' \
  '-r[raw time mode, interpret ranges as in the data file]' \
  '-a[absolute time mode, add TIMEZERO to timestamps]' \
  '-t[time ranges]:ranges:' \
  '-c[save the processed file upon completion]:flag:(yes no)' \
  '-h[display help information]' \
  '*:file:_files' && ret=0

return ret
