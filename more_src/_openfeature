#compdef openfeature
# Documentation: https://github.com/open-feature/cli
# Reference accessed: 2026-05-20
# Verified: open-feature/cli upstream README - subcommands init, manifest,
# compare, generate, pull, push, version (no completion/help subcommands).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a new flag manifest in the project'
  'manifest:manage flag definitions (add/list/delete)'
  'generate:generate strongly-typed flag accessors'
  'compare:compare two feature flag manifests'
  'pull:fetch flag configurations from a remote source'
  'push:push local flag configurations to a remote service'
  'version:print the version number of the OpenFeature CLI'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--manifest=[path to flag manifest]:file:_files -g "*.{json,yaml,yml}"' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'openfeature command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (manifest)
        _arguments \
          '*::sub:(add list delete)' \
          '--name=[flag name]:name:' \
          '--type=[flag type]:type:(boolean string number object)' \
          '--default=[default value]:value:' \
          '--description=[flag description]:desc:' && ret=0 ;;
      (generate)
        _arguments \
          '--output=[output directory]:dir:_files -/' \
          '*::language:(react go csharp java python nestjs nodejs angular typescript)' && ret=0 ;;
      (compare)
        _arguments \
          '--against=[path to comparison manifest]:file:_files' \
          '--output=[output format]:format:(tree flat json yaml)' && ret=0 ;;
      (pull|push)
        _arguments \
          '--flag-source-url=[remote flag source URL]:url:' \
          '--auth-token=[authentication token]:token:' \
          '--dry-run[print changes without applying]' && ret=0 ;;
      (init)
        _arguments \
          '--force[overwrite existing manifest]' && ret=0 ;;
    esac ;;
esac

return ret
