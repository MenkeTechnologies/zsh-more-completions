#compdef chase
# ============================================================================
#  _chase — chase: A formal-methods tool for solving geometric form satisfaction
#           problems (theorem prover output filter)
#
#  Source-direct extraction from
#    https://github.com/ramsdell/chase/blob/master/filter.ml
#    https://github.com/ramsdell/chase/blob/master/chase.ml
#    https://github.com/ocaml-getopt/ocaml-getopt (the Getopt library
#    by Alain Frisch)
#
#  Maintained by John Ramsdell, MITRE Corporation (ramsdell/chase).
#  6 GH stars.  chase is a theorem-prover-output filter for geometric
#  satisfaction problems — reads a logical theory, finds all "small"
#  models satisfying the theory.  Sister tools: paradox (model finder),
#  mace4 (Otter/Prover9 model finder), z3 (SMT solver, in corpus).
#
#  CLI library taxonomy update: 5th OCaml CLI library — Alain Frisch's
#  ocaml-getopt.  OCaml ecosystem now has 5 documented CLI libraries
#  (R271 Cmdliner + R325 stdlib Arg + R331 Jane Street Core.Command +
#  R339 rbardou/Clap + R369 ocaml-getopt) joining the multi-library
#  leaders.  OCaml ties Rust (9) for second place in documented CLI
#  library count after Go (9).
#
#  ocaml-getopt (ocaml-getopt/ocaml-getopt) is Alain Frisch's port of
#  GNU getopt_long to OCaml — used by Hercules emulator, libguestfs
#  virt-* tools, ligo blockchain compiler, dry-analyzer (Ethereum),
#  Synduce, and many other OCaml CLIs that need POSIX getopt semantics.
#
#  ocaml-getopt API:
#    open Getopt
#
#    let output = ref ""
#    let version = ref false
#    let help = ref false
#
#    let specs = [
#      ('o', "output", None, Getopt.atmost_once output
#                              (Getopt.Error "only one output"));
#      ('v', "version", Getopt.set version true, None);
#      ('h', "help", Getopt.set help true, None);
#    ]
#
#    let add_arg arg = ...
#
#    try Getopt.parse_cmdline specs add_arg
#    with Getopt.Error s -> prerr_endline s; exit 1
#
#  ocaml-getopt distinctive features:
#    - GNU getopt_long PORT to OCaml — POSIX getopt(3) semantics
#    - SPEC is a LIST OF 4-TUPLES: `(short_char, long_name,
#      no_arg_action_option, value_action_option)` — each tuple
#      describes ONE option
#    - `Getopt.set REF VALUE` — no-arg action that sets REF to VALUE
#    - `Getopt.atmost_once REF (Error MSG)` — value-arg action that
#      stores into REF, errors if seen twice
#    - `Getopt.append REF` — value-arg action that appends to a list REF
#    - `Some FN` for callback functions (caller-supplied closure)
#    - `None` for "this option has no no-arg action" (or no value action)
#    - `Getopt.parse_cmdline SPECS ANON_FN` — parses argv, calling
#      ANON_FN for each positional arg
#    - `Getopt.Error MSG` exception for invalid specs/values
#  Distinct from R271 OCaml Cmdliner (term-applicative-combinator with
#  auto-generated man pages), R325 OCaml stdlib Arg (mutable ref-cell
#  binding with `Arg.parse spec_list anon_fn usage_msg`), R331 OCaml
#  Jane Street Core.Command (PPX `let%map_open.Command` applicative),
#  R339 OCaml rbardou/Clap (imperative consumption mechanism with
#  global parser state), R272 C POSIX getopt (C language), R287 Nim
#  parseopt (low-level Nim iteration).  ocaml-getopt's approach: GNU
#  getopt_long PORT with SPEC AS LIST OF 4-TUPLES + REF-BASED MUTATION
#  + `Getopt.set`/`atmost_once`/`append` HELPER ACTIONS — corpus's
#  **first documented GNU-getopt_long-port-to-OCaml CLI pattern**.
#  Brings cross-language CLI library taxonomy variant count to 108;
#  OCaml ecosystem now has 5 documented CLI libraries.
#
#  Surface (verbatim from filter.ml `specs`):
#
#  Options:
#    -o, --output=FILE          Output file (default: stdout;
#                               at-most-once enforced)
#    -v, --version              Print version number
#    -h, --help                 Print help message
#
#  Positional:
#    <input>                    Input theory file (default: stdin)
#
#  Dup-skipped neighbors during hunt (in corpus, smaller surface):
#    - virt-builder / virt-cat / virt-customize / virt-df / virt-diff /
#      virt-edit / virt-format / virt-get-kernel / virt-inspector /
#      virt-log / virt-ls / virt-make-fs / virt-sparsify / virt-sysprep /
#      virt-tail (libguestfs/guestfs-tools — IN CORPUS, ALL use
#      ocaml-getopt internally via drivers.ml shared module)
#    - guestmount, virt-resize (IN CORPUS)
#    - synduce (synduce/Synduce 10 stars — uses ocaml-getopt; HOLD)
#    - dry-analyzer (pirapira/dry-analyzer 41 stars — uses ocaml-
#      getopt; binary name `main.native` not user-facing)
#    - ligo (ligolang/ligo 18 stars — uses GetoptLib.Getopt in lexer
#      CLI module; binary is hand-rolled at top level)
#    - jaq (searabbitx/jaq 0 stars — IN CORPUS via different jaq tool)
# ============================================================================

_chase() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-o --output)'{-o,--output}'=[output file (default stdout)]:file:_files' \
    '(-v --version)'{-v,--version}'[print version number]' \
    '(-h --help)'{-h,--help}'[print help message]' \
    '1:input theory file:_files'
}

_chase "$@"
