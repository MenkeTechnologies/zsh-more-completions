#compdef talhelper

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'completion:generate autocompletion script'
  'gencommand:generate commands for talosctl'
  'genconfig:generate Talos cluster config YAML files'
  'genschema:generate talconfig.yaml JSON schema'
  'gensecret:generate Talos cluster secrets'
  'genurl:generate URL for Talos installer or ISO'
  'validate:validate talconfig or Talos node config'
)

_arguments -C \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'talhelper subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (gencommand)
        _values 'gencommand target' \
          'apply' 'bootstrap' 'health' 'kubeconfig' 'reset' \
          'upgrade' 'upgrade-k8s' && ret=0
        ;;
      (genurl)
        _values 'genurl target' 'image' 'installer' && ret=0
        ;;
      (validate)
        _values 'validate target' 'nodeconfig' 'talconfig' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'fish' 'powershell' 'zsh' && ret=0
        ;;
    esac
    ;;
esac

return ret
