#compdef mtransfer
# Documentation: https://rueckstiess.github.io/mtools/
# mtools export and import MongoDB databases via metadata transfer

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--verbose[show extra information]' \
  '--dbpath=[path to the MongoDB database files]:path:_files -/' \
  '1:command:(export import)' \
  '2:database:' && ret=0

return ret
