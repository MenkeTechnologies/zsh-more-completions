#compdef rcl
# _rcl — reasonable configuration language CLI (ruuda/rcl)
# upstream: https://github.com/ruuda/rcl
# Subcommands + flags from src/cli.rs.

_rcl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global
    global=(
        '--about[print license and dependency information]'
        '--color=[output color mode]:mode:(ansi auto html none)'
        '(-C --directory)'{-C+,--directory=}'[change working directory]:dir:_files -/'
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
    )

    _arguments -C $global \
        '1: :_rcl_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                build)
                    _arguments \
                        '--check[exit 1 if files would be created/rewritten]' \
                        '--dry-run[print to stdout instead of writing files]' \
                        '--sandbox=[sandbox mode]:mode:(workdir unrestricted)' \
                        '1:buildfile:_files -g "*.rcl"'
                    ;;
                evaluate|eval|e|query|q|je|jq|re|rq)
                    _arguments \
                        '(-f --format)'{-f+,--format=}'[output format]:format:(json json-lines raw rcl toml toml-1.0 toml-1.1 yaml-stream)' \
                        '(-o --output)'{-o+,--output=}'[write output to file]:file:_files' \
                        '--output-depfile=[write a make-style depfile to this path]:file:_files' \
                        '--banner=[prepend this string to the output]:banner:' \
                        '--sandbox=[sandbox mode]:mode:(workdir unrestricted)' \
                        '(-w --width)'{-w+,--width=}'[target width in columns]:n:' \
                        '*:input file:_files -g "*.rcl"'
                    ;;
                format|fmt|f)
                    _arguments \
                        '--check[exit 1 if files would be reformatted]' \
                        '(-i --in-place)'{-i,--in-place}'[modify the input file in place]' \
                        '(-o --output)'{-o+,--output=}'[write output to file]:file:_files' \
                        '(-w --width)'{-w+,--width=}'[target width in columns]:n:' \
                        '*:input file:_files -g "*.rcl"'
                    ;;
                highlight|h)
                    _arguments '1:file:_files -g "*.rcl"'
                    ;;
                patch)
                    _arguments \
                        '--check[exit 1 if file would be modified]' \
                        '(-o --output)'{-o+,--output=}'[write output to file]:file:_files' \
                        '1:file:_files -g "*.rcl"' \
                        '2:path:' \
                        '3:replacement:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_rcl_commands] )) ||
_rcl_commands() {
    local -a commands
    commands=(
        'build:write formatted evaluation results to files'
        'evaluate:evaluate a document to an output format'
        'eval:alias for evaluate'
        'e:alias for evaluate'
        'je:eval with --format=json'
        'jq:query with --format=json'
        're:eval with --format=raw'
        'rq:query with --format=raw'
        'format:auto-format an RCL document'
        'fmt:alias for format'
        'f:alias for format'
        'highlight:print a document with syntax highlighting'
        'h:alias for highlight'
        'patch:replace a value inside an RCL document'
        'query:evaluate an expression against an input document'
        'q:alias for query'
    )
    _describe -t commands 'rcl command' commands
}

_rcl "$@"
