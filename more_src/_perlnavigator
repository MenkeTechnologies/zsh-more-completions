#compdef perlnavigator
# Documentation: https://github.com/bscan/PerlNavigator
# Reference accessed: 2026-05-27
# Verified: upstream server/src/server.ts (defaults to --stdio); other flags are vscode-languageserver/node connection transports

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(--socket --node-ipc --pipe)--stdio[communicate over stdin/stdout (default)]' \
  '(--stdio --node-ipc --pipe)--socket=[communicate over a TCP socket]:port:' \
  '--port=[TCP port for --socket transport]:port:' \
  '(--stdio --socket --pipe)--node-ipc[communicate over Node IPC]' \
  '(--stdio --socket --node-ipc)--pipe=[communicate over a named pipe]:name:' \
  '--clientProcessId=[parent process id; server exits when it dies]:pid:' \
  '*:file:_files' && ret=0

return ret
