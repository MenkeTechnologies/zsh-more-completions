#compdef alan
# ============================================================================
# _alan — zsh completion for Alan, David Ellis's autoscalable
#          programming language compiler (155th language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/alantech/alan
#   Website    : https://alan-lang.org
#   Author     : David Ellis  <isv.damocles@gmail.com> + alantech
#   License    : MIT
#   Stars      : 320
#   Language   : Rust (compiler) / Alan (.ln source files)
#   Crate      : alan v0.2.0  (workspace member under alan/)
#   Binary     : alan  (alan/Cargo.toml [package] name = "alan",
#                       built from alan/src/main.rs)
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   Alan is "the autoscalable programming language" — David Ellis's
#   data-parallel language whose semantics deliberately hide the
#   distinction between "this code runs on the CPU", "on the GPU
#   via wgpu", and "across many machines as scheduled work."  Source
#   files use the `.ln` extension and are compiled by the `alan`
#   driver into one of several outputs:  a native executable, a
#   transpiled Rust crate, a transpiled JavaScript module, or a web
#   bundle suitable for browser execution.  A test-mode driver
#   re-uses the same source under either the native runtime or the
#   Node.js runtime, and an install command resolves `.ln`
#   dependencies declared in `.dependencies.ln`.
#
# CLI ARGUMENT GRAMMAR  (verbatim from alan/src/main.rs clap-derive
#                       Cli + Commands enum)
#   alan [<LN_FILE>]
#   alan <SUBCOMMAND> [args...]
#
#   With a single positional `<LN_FILE>` argument and no subcommand,
#   the binary prints "TODO: Interpreter mode someday" — the
#   interpreter mode is reserved but not yet implemented.
#
#   Subcommands (every subcommand accepts an optional `<LN_FILE>`
#   positional that defaults to `./index.ln`):
#     bundle  [<LN_FILE>]    Compile `.ln` file(s) to a web bundle
#     compile [<LN_FILE>]    Compile `.ln` file(s) to an executable
#     to-rs   [<LN_FILE>]    Compile `.ln` file(s) to Rust source
#     to-js   [<LN_FILE>]    Compile `.ln` file(s) to JavaScript
#                            source
#     test    [<LN_FILE>]    Test a specified `.ln` file
#       -j, --js               Test via JavaScript & Node.js
#                              instead of natively
#     install [<DEP_FILE>]   Install dependencies for the project
#                            (runs the install script — defaults to
#                             `./.dependencies.ln`)
#
#   Standard clap auto-flags (with `propagate_version`):
#     -h, --help             Show help
#     -V, --version          Show version
#
# LANGUAGE-CORPUS POSITION
#   Alan is the 155th programming language entry in this completion
#   corpus, closing the 3+1 micro-cycle that began at R889 (_logram
#   / teloxide 0.3 Rust=130 OPENS Axis 75 Telegram Bot API Client
#   Library — round-number Rust=130 landmark) and continued through
#   R890 (_tg-bot / go-telegram-bot-api v4.6.4 Go=130 — round-number
#   R890 commit landmark) and R891 (_tele-aria2 / telegraf ^3.38.0
#   TS-Node=130 CLOSES Axis 75 at 1/1/1 three-language symmetry —
#   triple-130 landmark and 68th axis closed).  Alan joins Mech
#   (R888 154th — triple-8 commit landmark), Lisette (R884 153rd),
#   Bril (R880 152nd), Vyxal (R876 151st), EYG (R872 150th —
#   round-number language milestone), Roto (R868 149th), Pipefish
#   (R864 148th), Mochi (R860 147th), Oden (R856 146th), Hop (R852
#   145th), Lustre via Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ
#   (R840 142nd), Granule (R836 141st), Sixten (R832 140th), Imba
#   (R828 139th), Tao (R824 138th), Dada (R820 137th), Acton (R816
#   136th), and Stanza (R812 135th).
#
#   No completion for `alan` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_alan() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_alan_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                bundle|compile|to-rs|to-js)
                    _arguments \
                        ':Alan source file (default ./index.ln):_files -g "*.ln"' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                test)
                    _arguments \
                        '(-j --js)'{-j,--js}'[test via JavaScript & Node.js instead of natively]' \
                        ':Alan source file (default ./index.ln):_files -g "*.ln"' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                install)
                    _arguments \
                        ':dependencies file (default ./.dependencies.ln):_files -g "*.ln"' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_alan_commands] )) ||
_alan_commands() {
    local -a commands
    commands=(
        'bundle:compile .ln file(s) to a web bundle'
        'compile:compile .ln file(s) to a native executable'
        'to-rs:compile .ln file(s) to Rust source'
        'to-js:compile .ln file(s) to JavaScript source'
        'test:test a specified .ln file'
        'install:install dependencies for the Alan project'
    )
    _describe -t commands 'alan command' commands
}

_alan "$@"
