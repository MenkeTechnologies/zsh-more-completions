# -----------------------------------------------------------------------------
#
# WHY tokio-tungstenite IS THE 72ND RUST CLI LIBRARY
#
# tokio-tungstenite is the de-facto Rust async WebSocket client
# (and server).  Underlying `tungstenite-rs` provides the
# runtime-agnostic protocol implementation; `tokio-tungstenite`
# adapts it for the tokio runtime, exposing the WebSocket stream
# as Stream + Sink for natural integration with the futures
# ecosystem.
#
# Five distinguishing characteristics:
#
#   1. RFC 6455 PROTOCOL — handshake (HTTP/1.1 Upgrade), framing,
#      masking (client-to-server), unmasking (server-to-client),
#      ping/pong heartbeats, close codes (1000-4999), text vs
#      binary messages.  Distinct from HTTP libraries (reqwest,
#      hyper) which handle one-shot request/response cycles.
#
#   2. STREAM + SINK TRAITS — WebSocketStream implements
#      futures_util::Stream<Item = Result<Message, Error>> +
#      futures_util::Sink<Message, Error = Error>.  Integrates
#      with select! / merge / forward / split combinators.
#      Distinct from callback-based APIs.
#
#   3. SYNC + ASYNC SPLIT — separate `tungstenite` (sync) and
#      `tokio-tungstenite` (async tokio) + `async-tungstenite`
#      (async-std / smol) crates.  This factoring enables sync
#      use cases (CLI scripts, blocking servers) and async use
#      cases.  notify (R653) has a similar PollWatcher /
#      RecommendedWatcher split.
#
#   4. TLS BACKEND CHOICE — native-tls / rustls via Cargo
#      features.  Default is native-tls (libssl on Linux,
#      SChannel on Windows, Secure Transport on macOS).
#      Distinct from reqwest (also offers choice but with
#      default rustls).
#
#   5. SNAPVIEW / DANIEL-ABRAMOV ECOSYSTEM — distinct maintainer
#      from Sean McArthur (Hyperium), François Mockers (notify-
#      rs), Tolnay (serde), Sorhus (Node CLI).  snapview is a
#      Swiss-based Rust shop maintaining the foundational
#      Rust WebSocket stack.
#
# -----------------------------------------------------------------------------
#
# THE aspeak CLI — clap derive + tokio-tungstenite + reqwest + rodio + toml
#
# aspeak's CLI is in src/cli/args.rs + commands.rs.  Uses
# clap v4 derive with #[derive(Parser)] root + #[derive(Subcommand)]
# Command enum.
#
# Subcommands:
#   text [--file FILE] [--encoding ENC] [--mode rest|websocket]
#                                       [--output PATH] [--quality N]
#                                       [--container-format mp3|ogg|webm|wav]
#                                       [--format AZURE_FORMAT]
#                                       [TEXT]
#                       Speak plain text
#   ssml [--file FILE] [--encoding ENC] [--mode rest|websocket]
#                                       [--output PATH] ...
#                                       [SSML]
#                       Speak SSML markup
#   list-voices [-v VOICE] [-l LOCALE] [-u URL]
#                       List available voices
#   list-qualities      List available quality levels
#   list-formats        List available audio formats
#   config edit         Open default profile in editor
#   config init [--path PATH] [--overwrite]
#                       Initialize new profile
#   config where        Show full path to default profile
#
# Global auth flags (apply to text / ssml / list-voices):
#   --no-profile          do not use any profile config
#   --profile NAME        use specific profile from ~/.aspeak.toml
#   -e, --endpoint URL    full TTS API endpoint URL
#   -r, --region REGION   Azure region (auto-resolves endpoint)
#   -t, --token TOKEN     Azure auth token
#   -k, --key KEY         Azure subscription key
#   -H, --headers HDR     additional request headers (multiple)
#       --proxy URL       HTTP / SOCKS5 proxy URL
#
# tokio-tungstenite is used in src/synthesizer/ for the
# websocket-synthesizer feature path (--mode websocket).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/kxxt/aspeak/blob/main/src/cli/args.rs
# https://github.com/kxxt/aspeak/blob/main/src/cli/commands.rs
# clap derive #[arg] + #[command] definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _aspeak_cmds _aspeak_config_cmds _aspeak_modes _aspeak_formats _aspeak_colors
_aspeak_cmds=(
    'text:speak plain text (default)'
    'ssml:speak SSML markup'
    'list-voices:list available voices (filterable by --locale / --voice)'
    'list-qualities:list available quality levels'
    'list-formats:list available audio formats'
    'config:manage aspeak profiles'
    'help:show help for a subcommand'
)
_aspeak_config_cmds=(
    'edit:open default profile in your editor'
    'init:initialize a new profile'
    'where:show full path to the default profile'
)
_aspeak_modes=('rest:HTTP REST POST mode' 'websocket:streaming WebSocket mode (via tokio-tungstenite)')
_aspeak_formats=('mp3:MP3 container' 'ogg:Ogg container' 'webm:WebM container' 'wav:WAV container')
_aspeak_colors=('auto:auto-detect' 'always:always color' 'never:never color')

local auth_flags
auth_flags=(
    '--no-profile[do not use any profile config]'
    '--profile=[use specific profile name]:profile:_default'
    '(-e --endpoint)'{-e+,--endpoint=}'[full TTS API endpoint URL]:url:_default'
    '(-r --region)'{-r+,--region=}'[Azure region (auto-resolves endpoint)]:region:_default'
    '(-t --token)'{-t+,--token=}'[Azure auth token]:token:_default'
    '(-k --key)'{-k+,--key=}'[Azure subscription key]:key:_default'
    '*'{-H+,--headers=}'[additional request header]:header:_default'
    '--proxy=[HTTP / SOCKS5 proxy URL]:url:_default'
)

local output_flags
output_flags=(
    '(-o --output)'{-o+,--output=}'[output file path (use - for stdout)]:path:_files'
    '(-q --quality)'{-q+,--quality=}'[output quality level]:quality:_default'
    '(-c --container-format)'{-c+,--container-format=}'[output container format]:format:->container'
    '(-F --format)'{-F+,--format=}'[Azure-specific audio format]:format:_default'
)

local input_flags
input_flags=(
    '(-f --file)'{-f+,--file=}'[text/SSML file to speak (default stdin)]:file:_files'
    '(-e --encoding)'{-e+,--encoding=}'[text/SSML file encoding]:encoding:_default'
    '(-m --mode)'{-m+,--mode=}'[synthesizer mode]:mode:->mode'
)

_arguments -C \
    $auth_flags \
    '--color=[control color output]:color:->color' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'aspeak subcommand' _aspeak_cmds && ret=0
        ;;
    args)
        case $words[1] in
            text|ssml)
                _arguments \
                    $input_flags \
                    $output_flags \
                    '*:text:_default' \
                    && ret=0
                ;;
            list-voices)
                _arguments \
                    '(-v --voice)'{-v+,--voice=}'[voice to list]:voice:_default' \
                    '(-l --locale)'{-l+,--locale=}'[locale filter]:locale:_default' \
                    '(-u --url)'{-u+,--url=}'[voice list API URL]:url:_default' \
                    && ret=0
                ;;
            config)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'config subcommand' _aspeak_config_cmds && ret=0
                elif [[ $words[2] == init ]]; then
                    _arguments \
                        '(-p --path)'{-p+,--path=}'[new profile path]:path:_files' \
                        '--overwrite[overwrite existing profile]' \
                        && ret=0
                fi
                ;;
            help)
                _describe -t commands 'subcommand' _aspeak_cmds && ret=0
                ;;
        esac
        case $state in
            mode)      _describe -t modes 'synthesizer mode' _aspeak_modes && ret=0 ;;
            container) _describe -t formats 'container format' _aspeak_formats && ret=0 ;;
            color)     _describe -t colors 'color mode' _aspeak_colors && ret=0 ;;
        esac
        ;;
esac

return ret
