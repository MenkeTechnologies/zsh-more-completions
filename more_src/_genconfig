#compdef genconfig
# Documentation: https://github.com/ulfalizer/Kconfiglib
# genconfig - generate a C header of #defines from a Kconfig configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--header-path=[path to write the generated header file to]:file:_files' \
  '--config-out=[write the full configuration to this file]:file:_files' \
  '--sync-deps=[generate symbol dependency info into this directory]:dir:_files -/' \
  '--file-list=[write list of all Kconfig files to this file]:file:_files' \
  '--env-list=[write list of referenced environment variables to this file]:file:_files' \
  '*:kconfig file:_files' && ret=0

return ret
