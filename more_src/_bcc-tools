# _bcc-tools — iovisor bcc tools (curated Python + libbpf wrappers around BPF programs for kernel observability; per-tool flag surface differs but most accept -h help, -p pid, -c CPU, -i interval seconds, -T timestamps, -v verbose, -j JSON output, -d duration; many tools take a positional command to trace)
# upstream: https://github.com/iovisor/bcc (tools/)
# Common flags from iovisor/bcc tools/*.py on tip.

_bcc-tools() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '-p+[pid]:pid:_pids' \
        '-P+[ppid]:pid:_pids' \
        '-c+[cgroup path]:dir:_files -/' \
        '-d+[duration seconds]:seconds:' \
        '-i+[interval seconds]:seconds:' \
        '-T[timestamps]' \
        '-U[user-mode stacks]' \
        '-K[kernel-mode stacks]' \
        '-N[no headers]' \
        '-A[ip addresses w/o lookup]' \
        '-j[json output]' \
        '-m+[milliseconds]:ms:' \
        '-t+[threshold]:threshold:' \
        '-n+[name match]:name:' \
        '-q[quiet]' \
        '*:command:_command_names -e'
}

_bcc-tools "$@"
