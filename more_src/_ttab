#compdef ttab
# _ttab — Michael Klement ttab macOS Terminal/iTerm tab opener CLI (mklement0, JavaScript); custom argparse
# upstream: https://github.com/mklement0/ttab

_ttab() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--tab[open in new tab (default)]' \
        '-t[open in new tab (default)]' \
        '--window[open in new window]' \
        '-w[open in new window]' \
        '--app=+[terminal app]:app:(Terminal iTerm iTerm2)' \
        '-a+[terminal app]:app:(Terminal iTerm iTerm2)' \
        '--directory=+[working directory]:dir:_files -/' \
        '-d+[working directory]:dir:_files -/' \
        '--name=+[tab/window name]:str:' \
        '-T+[tab/window name]:str:' \
        '--profile=+[terminal profile/settings]:str:' \
        '-p+[terminal profile/settings]:str:' \
        '--group=+[group/tab assignment]:str:' \
        '-g+[group/tab assignment]:str:' \
        '--exec[exec command (replace shell)]' \
        '-e[exec command (replace shell)]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '*:cmd-and-args:_command_names -e'
}

_ttab "$@"
