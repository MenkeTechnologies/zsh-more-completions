#compdef gama
# Documentation: https://man.archlinux.org/search?q=gama
# Reference accessed: 2026-05-16

# https://github.com/termkit/gama — GitHub Actions TUI (`gama --help`)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '-v[version]' \
  '--version[version]' \
  '--github-token=-[PAT override]:token:' \
  '--repo=-[owner/repo filter]:repo:' \
  '*:ignored:_default'
