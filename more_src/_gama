#compdef gama
# Documentation: https://github.com/termkit/gama
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# termkit/gama: GitHub Actions TUI; flags from `gama --help`
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '-v[version]' \
  '--version[version]' \
  '--github-token=-[PAT override]:token:' \
  '--repo=-[owner/repo filter]:repo:' \
  '*:ignored:_default'
