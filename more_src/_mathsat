#compdef mathsat
# Documentation: https://mathsat.fbk.eu/documentation.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. The MathSAT documentation states the default
# input is SMT-LIB v2 and the input format is selected with -input; it also notes that
# the complete option set is available via the -help command-line switch. Only options
# explicitly documented on the upstream site are included here.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-input=[input format]:format:(smt2 smtlib1 dimacs)' \
  '-stats[print solver statistics]' \
  '-verbosity=[verbosity level]:n:' \
  '-random_seed=[random seed]:n:' \
  '*:smt2 file:_files -g "*.{smt2,smt}"' && ret=0

return ret
