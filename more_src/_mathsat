#compdef mathsat

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-input=[input format]:format:(smt2 smt dimacs)' \
  '-output=[output format]:format:(smt2 smt dimacs)' \
  '-stats[print solver statistics]' \
  '-verbosity=[verbosity level]:n:' \
  '-random_seed=[random seed]:n:' \
  '-model_generation=[model generation level]:n:(0 1 2 3)' \
  '-proof_generation=[proof generation level]:n:(0 1)' \
  '-unsat_core_generation=[unsat core level]:n:(0 1 2 3)' \
  '-interpolation=[interpolation level]:n:(0 1 2 3)' \
  '-print_model=[print model on sat]:bool:(true false)' \
  '-printer.model_as_formula=[model as formula]:bool:(true false)' \
  '-theory.la.split_rat_eq=[split equalities]:bool:(true false)' \
  '-theory.bv.eager=[bitblasting eagerness]:n:' \
  '-preprocessor.toplevel_propagation=[toplevel propagation]:bool:(true false)' \
  '-debug.solver_enabled=[enable debug mode]:bool:(true false)' \
  '*:smt2_file:_files -g "*.{smt2,smt}"' && ret=0

return ret
