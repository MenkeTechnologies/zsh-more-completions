#compdef synergyc
# Documentation: https://man.archlinux.org/search?q=synergyc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --debug)'{-d,--debug}'+[debug level]:level:(FATAL ERROR WARNING NOTE INFO DEBUG DEBUG1 DEBUG2)' \
  '(-n --name)'{-n,--name}'+[screen name]:name:' \
  '(-1 --no-restart)'{-1,--no-restart}'[do not restart on disconnect]' \
  '(--restart)--restart[restart on disconnect]' \
  '(-l --log)'{-l,--log}'+[log file]:file:_files' \
  '(-f --no-daemon)'{-f,--no-daemon}'[do not daemonize]' \
  '--daemon[daemonize]' \
  '--display=[X display]:display:' \
  '(--enable-crypto)--enable-crypto[enable SSL]' \
  '(--disable-crypto)--disable-crypto[disable SSL]' \
  '--profile-dir=[profile directory]:dir:_files -/' \
  '--plugin-dir=[plugin directory]:dir:_files -/' \
  '--yscroll=[Y scroll]:n:' \
  '*:server:_hosts' && ret=0

return ret
