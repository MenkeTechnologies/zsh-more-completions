#compdef synergyc
# Documentation: https://sources.debian.org/data/main/s/synergy/1.4.16-2/doc/synergyc.man
# Reference accessed: 2026-05-21
# Verified: upstream Synergy 1.4.16 synergyc(1) man source from Debian.
# Removed: --display, --enable-crypto, --disable-crypto, --profile-dir,
# --plugin-dir, --tls-cert (not in upstream manpage).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --debug)'{-d,--debug}'+[log filter level]:level:(FATAL ERROR WARNING NOTE INFO DEBUG DEBUG1 DEBUG2 DEBUG3 DEBUG4 DEBUG5)' \
  '(-n --name)'{-n,--name}'+[screen name]:name:' \
  '(-1 --no-restart)'{-1,--no-restart}'[do not restart on disconnect]' \
  '--restart[restart on disconnect (default)]' \
  '(-l --log)'{-l,--log}'+[log file]:file:_files' \
  '(-f --no-daemon)'{-f,--no-daemon}'[do not daemonize]' \
  '--daemon[daemonize (default)]' \
  '--yscroll=[vertical scrolling delta]:delta:' \
  '*:server:_hosts' && ret=0

return ret
