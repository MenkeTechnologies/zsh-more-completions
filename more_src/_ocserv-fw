#compdef ocserv-fw
# _ocserv-fw — OpenConnect ocserv-fw (firewall helper script invoked by ocserv connect/disconnect hooks; reads per-user IP / route / tun-device data via environment variables and installs corresponding iptables/nftables rules — typical args: --add to install rules, --del to remove, --interface tun device, --user username, --address client IP)
# upstream: https://gitlab.com/openconnect/ocserv
# Common flag shape from openconnect/ocserv doc/sample.ocserv-fw on tip.

_ocserv-fw() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--add[install firewall rules]' \
        '--del[remove firewall rules]' \
        '--interface+[tun device]:interface:_net_interfaces' \
        '--user+[username]:user:_users' \
        '--address+[client IP]:address:' \
        '--ipv6[apply to IPv6 chain]' \
        '--chain+[iptables chain]:chain:'
}

_ocserv-fw "$@"
