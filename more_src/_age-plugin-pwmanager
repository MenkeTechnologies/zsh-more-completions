#compdef age-plugin-pwmanager
# Documentation: https://github.com/pinpox/age-plugin-pwmanager
# use SSH keys from your password-manager with age

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--print-recipients[print public keys in OpenSSH authorized_keys format]' && ret=0

return ret
