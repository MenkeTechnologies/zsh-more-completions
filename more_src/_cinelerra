#compdef cinelerra cin
# Documentation: https://cinelerra-gg.org/download/CinelerraGG_Manual/CINELERRA_GG_Command_Line_h.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (Cinelerra-GG Manual).

# Cinelerra-GG: non-linear video editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-r[batch render job list]:job file:_files -g "*.xml"' \
  '-d[run in background as renderfarm client]:port:' \
  '-c[config file]:file:_files' \
  '-n[nice value if running as renderfarm client]:n:' \
  '*:project / clip:_files -g "*.(xml|cin|mp4|mkv|mov|avi|webm)"' && ret=0
return ret
