#compdef jiti

# Zsh completion for jiti - runtime TypeScript and ESM support for Node.js

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  '--debug[enable debug output]' \
  '--cache[enable filesystem cache]' \
  '--no-cache[disable filesystem cache]' \
  '--esmResolve[use ESM resolution algorithm]' \
  '--transform[enable source transformation]' \
  '--no-transform[disable source transformation]' \
  '--interopDefault[interop default exports]' \
  '--requireCache[use Node.js require cache]' \
  '(-e --eval)'{-e,--eval}'=[evaluate inline code]:code:' \
  '1:file:_files -g "*.{ts,mts,cts,js,mjs,cjs}"' \
  '*:args:'
