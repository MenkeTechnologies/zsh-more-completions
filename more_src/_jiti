#compdef jiti
# Documentation: https://github.com/unjs/jiti
# Reference accessed: 2026-05-17
# Verified: unjs/jiti upstream — thin CLI wrapper for runtime
# TypeScript/ESM loading. Real flags are minimal: --transform-only,
# --cache, --no-cache, -h/--help, -v/--version. Most config is via
# JITI_* env vars (JITI_DEBUG, JITI_CACHE, JITI_ALIAS,
# JITI_SOURCE_MAPS, JITI_TRANSFORM, JITI_INTEROP, JITI_JSX,
# JITI_FS_CACHE, JITI_MODULE_CACHE, JITI_EXTENSIONS).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --debug, --esmResolve, --interopDefault, --requireCache,
# -e/--eval, --transform/--no-transform (these are JITI_* env vars,
# not flags).

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--transform-only[print transformed source instead of running]' \
  '--cache[enable filesystem cache]' \
  '--no-cache[disable filesystem cache]' \
  '1:script:_files -g "*.(ts|tsx|js|jsx|mjs|mts|cjs|cts)(-.)"' \
  '*:args:' && ret=0
return ret
