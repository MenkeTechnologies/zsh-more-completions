#compdef ypp_rt
# Documentation: https://wiki.yambo-code.eu/wiki/index.php/Yambo_Post_Processing_(ypp)
# ypp_rt — yambo real-time post-processor: shared I/O options and analysis runlevels

local ret=1

_arguments -s -S \
  '(-h --help)-h[short help]' \
  '-H[long help]' \
  '-F[input file]:input file:_files' \
  '-I[core I/O directory]:core I/O dir:_directories' \
  '-O[additional I/O directory]:I/O dir:_directories' \
  '-J[job string identifier]:job string:' \
  '-V[input file verbosity]:verbosity:(RL kpt sc qp io gen resp all par)' \
  '-Q[do not launch the text editor]' \
  '-s[electrons (w=wave d=density s=DOS m=magnetization b=bands)]:electrons:(w d s m b c)' \
  '-e[excitons (s=sort sp=spin a=amplitude w=wave i=interpolate)]:excitons:(s sp a w i)' \
  '-k[BZ grid generator]:bz grid:(p q s h r e)' \
  '-b[read BXSF output generated by Wannier90]' \
  '-w[Wannier90 interface]' \
  '*:input file:_files' && ret=0

return ret
