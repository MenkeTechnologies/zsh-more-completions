#compdef libinput-list libinput-list-devices
# _libinput-list — Wayland/X libinput list devices CLI alias (Wayland project, C); custom argparse
# upstream: https://gitlab.freedesktop.org/libinput/libinput

_libinput-list() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '--device=+[device path]:file:_files -g "/dev/input/event*"' \
        '*:arg:'
}

_libinput-list "$@"
