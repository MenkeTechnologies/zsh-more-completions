#compdef api-linter

# googleapis/api-linter — `api-linter --help`

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--config=[linter config file]:file:_files' \
  '--debug[print stack on panic]' \
  '*'--descriptor-set-in='[FileDescriptorSet path]:file:_files'
  '*'--disable-rule='[rule id to disable]:rule:'
  '*'--enable-rule='[rule id to enable]:rule:'
  '--ignore-comment-disables[ignore api-linter disable comments]'
  '--list-rules[list rules and exit]'
  '--output-format=[results format]:format:(yaml json github summary)'
  '(-o)'{-o+,--output-path=}'[write results path]:file:_files'
  '*'{-I+,--proto-path=}'[proto import search path]:dir:_files -/'
  '--set-exit-status[exit 1 if lint errors]'
  '--skip-compilation[lint from descriptor set only]'
  '--version[print version]'
  '*:proto files:_files -g "*.proto"' && ret=0

return ret
