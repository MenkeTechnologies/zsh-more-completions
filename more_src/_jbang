#compdef jbang

# Zsh completion for jbang - Java scripting and jshell scripting

local curcontext="$curcontext" state line ret=1

_jbang_commands() {
  local -a commands=(
    'run:builds and runs provided script'
    'build:compiles and caches script without running'
    'edit:setup a temporary project for an IDE'
    'init:initialize a script'
    'alias:manage aliases for scripts'
    'catalog:manage catalogs of aliases'
    'trust:manage which URLs you trust'
    'cache:manage cache (clear)'
    'completion:output completion script for shell'
    'export:export script as jar, mvn, native, portable, etc.'
    'info:provides info about the script'
    'jdk:manage installed JDKs'
    'template:manage templates for scripts'
    'app:install or manage jbang scripts as system commands'
    'version:display version info'
    'config:manage jbang configuration'
    'wrapper:create/remove jbang wrapper script'
  )
  _describe -t commands 'jbang command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--verbose[be verbose]' \
  '--quiet[do not output anything]' \
  '--offline[work offline]' \
  '--fresh[download fresh dependencies]' \
  '--config=[config file path]:file:_files' \
  '1: :_jbang_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--java[specific Java version]:version' \
          '-m[main class]:class' \
          '--main[main class]:class' \
          '--jfr[start JFR recording]:config' \
          '--debug[enable remote debugging on port]:port' \
          '-D[set system property]:prop=value' \
          '-j[JVM options]:options' \
          '--javagent[use as Java agent]:agent' \
          '-d[deps to add (comma separated)]:deps' \
          '*:script:_files' && ret=0
        ;;
      build|info|export|edit)
        _arguments \
          '*:script:_files' && ret=0
        ;;
      init)
        _arguments \
          '-t[template]:template' \
          '--template[template]:template' \
          '--force[overwrite existing file]' \
          '*:file:_files' && ret=0
        ;;
      alias)
        _arguments \
          '1:subcommand:(add list remove)' \
          '*:alias' && ret=0
        ;;
      catalog)
        _arguments \
          '1:subcommand:(add list remove update)' && ret=0
        ;;
      jdk)
        _arguments \
          '1:subcommand:(install list uninstall default java-env home)' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
