#compdef mpcgain
# Documentation: https://www.musepack.net/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (verified locally via `mpcgain`
#   built-in usage string: "mpcgain <infile.mpc> [<infile2.mpc> ...]").

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*:input file:_files -g "*.mpc"' && ret=0

return ret
