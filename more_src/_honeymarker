#compdef honeymarker

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add a new marker'
  'list:list markers'
  'rm:delete a marker'
  'update:update a marker'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-k --writekey)'{-k+,--writekey=}'[Honeycomb configuration key]:key:' \
  '(-d --dataset)'{-d+,--dataset=}'[dataset (use __all__ for env-wide)]:dataset:' \
  '--api_host=[Honeycomb API host]:url:' \
  '--api-host=[Honeycomb API host]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'honeymarker command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '(-m --msg)'{-m+,--msg=}'[marker message]:msg:' \
          '(-t --type)'{-t+,--type=}'[marker type]:type:' \
          '(-u --url)'{-u+,--url=}'[marker URL]:url:' \
          '(-s --start_time)'{-s+,--start_time=}'[unix start time]:n:' \
          '(-e --end_time)'{-e+,--end_time=}'[unix end time]:n:' && ret=0 ;;
      (update)
        _arguments \
          '(-i --id)'{-i+,--id=}'[marker id]:id:' \
          '(-m --msg)'{-m+,--msg=}'[marker message]:msg:' \
          '(-t --type)'{-t+,--type=}'[marker type]:type:' \
          '(-u --url)'{-u+,--url=}'[marker URL]:url:' \
          '(-s --start_time)'{-s+,--start_time=}'[unix start time]:n:' \
          '(-e --end_time)'{-e+,--end_time=}'[unix end time]:n:' && ret=0 ;;
      (rm)
        _arguments '(-i --id)'{-i+,--id=}'[marker id]:id:' && ret=0 ;;
    esac ;;
esac

return ret
