#compdef bfdd
# _bfdd — FRR Project bfdd Bidirectional Forwarding Detection daemon for fast neighbor failure detection (FRRouting team, C); custom argparse
# upstream: https://github.com/FRRouting/frr

_bfdd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-d[run as daemon]' \
        '--daemon[run as daemon]' \
        '-f+[config file]:file:_files -g "bfdd.conf *.conf"' \
        '--config_file=+[config file]:file:_files -g "bfdd.conf *.conf"' \
        '-i+[pid file]:file:_files' \
        '--pid_file=+[pid file]:file:_files' \
        '-A+[vty bind address]:host:_hosts' \
        '--vty_addr=+[vty bind address]:host:_hosts' \
        '-P+[vty port]:port:_ports' \
        '--vty_port=+[vty port]:port:_ports' \
        '-u+[user]:user:_users' \
        '--user=+[user]:user:_users' \
        '-g+[group]:group:_groups' \
        '--group=+[group]:group:_groups' \
        '-z+[zebra socket]:file:_files' \
        '--socket=+[zebra socket]:file:_files' \
        '-N+[pathspace]:str:' \
        '--pathspace=+[pathspace]:str:' \
        '--watchfrr_sock=+[watchfrr socket]:file:_files' \
        '--log=+[log destination]:l:(stdout syslog file)' \
        '--log-level=+[level]:l:(emergencies alerts critical errors warnings notifications informational debugging)' \
        '--no-syslog[no syslog]' \
        '--no-zebra[no zebra connection]' \
        '--bfdctl=+[control socket]:file:_files' \
        '--cli[start CLI for debugging]'
}

_bfdd "$@"
