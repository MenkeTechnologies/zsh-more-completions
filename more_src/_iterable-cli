#compdef iterable-cli iterable
# _iterable-cli — Iterable iterable-cli CLI command-line frontend wrapping the Iterable cross-channel marketing platform REST API managing users events campaigns templates lists workflows experiments push-notifications-sms-email-in-app-web-push-message-channel-types data-feeds metadata catalog campaigns-templates-token-key-bulk (Iterable team, Go); cobra
# upstream: https://iterable.com/

_iterable-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'user:user operations'
        'event:event operations'
        'campaign:campaign operations'
        'template:template operations'
        'list:list operations'
        'workflow:workflow operations'
        'experiment:experiment operations'
        'data-feed:data feed operations'
        'metadata:metadata operations'
        'catalog:catalog operations'
        'webhook:webhook operations'
        'send:send a message'
        'bulk:bulk operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--region=+[r]:r:(us eu)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'iterable-cli subcommand' sub ;;
        args)
            case $words[1] in
                user|event|campaign|template|list|workflow|experiment|data-feed|metadata|catalog|webhook) _arguments '1:op:(list get create update delete send trigger pause resume)' '*:id:' ;;
                send|bulk) _arguments '*:payload:_files -g "*.json *.csv"' ;;
            esac
            ;;
    esac
}

_iterable-cli "$@"
