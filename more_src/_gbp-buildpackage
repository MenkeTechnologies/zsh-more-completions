#compdef gbp-buildpackage
# _gbp-buildpackage — build Debian packages from a Git repo (Debian/git-buildpackage)
# upstream: https://salsa.debian.org/agx/git-buildpackage
# Flags from gbp-buildpackage(1) man page.

_gbp-buildpackage() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--git-verbose[verbose output]' \
        '--git-color=[colorize output]:when:(on auto off)' \
        '--git-color-scheme=[colors for log levels]:scheme:' \
        '--configfile=[config file]:file:_files' \
        '--git-builder=[builder command]:cmd:' \
        '--git-cleaner=[cleaner command]:cmd:' \
        '--git-debian-branch=[Debian branch]:branch:' \
        '--git-upstream-branch=[upstream branch]:branch:' \
        '--git-upstream-tag=[upstream tag pattern]:pattern:' \
        '--git-upstream-tree=[upstream source tree]:tree:(branch tag tarball)' \
        '--git-upstream-signatures=[require upstream signatures]:when:(on auto off)' \
        '--git-debian-tag=[Debian tag pattern]:pattern:' \
        '--git-debian-tag-msg=[Debian tag message]:msg:' \
        '--git-keyid=[GPG key id for signing tags]:keyid:' \
        '--git-no-create-orig[do not create orig tarball]' \
        '--git-no-hooks[skip pre/post hooks]' \
        '--git-no-pbuilder[do not use pbuilder]' \
        '--git-no-purge[do not purge build directory]' \
        '--git-notify[notify after build]' \
        '--git-pbuilder[build with pbuilder]' \
        '--git-pbuilder-autoconf[auto-configure pbuilder]' \
        '--git-pbuilder-options=[pbuilder options]:opts:' \
        '--git-qemubuilder[build with qemubuilder]' \
        '--git-postbuild=[post-build hook]:cmd:' \
        '--git-postexport=[post-export hook]:cmd:' \
        '--git-posttag=[post-tag hook]:cmd:' \
        '--git-prebuild=[pre-build hook]:cmd:' \
        '--git-preexport=[pre-export hook]:cmd:' \
        '--git-pristine-tar[use pristine-tar]' \
        '--git-pristine-tar-commit[commit pristine-tar deltas]' \
        '--git-retag[allow re-creation of existing tag]' \
        '--git-tag[tag the build]' \
        '--git-tag-only[only tag, do not build]' \
        '--git-tarball-dir=[tarball directory]:dir:_files -/' \
        '--git-export=[git tree-ish to export]:treeish:' \
        '--git-export-dir=[export directory]:dir:_files -/' \
        '--git-ignore-branch[skip branch sanity checks]' \
        '--git-ignore-new[ignore uncommitted changes]' \
        '--git-force-create[force tarball recreation]' \
        '--git-arch=[architecture]:arch:' \
        '--git-dist=[distribution]:dist:' \
        '--git-component=[component to export]:component:' \
        '--git-compression=[tarball compression]:compression:(gzip bzip2 xz lzma)' \
        '--git-compression-level=[compression level]:level:'
}

_gbp-buildpackage "$@"
