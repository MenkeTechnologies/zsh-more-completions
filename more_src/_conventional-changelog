#compdef conventional-changelog

# Zsh completion for conventional-changelog - Generate changelogs

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --preset)'{-p,--preset}'[changelog preset]:preset:(angular atom codemirror conventionalcommits ember eslint express jquery jshint)' \
  '(-i --infile)'{-i,--infile}'[input changelog file]:input file:_files' \
  '(-o --outfile)'{-o,--outfile}'[output changelog file]:output file:_files' \
  '(-s --same-file)'{-s,--same-file}'[output to same file as input]' \
  '(-a --append)'{-a,--append}'[append to existing changelog]' \
  '(-r --release-count)'{-r,--release-count}'[number of releases to generate]:count' \
  '--skip-unstable[skip unstable tags]' \
  '(-u --output-unreleased)'{-u,--output-unreleased}'[output unreleased changelog]' \
  '--pkg=[path to package.json]:package file:_files -g "package.json"' \
  '--context=[path to context file]:context file:_files' \
  '--config=[path to config file]:config file:_files' \
  '--commit-path=[generate changelog scoped to path]:path:_files' \
  '(-t --tag-prefix)'{-t,--tag-prefix}'[tag prefix]:prefix' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--lernaPackage=[generate changelog for a lerna package]:package name'
