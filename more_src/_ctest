#compdef ctest
# _ctest — CMake CTest runner (Kitware, C++); driver for tests defined via add_test in CMake projects
# upstream: https://github.com/Kitware/CMake

_ctest() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--preset+[preset]:preset:' \
        '--list-presets[list presets]' \
        '-C+[build config]:cfg:(Debug Release RelWithDebInfo MinSizeRel)' \
        '--build-config+[build config]:cfg:' \
        '-V[verbose]' \
        '--verbose[verbose]' \
        '-VV[extra verbose]' \
        '--extra-verbose[extra verbose]' \
        '--debug[debug]' \
        '--output-on-failure[output on failure]' \
        '-F[failed only]' \
        '--rerun-failed[rerun failed]' \
        '-R+[include regex]:regex:' \
        '--tests-regex+[include regex]:regex:' \
        '-E+[exclude regex]:regex:' \
        '--exclude-regex+[exclude regex]:regex:' \
        '-LE+[exclude label]:label:' \
        '--label-exclude+[exclude label]:label:' \
        '-L+[label]:label:' \
        '--label-regex+[label]:label:' \
        '--print-labels[print labels]' \
        '--no-label-summary[no label summary]' \
        '--no-subproject-summary[no subproject summary]' \
        '-j+[jobs]:n:' \
        '--parallel+[jobs]:n:' \
        '--test-load+[load avg]:f:' \
        '--repeat+[repeat]:str:(until-fail:n until-pass:n after-timeout:n)' \
        '--repeat-until-fail+[repeat until fail]:n:' \
        '--max-width+[max width]:n:' \
        '-N[no test action]' \
        '--show-only+[show only]:fmt:(human json-v1)' \
        '-O+[log file]:file:_files' \
        '--output-log+[log file]:file:_files' \
        '--quiet[quiet]' \
        '-Q[quiet]' \
        '--progress[progress bar]' \
        '--stop-on-failure[stop on failure]' \
        '--stop-time+[stop time]:str:' \
        '--timeout+[timeout sec]:n:' \
        '--test-action+[test action]:action:(Start Update Configure Build Test Coverage MemCheck Submit)' \
        '--test-dir+[test dir]:dir:_files -/' \
        '--test-load+[test load]:n:' \
        '--test-output-size-passed+[passed output size]:n:' \
        '--test-output-size-failed+[failed output size]:n:' \
        '--show-only[show without running]' \
        '-I+[start,end,stride,test#]:str:' \
        '--tests-information+[start,end,stride,test#]:str:' \
        '--repeat-until-pass+[repeat until pass]:n:' \
        '--schedule-random[random schedule]' \
        '--interactive-debug-mode+[interactive debug mode]:bool:(0 1)' \
        '--no-tests+[no tests action]:action:(ignore error)' \
        '*:test:'
}

_ctest "$@"
