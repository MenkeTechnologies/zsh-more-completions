#compdef flux-dmesg
# Documentation: https://flux-framework.readthedocs.io/projects/flux-core/en/latest/man1/flux-dmesg.html
# print or manipulate the Flux broker ring buffer

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-C --clear)'{-C,--clear}'[clear the ring buffer]' \
  '(-c --read-clear)'{-c,--read-clear}'[clear ring buffer after printing]' \
  '(-f --follow)'{-f,--follow}'[wait for and print new entries]' \
  '(-n --new)'{-n,--new}'[follow only new log entries]' \
  '(-H --human)'{-H,--human}'[display human-readable output]' \
  '(-d --delta)'{-d,--delta}'[display time delta between messages]' \
  '(-L --color)'{-L,--color=}'[colorize output]:when:(always never auto)' && ret=0

return ret
