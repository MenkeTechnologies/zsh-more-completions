#compdef espfilt
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/espfilt/node9.html
# XMM-Newton SAS: filter EPIC event lists for soft proton flares

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-m[show manual page]' \
  '-p[display parameters]' \
  '-V+[verbosity control]:level:' \
  '-o+[ODF directory]:dir:_files -/' \
  '-i+[CCF calibration data directory]:dir:_files -/' \
  '--eventfile=[input FITS event list]:file:_files' \
  '--withoot=[input a PN OOT event list]:flag:(yes no)' \
  '--ootfile=[PN OOT FITS event list]:file:_files' \
  '--method=[fit method to use]:method:(ratio histogram)' \
  '--withsmoothing=[smooth data]:flag:(yes no)' \
  '--smooth=[smoothing factor in seconds]:secs:' \
  '--withbinning=[bin data]:flag:(yes no)' \
  '--binsize=[bin width in seconds]:secs:' \
  '--ratio=[flaring ratio of annulus counts]:ratio:' \
  '--elow=[low band energy]:energy:' \
  '--ehigh=[high band energy]:energy:' \
  '--rangescale=[histogram fit range scale factor]:scale:' \
  '--allowsigma=[limit in sigma for unflared rates]:sigma:' \
  '--limits=[parameter limits for gaussian fit]:limits:' \
  '--keepinterfiles=[keep intermediary files produced]:flag:(yes no)' \
  '*:event file:_files' && ret=0

return ret
