#compdef mfsfileinfo
# Documentation: https://manpages.debian.org/bookworm/moosefs-client/mfsfileinfo.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mfsfileinfo: print chunk locations of a file
local curcontext="$curcontext" ret=1
_arguments -C \
  '-n[print exact numbers]' \
  '-h[binary prefixes (Ki, Mi, Gi)]' \
  '-H[SI prefixes (k, M, G)]' \
  '-k[plain numbers in kibis]' \
  '-m[plain numbers in mebis]' \
  '-g[plain numbers in gibis]' \
  '*:file:_files' && ret=0
return ret
