#compdef presto-cli
# Documentation: https://prestodb.io/docs/current/installation/cli.html
# Presto distributed SQL query engine command-line client

local ret=1

_arguments -s -S \
  '--help[show available options]' \
  '--version[show version]' \
  '--server=[Presto coordinator address]:host\:port:' \
  '--catalog=[default catalog]:catalog:' \
  '--schema=[default schema]:schema:' \
  '--user=[username]:user:' \
  '--password[prompt for password]' \
  '--execute=[run a query and exit]:query:' \
  '--output-format=[output format for batch mode]:format:(ALIGNED VERTICAL CSV TSV CSV_HEADER TSV_HEADER JSON NULL)' \
  '--debug[show debug information and stack traces]' \
  '--history-file=[history file path]:file:_files' && ret=0

return ret
