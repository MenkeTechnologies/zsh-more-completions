#compdef presto trino-cli
# _presto-cli — Trino / Presto CLI (interactive SQL shell against a Presto/Trino coordinator; --server URL, --user, --password, --catalog, --schema, --execute one-shot query, --file script, --output-format CSV|TSV|JSON|VERTICAL|ALIGNED|MARKDOWN, --client-tags, --session prop=val, --extra-credential, --truststore-path, --keystore-path)
# upstream: https://github.com/trinodb/trino (client/trino-cli)
# Flags from trinodb/trino client/trino-cli/src/main/java/io/trino/cli/ClientOptions.java on tip.

_presto-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--server+[coordinator URL]:url:' \
        '--user+[user]:user:_users' \
        '--password[ask password]' \
        '--catalog+[catalog]:catalog:' \
        '--schema+[schema]:schema:' \
        '--source+[query source tag]:source:' \
        '--execute+[query]:query:' \
        '--file+[script]:file:_files -g "*.sql"' \
        '--output-format+[format]:format:(CSV CSV_HEADER CSV_UNQUOTED CSV_HEADER_UNQUOTED TSV TSV_HEADER JSON VERTICAL ALIGNED ALIGNED_VERTICAL MARKDOWN NULL)' \
        '--output-format-interactive+[interactive format]:format:(ALIGNED VERTICAL CSV CSV_HEADER TSV TSV_HEADER JSON MARKDOWN)' \
        '*--client-tags+[tags]:tags:' \
        '*--session+[prop=value]:session:' \
        '*--extra-credential+[name=value]:cred:' \
        '--truststore-path+[truststore]:file:_files' \
        '--truststore-password+[truststore password]:password:' \
        '--keystore-path+[keystore]:file:_files' \
        '--keystore-password+[keystore password]:password:' \
        '--krb5-config-path+[krb5 config]:file:_files' \
        '--krb5-keytab-path+[krb5 keytab]:file:_files' \
        '--krb5-principal+[krb5 principal]:principal:' \
        '--krb5-service-principal-pattern+[pattern]:pattern:' \
        '--debug[show debug]' \
        '--progress[show query progress]' \
        '--insecure[allow insecure TLS]' \
        '--access-token+[token]:token:' \
        '--client-info+[info]:info:' \
        '--no-progress[no query progress bar]' \
        '--validate-nextget-uri[validate next-uri]'
}

_presto-cli "$@"
