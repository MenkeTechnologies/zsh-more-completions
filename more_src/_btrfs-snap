#compdef btrfs-snap
# Documentation: https://github.com/jf647/btrfs-snap
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-r[create read-only snapshot]' \
  '-q[cron-compatible quiet output]' \
  '-c[use more compatible naming (no colons)]' \
  '-p[use prefix as postfix]' \
  '-E[treat omitted snapshots as errors]' \
  '-b+[snapshot directory mirroring source structure]:dir:_files -/' \
  '-B+[snapshot directory without subdirectory structure]:dir:_files -/' \
  '-d+[snapshot directory relative to mountpoint (default .snapshot)]:dir:_files -/' \
  '-t+[only snapshot if newest is older than seconds]:seconds:' \
  '-T+[transition-id comparison instead of timestamps]:seconds:' \
  '*:mountpoint_prefix_count:_files -/' && ret=0

return ret
