#compdef btrfs-snap
# Documentation: https://man.archlinux.org/search?q=btrfs-snap
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-r[read-only snapshot]' \
  '-b+[snapshot subdirectory]:dir:_files -/' \
  '-c[create snapshot]' \
  '-d[delete oldest]' \
  '*:path:_files -/' && ret=0

return ret
