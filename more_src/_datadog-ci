#compdef datadog-ci

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dsyms:upload dSYM files'
  'flutter:upload Flutter symbols'
  'git-metadata:upload git metadata'
  'junit:upload JUnit test results'
  'lambda:manage Lambda functions'
  'measure:custom metrics commands'
  'react-native:upload React Native source maps'
  'sarif:upload SARIF reports'
  'sbom:upload SBOM'
  'sourcemaps:upload JavaScript source maps'
  'stepfunctions:manage Step Functions'
  'synthetics:manage Synthetic tests'
  'tag:add tags to CI pipelines'
  'trace:upload APM traces'
  'unity:upload Unity symbols'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'datadog-ci command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (sourcemaps)
        local -a sm_cmds=('upload:upload source maps')
        _arguments \
          '1:sourcemaps command:_describe -t sm-cmds "sourcemaps command" sm_cmds' \
          '--service=[service name]:service' \
          '--release-version=[release version]:version' \
          '--min-size=[minimum file size]:bytes' \
          '--max-size=[maximum file size]:bytes' \
          '--project-path=[project root]:path:_directories' \
          '--repository-url=[repository URL]:url' \
          '--disable-git[disable git metadata upload]' \
          '--dry-run[dry run]' \
          '*:source maps directory:_directories' && ret=0
        ;;
      (synthetics)
        local -a synth_cmds=('run-tests:run Synthetic tests' 'upload-application:upload mobile app')
        _arguments \
          '1:synthetics command:_describe -t synth-cmds "synthetics command" synth_cmds' \
          '--apiKey=[API key]:key' \
          '--appKey=[App key]:key' \
          '--config=[config file]:file:_files' \
          '--public-id=[test public ID]:id' \
          '--search=[search query]:query' \
          '--files=[test config files]:files' \
          '--failOnCriticalErrors[fail on critical errors]' \
          '--failOnMissingTests[fail on missing tests]' \
          '--failOnTimeout[fail on timeout]' \
          '--tunnel[use testing tunnel]' && ret=0
        ;;
      (dsyms)
        _arguments \
          '1:action:(upload)' \
          '--dry-run[dry run]' \
          '--max-concurrency=[max concurrent uploads]:count' \
          '*:dSYM files or directories:_files' && ret=0
        ;;
      (junit)
        _arguments \
          '1:action:(upload)' \
          '--service=[service name]:service' \
          '--env=[environment]:env' \
          '--tags=[custom tags]:tags' \
          '--max-concurrency=[max concurrent uploads]:count' \
          '--dry-run[dry run]' \
          '*:JUnit XML files:_files -g "*.xml"' && ret=0
        ;;
      (tag)
        _arguments \
          '--level=[tag level]:level:(pipeline job)' \
          '--tags=[tags to add]:tags' \
          '--no-fail[do not fail on error]' && ret=0
        ;;
    esac
    ;;
esac

return ret
