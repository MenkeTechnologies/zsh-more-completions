#compdef AccurateMassSearch
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: search features against a mass database (e.g. HMDB)

local ret=1

_arguments -s -S \
  '-in[input featureXML or consensusXML file]:input file:_files' \
  '-out[output mzTab file]:output file:_files' \
  '-out_annotation[annotated copy of input file]:file:_files' \
  '-db:mapping[database file with mass, formula, identifier]:file:_files' \
  '-db:struct[database file with identifier, name, SMILES, INCHI]:file:_files' \
  '-positive_adducts[TSV of positive adducts to search]:file:_files' \
  '-negative_adducts[TSV of negative adducts to search]:file:_files' \
  '-algorithm:mass_error_value[tolerance for mass matching]:value:' \
  '-algorithm:mass_error_unit[error tolerance unit]:unit:(ppm Da)' \
  '-algorithm:ionization_mode[ionization polarity]:mode:(positive negative auto)' \
  '-algorithm:isotopic_similarity[enable similarity scoring for isotopic traces]' \
  '-algorithm:keep_unidentified_masses[retain unmatched features in output]' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
