#compdef tbls
# Documentation: https://man.archlinux.org/search?q=tbls
# Reference accessed: 2026-05-16

# Zsh completion for tbls (k1LoW/tbls). Pre-subcommand flags from cmd/root.go
# (also tbls disables cobra flag parsing; only -c/--config, --when, --dsn).
# Built-in subcommand names match cmd/*.go on main; extra names completed from
# executable tbls-* helpers on PATH (excluding tbls-driver-*), as getExtSubCmds.

local curcontext="$curcontext" state line ret=1
local -a cmdspec static seen
local p f bn

static=(
  'completion:shell completion helpers'
  'coverage:test coverage output'
  'diff:diff database documentation or schema'
  'doc:generate database documentation'
  'lint:lint documentation vs live schema'
  'ls:list tables'
  'out:output schema in standard format'
  'version:print tbls version'
)

cmdspec=("${static[@]}")
seen=(${cmdspec%%:*})
for p in ${(s.:.)PATH}; do
  [[ -d $p ]] || continue
  for f in $p/tbls-*(N); do
    bn=${${f:t}#tbls-}
    [[ $bn == driver-* ]] && continue
    if (( ! ${seen[(I)$bn]} )); then
      cmdspec+=("$bn:tbls-$bn helper on PATH")
      seen+=($bn)
    fi
  done
done

_arguments -C -s -S \
  '(-c --config)'{-c+,--config=}'[tbls config file path]:config:_files' \
  '--when=[only run subcommand when condition matches]:when:' \
  '--dsn=[DSN overriding config]:dsn:' \
  '1: :->sc' \
  '*::args:->args' && ret=0

case $state in
  (sc) _describe -t commands 'tbls subcommand' cmdspec && ret=0 ;;
  (args) _default && ret=0 ;;
esac

return ret
