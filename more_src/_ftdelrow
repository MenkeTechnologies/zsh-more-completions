#compdef ftdelrow
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftdelrow.html
# Delete rows from a FITS table

local ret=1

_arguments -s -S \
  'infile=[input FITS file with optional extension]:infile:_files' \
  'outfile=[output file, or none/blank for in-place]:outfile:_files' \
  'rows=[rows to delete, e.g. 3,10-15,45]:rows:' \
  'confirm=[prompt before in-place deletion]:confirm:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  '*:file:_files' && ret=0

return ret
