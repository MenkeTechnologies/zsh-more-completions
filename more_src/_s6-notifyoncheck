#compdef s6-notifyoncheck
# _s6-notifyoncheck — s6 supervision s6-notifyoncheck (run a long-lived service program and periodically run a `check` script; on first success notifies s6-supervise that the service is "ready" — common idiom for non-readiness-aware daemons)
# upstream: https://github.com/skarnet/s6
# Flags from src/supervision/s6-notifyoncheck.c on tip.

_s6-notifyoncheck() {
    _arguments \
        '-d[double-fork the child]' \
        '-3+[notification fd (default: from $NOTIFY_FD or 3)]:fd:' \
        '-s+[initial sleep before first check (ms)]:ms:' \
        '-T+[global timeout (ms)]:ms:' \
        '-t+[per-check timeout (ms)]:ms:' \
        '-w+[wait between failed checks (ms)]:ms:' \
        '-n+[max consecutive failed checks]:n:' \
        '-c+[check command-line]:cmd:' \
        '*::program:_command_names -e'
}

_s6-notifyoncheck "$@"
