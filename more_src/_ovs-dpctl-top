#compdef ovs-dpctl-top
# Documentation: https://www.openvswitch.org/support/dist-docs/ovs-dpctl-top.8.txt
# top-like utility for displaying Open vSwitch datapath flows

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-f --flow-file)'{-f,--flow-file}'=[file containing flows from ovs-dpctl dump-flow]:file:_files' \
  '(-V --verbose)'{-V,--verbose}'[enable debug level verbosity]' \
  '(-s --script)'{-s,--script}'[run from a script with no user interface]' \
  '--host=[specify user@host for retrieving flows]:host:_hosts' \
  '(-a --accumulate)'{-a,--accumulate}'[accumulate dump-flow content]' \
  '--accumulate-decay=[decay old accumulated flows in seconds]:seconds' \
  '(-d --delay)'{-d,--delay}'=[delay in milliseconds to collect dump-flow content]:milliseconds' && ret=0

return ret
