#compdef IlluminaBasecallsToFastq
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/illumina/IlluminaBasecallsToFastq.java
# Picard: generate FASTQ files from data in an Illumina BaseCalls output directory

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-B --BASECALLS_DIR)'{-B,--BASECALLS_DIR}'=[Illumina basecalls directory]:dir:_files -/' \
  '(-BCD --BARCODES_DIR)'{-BCD,--BARCODES_DIR}'=[directory with barcode files]:dir:_files -/' \
  '(-L --LANE)'{-L,--LANE}'=[lane number to process]:n:' \
  '--READ_STRUCTURE=[read structure describing logical reads]:s:' \
  '(-O --OUTPUT_PREFIX)'{-O,--OUTPUT_PREFIX}'=[output filename prefix for non-barcoded runs]:s:' \
  '--RUN_BARCODE=[barcode identifying the run]:s:' \
  '--MACHINE_NAME=[sequencer name for Casava 1.8 format]:s:' \
  '--FLOWCELL_BARCODE=[flowcell identifier for Casava 1.8 format]:s:' \
  '--READ_NAME_FORMAT=[read name format style]:f:(CASAVA_1_8 ILLUMINA)' \
  '--MULTIPLEX_PARAMS=[file for demultiplexing by barcode]:file:_files' \
  '--COMPRESS_OUTPUTS=[gzip compress output FASTQ files]:b:(true false)' \
  '--NUM_PROCESSORS=[number of parallel processing threads]:n:' \
  '--FIRST_TILE=[starting tile for processing]:n:' \
  '--TILE_LIMIT=[maximum number of tiles to process]:n:' \
  '--FORCE_GC=[periodically invoke garbage collection]:b:(true false)' \
  '--APPLY_EAMSS_FILTER=[apply EAMSS quality filtering]:b:(true false)' \
  '--MAX_READS_IN_RAM_PER_TILE=[deprecated; use MAX_RECORDS_IN_RAM]:n:' \
  '--MINIMUM_QUALITY=[quality threshold]:n:' \
  '(-NONPF --INCLUDE_NON_PF_READS)'{-NONPF,--INCLUDE_NON_PF_READS}'=[include reads failing quality filter]:b:(true false)' \
  '--IGNORE_UNEXPECTED_BARCODES=[skip reads with unmatched barcodes]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
