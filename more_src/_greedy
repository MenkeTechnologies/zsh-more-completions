#compdef greedy
# Documentation: https://greedy.readthedocs.io/en/latest/reference.html
# greedy - fast greedy diffeomorphic medical image registration

local ret=1

_arguments -s \
  '(- *)-h[show command-line help]' \
  '(- *)-version[print version information]' \
  '-d[image dimensionality]:dim:(2 3)' \
  '-threads[number of parallel CPU cores to use]:threads:' \
  '-float[use single-precision floating point]' \
  '-V[verbosity level]:level:(0 1 2)' \
  '-a[perform affine/rigid registration]' \
  '-r[reslice images using a transform chain]:*transforms:_files' \
  '-moments[match by moments of inertia]:order:(1 2)' \
  '-metric[compute metric between images]' \
  '-iw[invert a warp field]:in/out warp:_files' \
  '-root[compute 2^N-th root of a warp]:in/out/N:_files' \
  '-jac[compute Jacobian determinant of a warp]:in warp/out jac:_files' \
  '-brute[brute-force deformation search]:radius:' \
  '*-i[fixed/moving image pair]:image pair:_files -g "*.{nii,nii.gz,mhd,mha,img,hdr}"' \
  '-o[output file (matrix or warp image)]:output:_files' \
  '-w[weight for the subsequent image pair]:weight:' \
  '-mm[moving image mask]:moving mask:_files -g "*.{nii,nii.gz,mhd,mha}"' \
  '-gm[fixed image mask]:fixed mask:_files -g "*.{nii,nii.gz,mhd,mha}"' \
  '-gm-trim[auto-generate fixed mask by trimming]:radius:' \
  '-m[image similarity metric (SSD MI NMI NCC MAHAL)]:metric:(SSD MI NMI NCC MAHAL)' \
  '-n[iterations per multi-resolution level (NxNxN)]:iterations:' \
  '-e[step size epsilon]:epsilon:' \
  '-s[smoothing sigmas (gradient and warp)]:sigmas:' \
  '-oinv[output inverse warp image]:inverse warp:_files' \
  '-oroot[output warp root image]:warp root:_files' \
  '-wp[warp precision in voxels]:precision:' \
  '-exp[exponent for warp operations]:exponent:' \
  '-sv[use stationary velocity field mode]' \
  '-svlb[stationary velocity with more accurate updates]' \
  '-sv-incompr[incompressibility mode]' \
  '-id[initial warp/velocity field]:field:_files' \
  '-tscale[time step scaling mode]:mode:(CONST SCALE SCALEDOWN)' \
  '-noise[white-noise standard deviation for NCC]:value:' \
  '-it[initial transforms to apply]:*transforms:_files' \
  '-ref[reference space image]:reference:_files -g "*.{nii,nii.gz,mhd,mha}"' \
  '-ref-pad[pad fixed image to define reference space]:radius:' \
  '-bg[background fill value for missing data]:value:' \
  '-dof[degrees of freedom (6=rigid, 7=rigid+scale, 12=affine)]:dof:(6 7 12)' \
  '-ia[initial affine matrix file]:matrix:_files' \
  '-ia-identity[initialize affine from NIFTI headers]' \
  '-ia-image-centers[initialize by matching image centers]' \
  '-ia-image-side[initialize by image side matching]:code:' \
  '-ia-moments[initialize via moments of inertia]:order:(1 2)' \
  '-search[random search over rigid transforms]:N rot tran:' \
  '-jitter[random jitter for sample points]:sigma:' \
  '-rf[reference space image for reslicing]:fixed:_files -g "*.{nii,nii.gz,mhd,mha}"' \
  '*-rm[image reslice pair (moving output)]:reslice pair:_files' \
  '*-rs[mesh/surface reslice pair]:mesh pair:_files -g "*.vtk"' \
  '-ri[interpolation mode]:mode:(NN LINEAR LABEL)' \
  '-rb[background intensity outside image]:value:' \
  '-rc[compose transforms to an output warp]:out warp:_files' \
  '-rj[write Jacobian determinant image]:out jacobian:_files' \
  '-det[force determinant (flip or no flip)]:det:(-1 1)' \
  '-cov-id[use identity covariance, disable rotation]' \
  '-og[write metric gradient image]:out gradient:_files' \
  '-powell[use Powell method instead of LBFGS]' \
  '*:argument:_files' && ret=0

return ret
