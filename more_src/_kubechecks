#compdef kubechecks
# _kubechecks — Argo CI hooks for Kubernetes (zapier/kubechecks)
# upstream: https://github.com/zapier/kubechecks
# Flags from cmd/root.go (cobra + viper).

_kubechecks() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a persist
    persist=(
        '(-l --log-level)'{-l+,--log-level=}'[log output level]:level:(trace debug info warn error)'
        '--persist-log-level[propagate the log level to other module loggers]'
        '--vcs-base-url=[VCS base URL (self-hosted GitLab / enterprise GitHub)]:url:'
        '--vcs-upload-url=[VCS upload URL (enterprise GitHub)]:url:'
        '--vcs-type=[VCS type]:type:(github gitlab)'
        '--vcs-token=[VCS API token]:token:'
        '--vcs-username=[VCS username]:user:'
        '--vcs-email=[VCS email]:email:'
        '--github-private-key=[GitHub App private key (PEM)]:key:'
        '--github-app-id=[GitHub App id]:id:'
        '--github-installation-id=[GitHub installation id]:id:'
        '--argocd-api-token=[ArgoCD API token]:token:'
        '--argocd-api-server-addr=[ArgoCD API server address]:addr:'
        '--argocd-api-insecure[allow insecure TLS to the ArgoCD API server]'
        '--argocd-api-namespace=[ArgoCD namespace for Application / ApplicationSet CRDs]:ns:'
        '--argocd-api-plaintext[talk to the ArgoCD API in plaintext]'
        '--kubernetes-type=[Kubernetes API connection type]:type:(eks local)'
        '--kubernetes-clusterid=[Kubernetes cluster ID (required when type is eks)]:id:'
    )

    _arguments -C \
        $persist \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_kubechecks_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                controller)
                    _arguments $persist \
                        '--listen-addr=[address the webhook server listens on]:addr:' \
                        '--webhook-secret=[shared secret for VCS webhook payloads]:secret:' \
                        '--enable-conftest[enable Conftest policy checks]' \
                        '--enable-kubeconform[enable Kubeconform schema checks]' \
                        '--enable-preupgrade[enable pre-upgrade checks]' \
                        '--enable-hooks-renderer[enable Helm hooks renderer]' && ret=0 ;;
                process)
                    _arguments $persist \
                        '--owner=[VCS repository owner]:owner:' \
                        '--repo=[VCS repository name]:repo:' \
                        '--mr-id=[merge / pull request id]:id:' \
                        '--sha=[commit SHA to check]:sha:' && ret=0 ;;
                locations|version|help) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kubechecks_commands] )) ||
_kubechecks_commands() {
    local -a commands
    commands=(
        'controller:run the kubechecks webhook controller'
        'process:process a single PR / MR locally and emit results'
        'locations:print the source-of-truth locations resolved from config'
        'version:print version information'
    )
    _describe -t commands 'kubechecks command' commands
}

_kubechecks "$@"
