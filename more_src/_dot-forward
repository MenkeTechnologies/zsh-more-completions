#compdef dot-forward
# Documentation: https://manpages.debian.org/bookworm/dot-forward/dot-forward.1.en.html
# Source: djb dot-forward — read a .forward file under qmail (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-N -n)-N[(default) read and forward a message]' \
    '(-N -n)-n[parse file and print forwarding instructions, do not deliver]' \
    '1:forward file:_files' \
    && ret=0

return ret
