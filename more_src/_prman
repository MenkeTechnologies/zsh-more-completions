#compdef prman
# Documentation: https://renderman.jp/prmanual.html
# Pixar RenderMan RIB renderer executable

local ret=1

_arguments -s -S \
  '-help[print a usage message]' \
  '-version[print version information before rendering]' \
  '-cwd[set the current working directory root for relative paths]:path:_files -/' \
  '-progress[print a progress indicator to the terminal]' \
  '-Progress[print a progress indicator in an alternate machine-readable format]' \
  '-recover[recover a partially completed output image]:flag:(0 1)' \
  '-t[control multithreading; N target local CPUs]:threads:' \
  '-woff[turn off Xcpt warnings by message id]:msgid:' \
  '-catrib[copy ASCII/binary RIB data to an output file]:outfile:_files' \
  '-capture[copy all RIB as it is rendered, expanding procedurals]:outfile:_files' \
  '-nobake[disallow baking for re-rendering]' \
  '-res[override the RIB Format resolution]:x y[:par]:' \
  '-crop[override the CropWindow]:xmin xmax ymin ymax:' \
  '-maxsamples[override the maxsamples parameter]:samples:' \
  '-pixelvariance[override the pixelvariance parameter]:variance:' \
  '-d[override the RIB Display type]:dispType:' \
  '-statsfile[override the RIB stats file and level]:file:_files' \
  '-memorylimit[override the rendermemory option (Linux only)]:limit:' \
  '-checkpoint[set a checkpoint interval and optional exit time]:interval:' \
  '-rifmarker[add a marker for Rif chain edits]:marker:' \
  '-rif[load a chain of Rif plugins]:plugin:' \
  '*:RIB file:_files' && ret=0

return ret
