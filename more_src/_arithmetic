#compdef arithmetic
# Documentation: man arithmetic(6)
# Source: openbsd/src games/arithmetic/arithmetic.c — quiz on basic arithmetic (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '-o+[operators (combo of + - x /)]:keys:_default' \
    '-r+[range of numbers]:max:_default' \
    && ret=0

return ret
