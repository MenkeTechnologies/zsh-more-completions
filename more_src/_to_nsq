#compdef to_nsq
# Documentation: https://man.archlinux.org/search?q=to_nsq
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-version[show version]' \
  '-topic=[NSQ topic to publish to]:topic:' \
  '*-nsqd-tcp-address=[nsqd TCP address (repeatable)]:address:' \
  '-delimiter=[delimiter character]:delim:' \
  '-rate=[publishing rate (per second)]:n:' \
  '-producer-opt=[producer config option key=val (repeatable)]:opt:' && ret=0

return ret
