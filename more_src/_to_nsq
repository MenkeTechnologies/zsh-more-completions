#compdef to_nsq
# Documentation: https://github.com/nsqio/nsq/blob/master/apps/to_nsq/to_nsq.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '-topic=[NSQ topic to publish to]:topic:' \
  '*-nsqd-tcp-address=[destination nsqd TCP address (repeatable)]:address:' \
  '-delimiter=[character to split input from stdin]:delim:' \
  '-rate=[throttle messages to n/second (0 to disable)]:n:' \
  '*-producer-opt=[option to passthrough to nsq.Producer (repeatable)]:opt:' && ret=0

return ret
