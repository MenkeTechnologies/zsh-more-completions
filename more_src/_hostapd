#compdef hostapd
# _hostapd — OpenBSD hostapd (IAPP daemon for 802.11 Host AP mode access points; exchanges station association updates between APs in large wireless networks)
# upstream: https://github.com/openbsd/src (usr.sbin/hostapd)
# Flags from usr.sbin/hostapd/hostapd.8 on tip.

_hostapd() {
    _arguments \
        '-d[debug (foreground + log to stderr)]' \
        '-v[verbose (repeatable)]' \
        '*-D+[define macro=value]:macro=value:' \
        '-f+[config file (default /etc/hostapd.conf)]:file:_files'
}

_hostapd "$@"
