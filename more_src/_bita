#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/oll3/bita/blob/master/src/cli.rs
# `parse_opts` function with clap Command builder + per-
# subcommand arg setup.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _bita_cmds
_bita_cmds=(
    'compress:compress a file or stream into a bita archive'
    'clone:clone a remote or local archive (unpacks while cloning)'
    'diff:show the differential between two files'
    'info:show bita archive info (metadata, chunks)'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '*-v[increase verbosity (-v, -vv, -vvv)]' \
    '*--verbose[increase verbosity]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'bita subcommand' _bita_cmds && ret=0
        ;;
    args)
        case $words[1] in
            compress)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '(-i --input)'{-i+,--input=}'[input file (stdin if omitted)]:file:_files' \
                    '(-f --force)'{-f,--force}'[force overwrite output file]' \
                    '--buffered-chunks=[number of chunks buffered in memory]:N:' \
                    '*--metadata-file=[custom metadata KEY PATH (file contents)]:key path:' \
                    '*--metadata-value=[custom metadata KEY VALUE]:key value:' \
                    '--chunker-algorithm=[content-defined chunker algorithm]:algo:(buzhash rollsum fixed-size)' \
                    '--avg-chunk-size=[average chunk size in bytes]:N:' \
                    '--min-chunk-size=[minimum chunk size in bytes]:N:' \
                    '--max-chunk-size=[maximum chunk size in bytes]:N:' \
                    '--hash-length=[chunk hash length in bytes (default 16)]:N:' \
                    '--compression=[chunk compression algorithm]:algo:(none brotli lz4 zstd)' \
                    '--compression-level=[compression level]:level:' \
                    '*:output archive file:_files' \
                    && ret=0
                ;;
            clone)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '(-f --force)'{-f,--force}'[force overwrite output]' \
                    '--verify-header=[verify archive header SHA-256 checksum]:checksum:' \
                    '--verify-output[verify output file checksum matches archive]' \
                    '*--seed=[file to use as delta seed (use - for stdin)]:file:_files' \
                    '--seed-output[use output file as seed (in-place update)]' \
                    '--buffered-chunks=[number of chunks buffered]:N:' \
                    '*--http-header=[HTTP header NAME:VALUE pairs]:header:' \
                    '--http-retry-count=[HTTP retry count]:N:' \
                    '--http-retry-delay=[HTTP retry delay in seconds]:seconds:' \
                    '--http-timeout=[HTTP timeout in seconds]:seconds:' \
                    '1:archive URL or file:' \
                    '2:output file:_files' \
                    && ret=0
                ;;
            diff)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--chunker-algorithm=[chunker algorithm]:algo:(buzhash rollsum fixed-size)' \
                    '--avg-chunk-size=[average chunk size]:N:' \
                    '--min-chunk-size=[minimum chunk size]:N:' \
                    '--max-chunk-size=[maximum chunk size]:N:' \
                    '--hash-length=[chunk hash length]:N:' \
                    '1:file A:_files' \
                    '2:file B:_files' \
                    && ret=0
                ;;
            info)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--metadata-key=[print only metadata value for given key]:key:' \
                    '*--http-header=[HTTP header NAME:VALUE pairs]:header:' \
                    '1:archive URL or file:' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
