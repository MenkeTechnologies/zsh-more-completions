#
# WHAT IS fern AND WHY IS IT THE 56TH RUST CLI LIBRARY?
#
# fern (https://github.com/daboross/fern, 1300+ stars) is **David
# Ross's "simple, efficient logging for Rust"** — a chainable
# DISPATCH logger that implements the `log` crate's facade.
# Where env_logger (R582) takes the "stdlib defaults" approach
# and slog (R586) introduces an entirely separate structured-
# event model, fern stays WITHIN the `log` facade ecosystem
# while adding CHAINABLE COMPOSITION + FORMATTING + per-target
# level filtering.  Released 2014 around the same time as slog.
#
# fern's distinguishing characteristics:
#
#   1. CHAINABLE Dispatch BUILDER — fern's central concept is
#      the `Dispatch` value — a builder that accumulates format
#      + level + filter + target rules:
#
#          use fern::Dispatch;
#          use log::LevelFilter;
#
#          Dispatch::new()
#              .format(|out, message, record| {
#                  out.finish(format_args!(
#                      "[{}][{}][{}] {}",
#                      chrono::Local::now().format("%Y-%m-%dT%H:%M:%S"),
#                      record.target(),
#                      record.level(),
#                      message
#                  ))
#              })
#              .level(LevelFilter::Info)
#              .level_for("hyper", LevelFilter::Warn)
#              .level_for("my_crate::sensitive", LevelFilter::Off)
#              .chain(std::io::stdout())
#              .apply()?;
#
#      Compare:
#         * env_logger: simpler, RUST_LOG-driven, less composable
#         * slog: separate structured-event model (not log facade)
#         * tracing: async-aware spans + Subscribers
#         * fern: log-facade-compatible + chainable Dispatch
#                  composition
#      FIRST documented Rust logger with chainable Dispatch
#      builder + log-facade compatibility.
#
#   2. PARENT/CHILD DISPATCH HIERARCHY — fern's Dispatch values
#      can chain to OTHER Dispatch values, creating arbitrary
#      log-routing trees:
#
#          let file_logger = Dispatch::new()
#              .format(file_format)
#              .level(LevelFilter::Debug)
#              .chain(fern::log_file("app.log")?);
#
#          let console_logger = Dispatch::new()
#              .format(console_format)
#              .level(LevelFilter::Info)
#              .chain(std::io::stdout());
#
#          Dispatch::new()
#              .chain(file_logger)     // root → file with debug format
#              .chain(console_logger)  // root → stdout with info format
#              .apply()?;
#
#      Each branch of the tree gets its own format + filter +
#      destination.  Compare:
#         * env_logger: single output destination
#         * slog: drain chain (similar idea)
#         * tracing: Subscriber + Layer composition
#         * fern: PARENT/CHILD Dispatch tree
#      FIRST documented Rust logger with arbitrary parent/child
#      Dispatch hierarchy.
#
#   3. PER-TARGET LEVEL OVERRIDES — fern's `.level_for(target,
#      level)` lets users override the log level for specific
#      module paths or crate names:
#
#          Dispatch::new()
#              .level(LevelFilter::Info)              // default
#              .level_for("hyper", LevelFilter::Warn)  // silence hyper at info
#              .level_for("h2", LevelFilter::Off)      // h2 completely off
#              .level_for("my_crate", LevelFilter::Trace)  // my crate verbose
#              .chain(std::io::stdout())
#              .apply()?;
#
#      Compare:
#         * env_logger: similar via RUST_LOG=info,hyper=warn,h2=off
#         * slog: per-drain level filtering
#         * tracing: EnvFilter with same syntax as env_logger
#         * fern: PROGRAMMATIC per-target levels via builder
#      FIRST documented Rust logger with programmatic per-target
#      level filtering as a primary builder method.
#
#   4. CUSTOM FORMAT CLOSURES — fern's `format()` method takes
#      a CLOSURE that controls the output format with FULL
#      ACCESS to the log Record:
#
#          .format(|out, message, record| {
#              out.finish(format_args!(
#                  "{} {:5} [{}:{}] [{}] {}",
#                  chrono::Local::now().format("%Y-%m-%dT%H:%M:%S%.3f"),
#                  colors.color(record.level()),
#                  record.file().unwrap_or("?"),
#                  record.line().map(|l| l.to_string()).unwrap_or_default(),
#                  record.target(),
#                  message
#              ))
#          })
#
#      The closure receives `out: FormatCallback`, `message:
#      &Arguments`, `record: &Record` — gives access to file,
#      line, target, level, module path, key-values, etc.
#      Compare:
#         * env_logger: limited format hooks via env_logger::Builder
#         * slog: drain-level formatting
#         * tracing: fmt::layer().event_format(custom)
#         * fern: FULL CLOSURE control with FormatCallback + Record
#      FIRST documented Rust logger with raw-Record closure-
#      based format API.
#
#   5. COMPANION fern::colors FOR LEVEL COLORING — fern ships
#      with `fern::colors::ColoredLevelConfig` that provides
#      automatic level-based color formatting:
#
#          use fern::colors::{Color, ColoredLevelConfig};
#
#          let colors = ColoredLevelConfig::new()
#              .info(Color::Green)
#              .warn(Color::Yellow)
#              .error(Color::Red)
#              .debug(Color::Blue)
#              .trace(Color::Magenta);
#
#          .format(move |out, message, record| {
#              out.finish(format_args!(
#                  "{} {} {}",
#                  timestamp,
#                  colors.color(record.level()),
#                  message
#              ))
#          })
#
#      Built-in level-color helpers eliminate manual ANSI
#      escape handling.  Compare:
#         * env_logger: requires Builder.format() + manual color
#         * tracing-subscriber: ansi support but separate config
#         * fern + fern::colors: integrated level coloring helper
#      FIRST documented Rust logger with companion-crate level-
#      color helper.
#
# fern's relationship to other documented Rust libraries:
#
#   * Like env_logger (R582) — both implement the log facade
#   * Unlike env_logger — chainable Dispatch composition,
#                          parent/child hierarchy, per-target
#                          programmatic levels
#   * Like slog (R586) — both have chainable composition
#   * Unlike slog — fern stays within log facade; slog uses
#                    separate structured-event model
#   * Closest cross-language analogs:
#         * TS-Node: winston (R580) — both have chainable
#                     dispatch + transport architecture
#         * Go: zerolog (R583) — both have chained-builder API
#         * Python: stdlib `logging` with Handlers + Filters
#     fern is the FIRST documented Rust logger with chainable
#     Dispatch builder + log-facade compatibility + parent/child
#     hierarchy + per-target programmatic levels.
#
# -----------------------------------------------------------------------------
#
