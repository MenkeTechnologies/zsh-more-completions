#compdef strelka strelka-cli
# _strelka — Target Brands Strelka real-time file-scanning system CLI for distributed file extraction and analysis with YARA TRiD ssdeep ClamAV Lessstone enrichment YIN scanners across MongoDB/Coordinator/Backend/Frontend (target team, Go); cobra
# upstream: https://github.com/target/strelka

_strelka() {
    local -a sub=(
        'configtest:validate config'
        'submit:submit file'
        'fileshot:capture file submission'
        'mmrpc:run mmrpc request'
        'gencerts:generate TLS certs'
        'reload:reload scanners'
        'status:show status'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.toml *.json"' \
        '-c+[file]:file:_files -g "*.yaml *.yml *.toml *.json"' \
        '--coordinator=+[host:port]:str:' \
        '--frontend=+[host:port]:str:' \
        '--ca-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--client-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--client-key=+[file]:file:_files -g "*.pem *.key"' \
        '--insecure[allow self-signed certs]' \
        '--no-tls[no TLS]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'strelka subcommand' sub ;;
        args)
            case $words[1] in
                submit|fileshot) _arguments \
                    '--source=+[name]:str:' \
                    '--scanner=+[csv]:str:' \
                    '--tag=+[csv]:str:' \
                    '--output=+[file]:file:_files' \
                    '--mime=+[mime]:str:' \
                    '*:files:_files' ;;
                gencerts) _arguments \
                    '--dir=+[dir]:dir:_files -/' \
                    '--days=+[N]:n:' \
                    '--cn=+[CN]:str:' ;;
            esac
            ;;
    esac
}

_strelka "$@"
