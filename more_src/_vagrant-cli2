#compdef vagrant-cli2 vagrant2
# _vagrant-cli2 — HashiCorp Vagrant vagrant-cli2 CLI command-line frontend wrapping the Vagrant open-source tool for building and managing virtual machine environments in a single workflow lifecycle written in Ruby by HashiCorp originally Mitchell Hashimoto disposable VM environments that can be brought up with one command Vagrantfile HCL plugin install up down halt destroy reload provision suspend resume box plugin push global-status snapshot ssh ssh-config status validate winrm winrm-config rdp serve plugin-uninstall-list-install package login share connect autocomplete (HashiCorp team Mitchell Hashimoto, Ruby); custom argparse
# upstream: https://www.vagrantup.com/

_vagrant-cli2() {
    local -a sub=(
        'autocomplete:autocomplete helpers'
        'box:box operations'
        'cloud:Vagrant Cloud operations'
        'connect:connect to shared environment'
        'destroy:destroy machine resources'
        'docker-exec:exec a docker command'
        'docker-logs:show docker logs'
        'docker-run:run a docker command'
        'global-status:show global status'
        'halt:shutdown a machine'
        'help:show help'
        'init:initialize Vagrantfile'
        'list-commands:list commands'
        'login:authenticate with Vagrant Cloud'
        'package:package a machine'
        'plugin:plugin operations'
        'port:list forwarded ports'
        'powershell:open powershell'
        'provision:provision a machine'
        'push:push using strategies'
        'rdp:RDP into a machine'
        'reload:reload Vagrantfile config'
        'resume:resume a machine'
        'rsync:sync rsync folders'
        'rsync-auto:auto sync rsync folders'
        'serve:serve API'
        'share:share environment'
        'snapshot:snapshot operations'
        'ssh:ssh into a machine'
        'ssh-config:show ssh config'
        'status:show machine status'
        'suspend:suspend a machine'
        'up:start and provision'
        'upload:upload to machine'
        'validate:validate Vagrantfile'
        'version:show version'
        'winrm:run command over WinRM'
        'winrm-config:show WinRM config'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--debug-timestamp[debug timestamp]' \
        '--no-color[no color]' \
        '--color[force color]' \
        '--machine-readable[machine readable]' \
        '--timestamp[show timestamps]' \
        '-t[show timestamps]' \
        '--provider=+[name]:p:(virtualbox vmware_desktop vmware_fusion vmware_workstation libvirt parallels hyperv docker lxc qemu)' \
        '--provision[provision]' \
        '--no-provision[no provision]' \
        '--provision-with=+[providers]:str:' \
        '--destroy-on-error[destroy on error]' \
        '--no-destroy-on-error[no destroy on error]' \
        '--parallel[parallel]' \
        '--no-parallel[no parallel]' \
        '--install-provider[install provider]' \
        '--no-install-provider[no install provider]' \
        '--force[force]' \
        '-f[force]' \
        '--graceful[graceful]' \
        '--prune[prune]' \
        '-c+[command]:str:' \
        '--command=+[cmd]:str:' \
        '-A[forward SSH agent]' \
        '--forward-agent[forward agent]' \
        '-X[forward X11]' \
        '--forward-x11[forward X11]' \
        '-p[plain]' \
        '--plain[plain]' \
        '--host=+[host]:_hosts' \
        '--no-tty[no tty]' \
        '-N[no tty]' \
        '--output=+[file]:file:_files' \
        '-o+[output]:file:_files' \
        '--include=+[file]:file:_files' \
        '*--include=+[file]:file:_files' \
        '--base=+[name]:str:' \
        '--info=+[file]:file:_files' \
        '--vagrantfile=+[file]:file:_files -g "Vagrantfile *.rb"' \
        '--minimal[minimal Vagrantfile]' \
        '-m[minimal]' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--target=+[target]:str:' \
        '--driver=+[name]:str:' \
        '--default[default snapshot]' \
        '--no-rsync-auto[no rsync auto]' \
        '--no-tty[no tty]' \
        '--insert-key[insert key]' \
        '--no-insert-key[no insert key]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vagrant subcommand' sub ;;
        args)
            case $words[1] in
                up|halt|destroy|reload|provision|suspend|resume|ssh|status|snapshot|rdp|port|push|validate|share|connect|serve|rsync|rsync-auto|powershell|winrm|winrm-config|ssh-config|upload) _arguments '*:vm:' ;;
                box) _arguments '1:op:(add update list remove repackage prune outdated)' '*:name:' ;;
                plugin) _arguments '1:op:(install uninstall update list expunge license repair)' '*:name:' ;;
                snapshot) _arguments '1:op:(save restore list delete pop push)' '*:arg:' ;;
                init) _arguments '*:box name:' ;;
                cloud) _arguments '1:op:(auth box provider version search list)' '*:arg:' ;;
            esac
            ;;
    esac
}

_vagrant-cli2 "$@"
