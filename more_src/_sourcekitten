#compdef sourcekitten
# Documentation: https://github.com/jpsim/SourceKitten
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'complete:generate code completion options'
  'doc:print Swift or Objective-C docs as JSON'
  'format:format Swift file'
  'index:index Swift file and print as JSON'
  'module-info:obtain info about a Swift module and print as JSON'
  'request:run a raw SourceKit request'
  'structure:print Swift structure info as JSON'
  'syntax:print Swift syntax info as JSON'
  'version:display sourcekitten version'
  'help:show help for a subcommand'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      complete)
        _arguments \
          '--file=[source file]:file:_files -g "*.swift"' \
          '--text=[source text]:text:' \
          '--offset=[byte offset]:offset:' \
          '--spm-module=[Swift package module]:module:' \
          '--compilerargs=[compiler arguments]:args:' && ret=0
        ;;
      doc)
        _arguments \
          '--spm-module=[Swift package module]:module:' \
          '--module-name=[module name]:name:' \
          '--single-file[document a single file]' \
          '--objc[Objective-C mode]' \
          '*:file:_files -g "*.swift"' && ret=0
        ;;
      structure|syntax)
        _arguments \
          '--file=[source file]:file:_files -g "*.swift"' \
          '--text=[source text]:text:' && ret=0
        ;;
      module-info)
        _arguments \
          '--spm-module=[Swift package module]:module:' \
          '--module=[module name]:name:' \
          '--compilerargs=[compiler arguments]:args:' && ret=0
        ;;
      request)
        _arguments \
          '--yaml=[yaml request file]:file:_files -g "*.yaml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
