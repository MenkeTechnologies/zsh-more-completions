#compdef sourcekitten

# Zsh completion for sourcekitten - Swift source code information tool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'complete:generate code completions'
  'doc:generate documentation from Swift source'
  'format:reformat Swift source code'
  'index:index Swift source files'
  'module-info:get info about a Swift module'
  'request:make a SourceKit request'
  'structure:show structure of Swift source'
  'syntax:show syntax of Swift source'
  'version:display version'
  'help:display help'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      complete)
        _arguments \
          '--file=[source file]:file:_files -g "*.swift"' \
          '--text=[source text]:text:' \
          '--offset=[byte offset]:offset:' \
          '--spm-module=[Swift package module]:module:' \
          '--compilerargs=[compiler arguments]:args:' && ret=0
        ;;
      doc)
        _arguments \
          '--spm-module=[Swift package module]:module:' \
          '--module-name=[module name]:name:' \
          '--single-file[document a single file]' \
          '--compilerargs=[compiler arguments]:args:' \
          '*:file:_files -g "*.swift"' && ret=0
        ;;
      structure|syntax)
        _arguments \
          '--file=[source file]:file:_files -g "*.swift"' \
          '--text=[source text]:text:' \
          '--compilerargs=[compiler arguments]:args:' && ret=0
        ;;
      module-info)
        _arguments \
          '--spm-module=[Swift package module]:module:' \
          '--module=[module name]:name:' \
          '--compilerargs=[compiler arguments]:args:' && ret=0
        ;;
      request)
        _arguments ':yaml file:_files -g "*.yaml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
