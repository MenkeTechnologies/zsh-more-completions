#compdef condor_off

# condor_off: shut down condor daemons
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-pool[pool]:pool:' \
  '-name[daemon name]:name:' \
  '-addr[address]:sinful:' \
  '-fast[fast shutdown]' \
  '-peaceful[peaceful (drain)]' \
  '-graceful[graceful (default)]' \
  '-force-graceful[force graceful even if peaceful pending]' \
  '-master[master daemon]' \
  '-startd[startd]' \
  '-schedd[schedd]' \
  '-collector[collector]' \
  '-negotiator[negotiator]' \
  '-daemon[daemon type]:type:' \
  '-debug[debug]' \
  '-all[all hosts]' \
  '-constraint[constraint expression]:expr:' \
  '*:host:_hosts' && ret=0
return ret
