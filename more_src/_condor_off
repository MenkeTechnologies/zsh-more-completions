#compdef condor_off
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_off.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_off: shut down HTCondor daemons.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-graceful[graceful shutdown (default)]' \
  '-fast[fast shutdown]' \
  '-peaceful[peaceful (drain) shutdown]' \
  '-force-graceful[force graceful even with peaceful pending]' \
  '-drain[drain before shutdown]' \
  '-reason[shutdown reason text]:reason:' \
  '-request-id[request id for drain/check]:id:' \
  '-check[check drain status]' \
  '-start[start expression after drain]:expr:' \
  '-annex[target annex]' \
  '-exec[execute action]:action:' \
  '-debug[debug]' \
  '-pool[pool]:pool:' \
  '-name[daemon name / host]:name:' \
  '-addr[address (sinful)]:sinful:' \
  '-constraint[constraint expression]:expr:' \
  '-all[all hosts in pool]' \
  '-daemon[daemon type]:type:' \
  '-master[target master]' \
  '*:host:_hosts' && ret=0
return ret
