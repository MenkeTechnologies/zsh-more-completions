#compdef create-mcp-use-app
# Documentation: https://github.com/mcp-use/mcp-use/tree/main/packages/create-mcp-use-app
# Reference accessed: 2026-05-24
# Verified: npm view create-mcp-use-app bin; dist/index.js options in mcp-use at the URL above.

# Zsh completion for create-mcp-use-app - MCP-Use server project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-t --template)'{-t,--template=}'[template to use]:template:(starter mcp-ui mcp-apps blank)' \
  '--list-templates[list all available templates]' \
  '--install[install dependencies after creating project]' \
  '--no-install[skip installing dependencies]' \
  '--skills[install skills for all agents]' \
  '--no-skills[skip installing skills]' \
  '--no-git[skip initializing a git repository]' \
  '--dev[use workspace dependencies for development]' \
  '--canary[use canary versions of packages]' \
  '--yarn[use yarn as package manager]' \
  '--npm[use npm as package manager]' \
  '--pnpm[use pnpm as package manager]' \
  ':project name:' && ret=0

return ret
