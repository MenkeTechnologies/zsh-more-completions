#compdef uvgen
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvgen.html
# MIRIAD uvgen - simulate visibility data

local ret=1

_arguments -s -S \
  'source=[text file with source components]:source:_files' \
  'ant=[text file with antenna positions]:ant:_files' \
  'baseunit=[baseline unit to nanosecond conversion]:baseunit' \
  'telescop=[mount type and feed offset angle]:telescop' \
  'corr=[correlator setup]:corr' \
  'spectra=[Gaussian spectral line model]:spectra' \
  'time=[observation time / RNG seed]:time' \
  'seed=[random number generator seed]:seed' \
  'freq=[frequency and IF frequency in GHz]:freq' \
  'radec=[source RA and DEC]:radec' \
  'harange=[hour angle range start,stop,step]:harange' \
  'inttime=[integration cycle time in seconds]:inttime' \
  'ellim=[elevation limit in degrees]:ellim' \
  'stokes=[polarization parameters]:stokes' \
  'polar=[time-shared polarization sequences]:polar' \
  'leakage=[polarization leakage RMS percentage]:leakage' \
  'zeeman=[Zeeman effect coefficient]:zeeman' \
  'lat=[observatory latitude in degrees]:lat' \
  'cycle=[on-source and off-source cycle times]:cycle' \
  'pbfwhm=[primary beam FWHM in arcsec]:pbfwhm' \
  'center=[mosaic pointing offsets in arcsec]:center' \
  'gnoise=[antenna gain noise RMS percentage]:gnoise' \
  'pnoise=[antenna phase noise in degrees]:pnoise' \
  'systemp=[system temperature in Kelvin]:systemp' \
  'tpower=[total power variations]:tpower' \
  'jyperk=[system sensitivity in Jy/K]:jyperk' \
  'antfac=[noise factor and antenna numbers]:antfac' \
  'options=[leakfvar,delay,bandpass]:options' \
  'out=[output Miriad dataset filename]:out:_files' \
  '*:dataset:_files' && ret=0

return ret
