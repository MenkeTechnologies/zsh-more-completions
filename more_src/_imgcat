#compdef imgcat

# Zsh completion for imgcat (display images in terminal, iTerm2)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-W --width)'{-W,--width}'[set display width]:width (cells or pixels)' \
  '(-H --height)'{-H,--height}'[set display height]:height (cells or pixels)' \
  '--preserve-aspect-ratio[preserve aspect ratio]' \
  '--no-preserve-aspect-ratio[do not preserve aspect ratio]' \
  '(-u --url)'{-u,--url}'[display image from URL]:URL' \
  '(-d --depth)'{-d,--depth}'[color depth]:depth:(iterm2)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:image file:_files -g "*.{png,jpg,jpeg,gif,bmp,tiff,webp,svg,ico}"' && ret=0

return ret
