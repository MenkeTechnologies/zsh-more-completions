#compdef primitive
# Documentation: https://github.com/fogleman/primitive
# reproduce images with geometric primitives

local ret=1

_arguments -s \
  '-i+[input file]:input:_files' \
  '-o+[output file]:output:_files' \
  '-n+[number of shapes]:count:' \
  '-m+[mode: 0=combo 1=triangle 2=rect 3=ellipse 4=circle 5=rotatedrect 6=beziers 7=rotatedellipse 8=polygon]:mode:(0 1 2 3 4 5 6 7 8)' \
  '-rep+[add N extra shapes each iteration with reduced search]:n:' \
  '-nth+[save every Nth frame]:n:' \
  '-r+[resize large input images to this size before processing]:size:' \
  '-s+[output image size]:size:' \
  '-a+[color alpha (0 lets algorithm choose alpha per shape)]:alpha:' \
  '-bg+[starting background color (hex)]:color:' \
  '-j+[number of parallel workers (0 uses all cores)]:workers:' \
  '-v[verbose output]' \
  '-vv[very verbose output]' && ret=0

return ret
