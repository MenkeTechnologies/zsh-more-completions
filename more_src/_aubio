#compdef aubio aubiocut aubioonset aubiopitch aubiotrack aubionotes aubiomfcc aubioquiet
# _aubio — Paul Brossier aubio music information retrieval CLI utilities for onsets pitches beats notes detection (aubio team, C/Python); getopt
# upstream: https://github.com/aubio/aubio

_aubio() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i+[input audio]:file:_files -g "*.wav *.mp3 *.flac *.ogg *.aiff *.aif *.opus *.m4a *.au *.snd *.raw"' \
        '--input=+[input audio]:file:_files -g "*.wav *.mp3 *.flac *.ogg *.aiff *.aif *.opus *.m4a"' \
        '-r+[sample rate Hz]:n:' \
        '--samplerate=+[sample rate Hz]:n:' \
        '-B+[buffer size]:n:' \
        '--bufsize=+[buffer size]:n:' \
        '-H+[hop size]:n:' \
        '--hopsize=+[hop size]:n:' \
        '-O+[onset method]:o:(default energy hfc complex phase wphase specdiff kl mkl specflux)' \
        '--onset=+[onset method]:o:(default energy hfc complex phase wphase specdiff kl mkl specflux)' \
        '-t+[onset threshold]:f:' \
        '--threshold=+[onset threshold]:f:' \
        '-s+[silence threshold dB]:f:' \
        '--silence=+[silence threshold dB]:f:' \
        '-T+[time format]:t:(samples seconds ms milliseconds)' \
        '--time-format=+[time format]:t:(samples seconds ms milliseconds)' \
        '-p+[pitch method]:p:(default yin yinfast yinfft mcomb fcomb specacf schmitt)' \
        '--pitch=+[pitch method]:p:(default yin yinfast yinfft mcomb fcomb specacf schmitt)' \
        '-u+[pitch unit]:u:(Hz midi cent bin)' \
        '--pitch-unit=+[pitch unit]:u:(Hz midi cent bin)' \
        '-l+[pitch tolerance]:f:' \
        '--pitch-tolerance=+[pitch tolerance]:f:' \
        '-S+[slice mode]:s:(0 1 2)' \
        '--slice-at-onsets[slice at onsets]' \
        '--slice-at-tracks[slice at beats]' \
        '--cut[cut output]' \
        '-c+[cut length s]:f:' \
        '--cut-after=+[cut length s]:f:' \
        '--prefix=+[output prefix]:str:' \
        '--output=+[output dir]:dir:_files -/' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-j+[jack mode]:n:' \
        '--jack[JACK mode]' \
        '*:input audio:_files -g "*.wav *.mp3 *.flac *.ogg *.aiff *.aif"'
}

_aubio "$@"
