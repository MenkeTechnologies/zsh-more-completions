#compdef dalfox

# Zsh completion for dalfox - parameter analysis and XSS scanner

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'file:Use a file to scan (one URL per line)'
  'help:Show help'
  'pipe:Use pipe as input'
  'server:Run as API server'
  'sxss:Stored XSS mode'
  'url:Use a single target URL'
  'version:Show version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      url|file|pipe|sxss)
        _arguments \
          '(-b --blind)'{-b,--blind}'[blind XSS endpoint]:URL:' \
          '(-c --cookie)'{-c,--cookie}'[cookie]:cookie:' \
          '--custom-alert-type[custom alert type]:type:(none str)' \
          '--custom-alert-value[custom alert value]:value:' \
          '--custom-payload[custom payload file]:file:_files' \
          '--data[POST body data]:data:' \
          '--deep-domxss[deep DOM XSS testing with JavaScript parsing]' \
          '--delay[delay in milliseconds]:milliseconds:' \
          '--follow-redirects[follow HTTP redirects]' \
          '--format[output format]:format:(plain json)' \
          '(-H --header)'{-H,--header}'[add HTTP header]:header:' \
          '--ignore-return[ignore response return codes]:codes:' \
          '--mass[testing parameter, mass scanning]' \
          '--mining-dict-word[word list file for parameters mining]:file:_files' \
          '--mining-dom[use DOM XSS mining mode]' \
          '--only-discovery[only parameter discovery mode]' \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '--proxy[HTTP proxy]:proxy:' \
          '--remote-payloads[use payloads from remote URL]:URL:' \
          '--remote-wordlists[use wordlist from remote URL]:URL:' \
          '--report[show report after scanning]' \
          '--request-method[HTTP request method]:method:(GET POST)' \
          '--silence[only print PoC URLs and do not print all scanning information]' \
          '--timeout[HTTP request timeout in seconds]:seconds:' \
          '--trigger[XSS trigger code]:code:' \
          '--user-agent[custom user agent]:user-agent:' \
          '--waf-evasion[use WAF evasion techniques]' \
          '--worker[number of worker threads]:N:' \
          '*:URL:' && ret=0
        ;;
    esac
    ;;
esac

return ret
