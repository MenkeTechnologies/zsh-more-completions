#compdef flist flists
# Documentation: man flist(1)
# Source: nmh uip/flist.c (master) — list folders with sequence info (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-sequence+[sequence name]:name:_default' \
    '(-all -noall)-all[scan all folders]' \
    '(-all -noall)-noall[only named folders]' \
    '(-recurse -norecurse)-recurse[recursively scan subfolders]' \
    '(-recurse -norecurse)-norecurse[do not recurse]' \
    '(-showzero -noshowzero)-showzero[show zero-message folders]' \
    '(-showzero -noshowzero)-noshowzero[hide zero-message folders]' \
    '(-alpha -noalpha)-alpha[alphabetical sort]' \
    '(-alpha -noalpha)-noalpha[unsorted]' \
    '(-fast -nofast)-fast[fast output]' \
    '(-fast -nofast)-nofast[full output]' \
    '(-total -nototal)-total[show totals]' \
    '(-total -nototal)-nototal[no totals]' \
    '-version[show version]' \
    '-help[show help]' \
    '*::+folder:_default' \
    && ret=0

return ret
