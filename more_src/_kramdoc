#compdef kramdoc
# Documentation: https://github.com/asciidoctor/kramdown-asciidoc/blob/main/lib/kramdown-asciidoc/cli.rb
# Convert Markdown documents to AsciiDoc

local ret=1

_arguments -s -S \
  '(-o --output)'{-o+,--output=}'[set the output filename or stream]:file:_files' \
  '--format=[set the flavor of Markdown to parse]:format:(GFM kramdown markdown)' \
  '*'{-a+,--attribute=}'[set an attribute in the AsciiDoc document header]:attribute (KEY[=VALUE])' \
  '--diagram-languages=[specify source languages to treat as diagrams]:languages' \
  '--wrap=[set how lines are wrapped in the AsciiDoc document]:mode:(preserve none ventilate)' \
  '--imagesdir=[set the imagesdir attribute; remove value from image paths]:dir:_files -/' \
  '--heading-offset=[shift the heading level by the specified number]:number' \
  '--html-to-native[convert HTML to AsciiDoc syntax]' \
  '--no-html-to-native[pass through HTML]' \
  '--auto-ids[auto-generate IDs for all section titles]' \
  '--auto-id-prefix=[set prefix for auto-generated section title IDs]:prefix' \
  '--auto-id-separator=[set separator character for auto-generated IDs]:char' \
  '--lazy-ids[drop IDs matching auto-generated ID values]' \
  '--auto-links[convert bare URLs into links]' \
  '--no-auto-links[do not convert bare URLs into links]' \
  '(-h --help)'{-h,--help}'[display help text and exit]' \
  '(-v --version)'{-v,--version}'[display version information and exit]' \
  '*:file:_files' && ret=0

return ret
