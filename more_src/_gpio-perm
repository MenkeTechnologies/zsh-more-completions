#compdef gpio-perm
# _gpio-perm — gpio-perm CLI helper for managing GPIO chip device-node permissions adding udev rules user-group access ACL granting non-root access to GPIO sysfs class character-dev (gpiod team, Bash); getopt
# upstream: https://github.com/gpiod/gpio-perm

_gpio-perm() {
    local -a sub=(
        'install:install udev rules'
        'uninstall:remove udev rules'
        'check:check current permissions'
        'list:list known GPIO devices'
        'set:set permissions'
        'reset:reset permissions'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-u+[user]:u:_users' \
        '--user=+[user]:u:_users' \
        '-g+[group]:g:_groups' \
        '--group=+[group]:g:_groups' \
        '-m+[mode]:str:' \
        '--mode=+[mode]:str:' \
        '--reload-rules[reload udev rules]' \
        '--dry-run[dry run]' \
        '-y[yes confirm]' \
        '--yes[yes confirm]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gpio-perm subcommand' sub ;;
        args)
            case $words[1] in
                set|reset) _arguments '*:device:_files -g "/dev/gpiochip*"' ;;
            esac
            ;;
    esac
}

_gpio-perm "$@"
