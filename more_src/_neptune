#compdef neptune
# Documentation: https://github.com/neptune-ai/neptune-client
# Reference accessed: 2026-05-23
# Verified: neptune --help (neptune PyPI console script).

# Zsh completion for neptune - Neptune.ai experiment tracking CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'neptune command' \
      'clear[clear synchronized or trashed local metadata]' \
      'status[list synchronized and unsynchronized objects]' \
      'sync[synchronize objects with unsent data]' && ret=0
    ;;
esac

return ret
