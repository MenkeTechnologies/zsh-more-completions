#compdef podman-compose

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-f --file)'{-f,--file}'[compose file]:file:_files' \
  '(-p --project-name)'{-p,--project-name}'[project name]:name' \
  '--podman-path=[path to podman binary]:path:_files' \
  '--podman-args=[additional podman arguments]:args' \
  '--podman-pull-args=[additional podman pull arguments]:args' \
  '--podman-push-args=[additional podman push arguments]:args' \
  '--podman-build-args=[additional podman build arguments]:args' \
  '--podman-inspect-args=[additional podman inspect arguments]:args' \
  '--podman-run-args=[additional podman run arguments]:args' \
  '--podman-start-args=[additional podman start arguments]:args' \
  '--podman-stop-args=[additional podman stop arguments]:args' \
  '--podman-rm-args=[additional podman rm arguments]:args' \
  '--podman-volume-args=[additional podman volume arguments]:args' \
  '--no-ansi[do not print ANSI control characters]' \
  '--no-cleanup[do not cleanup after interrupt]' \
  '--dry-run[do not execute, print commands]' \
  '-t[timeout in seconds]:seconds' \
  '--env-file=[environment file]:file:_files' \
  '--profile=[specify a profile to enable]:profile' \
  '--in-pod=[run containers in a pod]:mode:(true false)' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'build:build or rebuild services'
      'bundle:generate a Docker bundle from the Compose file'
      'config:validate and view the Compose file'
      'create:create containers for a service'
      'down:stop and remove containers, networks'
      'events:receive real-time events from containers'
      'exec:execute a command in a running container'
      'help:get help on a command'
      'images:list images used by the created containers'
      'kill:force stop service containers'
      'logs:view output from containers'
      'pause:pause services'
      'port:print the public port for a port binding'
      'ps:list containers'
      'pull:pull service images'
      'push:push service images'
      'restart:restart service containers'
      'rm:remove stopped containers'
      'run:run a one-off command on a service'
      'scale:set number of containers for a service'
      'start:start services'
      'stop:stop services'
      'top:display the running processes'
      'unpause:unpause services'
      'up:create and start containers'
      'version:show version information'
      'wait:wait for containers to finish'
    )
    _describe -t commands 'podman-compose command' commands
    ;;
  args)
    case $words[1] in
      up)
        _arguments -s -S \
          '-d[detached mode]' \
          '--detach[detached mode]' \
          '--no-build[do not build before starting]' \
          '--no-start[do not start after creating]' \
          '--build[build images before starting]' \
          '--force-recreate[recreate containers]' \
          '--no-recreate[do not recreate if already running]' \
          '--no-deps[do not start linked services]' \
          '--remove-orphans[remove containers not defined in Compose file]' \
          '--scale=[scale service]:service=num' \
          '--exit-code-from=[return exit code from service]:service' \
          '--abort-on-container-exit[stop all containers on any exit]' \
          '-t[shutdown timeout]:seconds' \
          '--timeout[shutdown timeout]:seconds' \
          '--no-color[monochrome output]' \
          '--quiet-pull[pull without printing progress]' \
          '*:service:' && ret=0
        ;;
      down)
        _arguments -s -S \
          '--rmi=[remove images]:type:(all local)' \
          '-v[remove named volumes]' \
          '--volumes[remove named volumes]' \
          '--remove-orphans[remove containers not defined in Compose file]' \
          '-t[shutdown timeout]:seconds' \
          '--timeout[shutdown timeout]:seconds' && ret=0
        ;;
      logs)
        _arguments -s -S \
          '-f[follow log output]' \
          '--follow[follow log output]' \
          '--tail=[number of lines]:lines' \
          '-t[show timestamps]' \
          '--timestamps[show timestamps]' \
          '--no-color[monochrome output]' \
          '--since=[show logs since timestamp]:timestamp' \
          '--until=[show logs until timestamp]:timestamp' \
          '*:service:' && ret=0
        ;;
      exec)
        _arguments -s -S \
          '-T[disable pseudo-tty]' \
          '--privileged[give extended privileges]' \
          '-u[run as user]:user' \
          '--user=[run as user]:user' \
          '-e[set environment variable]:key=value' \
          '-w[working directory]:dir' \
          '--workdir=[working directory]:dir' \
          '--index=[container index]:index' \
          '1:service:' \
          '*:command:' && ret=0
        ;;
      run)
        _arguments -s -S \
          '-d[detached mode]' \
          '--detach[detached mode]' \
          '--name=[assign a name]:name' \
          '-u[run as user]:user' \
          '--user=[run as user]:user' \
          '-e[set environment variable]:key=value' \
          '--no-deps[do not start linked services]' \
          '--rm[remove container after exit]' \
          '-p[publish a port]:port' \
          '--publish=[publish a port]:port' \
          '-v[bind mount a volume]:volume' \
          '--volume=[bind mount a volume]:volume' \
          '-T[disable pseudo-tty]' \
          '-w[working directory]:dir' \
          '--workdir=[working directory]:dir' \
          '--entrypoint=[override the entrypoint]:entrypoint' \
          '--service-ports[run with service port mappings]' \
          '1:service:' \
          '*:command:' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--no-cache[do not use cache]' \
          '--pull[always pull newer image]' \
          '--force-rm[always remove intermediate containers]' \
          '--build-arg=[set build-time variables]:key=value' \
          '*:service:' && ret=0
        ;;
      kill)
        _arguments -s -S \
          '-s[signal to send]:signal:_signals' \
          '*:service:' && ret=0
        ;;
      stop|restart)
        _arguments -s -S \
          '-t[timeout in seconds]:seconds' \
          '--timeout=[timeout in seconds]:seconds' \
          '*:service:' && ret=0
        ;;
      rm)
        _arguments -s -S \
          '-f[do not ask for confirmation]' \
          '--force[do not ask for confirmation]' \
          '-v[remove anonymous volumes]' \
          '--volumes[remove anonymous volumes]' \
          '-s[stop containers if required]' \
          '--stop[stop containers if required]' \
          '*:service:' && ret=0
        ;;
      pull|push)
        _arguments -s -S \
          '--ignore-pull-failures[ignore pull failures]' \
          '*:service:' && ret=0
        ;;
      scale)
        _arguments '*:service=num:' && ret=0
        ;;
      ps)
        _arguments -s -S \
          '-q[only display IDs]' \
          '--quiet[only display IDs]' \
          '*:service:' && ret=0
        ;;
    esac
    ;;
esac

return ret