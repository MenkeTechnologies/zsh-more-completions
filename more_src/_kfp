#compdef kfp
# Documentation: https://man.archlinux.org/search?q=kfp
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'component:build shareable containerized components'
  'diagnose-me:run KFP environment diagnostic'
  'dsl:compile DSL to Pipeline Spec'
  'experiment:manage experiments'
  'pipeline:manage pipelines'
  'recurring-run:manage recurring runs'
  'run:manage runs'
  'version:show kfp version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--install-completion[install shell completion]' \
  '--endpoint=[KFP API endpoint]:url:' \
  '--iap-client-id=[IAP client id]:id:' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:' \
  '--other-client-id=[other client id]:id:' \
  '--other-client-secret=[other client secret]:secret:' \
  '--output=[output format]:format:(table json)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kfp command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (component)
        _arguments \
          '*::sub:(build)' \
          '--component-filepattern=[component file pattern]:pattern:' \
          '--engine=[container build engine]:engine:(docker kaniko cloudbuild)' \
          '--no-push-image[do not push built image]' \
          '--no-build-image[do not build image]' && ret=0 ;;
      (dsl)
        _arguments \
          '*::sub:(compile)' \
          '--py=[python source file]:file:_files -g "*.py"' \
          '--output=[output yaml file]:file:_files' \
          '--function=[function name to compile]:name:' \
          '--pipeline-parameters=[JSON dict of pipeline parameters]:json:' \
          '--disable-type-check[disable type check]' && ret=0 ;;
      (experiment)
        _arguments '*::sub:(archive create delete get list unarchive)' && ret=0 ;;
      (pipeline)
        _arguments '*::sub:(create create-version delete delete-version get get-version list list-versions)' && ret=0 ;;
      (recurring-run)
        _arguments '*::sub:(create delete disable enable get list)' && ret=0 ;;
      (run)
        _arguments \
          '*::sub:(archive create delete get list unarchive)' \
          '(-e --experiment-name)'{-e+,--experiment-name=}'[experiment name]:name:' \
          '(-r --run-name)'{-r+,--run-name=}'[run name]:name:' \
          '(-f --package-file)'{-f+,--package-file=}'[pipeline package file]:file:_files' \
          '(-p --pipeline-id)'{-p+,--pipeline-id=}'[pipeline id]:id:' \
          '--pipeline-version-id=[pipeline version id]:id:' \
          '--watch[watch run until finished]' \
          '-t+[timeout in seconds]:n:' \
          '--timeout=[timeout in seconds]:n:' && ret=0 ;;
    esac ;;
esac

return ret
