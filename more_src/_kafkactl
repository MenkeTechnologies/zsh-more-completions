#compdef kafkactl
# Documentation: https://github.com/deviceinsight/kafkactl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Apache Kafka CLI. Corrected from prior file against cmd/*/.go source:
# global flags are --config-file, --context, --clear-keyring, -V/--verbose;
# consume shorthands -k/-t/-a/-e/-p/-s/-g/-b/-o/-i; produce shorthands
# -p/-P/-k/-v/-f/-H/-S/-L/-s/-r. Removed invented -C/-b global and
# wrong consume/produce flag mappings.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config-file=[config file]:config:_files -g "*.{yaml,yml}"' \
  '--context=[select context]:context:' \
  '--clear-keyring[clear keyring credentials]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'alter:alter topics, partitions, brokers, or users'
      'attach:attach to a kubernetes pod'
      'clone:clone topics or consumer groups'
      'completion:generate shell completions'
      'config:show or modify config'
      'consume:consume messages from a topic'
      'create:create topics, consumer groups, ACLs, or users'
      'delete:delete records, consumer groups, ACLs, offsets, or users'
      'describe:describe topics, consumer groups, brokers, or users'
      'get:list topics, consumer-groups, brokers, ACLs, or users'
      'produce:produce messages to a topic'
      'reset:reset consumer group offsets'
      'version:print version'
    )
    _describe -t commands 'kafkactl command' commands && ret=0
    ;;
  args)
    case $line[1] in
      consume)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-k --print-keys)'{-k,--print-keys}'[print message keys]' \
          '(-t --print-timestamps)'{-t,--print-timestamps}'[print timestamps]' \
          '(-a --print-schema)'{-a,--print-schema}'[print Avro schema]' \
          '--print-headers[print headers]' \
          '--print-partitions[print partitions]' \
          '--print-all[print all metadata]' \
          '--tail=[print last n messages]:count' \
          '--from-timestamp=[start at timestamp]:timestamp' \
          '--to-timestamp=[stop at timestamp]:timestamp' \
          '--max-messages=[maximum messages]:count' \
          '(-e --exit)'{-e,--exit}'[exit when all messages consumed]' \
          '(-p --partitions)'{-p,--partitions}'=[partitions to consume]:partitions' \
          '(-s --separator)'{-s,--separator}'=[key separator]:separator' \
          '(-g --group)'{-g,--group}'=[consumer group]:group' \
          '--offset=[start offset]:offset' \
          '(-b --from-beginning)'{-b,--from-beginning}'[read from beginning]' \
          '(-o --output)'{-o,--output}'=[output format]:format:(default json yaml)' \
          '--key-encoding=[key encoding]:encoding:(none hex base64)' \
          '--value-encoding=[value encoding]:encoding:(none hex base64)' \
          '--filter-key=[filter by key]:filter' \
          '--filter-value=[filter by value]:filter' \
          '--filter-header=[filter by header]:filter' \
          '(-i --isolation-level)'{-i,--isolation-level}'=[isolation level]:level' \
          '1:topic' && ret=0
        ;;
      produce)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-k --key)'{-k,--key}'=[message key]:key' \
          '(-v --value)'{-v,--value}'=[message value]:value' \
          '--null-value[produce null value]' \
          '(-H --header)'{-H,--header}'=[message header]:header' \
          '(-S --separator)'{-S,--separator}'=[key separator]:separator' \
          '(-L --lineSeparator)'{-L,--lineSeparator}'=[line separator]:separator' \
          '(-p --partition)'{-p,--partition}'=[partition]:partition' \
          '(-P --partitioner)'{-P,--partitioner}'=[partitioner]:scheme:(murmur2 hash manual random)' \
          '(-f --file)'{-f,--file}'=[input file]:file:_files' \
          '--input-format=[input format]:format:(csv json)' \
          '--required-acks=[required acks]:acks' \
          '--max-message-bytes=[max message size]:bytes' \
          '--key-encoding=[key encoding]:encoding:(none hex base64)' \
          '--value-encoding=[value encoding]:encoding:(none hex base64)' \
          '(-s --silent)'{-s,--silent}'[suppress stdout]' \
          '(-r --rate)'{-r,--rate}'=[messages per second]:rate' \
          '1:topic' && ret=0
        ;;
      get|describe|delete)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'=[output format]:format:(yaml json table wide compact)' \
          '1:resource:(topics consumer-groups brokers acls users)' && ret=0
        ;;
      create)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:resource:(topic consumer-group acl user)' && ret=0
        ;;
    esac
    ;;
esac

return ret
