#compdef kafkactl

# Zsh completion for kafkactl - Apache Kafka CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-C+[config file]:config:_files -g "*.{yaml,yml}"' \
  '--config-file=[config file]:config:_files -g "*.{yaml,yml}"' \
  '--verbose[verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'alter:alter topics or configs'
      'attach:attach to consumer group'
      'clone:clone topics'
      'completion:generate shell completions'
      'config:show config'
      'consume:consume messages from a topic'
      'create:create topics or ACLs'
      'delete:delete topics, consumer groups, or ACLs'
      'describe:describe topics or consumer groups'
      'get:get topics, consumer-groups, or brokers'
      'produce:produce messages'
      'reset:reset consumer group offsets'
      'version:print version'
    )
    _describe -t commands 'kafkactl command' commands && ret=0
    ;;
  args)
    case $line[1] in
      consume)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-b[print only message value]' \
          '--print-keys[print message keys]' \
          '--print-timestamps[print timestamps]' \
          '--print-headers[print headers]' \
          '--print-schema[print Avro schema]' \
          '-g+[consumer group]:group' \
          '--group=[consumer group]:group' \
          '--from-beginning[read from beginning]' \
          '--offset=[start offset]:offset' \
          '--partitions=[partitions to consume]:partitions' \
          '--max-messages=[maximum messages]:count' \
          '--key-encoding=[key encoding]:encoding:(none hex base64)' \
          '--value-encoding=[value encoding]:encoding:(none hex base64)' \
          '-o+[output format]:format:(default json)' \
          '--output=[output format]:format:(default json)' \
          '-f[keep consuming (follow)]' \
          '1:topic' && ret=0
        ;;
      produce)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-k+[message key]:key' \
          '--key=[message key]:key' \
          '-v+[message value]:value' \
          '--value=[message value]:value' \
          '-H+[message header]:header' \
          '--header=[message header]:header' \
          '-S+[key separator]:separator' \
          '--separator=[key separator]:separator' \
          '-p+[partition]:partition' \
          '--partition=[partition]:partition' \
          '-f+[input file]:file:_files' \
          '--file=[input file]:file:_files' \
          '--lineSeparator=[line separator]:separator' \
          '--null-value[produce null value]' \
          '1:topic' && ret=0
        ;;
      get|describe|delete)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '-o+[output format]:format:(default json yaml wide compact)' \
          '--output=[output format]:format:(default json yaml wide compact)' \
          '1:resource:(topics consumer-groups brokers acl)' && ret=0
        ;;
      create)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:resource:(topic acl)' && ret=0
        ;;
    esac
    ;;
esac

return ret
