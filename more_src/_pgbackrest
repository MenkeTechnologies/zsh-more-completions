#compdef pgbackrest

# Zsh completion for pgbackrest - PostgreSQL backup and restore

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'archive-get:get a WAL segment from the archive'
  'archive-push:push a WAL segment to the archive'
  'backup:perform a backup'
  'check:check the configuration'
  'expire:expire backups and WAL archive'
  'info:retrieve information about backups'
  'repo-get:get a file from a repository'
  'repo-ls:list files in a repository'
  'restore:restore a backup'
  'server:pgBackRest server'
  'server-ping:ping pgBackRest server'
  'stanza-create:create the required stanza data'
  'stanza-delete:delete a stanza'
  'stanza-upgrade:upgrade a stanza'
  'start:allow pgBackRest processes to run'
  'stop:stop pgBackRest processes'
  'verify:verify contents of the repository'
  'version:get version'
  'help:get help'
)

_arguments -s -S \
  '1:command:->command' \
  '--config=[configuration file]:file:_files' \
  '--config-include-path=[path of configuration includes]:directory:_files -/' \
  '--config-path=[base path of configuration]:directory:_files -/' \
  '--log-level-console=[console log level]:level:(off error warn info detail debug trace)' \
  '--log-level-file=[file log level]:level:(off error warn info detail debug trace)' \
  '--log-level-stderr=[stderr log level]:level:(off error warn info detail debug trace)' \
  '--log-path=[log path]:directory:_files -/' \
  '--log-subprocess[enable subprocess logging]' \
  '--log-timestamp[enable log timestamps]' \
  '--pg=[PostgreSQL path and port]:path' \
  '--repo=[repository index]:index' \
  '--stanza=[stanza name]:stanza' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pgbackrest command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (backup)
        _arguments -s -S \
          '--type=[backup type]:type:(full diff incr)' \
          '--annotation=[add annotation to backup]:key=value' \
          '--archive-check[check WAL archive]' \
          '--archive-copy[copy WAL during backup]' \
          '--backup-standby[backup from standby]' \
          '--checksum-page[verify data page checksums]' \
          '--compress-type=[compression type]:type:(none gz bz2 lz4 zst)' \
          '--compress-level=[compression level]:level' \
          '--delta[restore using delta]' \
          '--dry-run[dry run]' \
          '--exclude=[exclude paths]:path' \
          '--expire-auto[auto-expire after backup]' \
          '--manifest-save-threshold=[manifest save threshold]:size' \
          '--online[perform an online backup]' \
          '--process-max=[max backup processes]:number' \
          '--resume[allow resume of failed backup]' \
          '--start-fast[use checkpoint to start backup quickly]' \
          '--stop-auto[stop backup if required]' && ret=0
        ;;
      (restore)
        _arguments -s -S \
          '--archive-mode=[mode to use for restoring WAL]:mode:(off preserve)' \
          '--db-include=[only restore specified databases]:database' \
          '--db-exclude=[exclude specified databases]:database' \
          '--delta[restore using delta]' \
          '--force[force a restore]' \
          '--link-all[restore all links]' \
          '--link-map=[remap a link to a new path]:link=path' \
          '--process-max=[max restore processes]:number' \
          '--recovery-option=[set recovery option]:option=value' \
          '--set=[backup set to restore]:set' \
          '--tablespace-map=[remap a tablespace]:tablespace=path' \
          '--tablespace-map-all=[remap all tablespaces]:path' \
          '--target=[recovery target]:target' \
          '--target-action=[action when recovery target is reached]:action:(pause promote shutdown)' \
          '--target-exclusive[stop before recovery target]' \
          '--target-timeline=[recovery target timeline]:timeline' \
          '--type=[recovery type]:type:(default immediate lsn name time xid preserve standby none)' && ret=0
        ;;
      (info)
        _arguments -s -S \
          '--output=[output format]:format:(text json)' \
          '--set=[backup set to query]:set' && ret=0
        ;;
      (expire)
        _arguments -s -S \
          '--dry-run[dry run]' \
          '--set=[backup set to expire]:set' && ret=0
        ;;
      (stanza-create|stanza-upgrade)
        _arguments -s -S \
          '--force[force operation]' \
          '--online[perform online operation]' && ret=0
        ;;
      (stanza-delete)
        _arguments -s -S \
          '--force[force operation]' && ret=0
        ;;
      (check)
        _arguments -s -S \
          '--archive-check[check WAL archive]' \
          '--archive-timeout=[WAL archive timeout]:seconds' && ret=0
        ;;
    esac
    ;;
esac

return ret
