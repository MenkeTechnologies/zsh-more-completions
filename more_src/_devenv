#compdef devenv
# Documentation: https://github.com/cachix/devenv
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a subcommands
subcommands=(
  'build:Build attributes from devenv.nix'
  'changelogs:View relevant changes'
  'container:Build and manage containers'
  'direnvrc:Generate direnv integration'
  'eval:Evaluate attributes and return JSON'
  'gc:Garbage collect old developer environments'
  'generate:Create environments using AI'
  'info:Display environment details'
  'init:Scaffold configuration files'
  'inputs:Manage environment inputs (devenv.yaml)'
  'lsp:Start the language server for devenv.nix'
  'mcp:Launch AI Model Context Protocol server'
  'processes:Manage process lifecycle'
  'repl:Launch an interactive Nix REPL'
  'search:Find packages and options'
  'shell:Activate the developer environment'
  'tasks:Execute task definitions'
  'test:Run test suites'
  'up:Start processes in foreground'
  'update:Update dependency locks'
  'version:Display version information'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --verbose)'{-v,--verbose}'[Enable debug output]' \
  '(-q --quiet)'{-q,--quiet}'[Suppress all logs]' \
  '(-s --system)'{-s,--system}'[Override target system]:system:' \
  '(-i --impure)'{-i,--impure}'[Relax environment isolation]' \
  '--nix-debugger[Enter debugger on evaluation failure]' \
  '--override-input=[Modify a dependency]:name=url:' \
  '--option=[Override a typed configuration value]:name value:' \
  '--tui[Enable terminal UI]' \
  '--no-tui[Disable terminal UI]' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      init)
        _arguments \
          '--target=[Target directory]:dir:_directories' \
          '1:template:'
        ;;
      container)
        _arguments \
          'build:Build a container' \
          'run:Run a container' \
          '--name=[Container name]:name:' \
          '--registry=[Container registry]:registry:'
        ;;
      inputs)
        _arguments \
          '1:action:(add)' \
          '2:input name:' \
          '3:input url:'
        ;;
      search)
        _arguments '1:query:'
        ;;
      shell)
        _arguments '*:command:'
        ;;
      up)
        _arguments \
          '(-d --detach)'{-d,--detach}'[Run processes in background]' \
          '*:process names:'
        ;;
      test)
        _arguments '*:test names:'
        ;;
    esac
    ;;
esac
