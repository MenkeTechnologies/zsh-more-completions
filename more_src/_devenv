#compdef devenv

local -a subcommands
subcommands=(
  'build:Build the developer environment'
  'ci:Build the developer environment for CI'
  'container:Build a container'
  'gc:Garbage collect old developer environments'
  'info:Show information about the environment'
  'init:Initialize a new developer environment'
  'inputs:Manage devenv.nix inputs'
  'repl:Open a Nix REPL with the environment'
  'search:Search for packages'
  'shell:Enter the developer environment shell'
  'test:Run tests'
  'up:Start processes'
  'update:Update devenv.lock'
  'version:Show version'
  'help:Show help'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '(-v --verbose)'{-v,--verbose}'[Verbose output]' \
  '(-d --debug)'{-d,--debug}'[Debug output]' \
  '(-s --system)'{-s,--system}'[Target system]:system:' \
  '--nix-debugger[Launch Nix debugger on evaluation failure]' \
  '--clean[Clean state before building]' \
  '--impure[Allow impure expressions]' \
  '--override-input=[Override an input]:name=url:' \
  '(-n --nix)'{-n,--nix}'[Pass extra arguments to Nix]:args:' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      init)
        _arguments \
          '--target=[Target directory]:dir:_directories' \
          '1:template:'
        ;;
      container)
        _arguments \
          'build:Build a container' \
          'run:Run a container' \
          '--name=[Container name]:name:' \
          '--registry=[Container registry]:registry:'
        ;;
      inputs)
        _arguments \
          '1:action:(add)' \
          '2:input name:' \
          '3:input url:'
        ;;
      search)
        _arguments '1:query:'
        ;;
      shell)
        _arguments '*:command:'
        ;;
      up)
        _arguments \
          '(-d --detach)'{-d,--detach}'[Run processes in background]' \
          '*:process names:'
        ;;
      test)
        _arguments '*:test names:'
        ;;
    esac
    ;;
esac
