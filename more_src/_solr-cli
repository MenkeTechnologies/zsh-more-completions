#compdef solr

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start solr'
  'stop:stop solr'
  'restart:restart solr'
  'status:check status'
  'healthcheck:healthcheck'
  'create:create core/collection'
  'create_core:create a core'
  'create_collection:create a collection'
  'delete:delete a core/collection'
  'version:show version'
  'zk:ZooKeeper commands'
  'auth:auth commands'
  'config:config commands'
  'export:export collection'
  'package:package management'
  'post:post documents to solr'
  'assert:assert conditions'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help,-help}'[show help]' \
  '*-version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'solr command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (start|restart)
        _arguments \
          '-cloud[start in SolrCloud mode]' \
          '-c[start in SolrCloud mode]' \
          '-d+[server dir]:dir:_files -/' \
          '-z+[ZK host]:host:' \
          '-h+[host]:host:_hosts' \
          '-p+[port]:port:' \
          '-m+[heap memory]:m:' \
          '-s+[Solr home dir]:dir:_files -/' \
          '-e+[example]:e:(cloud techproducts schemaless dih)' \
          '-a+[JVM args]:args:' \
          '-noprompt[no prompt]' \
          '-V[verbose]' \
          '-f[foreground]' \
          '-jvm-opts+[JVM opts]:opts:' \
          '*: :' && ret=0 ;;
      (stop)
        _arguments \
          '-p+[port]:port:' \
          '-all[stop all]' \
          '-k+[stop key]:k:' \
          '*: :' && ret=0 ;;
      (create|create_core|create_collection)
        _arguments \
          '-c+[name]:n:' \
          '-d+[config dir]:dir:_files -/' \
          '-n+[config name]:n:' \
          '-shards+[shards]:n:' \
          '-replicationFactor+[replication factor]:n:' \
          '-p+[port]:port:' \
          '-V[verbose]' \
          '*: :' && ret=0 ;;
      (delete)
        _arguments \
          '-c+[name]:n:' \
          '-deleteConfig+[delete config]:b:(true false)' \
          '-p+[port]:port:' \
          '*: :' && ret=0 ;;
      (zk)
        _arguments \
          '1:subcommand:(upconfig downconfig cp rm mv ls mkroot)' \
          '-z+[ZK host]:host:' \
          '*: :_files' && ret=0 ;;
      (post)
        _arguments \
          '-c+[collection]:c:' \
          '-format+[format]:f:(application/json text/csv text/xml)' \
          '-p+[port]:port:' \
          '-host+[host]:host:_hosts' \
          '-url+[Solr URL]:url:' \
          '-mode+[mode]:m:(args files stdin web)' \
          '*: :_files' && ret=0 ;;
      (auth)
        _arguments \
          '1:subcommand:(enable disable)' \
          '*: :' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(set unset show)' \
          '*: :' && ret=0 ;;
      (package)
        _arguments \
          '1:subcommand:(list-installed list-available install uninstall update deploy undeploy redeploy)' \
          '*: :' && ret=0 ;;
      (status|healthcheck)
        _arguments \
          '-z+[ZK host]:host:' \
          '-p+[port]:port:' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
