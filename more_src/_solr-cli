#compdef solr-cli
# Documentation: https://solr.apache.org/guide/solr/latest/deployment-guide/solr-control-script-reference.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: no separate `solr-cli` binary upstream; `bin/solr` is the CLI. This
# file exists for compdef aliasing only; users should rely on `_solr`.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start solr'
  'stop:stop solr'
  'restart:restart solr'
  'status:check status of running servers'
  'healthcheck:health report for SolrCloud collections'
  'create:create core/collection'
  'delete:delete a core/collection'
  'version:show version'
  'assert:validate installation/config'
  'zk:ZooKeeper subcommands'
  'auth:enable/disable authentication'
  'config:modify collection configuration'
  'export:export collection documents'
  'package:package manager'
  'post:post documents to a collection'
  'api:send HTTP request to Solr endpoint'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help,-help}'[show help]' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0

case $state in
  (cmd) _describe -t cmds 'solr-cli command' commands && ret=0 ;;
esac

return ret
