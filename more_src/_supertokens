#compdef supertokens

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start the core'
  'stop:stop the core'
  'list:list running cores'
  'uninstall:uninstall'
  'update:update SuperTokens'
  'load-license:load license'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'supertokens subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '--foreground[run in foreground]' \
          '--port=[port]:port:' \
          '--host=[host]:host:_hosts' \
          '--with-config=[config path]:file:_files' \
          '--with-temp-dir[use temp dir]' \
          '--with-space=[disk space MB]:n:' \
          '--help[show help]' && ret=0
        ;;
      (load-license)
        _arguments '--id=[license id]:id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
