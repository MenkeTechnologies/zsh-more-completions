#compdef pgwatch2
# Documentation: https://man.archlinux.org/search?q=pgwatch2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=+[config file]:file:_files -g "*.yaml"' \
  '--metrics-folder=+[metrics folder]:dir:_files -/' \
  '--host=+[postgres host]:host:_hosts' \
  '--port=+[postgres port]:port:' \
  '--user=+[postgres user]:user:' \
  '--password=+[postgres password]:pw:' \
  '--dbname=+[database name]:db:' \
  '--datastore=+[datastore type]:type:(graphite influx postgres prometheus json)' \
  '--graphite-host=+[graphite host]:host:_hosts' \
  '--graphite-port=+[graphite port]:port:' \
  '--influx-host=+[influxdb host]:host:_hosts' \
  '--influx-port=+[influxdb port]:port:' \
  '--influx-dbname=+[influxdb db]:db:' \
  '--prometheus-port=+[Prometheus port]:port:' \
  '--prometheus-namespace=+[Prometheus namespace]:ns:' \
  '--verbose=+[verbosity level]:level:(error warn info debug)' \
  '--testdata-multiplier=+[test data multiplier]:n:' \
  '--testdata-days=+[test data days]:days:' \
  '--servers-refresh-loop-seconds=+[servers refresh sec]:sec:' \
  '--no-helper-functions[disable helper functions]' \
  '--realdbname-fields[show real db name]' && ret=0

return ret
