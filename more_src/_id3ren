#compdef id3ren
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/id3ren.1.html
# id3ren - read/write ID3 tags from mp3 files and rename by tag

local ret=1

_arguments -s \
  '-help[display help]' \
  '-tag[request tag info even if file already tagged]' \
  '-edit[modify specific tag fields only]' \
  '-tagonly[request tag info without renaming files]' \
  '-showtag[display tags for specified files]' \
  '-striptag[remove tags from files]' \
  '-notagprompt[skip tag prompts; ignore untagged files]' \
  '-song=-[set song name for all files]:song' \
  '-artist=-[set artist name for all files]:artist' \
  '-album=-[set album name for all files]:album' \
  '-year=-[set year for all files]:year' \
  '-genre=-[set genre by number or name]:genre' \
  '-comment=-[set comment for all files]:comment' \
  '-track=-[set track number]:track' \
  '-copytagfrom=-[source file for tag copying]:file:_files' \
  '-copysong[copy song field]' \
  '-copyartist[copy artist field]' \
  '-copyalbum[copy album field]' \
  '-copyyear[copy year field]' \
  '-copygenre[copy genre field]' \
  '-copycomment[copy comment field]' \
  '-copytrack[copy track field]' \
  '-copyall[copy all fields]' \
  '-showgen[display all available genres]' \
  '-searchgen=-[search genres by number or name]:genre' \
  '-template=-[set filename pattern]:template' \
  '-tagtemplate=-[set tagging pattern]:template' \
  '-tagfromfilename[extract info from filename]' \
  '-tagffn[extract info from filename]' \
  '-defcase[use original case from tags]' \
  '-lower[convert to lowercase]' \
  '-upper[convert to uppercase]' \
  '-remchar=-[remove specified characters]:chars' \
  '-repchar=-[replace characters]:chars' \
  '-space=-[replace spaces with string]:string' \
  '-quick[skip album, comment, and year prompts]' \
  '-noalbum[skip album prompt]' \
  '-nocomment[skip comment prompt]' \
  '-noyear[skip year prompt]' \
  '-nogenre[skip genre prompt]' \
  '-notrack[skip track prompt]' \
  '-default=-[set fallback value for blank fields]:default' \
  '-nocfg[ignore config files]' \
  '-quiet[display only errors or prompts]' \
  '-verbose[show additional messages]' \
  '-log[log output to id3ren.log]' \
  '*:mp3 file:_files -g "*.mp3"' && ret=0

return ret
