#compdef bld
# Documentation: https://github.com/rife2/bld/wiki/Standard-Commands
# bld - pure Java build system

local ret=1

_arguments -s -S \
  '(- *)'{-?,--help}'[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    local -a cmds
    cmds=(
      'clean:clean the build files'
      'compile:compile the project'
      'dependency-tree:output the dependency tree of the project'
      'download:download all dependencies of the project'
      'help:provide help about any of the other commands'
      'jar:create a jar archive for the project'
      'jar-javadoc:create a javadoc jar archive for the project'
      'jar-sources:create a sources jar archive for the project'
      'javadoc:generate javadoc for the project'
      'precompile:pre-compile templates for production deployment'
      'publish:publish artifacts to a Maven-compatible repository'
      'publish-local:publish to the local maven repository'
      'purge:remove unused artifacts from the classpath'
      'run:run the project'
      'test:test the project with JUnit'
      'uberjar:create an UberJar archive for the project'
      'updates:check for updates of the project dependencies'
      'version:output the version of the build system'
      'war:create a deployable web archive'
    )
    _describe -t commands 'bld command' cmds && ret=0
    ;;
esac

return ret
