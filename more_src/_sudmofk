#compdef sudmofk
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/dip_moveout/sudmofk.c
# DMO via F-K domain (log-stretch) for common-offset gathers

local ret=1

_arguments -s -S \
  'cdpmin=[minimum cdp for which to apply DMO]:cdpmin' \
  'cdpmax=[maximum cdp for which to apply DMO]:cdpmax' \
  'dxcdp=[distance between adjacent cdp bins (m)]:dxcdp' \
  'noffmix=[number of offsets to mix]:noffmix' \
  'tdmo=[times corresponding to rms velocities in vdmo (s)]:tdmo' \
  'vdmo=[rms velocities corresponding to times in tdmo (m/s)]:vdmo' \
  'sdmo=[DMO stretch factor]:sdmo' \
  'fmax=[maximum frequency in input traces (Hz)]:fmax' \
  'verbose=[=1 for diagnostic print]:verbose' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0


return ret
