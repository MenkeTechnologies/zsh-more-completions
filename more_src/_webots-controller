#compdef webots-controller
# Documentation: https://www.cyberbotics.com/doc/guide/running-extern-robot-controllers
# Webots extern robot controller launcher

local ret=1

_arguments -s -S \
  '--help[display help message and exit]' \
  '--protocol=[communication protocol between controller and Webots]:protocol:(ipc tcp)' \
  '--ip-address=[remote machine IP address (required for tcp)]:ip' \
  '--port=[port for connection (default 1234)]:port' \
  '--robot-name=[target a specific robot by name]:name' \
  '--interactive[launch MATLAB in interactive debugging mode]' \
  '--matlab-path=[path to a specific MATLAB executable]:path:_files' \
  '--stdout-redirect[redirect controller stdout to Webots console]' \
  '--stderr-redirect[redirect controller stderr to Webots console]' \
  '*:controller:_files' && ret=0

return ret
