#compdef hclfmt
# Documentation: https://man.archlinux.org/search?q=hclfmt
# Reference accessed: 2026-05-16

_arguments -s \
  '-check[syntax check, no rewrite]' \
  '-require-no-change[non-zero exit if file would change]' \
  '-w[overwrite source files]' \
  '(- *)-version[print version]' \
  '*:hcl file:_files -g "*.(hcl|tf|tfvars)"'
