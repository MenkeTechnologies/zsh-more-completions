#compdef varnishstat

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-1[print statistics once and exit]' \
  '-f+[field inclusion glob]:glob' \
  '-j[output as JSON]' \
  '-l[list available counters]' \
  '-n+[specify varnishd instance name]:name' \
  '-N+[specify VSM file]:file:_files' \
  '-r[toggle raw/average mode]' \
  '-t+[timeout before dying]:seconds' \
  '-x[output as XML]' && ret=0

return ret
