#compdef klockstat klockstat-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/klockstat.py argparse)
# Reference accessed: 2026-05-29
# klockstat — trace kernel mutex/spinlock acquire/hold statistics with stacks (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --duration)'{-d,--duration=}'[total duration of trace in seconds]:sec:' \
  '(-i --interval)'{-i,--interval=}'[print summary at this interval (seconds)]:sec:' \
  '(-n --locks)'{-n,--locks=}'[print given number of locks (default unlimited)]:N:' \
  '(-s --stacks)'{-s,--stacks=}'[print given number of stack entries (default 1)]:N:' \
  '(-c --caller)'{-c,--caller=}'[print locks taken by given caller]:caller:' \
  '(-S --sort)'{-S,--sort=}'[sort data on <aq_field,hd_field>: acq_max/acq_total/acq_count/hld_max/hld_total/hld_count]:field:' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-t --tid)'{-t,--tid=}'[trace this TID only]:tid:' \
  '--stack-storage-size=[number of unique stack traces stored (default 16384)]:N:' \
  && ret=0

return ret
