#compdef clean
# Documentation: https://man.archlinux.org/search?q=clean
# Reference accessed: 2026-05-16

# Zsh completion for clean
# Upstream: Search for files matching a regex and delete them
# Conservative fallback — run `clean --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
