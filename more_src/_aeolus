#compdef aeolus

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-J[use JACK]' \
  '-A[use ALSA]' \
  '-O[OSC server]' \
  '-N+[JACK client name]:name:' \
  '-S+[stops directory]:dir:_files -/' \
  '-I+[instrument dir]:dir:_files -/' \
  '-W+[waves directory]:dir:_files -/' \
  '-r+[sample rate]:rate:(22050 44100 48000 96000)' \
  '-p+[period frames]:n:' \
  '-n+[number of voices]:n:' \
  '-B[do not start server in background]' \
  '-d+[midi device]:dev:' \
  '-t+[ALSA midi target]:target:' \
  '-u[uppercase only]' \
  '-v[verbose]' && ret=0

return ret
