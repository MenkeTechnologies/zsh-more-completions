#compdef wmsetbg
# Documentation: https://man.archlinux.org/search?q=wmsetbg
# Reference accessed: 2026-05-16

# wmsetbg: Window Maker tool to set root background
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-display[X display]:display:' \
  '-d[dither]:bool:(yes no)' \
  '-m[match colors]' \
  '-S[smooth fill]' \
  '-back[fill color]:color:' \
  '-tile[tile image]' \
  '-center[center image]' \
  '-scale[scale to fit]' \
  '-maxscale[scale preserving aspect ratio]' \
  '-fillscale[fill scaled image]' \
  '-update-domain[update WMRootMap domain]:domain:' \
  '-update-wmaker[update WindowMaker config]' \
  '-workspace[workspace]:ws:' \
  '-W[use texture]:texture:' \
  '-u[remember as default]' \
  '*:image:_files' && ret=0
return ret
