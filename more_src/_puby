#compdef puby
# Documentation: https://pub.dev/packages/puby
# puby - run pub/flutter commands across all projects in a monorepo

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
  '(-h --help)'{-h,--help}'[print usage information]' \
  '--version[show version information]' \
  '--no-fvm[disable FVM support]' \
  '1:command:(get link clean gen test upgrade mup exec run reset relink)' \
  '*::args:' && ret=0

return ret
