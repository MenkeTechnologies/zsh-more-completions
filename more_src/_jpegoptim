#compdef jpegoptim
# Zsh completion for jpegoptim
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  {-d,--dest}'[set destination directory]:directory:_directories' \
  {-f,--force}'[force optimization]' \
  {-m,--max}'[set maximum image quality factor (0-100)]:quality:' \
  {-n,--noaction}'[do not really optimize files, just print results]' \
  {-o,--overwrite}'[overwrite target file even if it exists]' \
  {-p,--preserve}'[preserve file modification times]' \
  {-q,--quiet}'[quiet mode]' \
  {-s,--strip-all}'[strip all markers from output file]' \
  {-t,--totals}'[print totals after processing all files]' \
  {-T,--threshold}'[set minimum percentage improvement threshold]:%:' \
  '--size[try to optimize file to given size]:size:' \
  '--all-normal[force all output files to be non-progressive]' \
  '--all-progressive[force all output files to be progressive]' \
  '--strip-com[strip comment markers from output file]' \
  '--strip-exif[strip EXIF markers from output file]' \
  '--strip-iptc[strip IPTC/Photoshop markers from output file]' \
  '--strip-icc[strip ICC profile markers from output file]' \
  '--strip-xmp[strip XMP markers from output file]' \
  '--strip-none[do not strip any markers]' \
  '--csv[print progress info in CSV format]' \
  '--stdin[read image from stdin]:filename:' \
  '--stdout[send output to stdout]' \
  {-v,--verbose}'[enable verbose mode]' \
  {-V,--version}'[print program version]' \
  {-h,--help}'[display help]' \
  '*:JPEG file:_files -g "*.(jpg|jpeg)(-.)"' && ret=0
return ret
