#compdef uptimerobot-cli uptimerobot uptimerobotctl
# _uptimerobot-cli — UptimeRobot uptimerobot-cli CLI command-line frontend wrapping the UptimeRobot uptime monitoring SSL monitoring keyword monitoring port monitoring HTTPS-HTTP-Ping-Port-Keyword-CRON-Heartbeat platform REST API providing getMonitors newMonitor editMonitor deleteMonitor resetMonitor getAlertContacts newAlertContact editAlertContact deleteAlertContact getMWindows newMWindow editMWindow deleteMWindow getPSPs newPSP editPSP deletePSP (UptimeRobot team, Go); cobra
# upstream: https://uptimerobot.com/

_uptimerobot-cli() {
    local -a sub=(
        'login:authenticate'
        'monitor:monitor operations'
        'alert-contact:alert contact operations'
        'maintenance-window:maintenance window operations'
        'psp:public status page operations'
        'account-details:account details'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '--type=+[t]:t:(HTTP keyword ping port heartbeat)' \
        '--friendly-name=+[name]:str:' \
        '--url=+[url]:str:' \
        '--interval=+[sec]:n:' \
        '--timeout=+[sec]:n:' \
        '--port=+[port]:n:' \
        '--sub-type=+[t]:t:(HTTP HTTPS FTP SMTP POP3 IMAP)' \
        '--keyword-type=+[t]:t:(exists notexists)' \
        '--keyword-value=+[value]:str:' \
        '--http-username=+[user]:_users' \
        '--http-password=+[password]:str:' \
        '--alert-contacts=+[ids]:str:' \
        '--mwindows=+[ids]:str:' \
        '--ignore-ssl-errors=+[v]:v:(0 1)' \
        '--custom-http-headers=+[json]:str:' \
        '--post-type=+[t]:t:(0 1)' \
        '--post-value=+[v]:str:' \
        '--post-content-type=+[t]:t:(0 1 2)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'uptimerobot subcommand' sub ;;
        args)
            case $words[1] in
                monitor|alert-contact|maintenance-window|psp) _arguments '1:op:(list get create update delete reset pause resume)' '*:id:' ;;
            esac
            ;;
    esac
}

_uptimerobot-cli "$@"
