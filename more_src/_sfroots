#compdef sfroots
# Documentation: https://github.com/ahay/src/blob/master/system/generic/Mroots.c
# Madagascar: find roots of a complex polynomial

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'niter=[number of iterations]:count' \
  'tol=[tolerance for convergence]:value' \
  'verb=[verbosity flag]:flag:(y n)' \
  'sort=[attribute for sorting]:attribute:(phase amplitude real imaginary)' \
  '*:RSF file:_files' && ret=0

return ret
