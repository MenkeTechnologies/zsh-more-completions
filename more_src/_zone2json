#compdef zone2json
# Documentation: https://doc.powerdns.com/authoritative/manpages/zone2json.1.html
# Convert BIND named.conf and zone files to JSON for the PowerDNS API

local ret=1

_arguments -s -S \
  '--help[display all available options]' \
  '--named-conf=[read BIND configuration from path]:path:_files' \
  '--zone=[parse only the zone file at path]:path:_files' \
  '--zone-name=[zone name for a single zone without $ORIGIN]:name:' \
  '--on-error-resume-next[continue parsing when zone files are missing]' \
  '--verbose[enable verbose output]' && ret=0

return ret
