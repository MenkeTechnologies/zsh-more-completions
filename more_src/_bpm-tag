#compdef bpm-tag
# Documentation: https://man.archlinux.org/search?q=bpm-tag
# Reference accessed: 2026-05-16

# Zsh completion for bpm-tag from bpm-tools — tags audio files with detected tempo

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h -?)'{-h,-?}'[help]' \
  '-f[recompute even if BPM tag exists]' \
  '-n[print BPM only, do not retag]' \
  '-m+[minimum BPM search bound]:bpm' \
  '-x+[maximum BPM search bound]:bpm' \
  '*:audio file:_files' && ret=0

return ret
