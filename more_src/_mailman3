#compdef mailman3 mailman
# Documentation: https://manpages.debian.org/bookworm/mailman3/mailman.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm mailman(1) manpage from the mailman3 package.
# Removed from prior file: fabricated -V flag and bogus man.archlinux.org
# search URL.

# mailman3: command-line interface for GNU Mailman 3
local curcontext="$curcontext" ret=1
local -a commands
commands=(
  'help:show help for a subcommand'
  'aliases:regenerate aliases.db file'
  'conf:print Mailman configuration'
  'create:create a mailing list'
  'digests:process pending digests'
  'import21:import a Mailman 2.1 list'
  'info:display Mailman system info'
  'inject:inject a message into the incoming queue'
  'lists:list all mailing lists'
  'members:list, add, or remove list members'
  'qfile:show contents of a queue file'
  'remove:remove a mailing list'
  'reopen:reopen all log files'
  'restart:restart the master and runners'
  'shell:open an interactive shell on a list'
  'start:start the master and runners'
  'status:show status of the master process'
  'stop:stop the master and runners'
  'unshunt:unshunt messages from the shunt queue'
  'version:print Mailman version'
  'withlist:operate on a list with a Python script'
)
_arguments -C \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-v --version)'{-v,--version}'[print version and exit]' \
  '(-C --config)'{-C,--config=}'[configuration file to use]:file:_files' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mailman command' commands && ret=0 ;;
esac
return ret
