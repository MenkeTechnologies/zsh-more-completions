#compdef pandoc
# Documentation: https://pandoc.org/MANUAL.html
# Source: jgm/pandoc — universal document converter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a formats=(
    markdown markdown_strict markdown_phpextra markdown_mmd commonmark commonmark_x gfm
    html html4 html5 epub epub2 epub3 docbook docbook4 docbook5 jats jats_archiving jats_articleauthoring jats_publishing
    asciidoc asciidoctor man muse opml org rst rtf tei texinfo textile
    latex beamer context docx odt pptx slidy slideous dzslides revealjs s5
    fb2 icml ipynb json native opendocument plain typst ms mediawiki dokuwiki tikiwiki vimwiki haddock t2t twiki
    csljson biblatex bibtex ris
)

_arguments -s \
    '(-f --from -r --read)'{-f+,--from=}'[input format]:fmt:('"$formats"')' \
    '(-f --from -r --read)'{-r+,--read=}'[input format (alias)]:fmt:('"$formats"')' \
    '(-t --to -w --write)'{-t+,--to=}'[output format]:fmt:('"$formats"')' \
    '(-t --to -w --write)'{-w+,--write=}'[output format (alias)]:fmt:('"$formats"')' \
    '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files' \
    '(-s --standalone)'{-s,--standalone}'[output with header/footer template]' \
    '--template=[custom template file]:file:_files' \
    '*'{-d,--defaults=}'[defaults YAML file]:file:_files' \
    '*'{-M,--metadata=}'[set metadata field (KEY[=VAL])]:metadata:' \
    '*'{-V,--variable=}'[set template variable (KEY[=VAL])]:variable:' \
    '*--metadata-file=[YAML/JSON metadata file]:file:_files' \
    '*'{-F,--filter=}'[apply executable filter to AST]:program:_command_names -e' \
    '*'{-L,--lua-filter=}'[Lua AST filter]:script:_files' \
    '(--toc --table-of-contents)--toc[include auto-generated table of contents]' \
    '(--toc --table-of-contents)--table-of-contents[include auto-generated table of contents]' \
    '--toc-depth=[TOC depth]:n:' \
    '(-N --number-sections)'{-N,--number-sections}'[number section headings]' \
    '(-i --incremental)'{-i,--incremental}'[display slide items one-by-one]' \
    '--slide-level=[heading level for slides]:n:' \
    '--mathjax=-[render math via MathJax (optional URL)]:url:' \
    '--katex=-[render math via KaTeX (optional URL)]:url:' \
    '--mathml[render math as MathML]' \
    '--pdf-engine=[PDF engine]:engine:(pdflatex lualatex xelatex tectonic latexmk wkhtmltopdf weasyprint prince pagedjs-cli context pdfroff typst)' \
    '*--css=[CSS stylesheet URL]:url:' \
    '--data-dir=[Pandoc data directory]:dir:_directories' \
    '--syntax-definition=[KDE XML syntax definition]:file:_files' \
    '--highlight-style=[code-syntax highlighting style]:style:(pygments tango espresso zenburn kate monochrome breezedark haddock)' \
    '--no-highlight[disable syntax highlighting]' \
    '--wrap=[text wrapping mode]:mode:(auto none preserve)' \
    '--columns=[line length]:n:' \
    '(--ascii)--ascii[use ASCII chars only]' \
    '--strip-comments[strip HTML comments]' \
    '(--verbose --quiet)'{-v,--verbose}'[verbose / debugging output]' \
    '(--verbose --quiet)--quiet[suppress informational messages]' \
    '--fail-if-warnings[exit non-zero on warnings]' \
    '--log=[write log messages to file]:file:_files' \
    '(- *)--version[print version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:input file:_files' \
    && ret=0

return ret
