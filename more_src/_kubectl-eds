#compdef kubectl-eds
# Documentation: https://github.com/DataDog/extendeddaemonset
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubeconfig context to use]:context:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'canary:control ExtendedDaemonset canary deployment'
      'get:get ExtendedDaemonSet deployment(s)'
      'get-ers:get ExtendedDaemonSetReplicaset deployment(s)'
      'pods:print the list of pods managed by the EDS'
      'help:help about any command'
    )
    _describe -t commands 'kubectl-eds command' commands && ret=0
    ;;
  args)
    case $line[1] in
      canary)
        _arguments -s -S \
          '1:subcommand:(pods validate pause unpause fail)' \
          '*::arg:_default' && ret=0
        ;;
      pods)
        _arguments -s -S \
          '--select=[filter pods]:filter:(not-ready canary)' \
          '*:: :_default' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
