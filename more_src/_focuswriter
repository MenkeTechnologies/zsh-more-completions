#compdef focuswriter

# FocusWriter: distraction-free writing tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '--portable[force portable mode]' \
  '--datadir=[data directory]:dir:_files -/' \
  '*:document to open:_files -g "*.(txt|md|rtf|odt|fwr)"' && ret=0
return ret
