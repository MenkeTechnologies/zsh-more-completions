#compdef focuswriter
# Documentation: https://man.archlinux.org/search?q=focuswriter
# Reference accessed: 2026-05-16

# FocusWriter: hide-the-world fullscreen writing app
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '*:documents:_files -g "*.(odt|docx|rtf|txt|md|fountain)"' && ret=0
return ret
