#compdef groonga-suggest-learner
# Documentation: https://man.archlinux.org/search?q=groonga-suggest-learner
# Reference accessed: 2026-05-16
# Source: https://github.com/hhatto/zsh_completions/blob/b1627488644e58825560d52b1f4c0c0a8feb6d39/_groonga-suggest-learner
# Repository: hhatto/zsh_completions (_groonga-suggest-learner)

typeset -A opt_args

_arguments -S \
    "-r[receive endpoint (default\: tcp\://*\:1235)]:receive endpoint:" \
    "-s[send endpoint (default\: tcp\://*\:1234)]:send endpoint:" \
    "-l[load from log files made on webserver]:log directory:_gnu_generic" \
    "-d[daemonize]" \
    "*::args:_gnu_generic"
