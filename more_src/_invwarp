#compdef invwarp
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/registration/fnirt/utils.html
# FSL: invert a non-linear warp field

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-w --warp)'{-w,--warp=}'[filename of warp/coefficient to be inverted]:warp:_files' \
  '(-o --out)'{-o,--out=}'[filename of output inverted warp]:output:_files' \
  '(-r --ref)'{-r,--ref=}'[filename of reference image in new target space]:ref:_files' \
  '--rel[treat warp field as relative displacements]' \
  '--abs[treat warp field as absolute coordinates]' \
  '--noconstraint[do not apply Jacobian constraint]' \
  '--niter=[number of gradient-descent iterations]:niter:' \
  '--regularise=[regularisation strength]:reg:' \
  '--jmin=[minimum acceptable Jacobian value]:jmin:' \
  '--jmax=[maximum acceptable Jacobian value]:jmax:' \
  '(-d --debug)'{-d,--debug}'[turn on debugging output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:image:_files' && ret=0

return ret
