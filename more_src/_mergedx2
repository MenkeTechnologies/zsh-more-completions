#compdef mergedx2
# Documentation: https://apbs.readthedocs.io/en/latest/using/tools.html
# Combine OpenDX files into a single resampled map

local ret=1

_arguments -s \
  '(- *)-h[print help message]' \
  '-o[output OpenDX file]:file:_files -g "*.dx"' \
  '-i[input OpenDX type]:type:(dx dxbin)' \
  '-t[output OpenDX type]:type:(dx dxbin)' \
  '-r[grid resolution: xres yres zres]:resolution' \
  '-b[bounds: xmin ymin zmin xmax ymax zmax]:bounds' \
  '-s[print bounds of input files only]' \
  '*:OpenDX file:_files -g "*.dx"' && ret=0

return ret
