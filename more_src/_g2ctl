#compdef g2ctl
# Documentation: https://www.cpc.ncep.noaa.gov/products/wesley/
# make a GrADS control (.ctl) descriptor file from a GRIB2 file

local ret=1

_arguments -s -S \
  '-verf[use end of ave/acc period or fcst time (default)]' \
  '-0[use analysis times]' \
  '-b[use start of averaging/accumulation period]' \
  '-365[use 365 day calendar]' \
  '-no_profile[no z coordinate]' \
  '-raw[use a raw grid]' \
  '-O[for analyses]' \
  '-ens[a list of quoted ensemble names]:ensembles:' \
  '*:grib2 file:_files -g "*.(grb|grb2|grib|grib2)"' && ret=0

return ret
