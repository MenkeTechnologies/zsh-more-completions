#compdef vikunja-cli vikunja
# _vikunja-cli — Vikunja open-source todo and kanban CLI alias (vikunja team, Go); cobra
# upstream: https://kolaente.dev/vikunja/vikunja

_vikunja-cli() {
    local -a sub=(
        'web:start web server'
        'migrate:run migrations'
        'migrate:list:list migrations'
        'migrate:rollback:rollback migrations'
        'migrate:status:migration status'
        'index:rebuild search index'
        'restore:restore from backup'
        'dump:dump everything'
        'testmail:send test mail'
        'user:create:create user'
        'user:list:list users'
        'user:reset-password:reset user password'
        'user:change-status:change user status'
        'user:delete:delete user'
        'user:update:update user'
        'user:set-token:set user api token'
        'project:list:list projects'
        'project:create:create project'
        'project:delete:delete project'
        'project:archive:archive project'
        'project:unarchive:unarchive project'
        'task:list:list tasks'
        'task:create:create task'
        'task:done:mark task done'
        'task:undone:mark task undone'
        'task:delete:delete task'
        'task:assign:assign task'
        'task:unassign:unassign task'
        'task:label:add label'
        'task:unlabel:remove label'
        'label:list:list labels'
        'label:create:create label'
        'label:delete:delete label'
        'comment:list:list comments'
        'comment:create:add comment'
        'comment:delete:delete comment'
        'team:list:list teams'
        'team:create:create team'
        'team:add-user:add user to team'
        'team:remove-user:remove user from team'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "*.{yaml,yml}"' \
        '-c+[config file]:file:_files -g "*.{yaml,yml}"' \
        '--api-url=+[api url]:url:_urls' \
        '--token=+[api token]:str:' \
        '--username=+[username]:user:_users' \
        '--password=+[password]:str:' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vikunja subcommand' sub ;;
        args)
            case $words[1] in
                user:create) _arguments \
                    '--username=+[username]:user:_users' \
                    '-u+[username]:user:_users' \
                    '--email=+[email]:str:' \
                    '-e+[email]:str:' \
                    '--password=+[password]:str:' \
                    '-p+[password]:str:' \
                    '--avatar-provider=+[avatar]:p:(gravatar initials upload marble)' ;;
                user:reset-password) _arguments \
                    '1:username:_users' \
                    '--password=+[new password]:str:' \
                    '-p+[new password]:str:' \
                    '--direct[direct reset]' ;;
                task:create) _arguments \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--project-id=+[project id]:n:' \
                    '--description=+[description]:str:' \
                    '--due=+[due date]:str:' \
                    '--priority=+[priority]:n:' \
                    '--label=+[label]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_vikunja-cli "$@"
