#compdef wazuh-clusterd
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/daemons/wazuh-clusterd.html
# Wazuh cluster daemon

local ret=1

_arguments -s \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-d --debug_level)'{-d,--debug_level}'[enable debug messages (repeat to increase verbosity)]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-r --root)'{-r,--root}'[run as root]' \
  '(-t --test_config)'{-t,--test_config}'[test configuration]' \
  '(-c --config_file)'{-c,--config_file}'[configuration file to use]:config file:_files' && ret=0

return ret
