#compdef lxsplit
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/lxsplit.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Only -j (join) and -s (split with
# size) modes are documented; no --help/--version.

# lxsplit: split or join files
local curcontext="$curcontext" ret=1
_arguments -C \
  '-j[join files beginning with given name]:basename:_files' \
  '-s[split given file into chunks of size (e.g. 15M, 100m, 5000k)]:file:_files' \
  '*:size or files:' && ret=0
return ret
