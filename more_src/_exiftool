#compdef exiftool
# Documentation: https://exiftool.org/exiftool_pod.html
# Source: Phil Harvey's ExifTool — read/write metadata in image/audio/video files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G[print group name for each tag]' \
    '-G0[print family-0 group name]' \
    '-G1[print family-1 group name]' \
    '-G2[print family-2 group name]' \
    '-s[short output (tag names instead of descriptions)]' \
    '-s2[short output level 2]' \
    '-s3[short output level 3 (values only)]' \
    '-S[very short format]' \
    '-short[same as -s]' \
    '-ee[extract from embedded documents]' \
    '-fast[increase speed (skip validations)]' \
    '-r[recursive]' \
    '-if[condition to evaluate per file]:expr:' \
    '-overwrite_original[overwrite original (no backup)]' \
    '-overwrite_original_in_place[overwrite preserving attributes]' \
    '-P[preserve filesystem mtime]' \
    '-delete_original[delete _original backups]' \
    '-delete_original\![delete _original backups without prompt]' \
    '*-p[output format string or file]:string or file:' \
    '-j[JSON output]' \
    '-X[ExifTool-specific RDF/XML output]' \
    '-csv[CSV output]' \
    '-t[tab-delimited output]' \
    '-charset[output character encoding]:encoding:(UTF8 Latin Latin1 Latin2 CP437 CP866 CP874 CP932 CP936 CP949 CP950 CP1250 CP1251 CP1252 CP1253 CP1254 CP1255 CP1256 CP1257 CP1258 ShiftJIS)' \
    '-L[Windows Latin1 (cp1252) output]' \
    '-fileOrder[process file order by tag]:tag:' \
    '*-api[ExifTool API option]:opt=value:' \
    '-execute[execute multiple commands on one line]' \
    '-common_args[common arguments for -execute]' \
    '-listd[list deletable tag groups]' \
    '-listr[list recognized file extensions]' \
    '-listg[list tag groups]' \
    '-All[indicate all meta info]' \
    '-All=[delete all metadata]' \
    '-tagsFromFile[copy tags from source file]:srcfile:_files' \
    '-q[suppress informational messages]' \
    '-v[verbose (use multiple times)]' \
    '*:file or directory:_files' \
    && ret=0

return ret
