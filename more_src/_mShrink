#compdef mShrink
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mShrink.html
# Shrink a FITS image by averaging pixel blocks

local ret=1

_arguments -s -S \
  '-f[fixed-size mode: factor is output image width]' \
  '-d+[debugging level (1-4)]:level' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '1:input FITS:_files -g "*.fits"' \
  '2:output FITS:_files -g "*.fits"' \
  '3:factor' && ret=0

return ret
