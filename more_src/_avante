#compdef avante
# Documentation: https://github.com/yetone/avante.nvim
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*::passthrough:_command_names' && ret=0

return ret
