#compdef pngnq-s9
# Documentation: https://sourceforge.net/p/pngnqs9/wiki/pngnq-s9%20Command%20Line%20Help/
# quantize a PNG image to 256 or fewer colours using NeuQuant

local ret=1

_arguments -s \
  '-H[print full help message]' \
  '-h[print shorter help message]' \
  '-V[print version information]' \
  '-v[print verbose status messages]' \
  '-n+[number of colours (1-256, default 256)]:colours' \
  '-s+[sample rate (input pixel sampling frequency)]:rate' \
  '-d+[output directory]:dir:_files -/' \
  '-e+[output file extension]:extension' \
  '-f[force overwrite of existing files]' \
  '-P+[user-supplied palette, strict RGBA]:palette:_files' \
  '-p+[user-supplied palette, nudge-able]:palette:_files' \
  '-g+[gamma correction value, unrecorded]:gamma' \
  '-G+[gamma correction value, recorded]:gamma' \
  '-t+[transparency extenuation]:value' \
  '-T+[transparency extenuation with strict remapping]:value' \
  '-A[turn alpha importance heuristic off]' \
  '-C+[colour space: r (RGBA) or y (YUVA)]:space:(r y)' \
  '-u+[un-isolate, emphasise rarely used colours]:value' \
  '-x+[exclusion threshold]:value' \
  '-Q+[dither mode: n (none) or f (Floyd-Steinberg)]:mode' \
  '-L[low colour mode preset (under 40 colours)]' \
  '-0+[sensitivity reduction factor for red or Y]:value' \
  '-1+[sensitivity reduction factor for green or U]:value' \
  '-2+[sensitivity reduction factor for blue or V]:value' \
  '-a+[sensitivity reduction factor for alpha]:value' \
  '-R[restrict remaining sensitivity flags to remapping]' \
  '*:png file:_files -g "*.(png|PNG)"' && ret=0

return ret
