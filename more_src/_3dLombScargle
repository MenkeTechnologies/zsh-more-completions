#compdef 3dLombScargle
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dLombScargle.html
# AFNI periodogram/amplitude-spectrum of non-uniformly sampled time series

local ret=1

_arguments -s -S \
  '-prefix[output prefix for volume and 1D files]:prefix:' \
  '-inset[input time series 4D volume]:dataset:_files' \
  '-censor_1D[1D row of keep(1)/censor(0) values]:file:_files' \
  '-censor_str[AFNI selector string of volumes to retain]:str:' \
  '-mask[mask of which voxels to analyze]:mask:_files' \
  '-out_pow_spec[output power spectrum instead of amplitude]' \
  '-nyq_mult[multiplier for max frequency threshold]:n2:' \
  '-nifti[output as compressed NIFTI (.nii.gz)]' \
  '*:dataset:_files' && ret=0

return ret
