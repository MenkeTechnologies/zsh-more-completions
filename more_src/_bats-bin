#compdef bats
# _bats-bin — Bats Bash Automated Testing System (Sam Stephenson, bats-core community); TAP-compliant Bash test framework
# upstream: https://github.com/bats-core/bats-core

_bats-bin() {
    _arguments \
        '(-c --count)'{-c,--count}'[count test count]' \
        '(-f --filter)'{-f,--filter}'+[filter regex]:regex:' \
        '(-F --formatter)'{-F,--formatter}'+[output formatter]:fmt:(pretty tap tap13 junit)' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-j --jobs)'{-j,--jobs}'+[parallel jobs]:n:' \
        '(--no-tempdir-cleanup)--no-tempdir-cleanup[keep BATS_RUN_TMPDIR]' \
        '(-o --output)'{-o,--output}'+[report output dir]:dir:_files -/' \
        '(-p --pretty)'{-p,--pretty}'[pretty formatter (default tty)]' \
        '(-T --timing)'{-T,--timing}'[show test timing]' \
        '(-t --tap)'{-t,--tap}'[TAP-compliant output]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-x --trace)'{-x,--trace}'[print test commands as executed]' \
        '(-r --recursive)'{-r,--recursive}'[recurse into dirs]' \
        '(--print-output-on-failure)--print-output-on-failure[show output on failed test]' \
        '(--show-output-of-passing-tests)--show-output-of-passing-tests[show output of passing tests]' \
        '(--verbose-run)--verbose-run[print run output]' \
        '(--gather-test-outputs-in)--gather-test-outputs-in+[gather outputs dir]:dir:_files -/' \
        '(--code-quote-style)--code-quote-style+[quote style]:style:' \
        '(--filter-status)--filter-status+[status filter]:status:(passed failed)' \
        '(--filter-tags)--filter-tags+[tag filter]:tags:' \
        '(--no-parallelize-across-files)--no-parallelize-across-files[serial across files]' \
        '(--no-parallelize-within-files)--no-parallelize-within-files[serial within file]' \
        '*:test file:_files -g "*.bats"'
}

_bats-bin "$@"
