#compdef bugsnag-cli
# Documentation: https://github.com/bugsnag/bugsnag-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands upload_subs

subcommands=(
  'create-android-build-id:create Android build id'
  'create-build:create a build'
  'upload:upload symbols/sourcemaps'
)

upload_subs=(
  'all:upload all sources auto-detected'
  'android-aab:upload Android AAB'
  'android-ndk:upload Android NDK'
  'android-proguard:upload Android Proguard'
  'breakpad:upload Breakpad symbols'
  'dart:upload Dart symbols'
  'dsym:upload dSYM (deprecated)'
  'js:upload JS sourcemaps'
  'linux:upload Linux symbols'
  'react-native:upload React Native'
  'react-native-android:upload React Native Android'
  'react-native-ios:upload React Native iOS'
  'react-native-sourcemaps:upload RN sourcemaps'
  'unity-android:upload Unity Android'
  'unity-ios:upload Unity iOS'
  'xcode-archive:upload Xcode archive'
  'xcode-build:upload Xcode build'
)

_arguments -C \
  '--api-key=[Bugsnag API key]:key:' \
  '--dry-run[do not upload]' \
  '--log-level=[log level]:level:(debug info warn fatal)' \
  '--port=[port]:port:' \
  '--verbose[verbose output]' \
  '(- *)--version[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'bugsnag-cli subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (upload)
        if (( CURRENT == 2 )); then
          _describe -t upload_subs 'upload type' upload_subs && ret=0
        else
          _arguments \
            '--overwrite[overwrite existing]' \
            '--project-root=[project root]:dir:_files -/' \
            '--version-name=[version name]:name:' \
            '--version-code=[version code]:code:' \
            '--application-id=[application id]:id:' \
            '--build-uuid=[build uuid]:uuid:' \
            '--no-build-uuid[no build uuid]' \
            '--variant=[build variant]:variant:' \
            '--app-manifest=[app manifest]:file:_files' \
            '--retries=[retries]:n:' \
            '--timeout=[timeout]:s:' \
            '--upload-api-root-url=[upload API URL]:url:' \
            '*--exclude=[exclude pattern]:pattern:' \
            '*:path:_files' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
