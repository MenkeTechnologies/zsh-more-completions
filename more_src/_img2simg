#compdef img2simg

# img2simg: convert raw image to Android sparse image
# Documentation: https://android.googlesource.com/platform/system/core/+/refs/heads/main/libsparse/README.md
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[do not compute checksums]' \
  '*:input output block_size:_files' && ret=0
return ret
