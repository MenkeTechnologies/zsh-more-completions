#compdef ecpprog
# _ecpprog — gregdavill ecpprog CLI flashing ECP5 FPGA bitstream files into SPI flash memory through FTDI FT2232H FT232H FT4232H USB-JTAG adapters write/read/verify/erase operations OrangeCrab ColorLight Versa boards (Greg Davill team, C); custom argparse
# upstream: https://github.com/gregdavill/ecpprog

_ecpprog() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d+[device serial]:str:' \
        '-I+[interface]:i:(A B C D)' \
        '-S+[serial]:str:' \
        '-r[read flash]' \
        '-R+[bytes]:n:' \
        '-w[write only no verify]' \
        '-c[check]' \
        '-b[bulk erase]' \
        '-e[erase]' \
        '-n[no erase]' \
        '-p[probe and exit]' \
        '-t[test SRAM mode]' \
        '-X[exit unstuck]' \
        '-o+[offset]:str:' \
        '-s+[hex offset]:str:' \
        '-x+[ignore size]:n:' \
        '--checkbusy[check busy]' \
        '*:bitstream:_files -g "*.bit *.svf *.bin"'
}

_ecpprog "$@"
