#compdef rggr
# ============================================================================
# rggr - Goodreads-upstream metadata server for Readarr (Go, GPL-3.0)
#
# Author : Bryce Lampe (blampe)
# Upstream: https://github.com/blampe/rreading-glasses
#
# `rggr` is the Goodreads-backed variant of "Reading Glasses"
# - a self-hostable metadata-server replacement for Readarr's
# upstream book-metadata API. The CLI runs an HTTP server
# that intercepts Readarr's metadata calls, fetches author /
# work / book / series data from Goodreads via GraphQL,
# enriches the responses with on-disk Postgres-cached state,
# and serves the result back as the upstream-compatible
# JSON Readarr expects. The point: Readarr's official
# upstream (BookInfo) has been flaky for years; rggr is
# Readarr operators' open-source alternative.
#
# Companion binary: `rghc` does the same for HardcoverApp
# instead of Goodreads (separate upstream, separate GraphQL
# schema).
#
# Subcommands (kong CLI):
#   serve                       - run the HTTP metadata server
#                                 (default)
#   bust <author-id>            - manually bust a cache entry
#
# serve flags:
#   --port <n>                  - bind port (default 8788)
#   --rpm <n>                   - max upstream requests/min (0=disabled)
#   --cookie / --cookie-file <p>- upstream HTTP cookie (xor)
#   --proxy <url>               - HTTP proxy for upstream
#   --upstream <host>           - REQUIRED upstream hostname
#                                 (e.g. www.goodreads.com)
#
# Postgres config (shared by serve + bust):
#   --postgres-host             - default localhost
#   --postgres-user             - default postgres
#   --postgres-password / --postgres-password-file (xor db-auth)
#   --postgres-port             - default 5432
#   --postgres-database         - default rreading-glasses
#
# Cloudflare cache-bust config (optional, all 3 required if any):
#   --cloudflare-token <tok>
#   --cloudflare-zone-id <id>
#   --cloudflare-domain <dom>
#
# Logging:
#   --verbose                   - DEBUG-level logs
#
# Every flag has a matching env var (kong's standard
# `env:"NAME"` mapping); e.g. POSTGRES_HOST, PORT, COOKIE,
# UPSTREAM, CLOUDFLARE_TOKEN, VERBOSE.
#
# The genqlient lane is built on `github.com/Khan/genqlient
# v0.8.1` (declared as a direct dep at upstream go.mod HEAD,
# with the `tool` directive marking it for go:generate-style
# codegen at build time), the canonical Go typed GraphQL
# client by Khan Academy (github.com/Khan/genqlient, 1900+
# stars). genqlient is Khan's *typed-codegen-first* answer
# to GraphQL clients in Go: point it at a schema and a
# query file, and it emits per-query strongly-typed
# request + response structs into a .go file that gets
# committed to the repo. rggr uses it for the Goodreads
# GraphQL schema (rggr's `internal.GRGQL` upstream wrapper) -
# every Goodreads query that rggr makes has a typed Go
# struct generated by genqlient at build time, so the
# entire upstream-fetch path is type-safe end-to-end.
#
# ----------------------------------------------------------------------------
# AXIS 237 :: GraphQL clients (typed queries from .graphql files)
# Round 1410 :: Go slot 2 of 4 :: continues Axis 237
#
# Cross-language canonical library family for this axis:
#   Rust    : graphql-rust/graphql-client  [R1409 _arbor-cli]
#   Go      : Khan/genqlient               [R1410 THIS FILE]
#   TS/Node : prisma-labs/graphql-request  [R1411 closing]
#
# genqlient is structurally interesting: the Khan Academy
# team built it explicitly because they were unsatisfied
# with shurcooL/graphql (the older Go GraphQL client) -
# shurcooL/graphql uses runtime reflection to bind responses
# into user-supplied structs, which Khan considered
# error-prone at scale. genqlient flips the model:
# everything is codegen + compile-time-typed. The two Go
# libraries coexist - shurcooL/graphql still works for
# small projects that don't want a build-time codegen step
# - but the Go-language preference for explicit typing has
# pushed the canonical-library mantle toward genqlient.
#
# The cross-lane structural pattern in Axis 237:
#   - Rust (graphql-client): derive-macro at compile time
#     reads .graphql files and emits typed structs into
#     the compilation
#   - Go (genqlient): codegen at `go generate` time reads
#     .graphql files and emits a typed .go file that gets
#     committed to the repo
#   - Node (graphql-request): runtime-typed via
#     TypeScript generics; the matching codegen layer
#     (graphql-codegen) is a separate package
#
# Three different positions on the codegen-vs-runtime
# spectrum, all targeting the same GraphQL spec wire
# format. Cross-language interop at the wire level is
# total - the produced HTTP POST bodies are byte-identical
# for the same query + variables.
# ============================================================================

_rggr() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '1: :_rggr_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                serve) _rggr_serve_args ;;
                bust)  _rggr_bust_args ;;
            esac
            ;;
    esac

    return ret
}

_rggr_cmds() {
    local -a cmds
    cmds=(
        'serve:Run the HTTP metadata server (default)'
        'bust:Bust cache entries by author ID'
    )
    _describe -t commands 'rggr command' cmds
}

_rggr_pg_args() {
    print -- \
        '--postgres-host[Postgres host (default localhost)]:host:' \
        '--postgres-user[Postgres user (default postgres)]:user:' \
        '--postgres-password[Postgres password]:password:' \
        '--postgres-password-file[file with the Postgres password]:file:_files' \
        '--postgres-port[Postgres port (default 5432)]:port:' \
        '--postgres-database[Postgres database (default rreading-glasses)]:name:'
}

_rggr_cf_args() {
    print -- \
        '--cloudflare-token[Cloudflare API token]:token:' \
        '--cloudflare-zone-id[Cloudflare zone ID]:id:' \
        '--cloudflare-domain[Cloudflare domain for URL construction]:domain:'
}

_rggr_serve_args() {
    _arguments \
        '--port[bind port (default 8788)]:port:' \
        '--rpm[max upstream requests/min (0=disabled)]:n:' \
        '--cookie[HTTP cookie for upstream requests]:cookie:' \
        '--cookie-file[file with cookie for upstream requests]:file:_files' \
        '--proxy[HTTP proxy URL for upstream requests]:url:' \
        '--upstream[upstream hostname (required)]:host:' \
        '--verbose[DEBUG-level logging]' \
        '--postgres-host[Postgres host (default localhost)]:host:' \
        '--postgres-user[Postgres user (default postgres)]:user:' \
        '--postgres-password[Postgres password]:password:' \
        '--postgres-password-file[file with Postgres password]:file:_files' \
        '--postgres-port[Postgres port (default 5432)]:port:' \
        '--postgres-database[Postgres database (default rreading-glasses)]:name:' \
        '--cloudflare-token[Cloudflare API token]:token:' \
        '--cloudflare-zone-id[Cloudflare zone ID]:id:' \
        '--cloudflare-domain[Cloudflare domain]:domain:' \
        '(- *)'{-h,--help}'[help]'
}

_rggr_bust_args() {
    _arguments \
        '--verbose[DEBUG-level logging]' \
        '--postgres-host[Postgres host]:host:' \
        '--postgres-user[Postgres user]:user:' \
        '--postgres-password[Postgres password]:password:' \
        '--postgres-password-file[file with Postgres password]:file:_files' \
        '--postgres-port[Postgres port]:port:' \
        '--postgres-database[Postgres database]:name:' \
        '--cloudflare-token[Cloudflare API token]:token:' \
        '--cloudflare-zone-id[Cloudflare zone ID]:id:' \
        '--cloudflare-domain[Cloudflare domain]:domain:' \
        '(- *)'{-h,--help}'[help]' \
        '1:author ID:'
}

_rggr "$@"
