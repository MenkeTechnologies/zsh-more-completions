#compdef kserve-cli kserve2
# _kserve-cli — KServe kserve-cli CLI command-line frontend wrapping the KServe Kubernetes-native model inference serving platform formerly KFServing managing InferenceService TrainedModel ClusterServingRuntime ServingRuntime predictor explainer transformer canary autoscaling rollout deploy delete describe predict explain (KServe team, Go); cobra
# upstream: https://kserve.github.io/

_kserve-cli() {
    local -a sub=(
        'install:install KServe'
        'uninstall:uninstall KServe'
        'apply:apply InferenceService manifest'
        'delete:delete InferenceService'
        'describe:describe InferenceService'
        'list:list InferenceServices'
        'predict:run prediction'
        'explain:run explanation'
        'logs:fetch logs'
        'rollout:rollout management'
        'runtime:ServingRuntime operations'
        'cluster-runtime:ClusterServingRuntime operations'
        'trained-model:TrainedModel operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '--predictor=+[t]:t:(sklearn xgboost tensorflow pytorch onnx triton lightgbm mlflow paddle pmml model-mesh huggingface)' \
        '--explainer=+[t]:t:(alibi alibi-explain art aix)' \
        '--transformer=+[image]:str:' \
        '--storage-uri=+[uri]:str:' \
        '--service-account-name=+[name]:str:' \
        '--canary-traffic-percent=+[N]:n:' \
        '--rollback-on-failure[rollback on failure]' \
        '--scale-target=+[N]:n:' \
        '--scale-min-replicas=+[N]:n:' \
        '--scale-max-replicas=+[N]:n:' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kserve-cli subcommand' sub ;;
        args)
            case $words[1] in
                apply) _arguments '*:file:_files -g "*.yaml *.yml *.json"' ;;
                delete|describe|predict|explain|logs|rollout) _arguments '*:inference service name:' ;;
                runtime|cluster-runtime|trained-model) _arguments '1:op:(list get apply delete)' '*:name:' ;;
            esac
            ;;
    esac
}

_kserve-cli "$@"
