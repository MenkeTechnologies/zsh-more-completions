#compdef whisper-vad-speech-segments
# Documentation: https://github.com/ggml-org/whisper.cpp/blob/master/examples/vad-speech-segments/speech.cpp
# Reference accessed: 2026-05-27
# Verified: upstream vad_params_parse() and vad_print_usage() in
# examples/vad-speech-segments/speech.cpp (ggml-org/whisper.cpp).
# Note: upstream parser has -vsd duplicated for both min-speech and
# min-silence; the printed usage text (the documented contract) uses
# -vspd for min-speech-duration-ms and -vsd for min-silence-duration-ms,
# matching the convention used elsewhere in whisper.cpp (whisper-cli).
# This completion follows the documented usage text.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-f --file)'{-f+,--file=}'[input audio file path]:file:_files -g "*.(wav|mp3|flac|ogg)(-.)"' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:n:' \
  '(-ug --use-gpu)'{-ug,--use-gpu}'[use GPU]' \
  '(-vm --vad-model)'{-vm+,--vad-model=}'[VAD model path]:file:_files' \
  '(-vt --vad-threshold)'{-vt+,--vad-threshold=}'[VAD speech probability threshold (0-1)]:float:' \
  '(-vspd --vad-min-speech-duration-ms)'{-vspd+,--vad-min-speech-duration-ms=}'[VAD minimum speech duration in ms]:ms:' \
  '(-vsd --vad-min-silence-duration-ms)'{-vsd+,--vad-min-silence-duration-ms=}'[VAD minimum silence duration in ms]:ms:' \
  '(-vmsd --vad-max-speech-duration-s)'{-vmsd+,--vad-max-speech-duration-s=}'[VAD maximum speech duration in seconds]:s:' \
  '(-vp --vad-speech-pad-ms)'{-vp+,--vad-speech-pad-ms=}'[VAD speech padding in ms]:ms:' \
  '(-vo --vad-samples-overlap)'{-vo+,--vad-samples-overlap=}'[VAD sample overlap in seconds]:s:' \
  '(-np --no-prints)'{-np,--no-prints}'[suppress output except results]' \
  '*:audio file:_files -g "*.(wav|mp3|flac|ogg)(-.)"' && ret=0

return ret
