#compdef binsider
# Documentation: https://github.com/orhun/binsider
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for binsider (ELF binary analyzer and inspector)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--tab=[start with specified tab]:tab:(general static dynamic strings hexdump)' \
  ':binary file:_files' && ret=0

return ret
