#compdef sunmo_a
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/stretching_moveout_resamp/sunmo_a.c
# SUNMO_a - NMO with experimental anisotropy options

local ret=1

_arguments -s -S \
  'tnmo=[NMO times corresponding to velocities]:t:' \
  'vnmo=[NMO velocities corresponding to times]:v:' \
  'anis1=[first anisotropy coefficient]:a:' \
  'anis2=[second anisotropy coefficient]:a:' \
  'cdp=[CDPs for which vnmo and tnmo are specified]:c:' \
  'smute=[NMO stretch exceeding smute is zeroed]:s:' \
  'lmute=[length (samples) of linear ramp for mute]:l:' \
  'sscale=[=1 divide output by NMO stretch factor]:s:(0 1)' \
  'invert=[=1 perform approximate inverse NMO]:i:(0 1)' \
  'upward=[=1 scan upward to find first sample to kill]:u:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
