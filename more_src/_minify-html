#compdef minify-html

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '--keep-comments[preserve comments]' \
  '--keep-html-and-head-opening-tags[keep <html> and <head>]' \
  '--keep-closing-tags[keep closing tags]' \
  '--keep-input-type-text-attr[keep type=text]' \
  '--keep-ssi-comments[keep SSI comments]' \
  '--minify-css[minify inline css]' \
  '--minify-css-level-1[CSS level 1]' \
  '--minify-css-level-2[CSS level 2]' \
  '--minify-css-level-3[CSS level 3]' \
  '--minify-js[minify inline js]' \
  '--preserve-brace-template-syntax[preserve mustache]' \
  '--preserve-chevron-percent-template-syntax[preserve template]' \
  '*:html:_files -g "*.{html,htm}"' && ret=0

return ret
