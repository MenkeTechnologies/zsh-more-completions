#compdef imapfilter

# Zsh completion for imapfilter - IMAP mail filtering utility

_arguments -s -S \
  '-c[specify configuration file]:config file:_files' \
  '-d[specify debug file]:debug file:_files' \
  '-e[specify inline configuration string]:config string' \
  '-l[specify log file]:log file:_files' \
  '-t[specify truststore file]:truststore file:_files' \
  '-p[specify pid file]:pid file:_files' \
  '(- *)-V[show version]' \
  '-v[enable verbose output]' \
  '(- *)-h[show help]'
