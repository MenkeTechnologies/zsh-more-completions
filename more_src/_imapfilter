#compdef imapfilter

# Zsh completion for imapfilter - IMAP mail filtering utility

_arguments -s -S \
  '-c[configuration file]:file:_files' \
  '-d[debug file]:file:_files' \
  '-e[inline configuration string]:config string:' \
  '-l[log file]:file:_files' \
  '-t[truststore file]:file:_files' \
  '-p[pidfile]:file:_files' \
  '-n[do not restrict strstriction to system namespace]' \
  '(- *)-V[show version]' \
  '-v[verbose mode]' \
  '(- *)-h[show help]'
