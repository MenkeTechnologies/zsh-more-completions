#compdef netexec nxc

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-t+[number of concurrent threads]:threads:' \
  '--threads=[number of concurrent threads]:threads:' \
  '--timeout=[connection timeout]:seconds:' \
  '--jitter=[jitter for connections]:seconds:' \
  '--verbose[verbose output]' \
  '--debug[debug output]' \
  '--no-progress[hide progress bar]' \
  '--log=[log file]:log file:_files' \
  '1:protocol:->protocols' \
  '*::arg:->args' && ret=0

case $state in
  protocols)
    local -a protocols=(
      'smb:SMB protocol'
      'ssh:SSH protocol'
      'ldap:LDAP protocol'
      'winrm:WinRM protocol'
      'mssql:MSSQL protocol'
      'rdp:RDP protocol'
      'ftp:FTP protocol'
      'wmi:WMI protocol'
      'vnc:VNC protocol'
    )
    _describe -t protocols 'protocol' protocols && ret=0
    ;;
  args)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '-u+[username]:username:' \
      '--username=[username]:username:' \
      '-p+[password]:password:' \
      '--password=[password]:password:' \
      '-H+[NTLM hash]:hash:' \
      '--hash=[NTLM hash]:hash:' \
      '-d+[domain]:domain:' \
      '--domain=[domain]:domain:' \
      '--local-auth[use local authentication]' \
      '--port=[target port]:port:' \
      '-x+[execute command]:command:' \
      '--exec-method=[execution method]:method:(smbexec wmiexec atexec mmcexec)' \
      '--share=[share name]:share:' \
      '--gen-relay-list=[generate relay list]:file:_files' \
      '--sam[dump SAM hashes]' \
      '--lsa[dump LSA secrets]' \
      '--ntds=[dump NTDS]:method:(vss drsuapi)' \
      '--shares[enumerate shares]' \
      '--sessions[enumerate sessions]' \
      '--disks[enumerate disks]' \
      '--loggedon-users[enumerate logged-on users]' \
      '--users[enumerate domain users]' \
      '--groups[enumerate domain groups]' \
      '--computers[enumerate domain computers]' \
      '--local-groups[enumerate local groups]' \
      '--pass-pol[get password policy]' \
      '--rid-brute=[RID brute force]:max RID:' \
      '--spider=[spider shares]:share:' \
      '--spider-folder=[spider folder]:folder:' \
      '--content[search file content]' \
      '--pattern=[search pattern]:pattern:' \
      '-M+[module to use]:module:' \
      '--module=[module to use]:module:' \
      '-o+[module options]:options:' \
      '--options=[module options]:options:' \
      '-L[list available modules]' \
      '--list-modules[list available modules]' \
      '*:targets:_hosts' && ret=0
    ;;
esac

return ret
