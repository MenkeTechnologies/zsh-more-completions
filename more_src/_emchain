#compdef emchain
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/emchain/node11.html
# XMM-Newton SAS: generate the EPIC-MOS event list product

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--odf=[input ODF directory name]:dir:_files -/' \
  '--ingtiset=[user-supplied good time intervals]:file:_files' \
  '--filteratt=[filter data on bad attitude]:flag:(yes no)' \
  '--filterhk=[filter data on bad housekeeping]:flag:(yes no)' \
  '--badpixfindalgo=[bad pixel finding algorithm]:algo:(EP EM NO)' \
  '--randomize=[randomize multiswitch settings]:flag:' \
  '--applyflaregti=[apply proton flare GTI]:flag:(yes no)' \
  '--exposures=[selected exposures to process]:exp:' \
  '--instruments=[selected instruments]:inst:(M1 M2)' \
  '--ccds=[selected CCDs (1-7)]:ccds:' \
  '--runccdloop=[loop over CCDs]:flag:(yes no)' \
  '--startfromodf=[analyze raw ODF files]:flag:(yes no)' \
  '--stopafterbadpixfind=[stop after bad pixels detection]:flag:(yes no)' \
  '--runevlistcomb=[merge CCD-specific event files]:flag:(yes no)' \
  '--makeflaregti=[build GTI for proton flare rejection]:flag:(yes no)' \
  '--rejectbadevents=[reject events with specific flags]:flag:(yes no)' \
  '--rejectionflag=[hexadecimal flag for deletion]:flag:' \
  '--writeccdbackground=[save CCD background per file]:flag:(yes no)' \
  '--processlowgain=[process low gain read-out data]:flag:(yes no)' \
  '--fulloutput=[keep all event list columns]:flag:(yes no)' \
  '--applyccdgti=[apply CCD-specific GTI]:flag:(yes no)' \
  '--usecanonicalnames=[use product-like file names]:flag:(yes no)' \
  '--keepintermediate=[retain intermediate files]:flag:(yes no)' \
  '--stoponerror=[stop at first task error]:flag:(yes no)' \
  '--clobber=[overwrite existing output]:flag:(yes no)' \
  '--globalflare=[build single flare screening timeseries]:flag:(yes no)' \
  '--flaretimebin=[time bin for flare rejection]:bin:' \
  '--flaremaxrate=[threshold for truncated singles rate]:rate:' \
  '--atttol=[tolerance for attitude filtering]:tol:' \
  '*:event file:_files' && ret=0

return ret
