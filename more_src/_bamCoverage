#compdef bamCoverage
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/bamCoverage.html
# deepTools: generate coverage tracks (bigWig/bedGraph) from a BAM file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bam)'{-b,--bam}'[BAM file to process]:bam:_files -g "*.bam"' \
  '(-o --outFileName)'{-o,--outFileName}'[output file name]:file:_files' \
  '(-of --outFileFormat)'{-of,--outFileFormat}'[output format]:format:(bigwig bedgraph)' \
  '--scaleFactor[multiplier for computed scaling factor]:factor:' \
  '--MNase[detect nucleosome positions from MNase-seq data]' \
  '--Offset[signal offset within reads in bases]:offset:' \
  '--filterRNAstrand[filter by strand]:strand:(forward reverse)' \
  '--version[show version]' \
  '(-bs --binSize)'{-bs,--binSize}'[bin size in bases]:size:' \
  '(-r --region)'{-r,--region}'[genomic region to process]:region:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[BED/GTF file of regions to exclude]:file:_files' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--effectiveGenomeSize[mappable genome size]:size:' \
  '--normalizeUsing[normalization method]:method:(RPKM CPM BPM RPGC None)' \
  '--exactScaling[use exact scaling instead of sampling]' \
  '(-ignore --ignoreForNormalization)'{-ignore,--ignoreForNormalization}'[chromosomes excluded from normalization]:chroms:' \
  '(--skipNonCoveredRegions --skipNAs)'{--skipNonCoveredRegions,--skipNAs}'[skip regions without reads]' \
  '--smoothLength[averaging window size]:length:' \
  '(-e --extendReads)'{-e,--extendReads}'[extend reads to fragment size]:length:' \
  '--ignoreDuplicates[count duplicate reads only once]' \
  '--minMappingQuality[minimum mapping quality threshold]:qual:' \
  '--centerReads[center reads by fragment length]' \
  '--samFlagInclude[include reads matching SAM flag]:flag:' \
  '--samFlagExclude[exclude reads matching SAM flag]:flag:' \
  '--minFragmentLength[minimum fragment length]:length:' \
  '--maxFragmentLength[maximum fragment length]:length:' && ret=0

return ret
