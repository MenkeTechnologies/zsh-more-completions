#compdef cn
# Documentation: https://docs.continue.dev/cli/quickstart
# Reference accessed: 2026-05-22
# Verified: upstream extensions/cli/src/index.ts and shared-options.ts.

# Zsh completion for cn - Continue CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --print)'{-p,--print}'[print response and exit (headless)]' \
  '--format[output format for headless mode]:format:(json)' \
  '--silent[strip thinking tags from headless output]' \
  '--resume[resume from last session]' \
  '--fork[fork from an existing session ID]:session:' \
  '--config[configuration file or hub slug]:config:' \
  '--org[organization slug (headless only)]:org:' \
  '--readonly[plan mode (read-only tools)]' \
  '--auto[auto mode (all tools allowed)]' \
  '--verbose[enable verbose logging]' \
  '--rule[add a rule (repeatable)]:rule:' \
  '--mcp[add MCP server from hub (repeatable)]:slug:' \
  '--model[add model from hub (repeatable)]:slug:' \
  '--prompt[add to initial message (repeatable)]:prompt:' \
  '--allow[allow tool (repeatable)]:tool:' \
  '--ask[ask before tool (repeatable)]:tool:' \
  '--exclude[exclude tool (repeatable)]:tool:' \
  '--agent[load agent file from hub]:slug:' \
  '--beta-subagent-tool[enable beta subagent tool]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'cn command' \
      'login[authenticate with Continue]' \
      'logout[log out from Continue]' \
      'ls[list recent chat sessions]' \
      'remote[launch a remote cn agent]' \
      'serve[start HTTP server with /state and /message]' \
      'remote-test[test remote TUI with local server]' \
      'checks[show CI check statuses for a PR]' \
      'review[run AI-powered reviews on changes]' && ret=0
    ;;
  args)
    case $line[1] in
      ls)
        _arguments '--json[output sessions as JSON]' && ret=0
        ;;
      remote)
        _arguments \
          '--url[connect to URL instead of new remote]:url:' \
          '--id[connect to existing remote agent]:id:' \
          '--idempotency-key[idempotency key for session]:key:' \
          '-s[create remote env and print connection details]' \
          '--branch[git branch for remote env]:branch:' \
          '--repo[repository URL for remote env]:url:' && ret=0
        ;;
      serve)
        _arguments \
          '--timeout[inactivity timeout in seconds]:seconds:' \
          '--port[port for HTTP server]:port:' \
          '--id[upload session snapshots with identifier]:id:' \
          '--beta-upload-artifact-tool[enable UploadArtifact tool]' && ret=0
        ;;
      remote-test)
        _arguments '--url[server URL]:url:' && ret=0
        ;;
      review)
        _arguments \
          '--base[base git ref to diff against]:ref:' \
          '--format[output format]:format:' \
          '--fix[automatically apply suggested fixes]' \
          '--patch[show patches]' \
          '--fail-fast[stop on first failure]' \
          '--review-agents[specific review agents]:agents:' \
          '--verbose[enable verbose logging]' && ret=0
        ;;
    esac
    ;;
esac

return ret
