#compdef phpspec-cli
# _phpspec-cli — Marcello Duarte PhpSpec BDD spec framework CLI alias (phpspec team, PHP); symfony console
# upstream: https://github.com/phpspec/phpspec

_phpspec-cli() {
    local -a sub=(
        'describe:create new spec'
        'run:run specs'
        'help:show help'
        'list:list commands'
        'completion:dump completion script'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--config=+[config file]:file:_files -g "phpspec.{yml,yaml,yml.dist,yaml.dist}"' \
        '-c+[config file]:file:_files -g "phpspec.{yml,yaml,yml.dist,yaml.dist}"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'phpspec subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '1:spec:_files' \
                    '--format=+[format]:f:(progress html junit pretty dot tap)' \
                    '-f+[format]:f:(progress html junit pretty dot tap)' \
                    '--stop-on-failure[stop on failure]' \
                    '--fake[fake namespaces]' \
                    '--bootstrap=+[bootstrap]:file:_files' \
                    '-b+[bootstrap]:file:_files' \
                    '--no-code-generation[no code gen]' \
                    '--no-rerun[no rerun]' ;;
                describe) _arguments '1:class name:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_phpspec-cli "$@"
