#compdef kubectl-trace
# Documentation: https://github.com/iovisor/kubectl-trace
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:schedule a bpftrace program on a node or pod'
  'get:list trace jobs'
  'attach:attach to a running trace'
  'delete:delete a trace job'
  'log:show trace logs'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'kubectl-trace subcommand' subcommands && ret=0 ;;
  (args)
      case $line[1] in
        (run)
          _arguments -s \
            '(-e --eval)'{-e+,--eval=}'[bpftrace program literal]:program:' \
            '(-f --filename)'{-f+,--filename=}'[bpftrace program file]:file:_files' \
            '--serviceaccount=[service account]:sa:' \
            '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
            '--patch=[customization patch file]:file:_files' \
            '--patch-type=[patch strategy]:type:(json merge strategic)' \
            '(-a --attach)'{-a,--attach}'[attach to trace after creation]' \
            '*:target:' && ret=0 ;;
        (get)
          _arguments \
            '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
            '*:trace id:' && ret=0 ;;
        (delete)
          _arguments \
            '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
            '*:trace id:' && ret=0 ;;
        (log)
          _arguments \
            '(-f --follow)'{-f,--follow}'[follow logs]' \
            '*:trace id:' && ret=0 ;;
        (attach) _arguments '*:trace id:' && ret=0 ;;
      esac
      ;;
esac

return ret
