#compdef kubectl-trace
# Documentation: https://man.archlinux.org/search?q=kubectl-trace
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run BPF program in pod'
  'get:list trace jobs'
  'attach:attach to running trace'
  'delete:delete trace job'
  'log:show trace logs'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'kubectl-trace subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments -s \
          '(-c --container)'{-c,--container}'=[container]:container:' \
          '(-e --eval)'{-e,--eval}'=[bpftrace program]:program:' \
          '(-f --filename)'{-f,--filename}'=[bpftrace file]:file:_files' \
          '--tracer=[tracer]:tracer:' \
          '--target-namespace=[namespace]:ns:' \
          '--process-selector=[selector]:selector:' \
          '--output=[output]:dest:' \
          '--program=[program]:program:' \
          '*--args=[args]:arg:' \
          '--google-application-secret=[GCP secret]:secret:' \
          '(-a --attach)'{-a,--attach}'[attach to trace]' \
          '--serviceaccount=[service account]:sa:' \
          '--imagename=[image]:image:' \
          '--init-imagename=[init image]:image:' \
          '--fetch-headers[fetch kernel headers]' \
          '--deadline=[seconds]:n:' \
          '--deadline-grace-period=[seconds]:n:' \
          '--patch=[patch file]:file:_files' \
          '--patch-type=[type]:type:(json merge strategic)' \
          '*:pod:' && ret=0 ;;
      (get)
        _arguments \
          '(-l --selector)'{-l,--selector}'=[selector]:selector:' \
          '--all-namespaces[all namespaces]' \
          '(-n --namespace)'{-n,--namespace}'=[namespace]:ns:' \
          '*:trace id:' && ret=0 ;;
      (delete)
        _arguments \
          '(-l --selector)'{-l,--selector}'=[selector]:selector:' \
          '--all[all]' \
          '(-n --namespace)'{-n,--namespace}'=[namespace]:ns:' \
          '*:trace id:' && ret=0 ;;
      (log)
        _arguments \
          '(-f --follow)'{-f,--follow}'[follow]' \
          '--timestamps[timestamps]' \
          '*:trace id:' && ret=0 ;;
      (attach) _arguments '*:trace id:' && ret=0 ;;
    esac
    ;;
esac

return ret
