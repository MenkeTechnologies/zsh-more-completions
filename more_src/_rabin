#compdef rabin rabin2-cli rabin-cli
# _rabin — radare2 rabin2 binary info CLI alias (radareorg, C); custom argparse
# upstream: https://github.com/radareorg/radare2

_rabin() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-@+[address]:str:' \
        '-a+[architecture]:str:' \
        '-A[list archs]' \
        '-b+[bits]:n:(16 32 64)' \
        '-B+[base address]:str:' \
        '-c[list classes]' \
        '-C+[create binary]:str:' \
        '-d[show debug info]' \
        '-D+[demangle]:str:' \
        '-e[entrypoints]' \
        '-E[entrypoints w/ exports]' \
        '-f+[file in archive]:str:' \
        '-F[output format]' \
        '-g[show all]' \
        '-G+[load address]:str:' \
        '-H[show file hashes]' \
        '-i[imports]' \
        '-I[binary info]' \
        '-j[json output]' \
        '-k+[show kernel info]:str:' \
        '-K+[checksum algorithm]:str:' \
        '-l[show libs]' \
        '-L[list plugins]' \
        '-m+[show source for line]:n:' \
        '-M[show methods]' \
        '-n+[show line for address]:str:' \
        '-N+[min max strings size]:str:' \
        '-o+[output file]:file:_files' \
        '-O+[binary operation]:str:' \
        '-p[show pic info]' \
        '-P[show pdb path]' \
        '-q[quiet]' \
        '-r[radare commands output]' \
        '-R[show relocs]' \
        '-s[show symbols]' \
        '-S[show sections]' \
        '-SS[show segments]' \
        '-SSS[show sections+segments]' \
        '-t[show file hash]' \
        '-T[show signature]' \
        '-u[unfiltered]' \
        '-U[show resources]' \
        '-v[show version]' \
        '-V[show version]' \
        '-w[show write rights]' \
        '-x[show hex info]' \
        '-X+[binary format]:str:' \
        '-z[show strings inside the data section]' \
        '-zz[show strings inside the whole binary]' \
        '-zzz[show strings inside the whole binary including base address]' \
        '-Z[show top byte stats]' \
        '*:file:_files'
}

_rabin "$@"
