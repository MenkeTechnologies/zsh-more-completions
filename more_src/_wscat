#compdef wscat

# Zsh completion for wscat - command-line WebSocket client

_arguments -s -S \
  '(-V --version)'{-V,--version}'[output the version number]' \
  '(-L --listen)'{-L,--listen}'[listen on port]:port:' \
  '(-c --connect)'{-c,--connect}'[connect to a WebSocket server]:url:' \
  '(-P --show-ping-pong)'{-P,--show-ping-pong}'[print a notification when a ping or pong is received]' \
  '(-s --subprotocol)'{-s,--subprotocol}'[optional subprotocol]:version:' \
  '(-n --no-check)'{-n,--no-check}'[do not check for unauthorized certificates]' \
  '(-H --header)'{-H,--header}'[set an HTTP header]:header:' \
  '--auth[add basic HTTP authentication header]:username\:password:' \
  '--ca[specify a Certificate Authority]:ca:_files' \
  '--cert[specify a Client SSL Certificate]:cert:_files' \
  '--key[specify a Client SSL Certificate key]:key:_files' \
  '--passphrase[specify a Client SSL Certificate key passphrase]:passphrase:' \
  '--no-color[run without color]' \
  '--proxy[connect via a proxy]:proxy url:' \
  '--slash[enable slash commands for control frames]' \
  '(-w --wait)'{-w,--wait}'[wait the given number of seconds to execute subsequent commands]:seconds:' \
  '(-x --execute)'{-x,--execute}'[execute a command on connection]:command:' \
  '(-h --help)'{-h,--help}'[output usage information]'
