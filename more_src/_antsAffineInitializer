local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:Image1.ext (fixed):_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:Image2.ext (moving):_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '4:TransformOutput.mat:_files -g "*.{mat,txt,h5}"' \
    '5::SearchFactor (degrees, default 10):_default' \
    '6::Radian-Fraction:_default' \
    '7::UsePrincipalAxes (bool):(0 1)' \
    '8::UseLocalSearch (uint):_default' \
    '9::Image1Mask:_files -g "*.{nii,nii.gz}"' \
    && ret=0

return ret
