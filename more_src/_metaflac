#compdef metaflac

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--no-utf8-convert[do not convert tags to UTF-8]' \
  '--show-md5sum[show MD5 of unencoded audio]' \
  '--show-min-blocksize[show min block size]' \
  '--show-max-blocksize[show max block size]' \
  '--show-min-framesize[show min frame size]' \
  '--show-max-framesize[show max frame size]' \
  '--show-sample-rate[show sample rate]' \
  '--show-channels[show number of channels]' \
  '--show-bps[show bits per sample]' \
  '--show-total-samples[show total samples]' \
  '--show-vendor-tag[show Vorbis comment vendor]' \
  '--show-tag=[show value of given tag]:tag:' \
  '--remove-tag=[remove given tag]:tag:' \
  '--remove-first-tag=[remove first occurrence of tag]:tag:' \
  '--remove-all-tags[remove all Vorbis comment tags]' \
  '--set-tag=[set tag NAME=VALUE]:tag:' \
  '--set-tag-from-file=[set tag NAME=FILENAME]:spec:' \
  '--import-tags-from=[import tags from file]:file:_files' \
  '--export-tags-to=[export tags to file]:file:_files' \
  '--import-cuesheet-from=[import cuesheet]:file:_files' \
  '--export-cuesheet-to=[export cuesheet]:file:_files' \
  '--import-picture-from=[import picture]:spec:' \
  '--export-picture-to=[export picture]:file:_files' \
  '--add-padding=[add padding bytes]:n:' \
  '--remove-padding[remove padding]' \
  '--add-replay-gain[add ReplayGain analysis]' \
  '--scan-replay-gain[scan ReplayGain]' \
  '--remove-replay-gain[remove ReplayGain]' \
  '--list[list metadata blocks]' \
  '--append=[append a block from file]:file:_files' \
  '--remove[remove metadata blocks]' \
  '--remove-all[remove all metadata blocks except STREAMINFO]' \
  '--block-number=[block numbers]:nums:' \
  '--block-type=[block types]:types:' \
  '--except-block-type=[block types to keep]:types:' \
  '--data-format=[output data format]:fmt:(binary text)' \
  '--application-data-format=[application data format]:fmt:(hexdump text)' \
  '--with-filename[show filenames]' \
  '--no-filename[do not show filenames]' \
  '--preserve-modtime[preserve modification time]' \
  '--dont-use-padding[do not use padding for new metadata]' \
  '*:input:_files -g "*.(flac|oga|ogg)"'
