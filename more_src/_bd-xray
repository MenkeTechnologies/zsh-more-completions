#compdef bd-xray
# Documentation: https://github.com/blackducksoftware/kubectl-bd-xray
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bd-xray: kubectl plugin running Black Duck image scans

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'namespace:scan all images in a namespace'
  'images:scan any set of images'
  'yaml:scan images from given yaml file'
  'helm:scan images from given helm chart'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '--blackduck.url=[Black Duck server URL]:url:' \
  '--blackduck.api.token=[Black Duck API token]:token:' \
  '1:subcommand:->cmd' \
  '*::args:_default' && ret=0

case $state in
  cmd) _describe -t commands 'bd-xray subcommand' commands && ret=0 ;;
esac

return ret
