#compdef codex-cli
# Documentation: https://github.com/openai/codex
# Reference accessed: 2026-05-23
# Verified: npx @openai/codex --help.

# Zsh completion for codex-cli - OpenAI Codex CLI (alternate binary name)

local curcontext="$curcontext" state line ret=1

_codex_cli_commands() {
  local -a commands=(
    'exec:run Codex non-interactively'
    'e:alias for exec'
    'review:run code review non-interactively'
    'login:manage login'
    'logout:remove stored credentials'
    'mcp:manage external MCP servers'
    'plugin:manage Codex plugins'
    'mcp-server:run Codex as MCP server'
    'app-server:run app server'
    'remote-control:manage app-server daemon'
    'app:launch Codex desktop app'
    'completion:generate shell completions'
    'update:update Codex'
    'doctor:diagnose installation and config'
    'sandbox:run commands in Codex sandbox'
    'debug:debugging tools'
    'apply:apply latest agent diff via git apply'
    'a:alias for apply'
    'resume:resume interactive session'
    'fork:fork interactive session'
    'cloud:browse Codex Cloud tasks'
    'exec-server:run exec-server service'
    'features:inspect feature flags'
    'help:show help'
  )
  _describe -t commands 'codex-cli command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-m --model)'{-m,--model}'[model]:model:' \
  '(-i --image)'{-i,--image}'[attach images]:file:_files' \
  '(-p --profile)'{-p,--profile}'[configuration profile]:profile:' \
  '--profile-v2[use named profile v2]:profile:' \
  '(-c --config)'{-c,--config}'[config override key=value]:setting:' \
  '--strict-config[error on unrecognized config]' \
  '*--enable=[enable feature flag]:feature:' \
  '*--disable=[disable feature flag]:feature:' \
  '--sandbox[sandbox mode]:(read-only workspace-write danger-full-access)' \
  '--ask-for-approval[approval mode]:(untrusted on-failure on-request never)' \
  '--dangerously-bypass-approvals-and-sandbox[bypass safety checks]' \
  '--search[enable web search]' \
  '--oss[open-source mode]' \
  '(-C --cwd)'{-C,--cwd}'[working directory]:directory:_directories' \
  '1: :_codex_cli_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      exec|e|review)
        _arguments '(-h --help)'{-h,--help}'[show help]' '*:task:' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
      resume|fork)
        _arguments '--last[use most recent session]' '*:session id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
