#compdef dracut-ng

# dracut-ng: next-generation dracut (same flag surface as dracut)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-f[overwrite existing initramfs]' \
  '-v[verbose]' \
  '-q[quiet]' \
  '--kver=[kernel version]:version:' \
  '--add=[add additional modules]:list:' \
  '--force-add=[force-add modules]:list:' \
  '--add-drivers=[drivers to include]:list:' \
  '--force-drivers=[force-load drivers]:list:' \
  '--omit-drivers=[drivers to exclude]:list:' \
  '--filesystems=[explicit FS list]:list:' \
  '--install=[binaries to include]:list:' \
  '--include=[file/dir path to include]:path:_files' \
  '--no-hostonly[generic initramfs]' \
  '--hostonly[host-specific initramfs]' \
  '--no-hostonly-cmdline[no host cmdline in initrd]' \
  '--no-kernel[skip kernel modules]' \
  '--mdadmconf[include mdadm.conf]' \
  '--lvmconf[include LVM conf]' \
  '--early-microcode[include early microcode]' \
  '--no-early-microcode[skip early microcode]' \
  '--strip[strip libraries/binaries]' \
  '--reproducible[reproducible build]' \
  '--uefi[build UKI]' \
  '--uefi-stub=[UEFI stub binary]:file:_files' \
  '--show-modules[list available modules]' \
  '--list-modules[list installed modules]' \
  '-c[config file]:file:_files' \
  '--conf=[config file]:file:_files' \
  '*:output image:_files' && ret=0
return ret
