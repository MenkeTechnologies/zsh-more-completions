#compdef dracut-ng
# Documentation: https://man.archlinux.org/search?q=dracut-ng
# Reference accessed: 2026-05-16

# dracut-ng: next-generation dracut initramfs generator (replaces dracut)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '--version[show version]' \
  '-f[force overwrite of existing initramfs]' \
  '--force[force overwrite of existing initramfs]' \
  '-a[add modules to set]:modules:' \
  '--add=[add modules to set]:modules:' \
  '-o[omit modules from set]:modules:' \
  '--omit=[omit modules from set]:modules:' \
  '-m[include only modules]:modules:' \
  '--modules=[include only modules]:modules:' \
  '--drivers=[install kernel drivers]:drivers:' \
  '--add-drivers=[add extra kernel drivers]:drivers:' \
  '--omit-drivers=[omit kernel drivers]:drivers:' \
  '--filesystems=[install kernel filesystem drivers]:fs:' \
  '--include=[include path inside initrd]:path:_files' \
  '--install=[install files into initrd]:files:_files' \
  '--gzip[gzip compression]' \
  '--xz[xz compression]' \
  '--lzma[lzma compression]' \
  '--bzip2[bzip2 compression]' \
  '--zstd[zstd compression]' \
  '--lz4[lz4 compression]' \
  '--compress=[compression program]:prog:' \
  '--no-compress[disable compression]' \
  '--conf=[config file]:file:_files' \
  '--confdir=[config directory]:dir:_files -/' \
  '-k[kernel modules dir]:dir:_files -/' \
  '--kmoddir=[kernel modules dir]:dir:_files -/' \
  '--kernel-image=[kernel image path]:file:_files' \
  '--kver=[kernel version]:ver:' \
  '--early-microcode[bundle early-microcode]' \
  '--no-early-microcode[skip early-microcode]' \
  '-H[hostonly mode]' \
  '--hostonly[hostonly mode]' \
  '--no-hostonly[generic image]' \
  '-N[no hostonly]' \
  '--persistent-policy=[persistent-device policy]:policy:(uuid label path)' \
  '--sshkey=[ssh authorized key for ssh module]:file:_files' \
  '--uefi[generate UEFI bootable initrd]' \
  '--uefi-stub=[UEFI stub binary]:file:_files' \
  '--logfile=[log file]:file:_files' \
  '-l[use kernel module compression from current kernel]' \
  '--local[use kernel module compression from current kernel]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '--debug[debug]' \
  '--verbose[verbose]' \
  '-v[verbose]' \
  '1::output image:_files' \
  '*::extra args:_files' && ret=0
return ret
