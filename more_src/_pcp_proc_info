#compdef pcp_proc_info

# pcp_proc_info: print Pgpool child process info
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "(- *)-V[show version]" \
  "--version[show version]" \
  "-w[no password prompt]" \
  "--no-password[no password prompt]" \
  "-W[force password prompt]" \
  "--password[force password prompt]" \
  "-d[debug]" \
  "--debug[debug]" \
  "-v[verbose]" \
  "--verbose[verbose]" \
  "-U[username]:user:_users" \
  "--username=[username]:user:_users" \
  "-H[pgpool host]:host:_hosts" \
  "--host=[pgpool host]:host:_hosts" \
  "-p[pcp port]:port:" \
  "--port=[pcp port]:port:" \
  "-s[scope]:scope:" \
  "--scope=[scope]:scope:" \
  "-P[child pid]:n:" "--process-id=[child pid]:n:" "-a[show all processes]" "--all[show all processes]" \
  '*::pcp_proc_info args:_files' && ret=0
return ret
