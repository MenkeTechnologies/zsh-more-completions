#compdef pcp_proc_info
# Documentation: https://www.pgpool.net/docs/latest/en/html/pcp-proc-info.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcp_proc_info: print Pgpool child process info
local curcontext="$curcontext" ret=1
_arguments -C \
  "(- *)--help[show help]" \
  "(- *)-\\?[show help]" \
  "(- *)-V[show version]" \
  "(- *)--version[show version]" \
  "-w[no password prompt]" \
  "--no-password[no password prompt]" \
  "-W[force password prompt]" \
  "--password[force password prompt]" \
  "-d[enable debug message]" \
  "--debug[enable debug message]" \
  "-v[verbose output]" \
  "--verbose[verbose output]" \
  "-U[PCP user name]:user:_users" \
  "--username=[PCP user name]:user:_users" \
  "-h[pgpool host]:host:_hosts" \
  "--host=[pgpool host]:host:_hosts" \
  "-p[PCP port number]:port:" \
  "--port=[PCP port number]:port:" \
  "-P[Pgpool-II child process PID]:pid:" \
  "--process-id=[Pgpool-II child process PID]:pid:" \
  "-a[display all child processes and connection slots]" \
  "--all[display all child processes and connection slots]" \
  '*::pcp_proc_info args:_files' && ret=0
return ret
