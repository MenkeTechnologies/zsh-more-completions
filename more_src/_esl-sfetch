#compdef esl-sfetch
# Documentation: https://www.mankier.com/1/esl-sfetch
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-sfetch: retrieve sequence(s) by name from a sequence file
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-o[output file]:file:_files' \
  '-c[fetch a subsequence (start..end)]:range:' \
  '-f[treat name argument as a file of names]' \
  '-n[rename single-sequence retrieval]:name:' \
  '-r[reverse-complement the fetched sequence]' \
  '--index[index a sequence file for fast retrieval]' \
  '--informat[input format]:fmt:(fasta embl genbank ddbj uniprot)' \
  '*:sequence file and name:_files' && ret=0
return ret
