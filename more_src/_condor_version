#compdef condor_version
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_version.html
# print HTCondor version and platform information

local ret=1

_arguments -s -S \
  '-help[print usage information]' \
  '-arch[print this machine computer architecture]' \
  '-opsys[print this machine operating system]' && ret=0

return ret
