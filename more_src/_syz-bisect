#compdef syz-bisect
# _syz-bisect — bisect a crash/fix in kernel and syzkaller history (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-bisect/bisect.go (flag).

_syz-bisect() {
    _arguments \
        '-config=[bisect config file]:file:_files' \
        '-crash=[dir with crash info]:dir:_files -/' \
        '-fix[search for crash fix instead of cause]' \
        '-kernel_commit=[original kernel commit]:sha:' \
        '-kernel_commit_title=[original kernel commit title]:title:' \
        '-syzkaller_commit=[original syzkaller commit]:sha:'
}

_syz-bisect "$@"
