#compdef audit2allow audit2why
# _audit2allow — SELinux audit2allow / audit2why (convert audit AVC denial messages into either allow rules (audit2allow) or human-readable explanations (audit2why); -a process audit.log directly, -i input file (default stdin), -m generate a loadable module name, -M generate module + binary policy, -p path to policy.conf, -r show reference rules, -d run dmesg + audit2why, -l only events since last load, -v verbose)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux policycoreutils/audit2allow on tip.

_audit2allow() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-a[process audit.log directly]' \
        '-i+[input file]:file:_files' \
        '-m+[module name]:name:' \
        '-M+[module name + binary]:name:' \
        '-p+[policy.conf path]:file:_files' \
        '-r[show reference rules]' \
        '-d[run dmesg + audit2why]' \
        '-l[only events since last load]' \
        '-v[verbose]' \
        '-x[explain]' \
        '-N[no neverallow check]' \
        '-w[explain rule context]' \
        '-t+[type]:type:'
}

_audit2allow "$@"
