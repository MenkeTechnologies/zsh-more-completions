#compdef credo
# Documentation: https://hexdocs.pm/credo/cli_switches.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'suggest:default static analysis report'
  'list:list configured checks'
  'explain:describe a check'
  'categories:list issue categories'
  'diff:diff-aware run'
  'info:internal credo info'
  'gen.check:generate custom check stub'
  'gen.config:generate starter config'
  'help:built-in help'
  'version:print version'
)

_arguments -s -S -C \
  '(-w --watch)'{-w,--watch}'[file watcher mode]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'credo command' subcmds && ret=0
    ;;
  rest)
    case $line[1] in
      suggest|'')
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[command help]' \
          '(-a --all)'{-a,--all}'[show all issues per category]' \
          '(-A --all-priorities)'{-A,--all-priorities,--strict}'[include low-priority issues]' \
          '--verbose[verbose logging]' \
          '(-c --checks --only)'{-c,--checks,--only}'[filter by check pattern]:pattern:' \
          '(-i --ignore --ignore-checks)'{-i,--ignore,--ignore-checks}'[ignore checks]:pattern:' \
          '--format=[output format]:fmt:(flycheck json sarif oneline)' \
          '--no-color[disable colored output]' \
          '--config-file=[custom config file]:file:_files' \
          '(-C --config-name)'{-C,--config-name=}'[named config variant]:name:' \
          '--min-priority=[min priority threshold]:atom:' \
          '*--checks-with-tag=[require tag]:tag:' \
          '*--checks-without-tag=[exclude tag]:tag:' \
          '--files-included=[only paths]:glob:' \
          '--files-excluded=[skip paths]:glob:' \
          '--enable-disabled-checks=[temporarily enable]:tuple:' \
          '--mute-exit-status[always exit 0]' \
          '--first-run[re-generate any rerun artifacts]' \
          '--read-from-stdin[read sources from stdin]' \
          '--crash-on-error[raise on check error]' \
          '--warn-on-redundant-config[warn redundant .credo.exs]' \
          '*:paths:_files' && ret=0
        ;;
      list|explain|categories|diff|info|gen.check|gen.config|help|version)
        _normal && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
