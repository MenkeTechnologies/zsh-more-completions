#compdef stl-g
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=stl-g&sektion=1
# BRL-CAD STL to geometry database converter

local ret=1

_arguments -s \
  '-b[input is binary STL (default ASCII)]' \
  '-d[print debugging information]' \
  '(-I)-i[starting ident number, increments per region]:ident' \
  '(-i)-I[constant ident number for all regions]:ident' \
  '-m[material code for all regions (default 1)]:code' \
  '-N[name for resulting BRL-CAD object]:name' \
  '-c[input file units (e.g. mm, in, ft)]:units' \
  '-t[vertex dedup tolerance (mm)]:tolerance' \
  '-x[librt debug flag]:flag' \
  '1:input.stl:_files' \
  '2:output:_files -g "*.g"' && ret=0

return ret
