#compdef sanic-cli
# _sanic-cli — Sanic async Python web framework CLI alias (Sanic Community, Python); argparse
# upstream: https://github.com/sanic-org/sanic

_sanic-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--host=+[host]:host:_hosts' \
        '-H+[host]:host:_hosts' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--unix=+[unix socket]:file:_files' \
        '-u+[unix socket]:file:_files' \
        '--cert=+[ssl cert]:file:_files' \
        '--key=+[ssl key]:file:_files' \
        '--tls=+[tls cert+key dir]:dir:_files -/' \
        '--tls-strict-host[tls strict host]' \
        '--workers=+[workers]:n:' \
        '-w+[workers]:n:' \
        '--fast[fast mode]' \
        '--single-process[single process]' \
        '--legacy[legacy server]' \
        '--access-logs[enable access logs]' \
        '--no-access-logs[disable access logs]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--no-debug[no debug]' \
        '--dev[dev mode]' \
        '-r[reload on change]' \
        '--reload[reload on change]' \
        '--no-reload[no reload]' \
        '--reload-dir=+[reload dir]:dir:_files -/' \
        '-R+[reload dir]:dir:_files -/' \
        '--motd[show motd banner]' \
        '--no-motd[no motd banner]' \
        '--motd-display=+[motd display]:str:' \
        '--coffee[coffee output]' \
        '--noisy-exceptions[noisy exceptions]' \
        '--no-noisy-exceptions[no noisy exceptions]' \
        '--auto-reload[auto reload]' \
        '--no-auto-reload[no auto reload]' \
        '--inspect[run inspector]' \
        '-i[run inspector]' \
        '--inspect-host=+[inspector host]:host:_hosts' \
        '--inspect-port=+[inspector port]:port:' \
        '--inspect-tls=+[inspector tls dir]:dir:_files -/' \
        '--repl[run interactive REPL after start]' \
        '*:module-or-arg:'
}

_sanic-cli "$@"
