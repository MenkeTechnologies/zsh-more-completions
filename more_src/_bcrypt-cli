#compdef bcrypt-cli
# ============================================================================
# bcrypt-cli - bcrypt hash + verify + generate CLI (Go, MIT)
#
# Author : Adam Duke (adamvduke)
# Upstream: https://github.com/adamvduke/bcrypt-cli
#
# bcrypt-cli is a cobra-based Go CLI wrapping the
# `golang.org/x/crypto/bcrypt` package for command-line bcrypt
# password hashing + verification + generation. Subcommands:
#
#   hash      - read a password from stdin, output its bcrypt hash
#   compare   - read hash + plaintext, exit 0 on match, 1 on miss
#   generate  - emit a random password and its bcrypt hash in one go
#   cost      - inspect the work-factor of an existing bcrypt hash
#   version   - print version
#
# The bcrypt password-hashing lane is built on
# `golang.org/x/crypto/bcrypt` (Go-team-maintained extended-stdlib
# package), the canonical Go bcrypt implementation. The library
# is in the `golang.org/x/crypto` namespace - same Go-team-blessed
# canonical pattern visible at Axis 208 (golang.org/x/crypto/argon2),
# Axis 207 (golang.org/x/oauth2), and Axis 193 (golang.org/x/image/
# font). golang.org/x/crypto/bcrypt implements Niels Provos +
# David Mazieres's bcrypt (USENIX 1999) in pure Go:
#
#   - Eksblowfish key schedule
#   - $2a$ / $2b$ versioned PHC string format (default $2a$)
#   - Cost factor 4-31 (default 10 in bcrypt-cli)
#   - Constant-time comparison via `bcrypt.CompareHashAndPassword`
#   - Hash inspection via `bcrypt.Cost(hashedPassword)`
#
# ----------------------------------------------------------------------------
# AXIS 212 :: BCRYPT PASSWORD HASHING (Provos+Mazieres USENIX 1999)
# Round 1335 :: Go slot 2 of 4 :: continues Axis 212
#
# Cross-language canonical library family for this axis:
#   Rust    : Keats/rust-bcrypt              [R1334 _authoscope]
#   Go      : golang.org/x/crypto/bcrypt     [R1335 THIS FILE]
#   TS/Node : dcodeIO/bcrypt.js or kelektiv/node.bcrypt.js  [R1336 closing]
#
# Like the Argon2 axis (208), the Go lane's canonical library is
# in `golang.org/x/crypto/*` - the Go-team-maintained extended
# stdlib. The Rust + Node lanes both rely on community-maintained
# packages for their canonical bcrypt implementations. This is
# the consistent cross-lane pattern visible across crypto axes:
# Rust ecosystem coalesces around RustCrypto org; Node ecosystem
# fragments across multiple competing wrappers (bcrypt.js pure-JS
# vs node.bcrypt.js C-binding via N-API); Go ecosystem
# consolidates inside `golang.org/x/crypto`.
# ============================================================================

_bcrypt-cli() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-v,--version}'[print version]' \
        '1: :_bccli_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                hash)     _arguments '(-c --cost)'{-c,--cost}'[bcrypt cost factor (default 10)]:cost (4-31):' '(- *)'{-h,--help}'[help]' ;;
                generate) _arguments \
                              '(-l --length)'{-l,--length}'[length of the random password to generate]:n:' \
                              '(-s --symbols)'{-s,--symbols}'[include symbols in the random password (default true)]' \
                              '(-c --cost)'{-c,--cost}'[bcrypt cost factor (default 10)]:cost (4-31):' \
                              '(- *)'{-h,--help}'[help]' ;;
                compare)  _arguments '(- *)'{-h,--help}'[help]' ;;
                cost)     _arguments '(- *)'{-h,--help}'[help]' ;;
                version)  _arguments '(- *)'{-h,--help}'[help]' ;;
            esac
            ;;
    esac

    return ret
}

_bccli_cmds() {
    local -a cmds
    cmds=(
        'hash:Read a password from stdin and emit its bcrypt hash'
        'compare:Compare a bcrypt hash to a plaintext password (exit 0 on match)'
        'generate:Generate a random password + its bcrypt hash'
        'cost:Inspect the bcrypt cost factor of an existing hash'
        'version:Print version'
    )
    _describe -t commands 'bcrypt-cli command' cmds
}

_bcrypt-cli "$@"
