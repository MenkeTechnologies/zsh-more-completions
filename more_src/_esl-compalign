#compdef esl-compalign
# Documentation: http://hmmer.org/documentation.html
# Easel: compare two multiple sequence alignments

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-c[print per-column statistics instead of per-sequence]' \
  '-p[print statistics on accuracy versus posterior probability]' \
  '--p-mask=[mask file to filter posterior probability accuracy stats]:file:_files' \
  '--c2dfile=[save an esl-ssdraw draw file of error and gap frequencies]:file:_files' \
  '--amino[assert input files are protein]' \
  '--dna[assert input files are DNA]' \
  '--rna[assert input files are RNA]' \
  '*:alignment file:_files' && ret=0

return ret
