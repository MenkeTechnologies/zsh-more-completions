#compdef compave
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss25.html
# KAPPA: reduces the size of an NDF by averaging values in rectangular boxes

local ret=1

_arguments -s \
  'IN=[input NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'COMPRESS=[compression factors per axis]:factors' \
  'WLIM=[min fraction of good input pixels]:frac' \
  'ALIGN=[alignment of compression boxes]:align' \
  'AXWEIGHT=[weight by axis widths]:bool:(TRUE FALSE)' \
  'PRESERVE=[preserve input data type]:bool:(TRUE FALSE)' \
  'TITLE=[title for the output NDF]:title' \
  'TRIM=[trim incomplete edge boxes]:bool:(TRUE FALSE)' \
  'WEIGHT=[weight values when averaging]:bool:(TRUE FALSE)' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
