#compdef ipset-list
# _ipset-list — netfilter ipset list (companion to ipset(8) for listing existing sets; positional argument is an optional set name to filter; -t terse (header only), -n names only, -r resolve hostnames in members, -s sorted, -o output format (plain|save|xml|json); shares its flag surface with the parent ipset binary)
# upstream: https://git.netfilter.org/ipset
# Flags from netfilter/ipset src/ipset.c on tip.

_ipset-list() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-t[terse]' \
        '-n[names only]' \
        '-r[resolve hostnames]' \
        '-s[sorted]' \
        '-o+[output format]:format:(plain save xml json)' \
        '1::setname:'
}

_ipset-list "$@"
