#compdef osh

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '-c+[execute command string]:command:' \
  '-i[interactive mode]' \
  '-l[login shell]' \
  '-n[check syntax without executing]' \
  '-o+[set option]:option:(errexit nounset pipefail xtrace verbose)' \
  '+o+[unset option]:option:' \
  '-O+[set Oils option]:option:(parse_at parse_brace parse_paren parse_triple_quote command_sub_errexit process_sub_fail strict_word_eval sigpipe_status_ok)' \
  '+O+[unset Oils option]:option:' \
  '-x[print commands before execution]' \
  '-v[print input as read]' \
  '-e[exit on error]' \
  '-u[error on unset variables]' \
  '-s[read from stdin]' \
  '--rcfile=[use alternate rc file]:file:_files' \
  '--rcdir=[rc directory]:dir:_files -/' \
  '--norc[do not read rc files]' \
  '--headless[run in headless mode]' \
  '--tool=[run built-in tool]:tool:(cat syntax-tree fmt)' \
  '*:script:_files' && ret=0

return ret
