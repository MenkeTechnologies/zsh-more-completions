#compdef rasa

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:create a new project'
  'train:train a Rasa model'
  'test:test a trained model'
  'run:start a server to run a model'
  'interactive:start interactive learning'
  'shell:start a shell to converse with a model'
  'telemetry:show or change telemetry settings'
  'visualize:visualize stories'
  'data:utilities for training/test data'
  'x:start Rasa X'
  'evaluate:evaluate marker behavior'
  'export:export tracker events'
  'license:show or manage Rasa Pro license'
  'validate:validate domain and data'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-vv --debug)'{-vv,--debug}'[debug output]' \
  '--quiet[quiet output]' \
  '--logging-config-file=[logging config file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rasa subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (data)
        _values 'data action' \
          'split' 'convert' 'migrate' 'validate' && ret=0
        ;;
      (test)
        _values 'test target' 'core' 'nlu' && ret=0
        ;;
      (run)
        _values 'run target' 'actions' && ret=0
        ;;
      (evaluate)
        _values 'evaluate target' 'markers' && ret=0
        ;;
      (telemetry)
        _values 'telemetry action' 'enable' 'disable' && ret=0
        ;;
    esac
    ;;
esac

return ret
