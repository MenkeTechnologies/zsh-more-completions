#compdef mythril myth
# Documentation: https://github.com/Consensys/mythril (mythril/interfaces/cli.py)
# Reference accessed: 2026-05-29
# Mythril — symbolic-execution security tool for Ethereum smart contracts.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'analyze:trigger the analysis of a smart contract'
  'a:analyze (alias)'
  'disassemble:disassemble a smart contract'
  'd:disassemble (alias)'
  'foundry:analyze smart contracts from Foundry projects'
  'f:foundry (alias)'
  'concolic:run concolic execution to flip desired branches'
  'c:concolic (alias)'
  'safe-functions:check functions completely safe under symbolic execution'
  'read-storage:retrieve storage slots from a given address via RPC'
  'function-to-hash:return the hash signature of a function'
  'hash-to-address:convert function hashes back to Ethereum addresses'
  'list-detectors:list available detection modules'
  'version:show Mythril version'
  'help:show help for a subcommand'
)

local -a _input_flags
_input_flags=(
  '(-c --code)'{-c,--code=}'[hex-encoded bytecode input]:bytecode:'
  '(-f --codefile)'{-f,--codefile=}'[file with hex-encoded bytecode]:file:_files'
  '(-a --address)'{-a,--address=}'[contract address (on-chain pull)]:addr:'
  '--bin-runtime[treat input as runtime bytecode]'
  '--solv=[solc version (e.g. 0.8.20)]:version:'
)

local -a _rpc_flags
_rpc_flags=(
  '--rpc=[custom RPC settings (default infura-mainnet)]:rpc:'
  '--infura-id=[Infura API ID]:id:'
  '--rpctls=[use TLS for RPC]:bool:(true false)'
)

local -a _global
_global=(
  '*-v[log level (0-5, default 2)]'
  '--epic[enable epic mode visualization]'
  '(-o --outform)'{-o,--outform=}'[report output format]:format:(text markdown json jsonv2)'
  '(-h --help)'{-h,--help}'[show help]'
  '--version[show version]'
)

_arguments -C \
  $_global \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'mythril subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      analyze|a)
        _arguments \
          $_global $_input_flags $_rpc_flags \
          '--execution-timeout=[execution timeout (seconds)]:seconds:' \
          '--solver-timeout=[Z3 solver timeout (ms)]:ms:' \
          '--create-timeout=[contract creation timeout (seconds)]:seconds:' \
          '--max-depth=[max search depth]:n:' \
          '--call-depth-limit=[max call depth]:n:' \
          '--transaction-count=[transactions to symbolically execute]:n:' \
          '*--strategy=[search strategy]:strategy:(dfs bfs naive-random weighted-random pending)' \
          '--loop-bound=[max iterations of any loop]:n:' \
          '--enable-iprof[enable instruction profiler]' \
          '--disable-dependency-pruning[disable dependency pruning]' \
          '--enable-coverage-strategy[enable coverage-guided strategy]' \
          '--enable-state-merging[enable state merging]' \
          '--phrack[output in Phrack-style]' \
          '--no-onchain-storage-access[disable on-chain storage access]' \
          '--enable-summaries[enable summaries]' \
          '*--modules=[detection modules to run (comma-separated)]:modules:' \
          '*:source file:_files -g "*.(sol|json)"' && ret=0
        ;;
      disassemble|d)
        _arguments \
          $_global $_input_flags \
          '*:source file:_files -g "*.(sol|json|bin)"' && ret=0
        ;;
      foundry|f)
        _arguments \
          $_global \
          '--foundry-out-dir=[Foundry build output dir]:dir:_directories' \
          '--execution-timeout=[execution timeout (seconds)]:seconds:' \
          '*:project dir:_directories' && ret=0
        ;;
      concolic|c)
        _arguments \
          $_global \
          '--branches=[branches to flip (PC,PC,...)]:branches:' \
          '*:bytecode file:_files' && ret=0
        ;;
      safe-functions)
        _arguments \
          $_global $_input_flags \
          '*:source file:_files' && ret=0
        ;;
      read-storage)
        _arguments \
          $_global $_rpc_flags \
          ':storage slot:' \
          ':contract address:' && ret=0
        ;;
      function-to-hash)
        _arguments ':function signature:' && ret=0
        ;;
      hash-to-address)
        _arguments ':4-byte function hash:' && ret=0
        ;;
    esac
    ;;
esac

return ret
