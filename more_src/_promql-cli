#compdef promql-cli promql
# Documentation: https://github.com/nalbury/promql-cli
# Prometheus query CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--auth-credentials=[optional auth credentials string]:creds' \
  '--auth-credentials-file=[path to auth credentials file]:_files' \
  '--auth-type=[auth scheme such as Basic or Bearer]:type:(Basic Bearer)' \
  '--config=[config file location]:_files' \
  '--host=[prometheus server url]:url' \
  '--start=[query range start, ISO 8601 date]:start' \
  '--end=[query range end, now or ISO 8601 date]:end' \
  '--step=[results step duration such as 1m]:step' \
  '--timeout=[timeout in seconds for queries]:seconds' \
  '--output=[override default output format]:format:(json csv)' \
  '--no-headers[disable table headers for instant queries]' \
  '*:command:(labels meta metrics help)' && ret=0

return ret
