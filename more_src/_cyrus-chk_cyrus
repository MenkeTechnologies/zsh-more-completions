#compdef cyrus-chk_cyrus
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/chk_cyrus.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org chk_cyrus(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-chk_cyrus: report Cyrus database/spool consistency
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '(-M --mailbox)'{-P+,--partition=}'[limit to partition (mutex with -M)]:partition:' \
  '(-P --partition)'{-M+,--mailbox=}'[only check mailbox (mutex with -P)]:mailbox:' && ret=0
return ret
