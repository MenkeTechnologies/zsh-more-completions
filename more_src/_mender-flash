#compdef mender-flash
# Documentation: source-direct extraction from upstream
# mendersoftware/mender-flash main.c lines 46-61 (the
# `static struct option long_options[]` array + `#define
# SHORT_OPTS` + PrintHelp() block).  Reference accessed:
# 2026-05-30 via gh api.
#
# mender-flash is Mender's standalone raw-device flasher —
# follow-up to R213's hunt-skip note: "mender-flash (raw-device
# flasher, separate repo mendersoftware/mender-flash) deferred
# for a future round".  Used during Update-Module workflows to
# `dd`-like write a raw image to a target block device with
# optional write-skipping (compare blocks first; skip writes
# that would be no-ops) and periodic fsync().  Sister tool to
# R213's mender-update — mender-update's Update Modules may
# shell out to mender-flash to write rootfs slot images.
#
# Critical extraction note: mender-flash uses bare getopt_long
# (NOT cobra/clap/GLib).  Short-option string at line 46:
#   #define SHORT_OPTS "hws:f:i:o:"
# 4 flags require arguments (s/f/i/o), 2 are no-arg (h/w).
# Only 6 long options total — the binary is intentionally
# minimal.  Both `-i`/`--input` and `-o`/`--output` are
# MANDATORY (no default; PrintHelp emits them without [...]
# brackets at line 59 to mark them required).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-w --write-everything)'{-w,--write-everything}'[disable write-skipping optimization (write every block even if target already matches)]' \
  '(-s --input-size)'{-s+,--input-size=}'[explicit input size in bytes (override stat() / ioctl() detection)]:size:' \
  '(-f --fsync-interval)'{-f+,--fsync-interval=}'[fsync() every N bytes written (0 = never; default device-dependent)]:bytes:' \
  '(-i --input)'{-i+,--input=}'[input file (REQUIRED; "-" for stdin)]:input:_files' \
  '(-o --output)'{-o+,--output=}'[output device (REQUIRED; typically /dev/mmcblkXpY or /dev/sdXY)]:device:_files -g "/dev/*"'
