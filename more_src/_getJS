#compdef getJS
# Documentation: https://github.com/003random/getJS
# tool to extract all the javascript files from a set of given URLs

local ret=1

_arguments -s -S \
  '-url[the URL from which JavaScript sources should be extracted]:url:_urls' \
  '*-input[URLs input file (one URL per line)]:file:_files' \
  '*-output[output file for results]:file:_files' \
  '-complete[complete/autofill relative URLs by adding the current origin]' \
  '-resolve[resolve JavaScript files (requires --complete)]' \
  '-threads[number of processing threads to spawn]:n' \
  '-verbose[print verbose runtime information and errors]' \
  '-method[request method for fetching remote contents]:method' \
  '*-header[request headers to add to requests]:header' \
  '-timeout[request timeout while fetching remote contents]:duration' && ret=0

return ret
