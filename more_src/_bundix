#compdef bundix

# Zsh completion for bundix - converts Ruby Gemfile.lock to Nix expressions

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--gemfile[path to Gemfile]:path:_files' \
  '--lockfile[path to Gemfile.lock]:path:_files' \
  '--gemset[path to gemset.nix output]:path:_files' \
  '--init[initialize gemset.nix]' \
  '--magic[use magic Gemfile.lock parser]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '--ruby[Ruby version]:version'
