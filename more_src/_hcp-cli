#compdef hcp
# _hcp-cli — HashiCorp Cloud Platform CLI (HashiCorp, Go); manage HCP Vault Secrets/Boundary/Consul/Vault clusters
# upstream: https://github.com/hashicorp/hcp

_hcp-cli() {
    local -a sub=(
        'auth:auth commands'
        'completion:print shell completion'
        'configure:configure profile'
        'consul:HCP Consul'
        'help:show help'
        'iam:IAM commands'
        'organization:organization commands'
        'packer:Packer registry'
        'profile:profile commands'
        'projects:project commands'
        'vault:HCP Vault'
        'vault-secrets:HCP Vault Secrets'
        'version:show version'
        'waypoint:HCP Waypoint'
        'workload-identity-providers:workload identity'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--debug[debug]' \
        '--format+[output format]:fmt:(json table)' \
        '--quiet[quiet]' \
        '--profile+[profile]:profile:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hcp subcommand' sub ;;
        args)
            case $words[1] in
                vault-secrets) _arguments '1:vs cmd:(apps secrets)' '*:args:' ;;
                auth) _arguments '1:auth cmd:(login logout print-access-token print-permissions)' '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_hcp-cli "$@"
