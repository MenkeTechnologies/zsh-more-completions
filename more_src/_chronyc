#compdef chronyc
# Documentation: https://chrony-project.org/doc/4.8/chronyc.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# chronyc: chrony command-line client

local -a commands=(
  'activity:check how many NTP sources are online/offline'
  'add\ server:add new NTP server'
  'add\ peer:add new NTP peer'
  'authdata:display authentication data of sources'
  'burst:start rapid set of measurements'
  'clients:report clients that have accessed the server'
  'delete:remove a server or peer'
  'dns:set DNS resolving configuration'
  'dump:dump measurements for all sources'
  'local:control local reference mode'
  'makestep:correct clock by stepping'
  'manual:set manual input mode'
  'maxdelay:modify max delay for a source'
  'maxpoll:modify max polling interval for a source'
  'maxupdateskew:modify max update skew'
  'minpoll:modify min polling interval for a source'
  'minstratum:modify min stratum for a source'
  'ntpdata:display NTP data for a source'
  'offline:set sources to offline mode'
  'online:set sources to online mode'
  'polltarget:modify poll target for a source'
  'quit:exit chronyc'
  'refresh:refresh IP addresses'
  'rekey:re-read keys file'
  'reload\ sources:reload sources from config file'
  'reselect:force reselection of source'
  'reselectdist:modify reselection distance'
  'reset\ sources:drop samples from all sources'
  'selectdata:display selection data of sources'
  'serverstats:display server statistics'
  'settime:set daemon time'
  'shutdown:stop chronyd'
  'smoothing:display smoothing state'
  'smoothtime:activate or reset time smoothing'
  'sources:display information about current sources'
  'sourcestats:display source statistics'
  'tracking:display system time info'
  'trimrtc:correct RTC relative to system time'
  'waitsync:wait for sync'
  'writertc:save RTC parameters'
)

_arguments \
  '(- *)--help[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-4[resolve hostnames to IPv4 only]' \
  '-6[resolve hostnames to IPv6 only]' \
  '-h+[host to contact]:host:_hosts' \
  '-p+[UDP port (default 323)]:port:' \
  '-n[do not resolve IP addresses to hostnames]' \
  '-N[print original source names]' \
  '-c[enable CSV output]' \
  '-d[enable debug messages]' \
  '-e[end each response with a single dot line]' \
  '-m[accept multiple commands]' \
  '-f+[ignored, compatibility only]:file:_files' \
  '-a[ignored, compatibility only]' \
  '-u+[username for privilege drop when run as root]:user:_users' \
  '*:command'
