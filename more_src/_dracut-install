#compdef dracut-install

# dracut-install: install files into the dracut initramfs (internal helper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-D[chroot directory]:dir:_files -/' \
  '-r[source root]:dir:_files -/' \
  '-d[destination directory]:dir:_files -/' \
  '-a[treat sources as keep-with-source paths]' \
  '-o[optional - do not error if missing]' \
  '-f[force overwrite]' \
  '-l[mark as library]' \
  '-m[install module (kernel)]' \
  '-p[mark as POSIX path]' \
  '-v[verbose]' \
  '-L[absolute symlink (no resolve)]' \
  '-H[install hostonly]' \
  '-N[install only into nss for given user]:user:' \
  '*:files to install:_files' && ret=0
return ret
