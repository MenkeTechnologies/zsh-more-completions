#compdef dracut-install
# Documentation: https://man.archlinux.org/search?q=dracut-install
# Reference accessed: 2026-05-16

# dracut-install: copy files/binaries into a dracut initramfs tree
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-D[initramfs root directory]:dir:_files -/' \
  '--destrootdir=[initramfs root directory]:dir:_files -/' \
  '-d[create destination if missing]' \
  '--makedir[create destination if missing]' \
  '-a[copy all files in pattern]' \
  '--all[copy all files in pattern]' \
  '-o[optional install (no error if missing)]' \
  '--optional[optional install (no error if missing)]' \
  '-l[ldd-resolve dependent libraries]' \
  '--ldd[ldd-resolve dependent libraries]' \
  '-R[resolve dependent kernel module dependencies]' \
  '--resolvelazy[resolve runtime library deps lazily]' \
  '--resolvedeps[resolve runtime library deps]' \
  '-H[hostonly mode]' \
  '--hostonly[hostonly mode]' \
  '-m[install kernel module + dependencies]' \
  '--module[install kernel module + dependencies]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '--debug[debug]' \
  '--silent[suppress messages]' \
  '*:files:_files' && ret=0
return ret
