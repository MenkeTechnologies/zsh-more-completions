#compdef bustools
# Documentation: https://github.com/BUStools/bustools
# bustools - manipulate BUS files for single-cell RNA-seq

local ret=1
local -a subcmds

subcmds=(
  'sort:sort BUS records by barcode, UMI, equivalence class'
  'correct:barcode error correction against an allowlist'
  'count:generate barcode-feature matrices (TCC or gene)'
  'inspect:report summary of a sorted BUS file'
  'allowlist:generate an allowlist from a sorted BUS file'
  'capture:separate BUS records by capture criteria'
  'text:convert binary BUS to tab-separated text'
  'fromtext:convert tab-separated text to binary BUS'
  'compress:compress a sorted BUS file'
  'decompress:inflate a compressed BUS file'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- :)--version[print version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'bustools command' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      sort)
        _arguments -s \
          '(-t --threads)'{-t,--threads}'=[number of threads]:threads:' \
          '(-m --memory)'{-m,--memory}'=[maximum memory used]:memory:' \
          '(-T --temp)'{-T,--temp}'=[temp file location and prefix]:prefix:' \
          '(-o --output)'{-o,--output}'=[file for sorted output]:file:_files' \
          '(-p --pipe)'{-p,--pipe}'[write to standard output]' \
          '*:bus file:_files' && ret=0
        ;;
      correct)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[file for corrected output]:file:_files' \
          '(-w --onlist)'{-w,--onlist}'=[on-list of barcodes to correct to]:file:_files' \
          '(-p --pipe)'{-p,--pipe}'[write to standard output]' \
          '*:bus file:_files' && ret=0
        ;;
      count)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[output prefix]:prefix:' \
          '(-g --genemap)'{-g,--genemap}'=[transcript-to-gene map file]:file:_files' \
          '(-e --ecmap)'{-e,--ecmap}'=[equivalence class to transcript map]:file:_files' \
          '(-t --txnames)'{-t,--txnames}'=[transcript names file]:file:_files' \
          '--genecounts[aggregate counts to genes only]' \
          '--cm[count multiplicities instead of UMIs]' \
          '*:bus file:_files' && ret=0
        ;;
      inspect)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[JSON output file]:file:_files' \
          '(-e --ecmap)'{-e,--ecmap}'=[equivalence class to transcript map]:file:_files' \
          '(-w --onlist)'{-w,--onlist}'=[on-list of barcodes]:file:_files' \
          '(-p --pipe)'{-p,--pipe}'[write to standard output]' \
          '*:bus file:_files' && ret=0
        ;;
      allowlist)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[file for the allowlist]:file:_files' \
          '(-f --threshold)'{-f,--threshold}'=[minimum barcode frequency]:count:' \
          '*:bus file:_files' && ret=0
        ;;
      capture)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
          '(-c --capture)'{-c,--capture}'=[transcripts to capture]:file:_files' \
          '(-e --ecmap)'{-e,--ecmap}'=[equivalence class to transcript map]:file:_files' \
          '(-t --txnames)'{-t,--txnames}'=[transcript names file]:file:_files' \
          '*:bus file:_files' && ret=0
        ;;
      text|fromtext)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '*:bus file:_files' && ret=0
        ;;
      compress)
        _arguments -s \
          '(-N --chunk-size)'{-N,--chunk-size}'=[rows per compressed block]:rows:' \
          '(-o --output)'{-o,--output}'=[compressed output file]:file:_files' \
          '(-p --pipe)'{-p,--pipe}'[write to standard output]' \
          '*:bus file:_files' && ret=0
        ;;
      decompress)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[decompressed output file]:file:_files' \
          '(-p --pipe)'{-p,--pipe}'[write to standard output]' \
          '*:bus file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
