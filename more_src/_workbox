#compdef workbox
# _workbox — Workbox service-worker CLI (GoogleChrome/workbox)
# upstream: https://github.com/GoogleChrome/workbox
# Subcommands from packages/workbox-cli/src/lib/help-text.ts.

_workbox() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '--debug[show full stack trace on error]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'wizard:run the configuration wizard'
                'generateSW:create a new service worker from config'
                'injectManifest:inject precache manifest into existing service worker'
                'copyLibraries:copy Workbox libraries to a local directory'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                wizard) _arguments '--injectManifest[wizard for injectManifest use case]' ;;
                generateSW|injectManifest)
                    _arguments \
                        '--watch[rebuild on file change]' \
                        '1:config file:_files -g "workbox-*.(js|cjs)"'
                    ;;
                copyLibraries)
                    _arguments '1:target directory:_files -/'
                    ;;
            esac
            ;;
    esac
}

_workbox "$@"
