#compdef jack_simple_client
# Documentation: https://man.archlinux.org/man/extra/jack-example-tools/jack_simple_client.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# jack_simple_client: minimal JACK client example
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-n[JACK client name]:name:' \
  '--name=[JACK client name]:name:' \
  '-s[JACK server name]:name:' \
  '--server=[JACK server name]:name:' \
  '*::jack_simple_client args:_files' && ret=0
return ret
