#compdef huh
# Documentation: https://man.archlinux.org/search?q=huh
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'select:choose one from a list'
  'multiselect:choose multiple from a list'
  'input:prompt for a single line of input'
  'confirm:ask a yes/no question'
  'text:prompt for multi-line text'
  'note:print a styled note'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--title=[prompt title]:title:' \
  '--description=[prompt description]:desc:' \
  '--theme=[theme]:theme:(charm dracula base16 catppuccin)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'huh command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (select|multiselect)
        _arguments \
          '--height=[viewport height]:n:' \
          '--filter[enable filtering]' \
          '--limit=[selection limit (multi)]:n:' \
          '*::option:' && ret=0 ;;
      (input|text)
        _arguments \
          '--placeholder=[input placeholder]:text:' \
          '--char-limit=[max input chars]:n:' \
          '--validate=[validation regex]:regex:' \
          '--password[mask input]' && ret=0 ;;
      (confirm)
        _arguments \
          '--affirmative=[affirmative label]:text:' \
          '--negative=[negative label]:text:' \
          '--default=[default value]:bool:(true false)' && ret=0 ;;
    esac ;;
esac

return ret
