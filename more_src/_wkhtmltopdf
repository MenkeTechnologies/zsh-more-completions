#compdef wkhtmltopdf

# Zsh completion for wkhtmltopdf - convert HTML to PDF

_arguments -s -S \
  '--collate[collate when printing multiple copies]' \
  '--no-collate[do not collate when printing multiple copies]' \
  '--cookie-jar[read and write cookies from and to the supplied cookie jar file]:file:_files' \
  '--copies[number of copies to print into the pdf file]:N:' \
  '(-H --extended-help)'{-H,--extended-help}'[display more extensive help]' \
  '(-g --grayscale)'{-g,--grayscale}'[PDF will be generated in grayscale]' \
  '--lowquality[generates lower quality pdf/ps]' \
  '--margin-bottom[set page bottom margin]:unitreal:' \
  '--margin-left[set page left margin]:unitreal:' \
  '--margin-right[set page right margin]:unitreal:' \
  '--margin-top[set page top margin]:unitreal:' \
  '(-O --orientation)'{-O,--orientation}'[set orientation]:orientation:(Landscape Portrait)' \
  '--page-height[set page height]:unitreal:' \
  '(-s --page-size)'{-s,--page-size}'[set paper size]:size:(A4 Letter Legal A3 A5)' \
  '--page-width[set page width]:unitreal:' \
  '--no-pdf-compression[do not use lossless compression on pdf objects]' \
  '(-q --quiet)'{-q,--quiet}'[be less verbose]' \
  '--read-args-from-stdin[read command line arguments from stdin]' \
  '--title[the title of the generated pdf file]:title:' \
  '(-V --version)'{-V,--version}'[output version information]' \
  '--zoom[use this zoom factor]:float:' \
  '--disable-javascript[do not allow web pages to run javascript]' \
  '--enable-javascript[allow web pages to run javascript (default)]' \
  '--javascript-delay[wait N milliseconds before page loading is done]:milliseconds:' \
  '--no-background[do not print background]' \
  '--background[do print background (default)]' \
  '--load-error-handling[specify how to handle pages that fail to load]:handler:(abort ignore skip)' \
  '--load-media-error-handling[specify how to handle media that fail to load]:handler:(abort ignore skip)' \
  '--bypass-proxy-for[bypass proxy for host]:host:_hosts' \
  '--cookie[set an additional cookie]:name value:' \
  '--custom-header[set an additional HTTP header]:name value:' \
  '--custom-header-propagation[propagate custom headers to other pages]' \
  '--no-custom-header-propagation[do not propagate custom headers to other pages]' \
  '--default-header[add a default header with the page name on the left and page number on the right]' \
  '--encoding[set the default text encoding]:encoding:' \
  '--disable-external-links[do not make links to remote web pages]' \
  '--enable-external-links[make links to remote web pages (default)]' \
  '--disable-forms[do not turn HTML form fields into pdf form fields]' \
  '--enable-forms[turn HTML form fields into pdf form fields]' \
  '--images[do load or print images (default)]' \
  '--no-images[do not load or print images]' \
  '--disable-internal-links[do not make local links]' \
  '--enable-internal-links[make local links (default)]' \
  '--disable-local-file-access[do not allow conversion of local files]' \
  '--enable-local-file-access[allow conversion of local files (default)]' \
  '--exclude-from-outline[do not include the page in the table of contents and outlines]' \
  '--include-in-outline[include the page in the table of contents and outlines (default)]' \
  '--minimum-font-size[minimum font size]:pt:' \
  '--page-offset[set the starting page number]:N:' \
  '--password[HTTP Authentication password]:password:' \
  '--disable-plugins[disable installed plugins]' \
  '--enable-plugins[enable installed plugins (default)]' \
  '--post[add additional HTTP POST field]:name value:' \
  '--proxy[use a proxy]:proxy:' \
  '--ssl-crt-path[path to the ssl certificate]:file:_files' \
  '--ssl-key-password[password to ssl private key]:password:' \
  '--ssl-key-path[path to ssl private key]:file:_files' \
  '--stop-slow-scripts[stop slow running javascript]' \
  '--no-stop-slow-scripts[do not stop slow running javascript (default)]' \
  '--disable-toc-back-links[do not link from section header to toc]' \
  '--enable-toc-back-links[link from section header to toc]' \
  '--user-style-sheet[specify a user style sheet]:file:_files' \
  '--username[HTTP Authentication username]:username:' \
  '--viewport-size[viewport size]:WxH:' \
  '--window-status[wait until window.status is equal to this string before rendering]:string:' \
  '--header-center[centered header text]:text:' \
  '--header-font-name[set header font name]:font:' \
  '--header-font-size[set header font size]:pt:' \
  '--header-html[add HTML page as header]:URL:' \
  '--header-left[left-aligned header text]:text:' \
  '--header-line[display line below the header]' \
  '--no-header-line[do not display line below the header]' \
  '--header-right[right-aligned header text]:text:' \
  '--header-spacing[spacing between header and content]:mm:' \
  '--footer-center[centered footer text]:text:' \
  '--footer-font-name[set footer font name]:font:' \
  '--footer-font-size[set footer font size]:pt:' \
  '--footer-html[add HTML page as footer]:URL:' \
  '--footer-left[left-aligned footer text]:text:' \
  '--footer-line[display line above the footer]' \
  '--no-footer-line[do not display line above the footer]' \
  '--footer-right[right-aligned footer text]:text:' \
  '--footer-spacing[spacing between footer and content]:mm:' \
  '--toc-depth[set the depth of the toc]:N:' \
  '--toc-disable-back-links[do not link from section header to toc]' \
  '--toc-disable-dotted-lines[do not use dotted lines in the toc]' \
  '--toc-header-text[the header text of the toc]:text:' \
  '--toc-level-indentation[indentation used for each level]:width:' \
  '--toc-text-size-shrink[factor to shrink the font for each level]:factor:' \
  '--toc-xsl-style-sheet[use the supplied xsl style sheet for printing the toc]:file:_files' \
  '*:HTML file or URL:_files -g "*.html *.htm"'
