#compdef blc
# ============================================================================
# _blc — zsh completion for the Biscuit Language compiler (`blc`), an
#         imperative LLVM-backed language inspired by Jonathan Blow's JAI
#         (166th programming language entry — fills the long-standing
#         `blc` blacklist entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/biscuitlang/bl
#   Homepage   : https://biscuitlang.org
#   Maintainer : biscuitlang (Travis Roman et al.)
#   License    : MIT
#   Stars      : 219
#   Language   : C  (implementation; backend = LLVM)
#   Binary     : blc  (src/main.c is the compiler driver)
#   Source ext : .bl
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   Biscuit Language (BL) is "an experimental, general-purpose,
#   compiled or interpreted programming language inspired by new
#   C/C++ followers such as Odin, JAI and Zig" — explicitly framed
#   by its author as a C sequel rather than a C++ replacement.  It
#   ships an LLVM-backed AOT pipeline, a tree-walking interpreter
#   for compile-time execution (`-run`), an integrated build system
#   driven by a `build.bl` script (`-build`), a unit-test harness
#   (`-test`), an autogenerated docs system (`-doc`), and a shared-
#   library emitter (`-shared`).  Features include polymorphic
#   functions and structs, struct inheritance, full C ABI for
#   linking against C libraries, runtime type information, defer,
#   multiple return values, custom allocators, and basic game-dev
#   support via `extra` packages.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.c `option_t` table
#                       and docs/src/manual.md — `blc` uses a hand-
#                       rolled flag parser, not a third-party
#                       library;  single-dash flags are "mode"
#                       switches, double-dash flags are
#                       configurable options)
#   blc [MODE] [OPTIONS] [<FILE.bl>...]
#
#   Mode-selector subcommand flags (mutually exclusive):
#     -init                          Initialize a new BL project
#                                    in the current directory
#     -build                         Run the build system (looks
#                                    for `build.bl` in cwd and
#                                    executes its `main` at
#                                    compile time)
#     -run <FILE.bl>                 Compile to IR and execute in
#                                    the BL interpreter (the
#                                    `main` function runs at
#                                    compile time)
#     -silent-run <FILE.bl>          Same as -run but suppress
#                                    informational messages
#     -test                          Run the unit-test harness on
#                                    every `_test.bl` file (also
#                                    equivalent to --run-tests)
#     -doc                           Generate documentation from
#                                    source files
#     -shared                        Compile to a shared library
#                                    instead of an executable
#
#   Output / project options:
#     --output <PATH>                Output binary path
#     --doc-out-dir <DIR>            Output directory for `-doc`
#     --work-dir <DIR>               Working directory override
#     --override-config <FILE>       Use a custom blc config file
#
#   Discovery / introspection flags:
#     --version                      Print version
#     --help                         Print help
#     --about                        Print compiler / author info
#     --where-is-api                 Print path to the BL stdlib
#                                    source directory
#     --where-is-config              Print path to the blc config
#                                    file
#     --target-host                  Print the host LLVM target
#                                    triple
#     --target-supported             Print the list of supported
#                                    target triples
#     --target-experimental          Print experimental targets
#     --configure                    Regenerate the blc config
#                                    file
#
#   Logging / output behavior:
#     --verbose                      Verbose output
#     --silent                       Silent output (errors only)
#     --no-finished-report           Skip the build summary
#     --no-color                     Disable ANSI color
#     --legacy-colors                Use legacy color escapes
#     --no-jobs                      Disable parallel build jobs
#     --warnings-as-errors           Treat warnings as errors
#     --no-warning                   Suppress warnings
#     --full-path                    Print full file paths in
#                                    diagnostics
#     --no-usage-check               Disable unused-symbol
#                                    warnings
#     --stats                        Print compilation statistics
#
#   Dump-stage flags (for compiler internals work):
#     --lex-dump                     Dump lexer tokens
#     --ast-dump                     Dump parser AST
#     --scope-dump-parenting         Dump scope parent tree
#     --scope-dump-injection         Dump scope injection map
#     --emit-llvm                    Emit LLVM IR
#     --emit-asm                     Emit native assembly
#     --emit-mir                     Emit BL's mid-level IR
#
#   Code-generation flags:
#     --di                           Emit debug info (for
#                                    gdb/lldb/Visual Studio)
#     -opt <LEVEL>                   Optimization level
#                                    (0|1|2|3|s|z)
#     -release                       Release build (equivalent to
#                                    -opt 3 with extra options)
#     --assert                       Keep `assert` calls in
#                                    release builds
#     --reg-split                    Enable register splitting
#                                    (LLVM)
#     --verify-llvm                  Run LLVM IR verifier
#
#   Test-harness flags:
#     --run-tests                    Run discovered tests
#     --tests-minimal-output         Minimal test output
#
#   Stdlib flags:
#     --no-api                       Do not implicitly import the
#                                    stdlib API
#
#   `-`                              Read source from stdin
#
# LANGUAGE-CORPUS POSITION
#   Biscuit (BL) is the 166th programming language entry in this
#   completion corpus, completing the 3+1 micro-cycle that began
#   at R933 (_kora / solana-foundation Rust=141 OPENS Axis 86
#   Solana SDK Library) and continued through R934 (_solana-
#   validator-failover / SOL-Strategies Go=141) and R935
#   (_outsmart / outsmartchad TS-Node=141 CLOSES Axis 86 at 1/1/1
#   three-language symmetry — triple-141 landmark and 79th axis
#   closed).  BL joins Rux (R932 165th), Jule (R928 164th),
#   Nevalang (R924 163rd), Corvid (R920 162nd — round-number
#   R920 commit landmark), Soppo (R916 161st), Cyrus (R912 160th —
#   round-number language milestone), Lumina (R908 159th), Penne
#   (R904 158th), EndBASIC (R900 157th — R900 TRIPLE-9 commit
#   landmark), goboscript (R896 156th), Alan (R892 155th), Mech
#   (R888 154th — triple-8 landmark), Lisette (R884 153rd), Bril
#   (R880 152nd), Vyxal (R876 151st), EYG (R872 150th — round-
#   number language milestone), Roto (R868 149th), Pipefish
#   (R864 148th), Mochi (R860 147th), Oden (R856 146th), Hop
#   (R852 145th), Lustre via Kind 2 (R848 144th), Ravi (R844
#   143rd), ZetZ (R840 142nd), Granule (R836 141st), Sixten
#   (R832 140th), Imba (R828 139th), Tao (R824 138th), Dada
#   (R820 137th), Acton (R816 136th), and Stanza (R812 135th).
#
#   The `blc` binary already had a placeholder entry on
#   blacklist.txt line 2433 from prior harvest rounds;  this
#   round fills that placeholder with a real completion.
#
#   No completion for `blc` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_blc() {
    _arguments -s \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '(- *)--about[show compiler / author info]' \
        '(- *)--where-is-api[print stdlib source directory path]' \
        '(- *)--where-is-config[print blc config file path]' \
        '(- *)--target-host[print host LLVM target triple]' \
        '(- *)--target-supported[print list of supported targets]' \
        '(- *)--target-experimental[print experimental targets]' \
        '(- *)--configure[regenerate the blc config file]' \
        '-init[initialize a new BL project in current directory]' \
        '-build[run the integrated build.bl script]' \
        '-run[compile and run in interpreter]' \
        '-silent-run[same as -run but silent]' \
        '-test[run the unit-test harness]' \
        '-doc[generate documentation]' \
        '-shared[compile to shared library]' \
        '--output=[output binary path]:path:_files' \
        '--doc-out-dir=[output directory for -doc]:dir:_files -/' \
        '--work-dir=[working directory override]:dir:_files -/' \
        '--override-config=[use custom blc config file]:config:_files' \
        '--verbose[verbose output]' \
        '--silent[silent output (errors only)]' \
        '--no-finished-report[skip the build summary]' \
        '--no-color[disable ANSI color]' \
        '--legacy-colors[use legacy color escapes]' \
        '--no-jobs[disable parallel build jobs]' \
        '--warnings-as-errors[treat warnings as errors]' \
        '--no-warning[suppress warnings]' \
        '--full-path[print full file paths in diagnostics]' \
        '--no-usage-check[disable unused-symbol warnings]' \
        '--stats[print compilation statistics]' \
        '--lex-dump[dump lexer tokens]' \
        '--ast-dump[dump parser AST]' \
        '--scope-dump-parenting[dump scope parent tree]' \
        '--scope-dump-injection[dump scope injection map]' \
        '--emit-llvm[emit LLVM IR]' \
        '--emit-asm[emit native assembly]' \
        '--emit-mir[emit BL mid-level IR]' \
        '--di[emit debug info]' \
        '-opt[optimization level]:level:(0 1 2 3 s z)' \
        '-release[release build]' \
        '--assert[keep assert calls in release builds]' \
        '--reg-split[enable LLVM register splitting]' \
        '--verify-llvm[run LLVM IR verifier]' \
        '--run-tests[run discovered tests]' \
        '--tests-minimal-output[minimal test output]' \
        '--no-api[do not implicitly import stdlib API]' \
        '*:Biscuit source file:_files -g "*.bl"'
}

_blc "$@"
