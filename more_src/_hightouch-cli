#compdef hightouch-cli hightouch
# _hightouch-cli — Hightouch hightouch-cli CLI command-line frontend wrapping the Hightouch Reverse-ETL data activation platform managing sources destinations syncs models audiences sync-runs workspaces parent-resource Snowflake BigQuery Databricks Redshift sync-to Salesforce HubSpot Marketo Iterable Customer.io Braze Hightouch-API (Hightouch team, Go); cobra
# upstream: https://hightouch.com/

_hightouch-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'workspace:workspace management'
        'source:source management'
        'destination:destination management'
        'model:model management'
        'sync:sync management'
        'sync-run:sync run management'
        'audience:audience management'
        'parent-resource:parent-resource management'
        'sequence:sequence management'
        'trigger:trigger a sync'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--workspace-id=+[id]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hightouch-cli subcommand' sub ;;
        args)
            case $words[1] in
                workspace|source|destination|model|sync|sync-run|audience|parent-resource|sequence) _arguments '1:op:(list get create update delete enable disable run trigger)' '*:id:' ;;
                trigger) _arguments '*:sync id:' ;;
            esac
            ;;
    esac
}

_hightouch-cli "$@"
