#compdef libgen-cli libgen

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'search:search Library Genesis for a query'
  'download:download a book by MD5'
  'download-all:download all results matching a query'
  'dbdumps:list/download Library Genesis db dumps'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'libgen-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (search|download-all)
        _arguments \
          '(-f --filter)'{-f+,--filter=}'[filter type]:type:(title author isbn extension language)' \
          '(-l --library)'{-l+,--library=}'[library variant]:library:(libgen libgen-fiction libgen-comics libgen-magazines)' \
          '(-n --results)'{-n+,--results=}'[number of results to show]:n:' \
          '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
          '(-r --require-author)'{-r,--require-author}'[require author in result]' \
          '*--extension=[filter by extension]:ext:(pdf epub mobi azw3 djvu)' \
          '*--year=[year filter]:year:' \
          '--ipfs-mirrors[use IPFS mirrors]' \
          '*::query:' && ret=0 ;;
      (download)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
          '--ipfs-mirrors[use IPFS mirrors]' \
          '*::md5:' && ret=0 ;;
      (dbdumps)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
          '*::which:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
