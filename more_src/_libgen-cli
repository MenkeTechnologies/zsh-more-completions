#compdef libgen-cli libgen
# Documentation: https://github.com/ciehanski/libgen-cli
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'search:query the Library Genesis dataset'
  'download:download a book by MD5'
  'download-all:download all results matching a query'
  'dbdumps:list/download Library Genesis db dumps'
  'link:retrieve direct download link for an MD5'
  'status:check mirror responsiveness'
  'version:display installed client version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'libgen-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (search|download-all)
        _arguments \
          '(-i --ipfs-mirrors)'{-i,--ipfs-mirrors}'[force IPFS mirror downloads]' \
          '(-r --results)'{-r+,--results=}'[number of results (1-100)]:n:' \
          '(-e --extension)'{-e+,--extension=}'[filter by file type]:ext:(pdf epub mobi azw3 djvu)' \
          '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
          '(-s --sort-by)'{-s+,--sort-by=}'[sort field]:field:(id title author pub year lang size ext)' \
          '--sort-asc[ascending sort order]' \
          '(-a --require-author)'{-a,--require-author}'[require author field present]' \
          '(-y --year)'{-y+,--year=}'[filter by publication year]:year:' \
          '(-p --publisher)'{-p+,--publisher=}'[filter by publisher]:publisher:' \
          '(-l --language)'{-l+,--language=}'[filter by language]:lang:' \
          '*::query:' && ret=0 ;;
      (download)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
          '--ipfs-mirrors[force IPFS mirror downloads]' \
          '*::md5:' && ret=0 ;;
      (dbdumps)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
          '*::dump:' && ret=0 ;;
      (link)
        _arguments \
          '-i[retrieve IPFS link]' \
          '*::md5:' && ret=0 ;;
      (status)
        _arguments \
          '-m+[filter by mirror type]:type:(download search)' && ret=0 ;;
    esac ;;
esac

return ret
