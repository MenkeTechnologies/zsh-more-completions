#compdef jest-cli2
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '--all[run all tests]' \
  '--bail=[bail after N failures]:n:' \
  '-b[bail]' \
  '--cache=[use cache]:b:(true false)' \
  '--cacheDirectory=[cache dir]:dir:_files -/' \
  '--ci[CI mode]' \
  '--clearCache[clear cache and exit]' \
  '--clearMocks[clear mocks before each test]' \
  '--collectCoverage[collect coverage]' \
  '--collectCoverageFrom=[coverage glob]:p:' \
  '--coverage[collect coverage]' \
  '--coverageDirectory=[coverage dir]:dir:_files -/' \
  '--coverageProvider=[coverage provider]:p:(babel v8)' \
  '--coverageReporters=[reporters csv]:list:' \
  '--coverageThreshold=[threshold JSON]:j:' \
  '--config=[config file]:file:_files -g "jest.config.* package.json"' \
  '-c+[config file]:file:_files' \
  '--debug[debug config]' \
  '--detectLeaks[detect leaks]' \
  '--detectOpenHandles[detect open handles]' \
  '--env=[test env]:e:(jsdom node)' \
  '--errorOnDeprecated[error on deprecated]' \
  '--expand[expand snapshot]' \
  '-e[expand]' \
  '--filter=[filter file]:file:_files' \
  '--findRelatedTests[only related tests]' \
  '--forceExit[force exit]' \
  '-h[show help]' \
  '--init[initialize jest config]' \
  '--injectGlobals[inject globals]:b:(true false)' \
  '--json[JSON output]' \
  '--lastCommit[only last commit]' \
  '--listTests[list tests]' \
  '--logHeapUsage[log heap]' \
  '--maxConcurrency=[max concurrent]:n:' \
  '--maxWorkers=[max workers]:n:' \
  '-w+[max workers]:n:' \
  '--noStackTrace[no stack trace]' \
  '--notify[notify on completion]' \
  '--notifyMode=[notify mode]:m:(always failure success change success-warning failure-warning)' \
  '--onlyChanged[only changed]' \
  '-o[only changed]' \
  '--onlyFailures[only failures]' \
  '--openHandlesTimeout=[open handles timeout]:n:' \
  '--outputFile=[output file]:file:_files' \
  '--passWithNoTests[pass with no tests]' \
  '--projects=[projects csv]:list:' \
  '--randomize[randomize tests]' \
  '--reporters=[reporters csv]:list:(default github-actions jest-junit jest-silent-reporter)' \
  '--resetMocks[reset mocks]' \
  '--resetModules[reset modules]' \
  '--restoreMocks[restore mocks]' \
  '--rootDir=[root dir]:dir:_files -/' \
  '--roots=[roots csv]:list:_files -/' \
  '--runInBand[serial]' \
  '-i[run in band]' \
  '--runTestsByPath[run by path]' \
  '--runtime=[runtime]:r:' \
  '--seed=[random seed]:n:' \
  '--selectProjects=[projects csv]:list:' \
  '--shard=[shard N/M]:s:' \
  '--showConfig[show config]' \
  '--showSeed[show seed]' \
  '--silent[silent]' \
  '--snapshotFormat=[snapshot format JSON]:j:' \
  '--snapshotSerializers=[serializers csv]:list:' \
  '--testEnvironment=[test env]:e:(jsdom node)' \
  '--testFailureExitCode=[exit code]:n:' \
  '--testLocationInResults[test location in results]' \
  '--testMatch=[test match glob]:p:' \
  '--testNamePattern=[name regex]:re:' \
  '-t+[name pattern]:re:' \
  '--testPathIgnorePatterns=[ignore regex]:re:' \
  '--testPathPattern=[path pattern]:re:' \
  '--testRegex=[test file regex]:re:' \
  '--testResultsProcessor=[processor]:p:' \
  '--testRunner=[runner]:r:' \
  '--testSequencer=[sequencer]:s:' \
  '--testTimeout=[timeout ms]:ms:' \
  '--useStderr[output to stderr]' \
  '-u[update snapshots]' \
  '--updateSnapshot[update snapshots]' \
  '--verbose[verbose]' \
  '--watch[watch mode]' \
  '--watchAll[watch all]' \
  '--watchman[use watchman]:b:(true false)' \
  '--workerIdleMemoryLimit=[worker idle mem]:s:' \
  '*: :_files' && ret=0

return ret
