#compdef igvtools

# Zsh completion for igvtools (Broad IGV utilities). Subcommands vary by distribution; see `igvtools version`.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:igvtools command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'version:print tool and genome metadata versions'
      'sort:sort alignment or feature file'
      'index:create index'
      'tile:generate tiled data'
      'count:compute coverage counts'
      'read:test read of a file'
      'genome:prepare fasta.dict'
      'listdict:list sequence dictionary'
      'formathisto:format histogram'
      'gui:launch IGV from igvtools helper'
    )
    _describe -t commands 'igvtools subcommand' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
