#compdef kshisen
# Documentation: https://invent.kde.org/games/kshisen/-/blob/master/src/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream kshisen src/main.cpp - only KAboutData::setupCommandLine
# (no custom QCommandLineOption). Removed KDE4-era --author/--license
# (not added by modern QCommandLineParser).

# kshisen: KDE Shisen-Sho tile-matching game
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' && ret=0
return ret
