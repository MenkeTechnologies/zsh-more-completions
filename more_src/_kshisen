#compdef kshisen
# Documentation: https://apps.kde.org/kshisen/
# Reference accessed: 2026-05-16
# Verified: upstream KDE kshisen GUI app. KAboutData standard flags
# only; no custom QCommandLineOption.
# Removed from prior file: bogus man.archlinux.org search URL.

# kshisen: KDE Shisen-Sho tile-matching game
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' && ret=0
return ret
