#compdef gjavah
# Documentation: https://man.cx/javah
# Reference accessed: 2026-05-16
# Verified: GNU Classpath implementation of Sun javah(1) - same flag
# set.
# Removed from prior file: bogus man.archlinux.org search URL.

# gjavah: GNU Classpath JNI header generator
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-o[output file]:file:_files' \
  '-d[output directory]:dir:_files -/' \
  '-jni[create JNI-style native method prototypes (default)]' \
  '-classpath[class search path]:path:_files -/' \
  '-bootclasspath[boot class path]:path:_files -/' \
  '-force[always write output files]' \
  '-stubs[generate stubs]' \
  '-verbose[verbose output]' \
  '-old[use old (1.0) JNI ABI]' \
  '*:class name:' && ret=0
return ret
