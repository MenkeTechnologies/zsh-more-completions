#compdef clickhouse-benchmark

_arguments -s \
  '(- *)--help[show help]' \
  '(-i --iterations)'{-i,--iterations=}'[number of iterations]:n:' \
  '(-c --concurrency)'{-c,--concurrency=}'[concurrent queries]:n:' \
  '(-C --max_concurrency)'{-C,--max_concurrency=}'[max concurrency]:n:' \
  '(-d --delay)'{-d,--delay=}'[reporting delay seconds]:secs:' \
  '(-t --timelimit)'{-t,--timelimit=}'[time limit seconds]:secs:' \
  '*'{-h,--host=}'[server host]:host:_hosts' \
  '--port=[server port]:port:' \
  '(-s --secure)'{-s,--secure}'[use TLS]' \
  '--database=[database]:db:' \
  '--user=[username]:user:_users' \
  '--password=[password]:password:' \
  '--query=[query to run]:sql:' \
  '--query_id=[query ID]:id:' \
  '--query_id_prefix=[query ID prefix]:prefix:' \
  '--stage=[query processing stage]:stage:(complete fetch_columns with_mergeable_state)' \
  '(-r --randomize)'{-r,--randomize}'[randomize order]' \
  '--confidence=[confidence level]:n:' \
  '--cumulative[cumulative output]' \
  '--client-side-time[measure client-side time]' \
  '--precise[precise mode]' \
  '--reconnect=[reconnect mode]:n:' \
  '--max-consecutive-errors=[max consecutive errors]:n:' \
  '--ignore-error[ignore errors]' \
  '--continue_on_errors[continue on errors]' \
  '--roundrobin[round-robin host selection]' \
  '--proto-caps=[protocol capabilities]:caps:' \
  '--stacktrace[show stacktrace]' \
  '--verbose[verbose output]'
