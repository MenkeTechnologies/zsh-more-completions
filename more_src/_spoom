#compdef spoom
# Documentation: https://github.com/Shopify/spoom
# Spoom Sorbet tooling and type coverage helper

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(config srb tc coverage bump deadcode lsp)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      tc)
        _arguments -s \
          '(-s --sort)'{-s,--sort}'=[sort errors by criterion]:sort:(code loc)' \
          '(-c --code)'{-c,--code}'=[filter by error code]:code' \
          '(-l --limit)'{-l,--limit}'=[limit number of errors shown]:limit' \
          '(-u --uniq)'{-u,--uniq}'[remove duplicated lines]' \
          '(-f --format)'{-f,--format}'=[custom error format string]:format' \
          '--no-count[do not display error count]' \
          '*:path:_files' && ret=0
        ;;
      coverage)
        _arguments -s \
          '--save=[save coverage data to directory]:dir:_files -/' \
          '--from=[start date YYYY-MM-DD]:date' \
          '--to=[end date YYYY-MM-DD]:date' \
          '--bundle-install[run bundle install for each commit]' \
          '1:subcommand:(timeline report open snapshot)' && ret=0
        ;;
      bump)
        _arguments -s \
          '--from=[strictness level to bump from]:level:(false true ignore typed strict strong)' \
          '--to=[strictness level to bump to]:level:(false true ignore typed strict strong)' \
          '(-f --force)'{-f,--force}'[bump without type checking]' && ret=0
        ;;
    esac
    ;;
esac

return ret
