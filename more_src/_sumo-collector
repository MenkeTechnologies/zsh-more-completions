#compdef sumo-collector

# sumo-collector: Sumo Logic Installed Collector
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-q[run as installed service]' \
  '--register[register collector]' \
  '--accessid=[Sumo access id]:id:' \
  '--accesskey=[Sumo access key]:key:' \
  '--collector-name=[collector name]:name:' \
  '--source-name=[source name]:name:' \
  '--category=[source category]:cat:' \
  '--ephemeral[mark collector ephemeral]' \
  '--clobber[overwrite existing collector with same name]' \
  '*::sumo-collector args:_files' && ret=0
return ret
