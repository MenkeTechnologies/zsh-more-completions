#compdef impacket-wmipersist

# Impacket wmipersist.py: WMI persistence install/remove tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug output]' \
  '-target[user[:pwd]@host]:target:' \
  '-hashes[NTLM LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos auth]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-target-ip[target host IP]:ip:' \
  '1: :(install remove list)' \
  '-name[filter/consumer name]:name:' \
  '-vbs[VBScript payload file]:file:_files' \
  '-filter[event filter WQL]:wql:' \
  '*::wmipersist args:_files' && ret=0
return ret
