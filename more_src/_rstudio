#compdef rstudio Rstudio
# Documentation: https://man.archlinux.org/search?q=rstudio
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:project:_files -g "*.{R,Rproj,Rmd,qmd}"' && ret=0

return ret
