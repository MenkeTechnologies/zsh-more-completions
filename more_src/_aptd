#compdef aptd aptdaemon
# Documentation: aptdaemon
# Source: linuxmint/aptdaemon aptdaemon/core.py (master) — D-Bus daemon wrapping apt (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-t --disable-timeout)'{-t,--disable-timeout}'[do not shutdown on inactivity]' \
    '--disable-plugins[do not load plugins]' \
    '(-d --debug)'{-d,--debug}'[show internal processing info]' \
    '(-r --replace)'{-r,--replace}'[replace running instance]' \
    '--session-bus[use session bus instead of system bus]' \
    '--chroot=[run inside chroot]:dir:_files -/' \
    '(-p --profile)'{-p+,--profile=}'[write profile to file]:file:_files' \
    '--dummy[run in dummy mode (no actual changes)]' \
    && ret=0

return ret
