#compdef cargo-bin

# https://github.com/dustinblackman/cargo-run-bin — run binaries from Cargo.toml metadata

_arguments -s -S \
  '(-s --sync-aliases)'{-s,--sync-aliases}'[write cargo-* aliases to .cargo/config.toml]' \
  '(-i --install)'{-i,--install}'[build/install all \[metadata.bin\] tools]' \
  '(-b --build)'{-b,--build}'[deprecated alias for --install]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-h --help)'{-h,--help}'[help]' \
  '*::bin_or_args:_default' && return 0
