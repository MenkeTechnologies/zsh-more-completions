#compdef infer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--project-root=[root directory of the project]:directory:_directories' \
  '--results-dir=[directory for results]:directory:_directories' \
  '(-o --out)'{-o,--out}'[alias for --results-dir]:directory:_directories' \
  '--reactive[reactive mode for incremental analysis]' \
  '--no-progress-bar[do not show progress bar]' \
  '--debug[enable debug mode]' \
  '--force-integration=[force build system integration]:integration:(cmake gradle make maven ant buck ndk javac xcode)' \
  '--jobs=[number of parallel jobs]:jobs' \
  '-j+[number of parallel jobs]:jobs' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'run:run infer analysis end-to-end'
      'analyze:analyze captured files'
      'capture:capture build commands'
      'compile:compile source files'
      'report:generate report from analysis results'
      'explore:explore analysis results'
      'debug:debug infer issues'
      'reportdiff:compute diff of two reports'
    )
    _describe -t commands 'infer command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (run)
        _arguments -s -S \
          '--help[show help]' \
          '--project-root=[root directory of the project]:directory:_directories' \
          '--results-dir=[directory for results]:directory:_directories' \
          '--reactive[reactive mode]' \
          '--no-progress-bar[do not show progress bar]' \
          '--skip-analysis-in-path=[skip analysis in path]:path' \
          '--force-integration=[force build system integration]:integration:(cmake gradle make maven ant buck ndk javac xcode)' \
          '--compilation-database=[use compilation database]:file:_files' \
          '--changed-files-index=[file with changed files]:file:_files' \
          '--debug[enable debug mode]' \
          '*:build command' && ret=0
        ;;
      (analyze)
        _arguments -s -S \
          '--help[show help]' \
          '--project-root=[root directory of the project]:directory:_directories' \
          '--results-dir=[directory for results]:directory:_directories' \
          '--no-progress-bar[do not show progress bar]' \
          '--debug[enable debug mode]' \
          '--jobs=[number of parallel jobs]:jobs' \
          '--biabduction[run biabduction analysis]' \
          '--linters[run linter analysis]' \
          '--racerd[run racerd analysis]' \
          '--bufferoverrun[run buffer overrun analysis]' \
          '--quandary[run taint analysis]' && ret=0
        ;;
      (capture)
        _arguments -s -S \
          '--help[show help]' \
          '--project-root=[root directory of the project]:directory:_directories' \
          '--results-dir=[directory for results]:directory:_directories' \
          '--force-integration=[force build system integration]:integration:(cmake gradle make maven ant buck ndk javac xcode)' \
          '--compilation-database=[use compilation database]:file:_files' \
          '--debug[enable debug mode]' \
          '*:build command' && ret=0
        ;;
      (report)
        _arguments -s -S \
          '--help[show help]' \
          '--results-dir=[directory for results]:directory:_directories' \
          '--project-root=[root directory of the project]:directory:_directories' \
          '--issues-csv=[output issues as CSV]:file:_files' \
          '--issues-json=[output issues as JSON]:file:_files' \
          '--issues-txt=[output issues as text]:file:_files' && ret=0
        ;;
      (reportdiff)
        _arguments -s -S \
          '--help[show help]' \
          '--report-current=[current report]:file:_files' \
          '--report-previous=[previous report]:file:_files' \
          '--project-root=[root directory of the project]:directory:_directories' && ret=0
        ;;
      (explore)
        _arguments -s -S \
          '--help[show help]' \
          '--results-dir=[directory for results]:directory:_directories' \
          '--select=[select issue type]:issue type' \
          '--max-nesting=[max nesting level]:level' && ret=0
        ;;
      (compile|debug)
        _arguments -s -S \
          '--help[show help]' \
          '*:arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
