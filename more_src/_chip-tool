#compdef chip-tool
# Documentation: https://github.com/project-chip/connectedhomeip/blob/master/docs/development_controllers/chip-tool/chip_tool_guide.md
# chip-tool: Matter (CHIP) controller and test tool

local ret=1
local -a clusters pairings
clusters=(
  'pairing:commission and manage devices'
  'onoff:OnOff cluster commands'
  'levelcontrol:LevelControl cluster commands'
  'colorcontrol:ColorControl cluster commands'
  'descriptor:Descriptor cluster commands'
  'basicinformation:BasicInformation cluster commands'
  'discover:discover commissionable nodes'
  'interactive:start an interactive shell'
  'any:wildcard cluster command'
)
pairings=(
  'ble-wifi:commission over BLE onto WiFi'
  'ble-thread:commission over BLE onto Thread'
  'onnetwork:commission an on-network device by setup code'
  'onnetwork-long:commission using a long discriminator'
  'code:commission using a QR or manual setup code'
  'code-wifi:commission using a setup code onto WiFi'
  'code-thread:commission using a setup code onto Thread'
  'unpair:forget the currently commissioned device'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--paa-trust-store-path=[directory of trusted PAA certificates]:dir:_files -/' \
  '--cd-trust-store-path=[directory of Certification Declaration signing certs]:dir:_files -/' \
  '--commissioner-name=[fabric commissioner to use]:name' \
  '--commissioner-nodeid=[node id to use on the fabric]:nodeid' \
  '--storage-directory=[directory to store device state]:dir:_files -/' \
  '--trace_file=[file to store trace data]:file:_files' \
  '--trace_log=[print trace data with automation logs]:flag:(0 1)' \
  '--ble-controller=[Bluetooth adapter to use]:controller' \
  '--bypass-attestation-verifier=[bypass the attestation verifier]:flag:(true false)' \
  '--timeout=[command timeout in seconds]:seconds' \
  '1:command:->cmd' \
  '2:subcommand:->sub' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'chip-tool cluster' clusters && ret=0 ;;
  sub)
    case $line[1] in
      pairing) _describe -t commands 'pairing command' pairings && ret=0 ;;
    esac ;;
esac

return ret
