#compdef xpbsmon
# _xpbsmon — PBS xpbsmon (Tk-based PBS cluster monitor: a refreshing dashboard of PBS Server queues, jobs, nodes and reservations; -refresh seconds, -h help, -display X display, -geometry WxH+X+Y, -server PBS server host; mostly used in scientific computing operator rooms)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/gui/xpbsmon on tip.

_xpbsmon() {
    _arguments \
        '-h[show help]' \
        '-refresh+[seconds]:seconds:' \
        '-display+[X display]:display:' \
        '-geometry+[WxH+X+Y]:geom:' \
        '-server+[PBS server]:host:_hosts'
}

_xpbsmon "$@"
