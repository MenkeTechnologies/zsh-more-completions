#compdef unrtf
# Documentation: https://man.archlinux.org/search?q=unrtf
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--html[output HTML (default)]' \
  '--text[output plain text]' \
  '--vt[output VT100 terminal]' \
  '--latex[output LaTeX]' \
  '--rtf[output de-obfuscated RTF]' \
  '--ps[output PostScript]' \
  '--wpml[output WPML]' \
  '(-t --tags)'{-t,--tags}'=[use custom tag file]:file:_files' \
  '--nopict[do not output pictures]' \
  '--noremap[do not remap special characters]' \
  '--quiet[suppress warnings]' \
  '*:RTF file:_files -g "*.rtf"' && ret=0

return ret
