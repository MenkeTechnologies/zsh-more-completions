#compdef unrtf
# Documentation: https://linux.die.net/man/1/unrtf
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--html[output HTML (default)]' \
  '--text[output plain ASCII text]' \
  '--vt[output text with VT100 escape codes]' \
  '--latex[output LaTeX]' \
  '--rtf[output RTF]' \
  '--nopict[disable automatic storage of embedded pictures]' \
  '--noremap[disable charset conversion for 8-bit charsets]' \
  '--verbose[print additional information]' \
  '--quiet[suppress leading comments]' \
  '-t[tags output configuration file]:file:_files' \
  '-P[config search path]:path:_files -/' \
  '*:RTF file:_files -g "*.rtf"' && ret=0

return ret
