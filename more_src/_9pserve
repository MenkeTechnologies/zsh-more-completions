#compdef 9pserve
# Documentation: https://9fans.github.io/plan9port/man/man4/9pserve.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c[run only one client at a time]' \
  '-l+[log file]:file:_files' \
  '-m+[msize]:n:' \
  '-n+[network]:net:(tcp unix tls)' \
  '-N+[noauth]' \
  '-q[quiet]' \
  '-v[verbose]' \
  '*:address:' && ret=0

return ret
