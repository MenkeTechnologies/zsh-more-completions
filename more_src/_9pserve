#compdef 9pserve
# Documentation: https://man.archlinux.org/search?q=9pserve
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c[run only one client at a time]' \
  '-l+[log file]:file:_files' \
  '-m+[msize]:n:' \
  '-n+[network]:net:(tcp unix tls)' \
  '-N+[noauth]' \
  '-q[quiet]' \
  '-v[verbose]' \
  '*:address:' && ret=0

return ret
