#compdef antsRegistration
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsRegistration.cxx — registration framework (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--version[print version]' \
    '(-d --dimensionality)'{-d+,--dimensionality=}'[image dimensionality]:n:(2 3 4)' \
    '(-o --output)'{-o+,--output=}'[output transform/warp]:spec:_default' \
    '(-j --save-state)'{-j+,--save-state=}'[save state file]:file:_files' \
    '(-k --restore-state)'{-k+,--restore-state=}'[restore state file]:file:_files' \
    '(-a --write-composite-transform)'{-a+,--write-composite-transform=}'[write composite transform]:n:(0 1)' \
    '(-p --print-similarity-measure-interval)'{-p+,--print-similarity-measure-interval=}'[print similarity measure interval]:n:_default' \
    '--write-interval-volumes=[write volumes at intervals]:n:_default' \
    '(-z --collapse-output-transforms)'{-z+,--collapse-output-transforms=}'[collapse output transforms]:n:(0 1)' \
    '(-i --initialize-transforms-per-stage)'{-i+,--initialize-transforms-per-stage=}'[initialize per stage]:n:(0 1)' \
    '(-n --interpolation)'{-n+,--interpolation=}'[interpolation]:method:(Linear NearestNeighbor MultiLabel Gaussian BSpline CosineWindowedSinc WelchWindowedSinc HammingWindowedSinc LanczosWindowedSinc GenericLabel)' \
    '(-g --restrict-deformation)'{-g+,--restrict-deformation=}'[restrict deformation directions]:spec:_default' \
    '(-q --initial-fixed-transform)'{-q+,--initial-fixed-transform=}'[initial fixed transform]:spec:_default' \
    '(-r --initial-moving-transform)'{-r+,--initial-moving-transform=}'[initial moving transform]:spec:_default' \
    '*'{-m+,--metric=}'[similarity metric spec (Mattes/MI/CC/MeanSquares/Demons/GC)]:spec:_default' \
    '*'{-t+,--transform=}'[transform spec (Rigid/Affine/SyN/BSplineSyN/Translation/...)]:spec:_default' \
    '*'{-c+,--convergence=}'[convergence (iters[,threshold[,window]])]:spec:_default' \
    '*'{-s+,--smoothing-sigmas=}'[per-stage smoothing sigmas]:spec:_default' \
    '*'{-f+,--shrink-factors=}'[per-stage shrink factors]:spec:_default' \
    '(-u --use-histogram-matching)'{-u+,--use-histogram-matching=}'[use histogram matching]:n:(0 1)' \
    '(-w --winsorize-image-intensities)'{-w+,--winsorize-image-intensities=}'[winsorize intensities (lo,hi)]:spec:_default' \
    '(-x --masks)'{-x+,--masks=}'[fixed/moving mask images]:spec:_default' \
    '--float=[use float precision]:n:(0 1)' \
    '--minc=[write MINC-format output]:n:(0 1)' \
    '--random-seed=[random seed]:n:_default' \
    '(- *)'{-v,--verbose}'[verbose]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
