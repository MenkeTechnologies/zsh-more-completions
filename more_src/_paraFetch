#compdef paraFetch
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: fetch url with multiple connections

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-newer[only download if newer than local version]' \
  '-progress[show progress of download]' \
  ':connections:' \
  ':retries:' \
  ':url:_urls' \
  '::out path:_files' && ret=0

return ret
