#compdef ksql ksqldb-cli
# _ksql — Confluent ksqlDB CLI (SQL-style streaming Kafka client; -u user, -p password, --request-properties prop=val per-request override, --execute one-shot statement, --file batch script, --version; once inside: LIST/SHOW STREAMS|TABLES|TOPICS, CREATE STREAM/TABLE, INSERT INTO, SELECT, PRINT TOPIC, DESCRIBE, EXPLAIN, TERMINATE)
# upstream: https://github.com/confluentinc/ksql
# Flags from Confluent ksqlDB ksqldb-cli on tip.

_ksql() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-u+[user]:user:_users' \
        '-p+[password]:password:' \
        '--config-file+[config file]:file:_files' \
        '--execute+[statement]:statement:' \
        '--file+[script]:file:_files' \
        '*--request-property+[name=value]:prop:' \
        '*--variable+[name=value]:var:' \
        '--output+[output format]:format:(JSON TABULAR)' \
        '1:ksqlDB server URL:'
}

_ksql "$@"
