#compdef guile-tools

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'compile:compile a Guile source file'
  'disassemble:disassemble compiled Guile code'
  'help:show help for a tool'
  'list:list available tools'
  'snarf:guile-snarf for C extension definitions'
  'system-tap:Guile SystemTap helper'
)

_arguments -C \
  '(- *)--version[show version]' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'guile-tools subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (compile)
        _files -g "*.scm" && ret=0
        ;;
      (disassemble)
        _files -g "*.go" && ret=0
        ;;
    esac
    ;;
esac

return ret
