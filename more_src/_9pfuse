#compdef 9pfuse
# Documentation: https://9fans.github.io/plan9port/man/man4/9pfuse.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-D[debug FUSE]' \
  '-d[debug 9P protocol]' \
  '-A+[file access cache time]:sec:' \
  '-C+[file attribute cache time]:sec:' \
  '-n+[username]:user:_users' \
  '-s[do not use socket]' \
  '-v[verbose]' \
  '1:server:' \
  '2:mountpoint:_files -/' && ret=0

return ret
