#compdef alerta alerta-cli
# _alerta — Alerta monitoring system CLI (Alerta project, Python); argparse
# upstream: https://github.com/alerta/python-alerta-client

_alerta() {
    local -a sub=(
        'config:show config'
        'send:send alert'
        'query:query alerts'
        'top:interactive top of active alerts'
        'tag:add tags'
        'untag:remove tags'
        'ack:acknowledge alerts'
        'unack:unacknowledge alerts'
        'shelve:shelve alerts'
        'unshelve:unshelve alerts'
        'note:add note'
        'close:close alerts'
        'delete:delete alerts'
        'whoami:show current user'
        'token:show token'
        'login:login'
        'logout:logout'
        'key:manage api keys'
        'user:manage users'
        'customer:manage customers'
        'group:manage groups'
        'heartbeat:send heartbeat'
        'status:show server status'
        'history:show history'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--endpoint-url=+[alerta endpoint]:url:_urls' \
        '-e+[alerta endpoint]:url:_urls' \
        '--key=+[api key]:str:' \
        '-K+[api key]:str:' \
        '--username=+[username]:str:_users' \
        '-u+[username]:str:_users' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--config-file=+[config file]:file:_files' \
        '--profile=+[profile]:profile:' \
        '--ssl-verify[verify SSL]' \
        '--no-ssl-verify[no ssl verify]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--json[json output]' \
        '-j[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'alerta subcommand' sub ;;
        args)
            case $words[1] in
                send) _arguments \
                    '--resource=+[resource]:str:' \
                    '-r+[resource]:str:' \
                    '--event=+[event]:str:' \
                    '-E+[event]:str:' \
                    '--severity=+[severity]:sev:(security critical major minor warning informational debug trace indeterminate ok cleared)' \
                    '-s+[severity]:sev:(security critical major minor warning informational debug trace indeterminate ok cleared)' \
                    '--environment=+[environment]:env:' \
                    '-e+[environment]:env:' \
                    '--service=+[service]:list:' \
                    '-S+[service]:list:' \
                    '--group=+[group]:str:_groups' \
                    '-g+[group]:str:_groups' \
                    '--value=+[value]:str:' \
                    '-v+[value]:str:' \
                    '--text=+[text]:str:' \
                    '-t+[text]:str:' \
                    '--tag=+[tag]:list:' \
                    '-T+[tag]:list:' \
                    '--attribute=+[attribute key=value]:str:' \
                    '-A+[attribute key=value]:str:' \
                    '--origin=+[origin]:str:' \
                    '--type=+[event type]:str:' \
                    '--timeout=+[timeout]:n:' ;;
                query|top|history) _arguments \
                    '--filters=+[filters]:str:' \
                    '--ids=+[ids]:list:' \
                    '--from-date=+[from date]:date:' \
                    '--to-date=+[to date]:date:' ;;
                tag|untag|note) _arguments \
                    '1:alert-id:' \
                    '--tags=+[tags]:list:' \
                    '--note=+[note text]:str:' ;;
                ack|unack|shelve|unshelve|close|delete) _arguments \
                    '*:alert-id:' \
                    '--note=+[note]:str:' \
                    '--timeout=+[timeout]:n:' ;;
                key|user|customer|group) _arguments \
                    '1:cmd:(list add update delete revoke)' \
                    '*:arg:' ;;
                heartbeat) _arguments \
                    '--origin=+[origin]:str:' \
                    '--tag=+[tag]:list:' \
                    '--timeout=+[timeout]:n:' ;;
            esac
            ;;
    esac
}

_alerta "$@"
