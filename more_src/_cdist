#compdef cdist
# Documentation: https://man.archlinux.org/search?q=cdist
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-d --debug)'{-d,--debug}'[set log level to debug]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'config:Configure a host'
      'install:Install cdist'
      'inventory:Inventory management'
      'shell:Open interactive shell'
      'banner:Show cdist banner'
      'info:Show cdist info'
      'scan:Scan for new hosts'
      'trigger:Trigger cdist run'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (config)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
          '(-d --debug)'{-d,--debug}'[debug mode]' \
          '(-b --beta)'{-b,--beta}'[enable beta features]' \
          '(-c --conf-dir)'{-c,--conf-dir}'=[config directory]:dir:_files -/' \
          '(-f --file)'{-f,--file}'=[read hosts from file]:file:_files' \
          '(-i --initial-manifest)'{-i,--initial-manifest}'=[initial manifest]:manifest:_files' \
          '(-j --jobs)'{-j,--jobs}'=[number of parallel jobs]:jobs:' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '(-o --out-dir)'{-o,--out-dir}'=[output directory]:dir:_files -/' \
          '(-p --parallel)'{-p,--parallel}'[run in parallel]' \
          '(-r --remote-out-dir)'{-r,--remote-out-dir}'=[remote output directory]:dir:' \
          '(-s --sequential)'{-s,--sequential}'[run sequentially]' \
          '--remote-copy=[remote copy command]:command:' \
          '--remote-exec=[remote exec command]:command:' \
          '--save-output-streams[save output streams]' \
          '*:host:_hosts' && ret=0
        ;;
      (inventory)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-I --inventory)'{-I,--inventory}'=[inventory directory]:dir:_files -/' \
          '1:action:(list add-host del-host add-tag del-tag)' \
          '*:host:_hosts' && ret=0
        ;;
      (shell)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-s --shell)'{-s,--shell}'=[shell to use]:shell:_files' \
          '*:host:_hosts' && ret=0
        ;;
    esac
    ;;
esac

return ret
