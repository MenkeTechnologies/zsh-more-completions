#compdef bandit

# zsh completions for 'bandit'
local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  {-r,--recursive}'[find and process files in subdirectories]'
  {-a,--aggregate}'[aggregate output by vulnerability or by filename]:aggregate type:(file vuln)'
  {-n,--number-lines}'[maximum number of code lines to output for each issue]:number:'
  {-c,--configfile}'[optional config file to use for selecting plugins]:config file:_files'
  {-p,--profile}'[profile to use (defaults to any found in config file)]:profile:'
  {-t,--tests}'[comma-separated list of test IDs to run]:tests:'
  {-s,--skip}'[comma-separated list of test IDs to skip]:tests:'
  {-l,--level}'[report only issues of a given severity level or higher]'
  {-i,--confidence}'[report only issues of a given confidence level or higher]'
  {-f,--format}'[specify output format]:format:(csv custom html json screen txt xml yaml)'
  {-o,--output}'[write report to filename]:output file:_files'
  '--msg-template[specify output message template]:template:'
  {-v,--verbose}'[output extra information like excluded and included tests]'
  {-d,--debug}'[turn on debug mode]'
  {-q,--quiet}'[only show output in the case of an error]'
  '--ignore-nosec[do not skip lines with # nosec comments]'
  {-x,--exclude}'[comma-separated list of paths to exclude from scan]:paths:'
  {-b,--baseline}'[path to baseline report to compare against]:baseline file:_files'
  '--ini[path to .bandit config file]:ini file:_files'
  '--exit-zero[force exit with code 0 even if issues are found]'
  '--severity-threshold[specify minimum severity threshold]:threshold:(low medium high)'
  '*:file or directory:_files'
)

_arguments -s -S $arguments
