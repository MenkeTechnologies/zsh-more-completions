#compdef rivet-merge
# Documentation: https://rivet.hepforge.org/
# rivet-merge - merge Rivet YODA output files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output-file)'{-o,--output-file}'[specify the output histo file path]:file:_files' \
  '(-e --equiv)'{-e,--equiv}'[assume yoda files are equivalent but statistically independent]' \
  '*'{-O,--merge-option}'[analysis option name where different options should be merged]:opt:' \
  '*:yodafile:_files' && ret=0

return ret
