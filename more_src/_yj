#compdef yj
# Zsh completion for yj
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-yj[convert YAML to JSON]' \
  '-jy[convert JSON to YAML]' \
  '-yt[convert YAML to TOML]' \
  '-ty[convert TOML to YAML]' \
  '-jt[convert JSON to TOML]' \
  '-tj[convert TOML to JSON]' \
  '-yy[convert YAML to YAML]' \
  '-jj[convert JSON to JSON]' \
  '-tt[convert TOML to TOML]' \
  '-e[escape HTML characters]' \
  '-i[indent N spaces]:spaces:' \
  '-k[sort keys]' \
  '-n[no trailing newline]' \
  '-h[display help]' && ret=0
return ret
