#compdef yj
# Documentation: https://github.com/sclevine/yj
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-y[YAML to JSON (default)]' \
  '-yy[convert YAML to YAML]' \
  '-yt[convert YAML to TOML]' \
  '-yc[convert YAML to HCL]' \
  '-yj[convert YAML to JSON]' \
  '-t[TOML to JSON]' \
  '-tj[convert TOML to JSON]' \
  '-ty[convert TOML to YAML]' \
  '-tt[convert TOML to TOML]' \
  '-tc[convert TOML to HCL]' \
  '-jj[convert JSON to JSON]' \
  '-jy[convert JSON to YAML]' \
  '-jt[convert JSON to TOML]' \
  '-jc[convert JSON to HCL]' \
  '-r[JSON to YAML]' \
  '-c[HCL to JSON]' \
  '-cy[convert HCL to YAML]' \
  '-ct[convert HCL to TOML]' \
  '-cj[convert HCL to JSON]' \
  '-cc[convert HCL to HCL]' \
  '-e[escape HTML (JSON out only)]' \
  '-i[indent output (JSON or TOML out only)]' \
  '-k[parse keys as objects or numeric types (YAML out only)]' \
  '-n[do not convert inf/-inf/NaN to/from strings]' \
  '-h[show help]' \
  '-v[show version]' && ret=0
return ret
