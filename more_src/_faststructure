#compdef faststructure structure.py
# Documentation: https://rajanil.github.io/fastStructure/
# fastStructure: variational inference of population structure from SNP data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-K+[number of populations to infer]:int' \
  '--input=[input genotype data file (without extension)]:prefix:_files' \
  '--output=[output file prefix]:prefix' \
  '--tol=[convergence criterion]:float' \
  '--prior=[choice of prior]:prior:(simple logistic)' \
  '--cv=[number of test sets for cross-validation]:int' \
  '--format=[format of input file]:format:(bed str)' \
  '--full[output all variational parameters]' \
  '--seed=[seed for random number generator]:int' && ret=0

return ret
