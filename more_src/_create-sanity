#compdef create-sanity
# Documentation: https://www.npmjs.com/package/create-sanity
# Reference accessed: 2026-05-24
# Verified: npx create-sanity --help.

# Zsh completion for create-sanity - Sanity Studio and project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-y --yes)'{-y,--yes}'[unattended mode with defaults]' \
  '--auto-updates[enable auto updates of studio versions]' \
  '--no-auto-updates[disable auto updates]' \
  '--bare[skip studio init; print project ID and dataset]' \
  '--coupon=[coupon code for new project]:code:' \
  '--dataset=[dataset name]:name:' \
  '--dataset-default[use public production dataset]' \
  '--env=[write environment variables to file]:file:_files' \
  '--git=[initial commit message]:message:' \
  '--no-git[skip git initialization]' \
  '--import-dataset[import template sample dataset]' \
  '--no-import-dataset[skip sample dataset import]' \
  '--mcp[enable AI editor MCP setup]' \
  '--no-mcp[skip MCP setup]' \
  '--organization=[organization ID]:id:' \
  '--output-path=[studio output path]:path:_directories' \
  '--overwrite-files[overwrite existing files]' \
  '--no-overwrite-files[do not overwrite existing files]' \
  '--package-manager=[package manager]:manager:(npm yarn pnpm)' \
  '--project=[project ID]:id:' \
  '--project-name=[new project name]:name:' \
  '--project-plan=[plan for new project]:plan:' \
  '--provider=[login provider]:provider:' \
  '--template=[project template]:template:(clean)' \
  '--typescript[enable TypeScript support]' \
  '--no-typescript[disable TypeScript support]' \
  '--visibility=[dataset visibility mode]:mode:' \
  '--nextjs-add-config-files[add config files to Next.js project]' \
  '--nextjs-append-env[append project ID and dataset to .env]' \
  '--nextjs-embed-studio[embed studio in Next.js project]' \
  '--json[format output as JSON]' && ret=0

return ret
