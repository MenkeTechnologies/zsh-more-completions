#compdef syncsnoop syncsnoop-bpfcc
# _syncsnoop — trace sync()/fsync()/fdatasync()/msync() syscalls (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/syncsnoop.py — takes no flags besides --help.

_syncsnoop() {
    _arguments '(- *)'{-h,--help}'[show help]'
}

_syncsnoop "$@"
