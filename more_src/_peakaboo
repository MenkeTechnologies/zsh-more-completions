#compdef peakaboo
# Documentation: https://proteowizard.sourceforge.io/tools/tools_base.html
# ProteoWizard: extract peaks from a region of a mass-spec data file

local ret=1

_arguments -s -S \
  '(-f --filelist)'{-f,--filelist}'[specify text file containing filenames]:file:_files' \
  '(-o --outdir)'{-o,--outdir}'[set output directory]:dir:_files -/' \
  '(-e --ext)'{-e,--ext}'[set extension for output files]:ext:' \
  '--scanBegin[set first scan]:scan:' \
  '--scanEnd[set last scan]:scan:' \
  '--mzLow[set mz low cutoff]:mz:' \
  '--mzHigh[set mz high cutoff]:mz:' \
  '*:data file:_files' && ret=0

return ret
