#compdef nwg-hello

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d[enable debug mode]' \
  '-l[set locale]:locale:' \
  '-s[custom CSS file]:css file:_files' \
  '-c[config file]:config file:_files' && ret=0

return ret
