#compdef nwg-hello
# Documentation: https://github.com/nwg-piotr/nwg-hello
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d[enable debug mode]' \
  '-l[set locale]:locale:' \
  '-s[custom CSS file]:css file:_files' \
  '-c[config file]:config file:_files' && ret=0

return ret
