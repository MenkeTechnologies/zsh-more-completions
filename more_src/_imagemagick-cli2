#compdef magick-cli mogrify-cli2

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '-list+[list info]:l:(Align Alpha AutoThreshold Boolean Cache Channel Class CLI Color ColorMatrix ColorOption Colorspace Combine Command Compose Compress ComplianceTrace Configure DataType Debug Decoration Delegate Direction Dispose Distort Dither Endian Evaluate FillRule Filter Font Format Function Gravity Group Intensity Intent Interlace Interpolate Kernel Layers LineCap LineJoin List Locale Log LogEvent MagicType Method Metric Mime Module Morphology MorphologyMethod Noise Orientation Path PathOperator PixelChannel PixelIntensityMethod PixelMask PixelTrait Policy Preview Primitive QuantumFormat Resource Sparse Statistic Storage Stretch Style Threshold Tool Type Units Validate VirtualPixel)' \
  '-density+[density]:d:' \
  '-quality+[quality 0-100]:n:' \
  '-resize+[geometry]:g:' \
  '-rotate+[degrees]:n:' \
  '-flip[flip vertical]' \
  '-flop[flip horizontal]' \
  '-crop+[geometry]:g:' \
  '-extent+[geometry]:g:' \
  '-strip[strip metadata]' \
  '-thumbnail+[geometry]:g:' \
  '-format+[format]:f:' \
  '-define+[k=v]:k:' \
  '-channel+[channel csv]:list:' \
  '-colorspace+[colorspace]:c:(CMY CMYK Gray HCL HCLp HSB HSI HSL HSV HWB LCH LCHab LCHuv LMS Lab Luv OHTA RGB Rec601YCbCr Rec709YCbCr XYZ YCC YCbCr YDbDr YIQ YPbPr YUV scRGB sRGB)' \
  '-depth+[bit depth]:n:(1 8 16 32)' \
  '-compress+[compression]:c:(None BZip Fax Group4 JPEG JPEG2000 LZW PackBits Piz RLE Zip)' \
  '-background+[color]:c:' \
  '-bordercolor+[color]:c:' \
  '-fill+[color]:c:' \
  '-stroke+[color]:c:' \
  '-pointsize+[font size]:n:' \
  '-font+[font name]:f:' \
  '-gravity+[gravity]:g:(NorthWest North NorthEast West Center East SouthWest South SouthEast)' \
  '-trim[trim edges]' \
  '-shave+[geometry]:g:' \
  '-splice+[geometry]:g:' \
  '-roll+[geometry]:g:' \
  '-shear+[degrees]:n:' \
  '-transpose[transpose]' \
  '-transverse[transverse]' \
  '-deskew+[threshold%]:n:' \
  '-despeckle[despeckle]' \
  '-edge+[radius]:n:' \
  '-emboss+[radius]:n:' \
  '-sharpen+[geometry]:g:' \
  '-blur+[geometry]:g:' \
  '-gaussian-blur+[geometry]:g:' \
  '-motion-blur+[geometry]:g:' \
  '-radial-blur+[degrees]:n:' \
  '-rotational-blur+[degrees]:n:' \
  '-noise+[radius]:n:' \
  '-charcoal+[radius]:n:' \
  '-paint+[radius]:n:' \
  '-sepia-tone+[threshold%]:n:' \
  '-solarize+[threshold]:n:' \
  '-equalize[equalize]' \
  '-normalize[normalize]' \
  '-contrast[increase contrast]' \
  '-modulate+[brightness,sat,hue]:m:' \
  '-brightness-contrast+[B,C]:s:' \
  '-level+[B,W,gamma]:l:' \
  '-gamma+[value]:n:' \
  '-tint+[value]:n:' \
  '-colorize+[value]:n:' \
  '-monochrome[monochrome]' \
  '-negate[negate]' \
  '-grayscale+[method]:m:(Average Brightness Lightness Luma Luminance Maximum MS Median Minimum Rec601Luma Rec601Luminance Rec709Luma Rec709Luminance RMS)' \
  '-threshold+[value]:n:' \
  '-write+[output]:file:_files' \
  '-page+[geometry]:g:' \
  '-units+[units]:u:(Undefined PixelsPerInch PixelsPerCentimeter)' \
  '-virtual-pixel+[method]:m:' \
  '-debug+[events]:e:' \
  '-verbose[verbose]' \
  '-quiet[quiet]' \
  '-monitor[monitor progress]' \
  '*: :_files' && ret=0

return ret
