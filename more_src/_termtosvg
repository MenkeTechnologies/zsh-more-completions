#compdef termtosvg

_termtosvg_commands() {
  local -a commands=(
    'record:record a terminal session'
  )
  _describe -t commands 'command' commands
}

_termtosvg() {
  local curcontext="$curcontext" state line ret=1

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help message]' \
    '--version[show version]' \
    '(-g --screen-geometry)'{-g,--screen-geometry}'[terminal screen geometry]:geometry (WxH)' \
    '(-m --min-frame-duration)'{-m,--min-frame-duration}'[minimum frame duration in ms]:milliseconds' \
    '(-M --max-frame-duration)'{-M,--max-frame-duration}'[maximum frame duration in ms]:milliseconds' \
    '(-s --still-frames)'{-s,--still-frames}'[use still frames]' \
    '(-t --template)'{-t,--template}'[SVG template]:template name' \
    '(-c --command)'{-c,--command}'[command to record]:command' \
    '--loop-delay[delay before looping in ms]:milliseconds' \
    '--verbose[verbose output]' \
    '(-D --screen-geometry-detection)'{-D,--screen-geometry-detection}'[screen geometry detection method]' \
    '1:output file:_files' && ret=0

  return ret
}

_termtosvg "$@"
