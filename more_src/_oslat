#compdef oslat
# OS latency measurement tool

local ret=1

_arguments -s -S \
  '-b[specify bucket width]:width:' \
  '-B[specify maximum buckets]:count:' \
  '-c[specify CPU list]:cpu list:' \
  '-C[CPU-intensive mode]' \
  '-D[specify duration]:duration:' \
  '-f[specify RT priority]:priority:' \
  '-T[specify number of threads]:threads:' \
  '-w[specify warmup time]:warmup:' \
  '-z[zero-crossing histogram]' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
