#compdef TextExporter
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: export OpenMS data files to tab/comma-separated text

local ret=1

_arguments -s -S \
  '-in[input file]:input file:_files' \
  '-out[output file]:output file:_files' \
  '-out_type[output file type]:type:(tsv csv txt)' \
  '-replacement[character to replace separator occurrences]:char:' \
  '-quoting[quoting method]:method:(none double escape)' \
  '-no_ids[suppress identification data output]' \
  '-feature:minimal[output only RT, m/z and intensity]' \
  '-feature:add_metavalues[include meta value columns at frequency]:freq:' \
  '-id:proteins_only[export protein information only]' \
  '-id:peptides_only[export peptide information only]' \
  '-id:protein_groups[include indistinguishable group info]' \
  '-id:first_dim_rt[include first dimension RT values]' \
  '-id:add_metavalues[add PeptideID meta value columns]:freq:' \
  '-id:add_hit_metavalues[add PeptideHit meta value columns]:freq:' \
  '-id:add_protein_hit_metavalues[add protein-level meta value columns]:freq:' \
  '-id:annotations[peak annotation format]:format:(none default)' \
  '-id:add_usi[add Universal Spectrum Identifiers column]' \
  '-id:usi_dataset_id[ProteomeXchange dataset id for USI]:id:' \
  '-consensus:centroids[output file for consensus feature centroids]:file:_files' \
  '-consensus:elements[output file for consensus feature elements]:file:_files' \
  '-consensus:features[output file for consensus features]:file:_files' \
  '-consensus:sorting_method[sorting criteria]:method:(none RT MZ RT_then_MZ intensity quality_decreasing quality_increasing)' \
  '-consensus:sort_by_maps[sort by covered maps lexicographically]' \
  '-consensus:sort_by_size[sort by decreasing element count]' \
  '-consensus:add_metavalues[include ConsensusFeature meta value columns]:freq:' \
  '-xic:mode[XIC output format]:mode:(summary explode)' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
