#compdef svix-server
# ---------------------------------------------------------------------------
# svix-server — Svix webhooks server: open-source webhook-delivery
#               infrastructure with retry-with-backoff queues, signature
#               verification, replay protection, application/endpoint
#               configuration, and HMAC + asymmetric (Ed25519 / RSA)
#               signature schemes — the self-hosted version of the
#               managed Svix service used by Stripe alternatives /
#               fintechs / large SaaS for transactional webhooks (Rust,
#               3232★ on the parent svix-webhooks repo)
#
# upstream: https://github.com/svix/svix-webhooks
#           (binary at server/svix-server/ in the workspace)
# author : Svix Inc. — also operators of the managed Svix service at
#          svix.com used by Hopin, Brex, Lithic, Clerk, and dozens of
#          other YC / pre-IPO fintechs.  The OSS version is feature-
#          identical to the managed offering minus the multi-tenant
#          control plane.
# license: MIT
#
# Source-direct completion: every subcommand + nested subcommand below
# is verbatim from server/svix-server/src/main.rs on the svix/svix-
# webhooks tip — clap `#[derive(Parser/Subcommand)]` macros (Args +
# Commands + JwtCommands + AsymmetricKeyCommands enums) parsed exactly
# as declared, with the top-level `--run-migrations` / `--wait-for`
# persistent flags + per-subcommand flags (Prune's `--older-than` /
# `--batch-size` / `--yes-i-know-what-im-doing`; Wipe's positional
# `org_id` + `--yes-i-know-what-im-doing`) preserved.
#
# Direct deps from server/svix-server/Cargo.toml (selected):
#   lapin                  "4.10.0"  ← canonical Rust AMQP 0.9.1 / RabbitMQ
#                                       client library (this axis) — by
#                                       Geoffroy Couprie (Geal) +
#                                       CleverCloud (the French cloud
#                                       provider); pure-Rust async-
#                                       first implementation of the
#                                       AMQP 0.9.1 wire protocol with
#                                       full support for channels,
#                                       exchanges (direct / topic /
#                                       fanout / headers / delayed-
#                                       message-x), queues (durable /
#                                       exclusive / auto-delete /
#                                       lazy / classic mirrored /
#                                       quorum), publisher confirms,
#                                       consumer prefetch / QoS,
#                                       publisher/consumer flow
#                                       control, transaction mode,
#                                       NACK + dead-letter exchange
#                                       routing, message expiration,
#                                       and the RabbitMQ extensions
#                                       (`exchange.bind`, sender-
#                                       selected distribution,
#                                       priority queues, single-active
#                                       consumer).  THE Rust answer
#                                       to "talk to RabbitMQ from a
#                                       Rust service."  Used by every
#                                       Rust-based AMQP consumer:
#                                       svix (the webhook delivery
#                                       service this completion is
#                                       for), vector.dev's AMQP sink,
#                                       chirpstack (LoRaWAN network
#                                       server), reacher.io
#                                       (email-existence checker),
#                                       densumesh/broccoli (Rust job
#                                       queue framework), joshstevens-
#                                       19/rindexer (EVM blockchain
#                                       indexer), rusty-celery (Celery
#                                       in Rust), svix-bridge (the
#                                       sister bridge daemon in this
#                                       same repo that forwards
#                                       webhooks between queues and
#                                       HTTP endpoints).  svix-server
#                                       uses lapin in src/queue/
#                                       rabbitmq.rs as one of the
#                                       optional queue backends
#                                       (alongside Redis Streams +
#                                       PostgreSQL-LISTEN/NOTIFY)
#                                       for the message-delivery
#                                       queue that fans webhook
#                                       attempts out to worker
#                                       processes — when the operator
#                                       configures `queue.type =
#                                       "rabbitmq"` in svix-server.json,
#                                       all `MessageTask` work items
#                                       flow through a lapin-managed
#                                       RabbitMQ channel rather than
#                                       Redis.
#   clap (with derive)               (CLI parser)
#   axum + axum-extra + aide         (HTTP server + OpenAPI generation
#                                      — `svix-server generate-openapi`
#                                      emits the same spec the managed
#                                      service publishes)
#   sea-orm + sqlx + bb8 + bb8-redis (Postgres ORM + Redis pool)
#   chacha20poly1305 + blake2 +      (symmetric AEAD for at-rest
#       ed25519-compact + ring         encryption + Ed25519 for
#                                      asymmetric webhook signatures
#                                      + BLAKE2 for HMAC variants)
#   figment + dotenvy + serde / yaml (multi-source config: TOML/JSON/
#                                      YAML files + env vars +
#                                      .env file)
#   opentelemetry + tracing-otel     (full OpenTelemetry tracing /
#                                      metrics / logs exporter)
#
# svix-server runs the webhook delivery infrastructure: applications
# register HTTP endpoints, the API accepts messages, the queue
# (lapin/RabbitMQ or Redis Streams) buffers attempts, and worker
# processes deliver to endpoints with retry-with-exponential-backoff
# + signature attachment + replay-window enforcement.  The CLI's
# subcommands cover the operational lifecycle: `migrate` runs schema
# migrations, `jwt generate` mints management tokens, `asymmetric-key
# generate` produces Ed25519 keypairs for signed webhooks, `wipe`
# destructively removes an organization's data (gated behind
# `--yes-i-know-what-im-doing`), `prune` garbage-collects old
# messages (cutoff must be ≥ 3 months in past), `generate-openapi`
# emits the API spec for client codegen, and `healthcheck <url>`
# verifies a running instance is responsive.
#
# ============================================================================
# === AXIS 190 OPENS — AMQP 0.9.1 / RabbitMQ client libraries ============
# === Rust=245 OPENS at slot 1/0/0 ========================================
# ============================================================================
# Axis position: Rust=245 OPENS Axis 190 at slot 1/0/0 — the first of the
# three lanes for the canonical AMQP 0.9.1 / RabbitMQ client trio.  The
# axis anchors on a single pure-host-language async client library for
# the AMQP 0.9.1 wire protocol (the version RabbitMQ implements; AMQP
# 1.0 is a separate incompatible protocol used by ActiveMQ / Azure
# Service Bus / Solace and has different canonical libs per language
# we're not covering here) with full channel / exchange / queue /
# publisher-confirms / consumer-QoS / dead-letter-routing surface:
#
#     Rust    : lapin                       by Geoffroy Couprie (Geal)
#                                              + CleverCloud (the
#                                              French cloud provider
#                                              where lapin grew out of
#                                              their internal RabbitMQ
#                                              tooling); pure-Rust
#                                              async-first AMQP 0.9.1
#                                              implementation.  Native
#                                              support for every
#                                              RabbitMQ extension
#                                              (exchange-to-exchange
#                                              binding, sender-selected
#                                              distribution, priority
#                                              queues, single-active
#                                              consumer, quorum queues,
#                                              streams).
#                 → svix-server (Svix Inc. — open-source webhooks
#                                 server with HMAC + Ed25519 signed
#                                 messages, retry-with-backoff queue
#                                 delivery, replay protection;
#                                 self-hosted version of the managed
#                                 Svix service; uses lapin in the
#                                 RabbitMQ queue backend; 3232★ MIT on
#                                 the parent svix-webhooks repo)
#                 _svix-server     [Rust=245 OPENS Axis 190, 1/0/0]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#
#     Go      : (next round — Go=245, slot 2/0/0)
#                Canonical Go AMQP client: github.com/rabbitmq/amqp091-
#                go (the rabbitmq-team-maintained fork of streadway/
#                amqp after the original maintainer Sean Treadway
#                stepped back in 2021).  Pure-Go AMQP 0.9.1 client
#                supporting the same RabbitMQ extension surface as
#                lapin.  THE Go answer to "talk to RabbitMQ from a Go
#                service."  Used by every Go microservice framework
#                with AMQP integration.  [TBD next-round consumer]
#
#     JS/Node : (Axis 190 CLOSES at TS-Node=245, slot 1/1/1)
#                Canonical JS AMQP client: `amqplib` by Michael Bridgen
#                (squaremo/amqplib; squaremo formerly RabbitMQ's
#                JavaScript-ecosystem lead).  Pure-JS AMQP 0.9.1 client
#                with both callback and Promise APIs; used by every
#                Node.js microservice that consumes/produces RabbitMQ
#                messages.  Alternative: `rascal` (onyxinsight/rascal)
#                — higher-level wrapper around amqplib that adds
#                opinionated retry / dead-letter / topic-naming
#                conventions for production deployments.  [TBD closer
#                consumer]
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=245     ← THIS FILE          (axis 190 OPENS, slot 1/0/0)
#   Go=245       ← next round         (axis 190 continues, slot 2/0/0)
#   TS-Node=245  ← round after        (axis 190 CLOSES at triple-245, 1/1/1)
# ============================================================================

_svix-server() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '--run-migrations[run database migrations before starting the HTTP server (idempotent — safe to leave on in production)]' \
        '--wait-for=[seconds to wait for a successful database connection before timing out at startup (useful for race-conditions during container orchestration startup)]:seconds:' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'jwt:JWT utilities (generate a management JWT for the admin API)'
                'asymmetric-key:asymmetric key utilities (generate an Ed25519 keypair for signed webhooks)'
                'migrate:run database migrations and exit'
                'revert-background-migration:revert a background migration by id'
                'wipe:destructively remove all data for a specific organization (irreversible; requires --yes-i-know-what-im-doing)'
                'prune:prune messages and their attempts older than a given date (cutoff must be ≥3 months in past; batched to avoid long-running transactions)'
                'generate-openapi:generate the OpenAPI JSON specification and exit (used for client SDK codegen)'
                'healthcheck:probe a running svix-server instance for liveness (returns non-zero on failure)'
                'help:print help for a subcommand'
            )
            _describe -t commands 'svix-server command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                jwt)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1: :->jwtcmds' \
                        '*::jwt-arg:->jwtargs' && ret=0
                    case $state in
                        jwtcmds)
                            _describe -t jwt-commands 'jwt subcommand' \
                                '(generate:generate a new management JWT (optional org_id positional; default org used if omitted))' && ret=0
                            ;;
                        jwtargs)
                            _arguments '1::organization id:' && ret=0
                            ;;
                    esac
                    ;;
                asymmetric-key)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1: :->akcmds' && ret=0
                    case $state in
                        akcmds)
                            _describe -t ak-commands 'asymmetric-key subcommand' \
                                '(generate:generate a new Ed25519 keypair for asymmetric webhook signing)' && ret=0
                            ;;
                    esac
                    ;;
                revert-background-migration)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1:background migration id:' && ret=0
                    ;;
                wipe)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--yes-i-know-what-im-doing[confirm that this destructive operation is irreversible]' \
                        '1:organization id (OrganizationId-format string):' && ret=0
                    ;;
                prune)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--older-than=[cutoff timestamp in RFC 3339 format (e.g. 2024-01-01T00:00:00Z); must be ≥3 months in past]:rfc3339:' \
                        '--batch-size=[number of rows to delete per batch (default 10000)]:n:' \
                        '--yes-i-know-what-im-doing[confirm that this destructive operation is irreversible]' && ret=0
                    ;;
                healthcheck)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1:server URL (e.g. http://localhost:8071):_urls' && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(jwt asymmetric-key migrate revert-background-migration wipe prune generate-openapi healthcheck)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_svix-server "$@"
