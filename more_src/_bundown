local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _bundown_cmds
_bundown_cmds=(
    'run:execute markdown file/directory/URL (default subcommand)'
    'sync:pack/unpack code blocks between markdown and directory'
    'upgrade:upgrade to the latest version of Bundown'
)

_arguments -C \
    '(-t --tag)'{-t+,--tag=}'[filter code blocks by tag]:tag:_default' \
    '(-p --print)'{-p,--print}'[pretty-print source during execution]' \
    '(- *)'{-v,--version}'[print version and exit]' \
    '(- *)'{-h,--help}'[display help menu and exit]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'bundown subcommand' _bundown_cmds && ret=0
        ;;
    args)
        case $words[1] in
            run)
                _arguments \
                    '(-t --tag)'{-t+,--tag=}'[filter blocks by tag]:tag:_default' \
                    '(-p --print)'{-p,--print}'[pretty-print source]' \
                    '1:markdown file/dir/URL:_files -g "*.md"' \
                    && ret=0
                ;;
            sync)
                _arguments \
                    '1:source (file.md or directory):_files' \
                    '2:destination (directory or file.md):_files' \
                    && ret=0
                ;;
            upgrade)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
