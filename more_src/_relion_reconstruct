#compdef relion_reconstruct
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: 3D reconstruction from 2D projection images with known orientations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input STAR file with projection images and orientations]:file:_files' \
  '--o=[name for output reconstruction]:file:_files' \
  '--sym=[symmetry group]:group' \
  '--maxres=[maximum resolution (A) to consider]:value' \
  '--pad=[padding factor]:value' \
  '--img=[optional image path prefix]:prefix' \
  '--subset=[subset of images (1: half1, 2: half2, other: all)]:value' \
  '--class=[consider only this class (-1: all)]:value' \
  '--angpix=[pixel size in the reconstruction]:value' \
  '--ctf[apply CTF correction]' \
  '--ctf_intact_first_peak[leave CTFs intact until first peak]' \
  '--ctf_phase_flipped[images have been phase flipped]' \
  '--only_flip_phases[do not correct CTF-amplitudes, only flip phases]' \
  '--ewald[correct for Ewald-sphere curvature]' \
  '--mask_diameter=[diameter (A) of mask for Ewald correction]:value' \
  '--width_mask_edge=[width (pixels) of soft edge on the mask]:value' \
  '--reverse_curvature[try curvature the other way around]' \
  '--newbox=[box size after Ewald sphere correction]:value' \
  '--sectors=[number of sectors for Ewald sphere correction]:value' \
  '--skip_mask[do not apply real space mask during Ewald correction]' \
  '--skip_weighting[do not apply weighting during Ewald correction]' \
  '--nr_helical_asu=[number of helical asymmetrical units]:value' \
  '--helical_rise=[helical rise (A)]:value' \
  '--helical_twist=[helical twist (degrees)]:value' \
  '--subtract=[subtract projections of this map from images]:file:_files' \
  '--NN[use nearest-neighbour interpolation before gridding]' \
  '--blob_r=[radius of blob for gridding interpolation]:value' \
  '--blob_m=[order of blob for gridding interpolation]:value' \
  '--blob_a=[alpha-value of blob for gridding interpolation]:value' \
  '--iter=[number of gridding-correction iterations]:value' \
  '--refdim=[dimension of the reconstruction (2 or 3)]:value:(2 3)' \
  '--angular_error=[stddev (degrees) of random deviations to Euler angles]:value' \
  '--shift_error=[stddev (A) of random deviations to translations]:value' \
  '--fom_weighting[weight particles according to figure-of-merit]' \
  '--fsc=[FSC-curve for regularized reconstruction]:file:_files' \
  '--3d_rot[perform 3D rotations instead of backprojections]' \
  '--reconstruct_ctf=[reconstruct from 2D CTF-images with this size]:value' \
  '--ctf2[reconstruct CTF^2 and then take the sqrt]' \
  '--external_reconstruct[write out BP denominator/numerator for external program]' \
  '--verb=[verbosity]:value' \
  '*:file:_files' && ret=0

return ret
