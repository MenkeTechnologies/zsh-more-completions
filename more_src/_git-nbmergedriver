#compdef git-nbmergedriver
# Documentation: https://nbdime.readthedocs.io/en/latest/vcs.html
# git-nbmergedriver - git merge driver entry point for Jupyter notebooks (nbdime)

local ret=1
local -a subcmds
subcmds=(
  'config:register/unregister the nbdime merge driver with git'
  'merge:run the merge (invoked by git)'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'git-nbmergedriver command' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      config)
        _arguments \
          '--enable[register the merge driver]' \
          '--disable[unregister the merge driver]' \
          '--global[apply at user level]' \
          '--system[apply at system level]' && ret=0
        ;;
      merge)
        _arguments '*:file:_files -g "*.ipynb"' && ret=0
        ;;
    esac
    ;;
esac

return ret
