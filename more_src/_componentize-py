#compdef componentize-py

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)'{-V,--version}'[Show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcmds
    subcmds=(
      'componentize:Create a WebAssembly component from a Python module'
      'bindings:Generate Python bindings from a WIT definition'
    )
    _describe -t commands 'componentize-py subcommand' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      componentize)
        _arguments -s -S \
          '--wit-path[Path to WIT directory]:path:_directories' \
          '--world[World to target]:world:' \
          '(-o --output)'{-o,--output}'[Output file]:file:_files' \
          '--python-path[Additional Python path]:path:_directories' \
          '--stub-wasi[Stub WASI imports]' \
          '--help[Show help]' \
          '1:module name:' && ret=0
        ;;
      bindings)
        _arguments -s -S \
          '--wit-path[Path to WIT directory]:path:_directories' \
          '--world[World to target]:world:' \
          '--help[Show help]' \
          '1:output directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
