#compdef scil_connectivity_compute_matrices
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_connectivity_compute_matrices.html
# Compute connectivity matrices from an HDF5 container

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--volume=[volume-weighted matrix output (mm3)]:file:_files' \
  '--streamline_count=[streamline count-weighted matrix]:file:_files' \
  '--length=[length-weighted matrix (mm)]:file:_files' \
  '--similarity[averaged bundle density maps folder and similarity matrix]:folder:_files -/:file:_files' \
  '--metrics[metric file and weighted matrix output]:metric:_files -g "*.nii.gz":file:_files' \
  '--lesion_load[binary lesion mask and output directory]:mask:_files:dir:_files -/' \
  '--include_dps=[save data_per_streamline matrices to directory]:dir:_files -/' \
  '--min_lesion_vol=[minimum lesion volume threshold in mm3]:vol' \
  '--density_weighting[apply density weighting to metric matrices]' \
  '--no_self_connection[remove diagonal elements from matrices]' \
  '--force_labels_list=[labels list file for missing atlas labels]:file:_files -g "*.txt"' \
  '--processes=[number of sub-processes]:n' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[force overwrite output files]' \
  '1:in_hdf5:_files -g "*.h5"' \
  '2:in_labels:_files -g "*.nii *.nii.gz"' && ret=0

return ret
