#compdef aks-engine
# _aks-engine — Azure AKS Engine self-managed AKS (Microsoft Azure, Go); deploy/upgrade self-managed AKS-like clusters
# upstream: https://github.com/Azure/aks-engine

_aks-engine() {
    local -a sub=(
        'addpool:add a node pool'
        'completion:print shell completion'
        'deploy:deploy a cluster (legacy)'
        'generate:generate ARM templates'
        'get-logs:get cluster logs'
        'get-skus:list valid VM sizes'
        'get-versions:list valid Kubernetes versions'
        'help:show help'
        'orchestrators:list valid orchestrators'
        'rotate-certs:rotate cluster certs'
        'scale:scale a node pool'
        'update:update a cluster'
        'upgrade:upgrade a cluster'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--debug[debug]' \
        '--show-default-models[show default models]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aks-engine subcommand' sub ;;
        args)
            case $words[1] in
                deploy|generate) _arguments \
                    '--api-model+[api model file]:file:_files' \
                    '-m+[api model file]:file:_files' \
                    '--azure-env+[Azure env]:env:(AzurePublicCloud AzureChinaCloud AzureGermanCloud AzureUSGovernmentCloud)' \
                    '--client-id+[client id]:str:' \
                    '--client-secret+[client secret]:str:' \
                    '--dns-prefix+[dns prefix]:str:' \
                    '--force-overwrite[force overwrite]' \
                    '-f[force overwrite]' \
                    '--location+[location]:loc:' \
                    '--resource-group+[resource group]:rg:' \
                    '-g+[resource group]:rg:' \
                    '--ssh-key+[ssh key path]:file:_files' \
                    '--subscription-id+[subscription id]:str:' \
                    '-s+[subscription id]:str:' \
                    '--output-directory+[output dir]:dir:_files -/' \
                    '-o+[output dir]:dir:_files -/' ;;
                scale) _arguments \
                    '--api-model+[api model file]:file:_files' \
                    '-m+[api model file]:file:_files' \
                    '--node-pool+[node pool]:pool:' \
                    '--new-node-count+[new node count]:n:' \
                    '--resource-group+[resource group]:rg:' \
                    '-g+[resource group]:rg:' \
                    '--apiserver+[apiserver fqdn]:fqdn:' \
                    '--master-fqdn+[master fqdn]:fqdn:' \
                    '--subscription-id+[subscription id]:str:' ;;
                upgrade|update) _arguments \
                    '--api-model+[api model file]:file:_files' \
                    '--upgrade-version+[k8s version]:ver:' \
                    '--resource-group+[resource group]:rg:' \
                    '--subscription-id+[subscription id]:str:' \
                    '--vm-timeout+[vm timeout minutes]:n:' \
                    '--control-plane-only[control plane only]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_aks-engine "$@"
