#compdef arkade

# Zsh completion for arkade - Kubernetes marketplace for downloading tools and installing helm charts

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'get:download a CLI tool'
  'install:install a Kubernetes app with helm or YAML'
  'info:show app info'
  'update:update arkade'
  'completion:generate shell completion'
  'system:system-level commands'
  'oci:OCI image related commands'
  'chart:chart related commands'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'arkade command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (get)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--version=[download a specific version]:version:' \
          '--arch=[target architecture]:arch:(amd64 arm64 armhf)' \
          '--os=[target operating system]:os:(linux darwin windows)' \
          '--quiet[suppress output]' \
          '--stash[stash the binary in a local directory]' \
          '--progress[display download progress]' \
          ':tool name:' && ret=0
        ;;
      (install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]:namespace:' \
          '*--set[set helm chart values]:key=value:' \
          '--wait[wait for resources to be ready]' \
          '--kubeconfig[path to kubeconfig file]:kubeconfig:_files' \
          '--node-arch[target node architecture]:arch:(amd64 arm64)' \
          ':app name:' && ret=0
        ;;
      (info)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':app name:' && ret=0
        ;;
      (completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':shell:(bash zsh fish powershell)' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:arguments:' && ret=0
        ;;
    esac
    ;;
esac

return ret
