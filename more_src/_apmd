#compdef apmd
# Documentation: man apmd(8)
# Source: netbsd/src usr.sbin/apmd — Advanced Power Management daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[ignore BIOS suspend requests on line power]' \
    '-d[debug mode, stay in foreground]' \
    '-f+[alternate APM device file]:devname:_files' \
    '-l[automatic suspend on low battery]' \
    '-m+[socket file mode (default 0660)]:sockmode:_default' \
    '-o+[socket owner:group (default 0:0)]:sockowner\:sockgroup:_default' \
    '-q[disable speaker announcements]' \
    '-S+[alternate communication socket name]:sockname:_files' \
    '-s[report battery statistics and exit]' \
    '-t+[polling interval in seconds (default 600)]:rate:_default' \
    '-v[periodically log power status]' \
    && ret=0

return ret
