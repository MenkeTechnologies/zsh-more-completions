#compdef lsload
# Documentation: https://www.ibm.com/docs/en/spectrum-lsf/10.1.0?topic=reference-command
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# lsload: show LSF host load (dynamic)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-l[long format]' \
  '-w[wide format]' \
  '-N[show batch and load index names]' \
  '-E[show normalized status]' \
  '-R[resource req]:expr:' \
  '-c[cluster]:name:' \
  '-I[load index name]:name:' \
  '-n[number of hosts]:n:' \
  '*:host:_hosts' && ret=0
return ret
