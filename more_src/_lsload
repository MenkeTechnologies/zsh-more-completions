#compdef lsload
# Documentation: https://man.archlinux.org/search?q=lsload
# Reference accessed: 2026-05-16

# lsload: show LSF host load (dynamic)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-l[long format]' \
  '-w[wide format]' \
  '-N[show batch and load index names]' \
  '-E[show normalized status]' \
  '-R[resource req]:expr:' \
  '-c[cluster]:name:' \
  '-I[load index name]:name:' \
  '-n[number of hosts]:n:' \
  '*:host:_hosts' && ret=0
return ret
