#compdef dipy_correct_motion
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_correct_motion.html
# DIPY: between-volumes motion correction

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--b0_threshold=[threshold used to find b0 volumes]:thr' \
  '--bvecs_tol=[threshold to check norm(bvec)=1]:tol' \
  '--level_iters=[iterations at each level of the Gaussian pyramid]:iters' \
  '--out_dir=[directory to save transformed image and affine matrix]:dir:_files -/' \
  '--out_moved=[name for the saved transformed image]:file:_files' \
  '--out_affine=[name for the saved affine matrix]:file:_files' \
  '*:input (volumes bvalues bvectors):_files' && ret=0

return ret
