#compdef rtwizard
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=rtwizard&sektion=1
# BRL-CAD image-generation wizard combining color, ghost and line renderings

local ret=1

_arguments -s -S \
  '(-i --input)'{-i,--input}'[geometry database to raytrace]:database:_files -g "*.g"' \
  '(-o --output)'{-o,--output}'[output image file]:output:_files' \
  '(-d --fbserv-device)'{-d,--fbserv-device}'[framebuffer device for fbserv]:device' \
  '(-p --fbserv-port)'{-p,--fbserv-port}'[framebuffer port for fbserv]:port' \
  '--gui[launch graphical interface]' \
  '--no-gui[force command-line mode]' \
  '(-a --azimuth)'{-a,--azimuth}'[azimuth viewing angle in degrees]:azimuth' \
  '(-e --elevation)'{-e,--elevation}'[elevation viewing angle in degrees]:elevation' \
  '--twist[twist viewing angle in degrees]:twist' \
  '(-P --perspective)'{-P,--perspective}'[perspective angle in degrees]:perspective' \
  '(-z --zoom)'{-z,--zoom}'[magnification factor]:zoom' \
  '--center[view center X Y Z]:center' \
  '(-c --color-objects)'{-c,--color-objects}'[objects to render in full color]:objects' \
  '(-C --background-color)'{-C,--background-color}'[background color]:color' \
  '(-g --ghost-objects)'{-g,--ghost-objects}'[objects rendered with ghosting]:objects' \
  '(-G --ghosting-intensity)'{-G,--ghosting-intensity}'[ghosted object visibility level]:intensity' \
  '(-l --line-objects)'{-l,--line-objects}'[objects rendered as lines via rtedge]:objects' \
  '--line-color[edge line color]:color' \
  '--non-line-color[rtedge non-line color]:color' \
  '(-n --height)'{-n,--height}'[output image height in pixels]:height' \
  '(-O --occlusion)'{-O,--occlusion}'[occlusion mode for rtedge lines]:mode' \
  '(-s --size)'{-s,--size}'[image width and height in pixels]:size' \
  '(-t --type)'{-t,--type}'[type of image to render]:type' \
  '(-w --width)'{-w,--width}'[output image width in pixels]:width' && ret=0

return ret
