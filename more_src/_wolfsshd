#compdef wolfsshd

# WolfSSH daemon: lightweight SSH server
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-D[do not detach (foreground)]' \
  '-d[debug output]' \
  '-f[config file]:file:_files' \
  '-h[host key file]:file:_files' \
  '-p[port]:port:' \
  '-E[error log file]:file:_files' \
  '-t[test config and exit]' \
  '*::wolfsshd args:_files' && ret=0
return ret
