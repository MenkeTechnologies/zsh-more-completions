#compdef wolfsshd

# wolfsshd: SSH server daemon from wolfSSL
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '-V[show version]' \
  '-d[debug, do not daemonize]' \
  '-D[run in foreground]' \
  '-p[port]:port:' \
  '-f[config file]:file:_files' \
  '-h[host key file]:file:_files' \
  '-i[run as inetd]' \
  '-t[test config and exit]' \
  '-T[test config and dump]' \
  '-q[quiet]' \
  '*::wolfsshd args:_files' && ret=0
return ret
