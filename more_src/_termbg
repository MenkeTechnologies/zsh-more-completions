#compdef termbg
# Documentation: https://man.archlinux.org/search?q=termbg
# Reference accessed: 2026-05-16

# Zsh completion for termbg terminal background detection (dalance/termbg)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' && ret=0

return ret
