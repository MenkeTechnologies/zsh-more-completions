#compdef license-plist

# Zsh completion for license-plist iOS dependency licenses (mono0926/LicensePlist)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--cartfile-path[Carthage Cartfile]:file:_files' \
  '--mintfile-path[Mint manifest]:file:_files' \
  '--nestfile-path[Nest manifest]:file:_files' \
  '--pods-path[CocoaPods directory]:dir:_directories' \
  '*--package-path[Swift package dirs]:dir:_directories' \
  '*--swift-package-paths[extra Swift package paths]:dir:_directories' \
  '--swift-package-sources-path[Swift sources root]:dir:_directories' \
  '--xcworkspace-path[Xcode workspace]:file:_files -g "*.xcworkspace"' \
  '--xcodeproj-path[Xcode project]:file:_files -g "*.xcodeproj"' \
  '--output-path[license output folder]:dir:_directories' \
  '--github-token[GitHub API token]:token' \
  '--config-path[license_plist.yml]:file:_files' \
  '--prefix[acknowledgements prefix]:text' \
  '--html-path[HTML output]:file:_files' \
  '--markdown-path[Markdown output]:file:_files' \
  '--csv-path[CSV output]:file:_files' \
  '*--license-file-names[license file basenames]:name' \
  '--force[overwrite outputs]' \
  '--no-force[skip overwriting]' \
  '--add-version-numbers[embed versions]' \
  '--no-add-version-numbers' \
  '--add-sources[embed URLs]' \
  '--no-add-sources' \
  '--suppress-opening-directory[do not open Finder]' \
  '--no-suppress-opening-directory' \
  '--single-page[one HTML page]' \
  '--no-single-page' \
  '--fail-if-missing-license[error when license missing]' \
  '--no-fail-if-missing-license' \
  '--sandbox-mode[automation-friendly defaults]' \
  '--no-sandbox-mode' \
  '1:: :_message "optional: add-acknowledgements-copy-script"' \
  '*::args:{ _files }' && ret=0

return ret
