#compdef keystone-status
# Documentation: https://docs.openstack.org/keystone/latest/cli/keystone-status.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# keystone-status: OpenStack Keystone upgrade readiness checks.
# Corrected from prior file: real interface is only "keystone-status
# upgrade check"; removed fabricated logging/RPC oslo flags that this
# tool does not document.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'upgrade:upgrade-related checks'
)
local -a upgrade_cmds=(
  'check:perform a release-specific readiness check before upgrading'
)
_arguments -C \
  "(- *)"{-h,--help}"[show help]" \
  "--config-file=[config file]:file:_files" \
  "--config-dir=[config dir]:dir:_files -/" \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'keystone-status command' commands && ret=0 ;;
  args)
    case $line[1] in
      (upgrade) _describe -t upgrade_cmds 'upgrade subcommand' upgrade_cmds && ret=0 ;;
    esac ;;
esac
return ret
