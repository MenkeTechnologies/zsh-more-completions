#compdef clashi
# Documentation: https://clash-lang.readthedocs.io/en/stable/developing-hardware/flags.html
# Clash interactive GHCi-based REPL (Haskell to VHDL/Verilog/SystemVerilog)

local ret=1

_arguments -s -S \
  '--vhdl[generate VHDL 1993 source code]' \
  '--verilog[generate Verilog 2001 source code]' \
  '--systemverilog[generate SystemVerilog 2012 source code]' \
  '-fclash-hdldir[specify directory generated HDL is written into]:dir:_files -/' \
  '-fclash-hdlsyn=[specify HDL synthesis tool]:syn:(Vivado Quartus Other)' \
  '-fclash-component-prefix=[prefix generated HDL component names]:prefix:' \
  '-fclash-edalize[generate metadata for Edalize integration]' \
  '-fclash-intwidth=[set bit width for Int/Word/Integer]:width:(32 64)' \
  '-fclash-float-support[enable hardware floating point support]' \
  '-fclash-spec-limit=[change function specialization limit]:n:' \
  '-fclash-inline-limit=[limit function inlining occurrences]:n:' \
  '-fclash-inline-function-limit=[set function size inline threshold]:n:' \
  '-fclash-inline-constant-limit=[set constant size inline threshold]:n:' \
  '-fclash-evaluator-fuel-limit=[set unfolding fuel threshold]:n:' \
  '-fclash-compile-ultra[aggressively run the normalizer]' \
  '-fclash-no-cache[disable reuse of previously generated HDL]' \
  '-fclash-clear[remove HDL directories before writing]' \
  '-fclash-debug=[set compiler debugging mode]:mode:' \
  '-fclash-debug-invariants[check invariants while debugging]' \
  '-fclash-no-prim-warn[disable warnAlways primitive warnings]' \
  '-fclash-error-extra[print additional info with compiler errors]' \
  '-fclash-aggressive-x-optimization[remove undefined case branches]' \
  '-main-is[specify the synthesis target entity]:entity:' \
  '*:Haskell file:_files -g "*.hs"' && ret=0

return ret
