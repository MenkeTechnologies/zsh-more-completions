#compdef smartcat

# Zsh completion for smartcat (AI-powered CLI tool)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[path to configuration file]:file:_files' \
  '(-p --prompt)'{-p,--prompt}'[use a named prompt from config]:prompt name' \
  '(-e --extend-conversation)'{-e,--extend-conversation}'[continue the last conversation]' \
  '(-r --repeat)'{-r,--repeat}'[repeat the last answer]' \
  '(-s --system-message)'{-s,--system-message}'[set system message]:message' \
  '(-m --model)'{-m,--model}'[model to use]:model' \
  '(-t --temperature)'{-t,--temperature}'[sampling temperature]:temperature' \
  '--api[API provider]:provider:(openai anthropic mistral ollama)' \
  '--api-url[custom API URL]:url' \
  '--input-file[read input from file]:file:_files' \
  '*:prompt text'
