#compdef smartcat
# Documentation: https://github.com/efugier/smartcat
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for smartcat (AI-powered CLI tool)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-e --extend-conversation)'{-e,--extend-conversation}'[extend previous conversation]' \
  '(-r --repeat-input)'{-r,--repeat-input}'[repeat input before output]' \
  '--api=[override API selection]:provider:(ollama anthropic groq mistral openai)' \
  '(-m --model)'{-m+,--model=}'[override model selection]:model' \
  '(-t --temperature)'{-t+,--temperature=}'[adjust response randomness]:temperature' \
  '(-l --char-limit)'{-l+,--char-limit=}'[set character limit with approval prompt]:limit' \
  '*'{-c+,--context=}'[include files via glob pattern]:context:_files' \
  '1:input or template ref:' \
  '2:input if template ref:'
