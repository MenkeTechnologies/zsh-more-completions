#compdef grade2
# Documentation: https://gphl.gitlab.io/grade2_docs/usage.html
# Grade2 - generate geometric restraint dictionaries for ligands

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message with all command-line arguments]' \
  '(-checkdeps --checkdeps)'{-checkdeps,--checkdeps}'[verify external tools are accessible and functional]' \
  '(-V --versions)'{-V,--versions}'[show version numbers for program and libraries]' \
  '(-P --PDB_ligand)'{-P,--PDB_ligand}'[download from wwPDB Chemical Component Dictionary]:PDB id' \
  '(-i --in)'{-i,--in}'[read molecule from file]:input file:_files' \
  '(-L --lookup)'{-L,--lookup}'[lookup molecule via external database script]:id' \
  '(-r --resname)'{-r,--resname}'[set output PDB residue name (3-letter code)]:resname' \
  '(-o --out)'{-o,--out}'[set output filename prefix]:prefix' \
  '-ocif[specify exact CIF restraint dictionary filename]:cif:_files' \
  '--ocif[specify exact CIF restraint dictionary filename]:cif:_files' \
  '(-f --force_overwrite)'{-f,--force_overwrite}'[overwrite existing files without prompting]' \
  '(-j --just_cif)'{-j,--just_cif}'[output only CIF dictionary, skip coordinate/diagram files]' \
  '(-s --shelx)'{-s,--shelx}'[produce SHELX .dfix format restraint files]' \
  '--ccd[generate PDB Chemical Component Dictionary CIF file]::ccd cif:_files' \
  '(-N --no_charging)'{-N,--no_charging}'[disable standard pH7 charging scheme]' \
  '(-e --ecloud)'{-e,--ecloud}'[use electron-cloud distances for X-H bonds]' \
  '(-c --chirality_both)'{-c,--chirality_both}'[set all chiral restraints to both]' \
  '--chiral_non_carbon[add chiral restraints for N, P, S atoms]' \
  '(-b --big_planes)'{-b,--big_planes}'[create large fused planes emphasizing ring planarity]' \
  '(-4 --4_atom_planes)'{-4,--4_atom_planes}'[use separate 4-atom planes instead of single ring planes]' \
  '--eh99_sigma_correction[scale non-hydrogen bond/angle sigmas to match EH99]' \
  '(-n --name)'{-n,--name}'[set human-readable ligand name]:name' \
  '--systematic[specify IUPAC systematic name]:iupac name' \
  '--pubchem_names[lookup ligand names from PubChem database]' \
  '--group[set CCP4 _chem_comp.group value]:group' \
  '(-d --database_id)'{-d,--database_id}'[add corporate/database identifiers]:id' \
  '(-X --no_extra)'{-X,--no_extra}'[omit Grade2-specific extra CIF items]' \
  '--itype[specify input file format]:format:(cif sdf mol mol2 smi)' \
  '--rcsb[download from RCSB before PDBeChem]' \
  '(-a --antecedent)'{-a,--antecedent}'[base atom IDs on related molecule]:cif:_files' \
  '(-ad --antecedent_disregard_element)'{-ad,--antecedent_disregard_element}'[match atoms ignoring element]:cif:_files' \
  '(-R --rdkit_canonical_atom_ids)'{-R,--rdkit_canonical_atom_ids}'[use RDKit canonical SMILES atom order]' \
  '--inchi_canonical_atom_ids[use InChI-canonical atom IDs]' \
  '--no_aa_labels[disable automatic amino acid atom ID recognition]' \
  '--aa_loose[enable atom ID setting for exotic amino acids]' \
  '--diagram_stereo_label[add stereochemistry labels to 2D diagrams]' \
  '--debug[enable debug-level terminal output]' \
  '*:molecule or SMILES:_files' && ret=0

return ret
