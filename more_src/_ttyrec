#compdef ttyrec
# Documentation: https://manpages.debian.org/bookworm/ttyrec/ttyrec.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm ttyrec(1) manpage.
# Removed from prior file: bogus man.archlinux.org search URL;
# mischaracterized -u (it invokes uudecode on uuencoded data, not
# "silence detection / auto-speed-up").

# ttyrec: terminal session recorder
local curcontext="$curcontext" ret=1
_arguments -C \
  '-a[append to output file]' \
  '-u[auto-invoke uudecode on uuencoded data]' \
  '-e+[run command on startup]:command:_command_names -e' \
  '*:output file (default ttyrecord):_files' && ret=0
return ret
