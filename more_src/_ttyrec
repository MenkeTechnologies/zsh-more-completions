#compdef ttyrec
# Documentation: https://man.archlinux.org/search?q=ttyrec
# Reference accessed: 2026-05-16

# Zsh completion for ttyrec - terminal recorder

_arguments -s -S \
  '-a[append to output file]' \
  '-u[detect silence and auto-speed-up]' \
  '-e+[run command]:command:_command_names -e' \
  '*:output file:_files'
