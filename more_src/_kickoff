#compdef kickoff
# Documentation: https://github.com/j0ru/kickoff/blob/main/src/main.rs
# Reference accessed: 2026-05-19
# Verified: upstream source (clap) at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '(-p --prompt)'{-p,--prompt}'+[set custom prompt, overwrites config]:prompt:' \
  '--from-stdin[read list from stdin instead of PATH]' \
  '--from-path[read list from PATH (default unless stdin set)]' \
  '*--from-file=[read list from file]:file:_files' \
  '--stdout[output selection to stdout instead of executing it]' \
  '--history=[custom history file]:file:_files' && ret=0

return ret
