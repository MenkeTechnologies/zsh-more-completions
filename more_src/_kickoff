#compdef kickoff

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--from-path[only show executables from PATH]' \
  '--from-stdin[read entries from stdin]' \
  '--prompt+[set prompt text]:prompt:' \
  '--font+[set font name]:font:' \
  '--font-size+[set font size]:size:' && ret=0

return ret
