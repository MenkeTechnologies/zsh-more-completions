#compdef antsMotionCorr
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsMotionCorr.cxx — time-series motion correction (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --dimensionality)'{-d+,--dimensionality=}'[image dimensionality]:n:(2 3)' \
    '(-n --n-images)'{-n+,--n-images=}'[number of images]:n:_default' \
    '*'{-m+,--metric=}'[similarity metric per stage]:spec:_default' \
    '(-u --useFixedReferenceImage)'{-u+,--useFixedReferenceImage=}'[use fixed reference image]:n:(0 1)' \
    '(-e --useScalesEstimator)'{-e+,--useScalesEstimator=}'[use scales estimator]:n:(0 1)' \
    '*'{-t+,--transform=}'[transform type spec]:spec:_default' \
    '*'{-i+,--iterations=}'[per-stage iterations]:spec:_default' \
    '*'{-s+,--smoothingSigmas=}'[per-stage smoothing sigmas]:spec:_default' \
    '*'{-f+,--shrinkFactors=}'[per-stage shrink factors]:spec:_default' \
    '(-o --output)'{-o+,--output=}'[output prefix]:spec:_default' \
    '(-a --average-image)'{-a+,--average-image=}'[output average image]:file:_files' \
    '(-w --write-displacement)'{-w+,--write-displacement=}'[write displacement (0/1)]:n:(0 1)' \
    '--use-histogram-matching=[use histogram matching]:n:(0 1)' \
    '--random-seed=[random seed]:n:_default' \
    '(-p --interpolation)'{-p+,--interpolation=}'[interpolation]:method:(Linear NearestNeighbor MultiLabel Gaussian BSpline CosineWindowedSinc WelchWindowedSinc HammingWindowedSinc LanczosWindowedSinc)' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
