#compdef amrecover
# Documentation: https://man.archlinux.org/search?q=amrecover
# Reference accessed: 2026-05-16

_arguments -s \
  '-C+[Amanda config]:config:' \
  '-s+[index server]:host:_hosts' \
  '-t+[tape server]:host:_hosts' \
  '-d+[tape device]:device:' \
  '-h+[hostname]:host:_hosts' \
  '*-o+[config override]:option:'
