#compdef plumed-pdbrenumber
# Documentation: https://www.plumed.org/doc-v2.9/user-doc/html/pdbrenumber.html
# PLUMED pdbrenumber: modify atom serial numbers in a PDB file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--ipdb=[name of the input PDB file]:file:_files' \
  '--opdb=[name of the output PDB file]:file:_files' \
  '--firstatomnumber=[serial number of the first atom of the output file]:number' \
  '--atomnumbers=[desired serial numbers of the atoms via a separate list]:file:_files' && ret=0

return ret
