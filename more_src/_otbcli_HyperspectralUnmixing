#compdef otbcli_HyperspectralUnmixing
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_HyperspectralUnmixing.html
# Orfeo ToolBox: estimate abundance maps from a hyperspectral image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[hyperspectral data cube input]:image:_files' \
  '-out[output abundance map]:output:_files' \
  '-ie[endmembers image to use for unmixing]:image:_files' \
  '-ua[algorithm to use for unmixing]:algo:(ucls isra mdmdnmf)' \
  '*::arg:_files' && ret=0

return ret
