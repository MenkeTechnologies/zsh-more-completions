#compdef ergo ergochat oragono
# _ergo — Ergo modern IRC server in Go (ergochat/ergo)
# upstream: https://github.com/ergochat/ergo
# Subcommands & flags from ergo.go (docopt).

_ergo() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--conf=[configuration file]:file:_files -g "*.(yml|yaml)"' \
        '--quiet[do not show startup/shutdown lines]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'initdb:initialize the database'
                'upgradedb:upgrade the database schema'
                'importdb:import a JSON database dump'
                'genpasswd:generate a bcrypt password hash'
                'mkcerts:generate self-signed TLS certs'
                'defaultconfig:print the default config to stdout'
                'gentoken:generate a random hex token'
                'run:run the IRC server'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                importdb) _arguments ':database JSON:_files -g "*.json"' ;;
                run)      _arguments '--smoke[exit after self-checks (smoke test)]' ;;
            esac
            ;;
    esac
}

_ergo "$@"
