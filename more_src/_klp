#compdef klp
# _klp — Kool Logfmt Parser (dloss/klp)
# upstream: https://github.com/dloss/klp
# Flags from klp.py (argparse).

_klp() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '--help-time[show extra help on time selectors]'
        '--help-python[show extra help on the Python expression language]'
        '--input-format=[input format]:format:(logfmt jsonl json csv tsv tap line clf combined unix sqlite syslog rfc3164 rfc5424 data)'
        '--input-encoding=[input encoding]:encoding:'
        '--input-delimiter=[input field delimiter (CSV/TSV)]:char:'
        '--input-quoting=[input quoting style (CSV)]:style:(minimal all none nonnumeric)'
        '--input-tablename=[table name (SQLite input)]:name:'
        '*--input-exec=[append the lines of a shell command to the input stream]:cmd:'
        '(-j --jsonl-input)'{-j,--jsonl-input}'[input is JSON Lines]'
        '--logical-lines[treat multi-line records via continuation indent]'
        '*--keys=[output only these keys (comma-separated)]:keys:'
        '*--keys-not=[hide these keys (comma-separated)]:keys:'
        '--common[show only the keys common to all records]'
        '*--grep=[only records where key/value matches pattern]:pat:'
        '*--grep-not=[exclude records matching pattern]:pat:'
        '*--grep-builtin=[built-in greps (key/value patterns)]:name:'
        '*--grep-builtin-not=[built-in negated greps]:name:'
        '--ignore-case[case-insensitive --grep/--where]'
        '--where=[Python expression to filter records]:expr:'
        '*--loglevels=[only include these log levels (comma-separated)]:levels:'
        '*--loglevels-not=[exclude these log levels]:levels:'
        '--loglevel-key=[name of the log-level key]:key:'
        '--from=[show only records on or after this timestamp]:ts:'
        '--to=[show only records before this timestamp]:ts:'
        '--since=[show only records within this duration of now]:duration:'
        '--until=[show only records older than this duration]:duration:'
        '--timespan=[show records within this duration window]:duration:'
        '--duration=[exit after processing this much real time]:duration:'
        '--ts-key=[timestamp key name]:key:'
        '--ts-format=[timestamp format (strptime / iso / unix)]:fmt:'
        '--utc[interpret bare timestamps as UTC]'
        '--localtime[render timestamps in local time]'
        '--output-format=[output format]:format:(default jsonl json csv tsv logfmt sqlite tabular extract template)'
        '--output-file=[write output to this file]:file:_files'
        '--output-template=[Python template for each output record]:tpl:'
        '--output-delimiter=[output field delimiter]:char:'
        '--output-quoting=[output quoting style]:style:(minimal all none nonnumeric)'
        '--output-sep=[key/value separator in default output]:sep:'
        '--output-event-sep=[separator between records]:sep:'
        '--output-tablename=[table name (SQLite output)]:name:'
        '--output-eval=[Python expression evaluated per record]:expr:'
        '--theme=[color theme name]:name:'
        '--color=[when to colorize]:when:(auto always never)'
        '--no-color[disable color (alias for --color=never)]'
        '--header=[prepend a header line]:line:'
        '--footer=[append a footer line]:line:'
        '--no-header[omit the auto-generated header]'
        '--indent[indent multi-line values]'
        '--no-indent[never indent values]'
        '--max-events=[stop after N records]:n:'
        '--max-block-lines=[max lines per record block]:n:'
        '--num-blocks=[stop after N record blocks]:n:'
        '--mark-gaps=[mark time gaps larger than this]:duration:'
        '--new[only show records newer than the last run]'
        '--start-with=[start the first event with the matching key/value]:expr:'
        '--start-after=[start the first event after the matching key/value]:expr:'
        '--stop-with=[stop on / including this matching record]:expr:'
        '--stop-before=[stop before the matching record]:expr:'
        '(-C --context)'{-C+,--context=}'[show N records of context]:n:'
        '(-A --after-context)'{-A+,--after-context=}'[show N records of trailing context]:n:'
        '(-B --before-context)'{-B+,--before-context=}'[show N records of leading context]:n:'
        '--stats[append per-key statistics]'
        '--stats-only[only print the statistics]'
        '--each-key[per-key analysis]'
        '--parallel=[parse with N parallel workers]:n:'
        '--fuse=[merge adjacent identical records within this gap]:duration:'
        '--errors=[error handling]:mode:(ignore warn fail)'
        '--debug[print parsing diagnostics]'
        '--debug-eval[print --output-eval / --where diagnostics]'
        '--debug-where[print --where diagnostics]'
        '--selftest[run the built-in self-test suite]'
        '--show-config[print the resolved configuration and exit]'
        '--ignore-config[do not read any klp config file]'
        '--ignore-mtime[do not record/honor input mtime markers]'
        '--no-plain[disable raw passthrough of unknown formats]'
        '--no-wrap[disable automatic line wrapping]'
        '--no-unicode[disable Unicode box characters]'
        '--unicode[force Unicode box characters]'
        '--plain[force raw passthrough output]'
        '*--alias=[define a config alias (name=cmdline)]:alias:'
        '*--keymap=[rename input keys]:from=to:'
        '*--levelmap=[remap log-level values]:from=to:'
        '*--normalize-patterns=[regex pattern set for --normalize]:patterns:'
        '--normalize[apply built-in value normalization]'
        '--normalize-level[also normalize the log-level value]'
        '--extract=[extract structured data from a key with a regex]:re:'
        '--extract-group=[regex capture group for --extract]:n:'
        '*--skip=[skip the first N records]:n:'
        '*:input file:_files'
    )
    _arguments -s $args
}

_klp "$@"
