#compdef dwg2dwg
# Documentation: https://qcad.org/en/qcad-command-line-tools
# QCAD: convert between DWG/DXF versions

local ret=1

_arguments -s -S \
  '(-f -force)'{-f,-force}'[overwrite existing output]' \
  '(-o -outfile)'{-o+,-outfile=}'[output file]:outfile:_files -g "*.(dwg|dxf|DWG|DXF)"' \
  '(-r -release)'{-r+,-release=}'[output format version]:release:' \
  '(-l -list)'{-l,-list}'[show supported releases]' \
  '(-s -set)'{-s+,-set=}'[modify DXF header variable (VARIABLE:VALUE)]:set:' \
  '(-n -setdimfont)'{-n+,-setdimfont=}'[change dimension font]:font:' \
  '(-h -help)'{-h,-help}'[display help]' \
  '*:DWG/DXF file:_files -g "*.(dwg|dxf|DWG|DXF)"' && ret=0

return ret
