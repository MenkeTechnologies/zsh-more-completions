#compdef ros
# Documentation: https://github.com/roswell/roswell/wiki/Roswell-as-Scripting-Environment
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. Roswell Common Lisp launcher.

local -a _1st_arguments
_1st_arguments=(
  'run:Run repl'
  'install:Install a given implementation or a system for roswell environment'
  'update:Update installed systems'
  'build:Make executable from script'
  'use:Change default implementation'
  'init:Create a new ros script, optionally based on a template'
  'fmt:Indent lisp source'
  'list:Information'
  'template:Manage templates'
  'delete:Delete installed implementations'
  'config:Get and set options'
  'version:Show the roswell version information'
  'help:Show help for a command or topic'
)

_arguments \
  '--version[Print version information and quit]' \
  '(-w --wrap)'{-w,--wrap}'[run roswell with a shell wrapper CODE]:code' \
  '(-m --image)'{-m,--image}'[continue from Lisp image IMAGE]:image:_files' \
  '(-M --module)'{-M,--module}'[execute ros script found in ROSWELLPATH]:name' \
  '(-L --lisp)'{-L,--lisp}'[run roswell with a lisp impl NAME(/VERSION)]:impl' \
  '(-l --load)'{-l,--load}'[load lisp FILE while building]:file:_files' \
  '(-S --source-registry)'{-S,--source-registry}'[override source registry of asdf systems]:path' \
  '(-s --system --load-system)'{-s,--system,--load-system}'[load asdf SYSTEM while building]:system' \
  '(-p --package)'{-p,--package}'[change current package to PACKAGE]:package' \
  '(-sp --system-package)'{-sp,--system-package}'[combination of -s SP and -p SP]:sp' \
  '(-e --eval)'{-e,--eval}'[evaluate FORM while building]:form' \
  '--require[require MODULE while building]:module' \
  '(-q --quit)'{-q,--quit}'[quit lisp here]' \
  '(-r --restart)'{-r,--restart}'[restart from build by calling (FUNC)]:func' \
  '(-E --entry)'{-E,--entry}'[restart from build by calling (FUNC argv)]:func' \
  '(-i --init)'{-i,--init}'[evaluate FORM after restart]:form' \
  '(-ip --print)'{-ip,--print}'[evaluate and princ FORM after restart]:form' \
  '(-iw --write)'{-iw,--write}'[evaluate and write FORM after restart]:form' \
  '(-F --final)'{-F,--final}'[evaluate FORM before dumping IMAGE]:form' \
  '(\+R --no-rc)'{\+R,--no-rc}'[skip /etc/rosrc, ~/.roswell/init.lisp]' \
  '(-A --asdf)'{-A,--asdf}'[use new asdf]' \
  '(\+Q --no-quicklisp)'{\+Q,--no-quicklisp}'[do not use quicklisp]' \
  '(-v --verbose)'{-v,--verbose}'[be quite noisy while building]' \
  '--quiet[be quite quiet while building default]' \
  '--test[for test purpose]' \
  '*:: :->subcmds' && return 0

if (( CURRENT == 1 )); then
  _describe -t commands "ros subcommand" _1st_arguments
  return
fi

case "$words[1]" in
  -l|--load)
    _files
    ;;
esac
