#compdef mdbook-template
# _mdbook-template — reusable template-file preprocessor for mdBook (sgoudham/mdbook-template)
# upstream: https://github.com/sgoudham/mdbook-template
# Subcommand from src/bin/mdbook-template.rs (clap App).

_mdbook-template() {
    _arguments \
        '1:command:(supports)' \
        '2:renderer:(html epub markdown latex)'
}

_mdbook-template "$@"
