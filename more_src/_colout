#compdef colout

local -a colors styles

colors=(none black red green yellow blue magenta cyan white
  light_black light_red light_green light_yellow light_blue
  light_magenta light_cyan light_white
  rainbow rainbow256 Random random Scale scale Hash hash)

styles=(normal bold faint italic underline blink rapid_blink
  reverse concealed crossed_out)

local -a arguments

arguments=(
  '(-t --theme)'{-t,--theme}'=[use a predefined theme]:theme:'
  '(-T --themes-dir)'{-T,--themes-dir}'=[directory containing themes]:dir:_files -/'
  '(-l --list-themes)'{-l,--list-themes}'[list available themes]'
  '(-r --resources)'{-r,--resources}'[print available resources]'
  '(-s --style)'{-s,--style}'=[text style]:style:(${(j: :)styles})'
  '(-a --all)'{-a,--all}'[color whole lines]'
  '(-c --colormap)'{-c,--colormap}'=[color map for scale]:colormap:'
  '(-d --debug)'{-d,--debug}'[debug mode]'
  '(-e --encoding)'{-e,--encoding}'=[set encoding]:encoding:'
  '(-g --groups)'{-g,--groups}'[use regex groups for coloring]'
  '--sep=[separator for multiple patterns]:separator:'
  '--scale=[scale range for scale mode]:min,max:'
  '1:pattern:' \
  '2:color:(${(j: :)colors})'
  '3:style:(${(j: :)styles})'
)

_arguments -s -S $arguments
