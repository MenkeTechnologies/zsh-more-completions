#compdef octopilot
# Documentation: https://github.com/dailymotion-oss/octopilot
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '*--repo=[target repository (supports discover-from queries)]:repo:' \
  '*--update=[file update rule (yaml/yq/sops/regex/exec)]:rule:' \
  '--github-token=[GitHub authentication token]:token:' \
  '--github-app-id=[GitHub App ID]:id:' \
  '--github-installation-id=[GitHub App installation ID]:id:' \
  '--github-privatekey=[GitHub App private key]:key:' \
  '--github-privatekey-file=[GitHub App private key file]:file:_files' \
  '--git-clone-dir=[base directory for clones]:dir:_files -/' \
  '--git-author-name=[git author name]:name:' \
  '--git-author-email=[git author email]:email:' \
  '--git-committer-name=[git committer name]:name:' \
  '--git-committer-email=[git committer email]:email:' \
  '--git-branch-prefix=[branch name prefix]:prefix:' \
  '--git-stay-on-ref[do not rebase onto base ref]' \
  '--restrict-to-branches=[only run on listed branches]:branches:' \
  '--pr-title=[pull request title]:title:' \
  '--pr-title-update-operation=[title update strategy]:op:(append prepend replace ignore)' \
  '--pr-body=[pull request body]:body:' \
  '--pr-body-update-operation=[body update strategy]:op:(append prepend replace ignore)' \
  '--pr-comments=[pull request comments]:comments:' \
  '--pr-labels=[pull request labels]:labels:' \
  '--pr-draft[create draft pull request]' \
  '--pr-merge[automatically merge the PR when checks pass]' \
  '--pr-merge-method=[merge method]:method:(merge squash rebase)' \
  '--pr-merge-commit-title=[merge commit title]:title:' \
  '--pr-merge-commit-message=[merge commit message]:msg:' \
  '--pr-merge-auto-wait=[auto-merge polling interval]:duration:' \
  '--strategy=[update strategy]:strategy:(reset append add)' \
  '--keep-files[keep local clone files after run]' \
  '--dry-run[do not push or create PRs]' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '*::args: _default'
