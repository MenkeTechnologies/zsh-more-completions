#compdef antsTransformInfo
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsTransformInfo.cxx — print info about ANTs transform files (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '*:transform file(s):_files -g "*.{txt,mat,h5,xfm,tfm}"' \
    && ret=0

return ret
