#compdef lan-mouse
# ---------------------------------------------------------------------------
# lan-mouse — software KVM switch / mouse & keyboard sharing for Local Area
#             Networks (Rust, 4,845★)
#
# upstream: https://github.com/feschber/lan-mouse
# author : Felix Schäfer (feschber)
# license: GPL-3.0-or-later
#
# Source-direct completion: every subcommand and every flag below is
# verbatim from src/config.rs `Args` clap-derive struct, src/capture_test.rs
# `TestCaptureArgs`, src/emulation_test.rs `TestEmulationArgs`, and
# lan-mouse-cli/src/lib.rs `CliArgs`/`CliSubcommand` parsed exactly as
# declared on the lan-mouse v0.10.0 tip.  Capture/Emulation backend
# value-enum lists are taken verbatim from CaptureBackend and Emulation-
# Backend serde renames.  Position enum (top/bottom/left/right) from
# lan-mouse-ipc/src/lib.rs.
#
# Direct deps from Cargo.toml (selected):
#   webrtc-dtls       0.12.0  ← canonical Rust WebRTC DTLS stack
#                               (this axis) — from the webrtc-rs collective
#                               (Rain Liu + the webrtc-rs/webrtc fork of
#                               pion/webrtc to Rust); secures lan-mouse's
#                               UDP transport between peers using PEM-loaded
#                               x509 certs generated by rcgen at first
#                               launch and pinned by SHA-256 fingerprint.
#   webrtc-util       0.11.0   (shared WebRTC utility types)
#   hickory-resolver  0.25.2   (DNS resolver, formerly Trust-DNS by Benjamin
#                               Fry — for resolving client hostnames at
#                               session connect time)
#   rustls            0.23.12  with `ring` provider (TLS for IPC)
#   rcgen             0.13.1   (self-signed x509 cert generation)
#   notify            8.2.0    (filesystem event watcher — hot-reload config)
#   clap              4.4.11   (derive — Args + Subcommand)
#   tokio             1.32.0   (async runtime — net/process/signal/sync)
#   serde / toml / toml_edit   (config in TOML at ~/.config/lan-mouse/config.toml)
#
# lan-mouse runs as a per-host daemon ("service") on each computer in the
# LAN; the daemon captures the system pointer when it crosses an
# edge-of-screen boundary configured for a remote client, then forwards
# keyboard + mouse events to that client over a DTLS-secured UDP channel.
# Pure software, no hardware KVM box.  Capture backends pluggable per OS:
# libei input portal (Wayland desktop portal), wlroots layer-shell hack
# (Sway/Hyprland), X11 XInput2 grabs, Windows raw input, macOS CGEvent
# taps.  Emulation likewise pluggable: wlroots virtual pointer, libei
# emulation, xdg-portal RemoteDesktop, X11 XTest, Windows SendInput,
# macOS CGEvent injection.
#
# === AXIS 170 OPENER — pure-language WebRTC stacks (DTLS+ICE+SCTP) ======
# Axis position: Rust=225 OPENS Axis 170 at slot 1/0/0.  Canonical Rust
# WebRTC implementation is the `webrtc-rs/webrtc` org — Rain Liu's pure-Rust
# port of pion/webrtc (the canonical Go WebRTC) covering ICE candidate
# gathering, DTLS handshake, SCTP datagram channels, SRTP media transport,
# and signaling.  lan-mouse pulls in only `webrtc-dtls` + `webrtc-util` —
# the bare DTLS + shared util crates — because it tunnels its own
# proprietary HID event protocol over the DTLS channel rather than using
# WebRTC's media engines, but the DTLS crate IS the canonical Rust
# implementation by virtue of being maintained by the same webrtc-rs
# collective as the larger Rust port of pion.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=225     ← THIS FILE              (axis 170 OPENS, slot 1/0/0)
#   Go=225       ← next round              (axis 170 continues, slot 2/0/0)
#   TS-Node=225  ← round after             (axis 170 CLOSES at triple-225, slot 1/1/1)
# ---------------------------------------------------------------------------

_lan-mouse() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '(-p --port)'{-p,--port=}'[listen port for lan-mouse (default from config)]:port:'
        '(-c --config)'{-c,--config=}'[non-default config file location]:file:_files -g "*.toml"'
        '--capture-backend=[capture backend override]:backend:(input-capture-portal layer-shell x11 windows macos dummy)'
        '--emulation-backend=[emulation backend override]:backend:(wlroots libei xdp x11 windows macos dummy)'
        '--cert-path=[path to non-default DTLS certificate location]:file:_files -g "*.(pem|crt|key)"'
    )

    _arguments -C \
        $global_opts \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'test-emulation:test input emulation (mouse / keyboard / scroll)'
                'test-capture:test input capture (no args)'
                'cli:Lan Mouse commandline interface (client management via IPC to running daemon)'
                'daemon:run in daemon mode (no GUI, attach the GTK frontend separately)'
            )
            _describe -t commands 'lan-mouse command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                test-emulation)
                    _arguments \
                        '--mouse[test mouse emulation]' \
                        '--keyboard[test keyboard emulation]' \
                        '--scroll[test scroll emulation]' && ret=0
                    ;;
                test-capture)
                    _arguments && ret=0
                    ;;
                cli)
                    _arguments \
                        '1: :->cli_cmds' \
                        '*::arg:->cli_args' && ret=0
                    case $state in
                        cli_cmds)
                            local -a subcmds
                            subcmds=(
                                'add-client:add a new client'
                                'remove-client:remove an existing client by ClientHandle id'
                                'activate:activate a client by id (start forwarding events to it)'
                                'deactivate:deactivate a client by id'
                                'list:list configured clients (id, hostname, port, position, active flag)'
                                'set-host:change hostname of a client'
                                'set-port:change UDP port of a client'
                                'set-position:set edge-of-screen position (which screen edge triggers handoff)'
                                'set-ips:set the explicit IP list to try (skip DNS for this client)'
                                'enable-capture:re-enable input capture on this host'
                                'enable-emulation:re-enable input emulation on this host'
                                'authorize-key:authorize a public key by SHA-256 fingerprint with a human-readable description'
                                'remove-authorized-key:deauthorize a public key by SHA-256 fingerprint'
                                'save-config:save in-memory configuration back to config.toml'
                            )
                            _describe -t commands 'lan-mouse cli subcommand' subcmds && ret=0
                            ;;
                        cli_args)
                            case $words[1] in
                                add-client)
                                    _arguments \
                                        '--hostname=[client hostname (resolved via hickory-resolver at session start)]:hostname:_hosts' \
                                        '--port=[client UDP port]:port:' \
                                        '*--ips=[client IP address (repeatable to provide multiple candidates)]:ip:' \
                                        '--enter-hook=[shell command to run when this client becomes active (KVM-style on-enter trigger)]:command:' && ret=0
                                    ;;
                                remove-client|activate|deactivate)
                                    _arguments '1:client id:' && ret=0
                                    ;;
                                set-host)
                                    _arguments \
                                        '1:client id:' \
                                        '2:new hostname (or empty to clear):_hosts' && ret=0
                                    ;;
                                set-port)
                                    _arguments \
                                        '1:client id:' \
                                        '2:new UDP port:' && ret=0
                                    ;;
                                set-position)
                                    _arguments \
                                        '1:client id:' \
                                        '2:screen edge position:(left right top bottom)' && ret=0
                                    ;;
                                set-ips)
                                    _arguments \
                                        '1:client id:' \
                                        '*:IP address:' && ret=0
                                    ;;
                                authorize-key)
                                    _arguments \
                                        '1:human-readable description:' \
                                        '2:SHA-256 fingerprint hex string:' && ret=0
                                    ;;
                                remove-authorized-key)
                                    _arguments \
                                        '1:SHA-256 fingerprint hex string:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                daemon)
                    _arguments && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_lan-mouse "$@"
