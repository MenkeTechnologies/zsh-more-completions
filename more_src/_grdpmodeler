#compdef grdpmodeler
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/spotter — evaluate plate model predictions on a grid

local ret=1

_arguments -s \
  '-E+[plate model rotation file/IDs/parameters]:rot:_default' \
  '-S+[prediction type(s) az/dist/stage/rate/etc]:type:_default' \
  '-F+[polygon file limiting evaluation area]:file:_files' \
  '-G+[output grid filename]:file:_files' \
  '-I+[grid spacing dx/dy]:spacing:_default' \
  '-R+[region west/east/south/north]:region:_default' \
  '-T+[fixed age (overrides age grid)]:age:_default' \
  '*-V[verbose (stackable)]' \
  '-b+[binary input format]:format:_default' \
  '-d+[nodata <-> NaN]:nodata:_default' \
  '-h+[header records]:n:_default' \
  '-o+[output column selection]:cols:_default' \
  '-r[pixel registration]' \
  '*:input grid:_files' \
  && ret=0

return ret
