#compdef pql

_pql() {
    local curcontext="$curcontext" ret=1

    _arguments \
        '--host[Prometheus host]:host:_hosts' \
        '--port[Prometheus port]:port:' \
        '--start[query range start time]:start time:' \
        '--end[query range end time]:end time:' \
        '--step[query resolution step]:step:' \
        '--timeout[query timeout]:timeout:' \
        '--format[output format]:format:(json csv table)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '*:PromQL query:' && ret=0

    return ret
}

_pql "$@"
