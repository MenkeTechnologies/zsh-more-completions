#compdef asyncapi
# Documentation: https://man.archlinux.org/search?q=asyncapi
# Reference accessed: 2026-05-16

# @asyncapi/cli — src/apps/cli/commands/* (oclif)

local curcontext="$curcontext" state line ret=1

local -a top=(
  bundle config convert diff format generate new optimize pretty start validate
)

_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd)
    _describe -t commands 'asyncapi command' $top && ret=0
    ;;
  (rest)
    _arguments '*:args:_default' && ret=0
    ;;
esac

return ret
