#compdef kfp-persistenceagent persistenceagent
# _kfp-persistenceagent — KFP Argo-Workflow → SQL persistence agent (kubeflow/pipelines)
# upstream: https://github.com/kubeflow/pipelines
# Flags from backend/src/agent/persistence/main.go on tip.

_kfp-persistenceagent() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file (out-of-cluster only)]:file:_files' \
        '--master=[apiserver URL override]:url:_urls' \
        '--logLevel=[log level]:level:(debug info warn error fatal panic)' \
        '--initializationTimeout=[ML pipeline API server init wait]:dur:' \
        '--timeout=[per-call timeout]:dur:' \
        '--mlPipelineAPIServerName=[ML pipeline API server hostname]:host:_hosts' \
        '--mlPipelineAPIServerHttpPort=[ML pipeline API server HTTP port]:port:' \
        '--mlPipelineAPIServerGRPCPort=[ML pipeline API server gRPC port]:port:' \
        '--mlPipelineAPIServerTLSEnabled=[ML pipeline API server uses TLS]:bool:(true false)' \
        '--mlPipelineAPIServerBasePath=[ML pipeline API server base path]:path:' \
        '--namespace=[informer namespace]:ns:' \
        '--ttlSecondsAfterWorkflowFinish=[TTL after workflow finishes (s)]:n:' \
        '--numWorker=[concurrent sync workers]:n:' \
        '--clientQPS=[Kubernetes client QPS]:f:' \
        '--clientBurst=[Kubernetes client burst]:n:' \
        '--executionType=[orchestration CR kind]:kind:(Workflow)' \
        '--saTokenRefreshInterval=[SA token reread interval (s)]:n:' \
        '--caCertPath=[trusted CA cert file]:file:_files'
}

_kfp-persistenceagent "$@"
