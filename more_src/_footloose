#compdef footloose
# Create containers that look like virtual machines

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:manage footloose configuration'
      'create:create containers'
      'delete:delete containers'
      'show:show container status'
      'ssh:SSH into a container'
      'stop:stop containers'
      'start:start containers'
    )
    _describe -t commands 'footloose command' commands && ret=0
    ;;
  args)
    _arguments \
      '(-c --config)'{-c,--config}'[config file]:file:_files' \
      '(-n --name)'{-n,--name}'[cluster name]:name:' \
      '*:machine:' && ret=0
    ;;
esac

return ret
