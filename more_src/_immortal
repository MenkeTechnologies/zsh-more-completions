#compdef immortal

_arguments -s -S \
  '(- *)--version[show version]' \
  '-c+[configuration file]:config file:_files -g "*.yml(-.)"' \
  '-ctl+[control socket directory]:directory:_directories' \
  '-d+[working directory]:directory:_directories' \
  '-e+[environment file]:env file:_files' \
  '-f+[follow PID from pid file]:pid file:_files' \
  '-l+[log file]:log file:_files' \
  '-logger+[log command]:command' \
  '-n+[service name]:name' \
  '-o+[log file for stdout]:log file:_files' \
  '-p+[PID file]:pid file:_files' \
  '-r+[retries before exiting]:retries' \
  '-s+[signal to send on timeout]:signal:(SIGHUP SIGINT SIGTERM SIGQUIT SIGKILL SIGUSR1 SIGUSR2)' \
  '-u+[user to run as]:user:_users' \
  '-w+[seconds to wait before starting]:seconds' \
  '-v[verbose mode]' \
  '*::command:_command_names -e' && return 0
