#compdef residualvm
# Documentation: https://github.com/residualvm/residualvm/blob/master/base/commandLine.cpp
# Reference accessed: 2026-05-16
# Verified: base/commandLine.cpp DO_COMMAND/DO_OPTION* macro invocations
# (lines 547-831). Prior file had a small subset; this is the verified full set.

# ResidualVM: 3D adventure game engine (merged into ScummVM)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '(-t --list-targets)'{-t,--list-targets}'[list configured targets]' \
  '(-z --list-games)'{-z,--list-games}'[list known games]' \
  '--list-engines[list known engines]' \
  '--list-saves[list saved games]' \
  '--list-audio-devices[list audio devices]' \
  '--list-themes[list available themes]' \
  '(-a --add)'{-a,--add}'[add game]' \
  '--detect[detect game in path]' \
  '--auto-detect[auto-detect and run]' \
  '--test-detector[test detector code]' \
  '--upgrade-targets[upgrade target list]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-l --logfile)'{-l,--logfile=}'[log file]:file:_files' \
  '(-b --boot-param)'{-b,--boot-param=}'[boot param]:n:' \
  '(-d --debuglevel)'{-d,--debuglevel=-}'[debug level]:n:' \
  '--debugflags=[debug flags]:flags:' \
  '--debug-channels-only[show only debug channels]' \
  '(-e --music-driver)'{-e,--music-driver=}'[music driver]:driver:' \
  '--output-rate=[output sample rate]:rate:' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen]' \
  '--no-fullscreen[windowed]' \
  '--filtering[graphics filtering]' \
  '--disable-display=[disable display N]:n:' \
  '--record-mode=[record mode]:mode:' \
  '--record-file-name=[record file]:file:_files' \
  '--opl-driver=[OPL driver]:driver:' \
  '(-g --gfx-mode)'{-g,--gfx-mode=}'[graphics mode]:mode:' \
  '--stretch-mode=[stretch mode]:mode:' \
  '--shader=[shader]:shader:' \
  '(-m --music-volume)'{-m,--music-volume=}'[music volume]:n:' \
  '(-n --subtitles)'{-n,--subtitles}'[enable subtitles]' \
  '(-p --path)'{-p,--path=}'[game path]:dir:_files -/' \
  '(-q --language)'{-q,--language=}'[language]:lang:' \
  '(-s --sfx-volume)'{-s,--sfx-volume=}'[SFX volume]:n:' \
  '(-r --speech-volume)'{-r,--speech-volume=}'[speech volume]:n:' \
  '--midi-gain=[MIDI gain]:n:' \
  '(-u --dump-scripts)'{-u,--dump-scripts}'[dump scripts]' \
  '(-x --save-slot)'{-x,--save-slot=-}'[save slot to load]:n:' \
  '--cdrom=[CD-ROM drive]:n:' \
  '--joystick=-[joystick number]:n:' \
  '--platform=[platform]:platform:' \
  '--soundfont=[soundfont file]:file:_files -g "*.sf2"' \
  '--disable-sdl-parachute[disable SDL parachute]' \
  '--multi-midi[multi MIDI]' \
  '--native-mt32[native MT-32]' \
  '--dump-midi[dump MIDI]' \
  '--enable-gs[enable GS]' \
  '--aspect-ratio[correct aspect ratio]' \
  '--render-mode=[render mode]:mode:' \
  '--dirtyrects[enable dirty rects]' \
  '--gamma=[gamma]:value:' \
  '--renderer=[renderer]:renderer:' \
  '--show-fps[show FPS]' \
  '--savepath=[savegame path]:dir:_files -/' \
  '--extrapath=[extra data path]:dir:_files -/' \
  '--talkspeed=[talk speed]:n:' \
  '--copy-protection[enable copy protection]' \
  '--gui-theme=[GUI theme]:theme:' \
  '--game=[game]:game:' \
  '--recursive[recursive add]' \
  '--themepath=[theme path]:dir:_files -/' \
  '--target-md5=[target MD5]:md5:' \
  '--tempo=[MIDI tempo]:n:' \
  '--dimuse-tempo=[DiMUSE tempo]:n:' \
  '--demo-mode[run in demo mode]' \
  '--alt-intro[use alternate intro]' \
  '--engine-speed=[engine speed]:n:' \
  '--launchedFromSB=[launched from Scumm Bar]:val:' \
  '--console[enable console]' \
  '--start-movie=[start with movie]:movie:' \
  '*:game:_files' && ret=0
return ret
