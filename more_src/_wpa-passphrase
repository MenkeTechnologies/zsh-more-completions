#compdef wpa-passphrase wpa_passphrase
# _wpa-passphrase — wpa_supplicant pre-shared key generator CLI (Jouni Malinen, C); custom argparse
# upstream: https://w1.fi/wpa_supplicant/

_wpa-passphrase() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:ssid:' \
        '2:passphrase:'
}

_wpa-passphrase "$@"
