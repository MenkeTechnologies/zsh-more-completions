# ============================================================================
# _lumina — zsh completion for Simon Larsson's Lumina, an
#            eager-by-default natively-compiled functional language
#            (159th language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/luminalang/lumina
#   Author     : Simon Larsson  <simon.larsson-general@protonmail.com>
#   License    : MPL-2.0
#   Stars      : 124
#   Language   : Rust (compiler) / Lumina (.lm source files)
#   Crate      : lumina v0.1.0  (workspace member under lumina/)
#   Binary     : lumina  (lumina/Cargo.toml [package] name = "lumina",
#                          built from lumina/src/main.rs)
#   Last push  : 2026-05-31
#
# WHAT IT IS
#   Lumina is "an eager-by-default natively-compiled functional
#   programming language" — Simon Larsson's strict ML-family
#   language with row-polymorphic records, GADTs, effects, and an
#   integrated LLVM-free Cranelift codegen for native binaries.
#   Lumina projects are organized as Cargo-like trees:  a project
#   directory contains a manifest, a source tree under `src/`, and
#   the `lumina` compiler drives the project lifecycle (init →
#   build → run → fmt).  Environment variable `LUMINAPATH` points
#   at the system-wide library directory;  the default location is
#   `$XDG_DATA_HOME/lumina` (via the `directories` crate).
#
# CLI ARGUMENT GRAMMAR  (verbatim from lumina/src/cli.rs clap-
#                       derive Cli + Commands enum + per-subcommand
#                       Args structs)
#   lumina <SUBCOMMAND> [args...] [-- <args-passed-to-program>...]
#
#   The trailing `-- ARGS` form is handled in `main.rs` via
#   `std::env::args().take_while(|arg| arg != "--")` — every
#   argument after `--` is forwarded to the program when running
#   under `lumina run`.
#
#   Subcommands:
#     init <PATH>                     Create a new Lumina project
#       --name <NAME>                   Project name (defaults to
#                                       directory name)
#       --authors <AUTHORS>...          Author entries (repeatable)
#       --version <VER>                 Project version
#                                       [default: "1.0"]
#       --force                         Create the project even if
#                                       the destination directory
#                                       isn't empty
#       --prelude <PATH>                Use a custom prelude library
#                                       (not recommended)
#
#     build [<PROJECT>]               Build a Lumina project
#                                     (defaults to current directory)
#       -t, --target <TRIPLE>           Target OS / triple
#       --epanic                        Panic in the compiler on the
#                                       first error
#       --super-debug                   Inject prints for every
#                                       function call
#                                       (~100000% perf hit)
#       -o, --output <PATH>             Output binary path
#
#     run [<PROJECT>]                 Build to a temporary directory
#                                     and run it.  Accepts the same
#                                     flags as `build`.  Anything
#                                     after a `--` separator is
#                                     forwarded to the program.
#
#     fmt [<PROJECT>]                 Format a Lumina project
#       --file <PATH>                   Format a single file instead
#                                       of the entire project
#       --overwrite                     Overwrite the existing file(s)
#
#   Standard clap auto-flags (with `flatten_help`):
#     -h, --help                      Show help
#     -V, --version                   Show version
#
#   Environment variables:
#     LUMINAPATH                      Override the Lumina library
#                                     directory.  When unset, the
#                                     compiler creates and uses
#                                     `<data_local_dir>/lumina`
#                                     (via the `directories` crate
#                                     — typically `~/.local/share/
#                                     lumina` on Linux).
#     RUST_LOG                        Read by `tracing_subscriber::
#                                     EnvFilter::from_default_env()`
#                                     for fine-grained per-module
#                                     log filtering.
#
# LANGUAGE-CORPUS POSITION
#   Lumina is the 159th programming language entry in this completion
#   corpus, closing the 3+1 micro-cycle that began at R905
#   (_jiascheduler / redis-rs 0.27 Rust=134 OPENS Axis 79 Redis
#   Client Library) and continued through R906 (_redis-viewer /
#   go-redis/redis v8.11.5 Go=134) and R907 (_rdcli / node-redis
#   ^3.1.2 TS-Node=134 CLOSES Axis 79 at 1/1/1 three-language
#   symmetry — triple-134 landmark and 72nd axis closed).  Lumina
#   joins Penne (R904 158th), EndBASIC (R900 157th — R900 TRIPLE-9
#   commit landmark), goboscript (R896 156th), Alan (R892 155th),
#   Mech (R888 154th — triple-8 landmark), Lisette (R884 153rd),
#   Bril (R880 152nd), Vyxal (R876 151st), EYG (R872 150th —
#   round-number language milestone), Roto (R868 149th), Pipefish
#   (R864 148th), Mochi (R860 147th), Oden (R856 146th), Hop (R852
#   145th), Lustre via Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ
#   (R840 142nd), Granule (R836 141st), Sixten (R832 140th), Imba
#   (R828 139th), Tao (R824 138th), Dada (R820 137th), Acton (R816
#   136th), and Stanza (R812 135th).
#
#   No completion for `lumina` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_lumina() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_lumina_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '--name=[project name (defaults to directory name)]:name:' \
                        '*--authors=[author entry (repeatable)]:author:' \
                        '--version=[project version (default 1.0)]:version:' \
                        '--force[create project even if dest dir is not empty]' \
                        '--prelude=[custom prelude library (not recommended)]:prelude:_files -/' \
                        ':project directory:_files -/' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                build|run)
                    _arguments \
                        '(-t --target)'{-t+,--target=}'[target OS / triple]:triple:' \
                        '--epanic[panic compiler on first error]' \
                        '--super-debug[inject prints for every function call]' \
                        '(-o --output)'{-o+,--output=}'[output binary path]:output:_files' \
                        ':project directory:_files -/' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                fmt)
                    _arguments \
                        '--file=[format a single file instead of the project]:file:_files -g "*.lm"' \
                        '--overwrite[overwrite existing file(s)]' \
                        ':project directory:_files -/' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_lumina_commands] )) ||
_lumina_commands() {
    local -a commands
    commands=(
        'init:create a new Lumina project'
        'build:build a Lumina project'
        'run:build a Lumina project and run it'
        'fmt:format a Lumina project or single source file'
    )
    _describe -t commands 'lumina command' commands
}

_lumina "$@"
