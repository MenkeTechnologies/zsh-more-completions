#compdef gdalsrsinfo

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--single-line[output on single line]' \
  '-V[validate SRS]' \
  '-e[output epsg]' \
  '-o+[output type]:type:(default all wkt wkt_simple wkt_noct wkt_esri wkt1 wkt2 wkt2_2015 wkt2_2018 wkt2_2019 proj4 epsg mapinfo xml)' \
  '-p[pretty-print]' \
  '*:SRS or filename:_files' && ret=0

return ret
