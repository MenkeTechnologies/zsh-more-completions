#compdef transiesta
# Documentation: https://docs.siesta-project.org/projects/siesta/en/stable/reference/tbtrans.html
# SIESTA non-equilibrium Green function transport DFT code (shares siesta CLI)

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print help and quit]' \
  '(-v -version)'{-v,-version}'[print version and quit]' \
  '(-o -out)'{-o,-out}'[write all output here instead of STDOUT]:file:_files' \
  '-L[override SystemLabel parameter]:label:' \
  '-V[override applied bias voltage e.g. 0.25:eV]:voltage:' \
  '-D[override directory parameter]:dir:_files -/' \
  '-fdf[set an fdf flag e.g. -fdf TBT.Voltage:0.2:eV]:fdf flag:' \
  '*:fdf file:_files' && ret=0

return ret
