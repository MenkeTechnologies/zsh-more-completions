#compdef gerbv

# Zsh completion for gerbv - Gerber file viewer

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --background)'{-b,--background}'=[background color (hex)]:color' \
  '(-f --foreground)'{-f,--foreground}'=[foreground color for next file (hex)]:color' \
  '(-l --log)'{-l,--log}'=[log file for layer]:log file:_files' \
  '(-o --output)'{-o,--output}'=[output file]:output file:_files' \
  '(-p --project)'{-p,--project}'=[load project file]:project file:_files -g "*.gvp"' \
  '(-t --translate)'{-t,--translate}'=[translate layer (x,y)]:offset' \
  '(-w --window_val)'{-w,--window_val}'=[window width]:width' \
  '--height=[window height]:height' \
  '(-a --antialias)'{-a,--antialias}'[use antialiasing]' \
  '(-T --export)'{-T,--export}'=[export file type]:format:(png pdf svg ps rs274x drill)' \
  '(-B --Border)'{-B,--Border}'=[border around image as percentage]:percent' \
  '(-D --dpi)'{-D,--dpi}'=[resolution in DPI for export]:dpi' \
  '(-W --auto_center)'{-W,--auto_center}'[auto-center image in window]' \
  '(-x --export)'{-x,--export}'=[export to file]:output file:_files' \
  '--window=[specify output size]:WxH' \
  '*:gerber files:_files -g "*.(gbr|ger|gtl|gbl|gts|gbs|gto|gbo|gtp|gbp|gm1|gml|drl|exc|pho|art)(-.)"'
