#compdef ipconfig

local -a subcommands

subcommands=(
    'getifaddr:Get interface address'
    'ifcount:Get number of interfaces'
    'getoption:Get DHCP option'
    'getpacket:Get DHCP packet'
    'getv6packet:Get DHCPv6 packet'
    'setverbose:Set verbose mode'
    'set:Set interface configuration'
    'waitall:Wait for all interfaces'
    'getiflist:Get list of interfaces'
    'getsummary:Get configuration summary'
    'setperformaliasaction:Set perform alias action'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*:: :->args' && return

case $state in
    subcmd)
        _describe 'ipconfig subcommand' subcommands
        ;;
    args)
        case $words[1] in
            getifaddr|getpacket|getv6packet|getsummary)
                _arguments '1:interface:_net_interfaces'
                ;;
            getoption)
                _arguments \
                    '1:interface or empty string:_net_interfaces' \
                    '2:option:(subnet_mask router domain_name_server domain_name lease_time server_identifier)'
                ;;
            set)
                _arguments \
                    '1:interface:_net_interfaces' \
                    '2:method:(BOOTP DHCP INFORM MANUAL NONE)' \
                    '*:arguments'
                ;;
            setverbose)
                _arguments '1:level:(0 1)'
                ;;
        esac
        ;;
esac
