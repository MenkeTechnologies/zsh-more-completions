#compdef release-please

# Zsh completion for release-please - automated release tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'release-pr:create or update a release PR'
      'github-release:create a GitHub release from merged release PR'
      'manifest-pr:create release PR from manifest config'
      'manifest-release:create releases from manifest config'
      'bootstrap:bootstrap a manifest config'
    )
    _describe -t commands 'release-please command' commands && ret=0
    ;;
  args)
    case $line[1] in
      release-pr)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--token=[GitHub token]:token' \
          '--repo-url=[GitHub repository URL]:url' \
          '--release-type=[release type]:type:(dart elixir go java krm-blueprint node ocaml php python ruby rust simple terraform)' \
          '--target-branch=[target branch]:branch' \
          '--default-branch=[default branch]:branch' \
          '--path=[path within repo]:path:_directories' \
          '--package-name=[package name]:name' \
          '--component=[component name]:name' \
          '--bump-minor-pre-major[bump minor for pre-1.0]' \
          '--bump-patch-for-minor-pre-major[bump patch for minor in pre-1.0]' \
          '--monorepo-tags[use monorepo tag format]' \
          '--pull-request-title-pattern=[PR title pattern]:pattern' \
          '--changelog-path=[path to changelog]:path:_files' \
          '--changelog-type=[changelog type]:type:(default github)' \
          '--draft[create draft PR]' \
          '--label=[PR labels]:labels' \
          '--fork[create PR from fork]' \
          '--signoff=[signoff on commits]:signoff' \
          '--extra-files=[extra files to update]:files' \
          '--version-file=[version file]:file:_files' \
          '--snapshot[snapshot release]' \
          '--prerelease[mark as prerelease]' \
          '--dry-run[dry run mode]' \
          '--debug[enable debug logging]' \
          '--trace[enable trace logging]' && ret=0
        ;;
      github-release)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--token=[GitHub token]:token' \
          '--repo-url=[GitHub repository URL]:url' \
          '--release-type=[release type]:type:(dart elixir go java krm-blueprint node ocaml php python ruby rust simple terraform)' \
          '--target-branch=[target branch]:branch' \
          '--path=[path within repo]:path:_directories' \
          '--package-name=[package name]:name' \
          '--component=[component name]:name' \
          '--monorepo-tags[use monorepo tag format]' \
          '--draft[create draft release]' \
          '--prerelease[mark as prerelease]' \
          '--label=[release labels]:labels' \
          '--dry-run[dry run mode]' \
          '--debug[enable debug logging]' && ret=0
        ;;
      manifest-pr|manifest-release)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--token=[GitHub token]:token' \
          '--repo-url=[GitHub repository URL]:url' \
          '--target-branch=[target branch]:branch' \
          '--config-file=[manifest config file]:file:_files -g "*.json"' \
          '--manifest-file=[manifest file]:file:_files -g "*.json"' \
          '--dry-run[dry run mode]' \
          '--debug[enable debug logging]' && ret=0
        ;;
      bootstrap)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--token=[GitHub token]:token' \
          '--repo-url=[GitHub repository URL]:url' \
          '--release-type=[release type]:type:(dart elixir go java krm-blueprint node ocaml php python ruby rust simple terraform)' \
          '--path=[path within repo]:path:_directories' \
          '--package-name=[package name]:name' \
          '--initial-version=[initial version]:version' \
          '--config-file=[config file]:file:_files -g "*.json"' \
          '--manifest-file=[manifest file]:file:_files -g "*.json"' \
          '--dry-run[dry run mode]' && ret=0
        ;;
    esac
    ;;
esac

return ret
