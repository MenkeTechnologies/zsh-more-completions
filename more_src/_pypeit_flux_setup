#compdef pypeit_flux_setup
# Documentation: https://pypeit.readthedocs.io/en/release/scripts.html
# Setup config files for flux calibration, 1D coadding, telluric correction

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '--name=[base name to use for the output files]:name' \
  '--objmodel=[science object model used in telluric fitting]:model:(qso star poly)' \
  '*:paths:_files' && ret=0

return ret
