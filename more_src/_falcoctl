#compdef falcoctl

# Zsh completion for falcoctl (Falco runtime security CLI)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'artifact:Interact with Falco artifacts'
  'driver:Interact with Falco drivers'
  'index:Manage artifact indexes'
  'registry:Interact with OCI registries'
  'tls:Generate TLS certificates'
  'completion:Generate shell completions'
  'version:Print version info'
)

_arguments -s -S -C \
  '--config=[Config file path]:file:_files -g "*.{yaml,yml}"' \
  '--disable-styling[Disable styling]' \
  '(-v --verbose)'{-v,--verbose}'[Enable verbose output]' \
  '(-h --help)'{-h,--help}'[Print help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'falcoctl command' commands && ret=0
    ;;
  args)
    case $words[1] in
      artifact)
        local -a artifact_cmds=(
          'install:Install a Falco artifact'
          'info:Print artifact info'
          'list:List installable artifacts'
          'search:Search for artifacts'
          'follow:Subscribe to artifacts for updates'
        )
        _describe -t artifact_cmds 'artifact subcommand' artifact_cmds && ret=0
        ;;
      driver)
        local -a driver_cmds=(
          'install:Install a Falco driver'
          'config:Configure the Falco driver'
          'printenv:Print driver configuration environment'
          'cleanup:Clean up the driver build environment'
        )
        _describe -t driver_cmds 'driver subcommand' driver_cmds && ret=0
        ;;
      index)
        local -a index_cmds=(
          'add:Add an index'
          'remove:Remove an index'
          'update:Update indexes'
          'list:List indexes'
        )
        _describe -t index_cmds 'index subcommand' index_cmds && ret=0
        ;;
      registry)
        local -a registry_cmds=(
          'auth:Manage registry authentication'
          'push:Push an artifact to a registry'
          'pull:Pull an artifact from a registry'
        )
        _describe -t registry_cmds 'registry subcommand' registry_cmds && ret=0
        ;;
      tls)
        _arguments -s -S \
          '--org=[Organization name]:org' \
          '--country=[Country]:country' \
          '--path=[Output directory]:dir:_files -/' \
          '--days=[Validity period in days]:days' \
          '--server=[DNS names for server cert]:dns names' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
