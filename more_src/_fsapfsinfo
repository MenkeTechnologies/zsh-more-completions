#compdef fsapfsinfo
# Documentation: https://github.com/libyal/libfsapfs
# Source: libyal/libfsapfs manuals/fsapfsinfo.1 — display info about an Apple File System (APFS) volume.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B[output file system info as a bodyfile]:bodyfile:_files' \
    '-d[calculate MD5 hash of file entry for bodyfile]' \
    '-E[show info about a specific file system entry or "all"]:entry:' \
    '-f[show info about a specific file system or "all"]:fsid:' \
    '-F[show info about a specific file entry path]:path:' \
    '-h[show help]' \
    '-H[show file system hierarchy]' \
    '-o[volume offset]:offset:' \
    '-p[password]:password:' \
    '-r[recovery password]:recovery password:' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:image or volume:_files' \
    && ret=0

return ret
