#compdef usbcfwflasher

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--rid=[reader index]:index:' \
  '--flash=[firmware file]:file:_files' \
  '--reset[reset device after flashing]' \
  '--noreset[do not reset device]' \
  '--noretries[do not retry on error]' \
  '--restore[restore mode]' \
  '--Gaid[Gaid mode]' \
  '--noGaid[no Gaid mode]' \
  '--stashExpectedFWVersion=[stash expected firmware version]:file:_files' \
  '--verbose[verbose output]' && ret=0

return ret
