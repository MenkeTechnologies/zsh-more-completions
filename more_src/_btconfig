#compdef btconfig
# Documentation: https://github.com/bluez/bluez/blob/master/tools/btconfig.c
# Source: BlueZ tools/btconfig.c — interactive Bluetooth controller configuration shell.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:command:' \
    && ret=0

return ret
