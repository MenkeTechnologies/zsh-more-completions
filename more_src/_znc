#compdef znc

# Zsh completion for znc - advanced modular IRC bouncer

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(- *)--makeconf[interactively create a new configuration]' \
  '(- *)--makepass[generate a password hash]' \
  '(- *)--makepem[generate a PEM file for SSL]' \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
  '(-d --datadir)'{-d,--datadir}'[set the data directory]:data directory:_directories' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-D --debug)'{-D,--debug}'[enable debug output]' \
  '--allow-root[allow running as root]' \
  '-p+[listen port]:port:'
