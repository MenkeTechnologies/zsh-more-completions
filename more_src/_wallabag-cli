#compdef wallabag-cli
# _wallabag-cli — Wallabag self-hosted read-it-later CLI alias (wallabag team, PHP); symfony console
# upstream: https://github.com/wallabag/wallabag

_wallabag-cli() {
    local -a sub=(
        'wallabag:install:install wallabag'
        'wallabag:migrate-articles:migrate articles'
        'wallabag:tag:all:tag all articles'
        'wallabag:export:export user data'
        'wallabag:import:import user data'
        'wallabag:user:create:create user'
        'wallabag:user:list:list users'
        'wallabag:user:show:show user'
        'wallabag:user:delete:delete user'
        'wallabag:user:rename:rename user'
        'wallabag:user:reset-password:reset password'
        'wallabag:user:reset-token:reset api token'
        'wallabag:install:create-config:create config'
        'wallabag:reload-entries:reload entries'
        'wallabag:show-user:show user'
        'wallabag:list-user:list users'
        'wallabag:clean-duplicates:clean dupes'
        'wallabag:fetching-images-on-the-fly:fetch images'
        'wallabag:purge-annotations:purge annotations'
        'wallabag:flush-2fa:flush 2fa'
        'wallabag:flush-author:flush author'
        'wallabag:downloader:fetch:fetch downloader'
        'wallabag:user:demote-admin:demote admin'
        'wallabag:user:promote-admin:promote admin'
        'doctrine:migrations:migrate:run migrations'
        'doctrine:database:create:create database'
        'doctrine:database:drop:drop database'
        'doctrine:schema:update:update schema'
        'cache:clear:clear cache'
        'cache:warmup:warm up cache'
        'assets:install:install assets'
        'completion:dump completion'
        'help:show help'
        'list:list commands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '-e+[env]:str:' \
        '--no-debug[no debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wallabag subcommand' sub ;;
        args)
            case $words[1] in
                wallabag:user:create) _arguments \
                    '1:username:_users' \
                    '2:password:' \
                    '3:email:' \
                    '--admin[create admin]' ;;
                wallabag:user:show|wallabag:user:delete|wallabag:user:reset-password|wallabag:user:reset-token|wallabag:user:promote-admin|wallabag:user:demote-admin) _arguments '1:username:_users' ;;
                wallabag:user:rename) _arguments '1:old name:' '2:new name:' ;;
                wallabag:tag:all|wallabag:reload-entries) _arguments '1:username:_users' ;;
                wallabag:install) _arguments '--reset[reset existing]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_wallabag-cli "$@"
