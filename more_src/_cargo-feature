#compdef cargo-feature
# Documentation: https://docs.rs/crate/cargo-feature/latest
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
  '--target=[target cfg expression]:target:' \
  '(-p --preview)'{-p,--preview}'[preview changes without writing]' \
  '(-i --ignore-progress)'{-i,--ignore-progress}'[disable progress output]' \
  '(-t --dependency-type)'{-t,--dependency-type}'=[dependency type]:type:(normal dev build)' \
  '--disable-default-features[disable default features]' \
  '--enable-default-features[enable default features]' \
  '1:crate:' \
  '*:features:'
