#compdef cargo-feature
# Documentation: https://man.archlinux.org/search?q=cargo-feature
# Reference accessed: 2026-05-16

_arguments -s \
  '--manifest-path=[manifest]:file:_files' \
  '--target=[target cfg]:target:' \
  '(-p --preview)'{-p,--preview}'[preview only]' \
  '(-i --ignore-progress)'{-i,--ignore-progress}'[no progress]' \
  '(-t --dependency-type)'{-t,--dependency-type}'=[dep type]:type:(normal dev build)' \
  '--disable-default-features[disable defaults]' \
  '--enable-default-features[enable defaults]' \
  '1:crate:' \
  '*:features:'
