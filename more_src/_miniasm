#compdef miniasm
# _miniasm — Heng Li lh3 miniasm CLI ultra-fast OLC overlap-layout-consensus de-novo assembler for long noisy Oxford Nanopore PacBio reads from minimap2 all-vs-all paf overlaps producing GFA unitig graph without correction polishing intended for downstream racon polishing pipeline (Heng Li team, C); getopt
# upstream: https://github.com/lh3/miniasm

_miniasm() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-f+[reads FASTA/Q]:file:_files -g "*.fa *.fasta *.fq *.fastq *.gz"' \
        '-m+[min match length]:n:' \
        '-i+[min identity]:n:' \
        '-s+[min span]:n:' \
        '-c+[min coverage]:n:' \
        '-o+[min overlap]:n:' \
        '-g+[max gap diff]:n:' \
        '-d+[max bubble distance]:n:' \
        '-e+[min unitig size]:n:' \
        '-n+[N rounds short overlap drop]:n:' \
        '-r+[N short overlap drop fraction]:n:' \
        '-I+[isolated read threshold]:n:' \
        '-F+[min final unitig length]:n:' \
        '-B+[bubble pop length]:n:' \
        '-1[skip 1-pass read selection]' \
        '-2[skip 2-pass read selection]' \
        '-h[show help]' \
        '*:paf file:_files -g "*.paf *.paf.gz"'
}

_miniasm "$@"
