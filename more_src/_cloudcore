#compdef cloudcore
# _cloudcore — KubeEdge cloud-side controller (kubeedge/kubeedge)
# upstream: https://github.com/kubeedge/kubeedge
# Flags from cloud/cmd/cloudcore/app/options/options.go + component-base on tip.

_cloudcore() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--config=[cloudcore configuration file (flags override values)]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[also log to stderr]' \
        '--log_dir=[klog log directory]:dir:_files -/' \
        '--log_file=[klog log file]:file:_files' \
        '--log_file_max_size=[per-file max size (MB)]:n:' \
        '--stderrthreshold=[stderr klog severity threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[per-module verbosity (pattern=N,...)]:spec:'
}

_cloudcore "$@"
