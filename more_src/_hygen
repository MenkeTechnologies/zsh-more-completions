#compdef hygen

# Zsh completion for hygen - code generator

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--help[show help]' \
  '--dry[perform a dry run without writing files]' \
  '1:generator:->generators' \
  '2:action:->actions' \
  '*:: :->args' && ret=0

case $state in
  generators)
    local templates_dir="${HYGEN_TMPLS:-_templates}"
    if [[ -d "$templates_dir" ]]; then
      local -a generators
      generators=(${templates_dir}/*(/:t))
      _describe -t generators 'generator' generators && ret=0
    fi
    ;;
  actions)
    local templates_dir="${HYGEN_TMPLS:-_templates}"
    if [[ -d "$templates_dir/${words[2]}" ]]; then
      local -a actions
      actions=(${templates_dir}/${words[2]}/*(/:t))
      _describe -t actions 'action' actions && ret=0
    fi
    ;;
esac

return ret
