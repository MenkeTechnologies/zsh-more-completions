#compdef RevertOriginalBaseQualitiesAndAddMateCigar
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#RevertOriginalBaseQualitiesAndAddMateCigar
# Picard: restore original base qualities (OQ) and add the mate cigar (MC) tag

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM/BAM file to revert the state of]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output SAM/BAM file to create]:bam:_files -g "*.(bam|sam)"' \
  {-SO=,--SORT_ORDER=}'[sort order of the reverted output]:order:(unsorted queryname coordinate duplicate unknown)' \
  {-OQ=,--RESTORE_ORIGINAL_QUALITIES=}'[restore original qualities from the OQ field]:bool:(true false)' \
  '--MAX_RECORDS_TO_EXAMINE=[max records to review before skipping output (0 disables)]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
