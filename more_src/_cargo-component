#compdef cargo-component

local -a subcommands
subcommands=(
  'new:Create a new WebAssembly component package'
  'add:Add a dependency to the component'
  'build:Build the component'
  'check:Check the component for errors'
  'clippy:Run clippy on the component'
  'doc:Build documentation'
  'key:Manage signing keys'
  'publish:Publish component to a registry'
  'update:Update dependencies'
  'wit:Manage WIT definitions'
  'help:Show help'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '(-q --quiet)'{-q,--quiet}'[Do not print cargo log messages]' \
  '(-v --verbose)'{-v,--verbose}'[Use verbose output]' \
  '--color=[Coloring]:when:(auto always never)' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      new)
        _arguments \
          '--lib[Create a library component]' \
          '--reactor[Create a reactor component]' \
          '--command[Create a command component]' \
          '--name=[Package name]:name:' \
          '--edition=[Rust edition]:edition:(2015 2018 2021 2024)' \
          '--target=[Target WIT world]:target:' \
          '--registry=[Registry to use]:registry:' \
          '1:path:_directories'
        ;;
      build)
        _arguments \
          '--release[Build in release mode]' \
          '(-p --package)'{-p,--package}'[Package to build]:package:' \
          '--target=[Target triple]:target:' \
          '--all-targets[Build all targets]' \
          '*:args:'
        ;;
      add)
        _arguments \
          '--name=[Rename dependency]:name:' \
          '--registry=[Registry to use]:registry:' \
          '--path=[Local path dependency]:path:_directories' \
          '--dry-run[Show what would be done]' \
          '1:package:'
        ;;
      publish)
        _arguments \
          '--registry=[Registry to use]:registry:' \
          '--dry-run[Show what would be done]' \
          '(-p --package)'{-p,--package}'[Package to publish]:package:'
        ;;
      key)
        _arguments \
          '1:action:(new set delete id)'
        ;;
    esac
    ;;
esac
