#compdef ignite

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--home=[home directory]:directory:_directories' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'scaffold:scaffold a new component'
      'chain:build, init, and start a chain'
      'app:manage app templates'
      'generate:generate client-side code'
      'network:manage decentralized launches'
      'node:manage a node'
      'relayer:manage relayer connections'
      'account:manage accounts'
      'docs:show documentation'
      'version:print version'
      'completion:generate shell completions'
    )
    _describe -t commands 'ignite command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (scaffold)
        local -a scaffold_cmds=(
          'chain:scaffold a new Cosmos SDK blockchain'
          'module:scaffold a new module'
          'message:scaffold a message'
          'query:scaffold a query'
          'type:scaffold a type'
          'list:scaffold a list CRUD module'
          'map:scaffold a map CRUD module'
          'single:scaffold a single-record CRUD module'
          'packet:scaffold an IBC packet'
          'band:scaffold a Band oracle integration'
          'vue:scaffold a Vue.js frontend'
          'react:scaffold a React frontend'
          'flutter:scaffold a Flutter frontend'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--path=[project path]:directory:_directories' \
          '--clear-cache[clear the build cache]' \
          '1:scaffold type:_describe -t scaffold-cmds "scaffold type" scaffold_cmds' \
          '*:arguments' && ret=0
        ;;
      (chain)
        local -a chain_cmds=(
          'build:build the blockchain'
          'init:initialize the blockchain'
          'serve:start the blockchain in development'
          'faucet:send coins to an account'
          'simulate:simulate load on the blockchain'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--path=[project path]:directory:_directories' \
          '--home=[home directory]:directory:_directories' \
          '1:chain command:_describe -t chain-cmds "chain command" chain_cmds' \
          '*:arguments' && ret=0
        ;;
      (generate)
        local -a generate_cmds=(
          'proto-go:generate Go code from proto files'
          'openapi:generate OpenAPI spec'
          'ts-client:generate TypeScript client'
          'composables:generate Vue composables'
          'hooks:generate React hooks'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--path=[project path]:directory:_directories' \
          '1:generate type:_describe -t generate-cmds "generate type" generate_cmds' \
          '*:arguments' && ret=0
        ;;
      (network)
        local -a network_cmds=(
          'chain:manage chains in the network'
          'coordinator:manage coordinator'
          'profile:manage profiles'
          'request:manage requests'
          'reward:manage rewards'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:network command:_describe -t network-cmds "network command" network_cmds' \
          '*:arguments' && ret=0
        ;;
      (node)
        local -a node_cmds=(
          'query:query the blockchain'
          'tx:send a transaction'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:node command:_describe -t node-cmds "node command" node_cmds' \
          '*:arguments' && ret=0
        ;;
      (account)
        local -a account_cmds=(
          'create:create a new account'
          'delete:delete an account'
          'show:show account details'
          'list:list all accounts'
          'import:import an account'
          'export:export an account'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:account command:_describe -t account-cmds "account command" account_cmds' \
          '*:arguments' && ret=0
        ;;
      (completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (relayer)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          'configure:configure relayer' \
          'connect:connect two chains' && ret=0
        ;;
      (version|docs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
