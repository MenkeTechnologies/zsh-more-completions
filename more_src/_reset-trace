#compdef reset-trace reset-trace-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/reset-trace.sh getopts)
# Reference accessed: 2026-05-29
# reset-trace — reset Linux ftrace state to disable lingering tracers (BCC/eBPF, but bash-only — no Python).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show usage]' \
  '-F[force: reset all tracing files]' \
  '-v[verbose: print details while working]' \
  '-q[quiet: no output]' \
  && ret=0

return ret
