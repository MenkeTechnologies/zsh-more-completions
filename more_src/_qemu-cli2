# _qemu-cli2 — Fabrice Bellard QEMU Project qemu-cli2 CLI command-line frontend wrapping the QEMU open-source generic and open source machine emulator and virtualizer it can run OSes and programs made for one machine on a different machine written in C originally by Fabrice Bellard now QEMU Project full system emulation OS dynamic translation user mode emulation KVM Xen accelerator hardware emulation virtio paravirtualization machine cpu m memory smp boot kernel initrd append drive netdev device usb-device chardev monitor display nographic vnc spice mon serial accel name uuid (Fabrice Bellard QEMU Project team, C); custom argparse
# upstream: https://www.qemu.org/

_qemu-cli2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-machine+[type]:str:' \
        '-M+[machine type]:str:' \
        '-cpu+[model]:str:' \
        '-smp+[N]:n:' \
        '-m+[memory]:str:' \
        '-name+[name]:str:' \
        '-uuid+[id]:str:' \
        '-boot+[order]:str:' \
        '-kernel+[file]:file:_files' \
        '-initrd+[file]:file:_files' \
        '-append+[args]:str:' \
        '-dtb+[file]:file:_files' \
        '-bios+[file]:file:_files' \
        '-drive+[options]:str:' \
        '*-drive+[options]:str:' \
        '-hda+[file]:file:_files -g "*.img *.qcow2 *.iso *.raw *.vmdk *.vdi"' \
        '-hdb+[file]:file:_files -g "*.img *.qcow2 *.iso *.raw *.vmdk *.vdi"' \
        '-hdc+[file]:file:_files -g "*.img *.qcow2 *.iso *.raw *.vmdk *.vdi"' \
        '-hdd+[file]:file:_files -g "*.img *.qcow2 *.iso *.raw *.vmdk *.vdi"' \
        '-cdrom+[file]:file:_files -g "*.iso *.img"' \
        '-fda+[file]:file:_files -g "*.img *.flp"' \
        '-fdb+[file]:file:_files -g "*.img *.flp"' \
        '-netdev+[options]:str:' \
        '*-netdev+[options]:str:' \
        '-net+[options]:str:' \
        '*-net+[options]:str:' \
        '-nic+[options]:str:' \
        '-device+[name]:str:' \
        '*-device+[name]:str:' \
        '-object+[options]:str:' \
        '*-object+[options]:str:' \
        '-usb[enable USB]' \
        '-usbdevice+[name]:str:' \
        '*-usbdevice+[name]:str:' \
        '-chardev+[options]:str:' \
        '*-chardev+[options]:str:' \
        '-serial+[dev]:str:' \
        '*-serial+[dev]:str:' \
        '-parallel+[dev]:str:' \
        '-monitor+[dev]:str:' \
        '-mon+[options]:str:' \
        '-qmp+[dev]:str:' \
        '-display+[type]:t:(none gtk sdl spice-app curses vnc dbus egl-headless)' \
        '-nographic[no graphics]' \
        '-vnc+[display]:str:' \
        '-spice+[options]:str:' \
        '-vga+[type]:t:(cirrus std vmware qxl xenfb tcx cg3 virtio none)' \
        '-soundhw+[name]:str:' \
        '-audiodev+[options]:str:' \
        '-enable-kvm[enable KVM]' \
        '-accel+[name]:n:(kvm xen hax hvf whpx tcg)' \
        '*-accel+[name]:n:(kvm xen hax hvf whpx tcg)' \
        '-no-kvm[no KVM]' \
        '-rtc+[options]:str:' \
        '-icount+[options]:str:' \
        '-cpu-clock-offset[CPU clock offset]' \
        '-snapshot[snapshot]' \
        '-no-fd-bootchk[no FD boot check]' \
        '-no-hpet[no HPET]' \
        '-no-shutdown[no shutdown]' \
        '-no-reboot[no reboot]' \
        '-daemonize[daemonize]' \
        '-pidfile+[file]:file:_files -g "*.pid"' \
        '-runas+[user]:_users' \
        '-fsdev+[options]:str:' \
        '-virtfs+[options]:str:' \
        '-pflash+[file]:file:_files' \
        '-rom+[options]:str:' \
        '-mem-path+[path]:_files' \
        '-mem-prealloc[preallocate memory]' \
        '-vmstate+[file]:file:_files' \
        '-loadvm+[name]:str:' \
        '-incoming+[uri]:str:' \
        '-only-migratable[only migratable]' \
        '-trace+[options]:str:' \
        '-msg+[options]:str:' \
        '-d+[items]:str:' \
        '-D+[file]:file:_files' \
        '-S[stop CPU at startup]' \
        '-s[short for -gdb tcp::1234]' \
        '-gdb+[dev]:str:' \
        '-singlestep[single step]' \
        '-watchdog+[name]:str:' \
        '-watchdog-action+[action]:str:' \
        '-readconfig+[file]:file:_files' \
        '-writeconfig+[file]:file:_files' \
        '-nodefaults[no defaults]' \
        '-action+[options]:str:' \
        '-sandbox+[options]:str:' \
        '-action-policy+[options]:str:' \
        '*:args:'
}

_qemu-cli2 "$@"
