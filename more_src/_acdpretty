#compdef acdpretty
# Documentation: https://man.archlinux.org/search?q=acdpretty
# Reference accessed: 2026-05-16

# EMBOSS acdpretty: pretty-print an ACD application definition file
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-program=[ACD program to format]:program:' \
  '-outfile=[formatted ACD output file]:file:_files -g "*.acd"' \
  '*::program name:' && ret=0
return ret
