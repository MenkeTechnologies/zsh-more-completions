#compdef keyscope

# Zsh completion for keyscope (SpectralOps/keyscope).

local -a subcmds
subcmds=(
  'validate:validate API keys for a provider'
  'requirements:show required params for a provider'
  'providers:list configured providers'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--no-banner[suppress startup banner]' \
  '(-v --verbose)'{-v,--verbose}'[enable debug logging]' \
  '(-c --config)'{-c,--config=}'[YAML config file]:file:_files' \
  '1: :{_describe '\''command'\'' subcmds}' \
  '*:: :->args'

[[ $state == args ]] || return 0

case $line[1] in
  validate)
    _arguments -s -S \
      '(-d --dry-run)'{-d,--dry-run}'[dry run with EXAMPLE_KEY]' \
      '(-r --reporter)'{-r,--reporter=}'[output format]:reporter:(console json junit quiet)' \
      '(-f --flip)'{-f,--flip}'[invert pass/fail meaning]' \
      '(-p --params)'{-p,--params+}'[provider-specific params]:param:' \
      '1:provider:'
    ;;
  requirements)
    _arguments '1:provider:'
    ;;
  providers)
    _arguments
    ;;
esac
