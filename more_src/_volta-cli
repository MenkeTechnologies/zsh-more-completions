#compdef volta
# Documentation: https://docs.volta.sh/reference/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'fetch:fetch a tool to local cache'
  'install:install a tool'
  'uninstall:uninstall a tool'
  'pin:pin tool to current project'
  'list:list installed tools'
  'ls:list installed tools'
  'completions:generate shell completions'
  'which:show path to tool'
  'setup:setup volta in shell'
  'run:run command using local tool versions'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*--verbose[verbose]' \
  '*--quiet[quiet]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'volta command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install|uninstall|pin|fetch)
        _arguments '*:tool:' && ret=0 ;;
      (list|ls)
        _arguments \
          '(--current)--current[current dir]' \
          '(--default)--default[default tools]' \
          '(--all)--all[all tools]' \
          '(--format)--format=[format]:f:(human plain)' \
          '*: :' && ret=0 ;;
      (which)
        _arguments '*:tool:' && ret=0 ;;
      (run)
        _arguments \
          '(--node)--node=[node version]:v:' \
          '(--npm)--npm=[npm version]:v:' \
          '(--yarn)--yarn=[yarn version]:v:' \
          '(--pnpm)--pnpm=[pnpm version]:v:' \
          '*: :' && ret=0 ;;
      (completions)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
