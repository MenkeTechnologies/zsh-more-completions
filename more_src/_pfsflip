#compdef pfsflip
# Documentation: http://pfstools.sourceforge.net/man1/pfsflip.1.html
# pfstools: flip frames in a pfs stream horizontally or vertically

local ret=1

_arguments -s -S \
  '-h[flip the image horizontally]' \
  '-v[flip the image vertically]' \
  '--help[print list of command line options]' && ret=0

return ret
