#compdef acdtrace
# EMBOSS: trace processing of an ACD file (ACD developer testing tool)

local ret=1

_arguments -s -S \
  '-auto[turn off prompts]' \
  '-debug[write debug output]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying program messages]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '-version[report version number and exit]' \
  '*:application name:_command_names -e' && ret=0

return ret
