#compdef kbfs kbfsfuse
# _kbfs — Keybase KBFS Keybase Filesystem FUSE/Dokan CLI (Keybase / Keybase team, Go); custom argparse
# upstream: https://github.com/keybase/client

_kbfs() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--mode=+[run mode]:m:(production staging devel)' \
        '--mount-type=+[mount type]:m:(default force none)' \
        '--mountpoint=+[mount point]:dir:_files -/' \
        '-m+[mount point]:dir:_files -/' \
        '--debug=+[debug categories]:list:' \
        '--mdserver=+[md server]:str:' \
        '--bserver=+[block server]:str:' \
        '--keyserver=+[key server]:str:' \
        '--server-addr=+[server addr]:str:' \
        '--platform-app-name=+[platform app name]:str:' \
        '--mounted-by-fuse[mounted by fuse]' \
        '--enable-disk-cache-for-self-pinned-folders[enable disk cache for self-pinned]' \
        '--disable-conflict-resolver[disable conflict resolver]' \
        '--root-team-name=+[root team name]:str:' \
        '--bw-stats[bandwidth stats]' \
        '--disable-prefetch[disable prefetch]' \
        '--auto-start[auto start]' \
        '--bg-fetch-period=+[background fetch period]:dur:' \
        '--bg-fetch-fetcher=+[bg fetcher]:f:(fast slow)' \
        '--block-cache-mem-cap=+[block cache mem cap]:n:' \
        '--enable-journal[enable journal]' \
        '--disable-journal[disable journal]' \
        '--journal-server-port=+[journal server port]:port:' \
        '--client-version=+[client version]:str:' \
        '--show-license[show license]' \
        '--no-color[no color]' \
        '*:arg:'
}

_kbfs "$@"
