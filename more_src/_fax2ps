#compdef fax2ps
# Documentation: fax2ps usage (libtiff 4.7.1)
# Source: convert TIFF facsimile to compressed PostScript.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-w[suppress warnings]' \
    '-l+[max output line length]:chars:' \
    '*-p+[page to print (repeatable)]:page#:' \
    '-x+[horizontal resolution dpi]:xres:' \
    '-y+[vertical resolution lpi]:yres:' \
    '-S[scale output to page size]' \
    '-W+[output page width (inches)]:width:' \
    '-H+[output page height (inches)]:height:' \
    '*:tiff file:_files -g "*.(tif|tiff)"' \
    && ret=0

return ret
