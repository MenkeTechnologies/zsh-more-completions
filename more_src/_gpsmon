#compdef gpsmon
# Documentation: https://gpsd.io/gpsmon.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help,-\?}'[show help]' \
  '(- *)-V[show version]' \
  '(-L --list)'{-L,--list}'[list supported GPS device types and commands]' \
  '(-D --debug)'{-D+,--debug=}'[packet getter debug level]:level:' \
  '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
  '(-n --nmea)'{-n,--nmea}'[request NMEA0183 packets]' \
  '(-t --type)'{-t+,--type=}'[fallback device type prefix]:type:' \
  '(-a --nocurses)'{-a,--nocurses}'[debugging mode without curses screen]' \
  '*:gpsd_source:' && ret=0

return ret
