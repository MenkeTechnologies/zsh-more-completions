#compdef gpsmon
# Documentation: https://man.archlinux.org/search?q=gpsmon
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-D+[debug level]:level:' \
  '-L[list packet types]' \
  '-l+[log file]:file:_files' \
  '-n[no GPSD - connect directly to device]' \
  '-t+[force device type]:type:' \
  '-T+[set timer expiration]:sec:' \
  '-a[ASCII display only]' \
  '*:gpsd_source:' && ret=0

return ret
