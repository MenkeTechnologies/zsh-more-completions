#compdef dgord
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/dgord.1.html
# PT-Scotch: compute a distributed sparse-matrix block ordering

local ret=1

_arguments -s \
  '-c-[choose default ordering strategy (b,q,s,t,x options)]:options' \
  '-h[display help]' \
  '-m-[save column block mapping data to file]:mfile:_files' \
  '-o-[use parallel graph ordering strategy]:strat' \
  '-r-[set root process for centralized files (default 0)]:pnum' \
  '-t-[save partitioning tree data to file]:tfile:_files' \
  '-V[display version and copyright]' \
  '-v-[set verbose mode (s,t)]:verb' \
  '*:file:_files' && ret=0

return ret
