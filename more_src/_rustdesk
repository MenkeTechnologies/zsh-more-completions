#compdef rustdesk

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--id=[set the ID for this device]:id' \
  '--server[start as server]' \
  '--service[start as service]' \
  '--connect=[connect to remote ID]:remote id' \
  '--file-transfer=[file transfer to remote ID]:remote id' \
  '--port-forward=[port forward]:host\:port' \
  '--rdp=[connect via RDP to remote ID]:remote id' \
  '--password=[set permanent password]:password' \
  '--get-id[print assigned ID]' \
  '--set-id=[set ID]:id' \
  '--config=[specify config directory]:directory:_files -/' \
  '--install[install service]' \
  '--uninstall[uninstall service]' \
  '--silent-install[install silently]' \
  '--tray[run in system tray]' \
  '--no-server[do not start relay server]' \
  '--check-hwcodec[check hardware codec support]' \
  '*:remote id' && ret=0

return ret
