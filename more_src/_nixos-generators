#compdef nixos-generate

# Zsh completion for nixos-generate - NixOS image format generator

local curcontext="$curcontext" state line ret=1

local -a formats=(
  'iso:ISO image'
  'install-iso:installation ISO image'
  'sd-aarch64:SD card image for aarch64'
  'sd-aarch64-installer:SD card installer for aarch64'
  'vm:QEMU VM image'
  'vm-nogui:QEMU VM image without GUI'
  'docker:Docker image'
  'raw:raw disk image'
  'raw-efi:raw EFI disk image'
  'qcow:QCOW2 disk image'
  'amazon:Amazon EC2 AMI image'
  'azure:Microsoft Azure image'
  'gce:Google Compute Engine image'
  'virtualbox:VirtualBox image'
  'vagrant-virtualbox:Vagrant VirtualBox image'
  'vmware:VMware image'
  'proxmox:Proxmox VE image'
  'lxc:LXC container image'
  'lxc-metadata:LXC container metadata'
  'hyperv:Hyper-V image'
  'kube:Kubernetes image'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--list[list available formats]' \
  '(-f --format)'{-f,--format}'[image format to generate]:format:->format' \
  '(-c --configuration)'{-c,--configuration}'[path to NixOS configuration file]:config file:_files -g "*.nix"' \
  '--system[target system architecture]:system:(x86_64-linux aarch64-linux armv7l-linux i686-linux)' \
  '--flake[flake URI]:flake URI:_files' \
  '--pkgs[path to nixpkgs]:nixpkgs path:_files' \
  '--nixpkgs[path to nixpkgs]:nixpkgs path:_files' \
  '--run[run the built image after building]' \
  && ret=0

case $state in
  format)
    _describe -t formats 'image format' formats && ret=0
    ;;
esac

return ret
