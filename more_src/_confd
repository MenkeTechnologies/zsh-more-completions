#compdef confd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-backend=[config backend]:backend:(consul dynamodb env etcd etcdv3 file rancher redis ssm vault zookeeper)' \
  '-client-ca-keys=[client CA keys]:file:_files' \
  '-client-cert=[client certificate]:cert file:_files' \
  '-client-key=[client key]:key file:_files' \
  '-confdir=[config directory]:directory:_directories' \
  '-config-file=[config file]:file:_files -g "*.toml"' \
  '-interval=[polling interval in seconds]:seconds' \
  '-keep-stage-file[keep staged files]' \
  '-log-level=[log level]:level:(debug info warn error)' \
  '-node=[backend node]:node' \
  '-noop[dry run mode]' \
  '-onetime[run once and exit]' \
  '-prefix=[key prefix]:prefix' \
  '-scheme=[backend URI scheme]:scheme:(http https)' \
  '-srv-domain=[SRV domain]:domain' \
  '-sync-only[sync only mode]' \
  '-table=[DynamoDB table]:table' \
  '-watch[use watching instead of polling]' \
  '-auth-token=[vault auth token]:token' \
  '-auth-type=[vault auth type]:type:(token app-id)' \
  '-app-id=[vault app ID]:app ID' \
  '-user-id=[vault user ID]:user ID' \
  '-username=[basic auth username]:username' \
  '-password=[basic auth password]:password' \
  '-separator=[separator for list values]:separator' && ret=0

return ret
