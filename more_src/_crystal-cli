#compdef crystal
# _crystal-cli — Crystal language CLI (Manas Technology Solutions + Crystal Team, Crystal); compile/run/test Crystal source
# upstream: https://github.com/crystal-lang/crystal

_crystal-cli() {
    local -a sub=(
        'build:build executable'
        'docs:generate docs'
        'env:print env'
        'eval:eval source'
        'help:show help'
        'init:initialize new project'
        'i:alias for interactive'
        'interactive:start interactive shell'
        'play:start playground'
        'run:build + run'
        'spec:run specs'
        'tool:tool subcommands'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'crystal subcommand' sub ;;
        args)
            case $words[1] in
                build|run) _arguments \
                    '--release[release build]' \
                    '--no-debug[no debug info]' \
                    '--debug[debug info]' \
                    '--cross-compile[cross compile]' \
                    '-D+[flag]:flag:' \
                    '--define+[flag]:flag:' \
                    '--emit+[emit]:emit:(asm llvm-bc llvm-ir obj)' \
                    '--error-trace[error trace]' \
                    '--exhaustive-overload-order[exhaustive overload order]' \
                    '--ll[dump LLVM IR]' \
                    '--link-flags+[link flags]:str:' \
                    '--mcpu+[cpu]:cpu:' \
                    '--mattr+[mattr]:str:' \
                    '--mcmodel+[code model]:model:(small medium large kernel)' \
                    '-o+[output file]:file:_files' \
                    '--output+[output file]:file:_files' \
                    '--prelude+[prelude]:file:_files' \
                    '--single-module[single module]' \
                    '--threads+[threads]:n:' \
                    '--target+[target triple]:str:' \
                    '--time[print compile time]' \
                    '*:file:_files -g "*.cr"' ;;
                init) _arguments \
                    '1:type:(lib app)' \
                    '*:name:' ;;
                spec) _arguments \
                    '*:spec:_files -g "*.cr"' \
                    '--no-color[no color]' \
                    '--verbose[verbose]' \
                    '--profile[profile]' \
                    '--fail-fast[fail fast]' ;;
                tool) _arguments '1:tool cmd:(context dependencies expand flags format hierarchy implementations macro_code_coverage types unreachable)' '*:args:' ;;
            esac
            ;;
    esac
}

_crystal-cli "$@"
