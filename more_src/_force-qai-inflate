#compdef force-qai-inflate
# Documentation: https://force-eo.readthedocs.io/en/latest/components/auxilliary/qai-inflate.html
# FORCE: inflate QAI bit layers into separate QIM files

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-v)-v[show version]' \
  '(-i)-i[show program purpose]' \
  '1:input QAI file:_files' \
  '2:output dir:_files -/' && ret=0

return ret
