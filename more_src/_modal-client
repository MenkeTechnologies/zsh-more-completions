#compdef modal-client
# Documentation: https://github.com/modal-labs/modal-client
# Reference accessed: 2026-05-27
# Verified: upstream py/modal/cli/entry_point.py and per-subcommand files
# (app.py, container.py, cluster.py, dict.py, network_file_system.py,
# secret.py, queues.py, volume.py, token.py, environment.py, profile.py,
# config.py, run.py).
# Note: the installed binary is named `modal`, covered by the existing
# _modal file. This file targets the alternate name `modal-client` reserved
# in the parent project's plan. Coverage: full top-level subcommand tree
# plus first-level nested subcommands; per-subcommand option flags are not
# enumerated to keep the file readable.
# Deviations from spec: dropped `function`, `logs` (no such top-level
# subcommands; `logs` lives under `app logs` and `container logs`).

local curcontext="$curcontext" state line ret=1

local -a _modal_subcommands
_modal_subcommands=(
  'deploy:deploy an App from a local file or module'
  'serve:run an App ephemerally and hot-reload local changes'
  'shell:start an interactive shell inside a Modal container'
  'run:run a Modal function locally driving a remote App'
  'app:manage deployed Modal Apps'
  'container:inspect or interact with running containers'
  'cluster:manage multi-node clusters (beta)'
  'dict:manage modal.Dict objects'
  'nfs:manage modal.NetworkFileSystem volumes'
  'queue:manage modal.Queue objects'
  'secret:manage named Secrets'
  'volume:manage modal.Volume objects'
  'setup:bootstrap Modal configuration (login)'
  'bootstrap:bootstrap workspace configuration'
  'config:read or modify the local Modal config'
  'environment:manage workspace environments'
  'profile:manage local Modal profiles'
  'token:create, set, or inspect API tokens'
  'billing:inspect workspace billing information'
  'changelog:print recent Modal changelog entries'
  'dashboard:open the Modal dashboard in a browser'
)

_arguments -C \
  '(- *)--version[show modal client version]' \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'modal-client subcommand' _modal_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments \
          '(-n --name)'{-n+,--name=}'[name for this run of the App]:name:' \
          '(-w --write-result)'{-w+,--write-result=}'[write return value to this path]:file:_files' \
          '(-q --quiet)'{-q,--quiet}'[do not show Modal progress indicators]' \
          '(-d --detach)'{-d,--detach}'[do not stop the app if local process dies]' \
          '(-i --interactive)'{-i,--interactive}'[run in interactive mode]' \
          '(-e --env)'{-e+,--env=}'[environment name]:env:' \
          '-m[interpret argument as a Python module path]' \
          '--timestamps[show timestamps for each log line]' \
          '*:python ref:_files -g "*.py"' && ret=0
        ;;
      deploy|serve)
        _arguments '*:python ref:_files -g "*.py"' && ret=0
        ;;
      app)
        local -a _modal_app
        _modal_app=(
          'list:list Apps in the current workspace'
          'logs:stream logs for a deployed App'
          'rollback:roll back an App to a previous version'
          'rollover:re-deploy without container restart'
          'stop:stop a running App'
          'history:show deployment history for an App'
          'dashboard:open an App in the dashboard'
        )
        _describe -t commands 'modal app subcommand' _modal_app && ret=0
        ;;
      container)
        local -a _modal_container
        _modal_container=(
          'list:list running containers'
          'logs:stream logs for a container'
          'exec:execute a command inside a container'
          'stop:stop a running container'
        )
        _describe -t commands 'modal container subcommand' _modal_container && ret=0
        ;;
      cluster)
        local -a _modal_cluster
        _modal_cluster=(
          'list:list multi-node clusters'
          'shell:open a shell into a cluster node'
        )
        _describe -t commands 'modal cluster subcommand' _modal_cluster && ret=0
        ;;
      dict)
        local -a _modal_dict
        _modal_dict=(
          'create:create a named modal.Dict'
          'list:list modal.Dict objects'
          'clear:clear all entries in a modal.Dict'
          'delete:delete a named modal.Dict'
          'get:read an entry from a modal.Dict'
          'items:list entries of a modal.Dict'
        )
        _describe -t commands 'modal dict subcommand' _modal_dict && ret=0
        ;;
      nfs)
        local -a _modal_nfs
        _modal_nfs=(
          'list:list network file systems'
          'create:create a named network file system'
          'ls:list files in a network file system'
          'put:upload a file or directory'
          'get:download a file or directory'
          'rm:remove a file or directory'
          'delete:delete a named network file system'
        )
        _describe -t commands 'modal nfs subcommand' _modal_nfs && ret=0
        ;;
      queue)
        local -a _modal_queue
        _modal_queue=(
          'create:create a named modal.Queue'
          'delete:delete a named modal.Queue'
          'list:list modal.Queue objects'
          'clear:clear all entries in a modal.Queue'
          'peek:peek at entries without removing them'
          'len:print the length of a modal.Queue'
        )
        _describe -t commands 'modal queue subcommand' _modal_queue && ret=0
        ;;
      secret)
        local -a _modal_secret
        _modal_secret=(
          'list:list published secrets'
          'create:create a new secret'
          'delete:delete a named secret'
        )
        _describe -t commands 'modal secret subcommand' _modal_secret && ret=0
        ;;
      volume)
        local -a _modal_volume
        _modal_volume=(
          'create:create a named, persistent modal.Volume'
          'get:download a file from a volume'
          'list:list modal.Volume objects'
          'ls:list files and directories in a volume'
          'put:upload a file or directory to a volume'
          'rm:remove a file or directory from a volume'
          'cp:copy a file inside or across volumes'
          'delete:delete a named volume and all its data'
          'rename:rename a volume'
          'dashboard:open the volume dashboard'
        )
        _describe -t commands 'modal volume subcommand' _modal_volume && ret=0
        ;;
      token)
        local -a _modal_token
        _modal_token=(
          'set:set token id and secret for a profile'
          'new:create a new token interactively'
          'info:print active token info'
        )
        _describe -t commands 'modal token subcommand' _modal_token && ret=0
        ;;
      environment)
        local -a _modal_env
        _modal_env=(
          'list:list environments in the current workspace'
          'create:create a new environment'
          'delete:delete an environment'
          'update:update environment-level settings'
        )
        _describe -t commands 'modal environment subcommand' _modal_env && ret=0
        ;;
      profile)
        local -a _modal_profile
        _modal_profile=(
          'activate:change the active Modal profile'
          'current:print the active Modal profile'
          'list:show all Modal profiles'
        )
        _describe -t commands 'modal profile subcommand' _modal_profile && ret=0
        ;;
      config)
        local -a _modal_config
        _modal_config=(
          'show:show current configuration values'
          'set-environment:set the default environment for the profile'
          'set:set a configuration value'
        )
        _describe -t commands 'modal config subcommand' _modal_config && ret=0
        ;;
      setup)
        _arguments '--profile=[profile name]:profile:' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
