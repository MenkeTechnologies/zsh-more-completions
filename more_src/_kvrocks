#compdef kvrocks
# Documentation: https://github.com/apache/kvrocks/blob/unstable/src/cli/main.cc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Apache Kvrocks server. Only three real flags exist; additionally any
# `--<config-key> <value>` is accepted and forwarded as a config override.
# Removed from prior file: bogus man.archlinux.org search URL.

_arguments -s \
  '(-c --config)'{-c+,--config=}'[set config file (- for stdin)]:file:_files -g "*.conf"' \
  '(- *)'{-v,--version}'[print version information]' \
  '(- *)'{-h,--help}'[print help message]' \
  '*: :_default'
