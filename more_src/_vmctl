#compdef vmctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'opentsdb:migrate from OpenTSDB'
  'influx:migrate from InfluxDB'
  'prometheus:migrate from Prometheus snapshot'
  'vm-native:migrate between VictoriaMetrics instances'
  'remote-read:migrate via Prometheus remote-read API'
  'thanos:migrate from Thanos blocks'
  'verify-block:verify a VictoriaMetrics block'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--vm-addr=[VictoriaMetrics destination URL]:url:' \
  '--vm-account-id=[account id]:id:' \
  '--vm-user=[user]:user:_users' \
  '--vm-password=[password]:password:' \
  '--vm-concurrency=[concurrent workers]:n:' \
  '--vm-batch-size=[batch size]:n:' \
  '*--vm-extra-label=[extra label key=value]:label:' \
  '--vm-round-digits=[round digits]:n:' \
  '--vm-rate-limit=[rate limit]:bps:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'vmctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (opentsdb)
        _arguments \
          '--opentsdb-addr=[OpenTSDB address]:addr:' && ret=0
        ;;
      (influx)
        _arguments \
          '--influx-addr=[InfluxDB address]:addr:' \
          '--influx-user=[InfluxDB user]:user:_users' \
          '--influx-password=[InfluxDB password]:password:' && ret=0
        ;;
      (prometheus)
        _arguments \
          '--prom-snapshot=[Prometheus snapshot path]:dir:_files -/' && ret=0
        ;;
      (remote-read)
        _arguments \
          '--remote-read-url=[remote-read URL]:url:' && ret=0
        ;;
      (thanos)
        _arguments \
          '--thanos-path=[Thanos blocks path]:dir:_files -/' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
