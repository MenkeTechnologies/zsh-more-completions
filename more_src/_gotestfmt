#compdef gotestfmt

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--ci[run in CI mode, do not use terminal colors]' \
  '--hide[hide certain test outputs]:hide:(successful-tests successful-packages empty-packages successful-downloads all)' \
  '--formatter[formatter directory to use]:directory:_directories' && ret=0

return ret
