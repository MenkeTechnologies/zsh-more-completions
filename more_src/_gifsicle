#compdef gifsicle
# Documentation: https://www.lcdf.org/gifsicle/man.html
# Source: Eddie Kohler's gifsicle — GIF inspector, animator, optimizer.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-i --interlace)'{-i,--interlace}'[interlace output]' \
    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
    '(-b --batch)'{-b,--batch}'[modify each input in place]' \
    '(-m --merge -e --explode)'{-m,--merge}'[merge inputs into one animation]' \
    '(-m --merge -e --explode)'{-e,--explode}'[create one GIF per frame]' \
    '(-I --info)'{-I,--info}'[print human-readable info about each input]' \
    '(-O --optimize -U --unoptimize)'{-O-,--optimize=-}'[optimize animation file size (opt level)]:level:(1 2 3)' \
    '(-O --optimize -U --unoptimize)'{-U,--unoptimize}'[convert to unoptimized GIF]' \
    '(-k --colors)'{-k+,--colors=}'[reduce to N distinct colors]:n:' \
    '(-f --dither)'{-f,--dither}'[dither when colormap changes]' \
    '--use-colormap=[use this colormap]:colormap:(web bw gray halftone)' \
    '(-t --transparent)'{-t+,--transparent=}'[make color transparent]:color:' \
    '(-B --background)'{-B+,--background=}'[set background color]:color:' \
    '--crop=[crop frames to rectangle]:geometry:' \
    '--resize=[resize to width x height]:WxH:' \
    '--scale=[scale by factors]:factor:' \
    '--rotate-90[rotate 90 deg]' \
    '--rotate-180[rotate 180 deg]' \
    '--rotate-270[rotate 270 deg]' \
    '--flip-horizontal[flip horizontally]' \
    '--flip-vertical[flip vertically]' \
    '(-d --delay)'{-d+,--delay=}'[frame delay (1/100 sec)]:n:' \
    '(-l --loopcount)'{-l-,--loopcount=-}'[Netscape loop extension (default infinite)]:n:' \
    '--replace=[replace specified frames]:frames:' \
    '--no-extensions[remove extensions]' \
    '--no-comments[remove comments]' \
    '--no-names[remove name extensions]' \
    '--append[append frames]' \
    '--multifile[read multiple GIFs per file]' \
    '*:input .gif:_files -g "*.gif"' \
    && ret=0

return ret
