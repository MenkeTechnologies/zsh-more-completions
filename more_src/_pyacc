#compdef pyacc
# Documentation: https://www.musikwissenschaft.uni-mainz.de/~ag/pyacc/
# Reference accessed: 2026-05-20
# Verified: pyacc --help (TP Yacc Version 4.1a, Albert Graef).

local curcontext="$curcontext" state line ret=1

_arguments \
  '-v[verbose]' \
  '-d[debug]' \
  '1:grammar file:_files -g "*.y"' \
  '2:output pas file:_files -g "*.pas"' && ret=0

return ret
