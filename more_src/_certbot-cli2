#compdef certbot-cli2 letsencrypt-cli
# Documentation: https://man.archlinux.org/search?q=certbot-cli2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:obtain and install certificate (default)'
  'certonly:obtain only, no install'
  'renew:renew all certificates'
  'enhance:add HSTS/redirect to existing'
  'install:install certificate using plugin'
  'revoke:revoke a certificate'
  'register:create ACME account'
  'update_account:update existing account'
  'show_account:show account info'
  'unregister:deactivate account'
  'rollback:rollback server config'
  'plugins:plugins list'
  'update_symlinks:update symlinks'
  'reconfigure:reconfigure cert'
  'delete:delete cert from disk'
  'certificates:list cert info'
  'help:show help'
  'config_changes:show config changes'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*-c+[config file]:file:_files -g "*.ini"' \
  '*--config=[config file]:file:_files' \
  '*--work-dir=[work dir]:dir:_files -/' \
  '*--logs-dir=[logs dir]:dir:_files -/' \
  '*--config-dir=[config dir]:dir:_files -/' \
  '*--non-interactive[non-interactive]' \
  '*-n[non-interactive]' \
  '*--noninteractive[non-interactive]' \
  '*--force-interactive[force interactive]' \
  '*--dry-run[dry run]' \
  '*--debug-challenges[debug challenges]' \
  '*--no-verify-ssl[no verify SSL]' \
  '*--http-01-port=[port]:port:' \
  '*--http-01-address=[bind addr]:addr:' \
  '*--https-port=[port]:port:' \
  '*--break-my-certs[issue weak certs]' \
  '*--rsa-key-size=[bits]:n:' \
  '*--key-type=[type]:t:(rsa ecdsa)' \
  '*--elliptic-curve=[curve]:c:(secp256r1 secp384r1 secp521r1)' \
  '*--no-reuse-key[do not reuse key]' \
  '*--reuse-key[reuse key]' \
  '*--must-staple[must-staple]' \
  '*--redirect[redirect HTTP to HTTPS]' \
  '*--no-redirect[no redirect]' \
  '*--hsts[HSTS]' \
  '*--uir[upgrade-insecure-requests]' \
  '*--staple-ocsp[staple OCSP]' \
  '*--no-eff-email[no EFF email]' \
  '*--eff-email[opt in EFF email]' \
  '*--manual[manual plugin]' \
  '*--manual-public-ip-logging-ok[OK to log IP]' \
  '*--manual-auth-hook=[auth hook]:file:_files' \
  '*--manual-cleanup-hook=[cleanup hook]:file:_files' \
  '*--standalone[standalone plugin]' \
  '*--apache[apache plugin]' \
  '*--nginx[nginx plugin]' \
  '*--apache-server-root=[apache root]:dir:_files -/' \
  '*--apache-vhost-root=[vhost root]:dir:_files -/' \
  '*--nginx-server-root=[nginx root]:dir:_files -/' \
  '*--nginx-ctl=[nginx binary]:file:_files' \
  '*--webroot[webroot plugin]' \
  '*--webroot-path=[webroot]:dir:_files -/' \
  '*-w+[webroot]:dir:_files -/' \
  '*--webroot-map=[map]:m:' \
  '*--dns-cloudflare[cloudflare DNS]' \
  '*--dns-cloudflare-credentials=[creds]:file:_files' \
  '*--dns-cloudflare-propagation-seconds=[s]:s:' \
  '*--dns-route53[route53 DNS]' \
  '*--dns-google[google DNS]' \
  '*--dns-google-credentials=[creds]:file:_files' \
  '*--dns-digitalocean[DO DNS]' \
  '*--dns-digitalocean-credentials=[creds]:file:_files' \
  '*--dns-rfc2136[nsupdate]' \
  '*--dns-rfc2136-credentials=[creds]:file:_files' \
  '*-d+[domain]:d:' \
  '*--domain=[domain]:d:' \
  '*--domains=[domains csv]:list:' \
  '*--cert-name=[cert name]:n:' \
  '*--server=[ACME server URL]:url:' \
  '*--email=[email]:e:' \
  '*-m+[email]:e:' \
  '*--no-eff-email[no EFF email]' \
  '*--register-unsafely-without-email[no email]' \
  '*--user-agent=[UA]:ua:' \
  '*--account=[account ID]:a:' \
  '*--no-self-upgrade[no self upgrade]' \
  '*--quiet[quiet]' \
  '*-q[quiet]' \
  '*--verbose[verbose]' \
  '*-v[verbose]' \
  '*--text[text output]' \
  '*--max-log-backups=[n]:n:' \
  '*--keep-until-expiring[keep until expiring]' \
  '*--keep[keep]' \
  '*--reinstall[reinstall]' \
  '*--expand[expand cert]' \
  '*--renew-by-default[renew by default]' \
  '*--renew-with-new-domains[renew with new]' \
  '*--allow-subset-of-names[allow subset]' \
  '*--agree-tos[agree to TOS]' \
  '*--duplicate[duplicate]' \
  '*--os-packages-only[OS pkgs only]' \
  '*--no-permissions-check[no perms check]' \
  '*--force-renewal[force renewal]' \
  '*--renew-hook=[hook]:c:' \
  '*--pre-hook=[hook]:c:' \
  '*--post-hook=[hook]:c:' \
  '*--deploy-hook=[hook]:c:' \
  '*--disable-hook-validation[no hook validation]' \
  '*--no-directory-hooks[no dir hooks]' \
  '*--disable-renew-updates[no renew updates]' \
  '*--no-autorenew[no autorenew]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'certbot command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
