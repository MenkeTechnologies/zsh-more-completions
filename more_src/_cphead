#compdef cphead
# _cphead — copy FITS header keywords between files (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from cphead.c (single-letter getopt-style).

_cphead() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-a[copy entire header]' \
        '-d+[root directory for input files]:dir:_files -/' \
        '-h+[HISTORY string]:hist:' \
        '-k+[set CPHEAD keyword]:keyword:' \
        '-n[write new file]' \
        '-p+[decimal places]:n:' \
        '-v[verbose output]' \
        '-w[copy entire WCS]' \
        '1:source FITS file:_files -g "*.(fits|fit|fts)"' \
        '*:target FITS file or keyword:_files -g "*.(fits|fit|fts)"'
}

_cphead "$@"
