#compdef c_rehash
# Documentation: man openssl-rehash(1) / c_rehash(1ssl)
# Source: OpenSSL c_rehash — create symbolic links named by certificate hash.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '-old[use old (pre-1.0.0) hash format]' \
    '-n[skip removing old links before rehashing]' \
    '-v[verbose output]' \
    '*-provider+[OpenSSL provider to load]:name:' \
    '*-provider-path+[provider search path]:path:_files -/' \
    '*-provparam+[provider parameter ([name:]key=value)]:param:' \
    '-propquery+[property query]:propq:' \
    '*:certificate directory:_files -/' \
    && ret=0

return ret
