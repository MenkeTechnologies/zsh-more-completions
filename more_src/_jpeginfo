#compdef jpeginfo
# Documentation: https://manpages.debian.org/bookworm/jpeginfo/jpeginfo.1.en.html
# Reference accessed: 2026-05-30
# jpeginfo — Timo Kokkonen's libjpeg-based info dumper. Prints dimensions,
# colour info, optional MD5/SHA-256/SHA-512 checksums; can delete files that
# fail integrity check.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)--version[show version and exit]' \
  '(-c --check)'{-c,--check}'[scan files for errors (default is headers only)]' \
  '(-C --comments)'{-C,--comments}'[display COM-marker comments]' \
  '(-d --delete)'{-d,--delete}'[delete files that have errors]' \
  '(-m --mode)'{-m,--mode=}'[delete mode (only with -d)]:mode:(all erronly)' \
  '(-f --file)'{-f,--file=}'[read filenames from FILE (- for stdin)]:list-file:_files' \
  '(- --stdin)--stdin[read image data from stdin]' \
  '-[read image data from stdin (alias for --stdin)]' \
  '(-H --header)'{-H,--header}'[print column-name header row]' \
  '(-2 --sha256)'{-2,--sha256}'[compute SHA-256 per file]' \
  '--sha512[compute SHA-512 per file]' \
  '(-5 --md5)'{-5,--md5}'[compute MD5 per file]' \
  '(-i --info)'{-i,--info}'[show extended info (coding, density, CCIR601)]' \
  '(-l --lsstyle -j --json -s --csv -q --quiet)'{-l,--lsstyle}'[ls -l style listing]' \
  '(-l --lsstyle -j --json -s --csv -q --quiet)'{-j,--json}'[JSON output]' \
  '(-l --lsstyle -j --json -s --csv -q --quiet)'{-s,--csv}'[CSV output]' \
  '(-l --lsstyle -j --json -s --csv -q --quiet)'{-q,--quiet}'[quiet mode (jpeg info only)]' \
  '(-v --verbose)'{-v,--verbose}'[verbose (positively chatty)]' \
  '*:jpeg file:_files -g "*.(jpg|jpeg|jpe|jfif|jif)"' \
  && ret=0

return ret
