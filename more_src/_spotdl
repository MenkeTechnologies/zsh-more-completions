#compdef spotdl

# Zsh completion for spotdl - Spotify downloader

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'download:download songs'
  'save:save songs metadata to file'
  'web:start web UI'
  'sync:sync a playlist to a directory'
  'url:get download URLs for songs'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--audio[audio provider]:provider:(youtube youtube-music piped bandcamp soundcloud)' \
  '--lyrics[lyrics provider]:provider:(genius musixmatch azlyrics synced)' \
  '--output[output path template]:template' \
  '--format[output format]:format:(mp3 flac ogg opus m4a wav)' \
  '--bitrate[audio bitrate]:bitrate:(auto 128k 192k 256k 320k)' \
  '--cookie-file[path to cookies file]:file:_files' \
  '--ffmpeg[path to ffmpeg binary]:file:_files' \
  '--threads[number of download threads]:threads' \
  '--overwrite[overwrite existing files]:mode:(skip metadata force)' \
  '--restrict[restrict characters in filenames]' \
  '--print-errors[print errors]' \
  '--sponsor-block[skip sponsor segments]' \
  '--preload[preload search results]' \
  '--archive[archive file for skipping songs]:file:_files' \
  '--log-level[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--simple-tui[use simple TUI]' \
  '--headless[headless mode]' \
  '1:command:->command' \
  '*:query or URL' && ret=0

case $state in
  command)
    _describe -t commands 'spotdl command' commands && ret=0
    ;;
esac

return ret
