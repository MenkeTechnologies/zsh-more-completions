#compdef spotdl
# Documentation: https://github.com/spotDL/spotify-downloader
# Reference accessed: 2026-05-21
# Verified: upstream spotDL/spotify-downloader README.

# Zsh completion for spotdl - Spotify downloader

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'download:download songs from YouTube and embed metadata'
  'save:store metadata from Spotify without downloading'
  'web:launch web interface'
  'url:generate download URLs for each song'
  'sync:update directory by comparing with playlist state'
  'meta:update metadata for provided song files'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--save-file[where to save metadata or sync files]:file:_files -g "*.spotdl"' \
  '--download-ffmpeg[install ffmpeg to spotdl directory]' \
  '--download-deno[install Deno to spotdl directory]' \
  '1:command:->command' \
  '*:query or URL' && ret=0

case $state in
  command)
    _describe -t commands 'spotdl command' commands && ret=0
    ;;
esac

return ret
