#compdef tlrc tldr

# tlrc TLDR client completion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-l,--list}'[list all available pages]' \
  {-r,--render}'[render a local file]:file:_files' \
  {-u,--update}'[update the local cache]' \
  {-c,--clean-cache}'[clean the local cache]' \
  {-p,--platform}'=[specify platform]:platform:(linux osx windows sunos android common)' \
  {-L,--language}'=[specify language]:language' \
  '--color=[color output]:color:(auto always never)' \
  '--config=[config file path]:config file:_files' \
  '--no-config[do not load config file]' \
  {-q,--quiet}'[suppress informational messages]' \
  '1:command name:' \
  && ret=0

return ret
