#compdef sphinx-intl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'update:update language po files from pot'
  'build:build language po files into mo'
  'stat:print statistics for all po files'
  'create-transifexrc:create transifexrc file (deprecated)'
  'create-txconfig:create .tx/config'
  'update-txconfig-resources:update resources in .tx/config'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sphinx-intl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (update)
        _arguments \
          '(-d --locale-dir)'{-d,--locale-dir=}'[locale directory]:dir:_files -/' \
          '(-p --pot-dir)'{-p,--pot-dir=}'[pot directory]:dir:_files -/' \
          '*'{-l,--language=}'[language]:lang:' \
          '(-w --line-width)'{-w,--line-width=}'[line width]:width:' \
          '--no-obsolete[remove obsolete entries]' \
          '(-j --jobs)'{-j,--jobs=}'[parallel jobs]:n:' && ret=0
        ;;
      (build)
        _arguments \
          '(-d --locale-dir)'{-d,--locale-dir=}'[locale directory]:dir:_files -/' \
          '(-o --output-dir)'{-o,--output-dir=}'[output directory]:dir:_files -/' \
          '*'{-l,--language=}'[language]:lang:' && ret=0
        ;;
      (stat)
        _arguments \
          '(-d --locale-dir)'{-d,--locale-dir=}'[locale directory]:dir:_files -/' \
          '*'{-l,--language=}'[language]:lang:' && ret=0
        ;;
      (update-txconfig-resources)
        _arguments \
          '--transifex-organization-name=[Transifex org]:org:' \
          '--transifex-project-name=[Transifex project]:project:' \
          '(-d --locale-dir)'{-d,--locale-dir=}'[locale directory]:dir:_files -/' \
          '(-p --pot-dir)'{-p,--pot-dir=}'[pot directory]:dir:_files -/' && ret=0
        ;;
      (create-transifexrc)
        _arguments '--transifex-token=[Transifex token]:token:' && ret=0
        ;;
    esac
    ;;
esac

return ret
