#compdef crm114 crm
# Documentation: https://man.archlinux.org/search?q=crm114
# Reference accessed: 2026-05-16

# Debian crm(1) / CRM114 — crm [OPTION]... CRMFILE [positional args]
# Flags for tracing, debugger, feature window sizing, etc.

_arguments -s -S \
  '-d+[enter debugger after N cycles (omit N for 0)]::cycles:' \
  '-e[do not import environment variables]' \
  '-h[print bundled help text]' \
  '-p[emit execution-time profile on exit]' \
  '-P+[max program lines]::lines:' \
  '-q+[math mode (0-3; alg vs RPN; EVAL-only vs global)]::mode:' \
  '-s+[.css feature file size (bytes)]::bytes:' \
  '-S+[feature file size snapped to 2^n+1 slots]::bytes:' \
  '-t[enable user trace output]' \
  '-T[enable implementor trace output]' \
  '-u+[chdir before running]:directory:_files -/' \
  '-v[print CRM114 version and exit]' \
  '-w+[max data window in bytes (default ~16MB)]::bytes:' \
  '--[end of CRM114 flags; remaining words are user program args]' \
  '1:CRM114 program:_files -g "*.crm(-.)"' \
  '*:user program positional args:_normal'
