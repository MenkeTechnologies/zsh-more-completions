#compdef gh-actions-cache
# Documentation: https://github.com/actions/gh-actions-cache
# Source: actions/gh-actions-cache — gh CLI extension to manage GitHub Actions caches.
# Reference accessed: 2026-06-01
# Also reachable as `gh actions-cache <subcommand>`.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _gac_cmds
_gac_cmds=(
    'list:list active Actions caches'
    'delete:delete caches by key'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'gh-actions-cache command' _gac_cmds && ret=0
        ;;
    args)
        case $line[1] in
            list)
                _arguments -s -S \
                    '(-R --repo)'{-R+,--repo=}'[[HOST/]owner/repo]:repo:_default' \
                    '(-B --branch)'{-B+,--branch=}'[filter by branch]:branch:_default' \
                    '(-L --limit)'{-L+,--limit=}'[max items (default 30, max 100)]:n:_default' \
                    '--key=[filter by key or key prefix]:key:_default' \
                    '--order=[sort order]:order:(asc desc)' \
                    '--sort=[sort criteria]:criteria:(last-used size created-at)' \
                    && ret=0
                ;;
            delete)
                _arguments -s -S \
                    '(-R --repo)'{-R+,--repo=}'[[HOST/]owner/repo]:repo:_default' \
                    '(-B --branch)'{-B+,--branch=}'[branch (full ref form)]:branch:_default' \
                    '--confirm[skip confirmation prompt]' \
                    '*:cache key:_default' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
