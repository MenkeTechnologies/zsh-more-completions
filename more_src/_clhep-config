#compdef clhep-config
# Documentation: https://manpages.debian.org/testing/libclhep-dev/clhep-config.1.en.html
# return configuration of the installed CLHEP library

local ret=1

_arguments -s -S \
  '(- *)--help[display help and exit]' \
  '(- *)--version[output version information]' \
  '--prefix[show installation prefix]' \
  '--cxx[print C++ compilation command]' \
  '--cpp[print pre-processor commands]' \
  '--include[print include path]' \
  '--ldflags[print linker flags]' \
  '--libs[print libraries to link against]' && ret=0

return ret
