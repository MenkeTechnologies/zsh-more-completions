#compdef dh_dwz
# Documentation: https://manpages.debian.org/dh_dwz
# Source: Debian/debhelper dh_dwz — optimise DWARF debug info via dwz (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a --arch)'{-a,--arch}'[only arch-dep packages]' \
    '(-i --indep)'{-i,--indep}'[only arch-indep packages]' \
    '*-p+[apply to package]:pkg:_default' \
    '*-N+[skip package]:pkg:_default' \
    '*-X+[exclude pattern]:pattern:_default' \
    '--no-act[do not act]' \
    '(--no-dwz-multifile)--dwz-multifile[create multi-file]' \
    '(--dwz-multifile)--no-dwz-multifile[do not create multi-file]' \
    '*-O+[passthrough option]:opt:_default' \
    && ret=0

return ret
