#compdef fixelcfestats
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/fixelcfestats.html
# fixel-based analysis of statistics across subjects using connectivity-based fixel enhancement

local ret=1

_arguments -s -S \
  '-mask=[provide fixel mask for processing]:file:_files' \
  '-notest[output population statistics only; skip inference]' \
  '-nshuffles=[number of shuffles (default 5000)]:number' \
  '-strong[use strong familywise error control]' \
  '-errors=[error nature]:spec:(ee ise both)' \
  '-exchange_within=[exchange blocks within observations]:file:_files' \
  '-exchange_whole=[exchange blocks between observations]:file:_files' \
  '-permutations=[manually define permutation matrix]:file:_files' \
  '-nonstationarity[perform empirical non-stationarity correction]' \
  '-skew_nonstationarity=[skew parameter (default 1)]:value' \
  '-nshuffles_nonstationarity=[shuffles for empirical statistics]:number' \
  '-permutations_nonstationarity=[manual permutation matrix for correction]:file:_files' \
  '-cfe_dh=[height increment (default 0.1)]:value' \
  '-cfe_e=[extent exponent (default 2)]:value' \
  '-cfe_h=[height exponent (default 3)]:value' \
  '-cfe_c=[connectivity exponent (default 0.5)]:value' \
  '-cfe_legacy[use legacy non-normalised CFE equation]' \
  '-variance=[define variance groups for G-statistic]:file:_files' \
  '-ftests=[F-test specification file]:file:_files' \
  '-fonly[F-tests only; skip contrast matrix inference]' \
  '*-column=[add subject fixel-wise values column]:file:_files' \
  '-info[display information messages]' \
  '-quiet[suppress information and progress messages]' \
  '-debug[display debugging messages]' \
  '-force[force overwrite of output files]' \
  '-nthreads=[number of threads]:number' \
  '-config=[temporarily set a config entry]:key:_default:value' \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[display version information]' \
  '1:in_fixel_directory:_files -/' \
  '2:subjects:_files' \
  '3:design:_files' \
  '4:contrast:_files' \
  '5:connectivity:_files' \
  '6:out_fixel_directory:_files -/' && ret=0

return ret
