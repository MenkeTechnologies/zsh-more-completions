#compdef wifipumpkin3
# Rogue access point framework for Wi-Fi security auditing

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--no-colors[disable colored output]' \
  '--pulp[interactive shell mode]' \
  '--xpulp[execute commands and exit]:commands:' \
  '--wireless-mode[set wireless mode]:mode:' \
  '--restapi[start REST API server]' \
  '-i[network interface]:interface:' \
  '-s[session file]:file:_files' \
  && return 0
