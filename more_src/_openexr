#compdef exrheader exrinfo exrmaketiled exrenvmap exr2aces exrmultipart exrmultiview exrstdattr exrcheck openexr
# _openexr — Industrial Light Magic OpenEXR exrheader exrinfo exrmaketiled exrenvmap CLI tools for high dynamic range image format (AcademySoftwareFoundation team, C++); getopt
# upstream: https://github.com/AcademySoftwareFoundation/openexr

_openexr() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-l[list metadata]' \
        '--list[list metadata]' \
        '-s+[scanline size]:n:' \
        '-t+[tile size]:str:' \
        '--tile=+[tile size]:str:' \
        '-r[rip-map]' \
        '--rip[rip-map]' \
        '-m+[mode]:m:(scanline tiles)' \
        '-c+[compression]:c:(NO RLE ZIPS ZIP PIZ PXR24 B44 B44A DWAA DWAB)' \
        '--compression=+[compression]:c:(NO RLE ZIPS ZIP PIZ PXR24 B44 B44A DWAA DWAB)' \
        '-q+[DWA compression level]:n:' \
        '--dwa-level=+[DWA compression level]:n:' \
        '--type=+[envmap type]:e:(latlong cube)' \
        '--filter=+[filter mode]:f:(box gauss)' \
        '--padding=+[N]:n:' \
        '--padmode=+[mode]:m:(0 1)' \
        '--scanline[output scanline]' \
        '--mipmap-levels=+[N]:n:' \
        '--ripmap-levels=+[N]:n:' \
        '-p+[part number]:n:' \
        '--part=+[part number]:n:' \
        '-X+[x offset]:n:' \
        '-Y+[y offset]:n:' \
        '-w+[output width]:n:' \
        '-H+[output height]:n:' \
        '--no-mipmap[no mipmap]' \
        '--keep-views[keep views]' \
        '--combine[combine parts]' \
        '--split[split parts]' \
        '*:exr file:_files -g "*.exr *.aces *.dpx *.cin *.tiff *.tif *.tx"'
}

_openexr "$@"
