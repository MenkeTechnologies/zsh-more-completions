#compdef airmon-zc
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man8/airmon-zc.8.html
# bash script designed to turn wireless cards into monitor mode, Zero_Chaos version

local ret=1

_arguments -s -S \
  '1:command:((start\:"enable monitor mode on an interface" stop\:"disable monitor mode, back to managed" check\:"list/kill interfering programs"))' \
  '2:interface or kill:_files' \
  '3:channel:' && ret=0

return ret
