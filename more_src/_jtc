#compdef jtc
# Documentation: https://github.com/ldn-softdev/jtc
# JSON test console: walk, transform and edit JSON

local ret=1

_arguments -s \
  '(-g)-g[mini USER-GUIDE: walk path syntax, usage notes, examples]' \
  '*-a[process all JSONs from source, or disable multithreading]' \
  '-c[compare with JSON: display delta between two JSONs]' \
  '*-d[turn on debugs (multiple calls increase verbosity)]' \
  '-e[make option parameters for -i/-u be processed via shell]' \
  '-f[apply changes into the file argument instead of printing JSON]' \
  '*-i[insert JSON (given as JSON/walk/template)]' \
  '-J[wrap all processed JSONs into an array]' \
  '-j[wrap all walked elements from one JSON into a JSON array]' \
  '*-l[print labels (if present) for walked JSONs]' \
  '*-m[modifier: toggle merging for options -i, -u, -c]' \
  '*-n[do not print/process walks interleaved]' \
  '*-p[purge all walked JSON elements]' \
  '*-q[enforce strict quoted solidus parsing]' \
  '*-r[print JSON in a raw (compact, one-line) format]' \
  '-s[swap around JSON elements pointed by pairs of walks]' \
  '*-T[a template to interpolate and apply upon -i/-u]' \
  '-t[indent for pretty printing]' \
  '*-u[update with JSON (given as JSON/walk/template)]' \
  '*-w[a standalone walk path (multiple may be given)]' \
  '-x[a common part of a walk-path, prepended to every -y]' \
  '*-y[an individual part of a walk-path, prepended by preceding -x]' \
  '*-z[print size (number of nodes in JSON) at end of output]' \
  '*:file:_files' && ret=0

return ret
