#compdef azcopy

# Zsh completion for azcopy (Azure Storage copy tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'bench:run a performance benchmark'
  'completion:generate shell completions'
  'copy:copy data between source and destination (alias: cp)'
  'doc:generate documentation in Markdown format'
  'env:show environment variables that configure azcopy'
  'jobs:manage transfer jobs'
  'list:list entities in a given resource'
  'login:log in to Azure Active Directory'
  'logout:log out to terminate access'
  'make:create a container or file share'
  'remove:delete blobs or files (alias: rm)'
  'set-properties:set properties on blobs or files'
  'sync:replicate source to destination'
)

_arguments -s -S \
  '--cap-mbps[cap transfer rate in megabits per second]:rate:' \
  '--log-level[log verbosity]:level:(NONE DEBUG INFO WARNING ERROR PANIC FATAL)' \
  '--output-level[output verbosity]:level:(default essential quiet)' \
  '--output-type[format of output]:type:(text json)' \
  '--trusted-microsoft-suffixes[trusted Azure AD suffixes]:suffixes:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'azcopy command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (copy|cp)
        _arguments \
          '--blob-type[type of blob]:type:(Detect BlockBlob PageBlob AppendBlob)' \
          '--block-blob-tier[tier for block blobs]:tier:(None Hot Cool Cold Archive)' \
          '--page-blob-tier[tier for page blobs]:tier:(None P10 P15 P20 P30 P40 P50 P60)' \
          '--block-size-mb[block size in MiB]:size:' \
          '--check-length[check length after transfer]' \
          '--check-md5[validate MD5 hashes]:policy:(NoCheck LogOnly FailIfDifferent FailIfDifferentOrMissing)' \
          '--content-type[content type]:type:' \
          '--decompress[auto decompress downloads]' \
          '--exclude-path[exclude paths]:paths:' \
          '--exclude-pattern[exclude file patterns]:patterns:' \
          '--exclude-regex[exclude regex patterns]:patterns:' \
          '--follow-symlinks[follow symbolic links]' \
          '--force-if-read-only[force overwrite of read-only files]' \
          '--from-to[source-destination combination]:combination:' \
          '--include-after[include files modified after date]:date:' \
          '--include-before[include files modified before date]:date:' \
          '--include-path[include only paths]:paths:' \
          '--include-pattern[include only file patterns]:patterns:' \
          '--include-regex[include only regex patterns]:patterns:' \
          '--overwrite[overwrite existing files]:policy:(true false prompt ifSourceNewer)' \
          '--put-md5[create MD5 hash and store as property]' \
          '--recursive[recurse into subdirectories]' \
          '--s2s-preserve-access-tier[preserve access tier in S2S copies]' \
          '1:source:_files' \
          '2:destination:_files' && ret=0
        ;;
      (sync)
        _arguments \
          '--block-size-mb[block size in MiB]:size:' \
          '--check-md5[validate MD5 hashes]:policy:(NoCheck LogOnly FailIfDifferent FailIfDifferentOrMissing)' \
          '--delete-destination[delete extra files at destination]:policy:(true false prompt)' \
          '--exclude-path[exclude paths]:paths:' \
          '--exclude-pattern[exclude file patterns]:patterns:' \
          '--include-pattern[include file patterns]:patterns:' \
          '--put-md5[create MD5 hash]' \
          '--recursive[recurse into subdirectories]' \
          '--s2s-preserve-access-tier[preserve access tier]' \
          '1:source:_files' \
          '2:destination:_files' && ret=0
        ;;
      (remove|rm)
        _arguments \
          '--exclude-path[exclude paths]:paths:' \
          '--exclude-pattern[exclude patterns]:patterns:' \
          '--include-path[include paths]:paths:' \
          '--include-pattern[include patterns]:patterns:' \
          '--list-of-files[file containing list to delete]:file:_files' \
          '--recursive[recurse into subdirectories]' \
          '1:resource URL:' && ret=0
        ;;
      (login)
        _arguments \
          '--aad-endpoint[Azure AD endpoint]:url:_urls' \
          '--application-id[application ID for SPN]:id:' \
          '--cert-path[certificate path for SPN]:file:_files' \
          '--identity[log in using VM managed identity]' \
          '--identity-client-id[client ID of user-assigned identity]:id:' \
          '--identity-object-id[object ID of user-assigned identity]:id:' \
          '--identity-resource-id[resource ID of user-assigned identity]:id:' \
          '--service-principal[log in via SPN]' \
          '--tenant-id[Azure AD tenant ID]:id:' && ret=0
        ;;
      (list)
        _arguments \
          '--machine-readable[show file sizes in bytes]' \
          '--mega-units[show sizes in MB not MiB]' \
          '--running-tally[count total files and sizes]' \
          '1:resource URL:' && ret=0
        ;;
      (jobs)
        local -a job_cmds=('clean:clean up job files' 'list:list all jobs' 'remove:remove a job' 'resume:resume a job' 'show:show a job')
        _arguments '1:jobs command:((${(j: :)${job_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
