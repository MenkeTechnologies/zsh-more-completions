#compdef cphstats
# Documentation: https://biobb-amber.readthedocs.io/en/latest/cphstats.html
# AmberTools: compute statistics from constant pH MD cpout files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-O[allow existing outputs to be overwritten]' \
  '(-i --cpin)'{-i,--cpin}'+[input cpin file with titrating residue info]:file:_files' \
  '(-o --calcpka-output)'{-o,--calcpka-output}'+[calcpka-style output file]:file:_files' \
  '--population=[output file for protonation state populations]:file:_files' \
  '--chunk=[compute pKas over chunks of WINDOW steps]:window' \
  '--chunk-out=[chunk output file]:file:_files' \
  '--cumulative[compute cumulative average time series]' \
  '--cumulative-out=[cumulative output file]:file:_files' \
  '--running-avg=[running average window in MD steps]:window' \
  '--running-avg-out=[running average output file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'+[verbosity level]:level' \
  '(-n --interval)'{-n,--interval}'+[interval between time series points]:interval' \
  '--time-step=[time step in ps]:ps' \
  '(-p --protonated)'{-p,--protonated}'[print fraction protonated]' \
  '(-d --deprotonated)'{-d,--deprotonated}'[print fraction deprotonated]' \
  '--calcpka[trigger calcpka-style output]' \
  '--no-calcpka[disable calcpka-style output]' \
  '--fix-remd=[re-order cpout files from a pH-REMD run]:prefix' \
  '*-c+[conditional probability condition]:condition' \
  '--conditional-output=[conditional probability output file]:file:_files' \
  '--chunk-conditional=[conditional chunk output file]:file:_files' && ret=0

return ret
