#compdef waline
# _waline — Waline simple comment system for static sites CLI alias (walinejs team, TypeScript); cac
# upstream: https://github.com/walinejs/waline

_waline() {
    local -a sub=(
        'dev:start dev server'
        'start:start production server'
        'export:export comments'
        'import:import comments'
        'migrate:migrate from another system'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--server-url=+[server url]:url:_urls' \
        '--token=+[token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'waline subcommand' sub ;;
        args)
            case $words[1] in
                dev|start) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--db=+[db type]:db:(mysql postgresql sqlite mongodb leancloud cloudbase deta vercel-postgres mariadb)' ;;
                export) _arguments \
                    '--out=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--format=+[format]:f:(json csv)' ;;
                import) _arguments \
                    '--file=+[input file]:file:_files' \
                    '-f+[input file]:file:_files' \
                    '--type=+[source type]:t:(disqus valine artalk twikoo livere)' ;;
                migrate) _arguments \
                    '1:from:(disqus valine twikoo artalk livere)' \
                    '--file=+[file]:file:_files' ;;
            esac
            ;;
    esac
}

_waline "$@"
