#compdef mdq
# Documentation: https://man.archlinux.org/search?q=mdq
# Reference accessed: 2026-05-16

# CLI flags from https://github.com/yshavit/mdq (src/run/cli.rs, output/fmt_md.rs, output/link_transform.rs)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--link-pos=[link reference placement]:placement:(section doc)' \
  '--footnote-pos=[footnote reference placement]:placement:(section doc)' \
  '--link-format=[link output style]:format:(keep inline never-inline)' \
  '--renumber-footnotes[renumber numeric link references]' \
  '--no-renumber-footnotes[disable renumbering of link references]' \
  {-o,--output}'=[output format]:format:(markdown md json plain)' \
  '--wrap-width=[wrap plain-text at width in markdown output]:width:' \
  {-q,--quiet}'[no stdout; exit status indicates matches]' \
  '--br[add blank line or thematic break between elements]' \
  '--no-br[omit breaks between elements]' \
  '*:markdown path or selector:_files' && ret=0

return ret
