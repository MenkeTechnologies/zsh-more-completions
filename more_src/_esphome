#compdef esphome
# Documentation: https://esphome.io/guides/cli.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for esphome (ESPHome IoT firmware tool)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '(-q --quiet)'{-q,--quiet}'[disable all non-error logging]' \
  '(-s --substitution)'{-s+,--substitution=}'[substitution key value]:substitution (KEY VALUE)' \
  '(-V --version)'{-V,--version}'[print ESPHome version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:validate and print config'
      'config-hash:print hash of the configuration'
      'compile:read configuration and compile firmware'
      'upload:validate config and upload latest binary'
      'logs:validate config and show all logs'
      'discover:show all discovered devices'
      'run:validate, compile, upload, show logs'
      'clean-mqtt:clear retained MQTT discovery messages'
      'wizard:interactive setup wizard'
      'version:print ESPHome version'
      'clean:delete all temporary build files'
      'clean-all:clean all build and platform files'
      'dashboard:start the dashboard web server'
      'vscode:helper used by the VS Code extension'
      'update-all:compile and upload to multiple devices'
      'idedata:generate IDE metadata for PlatformIO'
      'rename:rename a device in the config'
      'analyze-memory:analyze memory usage by component'
      'bundle:create a self-contained config bundle'
    )
    _describe -t commands 'esphome command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      config|compile|upload|logs|run|clean|idedata|discover|analyze-memory|bundle|update-all|config-hash|clean-all)
        _arguments \
          '--device=[upload device/port]:device' \
          '--no-logs[do not show logs after uploading]' \
          '*:config file:_files -g "*.yaml"' && ret=0
        ;;
      dashboard)
        _arguments \
          '--address=[address for the dashboard]:address' \
          '--port=[HTTP port for dashboard]:port' \
          '--username=[username for HTTP auth]:username' \
          '--password=[password for HTTP auth]:password' \
          '--open-ui[open dashboard in browser]' \
          '--ha-addon[run as Home Assistant add-on]' \
          '--socket=[unix socket path]:socket path:_files' \
          '*:config directory:_directories' && ret=0
        ;;
      rename)
        _arguments \
          '1:config file:_files -g "*.yaml"' \
          '2:new name' && ret=0
        ;;
      wizard)
        _arguments \
          '*:output file:_files -g "*.yaml"' && ret=0
        ;;
      vscode)
        _arguments \
          '--ace[enable Ace editor protocol]' \
          '1:configuration file:_files -g "*.yaml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
