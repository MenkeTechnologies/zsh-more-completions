#compdef esphome

# Zsh completion for esphome (ESPHome IoT firmware tool)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Show help]' \
  '--help[Show help]' \
  '-v[Enable verbose logging]' \
  '--verbose[Enable verbose logging]' \
  '-q[Disable all non-error logging]' \
  '--quiet[Disable all non-error logging]' \
  '-s+[Substitution key=value]:substitution (KEY=VALUE):' \
  '--substitution=[Substitution key=value]:substitution (KEY=VALUE):' \
  '-V[Print ESPHome version]' \
  '--version[Print ESPHome version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:Validate and print config'
      'compile:Compile and validate firmware'
      'upload:Upload firmware to the device'
      'logs:Show device logs'
      'run:Compile, upload, and show logs'
      'clean-mqtt:Clear retained MQTT messages'
      'wizard:Create a basic config via wizard'
      'mqtt-fingerprint:Get SSL fingerprint for MQTT broker'
      'version:Print ESPHome version'
      'clean:Delete all temporary build files'
      'dashboard:Start the ESPHome dashboard web server'
      'rename:Rename a device in the config'
      'idedata:Generate IDE metadata for PlatformIO'
    )
    _describe -t commands 'esphome command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      config|compile|upload|logs|run|clean|idedata)
        _arguments \
          '--device=[Manually specify upload device/port]:device:' \
          '--no-logs[Do not show logs after uploading]' \
          '*:config file:_files -g "*.yaml"' && ret=0
        ;;
      dashboard)
        _arguments \
          '--port=[HTTP port for dashboard]:port:' \
          '--username=[Username for HTTP auth]:username:' \
          '--password=[Password for HTTP auth]:password:' \
          '--open-ui[Open the dashboard in browser]' \
          '--ha-addon[Run as Home Assistant add-on]' \
          '--socket=[Unix socket path]:socket path:_files' \
          '*:config directory:_directories' && ret=0
        ;;
      rename)
        _arguments \
          '1:config file:_files -g "*.yaml"' \
          '2:new name:' && ret=0
        ;;
      wizard)
        _arguments \
          '*:output file:_files -g "*.yaml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
