#compdef yurt-tunnel-server
# _yurt-tunnel-server — OpenYurt cloud-side tunnel server (openyurtio/openyurt)
# upstream: https://github.com/openyurtio/openyurt
# Flags from cmd/yurt-tunnel-server/app/options/options.go (pflag).

_yurt-tunnel-server() {
    _arguments \
        '--version[print version and exit]' \
        '--kube-config=[kubeconfig file]:file:_files' \
        '--bind-address=[secure listen address]:ip:' \
        '--insecure-bind-address=[insecure listen address]:ip:' \
        '--cert-dns-names=[DNS names added to server certificate]:list:' \
        '--cert-ips=[IPs added to server certificate]:list:' \
        '--cert-dir=[certificate directory]:dir:_files -/' \
        '--enable-iptables[allow iptable manager to set DNAT rules]' \
        '--enable-dns-controller[allow DNS controller to set DNS rules]' \
        '--egress-selector-enable[apiserver egress selector enabled]' \
        '--iptables-sync-period=[iptables sync period (s)]:s:' \
        '--dns-sync-period=[DNS controller sync period (s)]:s:' \
        '--server-count=[number of proxy server instances]:n:' \
        '--proxy-strategy=[strategy for proxying requests to agents]:strategy:' \
        '--tunnel-agent-connect-port=[port for agent TCP packets]:port:'
}

_yurt-tunnel-server "$@"
