#compdef mlaunch
# Documentation: https://rueckstiess.github.io/mtools/
# mtools utility to quickly set up MongoDB test environments

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--verbose[print additional information]' \
  '--dir=[data directory]:dir:_files -/' \
  '1:command:(init start stop restart kill list)' \
  '--single[create standalone nodes]' \
  '--replicaset[create replica set]' \
  '--nodes=[number of data-bearing nodes]:n' \
  '--arbiter[add one arbiter]' \
  '--name=[replica set name]:name' \
  '--sharded=[number or names of shards]:shards' \
  '--config=[number of config servers (1 or 3)]:n:(1 3)' \
  '--csrs[use config servers as replica set]' \
  '--mongos=[number of mongos instances]:n' \
  '--port=[starting port number]:port' \
  '--binarypath=[path to mongod/mongos binaries]:path:_files -/' \
  '--hostname=[hostname configuration]:hostname:_hosts' \
  '--auth[enable authentication]' \
  '--username=[username]:user' \
  '--password=[password]:password' \
  '--auth-db=[authentication database]:db' \
  '--auth-roles=[user roles]:roles' \
  '--no-initial-user[skip initial user creation]' \
  '--json[JSON output format (list)]' \
  '--tags[show node tags (list)]' \
  '--startup[show startup commands (list)]' \
  '--signal=[signal to send (kill)]:signal' \
  '*::args:_files' && ret=0

return ret
