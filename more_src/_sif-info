#compdef sif-info
# Documentation: https://man.archlinux.org/search?q=sif-info
# Reference accessed: 2026-05-16

# sif-info: print SIF header information (deprecated, use sif info)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*:SIF file:_files -g "*.sif"' && ret=0
return ret
