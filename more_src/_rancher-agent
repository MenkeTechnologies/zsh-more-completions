#compdef rancher-agent
# Documentation: https://man.archlinux.org/search?q=rancher-agent
# Reference accessed: 2026-05-16

# rancher-agent: Rancher cluster agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--server=[Rancher server URL]:url:' \
  '--token=[registration token]:token:' \
  '--ca-checksum=[CA checksum]:sha:' \
  '--node-name=[node name]:name:' \
  '--internal-address=[internal address]:addr:' \
  '--address=[external address]:addr:' \
  '--worker[register as worker]' \
  '--controlplane[register as controlplane]' \
  '--etcd[register as etcd]' \
  '--label=[label]:list:' \
  '--taint=[taint]:list:' \
  '--no-register[skip registration]' \
  '*::rancher-agent args:_files' && ret=0
return ret
