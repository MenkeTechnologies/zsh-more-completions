#compdef suinvzco3d
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/migration_inversion/suinvzco3d.c
# Seismic INVersion of Common Offset data with V(Z) velocity

local ret=1

_arguments -s -S \
  'nz=[nz]:nz:' \
  'nxm=[nxm]:nxm:' \
  'ny=[ny]:ny:' \
  'dt=[dt]:dt:' \
  'offs=[offs]:offs:' \
  'dxm=[dxm]:dxm:' \
  'fxm=[fxm]:fxm:' \
  'nxd=[nxd]:nxd:' \
  'dx=[dx]:dx:' \
  'fx=[fx]:fx:' \
  'dz=[dz]:dz:' \
  'nxb=[nxb]:nxb:' \
  'fxo=[fxo]:fxo:' \
  'dxo=[dxo]:dxo:' \
  'nxo=[nxo]:nxo:' \
  'fyo=[fyo]:fyo:' \
  'dyo=[dyo]:dyo:' \
  'nyo=[nyo]:nyo:' \
  'fzo=[fzo]:fzo:' \
  'dzo=[dzo]:dzo:' \
  'nzo=[nzo]:nzo:' \
  'fmax=[fmax]:fmax:' \
  'ang=[ang]:ang:' \
  'verbose=[verbose]:verbose:' \
  '*:file:_files' && ret=0

return ret
