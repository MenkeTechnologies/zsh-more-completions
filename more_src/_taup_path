#compdef taup_path
# Documentation: https://taup.readthedocs.io/en/latest/taup_path.html
# TauP seismic travel-time / raypath tool

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '(--mod --model)'{--mod,--model}'=[velocity model name]:model:(prem iasp91 ak135 ak135fcont ak135favg)' \
  '-h+[source depth in km]:depth:' \
  '(--evdepth --sourcedepth)'{--evdepth,--sourcedepth}'=[source depth in km]:depth:' \
  '(--stadepth --receiverdepth)'{--stadepth,--receiverdepth}'=[receiver depth in km]:depth:' \
  '(-p --ph --phase)'{-p,--ph,--phase}'=[phase names]:phases:' \
  '--rel=[phase names for relative times]:phases:' \
  '(--deg --degree)'{--deg,--degree}'=[distance in degrees]:deg:' \
  '(--km --kilometer)'{--km,--kilometer}'=[distance in km]:km:' \
  '--exactdegree=[exact distance in degrees]:deg:' \
  '--exactkilometer=[exact distance in km]:km:' \
  '--degreerange=[range of distances in degrees]:range:' \
  '--kilometerrange=[range of distances in km]:range:' \
  '(--sta --station)'{--sta,--station}'=[station lat lon]:latlon:' \
  '(--evt --event)'{--evt,--event}'=[event lat lon]:latlon:' \
  '--az=[azimuth in degrees]:az:' \
  '--baz=[back azimuth in degrees]:baz:' \
  '--eid=[event id]:eid:' \
  '--sid=[station id]:sid:' \
  '(--qml --quakeml)'{--qml,--quakeml}'=[QuakeML input file]:file:_files' \
  '--staxml=[StationXML input file]:file:_files' \
  '--phasefile=[phase definition file]:file:_files' \
  '--prop=[tool properties file]:file:_files' \
  '--takeoff=[takeoff angle in degrees]:deg:' \
  '--incident=[incident angle in degrees]:deg:' \
  '--scat=[scatterer depth and distance]:depthdeg:' \
  '--mw=[moment magnitude]:mw:' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '--json[JSON output]' \
  '--csv[CSV output]' \
  '--text[plain text output]' \
  '--html[HTML output]' \
  '(--first --onlyfirst)'{--first,--onlyfirst}'[only first arrival]' \
  '(--time --onlytime)'{--time,--onlytime}'[only travel time]' \
  '(--rayp --onlyrayp)'{--rayp,--onlyrayp}'[only ray parameter]' \
  '--amp[include amplitude factor]' \
  '--geodetic[use geodetic latitudes]' \
  '--debug[debug output]' \
  '--verbose[verbose output]' \
  '*:file:_files' && ret=0

return ret
