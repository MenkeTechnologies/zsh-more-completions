#compdef GoldsteinPhaseFiltering
# Documentation: https://github.com/senbox-org/s1tbx/blob/master/s1tbx-op-insar/src/main/java/org/esa/s1tbx/insar/gpf/GoldsteinFilterOp.java
# ESA SNAP gpt GoldsteinPhaseFiltering operator - Goldstein adaptive phase filtering

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show operator help]' \
  '-e[show detailed error messages with stack trace]' \
  '-t+[set target output file]:target:_files' \
  '-f+[set output file format]:format:(GeoTIFF GeoTIFF-BigTIFF HDF5 BEAM-DIMAP NetCDF4-CF)' \
  '-p+[read processing parameters from file]:param file:_files' \
  '-c+[set tile cache size in bytes]:size' \
  '-q+[set maximum parallelism]:threads' \
  '-x[clear internal tile cache after each tile row]' \
  '*-S-[define a source product location]:source=file:_files' \
  '*-D-[define a system property]:name=value' \
  '-Palpha=-[adaptive filter exponent]:alpha' \
  '-PFFTSizeString=-[FFT size]:size:(32 64 128 256)' \
  '-PwindowSizeString=-[window size]:size:(3 5 7)' \
  '-PuseCoherenceMask=-[use coherence mask]:bool:(true false)' \
  '-PcoherenceThreshold=-[the coherence threshold]:threshold' \
  '*:source product:_files' && ret=0

return ret
