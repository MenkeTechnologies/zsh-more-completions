#compdef seldon-deploy
# Documentation: https://man.archlinux.org/search?q=seldon-deploy
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'deploy:deploy a new version of a Seldon resource'
  'list:list Seldon Deploy resources'
  'get:get a single resource'
  'update:update an existing deployment'
  'delete:delete a deployment'
  'promote:promote a deployment between environments'
  'predict:send a prediction request'
  'login:login to Seldon Deploy (OIDC or basic)'
  'logout:clear stored credentials'
  'config:CLI configuration'
  'completion:generate shell completion'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--server=[Seldon Deploy server URL]:url:' \
  '(-n --namespace)'{-n+,--namespace=}'[target namespace]:namespace:' \
  '--user=[Seldon Deploy user]:user:' \
  '--password=[Seldon Deploy password]:password:' \
  '--sso[use OIDC SSO flow]' \
  '--oidc-server=[OIDC server URL]:url:' \
  '--oidc-client=[OIDC client id]:id:' \
  '--insecure[skip TLS verification]' \
  '--config=[config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'seldon-deploy command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy)
        _arguments \
          '(-f --file)'{-f+,--file=}'[deployment YAML file]:file:_files -g "*.{yaml,yml}"' \
          '--wait[wait for deployment to be ready]' \
          '--timeout=[wait timeout]:duration:' && ret=0 ;;
      (list|get)
        local -a list_resources=(
          'sdep:SeldonDeployments'
          'inferenceservice:InferenceServices'
          'isvc:InferenceServices alias'
          'experiment:experiments'
          'detector:outlier/drift detectors'
          'monitor:monitors'
          'auditlog:audit log entries'
          'requestlog:request log entries'
        )
        _describe -t res 'resource' list_resources && ret=0
        _arguments \
          '--output=[output format]:format:(json yaml table)' && ret=0 ;;
      (promote)
        _arguments \
          '--from=[source environment]:env:' \
          '--to=[target environment]:env:' \
          '--name=[deployment name]:name:' && ret=0 ;;
      (predict)
        _arguments \
          '--name=[deployment name]:name:' \
          '--data=[request payload]:json:' \
          '--data-file=[request payload file]:file:_files' \
          '--protocol=[protocol]:protocol:(seldon tensorflow v2)' && ret=0 ;;
      (login)
        _arguments \
          '--user=[username]:user:' \
          '--password=[password]:password:' \
          '--sso[OIDC SSO flow]' \
          '--oidc-server=[OIDC server URL]:url:' && ret=0 ;;
      (config)
        _arguments '*::sub:(set get list)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish)' && ret=0 ;;
    esac ;;
esac

return ret
