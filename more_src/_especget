#compdef especget
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/especget/node15.html
# XMM-Newton SAS: generate source/background spectra plus ARF and RMF files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--withfilestem=[use filestem for output file naming]:flag:(yes no)' \
  '--filestem=[stem for generating output filenames]:stem:' \
  '--srcspecset=[output source spectrum file]:file:_files' \
  '--bckspecset=[output background spectrum file]:file:_files' \
  '--srcarfset=[output effective area file (ARF)]:file:_files' \
  '--srcrmfset=[output redistribution matrix (RMF)]:file:_files' \
  '--srcexp=[expression for extracting source events]:expr:' \
  '--backexp=[expression for extracting background events]:expr:' \
  '--table=[table specifier pointing to event list]:table:' \
  '--withbadpixcorr=[incorporate bad pixels and chip gaps in ARF]:flag:(yes no)' \
  '--useodfatt=[use ODF attitude file for position]:flag:(yes no)' \
  '--extendedsource=[run arfgen with extended source parameters]:flag:(yes no)' \
  '--detxbins=[number of x bins in the detector map]:bins:' \
  '--detybins=[number of y bins in the detector map]:bins:' \
  '--withsourcepos=[manually define source position]:flag:(yes no)' \
  '--sourcecoords=[coordinate system for source position]:coords:' \
  '--sourcex=[x-position of source center]:x:' \
  '--sourcey=[y-position of source center]:y:' \
  '--witharfset=[control whether ARF production occurs]:flag:(yes no)' \
  '--withrmfset=[use existing RMF or generate new]:flag:(yes no)' \
  '--rmfset=[name of the RMF file to use]:file:_files' \
  '--withenergybins=[use custom energy grid]:flag:(yes no)' \
  '--energymin=[lower energy bound (keV)]:energy:' \
  '--energymax=[upper energy bound (keV)]:energy:' \
  '--nenergybins=[number of bins in the energy grid]:bins:' \
  '--a0removefiles=[cleanup files when ARF is zero/negative]:flag:(yes no)' \
  '*:event file:_files' && ret=0

return ret
