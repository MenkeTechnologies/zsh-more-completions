#compdef ip-route
# Documentation: https://man.archlinux.org/man/ip-route.8.en
# ip route - routing table management

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip route command' \
      'add[create new route]' 'del[delete route]' 'change[modify route]' \
      'append[add to multipath route]' 'replace[change or add route]' \
      'show[display routes]' 'flush[remove matching routes]' \
      'get[resolve single route]' 'save[export routing table]' \
      'restore[import routing table]' \
      'to[route destination prefix]' 'root[prefixes not shorter than]' \
      'match[prefixes not longer than]' 'exact[exact prefix]' \
      'via[nexthop router address]' 'dev[output device]' \
      'encap[tunnel encapsulation]' 'from[source address range]' \
      'src[preferred source address]' 'iif[input interface]' \
      'oif[output interface]' 'metric[route priority]' \
      'preference[route priority]' 'table[routing table id]' \
      'proto[routing protocol]' 'scope[route scope]' 'type[route type]' \
      'tos[type of service]' 'dsfield[type of service]' 'vrf[VRF device]' \
      'mtu[maximum transmission unit]' 'window[TCP advertise window]' \
      'rtt[round trip time]' 'rttvar[RTT variance]' 'cwnd[congestion window]' \
      'advmss[advertised MSS]' 'weight[multipath weight]' 'realm[route realm]' \
      'mark[firewall mark]' 'ttl-propagate[TTL inheritance]' \
      'nexthop[multipath nexthop]' 'nhid[nexthop object reference]' && ret=0
    ;;
esac

return ret
