#compdef legit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'branches:display available branches'
      'switch:switch to a branch'
      'sync:sync current branch with remote'
      'publish:publish current branch to remote'
      'unpublish:remove branch from remote'
      'undo:undo last commit, keeping changes'
      'sprout:create and switch to new branch from current'
      'graft:merge branch into current and delete it'
      'harvest:cherry-pick commits from a branch'
      'resync:sync stale branch with remote'
    )
    _describe -t commands 'legit command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (switch|unpublish|graft|harvest|resync)
        _arguments -s -S \
          '1:branch:__legit_branches' && ret=0
        ;;
      (sprout)
        _arguments -s -S \
          '1:new branch name' && ret=0
        ;;
      (branches|sync|publish|undo)
        ret=0
        ;;
    esac
    ;;
esac

__legit_branches() {
  local -a branches
  branches=(${${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"}})
  _describe -t branches 'branch' branches
}

return ret
