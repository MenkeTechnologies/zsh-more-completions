#compdef ccomps
# Documentation: man ccomps(1) (graphviz)
# Source: GraphViz ccomps — extract or count connected components.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s[no output; use return value]' \
    '(-x -X)-x[print connected components as separate graphs]' \
    '(-x -X)-X+[print only component containing node, or range/size selector]:selector:' \
    '-C[use clusters in component computation]' \
    '-z[sort components by size (largest first)]' \
    '-n[do not project subgraph structure]' \
    '-e[do not induce edges in components]' \
    '-v[print counts of nodes/edges/components]' \
    '-o+[output base file (split per component)]:file:_files' \
    '(- *)-?[show usage]' \
    '*:DOT file:_files -g "*.{dot,gv}"' \
    && ret=0

return ret
