#compdef cargo-report
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-report.html

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:report type:->report_type' \
  '*'{-v,--verbose}'[use verbose output]' \
  '--color=[coloring]:when:(auto always never)' \
  '*--config=[override cargo configuration]:KEY=VALUE_or_path' \
  '*-Z+[unstable cargo flag]:flag' && ret=0

case $state in
  report_type)
    local -a types=(
      'future-incompatibilities:report future-incompatible crate dependencies'
    )
    _describe -t types 'report type' types && ret=0
    ;;
esac

return ret
