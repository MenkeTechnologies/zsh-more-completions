#compdef alertmanager-cli amtool-cli
# _alertmanager-cli — Prometheus Alertmanager alertmanager-cli amtool-cli CLI command-line frontend to the Alertmanager API querying alerts firing-and-pending silences receivers cluster-state config-receivers-routes adding deleting expiring silences viewing alert groups for the de-facto Prometheus notification deduplication grouping routing service (Prometheus team, Go); kingpin
# upstream: https://prometheus.io/docs/alerting/latest/alertmanager/

_alertmanager-cli() {
    local -a sub=(
        'alert:alert operations'
        'silence:silence operations'
        'check-config:check Alertmanager configuration'
        'config:fetch live config'
        'cluster:cluster operations'
        'template:template operations'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--alertmanager.url=+[url]:str:' \
        '--tls.skip-verify[skip TLS verify]' \
        '--tls.ca-file=+[file]:file:_files' \
        '--tls.cert-file=+[file]:file:_files' \
        '--tls.key-file=+[file]:file:_files' \
        '--http.config.file=+[file]:file:_files -g "*.yaml *.yml"' \
        '--timeout=+[duration]:str:' \
        '-o+[output format]:f:(simple extended json yaml)' \
        '--output=+[format]:f:(simple extended json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'alertmanager-cli subcommand' sub ;;
        args)
            case $words[1] in
                alert) _arguments \
                    '1:op:(query add)' \
                    '--silenced=+[bool]:s:(true false)' \
                    '--inhibited=+[bool]:s:(true false)' \
                    '--unprocessed=+[bool]:s:(true false)' \
                    '--active=+[bool]:s:(true false)' \
                    '*:matcher:' ;;
                silence) _arguments \
                    '1:op:(query add expire import update)' \
                    '--duration=+[duration]:str:' \
                    '--start=+[time]:str:' \
                    '--end=+[time]:str:' \
                    '--author=+[user]:str:' \
                    '--comment=+[text]:str:' \
                    '*:matcher or id:' ;;
                cluster) _arguments '1:op:(show)' ;;
            esac
            ;;
    esac
}

_alertmanager-cli "$@"
