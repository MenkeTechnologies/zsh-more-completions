#compdef hardinfo hardinfo2

# Zsh completion for hardinfo/hardinfo2 - system profiler and benchmark

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --report)'{-r,--report}'[generate report]' \
  '(-f --format)'{-f,--format}'[report format]:format:(text html)' \
  '(-m --module)'{-m,--module}'[load specific module]:module' \
  '(-a --autoload)'{-a,--autoload}'[autoload modules]' \
  '(-l --list-modules)'{-l,--list-modules}'[list available modules]'
