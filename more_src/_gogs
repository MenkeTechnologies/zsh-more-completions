#compdef gogs
# Documentation: https://github.com/gogs/gogs
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcommands=(
      'web:start web server'
      'serv:SSH serv command (internal)'
      'hook:delegate commands to Git hooks'
      'cert:generate self-signed certificate'
      'admin:admin commands'
      'import:import locale files'
      'backup:backup repository data'
      'restore:restore from a backup'
      'help:show help for a command'
    )
    _describe -t commands 'gogs subcommand' subcommands && ret=0
    ;;
  args)
    _normal && ret=0
    ;;
esac

return ret
