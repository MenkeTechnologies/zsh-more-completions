#compdef optuna-cli optuna2
# _optuna-cli — Preferred Networks Optuna optuna-cli CLI command-line frontend wrapping the Optuna automatic hyperparameter optimization framework providing create-study delete-study tell ask trials best-trial best-trials studies study-statistics dashboard storage-management RDB-backend MLflow-tensorboard-integration sample TPE CMA-ES NSGA-II (Preferred Networks team, Python); click
# upstream: https://optuna.org/

_optuna-cli() {
    local -a sub=(
        'create-study:create a new study'
        'delete-study:delete a study'
        'study-names:list study names'
        'studies:list studies'
        'study-set-user-attr:set user attribute'
        'trials:list trials of a study'
        'best-trial:show best trial'
        'best-trials:show all best trials'
        'tell:report a trial value'
        'ask:get a new trial parameter set'
        'storage-upgrade:upgrade storage schema'
        'storage:storage management'
        'dashboard:start dashboard'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--storage=+[uri]:str:' \
        '--study-name=+[name]:str:' \
        '--direction=+[d]:d:(minimize maximize)' \
        '--directions=+[list]:str:' \
        '--sampler=+[s]:s:(TPESampler RandomSampler CmaEsSampler GridSampler PartialFixedSampler NSGAIISampler QMCSampler GPSampler)' \
        '--pruner=+[p]:p:(MedianPruner NopPruner PercentilePruner SuccessiveHalvingPruner HyperbandPruner ThresholdPruner PatientPruner)' \
        '--skip-if-exists[skip if study exists]' \
        '--load-if-exists[load if exists]' \
        '--n-trials=+[N]:n:' \
        '--timeout=+[sec]:n:' \
        '--n-jobs=+[N]:n:' \
        '--gc-after-trial[gc after trial]' \
        '--show-progress-bar[show progress bar]' \
        '--seed=+[N]:n:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'optuna-cli subcommand' sub ;;
    esac
}

_optuna-cli "$@"
