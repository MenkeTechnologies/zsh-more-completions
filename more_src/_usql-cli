#compdef usql
# Documentation: https://github.com/xo/usql
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --command)*'{-c+,--command=}'[run command]:cmd:' \
  '(-f --file)*'{-f+,--file=}'[execute file]:file:_files -g "*.sql"' \
  '(-w --no-password)'{-w,--no-password}'[no password]' \
  '(-W --password)'{-W,--password}'[force password]' \
  '(-X --no-rc)'{-X,--no-rc}'[no init file]' \
  '(-1 --single-transaction)'{-1,--single-transaction}'[single transaction]' \
  '*'{-v+,--set=}'[set variable]:var:' \
  '*'{-N+,--cset=}'[connection variable]:var:' \
  '(-J --json-lines)'{-J,--json-lines}'[JSON lines output]' \
  '(-G --field-separator)'{-G+,--field-separator=}'[field separator]:s:' \
  '(-z --field-separator-zero)'{-z,--field-separator-zero}'[null field sep]' \
  '(-R --record-separator)'{-R+,--record-separator=}'[record separator]:s:' \
  '(-0 --record-separator-zero)'{-0,--record-separator-zero}'[null record sep]' \
  '(-A --no-align)'{-A,--no-align}'[unaligned output]' \
  '(-a --echo-queries)'{-a,--echo-queries}'[echo queries]' \
  '(-b --echo-errors)'{-b,--echo-errors}'[echo errors]' \
  '(-e --echo-all)'{-e,--echo-all}'[echo all]' \
  '(-E --echo-hidden)'{-E,--echo-hidden}'[echo hidden]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-l --list)'{-l,--list}'[list databases]' \
  '(-L --log-file)'{-L+,--log-file=}'[log file]:file:_files' \
  '(-S --schema-discovery)'{-S,--schema-discovery}'[schema discovery]' \
  '(-T --table-attr)'{-T+,--table-attr=}'[table attrs]:attr:' \
  '(-x --expanded)'{-x,--expanded}'[expanded output]' \
  '(-t --tuples-only)'{-t,--tuples-only}'[tuples only]' \
  '(-H --html)'{-H,--html}'[HTML output]' \
  '(-U --user)'{-U+,--user=}'[user]:user:_users' \
  '(-P --pset)'{-P+,--pset=}'[print setting]:s:' \
  '(-F --output)'{-F+,--output=}'[output format]:fmt:(aligned unaligned wrapped html asciidoc latex troff-ms json csv vertical)' \
  '*: :' && ret=0

return ret
