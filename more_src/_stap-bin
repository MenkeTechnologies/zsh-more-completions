#compdef stap
# _stap-bin — SystemTap scriptable tracer (Red Hat); compiles .stp script into kernel module for instrumentation
# upstream: https://sourceware.org/systemtap

_stap-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-c+[command to run]:cmd:_command_names -e' \
        '-x+[target PID]:pid:_pids' \
        '-p+[stop after pass N]:n:(1 2 3 4 5)' \
        '-v[verbose]' \
        '-vp+[per-pass verbosity]:str:' \
        '-k[keep temporary files]' \
        '-g[guru mode (embedded C)]' \
        '-P[prologue searching]' \
        '-u[unoptimized]' \
        '-w[no warnings]' \
        '-W[warnings as errors]' \
        '-t[print timing]' \
        '-s+[buffer size MB]:n:' \
        '-o+[output file]:file:_files' \
        '-m+[module name]:name:' \
        '-r+[kernel release]:str:' \
        '-a+[architecture]:str:' \
        '-B+[build option]:str:' \
        '-D+[define]:name:' \
        '-I+[include dir]:dir:_files -/' \
        '-R+[runtime dir]:dir:_files -/' \
        '-G+[arg]:val:' \
        '-e+[script string]:script:' \
        '-l+[list probes glob]:glob:' \
        '-L+[list probes long]:glob:' \
        '--ldd[probe shared library deps]' \
        '--all-modules[probe all modules]' \
        '--vp+[per-pass verbosity]:str:' \
        '--remote+[remote target]:target:' \
        '--use-server+[stap server]:str:' \
        '--list-servers[list stap servers]' \
        '--target-namespaces+[namespaces]:str:' \
        '--monitor+[monitor mode interval]:sec:' \
        '*:script:_files -g "*.stp"'
}

_stap-bin "$@"
