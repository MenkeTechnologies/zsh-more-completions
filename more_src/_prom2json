#compdef prom2json
# Documentation: https://raw.githubusercontent.com/prometheus/prom2json/master/cmd/prom2json/main.go
# Reference accessed: 2026-05-20
# Verified: upstream cmd/prom2json/main.go kingpin Flag definitions.

# prom2json: convert Prometheus metrics to JSON
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cert=[client certificate file]:file:_files' \
  '--key=[client certificate key file]:file:_files' \
  '--accept-invalid-cert[accept any TLS cert (insecure)]' \
  '--escaping=[escaping scheme for content negotiation]:scheme:(allow-utf-8 underscores dots values)' \
  '*:metrics path or URL:_files' && ret=0
return ret
