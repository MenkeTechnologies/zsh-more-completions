#compdef prom2json
# Documentation: https://github.com/prometheus/prom2json/blob/master/cmd/prom2json/main.go
# Reference accessed: 2026-05-16
# Verified: upstream cmd/prom2json/main.go kingpin definitions.

# prom2json: convert Prometheus metrics to JSON
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--cert=[client certificate file]:file:_files' \
  '--key=[client certificate key file]:file:_files' \
  '--accept-invalid-cert[accept any TLS cert (insecure)]' \
  '--escaping=[escaping scheme]:scheme:(allow-utf-8)' \
  '*:metrics path or URL:_files' && ret=0
return ret
