#compdef wifite wifite2
# _wifite — automated wireless attack tool (derv82/wifite2)
# upstream: https://github.com/derv82/wifite2
# Flags from wifite/args.py (argparse).

_wifite() {
    _arguments \
        '(- *)-h[show help]' \
        '*-v[verbose (repeat for more)]' \
        '*--verbose[verbose (repeat for more)]' \
        '-i+[wireless interface]:iface:' \
        '-c+[wireless channel]:n:' \
        '--channel=[wireless channel]:n:' \
        '(-5 --5ghz)'{-5,--5ghz}'[include 5GHz channels]' \
        '(-mac --random-mac)'{-mac,--random-mac}'[randomize wireless MAC]' \
        '-p+[pillage mode scan time (s)]:secs:' \
        '--pillage=[pillage mode scan time (s)]:secs:' \
        '--kill[kill conflicting processes]' \
        '-b+[target BSSID]:bssid:' \
        '--bssid=[target BSSID]:bssid:' \
        '-e+[target ESSID]:essid:' \
        '--essid=[target ESSID]:essid:' \
        '--ignore-essid=[ESSID to ignore]:essid:' \
        '--clients-only[only attack APs with clients]' \
        '--showb[show BSSIDs in scan]' \
        '--nodeauths[skip deauths]' \
        '--no-deauths[skip deauths]' \
        '-nd[skip deauths]' \
        '--num-deauths=[deauth packet count]:n:' \
        '--eviltwin[enable evil twin attack]' \
        '--wep[only target WEP networks]' \
        '--wpa[only target WPA/WPA2 networks]' \
        '--wps[only target WPS networks]' \
        '--pmkid[only target PMKID]' \
        '--dict=[wordlist path]:file:_files' \
        '--hs-dir=[handshake save dir]:dir:_files -/' \
        '--new-hs[only save new handshakes]'
}

_wifite "$@"
