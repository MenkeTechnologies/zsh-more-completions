#compdef paraSync
# UCSC kent: use paraFetch to recursively mirror url to given path

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-A=[accept only files with these comma-separated extensions]:exts:' \
  '-newer[only download if newer than local version]' \
  '-progress[show progress of download]' \
  ':connections:' \
  ':retries:' \
  ':url:_urls' \
  ':out path:_files' && ret=0

return ret
