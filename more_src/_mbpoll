#compdef mbpoll
# Documentation: https://github.com/epsilonrt/mbpoll
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mbpoll - command line utility to communicate with Modbus slave (RTU or TCP)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-m+[mode: rtu or tcp]:mode:(rtu tcp)' \
  '-a+[slave address (1-255 or list like 32,33,34)]:address' \
  '-r+[start reference]:reference' \
  '-c+[number of values to read]:count' \
  '-u[read the description of the type, the current status, and other information specific to a remote device (RTU only)]' \
  '-t+[register type/format]:type:(0 1 3 4 3:int16 3:hex 3:string 3:int 3:float 4:int16 4:hex 4:string 4:int 4:float)' \
  '-0[use PDU addressing (0-based) instead of 1-based]' \
  '-B[big endian word order for 32-bit values]' \
  '-1[poll once only]' \
  '-l+[poll rate in milliseconds]:ms' \
  '-o+[timeout in seconds (0.01 - 10.00)]:seconds' \
  '-q[quiet mode]' \
  '-x[display addresses in hexadecimal]' \
  '-Q[enable MAX_SLAVE quirk]' \
  '-X[enable REPLY_TO_BROADCAST quirk]' \
  '-p+[TCP port number]:port' \
  '-b+[serial baud rate]:baud:(1200 2400 4800 9600 19200 38400 57600 115200 230400 460800 921600)' \
  '-d+[serial data bits]:bits:(7 8)' \
  '-s+[serial stop bits]:bits:(1 2)' \
  '-P+[serial parity]:parity:(none even odd)' \
  '-R[RS-485 mode (RTS on after sending)]' \
  '-F[RS-485 mode (RTS on when sending)]' \
  '-h[display help summary]' \
  '-V[print version and exit]' \
  '-v[verbose/debug output]' \
  '*:device or host:_files' && ret=0

return ret
