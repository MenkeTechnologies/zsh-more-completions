#compdef mbpoll
# Documentation: https://man.archlinux.org/search?q=mbpoll
# Reference accessed: 2026-05-16

# Zsh completion for mbpoll Modbus poll tool

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-t --timeout)'{-t,--timeout}'[timeout ms]:ms' \
  '(-r --reference)'{-r,--reference}'[reference id]:id' \
  '*:: : _message "see mbpoll -h"' && ret=0

return ret
