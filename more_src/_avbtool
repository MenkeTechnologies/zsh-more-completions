#compdef avbtool

# avbtool: Android Verified Boot (AVB 2.0) command-line tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'add_hash_footer:add hash footer to image'
  'add_hashtree_footer:add hashtree footer'
  'append_vbmeta_image:append vbmeta to image'
  'calculate_kernel_cmdline:calc kernel cmdline'
  'calculate_vbmeta_digest:calc vbmeta digest'
  'erase_footer:remove footer'
  'extract_public_key:extract public key from PEM'
  'extract_vbmeta_image:extract vbmeta from image'
  'generate_test_image:generate test image'
  'info_image:show image info'
  'make_atx_certificate:make ATX cert'
  'make_atx_metadata:make ATX metadata'
  'make_atx_unlock_credential:make ATX unlock credential'
  'make_atx_pik_certificate:make ATX PIK cert'
  'make_atx_permanent_attributes:make ATX permanent attrs'
  'make_vbmeta_image:make vbmeta.img'
  'print_partition_digests:print partition digests'
  'resign_image:resign image with new key'
  'set_ab_metadata:set A/B metadata'
  'verify_image:verify image'
  'version:show version'
  'help:show help'
)
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'avbtool command' commands && ret=0 ;;
esac
return ret
