#compdef rpki-client
# Documentation: https://man.openbsd.org/rpki-client
# Reference accessed: 2026-05-17
# Verified: OpenBSD rpki-client(8) upstream — RPKI validator for
# BGP origin validation. Single-dash flags only. Real flags: -0,
# -A, -B, -b, -c, -d, -e, -f, -H, -j, -m, -n, -o, -P, -R, -r,
# -s, -S, -t, -T, -u, -v, -V, -x. NOTE: -B is BGPd output (NOT
# BIRD; BIRD is -o). Real -p does not exist; -P is
# validate-after time.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -p (parallel threads — no such flag), -s (total
# timeout — no such flag). Corrected -B description.

local ret=1
_arguments -s \
  '(- *)-V[print version]' \
  '-0[include AS0 TALs]' \
  '-A[exclude ASPA]' \
  '-B[bgpd output (default)]' \
  '-b+[source address]:addr:' \
  '-c[CSV output]' \
  '-d+[cache directory]:dir:_files -/' \
  '-e+[validate-after epoch (seconds)]:seconds:' \
  '-f+[analyze single file]:file:_files' \
  '-H+[RRDP-only host:port]:host:_hosts' \
  '-j[JSON output]' \
  '-m[output extra metrics]' \
  '-n[RSYNC only, no RRDP]' \
  '-o[BIRD output]' \
  '-P+[validate-after time (epoch seconds)]:seconds:' \
  '-R[do not RSYNC]' \
  '-r[do not RRDP]' \
  '-s+[skip list file]:file:_files' \
  '-S+[TAL skip list]:file:_files' \
  '*-T+[TAL file]:file:_files' \
  '-t+[alias for -T (TAL file)]:file:_files' \
  '-u+[rsync program]:cmd:_command_names -e' \
  '*-v[verbose (repeatable)]' \
  '-x[experimental output formats]' \
  '*:output dir:_files -/' && ret=0
return ret
