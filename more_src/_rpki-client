#compdef rpki-client
# Documentation: https://man.archlinux.org/search?q=rpki-client
# Reference accessed: 2026-05-16

_arguments -s \
  '-0[print SKI/AKI in hex]' \
  '-A[ASPA output]' \
  '-B[BIRD output]' \
  '-b[source address]:addr:' \
  '-c[CSV output]' \
  '-d[cache directory]:dir:_files -/' \
  '-e[rsync program]:cmd:' \
  '-f[validate file]:file:_files' \
  '-H[FQDN]:host:_hosts' \
  '-j[JSON output]' \
  '-m[print metric output]' \
  '-n[no update of repository]' \
  '-o[output directory]:dir:_files -/' \
  '-P[POSIX seconds]:seconds:' \
  '-p[parallel threads]:n:' \
  '-R[disable RRDP]' \
  '-S[skiplist file]:file:_files' \
  '-s[total timeout]:s:' \
  '-t[TAL file]:file:_files' \
  '-V[print version]' \
  '-v[verbose]' \
  '-x[XML output]' \
  '*:output dir:_files -/'
