#compdef vegeta
# Documentation: https://man.archlinux.org/search?q=vegeta
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'attack:run an attack'
  'encode:encode results to other formats'
  'plot:generate HTML plot'
  'report:generate report'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*-cpus=[CPUs]:n:' \
  '*-profile=[profile mode]:m:(cpu mem block mutex trace heap allocs)' \
  '*-version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vegeta command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (attack)
        _arguments \
          '*-targets=[targets file]:file:_files' \
          '*-format=[targets format]:f:(http json)' \
          '*-rate=[req per sec]:n:' \
          '*-duration=[duration]:t:' \
          '*-workers=[initial workers]:n:' \
          '*-max-workers=[max workers]:n:' \
          '*-connections=[max conns]:n:' \
          '*-max-connections=[max conns]:n:' \
          '*-h2c[force HTTP/2 cleartext]' \
          '*-http2=[HTTP/2]:b:(true false)' \
          '*-keepalive=[keep-alive]:b:(true false)' \
          '*-laddr=[local addr]:a:' \
          '*-output=[output file]:file:_files' \
          '*-redirects=[max redirects]:n:' \
          '*-resolvers=[DNS resolvers csv]:list:' \
          '*-proxy-header=[proxy header]:h:' \
          '*-rate-period=[rate period]:t:' \
          '*-prometheus-addr=[prometheus addr]:a:' \
          '*-cert=[client cert]:file:_files' \
          '*-key=[client key]:file:_files' \
          '*-root-certs=[CA certs csv]:list:_files' \
          '*-insecure[insecure TLS]' \
          '*-name=[attack name]:n:' \
          '*-timeout=[request timeout]:t:' \
          '*-chunked[chunked TE]' \
          '*-body=[request body]:file:_files' \
          '*-header=[k=v header]:h:' \
          '*-session=[session sticky]:b:(true false)' \
          '*-dns-ttl=[DNS TTL]:t:' \
          '*: :' && ret=0 ;;
      (report)
        _arguments \
          '*-type=[report type]:t:(text json hist[bucket1,bucket2,...])' \
          '*-buckets=[histogram buckets]:b:' \
          '*-output=[output file]:file:_files' \
          '*-every=[every]:t:' \
          '*: :_files' && ret=0 ;;
      (plot)
        _arguments \
          '*-output=[output HTML]:file:_files' \
          '*-threshold=[threshold]:n:' \
          '*-title=[title]:t:' \
          '*: :_files' && ret=0 ;;
      (encode)
        _arguments \
          '*-output=[output file]:file:_files' \
          '*-to=[target format]:f:(csv json gob)' \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
