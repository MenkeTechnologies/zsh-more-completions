#compdef systemctl-cli
# _systemctl-cli — systemd systemctl control the systemd system and service manager CLI alias (systemd team, C); custom argparse
# upstream: https://github.com/systemd/systemd

_systemctl-cli() {
    local -a sub=(
        'list-units:list units'
        'list-sockets:list sockets'
        'list-timers:list timers'
        'list-jobs:list jobs'
        'list-machines:list machines'
        'list-dependencies:list dependencies'
        'list-unit-files:list unit files'
        'list-installed:list installed unit files'
        'list-paths:list paths'
        'is-active:check active'
        'is-failed:check failed'
        'is-enabled:check enabled'
        'is-system-running:check system state'
        'status:show status'
        'show:show properties'
        'show-environment:show env'
        'cat:show config'
        'help:show help for unit'
        'start:start unit'
        'stop:stop unit'
        'restart:restart unit'
        'try-restart:try restart unit'
        'reload:reload unit'
        'reload-or-restart:reload or restart unit'
        'try-reload-or-restart:try reload or restart unit'
        'isolate:isolate unit'
        'kill:send signal'
        'clean:clean state'
        'enable:enable unit'
        'disable:disable unit'
        'reenable:reenable unit'
        'preset:preset unit'
        'preset-all:preset all units'
        'mask:mask unit'
        'unmask:unmask unit'
        'edit:edit unit'
        'revert:revert unit overrides'
        'add-wants:add wants dependency'
        'add-requires:add requires dependency'
        'set-default:set default target'
        'get-default:get default target'
        'set-environment:set env'
        'unset-environment:unset env'
        'import-environment:import env'
        'reset-failed:reset failed state'
        'daemon-reload:reload systemd'
        'daemon-reexec:reexecute systemd'
        'log-level:show/set log level'
        'log-target:show/set log target'
        'service-watchdogs:show/set watchdogs'
        'cancel:cancel pending job'
        'switch-root:switch root'
        'halt:halt system'
        'poweroff:poweroff system'
        'reboot:reboot system'
        'kexec:kexec system'
        'exit:exit user session'
        'suspend:suspend system'
        'hibernate:hibernate system'
        'hybrid-sleep:hybrid sleep'
        'suspend-then-hibernate:suspend then hibernate'
        'rescue:enter rescue mode'
        'emergency:enter emergency mode'
        'default:return to default target'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--system[talk to system manager]' \
        '--user[talk to user manager]' \
        '-H+[host]:host:_hosts' \
        '--host=+[host]:host:_hosts' \
        '-M+[machine]:str:' \
        '--machine=+[machine]:str:' \
        '-t+[type]:str:' \
        '--type=+[type]:str:' \
        '--state=+[state]:str:' \
        '-p+[property]:str:' \
        '--property=+[property]:str:' \
        '-P+[property]:str:' \
        '-a[all]' \
        '--all[all]' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '--reverse[reverse]' \
        '--after[after]' \
        '--before[before]' \
        '--show-types[show types]' \
        '--value[value only]' \
        '--check-inhibitors=+[mode]:m:(auto yes no)' \
        '--kill-whom=+[whom]:w:(main control all)' \
        '-s+[signal]:str:' \
        '--signal=+[signal]:str:' \
        '--what=+[type]:str:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-block[no block]' \
        '--wait[wait]' \
        '--no-wall[no wall]' \
        '--global[global]' \
        '--no-reload[no reload]' \
        '--no-warn[no warn]' \
        '--no-pager[no pager]' \
        '--no-ask-password[no ask password]' \
        '--kill-who=+[whom]:str:' \
        '--full[full output]' \
        '-l[full output]' \
        '--lines=+[lines]:n:' \
        '-n+[lines]:n:' \
        '--output=+[format]:f:(short short-precise short-iso short-iso-precise short-full short-monotonic short-unix verbose export json json-pretty json-sse cat with-unit)' \
        '-o+[format]:f:(short short-precise short-iso short-iso-precise short-full short-monotonic short-unix verbose export json json-pretty json-sse cat with-unit)' \
        '-i[ignore inhibitors]' \
        '--ignore-inhibitors[ignore inhibitors]' \
        '--with-dependencies[with dependencies]' \
        '--plain[plain output]' \
        '--firmware-setup[firmware setup]' \
        '--boot-loader-menu=+[seconds]:n:' \
        '--boot-loader-entry=+[entry]:str:' \
        '--now[do action now]' \
        '--root=+[dir]:dir:_files -/' \
        '--image=+[file]:file:_files' \
        '--runtime[runtime]' \
        '--preset-mode=+[mode]:m:(full enable-only disable-only)' \
        '--legend=+[bool]:b:(true false)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'systemctl subcommand' sub ;;
    esac
}

_systemctl-cli "$@"
