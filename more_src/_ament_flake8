#compdef ament_flake8
# Documentation: https://github.com/ament/ament_lint/blob/rolling/ament_flake8/ament_flake8/main.py
# ament_flake8 - check Python code against flake8 style conventions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[the flake8 config file]:config:_files' \
  '--linelength=[the maximum line length]:N:' \
  '*--exclude=[the filenames to exclude]:filename:_files' \
  '--xunit-file=[generate a xunit compliant XML file]:file:_files' \
  '*:path:_files' && ret=0

return ret
