#compdef bsv-cli bitcoin-sv-cli bitcoinsv-cli
# _bsv-cli — Bitcoin SV bsv-cli JSON-RPC client CLI for the Bitcoin SV Node daemon issuing wallet getbalance sendtoaddress listunspent generate getblockchaininfo getmempoolinfo addnode getpeerinfo importprivkey large-block scaling testnet stn (bitcoin-sv team, C++); custom argparse
# upstream: https://github.com/bitcoin-sv/bitcoin-sv

_bsv-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf bitcoin.conf bsv.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-testnet[use testnet]' \
        '-stn[use STN scaling test network]' \
        '-regtest[use regtest]' \
        '-named[use named JSON-RPC]' \
        '-rpcconnect=+[host]:h:_hosts' \
        '-rpcport=+[port]:n:' \
        '-rpcwait[wait for RPC server]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcclienttimeout=+[seconds]:n:' \
        '-rpccookiefile=+[file]:file:_files' \
        '-stdin[read input from stdin]' \
        '-stdinrpcpass[read RPC password from stdin]' \
        '-getinfo[print info]' \
        '*:rpc command:(getblockchaininfo getblockcount getblockhash getblock getnetworkinfo getmempoolinfo getmininginfo getbalance listunspent listtransactions sendtoaddress sendmany getnewaddress validateaddress dumpprivkey importprivkey importwallet dumpwallet generate generatetoaddress getrawtransaction createrawtransaction signrawtransaction sendrawtransaction addnode getpeerinfo getnettotals setban listbanned getminerinfo verifyconsolidationtxn)'
}

_bsv-cli "$@"
