#compdef elia
# Documentation: https://github.com/darrenburns/elia
# A snappy, keyboard-centric terminal user interface for interacting with LLMs

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '(-i --inline)'{-i,--inline}'[launch a new chat inline under your prompt]' \
  '(-m --model)'{-m,--model}'+[specify which model to use]:model:' \
  '1:command:((import\:"import conversations from a ChatGPT JSON export" reset\:"wipe the database"))' \
  '*::arg:_files' && ret=0

return ret
