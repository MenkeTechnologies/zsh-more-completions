#compdef xkbbell xkbvleds xkbwatch
# Documentation: https://www.freshports.org/x11/xkbutils/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

case $service in
  (xkbbell)
    _arguments \
      '-display+[X display]:display:' \
      '-name+[bell name]:name:' \
      '-volume+[volume]:vol:' \
      '-pitch+[pitch]:pitch:' \
      '-duration+[duration ms]:ms:' \
      '-bell_class+[bell class]:class:' \
      '-bell_id+[bell id]:id:' \
      '-force[force audible]' \
      '-event[trigger an event]' && ret=0 ;;
  (xkbvleds)
    _arguments \
      '-display+[X display]:display:' \
      '-name+[name]:name:' \
      '-bg+[background color]:color:' \
      '-fg+[foreground color]:color:' \
      '-watch+[indicators to watch]:flags:' && ret=0 ;;
  (xkbwatch)
    _arguments \
      '-display+[X display]:display:' \
      '-iconic[start iconified]' \
      '-bg+[background color]:color:' \
      '-fg+[foreground color]:color:' && ret=0 ;;
esac

return ret
