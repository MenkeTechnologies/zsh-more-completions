#compdef dehydrated

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --cron)'{-c,--cron}'[sign/renew certificates]' \
  '(-r --register)'{-r,--register}'[register account key]' \
  '--accept-terms[accept CA terms of service]' \
  '(-s --signcsr)'{-s,--signcsr}'[sign a CSR]:csr file:_files -g "*.csr"' \
  '(-g --revoke)'{-g,--revoke}'[revoke a certificate]:cert file:_files -g "*.pem"' \
  '--cleanup[move unused certificate files to archive]' \
  '(-e --env)'{-e,--env}'[output current environment]' \
  '(-l --lock)'{-l,--lock}'[acquire lock before execution]' \
  '--lock-suffix=[suffix for lock file]:suffix' \
  '(-d --domain)'{-d,--domain}'[domain to manage]:domain' \
  '--alias=[use alternative name for directory]:alias' \
  '--ocsp[set OCSP must-staple extension]' \
  '--no-lock[do not use lock file]' \
  '--keep-going[keep going on errors]' \
  '--force[force renewal]' \
  '--force-validation[force validation]' \
  '(-x --privkey)'{-x,--privkey}'[use specified private key]:key file:_files' \
  '(-f --config)'{-f,--config}'[config file]:file:_files' \
  '--hook=[hook script]:script:_files' \
  '--out=[output directory]:directory:_directories' \
  '--challenge=[challenge type]:type:(http-01 dns-01 tls-alpn-01)' \
  '--algo=[key algorithm]:algo:(rsa secp384r1 prime256v1)' \
  '--keysize=[RSA key size]:size:(2048 4096)' \
  '--ca=[certificate authority]:url' \
  '--preferred-chain=[preferred cert chain]:issuer' && ret=0

return ret
