#compdef btdevctl
# Documentation: man btdevctl(8)
# Source: netbsd/src usr.sbin/btdevctl — Bluetooth remote device control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-D)-A[attach device]' \
    '(-A)-D[detach device]' \
    '-a+[remote device address (BDADDR or name)]:address:_default' \
    '-d+[local device address (BDADDR or name)]:device:_default' \
    '-m+[connection link mode]:mode:(none auth encrypt secure)' \
    '-q[ignore cached data, fresh SDP query]' \
    '-s+[service to configure]:service:(HID HF HSET)' \
    '-v[verbose output]' \
    && ret=0

return ret
