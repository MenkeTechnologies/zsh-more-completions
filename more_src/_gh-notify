#compdef gh-notify
# Documentation: https://man.archlinux.org/search?q=gh-notify
# Reference accessed: 2026-05-16

_gh-notify() {
    _arguments \
        '-a[Show all notifications]' \
        '-n[Limit number of notifications]:number:' \
        '-p[Show only participating notifications]' \
        '-r[Mark all as read]' \
        '-s[Print static list]' \
        '-w[Open preview window immediately]' \
        '-h[Show help]'
}

_gh-notify "$@"
