#compdef llvm-dlltool
# _llvm-dlltool — LLVM DLL import lib generator (LLVM project, C++); make import libraries from PE .def files
# upstream: https://github.com/llvm/llvm-project

_llvm-dlltool() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-d+[input def file]:file:_files -g "*.def"' \
        '--input-def=+[input def file]:file:_files -g "*.def"' \
        '-l+[output import lib]:file:_files' \
        '--output-lib=+[output import lib]:file:_files' \
        '-D+[name of dll]:str:' \
        '--dllname=+[name of dll]:str:' \
        '-m+[machine]:machine:(arm arm64 arm64ec arm64x i386 i386:x86-64)' \
        '--machine=+[machine]:machine:(arm arm64 arm64ec arm64x i386 i386:x86-64)' \
        '-N+[output name to use in import library]:str:' \
        '--name=+[output name]:str:' \
        '-k[no leading underscore]' \
        '--kill-at[no leading underscore]' \
        '-S+[assembler]:file:_files' \
        '--as=+[assembler]:file:_files' \
        '-f+[assembler flags]:str:' \
        '--as-flags=+[assembler flags]:str:' \
        '*:file:_files'
}

_llvm-dlltool "$@"
