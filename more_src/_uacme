#compdef uacme
# Documentation: https://manpages.debian.org/bookworm/uacme/uacme.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm uacme(1) manpage.

# uacme: lightweight ACMEv2 client
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'new:create new account'
  'update:update account'
  'deactivate:deactivate account'
  'newkey:create new account key'
  'issue:issue certificate'
  'revoke:revoke certificate'
)
_arguments -C \
  '(-? --help)'{-?,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --acme-url)'{-a,--acme-url=}'[ACMEv2 directory URL]:url:' \
  '(-b --bits)'{-b,--bits=}'[key bit length]:bits:' \
  '(-c --confdir)'{-c,--confdir=}'[config directory]:dir:_files -/' \
  '(-d --days)'{-d,--days=}'[do not reissue if valid >N days]:days:' \
  '(-e --eab)'{-e,--eab=}'[External Account Binding (KEYID:KEY)]:keyid\:key:' \
  '(-f --force)'{-f,--force}'[force reissuance]' \
  '(-h --hook)'{-h,--hook=}'[challenge hook program]:program:_files' \
  '(-l --alternate)'{-l,--alternate=}'[select alternate chain]:N or fp:' \
  '(-m --must-staple)'{-m,--must-staple}'[request OCSP Must-Staple]' \
  '(-n --never-create)'{-n,--never-create}'[never create missing dirs/keys]' \
  '(-o --no-ocsp)'{-o,--no-ocsp}'[skip OCSP validation]' \
  '(-r --reason)'{-r,--reason=}'[revocation reason code]:code:' \
  '(-s --staging)'{-s,--staging}'[use Let'\''s Encrypt staging]' \
  '(-t --type)'{-t,--type=}'[key type]:type:(RSA EC)' \
  '*'{-v,--verbose}'[verbose (repeatable)]' \
  '(-y --yes)'{-y,--yes}'[auto-accept ACME terms]' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'uacme command' commands && ret=0 ;;
esac
return ret
