#compdef mdp

# Zsh completion for mdp - Markdown presentation tool

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d[enable debug mode]' \
  '--debug[enable debug mode]' \
  '-e[enable character entity expansion]' \
  '--expand[enable character entity expansion]' \
  '-f[enable fading transitions]' \
  '--fade[enable fading transitions]' \
  '-i[enable invert colors]' \
  '--invert[enable invert colors]' \
  '-s[do not resize the terminal on startup]' \
  '--noslidenum[suppress slide number]' \
  '-t[transparency]:0-1:' \
  '--trans=[transparency]:0-1:' \
  '-x[character for horizontal rules]:character:' \
  '--nofade[disable fading transitions]' \
  '--notrans[disable transparency]' \
  '1:markdown file:_files -g "*.{md,markdown}"'
