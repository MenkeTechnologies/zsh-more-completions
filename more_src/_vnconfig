#compdef vnconfig
# _vnconfig — OpenBSD vnconfig (configure vnd(4) pseudo-disk devices over regular files; -K enables Blowfish encryption with PKCS#5 rounds + saltfile, -l lists, -u unconfigures, -t sets disktype)
# upstream: https://github.com/openbsd/src (sbin/vnconfig)
# Flags from sbin/vnconfig/vnconfig.8 on tip.

_vnconfig() {
    _arguments \
        '-v[verbose]' \
        '-l[list configured vnds]' \
        '-u[unconfigure]' \
        '-k[prompt for key on stdin]' \
        '-K+[encrypt with N rounds]:rounds:' \
        '-S+[salt file]:file:_files' \
        '-t+[disk type from /etc/disktab]:type:' \
        '1:vnd_dev:_files -g "/dev/vnd*"' \
        '2:image:_files'
}

_vnconfig "$@"
