#compdef orbprofile
# _orbprofile — orbuculum project orbprofile CLI gprof-style flat call-graph profiler client connecting to orbuculum daemon decoding ARM ETM ITM PC-sample trace stream emitting gmon.out KCachegrind callgrind output for offline performance analysis (Dave Marples team, C); custom argparse
# upstream: https://github.com/orbcode/orbuculum

_orbprofile() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose level]:l:(0 1 2 3 4)' \
        '-c+[capture sec]:n:' \
        '-e+[elf file]:file:_files -g "*.elf *.axf *.out"' \
        '-E+[entry func]:str:' \
        '-f+[output file]:file:_files' \
        '-F+[format]:f:(gmon callgrind dot json)' \
        '-I+[interval ms]:n:' \
        '-O+[objdump path]:file:_files' \
        '-p+[protocol]:p:(etm4 etm3 itm tpiu)' \
        '-s+[server:port]:host:port:' \
        '-t+[tag]:str:' \
        '-T[TPIU framing]' \
        '-D[no demangle]' \
        '-y+[output dir]:dir:_files -/' \
        '*:elf file:_files -g "*.elf *.axf"'
}

_orbprofile "$@"
