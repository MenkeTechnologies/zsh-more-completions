#compdef fmit
# Documentation: https://man.archlinux.org/search?q=fmit
# Reference accessed: 2026-05-16

# FMIT: free music instrument tuner
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '*::fmit args:_files' && ret=0
return ret
