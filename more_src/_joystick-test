#compdef joystick-test jstest
# Documentation: https://manpages.debian.org/bookworm/joystick/jstest.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian joystick package jstest(1) manpage OPTIONS section.
# Note: the actual binary is "jstest", not "joystick-test"; package name is
# "joystick" on Debian/Ubuntu (no separate "joystick-test" package exists).
# Removed from prior file: -h/--help, -V/--version (not documented in the
# real jstest manpage; jstest uses long-form mode flags only).

# jstest: command-line joystick test tool (from joystick package)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--normal[one-line mode showing immediate status]' \
  '--old[same as --normal, using 0.x interface]' \
  '--event[print events as they come in]' \
  '--nonblock[same as --event, nonblocking mode]' \
  '--select[same as --event, using select(2)]' \
  '*:joystick device:_files -g "/dev/input/js*"' && ret=0
return ret
