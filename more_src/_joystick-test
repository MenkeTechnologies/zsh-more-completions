#compdef joystick-test
# Documentation: https://manpages.debian.org/joystick
# Reference accessed: 2026-05-16

# joystick-test: command-line joystick test tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '*:joystick device:_files -g "/dev/input/js*"' && ret=0
return ret
