#compdef jupyter-book jb

# Zsh completion for jupyter-book (jb) - build Jupyter Books and documentation

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:convert Jupyter Book content to HTML or PDF'
  'create:create a simple Jupyter Book that you can build and edit'
  'clean:clean build artifacts generated from Jupyter Book'
  'config:inspect or generate configuration'
  'myst:manage MyST markdown files'
  'toc:commands related to the table of contents'
  'page:build a page rather than a book'
)

local -a builders=(
  'html:HTML builder'
  'singlehtml:single HTML page builder'
  'dirhtml:directory HTML builder'
  'pdfhtml:build the HTML then use pyppeteer to print PDF'
  'linkcheck:check links for errors'
  'latex:build LaTeX only'
  'pdflatex:build LaTeX and then run pdf build'
  'custom:use a custom Sphinx builder'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'jupyter-book command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '--path-output[path to output artifacts]:dir:_files -/' \
          '--config[path to the config file]:file:_files -g "*.(yml|yaml)"' \
          '--toc[path to the table of contents]:file:_files -g "*.(yml|yaml)"' \
          '(-W --warningiserror)'{-W,--warningiserror}'[treat warnings as errors]' \
          '(-n --nitpick)'{-n,--nitpick}'[nitpicky mode]' \
          '--keep-going[continue on warnings]' \
          '--freshenv[build without cache]' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(-q --quiet)'{-q,--quiet}'[only show errors]' \
          '--individualpages[build each page individually]' \
          '--builder[Sphinx builder to use]:builder:(html singlehtml dirhtml pdfhtml linkcheck latex pdflatex custom)' \
          '--custom-builder[custom builder name]:name:' \
          '(-a --all)'{-a,--all}'[rebuild all files]' \
          '*:source path:_files -/' && ret=0
        ;;
      (create)
        _arguments \
          '--cookiecutter[use cookiecutter template]' \
          '--no-input[do not prompt for input]' \
          '1:destination:_files -/' && ret=0
        ;;
      (clean)
        _arguments \
          '--all[clean all build artifacts]' \
          '(-h --html)'{-h,--html}'[clean the HTML build]' \
          '--latex[clean the LaTeX build]' \
          '1:source path:_files -/' && ret=0
        ;;
      (config)
        _arguments \
          '1:subcommand:(sphinx)' \
          '*:source path:_files -/' && ret=0
        ;;
      (myst)
        _arguments \
          '1:subcommand:(init)' \
          '*:file:_files -g "*.(md|ipynb)"' && ret=0
        ;;
      (toc)
        _arguments \
          '1:subcommand:(from-project migrate)' \
          '*:file or path:_files' && ret=0
        ;;
      (page)
        _arguments \
          '--path-output[path to output]:dir:_files -/' \
          '--execute[execute notebooks]' \
          '1:file:_files -g "*.(md|ipynb|rst)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
