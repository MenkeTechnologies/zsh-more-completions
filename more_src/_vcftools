#compdef vcftools
# Documentation: https://vcftools.github.io/man_latest.html
# Reference accessed: 2026-05-21
# Verified: upstream vcftools(1) manpage.

# VCFtools: filter, analyze, and convert VCF files
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--vcf=[input VCF file]:file:_files -g "*.vcf"' \
  '--gzvcf=[input gzipped VCF]:file:_files -g "*.vcf.gz"' \
  '--bcf=[input BCF]:file:_files -g "*.bcf"' \
  '--out=[output prefix]:prefix:' \
  '--stdout[output to stdout]' \
  '-c[output to stdout]' \
  '--temp=[temporary directory]:dir:_files -/' \
  '--keep=[file with sample IDs to keep]:file:_files' \
  '--remove=[file with sample IDs to remove]:file:_files' \
  '--indv=[sample to keep (repeatable)]:sample:' \
  '--remove-indv=[sample to remove]:sample:' \
  '--max-indv=[randomly retain N individuals]:n:' \
  '--chr=[chromosome to keep]:chrom:' \
  '--not-chr=[chromosome to exclude]:chrom:' \
  '--from-bp=[start position]:n:' \
  '--to-bp=[end position]:n:' \
  '--bed=[BED file of regions to keep]:file:_files' \
  '--exclude-bed=[BED file of regions to exclude]:file:_files' \
  '--positions=[positions to keep]:file:_files' \
  '--exclude-positions=[positions to exclude]:file:_files' \
  '--positions-overlap=[positions overlap (REF allele)]:file:_files' \
  '--exclude-positions-overlap=[exclude positions overlap]:file:_files' \
  '--thin=[thin sites to N apart]:n:' \
  '--mask=[mask file]:file:_files' \
  '--invert-mask=[invert mask file]:file:_files' \
  '--mask-min=[mask threshold]:n:' \
  '--snp=[SNP ID to keep]:id:' \
  '--snps=[file of SNP IDs to keep]:file:_files' \
  '--exclude=[file of SNP IDs to exclude]:file:_files' \
  '--remove-indels[remove indels]' \
  '--keep-only-indels[keep only indels]' \
  '--remove-filtered-all[remove all non-PASS sites]' \
  '--keep-filtered=[keep sites with FILTER flag]:flag:' \
  '--remove-filtered=[remove sites with FILTER flag]:flag:' \
  '--keep-INFO=[keep sites with INFO flag]:flag:' \
  '--remove-INFO=[remove sites with INFO flag]:flag:' \
  '--min-alleles=[min number of alleles]:n:' \
  '--max-alleles=[max number of alleles]:n:' \
  '--maf=[min minor allele frequency]:val:' \
  '--max-maf=[max MAF]:val:' \
  '--mac=[min minor allele count]:n:' \
  '--max-mac=[max MAC]:n:' \
  '--non-ref-af=[min non-reference AF]:val:' \
  '--max-non-ref-af=[max non-reference AF]:val:' \
  '--non-ref-ac=[min non-reference AC]:n:' \
  '--max-non-ref-ac=[max non-reference AC]:n:' \
  '--non-ref-af-any=[min non-ref AF (any allele)]:val:' \
  '--max-non-ref-af-any=[max non-ref AF (any allele)]:val:' \
  '--non-ref-ac-any=[min non-ref AC (any allele)]:n:' \
  '--max-non-ref-ac-any=[max non-ref AC (any allele)]:n:' \
  '--min-meanDP=[min mean depth across individuals]:val:' \
  '--max-meanDP=[max mean depth]:val:' \
  '--hwe=[Hardy-Weinberg p-value cutoff]:val:' \
  '--max-missing=[max missing fraction]:val:' \
  '--max-missing-count=[max missing count]:n:' \
  '--phased[exclude unphased sites]' \
  '--minQ=[min quality score]:val:' \
  '--remove-filtered-geno-all[exclude non-PASS filtered genotypes]' \
  '--remove-filtered-geno=[exclude filtered genotypes]:flag:' \
  '--minGQ=[min genotype quality]:val:' \
  '--minDP=[min genotype depth]:val:' \
  '--maxDP=[max genotype depth]:val:' \
  '--missing-indv[missingness per individual]' \
  '--missing-site[missingness per site]' \
  '--het[per-individual heterozygosity]' \
  '--depth[per-individual mean depth]' \
  '--site-depth[per-site total depth]' \
  '--site-mean-depth[per-site mean depth]' \
  '--geno-depth[depth per genotype]' \
  '--hardy[per-site HWE p-value]' \
  '--site-quality[per-site SNP quality]' \
  '--counts[allele counts at each site]' \
  '--counts2[raw counts (no allele info)]' \
  '--freq[allele frequency at each site]' \
  '--freq2[allele frequency (no labels)]' \
  '--derived[reorder with ancestral allele first]' \
  '--hap-r2[phased haplotype r2/D/D'\'']' \
  '--geno-r2[genotype squared correlation]' \
  '--geno-chisq[genotype chi-squared test]' \
  '--hap-r2-positions=[r2 against positions in file]:file:_files' \
  '--geno-r2-positions=[r2 against positions in file]:file:_files' \
  '--ld-window=[max SNPs between pairs]:n:' \
  '--ld-window-bp=[max bp between pairs]:n:' \
  '--ld-window-min=[min SNPs between pairs]:n:' \
  '--ld-window-bp-min=[min bp between pairs]:n:' \
  '--min-r2=[min r2 to report]:val:' \
  '--interchrom-hap-r2[interchrom hap r2]' \
  '--interchrom-geno-r2[interchrom geno r2]' \
  '--TsTv=[Ts/Tv ratio in bins]:n:' \
  '--TsTv-summary[Ts/Tv summary]' \
  '--TsTv-by-count[Ts/Tv by allele count]' \
  '--TsTv-by-qual[Ts/Tv by quality]' \
  '--FILTER-summary[SNP and Ts/Tv summary by FILTER]' \
  '--site-pi[per-site nucleotide divergence]' \
  '--window-pi=[windowed nucleotide diversity]:n:' \
  '--window-pi-step=[window step size]:n:' \
  '--weir-fst-pop=[Fst pop file]:file:_files' \
  '--fst-window-size=[Fst window size]:n:' \
  '--fst-window-step=[Fst window step]:n:' \
  '--TajimaD=[Tajima D in bins]:n:' \
  '--indv-freq-burden[per-individual variant count by frequency]' \
  '--LROH[long runs of homozygosity]' \
  '--relatedness[Yang relatedness statistic]' \
  '--relatedness2[KING relatedness statistic]' \
  '--SNPdensity=[SNP density per window]:n:' \
  '--kept-sites[file of retained sites]' \
  '--removed-sites[file of removed sites]' \
  '--singletons[singletons and private doubletons]' \
  '--hist-indel-len[histogram of indel lengths]' \
  '--hapcount=[unique haplotypes per BED bin]:file:_files' \
  '--mendel=[Mendelian errors PED file]:file:_files' \
  '--extract-FORMAT-info=[FORMAT field to extract]:field:' \
  '--get-INFO=[INFO field to extract]:field:' \
  '--recode[output new VCF]' \
  '--recode-bcf[output new BCF]' \
  '--recode-INFO=[INFO field to keep]:field:' \
  '--recode-INFO-all[keep all INFO fields]' \
  '--contigs=[contig header file for BCF]:file:_files' \
  '--012[genotypes as 0/1/2 matrix]' \
  '--IMPUTE[IMPUTE phased haplotype format]' \
  '--ldhat[LDhat phased output]' \
  '--ldhat-geno[LDhat unphased output]' \
  '--BEAGLE-GL[BEAGLE genotype likelihoods]' \
  '--BEAGLE-PL[BEAGLE phred-scaled likelihoods]' \
  '--plink[PLINK PED format]' \
  '--plink-tped[PLINK transposed format]' \
  '--chrom-map=[chromosome integer map]:file:_files' \
  '--diff=[compare to VCF]:file:_files' \
  '--gzdiff=[compare to gzip VCF]:file:_files' \
  '--diff-bcf=[compare to BCF]:file:_files' \
  '--diff-site[common/unique sites]' \
  '--diff-indv[common/unique individuals]' \
  '--diff-site-discordance[site-by-site discordance]' \
  '--diff-indv-discordance[per-individual discordance]' \
  '--diff-indv-map=[individual ID map]:file:_files' \
  '--diff-discordance-matrix[discordance matrix]' \
  '--diff-switch-error[phasing switch errors]' \
  '*:additional args:_files' && ret=0
return ret
