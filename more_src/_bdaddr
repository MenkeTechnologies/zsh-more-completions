#compdef bdaddr
# _bdaddr — BlueZ bdaddr (read/change a Bluetooth controller's BD_ADDR; -i hciX device, -r reset chip after write, -t transient (not persisted), positional argument is the new XX:XX:XX:XX:XX:XX address)
# upstream: https://github.com/bluez/bluez (tools/bdaddr.c)
# Flags from bluez tools/bdaddr.c on tip.

_bdaddr() {
    _arguments \
        '-h[show help]' \
        '-i+[hciX device]:device:' \
        '-r[reset chip after write]' \
        '-t[transient (not persisted)]' \
        '1:new BD_ADDR (XX:XX:XX:XX:XX:XX):'
}

_bdaddr "$@"
