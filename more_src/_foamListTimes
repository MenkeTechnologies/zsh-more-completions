#compdef foamListTimes
# Documentation: https://github.com/OpenFOAM/OpenFOAM-12/blob/master/applications/utilities/miscellaneous/foamListTimes/foamListTimes.C
# Documentation: https://github.com/OpenFOAM/OpenFOAM-12/blob/master/src/OpenFOAM/db/Time/timeSelector.C
# Documentation: https://github.com/OpenFOAM/OpenFOAM-12/blob/master/src/OpenFOAM/global/argList/argList.C
# Reference accessed: 2026-05-27
# Verified: upstream foamListTimes.C addBoolOption calls plus timeSelector::addOptions(true, true).
# noParallel() is called so -parallel/-roots/-hostRoots are removed; noFunctionObjects is removed too.

# foamListTimes: list times in an OpenFOAM case directory.
local curcontext="$curcontext" ret=1
_arguments -s \
  '-case[specify alternate case directory (default cwd)]:dir:_files -/' \
  '-fileHandler[override the file handler]:handler:(uncollated collated masterUncollated)' \
  '-libs[pre-load shared libraries]:libs:' \
  '-constant[include the constant/ dir in the times list]' \
  '-withZero[include the 0/ dir in the times list]' \
  '-noZero[exclude the 0/ dir from the times list (precedence over -withZero)]' \
  '-latestTime[select the latest time]' \
  '-time[comma-separated time ranges (e.g. :10,20,40:70,1000:)]:ranges:' \
  '-processor[list times from processor0/ directory]' \
  '-rm[remove selected time directories]' \
  '-functionEntries[execute functionEntries]' \
  '-help[display help]' \
  '-doc[display application documentation in browser]' \
  '-srcDoc[display source documentation in browser]' && ret=0
return ret
