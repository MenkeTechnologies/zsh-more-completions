#compdef higan ares bsnes
# Documentation: https://higan.readthedocs.io/en/stable/interface/higan-cli/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--fullscreen[start in fullscreen]' \
  '--system+[system]:s:(SNES NES Famicom GB GBC GBA SuperFamicom MasterSystem MegaDrive Genesis NeoGeoPocket NeoGeoPocketColor PCEngine SuperGrafx WonderSwan WonderSwanColor)' \
  '*: :_files -g "*.sfc *.smc *.gb *.gbc *.gba *.nes *.fc *.md *.gen *.smd *.gg *.sms *.pce *.zip *.7z"' && ret=0

return ret
