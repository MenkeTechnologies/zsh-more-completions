#compdef crfsuite
# Documentation: http://www.chokkan.org/software/crfsuite/manual.html
# Reference accessed: 2026-05-17
# Verified: upstream manual at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'learn:train a model from labeled data'
  'tag:label instances with a model'
  'dump:dump model as plain text'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[usage for crfsuite]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'crfsuite' subcmds && ret=0
    ;;
  rest)
    case $line[1] in
      learn)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[learn usage]' \
          '(-H --help-parameters)'{-H,--help-parameters}'[algorithm parameter help]' \
          '(-t --type)'{-t,--type=}'[graphical model]:model:(1d)' \
          '(-a --algorithm)'{-a,--algorithm=}'[trainer algorithm]:algo:(lbfgs l2sgd ap pa arow)' \
          '*'{-p,--set=}'[algorithm key=value parameter]:param:' \
          '(-m --model)'{-m,--model=}'[write model file]:file:_files' \
          '(-g --split)'{-g,--split=}'[N-way data split]:count:' \
          '(-e --holdout)'{-e,--holdout=}'[hold out 1-based group M]:group:' \
          '(-x --cross-validate)'{-x,--cross-validate}'[N-fold cross validation]' \
          '(-l --log-to-file)'{-l,--log-to-file}'[log to auto-named file]' \
          '(-L --logbase)'{-L,--logbase=}'[log file base name]:base:' \
          '*:training data:_files' && ret=0
        ;;
      tag)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[tag usage]' \
          '(-m --model)'{-m,--model=}'[model file]:file:_files' \
          '(-t --test)'{-t,--test}'[evaluate on labeled data]' \
          '(-r --reference)'{-r,--reference}'[print reference labels]' \
          '(-p --probability)'{-p,--probability}'[print sequence probabilities]' \
          '(-i --marginal)'{-i,--marginal}'[marginal prob for predicted label]' \
          '(-q --quiet)'{-q,--quiet}'[suppress tagging output]' \
          '*:data file:_files' && ret=0
        ;;
      dump)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[dump usage]' \
          '1:model file:_files' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
