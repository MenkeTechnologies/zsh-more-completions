#compdef pg_bulkload
# _pg_bulkload — PostgreSQL high-speed data loader (ossc-db/pg_bulkload)
# upstream: https://github.com/ossc-db/pg_bulkload
# Flags from bin/pg_bulkload.c (pgut_option table).

_pg_bulkload() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-i --infile)'{-i+,--infile=}'[control or data input file]:file:_files' \
        '--input=[input file (alternative to -i)]:file:_files' \
        '(-O --output)'{-O+,--output=}'[output destination]:dest:' \
        '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
        '(-P --parse-badfile)'{-P+,--parse-badfile=}'[parse-error bad records file]:file:_files' \
        '(-u --duplicate-badfile)'{-u+,--duplicate-badfile=}'[duplicate-error bad records file]:file:_files' \
        '*'{-o+,--option=}'[control-file KEY=VALUE option]:KEY=VAL:' \
        '(-D --pgdata)'{-D+,--pgdata=}'[PostgreSQL data directory (for -r recovery)]:dir:_files -/' \
        '(-r --recovery)'{-r,--recovery}'[run recovery instead of loading]' \
        '(-d --dbname)'{-d+,--dbname=}'[database name]:db:' \
        '(-h --host)'{-h+,--host=}'[Postgres host]:host:_hosts' \
        '(-p --port)'{-p+,--port=}'[Postgres port]:port:' \
        '(-U --username)'{-U+,--username=}'[Postgres user]:user:_users' \
        '(-W --password)'{-W,--password}'[force password prompt]' \
        '*:control or data file:_files'
}

_pg_bulkload "$@"
