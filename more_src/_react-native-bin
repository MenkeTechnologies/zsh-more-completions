#compdef react-native
# _react-native-bin — React Native CLI (Meta Inc); init/run/build/log Android+iOS native apps
# upstream: https://github.com/react-native-community/cli

_react-native-bin() {
    local -a sub=(
        'init:initialize new project'
        'start:run Metro dev server'
        'run-android:build and run on Android'
        'run-ios:build and run on iOS'
        'build-android:assemble Android'
        'build-ios:build iOS via xcodebuild'
        'log-android:tail logcat'
        'log-ios:tail iOS simulator log'
        'doctor:diagnose environment'
        'config:print resolved config'
        'info:print env info'
        'bundle:generate JS bundle'
        'ram-bundle:generate RAM bundle'
        'upgrade:upgrade RN version'
        'unbundle:alias for ram-bundle'
        'profile-hermes:profile Hermes engine'
        'eject:eject (deprecated)'
        'install:install package + link'
        'uninstall:uninstall package + unlink'
        'link:link native dependencies'
        'unlink:unlink native dependencies'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--projectRoot+[project root]:dir:_files -/' \
        '--reactNativePath+[react native path]:dir:_files -/' \
        '--verbose[verbose]' \
        '--no-interactive[no prompts]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'react-native subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '--port+[port]:port:' \
                    '--host+[host]:host:_hosts' \
                    '--projectRoot+[project root]:dir:_files -/' \
                    '--reset-cache[reset Metro cache]' \
                    '--watchFolders+[watch folder]:dir:_files -/' \
                    '--max-workers+[max workers]:n:' \
                    '--config+[Metro config]:file:_files' \
                    '--custom-log-reporter-path+[custom log reporter]:file:_files' \
                    '--https[serve over HTTPS]' \
                    '--cert+[TLS cert]:file:_files' \
                    '--key+[TLS key]:file:_files' \
                    '--no-interactive[no interactive shortcuts]' \
                    '--client-logs[include client logs]' ;;
                run-android) _arguments \
                    '--variant+[variant]:variant:(debug release)' \
                    '--mode+[mode]:mode:(debug release)' \
                    '--port+[Metro port]:port:' \
                    '--no-packager[do not launch packager]' \
                    '--terminal+[terminal app]:app:' \
                    '--device+[device id]:device:' \
                    '--deviceId+[device id]:device:' \
                    '--appId+[android applicationId]:id:' \
                    '--appIdSuffix+[applicationIdSuffix]:suffix:' \
                    '--main-activity+[main activity]:activity:' \
                    '--user+[run as user]:user:_users' \
                    '--tasks+[gradle tasks]:tasks:' \
                    '--list-devices[list devices]' ;;
                run-ios) _arguments \
                    '--simulator+[simulator name]:name:' \
                    '--device+[device id]:device:' \
                    '--udid+[device UDID]:udid:' \
                    '--configuration+[configuration]:cfg:(Debug Release)' \
                    '--mode+[configuration]:cfg:(Debug Release)' \
                    '--scheme+[scheme]:scheme:' \
                    '--project-path+[Xcode project path]:dir:_files -/' \
                    '--port+[Metro port]:port:' \
                    '--no-packager[do not launch packager]' \
                    '--terminal+[terminal app]:app:' \
                    '--list-devices[list devices]' \
                    '--binary-path+[prebuilt app]:file:_files' \
                    '--build-folder+[build folder]:dir:_files -/' ;;
                init) _arguments \
                    '1:name:' \
                    '--directory+[output dir]:dir:_files -/' \
                    '--template+[template]:template:' \
                    '--version+[RN version]:ver:' \
                    '--npm[use npm]' \
                    '--pm+[package manager]:pm:(npm yarn pnpm bun)' \
                    '--skip-install[skip install]' \
                    '--title+[app title]:str:' \
                    '--skip-git-init[skip git init]' ;;
            esac
            ;;
    esac
}

_react-native-bin "$@"
