#compdef erlfmt

# Zsh completion for erlfmt - Erlang source code formatter

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '(-V --version)'{-V,--version}'[show erlfmt version]'
  '(-c --check)'{-c,--check}'[check formatting without modifying files]'
  '(-w --write)'{-w,--write}'[write formatted output to file]'
  '(-i --insert-pragma)'{-i,--insert-pragma}'[insert @format pragma to unformatted files]'
  '--require-pragma[only format files with the @format pragma]'
  '--print-width[max line width]:width:'
  '--pragma-tag[pragma tag to use]:tag:'
  '--exclude-files[glob patterns to exclude]:pattern:'
  '--out[output directory]:dir:_files -/'
  '*:erlang file:_files -g "*.(erl|hrl|escript|app.src)"'
)

_arguments -s $arguments
