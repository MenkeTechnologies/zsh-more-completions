#compdef groupdel
# _groupdel — OpenBSD groupdel (low-level binary behind group del; removes a group line from /etc/group; verbose mode echoes each command as executed)
# upstream: https://github.com/openbsd/src (usr.sbin/user)
# Flags from usr.sbin/user/groupdel.8 on tip.

_groupdel() {
    _arguments \
        '-v[verbose]' \
        '1:group:_groups'
}

_groupdel "$@"
