#compdef meilitool
# Documentation: https://github.com/meilisearch/meilisearch/tree/main/crates/meilitool
# CLI tool to perform offline operations on a Meilisearch database

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--db-path=[database path where Meilisearch is running]:path:_files -/' \
  '1:command:((
    clear-task-queue\:"clear the task queue, making it empty"
    export-a-dump\:"export a dump from the Meilisearch database"
    export-documents\:"export documents from an index in NDJSON format to stdout"
    export-word-fst\:"export the word FST for a given index"
    offline-upgrade\:"attempt a version upgrade without a dump"
    index-compaction\:"compact an index using LMDB"
    hair-dryer\:"make dedicated pages hot in cache"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      export-a-dump)
        _arguments -s -S \
          '--dump-dir=[directory for dump creation]:path:_files -/' \
          '--skip-enqueued-tasks[skip dumping enqueued or processing tasks]' && ret=0
        ;;
      export-documents)
        _arguments -s -S \
          '--index-name=[index name to export from]:name:' \
          '--ignore-vectors[do not export vectors with documents]' \
          '--offset=[number of documents to skip]:offset:' && ret=0
        ;;
      offline-upgrade)
        _arguments -s -S \
          '--target-version=[target version in MAJOR.MINOR.PATCH format]:version:' && ret=0
        ;;
      hair-dryer)
        _arguments -s -S \
          '--index-name=[comma-delimited index names]:names:' \
          '--index-part=[comma-delimited index parts]:parts:' && ret=0
        ;;
      export-word-fst|index-compaction)
        _arguments '*:index name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
