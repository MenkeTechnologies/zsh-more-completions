#compdef cueconvert
# Documentation: https://man.archlinux.org/search?q=cueconvert
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --input-format)'{-i+,--input-format=}'[input format]:format:(cue toc)' \
  '(-o --output-format)'{-o+,--output-format=}'[output format]:format:(cue toc)' \
  '*:cue_or_toc:_files -g "*.{cue,toc}"' && ret=0

return ret
