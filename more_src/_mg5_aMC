#compdef mg5_aMC
# Documentation: https://launchpad.net/mg5amcnlo
# mg5_aMC - MadGraph5_aMC@NLO command-line interface

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --logging)'{-l,--logging}'[logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '(-f --file)'{-f,--file}'[script file to execute]:file:_files' \
  '(-d --mgme_dir)'{-d,--mgme_dir}'[MG_ME directory path to use]:dir:_files -/' \
  '--web[activate web mode operation]' \
  '--debug[force debug mode activation]' \
  '(-m --mode)'{-m,--mode}'[load additional commands via a plugin]:plugin:' \
  '(-s --nocaffeinate)'{-s,--nocaffeinate}'[disable caffeinate on macOS when running scripts]' \
  '*:file:_files' && ret=0

return ret
