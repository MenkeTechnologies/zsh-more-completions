#compdef xcdebug

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'launch:launch a binary under debug'
  'attach:attach to a process'
  'lldb:launch lldb session'
  'lldbserver:launch lldb-server'
  'help:show help'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'xcdebug subcommand' subcommands && ret=0
    ;;
esac

return ret
