#compdef ucloud
# Documentation: https://github.com/ucloud/ucloud-cli
# UCloud Command Line Interface

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version information]' \
  '--profile=[select which profile to use]:profile' \
  '--project-id=[override default project]:project id' \
  '--region=[override default region]:region' \
  '--zone=[override default zone]:zone' \
  '--base-url=[override API endpoint URL]:url' \
  '--timeout=[query timeout in seconds]:seconds' \
  '--public-key=[account public key]:key' \
  '--private-key=[account private key]:key' \
  '--max-retry-times=[retry attempts for idempotent APIs]:count' \
  '*:command:((init\:"initial setup and configuration" config\:"manage profiles" auth\:"authentication methods" uhost\:"virtual machine management" eip\:"elastic IP operations" gssh\:"GlobalSSH configuration" udisk\:"storage disk operations" ulb\:"load balancer management" region\:"region information" api\:"direct API calls"))' && ret=0

return ret
