#compdef ethr
# Documentation: https://github.com/microsoft/ethr
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-version[show version]' \
  '-s[run in server mode]' \
  '-c+[run in client mode against server]:server:_hosts' \
  '-x+[run in external client mode]:url:' \
  '-m+[multi client mode list URL]:url:' \
  '-t+[test type]:type:(b c p l pi tr cl)' \
  '-protocol[protocol]:proto:(tcp udp icmp http https)' \
  '-p+[port number]:port:' \
  '-r[reverse mode (server transmits)]' \
  '-d+[duration]:dur:' \
  '-i+[gap between latency tests]:dur:' \
  '-w+[buffer size in bytes]:bytes:' \
  '-l+[buffer size]:size:' \
  '-n+[parallel sessions or threads]:n:' \
  '-b+[bandwidth bits/sec]:rate:' \
  '-thc+[thread count for HTTP]:n:' \
  '-tos+[ToS or DSCP]:tos:' \
  '-iter+[ICMP iterations]:n:' \
  '-no[no output]' \
  '-o+[output file]:file:_files' \
  '-format=[output format]:fmt:(byte bit kbit kbyte mbit mbyte gbit gbyte tbit tbyte)' \
  '-debug[enable debug logging]' \
  '-ic[ignore certs]' \
  '-ports+[server ports csv]:list:' \
  '-4[IPv4 only]' \
  '-6[IPv6 only]' \
  '-ports.tcp=[tcp ports]:ports:' \
  '-ports.udp=[udp ports]:ports:' \
  '-ports.http=[http ports]:ports:' \
  '-ports.https=[https ports]:ports:' \
  '-ports.icmp=[icmp ports]:ports:' && ret=0

return ret
