#compdef kstars
# Documentation: https://docs.kde.org/stable5/en/kstars/kstars/commands.html
# Reference accessed: 2026-05-16
# Verified: KDE Stars Handbook "Command-Line Options" + upstream KDE
# kstars/main.cpp QCommandLineParser setup.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --paper option.

# kstars: KDE desktop planetarium
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help-all[show all options (including Qt/KDE)]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--dump[immediately dump a sky chart then quit]' \
  '--script=[script to execute]:file:_files -g "*.kstars(-.)"' \
  '--width=[image width in pixels]:px:' \
  '--height=[image height in pixels]:px:' \
  '--filename=[output file for dumped image]:file:_files' \
  '--date=[FITS date in ISO 8601 format]:date:' \
  '--qwindowicon=[set default window icon]:icon:' \
  '--qwindowtitle=[set window title]:title:' \
  '--display=[X display]:disp:' \
  '--platform=[Qt platform plugin]:platform:' && ret=0
return ret
