#compdef kstars

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--dump[take screenshot and quit]' \
  '--script=+[script file]:file:_files -g "*.kstars"' \
  '--width=+[width]:px:' \
  '--height=+[height]:px:' \
  '--filename=+[output file]:file:_files -g "*.{png,jpg}"' \
  '--date=+[date]:date:' \
  '--paper=+[paper size]:size:' \
  '--display=+[X display]:disp:' && ret=0

return ret
