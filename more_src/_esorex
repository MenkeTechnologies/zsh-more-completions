#compdef esorex
# Documentation: https://manpages.debian.org/testing/esorex/esorex.1.en.html
# ESO Recipe Execution Tool

local ret=1

_arguments -s -S \
  '(- *)--help[display help and exit]' \
  '(- *)--version[show version details and exit]' \
  '--check-sof-exist[verify all input files exist and are readable before execution]' \
  '--config=[configuration file for esorex]:config file:_files' \
  '--create-config=[create a configuration file]:value or file:_files' \
  '--link-dir=[output location for symbolic links to products]:directory:_files -/' \
  '--log-dir=[directory where to place the logfile]:directory:_files -/' \
  '--log-file=[name of the logfile]:logfile:_files' \
  '--log-level=[severity threshold for logfile messages]:level:(debug info warning error off)' \
  '--no-datamd5[disable MD5 hash computation for FITS products]' \
  '--no-checksum[disable standard FITS product checksums]' \
  '--man-page[display a manual page for the specified recipe and exit]' \
  '--mem-check[report memory status after recipe execution]' \
  '--msg-level=[severity threshold for terminal messages]:level:(debug info warning error off)' \
  '--output-dir=[destination for final product files]:directory:_files -/' \
  '--output-prefix=[prefix applied to output files]:prefix:' \
  '--output-readonly[set output products to read-only permissions]' \
  '--paf-config=[configuration file for PAF file creation]:paf config:_files' \
  '--params[list input parameters and their current settings]' \
  '--products-sof=[output file listing FITS files created by recipe]:sof file:_files' \
  '--recipes[display a list of all available recipes]' \
  '--recipe-config=[configuration file for selected recipe]:recipe config:_files' \
  '--recipe-dir=[directory containing recipe libraries]:directory:_files -/' \
  '--show-hidden[display recipe parameters marked as hidden]' \
  '--suppress-link[prevent creation of symbolic links to products]' \
  '--suppress-prefix[maintain the original name of the output product]' \
  '--time[measure and display recipe execution duration]' \
  '--unload-plugin[unload plugin after execution]' \
  '*:recipe or sof:_files' && ret=0

return ret
