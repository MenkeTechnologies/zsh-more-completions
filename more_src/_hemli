# Probed via: completions zsh

autoload -U is-at-least

_hemli() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
":: :_hemli_commands" \
"*::: :->hemli" \
&& ret=0
    case $state in
    (hemli)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:hemli-command-$line[1]:"
        case $line[1] in
            (get)
_arguments "${_arguments_options[@]}" : \
'-n+[Namespace for the secret]:NAMESPACE:_default' \
'--namespace=[Namespace for the secret]:NAMESPACE:_default' \
'--ttl=[TTL (duration) for the cached secret]:TTL:_default' \
'(--source-cmd)--source-sh=[Source command to run via sh -c]:SOURCE_SH:_default' \
'(--source-sh)--source-cmd=[Source command to run directly]:SOURCE_CMD:_default' \
'(--no-refresh)--force-refresh[Force refresh from source even if cached]' \
'(--force-refresh)--no-refresh[Only return cached value, never refresh]' \
'--no-store[Don'\''t store the fetched secret in keyring]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':secret -- Name of the secret:_default' \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
'-n+[Namespace for the secret]:NAMESPACE:_default' \
'--namespace=[Namespace for the secret]:NAMESPACE:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':secret -- Name of the secret:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-n+[Filter by namespace]:NAMESPACE:_default' \
'--namespace=[Filter by namespace]:NAMESPACE:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(inspect)
_arguments "${_arguments_options[@]}" : \
'-n+[Namespace for the secret]:NAMESPACE:_default' \
'--namespace=[Namespace for the secret]:NAMESPACE:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':secret -- Name of the secret:_default' \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
'-n+[Namespace for the secret]:NAMESPACE:_default' \
'--namespace=[Namespace for the secret]:NAMESPACE:_default' \
'(--clear-ttl)--ttl=[New TTL (duration)]:TTL:_default' \
'(--source-cmd)--source-sh=[New source command (sh -c)]:SOURCE_SH:_default' \
'(--source-sh)--source-cmd=[New source command (direct)]:SOURCE_CMD:_default' \
'(--ttl)--clear-ttl[Remove TTL (secret will never expire)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':secret -- Name of the secret:_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- The shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_hemli__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:hemli-help-command-$line[1]:"
        case $line[1] in
            (get)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(inspect)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_hemli_commands] )) ||
_hemli_commands() {
    local commands; commands=(
'get:Get a secret, fetching from source if needed' \
'delete:Delete a secret from the keyring' \
'list:List stored secrets' \
'inspect:Inspect a cached secret, showing full metadata as JSON' \
'edit:Edit metadata of a cached secret (TTL, source command)' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'hemli commands' commands "$@"
}
(( $+functions[_hemli__subcmd__completions_commands] )) ||
_hemli__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'hemli completions commands' commands "$@"
}
