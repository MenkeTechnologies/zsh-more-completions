#compdef argdist argdist-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/argdist.py argparse)
# Reference accessed: 2026-05-29
# argdist — display function parameter values as a histogram or frequency count (BCC/eBPF).
# Probe specifier: P:LIB:FUNC(SIG)[:EXPR[:FILTER]][#LABEL]  (P = p/r/u/t for kprobe/kretprobe/uprobe/tracepoint)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-t --tid)'{-t,--tid=}'[trace this TID only]:tid:' \
  '(-z --string-size)'{-z,--string-size=}'[max string size to read from char* args (default 80)]:size:' \
  '(-i --interval)'{-i,--interval=}'[output interval in seconds (default 1)]:sec:' \
  '(-d --duration)'{-d,--duration=}'[total duration of trace, in seconds]:sec:' \
  '(-n --number)'{-n,--number=}'[number of outputs]:N:' \
  '(-v --verbose)'{-v,--verbose}'[print resulting BPF program code before executing]' \
  '(-c --cumulative)'{-c,--cumulative}'[do not clear histograms / freq counts at each interval]' \
  '(-T --top)'{-T,--top=}'[number of top results to show (not for histograms)]:N:' \
  '*'{-H,--histogram=}'[probe specifier to capture histogram of]:specifier:' \
  '*'{-C,--count=}'[probe specifier to capture count of]:specifier:' \
  '*'{-I,--include=}'[additional header file to include in BPF program]:header:_files -g "*.h"' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
