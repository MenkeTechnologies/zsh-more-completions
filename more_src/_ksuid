#compdef ksuid

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-n --count)'{-n,--count}'=[number of KSUIDs to generate]:count' \
  '(-f --format)'{-f,--format}'=[output format]:format:(string inspect time stamp raw)' \
  '(-t --template)'{-t,--template}'=[Go template for output]:template' \
  '(-v --verbose)'{-v,--verbose}'[verbose output, show timestamp and payload]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:ksuid to inspect' && ret=0

return ret
