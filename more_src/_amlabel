#compdef amlabel
# _amlabel — Zmanda Amanda amlabel CLI for writing tape headers labelling Amanda backup tapes assigning labels to changer slots verifying labels overwriting tape erasing with optional force barcode mode (zmanda team, C); getopt
# upstream: https://github.com/zmanda/amanda

_amlabel() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-f[force write]' \
        '--force[force write]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r[reset/clear]' \
        '--reset[reset/clear]' \
        '-o+[option]:str:' \
        '--changer-name=+[name]:str:' \
        '--slot=+[N]:n:' \
        '--meta-label=+[label]:str:' \
        '--storage=+[name]:str:' \
        '--barcode=+[code]:str:' \
        '--check-and-label[check and label]' \
        '--print-only[print only]' \
        '*:config label:'
}

_amlabel "$@"
