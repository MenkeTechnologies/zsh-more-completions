#compdef sfvscan
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mvscan.c
# Madagascar: velocity analysis (semblance scan)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'semblance=[if y, compute semblance; if n, stack]:flag:(y n)' \
  'diffsemblance=[if y, compute differential semblance]:flag:(y n)' \
  'avosemblance=[if y, compute AVO-friendly semblance]:flag:(y n)' \
  'type=[type of semblance]:type:(avo diff sembl power weighted)' \
  'nb=[semblance averaging]:samples' \
  'weight=[if y, apply pseudo-unitary weighting]:flag:(y n)' \
  'half=[if y, second axis is half-offset instead of full offset]:flag:(y n)' \
  'offset=[optional offset file]:file:_files' \
  'mask=[optional mask file]:file:_files' \
  'v0=[first scanned velocity]:velocity' \
  'dv=[step in velocity]:step' \
  'nv=[number of scanned velocities]:count' \
  'smax=[maximum heterogeneity]:value' \
  'ns=[number of heterogeneity scans]:count' \
  'slowness=[if y, use slowness instead of velocity]:flag:(y n)' \
  'squared=[if y, the slowness or velocity is squared]:flag:(y n)' \
  'v1=[reference velocity]:velocity' \
  'grad=[gradient file input]:file:_files' \
  'extend=[trace extension]:samples' \
  'mute=[mute zone]:samples' \
  'str=[maximum stretch allowed]:value' \
  '*:RSF file:_files' && ret=0

return ret
