#compdef gpssh
# Greenplum utility to run commands across multiple cluster hosts via SSH

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '--version[show version]' \
  '-f+[file containing list of hosts]:file:_files' \
  '*-h+[individual host name]:host:_hosts' \
  '-e[echo commands and their output]' \
  '-d+[wait time at start of SSH interaction]:secs:' \
  '-t+[timeout multiplier for ssh prompt validation]:multiplier:' \
  '-s[source greenplum_path.sh before running commands]' \
  '-v[verbose mode]' \
  '*:command:_command_names -e' && ret=0

return ret
