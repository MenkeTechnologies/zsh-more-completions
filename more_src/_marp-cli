#compdef marp
# Documentation: https://github.com/marp-team/marp-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '(-o --output)'{-o,--output}'=[output file]:file:_files'
  '(-I --input-dir)'{-I,--input-dir}'=[input directory]:dir:_files -/'
  '(-c --config --config-file)'{-c,--config,--config-file}'=[configuration file]:file:_files'
  '--no-config[disable config file lookup]'
  '--no-config-file[disable config file lookup]'
  '--theme=[theme name or CSS file]:theme:'
  '--theme-set=[path to additional themes]:dir:_files -/'
  '--engine=[Marpit engine]:engine:'
  '--template=[template]:template:(bare bespoke)'
  '--html[enable inline HTML]'
  '--pdf[convert to PDF]'
  '--pptx[convert to PPTX]'
  '--pptx-editable[generate editable PPTX]'
  '--notes[export presenter notes as text]'
  '--image=[convert title slide to image]:format:(png jpeg)'
  '--images=[convert slides to images]:format:(png jpeg)'
  '--image-scale=[scale factor for images]:scale:'
  '--jpeg-quality=[JPEG quality]:quality:'
  '--allow-local-files[allow local file access]'
  '(-w --watch)'{-w,--watch}'[watch mode]'
  '(-s --server)'{-s,--server}'[server mode]'
  '(-p --preview)'{-p,--preview}'[open preview window]'
  '(-P --parallel)'{-P,--parallel}'=[concurrency level]:n:'
  '--no-parallel[disable parallel processing]'
  '--pdf-notes[add presenter notes to PDF]'
  '--pdf-outlines[add outlines to PDF]'
  '--pdf-outlines.headings[add heading outlines to PDF]'
  '--pdf-outlines.pages[add page outlines to PDF]'
  '--bespoke.osc[enable on-screen controller for bespoke template]'
  '--bespoke.progress[enable progress bar for bespoke template]'
  '--bespoke.transition[enable transitions for bespoke template]'
  '--title=[HTML title]:title:'
  '--description=[HTML description]:description:'
  '--author=[HTML author]:author:'
  '--keywords=[HTML keywords]:keywords:'
  '--url=[canonical URL]:url:'
  '--og-image=[Open Graph image URL]:url:'
  '--browser=[browser to use]:browser:(auto chrome edge firefox)'
  '--browser-path=[browser executable path]:path:_files'
  '--browser-protocol=[connection protocol]:protocol:(cdp webdriver-bidi)'
  '--browser-timeout=[browser operation timeout in seconds]:seconds:'
  '(-h --help)'{-h,--help}'[show help]'
  '(-v --version)'{-v,--version}'[show version]'
  '*:markdown file:_files -g "*.md"'
)

_arguments -s -S $arguments
