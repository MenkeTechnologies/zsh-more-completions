#compdef cribbage
# Documentation: man cribbage(6)
# Source: openbsd/src games/cribbage/crib.c — card game (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '-e[explain scoring]' \
    '-m[muggins rule]' \
    '-q[quiet]' \
    '-r[random scoring details]' \
    && ret=0

return ret
