#compdef spacemacs

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug-init[Spacemacs/Emacs debug init]' \
  '--no-init[do not load init file]' \
  '--no-site-file[do not load site-start.el]' \
  '--no-splash[skip splash screen]' \
  '--user-init-dir=[user init directory]:dir:_files -/' \
  '*::passthrough:_command_names' && ret=0

return ret
