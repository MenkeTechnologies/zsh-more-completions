#compdef spacemacs
# Documentation: https://www.spacemacs.org/doc/DOCUMENTATION.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: Spacemacs is an Emacs distribution/configuration, not a standalone CLI.
# It is invoked via the `emacs` binary; there is no dedicated `spacemacs` command
# documented with its own flag set. Provide file completion as a fallback.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:file:_files' && ret=0
return ret
