#compdef conpix
# _conpix — apply a constant operation to every pixel in a FITS image (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from conpix.c (single-letter getopt-style).

_conpix() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-a+[add constant to all pixels]:val:' \
        '-c+[set all pixels to a constant value]:val:' \
        '-d+[divide all pixels by constant]:val:' \
        '-g[add Gaussian noise (sqrt pixel value)]' \
        '-i+[logging frequency]:n:' \
        '-l[take log base 10 of all pixels]' \
        '-m+[multiply all pixels by constant]:val:' \
        '-n[output to new file]' \
        '-r[take square root of all pixels]' \
        '-s+[subtract constant from all pixels]:val:' \
        '-@+[file with list of input filenames]:file:_files' \
        '-v[verbose output]' \
        '*:FITS file:_files -g "*.(fits|fit|fts|imh)"'
}

_conpix "$@"
