#compdef asciidoctor
# Documentation: https://docs.asciidoctor.org/asciidoctor/latest/cli/man1/asciidoctor/
# Source: asciidoctor — AsciiDoc → HTML / DocBook / man page converter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-B --base-dir)'{-B+,--base-dir=}'[base directory of document + resources]:dir:_directories' \
    '(-S --safe-mode)'{-S+,--safe-mode=}'[safe mode level]:mode:(unsafe safe server secure)' \
    '--safe[set safe mode level to safe]' \
    '*'{-a,--attribute=}'[define / override / unset a document attribute]:name=value:' \
    '(-b --backend)'{-b+,--backend=}'[backend output format]:backend:(html5 docbook5 manpage)' \
    '(-d --doctype)'{-d+,--doctype=}'[document type]:doctype:(article book manpage inline)' \
    '(-D --destination-dir)'{-D+,--destination-dir=}'[destination output directory]:dir:_directories' \
    '(-E --template-engine)'{-E+,--template-engine=}'[template engine for custom converter templates]:engine:(erb slim haml liquid)' \
    '(-e --embedded -s --no-header-footer)'{-e,--embedded}'[output embeddable document (no header/footer)]' \
    '(-e --embedded -s --no-header-footer)'{-s,--no-header-footer}'[output embeddable document (alias)]' \
    '*'{-I,--load-path=}'[add directory to Ruby load path]:dir:_directories' \
    '(-n --section-numbers)'{-n,--section-numbers}'[auto-number section titles]' \
    '(-o --out-file)'{-o+,--out-file=}'[output file]:file:_files' \
    '(-R --source-dir)'{-R+,--source-dir=}'[source dir to preserve structure under -D]:dir:_directories' \
    '*'{-r,--require=}'[require library before processing]:lib:' \
    '(-T --template-dir)'{-T+,--template-dir=}'[custom converter templates directory]:dir:_directories' \
    '--failure-level=[min log level for non-zero exit]:level:(WARN ERROR FATAL)' \
    '(-q --quiet)'{-q,--quiet}'[silence log messages and warnings]' \
    '--trace[include backtrace when reporting errors]' \
    '(-v --verbose)'{-v,--verbose}'[set log level to DEBUG]' \
    '(-w --warnings)'{-w,--warnings}'[turn on script warnings]' \
    '(-t --timings)'{-t,--timings}'[print timings report to stderr]' \
    '(- *)'{-h,--help=-}'[show help (optional TOPIC)]:topic:' \
    '(- *)'{-V,--version}'[print version]' \
    '*:.adoc file:_files -g "*.(adoc|asciidoc|ad)"' \
    && ret=0

return ret
