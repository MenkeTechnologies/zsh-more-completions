#compdef asciidoctor

_arguments -s \
  '(- *)'{-h,--help}'[show help]:topic:(syntax manpage)' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --backend)'{-b,--backend=}'[output backend]:backend:(html5 xhtml5 docbook5 manpage pdf epub3)' \
  '(-d --doctype)'{-d,--doctype=}'[document type]:doctype:(article book manpage inline)' \
  '(-e --embedded)'{-e,--embedded}'[embedded mode]' \
  '(-o --out-file)'{-o,--out-file=}'[output file]:file:_files' \
  '--safe[set safe mode to safe]' \
  '(-S --safe-mode)'{-S,--safe-mode=}'[safe mode]:mode:(unsafe safe server secure)' \
  '(-s --no-header-footer)'{-s,--no-header-footer}'[suppress header and footer]' \
  '(-n --section-numbers)'{-n,--section-numbers}'[number sections]' \
  '--eruby=[eruby implementation]:impl:(erb erubi erubis)' \
  '*'{-a,--attribute=}'[set attribute name=value]:attr:' \
  '*'{-T,--template-dir=}'[template directory]:dir:_files -/' \
  '(-E --template-engine)'{-E,--template-engine=}'[template engine]:engine:' \
  '(-B --base-dir)'{-B,--base-dir=}'[base directory]:dir:_files -/' \
  '(-R --source-dir)'{-R,--source-dir=}'[source directory]:dir:_files -/' \
  '(-D --destination-dir)'{-D,--destination-dir=}'[destination directory]:dir:_files -/' \
  '*'{-I,--load-path=}'[Ruby load path]:dir:_files -/' \
  '*'{-r,--require=}'[require Ruby library]:lib:' \
  '--failure-level=[level]:level:(INFO WARN ERROR FATAL)' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--trace[trace exceptions]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-w --warnings)'{-w,--warnings}'[show warnings]' \
  '(-t --timings)'{-t,--timings}'[show timings]' \
  '*:input:_files -g "*.(adoc|asciidoc|asc|ad|txt)"'
