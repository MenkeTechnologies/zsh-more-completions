#compdef urbackupclientctl
# Documentation: https://www.urbackup.org/administration_manual.html
# urbackupclientctl: command line control for the UrBackup client

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'start:start an incremental or full file/image backup'
      'status:get current backup status'
      'browse:browse backups and files/folders in backups'
      'restore-start:restore files/folders from a backup'
      'set-settings:set backup settings'
      'reset-keep:reset keeping files during incremental backups'
      'add-backupdir:add a new directory to the backup set'
      'list-backupdirs:list directories that are being backed up'
      'remove-backupdir:remove a directory from the backup set'
    )
    _describe -t commands 'urbackupclientctl command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      start)
        _arguments \
          '-i[start an incremental backup]' \
          '-f[start a full backup]' \
          '*:file:_files' && ret=0
        ;;
      add-backupdir|remove-backupdir)
        _arguments \
          '-d[directory path]:dir:_files -/' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
