#compdef supabase
# Documentation: https://supabase.com/docs/reference/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--debug[output debug logs to stderr]' \
  '--experimental[enable experimental features]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(env pretty json toml yaml)' \
  '--profile=[configuration profile]:profile:' \
  '--workdir=[project directory]:dir:_files -/' \
  '--yes[skip confirmation prompts]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'init:set up local development configuration'
      'login:authenticate with Supabase account'
      'link:connect local project to a hosted instance'
      'start:launch local development environment'
      'stop:shut down local development stack'
      'status:display current stack status'
      'db:manage database operations'
      'migration:handle schema migrations'
      'gen:generate types and signing keys'
      'test:run pgTAP tests'
      'projects:manage projects'
      'orgs:manage organizations'
      'branches:handle preview branches'
      'config:update project configurations'
      'functions:deploy and manage Edge Functions'
      'secrets:store environment variables'
      'sso:configure identity providers'
      'domains:set up custom domains'
      'network-restrictions:restrict DB access by IP'
      'network-bans:manage network bans'
      'ssl-enforcement:manage SSL requirements'
      'storage:manage file storage buckets'
      'seed:populate initial data'
      'inspect:inspect database performance and health'
      'services:display service versions'
      'telemetry:manage analytics settings'
      'completion:generate shell autocomplete scripts'
    )
    _describe -t commands 'supabase command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      db)
        local -a db_cmds=(
          'pull:pull remote schema changes'
          'push:push local migrations to remote'
          'reset:reset local database'
          'dump:dump remote database'
          'diff:diff local and remote schemas'
          'lint:lint local database'
          'start:start local database'
        )
        _describe -t commands 'supabase db command' db_cmds && ret=0
        ;;
      functions)
        local -a fn_cmds=(
          'new:create a new function'
          'serve:serve functions locally'
          'deploy:deploy functions'
          'delete:delete a function'
          'list:list functions'
        )
        _describe -t commands 'supabase functions command' fn_cmds && ret=0
        ;;
      migration)
        local -a mig_cmds=(
          'new:create a new migration'
          'list:list migrations'
          'fetch:fetch migrations from remote'
          'repair:repair migration history'
          'squash:squash migrations'
          'up:apply pending migrations'
          'down:revert applied migrations'
        )
        _describe -t commands 'supabase migration command' mig_cmds && ret=0
        ;;
      gen)
        local -a gen_cmds=(
          'types:output database-derived type definitions'
          'signing-key:create JWT signing keys'
        )
        _describe -t commands 'supabase gen command' gen_cmds && ret=0
        ;;
      inspect)
        _arguments '1:subcommand:(db)' && ret=0
        ;;
    esac
    ;;
esac
return ret
