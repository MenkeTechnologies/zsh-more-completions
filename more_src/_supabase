#compdef supabase

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'init:initialize a local project'
      'login:log in to Supabase'
      'link:link to a Supabase project'
      'start:start local Supabase containers'
      'stop:stop local Supabase containers'
      'status:show status of local Supabase containers'
      'db:manage local databases'
      'gen:generate types and schemas'
      'migration:manage database migrations'
      'functions:manage edge functions'
      'secrets:manage project secrets'
      'domains:manage custom domains'
      'vanity-subdomains:manage vanity subdomains'
      'network-bans:manage network bans'
      'network-restrictions:manage network restrictions'
      'ssl-enforcement:manage SSL enforcement'
      'projects:manage Supabase projects'
      'orgs:manage Supabase organizations'
      'services:show services status'
      'sso:manage single sign-on'
      'storage:manage storage'
      'inspect:inspect database'
      'completion:generate shell completion'
      'version:show version'
    )
    _describe -t commands 'supabase command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      db)
        local -a db_cmds=(
          'push:push local migrations to remote'
          'pull:pull remote schema changes'
          'reset:reset local database'
          'diff:diff local and remote schemas'
          'lint:lint local database'
          'dump:dump remote database'
        )
        _describe -t commands 'supabase db command' db_cmds && ret=0
        ;;
      functions)
        local -a fn_cmds=(
          'new:create a new function'
          'serve:serve functions locally'
          'deploy:deploy functions'
          'delete:delete a function'
          'list:list functions'
        )
        _describe -t commands 'supabase functions command' fn_cmds && ret=0
        ;;
      migration)
        local -a mig_cmds=(
          'new:create a new migration'
          'list:list migrations'
          'repair:repair migration history'
          'squash:squash migrations'
          'up:apply pending migrations'
        )
        _describe -t commands 'supabase migration command' mig_cmds && ret=0
        ;;
    esac
    ;;
esac
return ret
