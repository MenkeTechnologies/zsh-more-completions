#compdef knative-cli kn-cli2
# _knative-cli — Knative knative-cli CLI command-line frontend wrapping the Knative serverless platform Kubernetes-native serving eventing services revisions routes triggers brokers sources channels subscriptions parallels-sequences-flows quickstart-domain-mapping container-source-pingsource (Knative team, Go); cobra
# upstream: https://knative.dev/

_knative-cli() {
    local -a sub=(
        'service:Knative Service operations'
        'revision:Revision operations'
        'route:Route operations'
        'config:configuration'
        'plugin:plugin management'
        'trigger:Trigger operations'
        'broker:Broker operations'
        'source:Source operations'
        'channel:Channel operations'
        'subscription:Subscription operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-A[all namespaces]' \
        '--cluster=+[name]:str:' \
        '--user=+[user]:str:' \
        '-o+[format]:f:(json yaml table wide name url description)' \
        '--output=+[format]:f:(json yaml table wide name url description)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'knative-cli subcommand' sub ;;
        args)
            case $words[1] in
                service|revision|route|trigger|broker|source|channel|subscription) _arguments \
                    '1:op:(list get create update delete describe apply)' \
                    '--image=+[image]:str:' \
                    '--port=+[port]:n:' \
                    '--env=+[k=v]:str:' \
                    '--annotation=+[k=v]:str:' \
                    '--label=+[k=v]:str:' \
                    '--limit=+[k=v]:str:' \
                    '--request=+[k=v]:str:' \
                    '--scale-min=+[N]:n:' \
                    '--scale-max=+[N]:n:' \
                    '*:name:' ;;
            esac
            ;;
    esac
}

_knative-cli "$@"
