#compdef create-my-express
# Documentation: https://www.npmjs.com/package/create-my-express
# Reference accessed: 2026-05-23
# Verified: npm view create-my-express bin; npm readme Options section.

# Zsh completion for create-my-express - Express.js project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-G --nogit)'{-G,--nogit}'[do not initialize a git repository]' \
  '(-n --name)'{-n,--name=}'[project name]:name:' \
  '(-t --typescript)'{-t,--typescript}'[generate TypeScript project template]' \
  '(-y --yarn)'{-y,--yarn}'[use yarn instead of npm]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[output version number]' \
  ':project name:' && ret=0

return ret
