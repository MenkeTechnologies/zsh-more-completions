#compdef faNoise
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# add noise to .fa file

local ret=1

_arguments -s -S \
  '-upper[output in upper case]' \
  '1:in name:_files -g "*.(fa|fasta)"' \
  '2:out name:_files' \
  '3:transition ppt' \
  '4:transversion ppt' \
  '5:insert ppt' \
  '6:delete ppt' \
  '7:chimera ppt' && ret=0

return ret
