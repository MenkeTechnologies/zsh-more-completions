#compdef qpid-config
# Documentation: https://qpid.apache.org/releases/qpid-cpp-1.39.0/cpp-broker/book/chapter-Managing-CPP-Broker.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'exchanges:list exchanges'
  'queues:list queues'
  'add:add an object (exchange or queue)'
  'del:delete an object (exchange or queue)'
  'bind:bind a queue to an exchange'
  'unbind:remove a binding'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --bindings)'{-b,--bindings}'[show bindings in queue/exchange list]' \
  '(-a --broker-addr)'{-a,--broker-addr=}'[broker address (default localhost)]:addr:' \
  '--durable[make queue/exchange persistent]' \
  '--file-count=[journal file count]:n:' \
  '--file-size=[journal file size in 64KiB pages]:n:' \
  '--max-queue-size=[maximum in-memory queue size in bytes]:bytes:' \
  '--max-queue-count=[maximum message count for queue]:n:' \
  '--limit-policy=[queue overflow behavior]:policy:(none reject flow-to-disk ring ring-strict)' \
  '--order=[queue ordering]:policy:(fifo lvq lvq-no-browse)' \
  '--sequence[insert message sequence field on exchange]' \
  '--ive[enable initial-value-exchange behavior]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'qpid-config subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (add|del)
        _values 'object' 'exchange' 'queue' && ret=0
        ;;
    esac
    ;;
esac

return ret
