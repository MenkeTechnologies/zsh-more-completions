#compdef qpid-config

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'exchanges:list exchanges'
  'queues:list queues'
  'add:add an object'
  'del:delete an object'
  'bind:bind a queue to an exchange'
  'unbind:unbind a queue from an exchange'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --bindings)'{-b,--bindings}'[show bindings]' \
  '(-a --broker-addr)'{-a,--broker-addr=}'[broker address]:addr:' \
  '--durable[make queue/exchange durable]' \
  '--file-count=[journal file count]:n:' \
  '--file-size=[journal file size]:size:' \
  '--max-queue-size=[max queue size bytes]:bytes:' \
  '--max-queue-count=[max queue message count]:n:' \
  '--limit-policy=[queue limit policy]:policy:(none reject flow_to_disk ring ring_strict)' \
  '--order=[queue ordering policy]:policy:(fifo lvq)' \
  '--sequence[exchange sequence option]' \
  '--ive[initial value exchange option]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'qpid-config subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (add|del)
        _values 'object' 'exchange' 'queue' && ret=0
        ;;
    esac
    ;;
esac

return ret
