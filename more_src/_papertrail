#compdef papertrail
# Documentation: https://man.archlinux.org/search?q=papertrail
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '(-f --follow)'{-f,--follow}'[continue running and print new events]' \
  '(-d --delay)'{-d+,--delay=}'[delay between refreshes (s)]:seconds:' \
  '(-c --configfile)'{-c+,--configfile=}'[config file]:file:_files' \
  '(-s --system)'{-s+,--system=}'[system to search]:system:' \
  '(-g --group)'{-g+,--group=}'[group to search]:group:' \
  '(-j --json)'{-j,--json}'[output raw JSON]' \
  '--color=[color mode]:mode:(off auto always)' \
  '--force-color[force ANSI color]' \
  '--min-time=[earliest time to search]:time:' \
  '--max-time=[latest time to search]:time:' \
  '--min-id=[minimum event id]:id:' \
  '--max-id=[maximum event id]:id:' \
  '*::query:' && ret=0

return ret
