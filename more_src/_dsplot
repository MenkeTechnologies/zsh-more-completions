#compdef dsplot
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/dsplot/node4.html
# Plot tables in data sets using Grace

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--plotter=[plotting program to invoke on the generated file]:program:_command_names -e' \
  '*:param=value:_default' && ret=0

return ret
