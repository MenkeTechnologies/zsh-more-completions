#compdef cloak

_cloak_subcommands() {
  local -a subcmds=(
    'add:Add a secret'
    'edit:Edit a secret'
    'get:Get a secret value'
    'list:List secrets'
    'remove:Remove a secret'
    'init:Initialize a new secrets store'
    'env:Manage environments'
    'export:Export secrets'
    'import:Import secrets'
    'generate:Generate a new secret value'
    'sync:Sync secrets with remote'
    'config:Manage configuration'
    'version:Show version information'
  )
  _describe -t commands 'cloak subcommand' subcmds
}

_cloak() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-V,--version}'[Show version]' \
    '--config[Config file]:file:_files' \
    '--env[Environment to use]:env:' \
    '--verbose[Enable verbose output]' \
    '1:subcommand:_cloak_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        add)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--env[Environment]:env:' \
            '--generate[Generate a random value]' \
            '--length[Length of generated value]:length:' \
            '1:key:' \
            '2:value:'
          ;;
        get)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--env[Environment]:env:' \
            '--format[Output format]:format:(plain json)' \
            '1:key:'
          ;;
        remove)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--env[Environment]:env:' \
            '1:key:'
          ;;
        list)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--env[Environment]:env:' \
            '--format[Output format]:format:(plain json table)' \
            '--show-values[Show secret values]'
          ;;
        export)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--env[Environment]:env:' \
            '--format[Export format]:format:(dotenv json yaml shell)' \
            '-o[Output file]:file:_files' \
            '--output[Output file]:file:_files'
          ;;
        import)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--env[Environment]:env:' \
            '--format[Import format]:format:(dotenv json yaml)' \
            '1:file:_files'
          ;;
        env)
          _arguments \
            '1:action:(create list delete switch)' \
            '2:name:'
          ;;
      esac
      ;;
  esac
}

_cloak "$@"
