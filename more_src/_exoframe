#compdef exoframe

if (( CURRENT == 1 )); then
  _values 'exoframe command' \
    config deploy endpoint login list logs remove secret setup system template token update
  return
fi

_exoframe_config_main() {
  _arguments -s -S \
    '(--init)--init[bootstrap config]' \
    '(-d --domain)'{-d,--domain}'=[domain]:domain:' \
    '--port=[port]:port:' \
    '(-p --project)'{-p,--project}'=[project name]:project:' \
    '(-n --name)'{-n,--name}'=[deployment name]:name:' \
    '(-r --restart)'{-r,--restart}'=[restart policy]:policy:' \
    '--hostname=[ingress hostname]:host:' \
    '(-h --help)'{-h,--help}'[help]'
}

case $words[1] in
  config)
    case $words[2] in
      auth)
        _arguments -s -S \
          '(-u --user)'{-u,--user}'=[basic-auth user]:user:' \
          '(-p --pass)'{-p,--pass}'=[basic-auth password]:pass:' \
          '(-h --help)'{-h,--help}'[help]'
        ;;
      *)
        if (( CURRENT == 2 )) && [[ $words[2] != -* ]]; then
          _wanted commands expl 'config subcommand' compadd -M 'm:{a-zA-Z}={A-Za-z}' -- auth && return
        fi
        _exoframe_config_main
        ;;
    esac
    ;;
  deploy)
    _arguments -s -S \
      '::folder:_directories' \
      '(-c --config)'{-c,--config}'=[exoframe.json path]:file:_files' \
      '(-e --endpoint)'{-e,--endpoint}'=[override API endpoint]:url:_urls' \
      '(-t --token)'{-t,--token}'=[deploy token]:token:' \
      '(-u --update)'{-u,--update}'[redeploy existing project]' \
      '(-o --open)'{-o,--open}'[open in browser]' \
      '*'{-v,--verbose}'[verbose]' \
      '(-h --help)'{-h,--help}'[help]'
    ;;
  endpoint)
    if (( CURRENT == 2 )); then
      _alternative \
        'subcommands:endpoint:(add remove rm)' \
        'switch-url:if no subcommand URL for switch:_urls'
      return
    fi
    case $words[2] in
      add|remove|rm)
        _arguments -s -S \
          '::url:_urls' \
          '(-h --help)'{-h,--help}'[help]'
        ;;
      *)
        _arguments -s -S \
          '::url:_urls' \
          '(-h --help)'{-h,--help}'[help]'
        ;;
    esac
    ;;
  login)
    _arguments -s -S \
      '(-k --key)'{-k,--key}'=[SSH private key path]:file:_files' \
      '(-p --passphrase)'{-p,--passphrase}'=[key passphrase]:pass:' \
      '(-u --url)'{-u,--url}'=[endpoint URL]:url:_urls' \
      '(-h --help)'{-h,--help}'[help]'
    ;;
  list|setup|system)
    _arguments -s -S '(-h --help)'{-h,--help}'[help]'
    ;;
  logs)
    _arguments -s -S \
      '1:deployment id:_default' \
      '(-f --follow)'{-f,--follow}'[follow]' \
      '(-h --help)'{-h,--help}'[help]'
    ;;
  remove)
    _arguments -s -S \
      '1:deployment id:_default' \
      '(-t --token)'{-t,--token}'=[token]:token:' \
      '(-h --help)'{-h,--help}'[help]'
    ;;
  secret)
    if (( CURRENT == 2 )); then
      _values 'secret subcommand' add list ls get remove rm
      return
    fi
    case $words[2] in
      add)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'=[secret name]:name:' \
          '(-v --value)'{-v,--value}'=[secret value]:value:' \
          '(-h --help)'{-h,--help}'[help]'
        ;;
      get)
        _arguments -s -S \
          '::secret name:_default' \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' \
          '(-h --help)'{-h,--help}'[help]'
        ;;
      remove|rm)
        _arguments -s -S \
          '::secret name:_default' \
          '(-h --help)'{-h,--help}'[help]'
        ;;
      list|ls)
        _arguments -s -S '(-h --help)'{-h,--help}'[help]'
        ;;
      *)
        _arguments -s -S '(-h --help)'{-h,--help}'[help]'
        ;;
    esac
    ;;
  template)
    if (( CURRENT == 2 )); then
      _values 'template subcommand' install remove list ls
      return
    fi
    case $words[2] in
      install|remove)
        _arguments -s -S \
          '::template name:_default' \
          '*'{-v,--verbose}'[verbose]' \
          '(-h --help)'{-h,--help}'[help]'
        ;;
      list|ls)
        _arguments -s -S '(-h --help)'{-h,--help}'[help]'
        ;;
      *)
        _arguments -s -S '(-h --help)'{-h,--help}'[help]'
        ;;
    esac
    ;;
  token)
    if (( CURRENT == 2 )); then
      _values 'token subcommand' add list ls remove rm
      return
    fi
    case $words[2] in
      add|remove|rm)
        _arguments -s -S \
          '::token name:_default' \
          '(-h --help)'{-h,--help}'[help]'
        ;;
      list|ls)
        _arguments -s -S '(-h --help)'{-h,--help}'[help]'
        ;;
      *)
        _arguments -s -S '(-h --help)'{-h,--help}'[help]'
        ;;
    esac
    ;;
  update)
    _arguments -s -S \
      '::target:(all server traefik)' \
      '(-h --help)'{-h,--help}'[help]'
    ;;
  *)
    return 1
    ;;
esac
