#compdef maestral
# Documentation: https://maestral.app/cli
# maestral: open-source Dropbox client for macOS and Linux

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show the version and exit]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'start:start the sync daemon'
      'stop:stop the sync daemon'
      'gui:start the GUI'
      'pause:pause syncing'
      'resume:resume syncing'
      'auth:link and unlink Dropbox accounts'
      'sharelink:create and manage shared links'
      'status:show the status of the daemon'
      'filestatus:show the sync status of a file or folder'
      'activity:show currently syncing items'
      'history:show recently changed or added files'
      'ls:list contents of a Dropbox directory'
      'config-files:list all configured accounts'
      'autostart:start the sync daemon on login'
      'excluded:manage selective sync settings'
      'notify:manage desktop notifications'
      'move-dir:move the local Dropbox folder'
      'rebuild-index:rebuild the sync index'
      'revs:list old revisions of a file'
      'diff:compare two revisions of a text file'
      'restore:restore an old revision of a file'
      'log:view and manage the log'
      'config:manage configuration values'
      'completion:generate shell completion script'
    )
    _describe -t commands 'maestral command' cmds && ret=0
    ;;
esac

return ret
