#compdef pamac-cli pamac
# Documentation: https://wiki.manjaro.org/index.php/Pamac
# Reference accessed: 2026-05-16
# Verified: Manjaro wiki + linuxcommandlibrary.com pamac entry. The full pamac.8
# manpage is only shipped with Manjaro and not exposed on manpages.debian.org.

# pamac: Manjaro package manager (CLI)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'search:search packages'
  'list:list packages'
  'info:show package info'
  'install:install packages'
  'reinstall:reinstall packages'
  'remove:remove packages'
  'checkupdates:check for updates'
  'update:update package list'
  'upgrade:upgrade packages'
  'clone:clone AUR package'
  'build:build AUR package'
  'clean:clean cache'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'pamac command' commands && ret=0 ;;
  args)
    _arguments \
      '--orphans[only orphans]' \
      '--aur[include AUR]' \
      '--no-confirm[skip confirmation]' \
      '--installed[only installed]' \
      '(-a --all)'{-a,--all}'[show all]' \
      '*:packages:' && ret=0 ;;
esac
return ret
