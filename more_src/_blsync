#compdef blsync era
# Documentation: upstream cmd/{blsync,era}/main.go + cmd/utils/flags.go
# at github.com/ethereum/go-ethereum
# Reference accessed: 2026-05-30
# Continuation of go-ethereum sister-binary R41. Both ship alongside
# the previously-covered _geth/_abigen/_clef/_devp2p/_ethkey/_rlpdump
# binaries.

local curcontext="$curcontext" state line ret=1

case $service in

  blsync)
    # ethereum/go-ethereum blsync — beacon light sync client.
    # Connects to a CL beacon-API + EL engine-API and drives the EL
    # head from the optimistically-synced beacon chain.
    _arguments -s -S \
      '--beacon.api=[Beacon chain API URLs (repeatable)]:url:' \
      '--beacon.api.header=[Custom HTTP header for Beacon API]:header:' \
      '--beacon.threshold=[Beacon-sync threshold (committee signers)]:N:' \
      '--beacon.nofilter[disable filter on beacon-sync state validation]' \
      '--beacon.config=[Beacon chain config file]:file:_files' \
      '--beacon.genesis.gvroot=[Beacon genesis validators root]:root:' \
      '--beacon.genesis.time=[Beacon genesis time (unix seconds)]:timestamp:' \
      '--beacon.checkpoint=[Beacon checkpoint root]:root:' \
      '--beacon.checkpoint.file=[Beacon checkpoint file]:file:_files' \
      '--blsync.engine.api=[Engine API URL of the EL]:url:' \
      '--blsync.jwtsecret=[JWT secret file for engine API]:file:_files' \
      '--mainnet[Ethereum mainnet]' \
      '--sepolia[Sepolia testnet]' \
      '--holesky[Holesky testnet]' \
      '--hoodi[Hoodi testnet]' \
      && ret=0
    ;;

  era)
    # ethereum/go-ethereum era — era1 file format tools (rollup-style
    # historical chain segments for trustless archival access).
    local -a _subcmds
    _subcmds=(
      'block:get block data <number>'
      'info:get epoch information <epoch>'
      'verify:verify each era1 against expected accumulator root <expected>'
    )
    _arguments -C -s -S \
      '-dir=[era1 directory (default eras)]:directory:_directories' \
      '-network=[network name (default mainnet)]:network:(mainnet sepolia holesky hoodi)' \
      '-size=[blocks per era (default era.MaxSize)]:N:' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'era subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          block)
            _arguments \
              '-txs[print full transaction values]' \
              '1:block number:' && ret=0
            ;;
          info)
            _arguments '1:epoch number:' && ret=0
            ;;
          verify)
            _arguments '1:expected accumulator root:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
