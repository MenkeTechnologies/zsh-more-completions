#compdef altqd
# Documentation: man altqd(8)
# Source: netbsd/src usr.sbin/altq/altqd — ALTQ queueing configuration daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[debug mode, do not detach]' \
    '-f+[configuration file (default /etc/altq.conf)]:config file:_files' \
    '-v[print debugging information (implies -d)]' \
    && ret=0

return ret
