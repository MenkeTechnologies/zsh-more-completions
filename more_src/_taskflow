#compdef taskflow
# Documentation: https://github.com/AbhiShake1/taskflow
# Reference accessed: 2026-05-22
# Verified: cli/index.ts cac command definitions.

# Zsh completion for taskflow - multi-agent orchestration harness CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'taskflow command' \
      'init[scaffold taskflow.json and config]' \
      'add[install harness from registry or URL]' \
      'view[print resolved registry item JSON]' \
      'list[list installed harnesses]' \
      'search[fuzzy search registry]' \
      'update[re-resolve installed harnesses]' \
      'remove[delete installed harness]' \
      'apply[re-install preset with overwrite]' \
      'build[publisher build registry JSON]' \
      'run[execute harness file]' \
      'watch[alias for run]' \
      'plan[static AST preview]' \
      'mcp[start MCP server stdio]' && ret=0
    ;;
  args)
    case $line[1] in
      init|add|update|apply)
        _arguments \
          '(-y --yes)'{-y,--yes}'[skip prompts]' \
          '(-o --overwrite)'{-o,--overwrite}'[overwrite existing files]' \
          '--dry-run[preview only]' \
          '(-c --cwd)'{-c,--cwd}'[working directory]:directory:_directories' \
          '(-s --silent)'{-s,--silent}'[mute output]' \
          '--skip-adapter-check[skip adapter preflight]' && ret=0
        ;;
      add)
        _arguments \
          '(-p --path)'{-p,--path}'[harness install directory]:directory:_directories' \
          '--frozen[error on lockfile drift]' \
          '--diff[preview changes]' \
          '--view[print registry JSON and exit]' \
          '*:source:' && ret=0
        ;;
      build)
        _arguments \
          '(-o --output)'{-o,--output}'[output directory]:directory:_directories' \
          '(-c --cwd)'{-c,--cwd}'[working directory]:directory:_directories' \
          '1:input file:' && ret=0
        ;;
      view|remove|run|watch|plan)
        _arguments \
          '(-c --cwd)'{-c,--cwd}'[working directory]:directory:_directories' \
          '1:name or harness:' && ret=0
        ;;
      search)
        _arguments \
          '(-c --cwd)'{-c,--cwd}'[working directory]:directory:_directories' \
          '1:query:' && ret=0
        ;;
      list|mcp)
        _arguments '(-c --cwd)'{-c,--cwd}'[working directory]:directory:_directories' && ret=0
        ;;
      update)
        _arguments '*:harness names:' && ret=0
        ;;
      apply)
        _arguments '1:preset:' && ret=0
        ;;
    esac
    ;;
esac

return ret
