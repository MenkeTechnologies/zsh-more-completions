#compdef cargo-dist

# Zsh completion for cargo-dist (Rust distribution/packaging tool)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '-v[Use verbose output]' \
  '--verbose[Use verbose output]' \
  '--output-format=[Output format]:format:(human json)' \
  '--no-local-paths[Strip local paths from output]' \
  '--target=[Target triples to build for]:target' \
  '--ci=[CI backends to generate]:ci:(github)' \
  '--installer=[Installers to generate]:installer:(shell powershell npm homebrew msi)' \
  '--tag=[Git tag to use]:tag' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Setup or update cargo-dist for your project'
      'generate:Generate CI scripts and installers'
      'build:Build artifacts'
      'manifest:Print the dist manifest'
      'plan:Print what cargo-dist would do'
      'host:Host artifacts'
      'linkage:Report on the dynamic libraries used by built artifacts'
      'selfupdate:Update cargo-dist itself'
    )
    _describe -t commands 'cargo-dist command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-v[Use verbose output]' \
          '--verbose[Use verbose output]' \
          '--yes[Accept default answers]' \
          '-y[Accept default answers]' \
          '--no-generate[Do not run generate after init]' \
          '--with-json-config=[Path to a JSON file with config]:file:_files' \
          '--hosting=[Hosting provider]:hosting:(github axodotdev)' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-v[Use verbose output]' \
          '--verbose[Use verbose output]' \
          '--mode=[Generate mode]:mode:(ci)' \
          '--check[Check if generated files are up to date]' && ret=0
        ;;
      build)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-v[Use verbose output]' \
          '--verbose[Use verbose output]' \
          '--output-format=[Output format]:format:(human json)' \
          '--no-local-paths[Strip local paths from output]' \
          '--target=[Target triples to build for]:target' \
          '--tag=[Git tag to use]:tag' \
          '--artifacts=[Artifacts to build]:artifacts:(local global all)' \
          '--print=[What to print]:what:(linkage)' && ret=0
        ;;
      manifest)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-v[Use verbose output]' \
          '--verbose[Use verbose output]' \
          '--output-format=[Output format]:format:(human json)' \
          '--no-local-paths[Strip local paths from output]' \
          '--target=[Target triples]:target' \
          '--tag=[Git tag to use]:tag' \
          '--artifacts=[Artifacts to include]:artifacts:(local global all)' && ret=0
        ;;
      plan)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-v[Use verbose output]' \
          '--verbose[Use verbose output]' \
          '--output-format=[Output format]:format:(human json)' \
          '--no-local-paths[Strip local paths from output]' \
          '--tag=[Git tag to use]:tag' && ret=0
        ;;
      host)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-v[Use verbose output]' \
          '--verbose[Use verbose output]' \
          '--output-format=[Output format]:format:(human json)' \
          '--no-local-paths[Strip local paths from output]' \
          '--tag=[Git tag to use]:tag' \
          '--steps=[Steps to run]:steps:(check upload release announce)' && ret=0
        ;;
      linkage)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-v[Use verbose output]' \
          '--verbose[Use verbose output]' \
          '--output-format=[Output format]:format:(human json)' \
          '--print-command[Print the command used to check linkage]' \
          '--from-json=[Read artifacts from a manifest]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
