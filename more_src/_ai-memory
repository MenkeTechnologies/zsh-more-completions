'--json[Output as JSON (machine-parseable)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_ai-memory_commands" \
"*::: :->ai-memory" \
&& ret=0
    case $state in
    (ai-memory)
