#compdef pomerium
# Documentation: https://man.archlinux.org/search?q=pomerium
# Reference accessed: 2026-05-16

# Zsh completion for Pomerium identity-aware proxy server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[path to configuration file]:config file:_files -g "*.{yaml,yml,json,toml}"' \
  '--config-file=[path to configuration file]:config file:_files -g "*.{yaml,yml,json,toml}"' \
  '--envoy-version=[override the bundled Envoy version]:version:' \
  && ret=0

return ret
