#compdef pomerium
# Documentation: https://github.com/pomerium/pomerium/blob/main/cmd/pomerium/main.go
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for Pomerium identity-aware proxy server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[show pomerium and envoy version]' \
  '--config=[specify configuration file location]:config file:_files -g "*.{yaml,yml,json,toml}"' \
  && ret=0

return ret
