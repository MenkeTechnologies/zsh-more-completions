#compdef hp-fax
# Documentation: (no user CLI - see hp-sendfax)
# Reference accessed: 2026-05-16
# Verified: `hp-fax` is a CUPS fax backend (/usr/lib/cups/backend/hp
# and the hpfax queues), not an end-user CLI. There is no manpage in
# Debian bookworm or Ubuntu. The user-facing fax sender is
# `hp-sendfax`. The fax.py in upstream HPLIP is a library, not an
# entry point.
# Removed from prior file: fabricated -h/--help/-V/--version flags
# and bogus man.archlinux.org search URL.

# hp-fax: CUPS fax backend (not a user CLI; see hp-sendfax)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:arg:_files' && ret=0
return ret
