#compdef kibi
# Documentation: https://man.archlinux.org/search?q=kibi
# Reference accessed: 2026-05-16

# Argument parsing from https://github.com/ilai-deutel/kibi (src/main.rs): optional path, --version, optional --

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'--version'[print kibi version]' \
  '--[end of options]' \
  '::file to edit:_files' && ret=0

return ret
