#compdef mdv

local -a arguments

arguments=(
    '-A[All changes mode]'
    '-C[No colors]'
    '-H[HTML output]'
    '-L[Lazy display]'
    '-M[Monitor file for changes]'
    '-T[Theme]:theme'
    '-X[No header rewriting]'
    '-c[Columns]:columns'
    '-f[Display from file]:file:_files -g "*.{md,markdown,mkd}"'
    '-h[Show help]'
    '-i[Show images as block chars]'
    '-m[Display specific module docs]:module'
    '-n[No pager]'
    '-t[Table style]:style'
    '-u[Unicode replacement mode]'
    '-x[Horizontal padding]:padding'
    '*:markdown file:_files -g "*.{md,markdown,mkd}"'
)

_arguments -s -S $arguments
