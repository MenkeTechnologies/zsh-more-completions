#compdef mdv
# Documentation: https://github.com/axiros/terminal_markdown_viewer
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '-A[strip all ansi (no colors)]'
    '-C[sourcecode highlighting mode]:mode:'
    '-H[print html version]'
    '-L[backwards compatible shortcut for -u i]'
    '-M[monitor directory for markdown file changes]:dir:_directories'
    '-T[theme for code highlight]:theme:'
    '-X[default lexer name]:lexer:'
    '-b[tab length (default 4)]:length:'
    '-c[fix columns to this width]:cols:'
    '-f[display from given substring of file]:from:'
    '-h[show help]'
    '-i[show theme infos with output]'
    '-l[light background (not yet supported)]'
    '-m[monitor file for changes and redisplay from given substring]'
    '-n[header numbering]:nrs:'
    '-t[ansi color theme key]:theme:'
    '-u[link style: inline/table/hide]:style:(it table h i)'
    '-x[do not guess code lexer]'
    '*:markdown file:_files -g "*.{md,markdown,mkd}"'
)

_arguments -s -S $arguments
