#compdef yakuake
# Documentation: https://apps.kde.org/yakuake/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: yakuake is a KDE GUI drop-down terminal driven via D-Bus; no documented
# command-line flag set beyond standard Qt/KDE help and version options.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--help-all[all help options]' \
  '--help-qt[Qt help]' \
  '--help-kde[KDE help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author info]' \
  '--license[show license info]' && ret=0

return ret
