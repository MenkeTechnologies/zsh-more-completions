#compdef dvanalyzer
# Documentation: https://man.archlinux.org/search?q=dvanalyzer
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/dvanalyzer
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--Header+[print header for file]:media:_files' \
  '--Version[show version]' \
  '*::file:_files'
