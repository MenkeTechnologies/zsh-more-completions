#compdef ctx7
# Documentation: https://github.com/upstash/context7
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# context7.com CLI shipped as the `ctx7` binary (npm package).
# Top-level verbs; `skills` nests generate/install/search/list/remove/info/suggest.

local curcontext="$curcontext" state line ret=1
local -a top skill

top=(
  'login:Context7 OAuth login'
  'logout:end session'
  'whoami:print auth status'
  'setup:install MCP/skills integration'
  'remove:strip Context7 from an agent'
  'library:resolve friendly name to library id'
  'docs:query docs for /org/project id'
  'upgrade:self-upgrade helper'
  'skills:skill subcommands (alias: skill)'
)

skill=(
  'generate:scaffold skill (aliases: gen g)'
  'install:from GitHub (aliases: i add)'
  'search:search registry (alias: s)'
  'list:installed skills (alias: ls)'
  'remove:delete skill (aliases: rm delete)'
  'info:skills inside a repo'
  'suggest:recommend from lockfiles'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '--base-url=[API base]:url:' \
  '1: :->t1' \
  '*:: :->rx' && ret=0

case $state in
  t1)
    _describe -t commands 'ctx7' top && ret=0
    ;;
  rx)
    case $line[1] in
      skills|skill)
        if (( CURRENT == 2 )); then
          _describe -t commands 'ctx7 skills' skill && ret=0
        else
          _arguments -s \
            '--global[use global skills dir]' \
            '--claude[write under .claude/skills]' \
            '--cursor[write under .cursor/skills]' \
            '--universal[write under .agents/skills]' \
            '--antigravity[write under .agent/skills]' \
            '--all[install all matches without prompts]' \
            '--all-agents[install to every agent dir]' \
            '(-y --yes)'{-y,--yes}'[assume yes]' \
            '(-o --output)'{-o,--output}'[output directory]:dir:_files -/' \
            '*:args:_normal' && ret=0
        fi
        ;;
      setup)
        _arguments -s \
          '--claude[Claude Code]' \
          '--cursor[Cursor]' \
          '--universal[Universal bundle]' \
          '--antigravity[Antigravity]' \
          '--opencode[OpenCode]' \
          '--codex[Codex CLI]' \
          '--gemini[Gemini CLI]' \
          '--mcp[MCP-only integration]' \
          '--cli[CLI + skills bundle]' \
          '(-p --project)'{-p,--project}'[project-scoped install]' \
          '(-y --yes)'{-y,--yes}'[non-interactive]' \
          '--api-key=[API key]:key:' \
          '--oauth[OAuth endpoint]' \
          '*:args:_normal' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
