#compdef llama-cli llama-server llama-bench llama-quantize llama-perplexity

# Zsh completion for llama.cpp tools

_llama-cpp() {
  local curcontext="$curcontext" state line ret=1
  local prog=${words[1]:t}

  local -a common_opts=(
    '(-m --model)'{-m,--model}'[path to model file]:model file:_files -g "*.gguf"'
    '(-n --n-predict)'{-n,--n-predict}'[number of tokens to predict]:count:'
    '(-c --ctx-size)'{-c,--ctx-size}'[size of the prompt context]:size:'
    '(-b --batch-size)'{-b,--batch-size}'[batch size for prompt processing]:size:'
    '(-t --threads)'{-t,--threads}'[number of threads]:threads:'
    '--threads-batch=[number of threads for batch processing]:threads:'
    '(-ngl --n-gpu-layers)'{-ngl,--n-gpu-layers}'[number of layers to offload to GPU]:layers:'
    '--main-gpu=[main GPU to use]:GPU index:'
    '--tensor-split=[split tensors across GPUs]:split ratios:'
    '--rope-scaling=[RoPE scaling type]:type:(none linear yarn)'
    '--rope-freq-base=[RoPE frequency base]:frequency:'
    '--rope-freq-scale=[RoPE frequency scale]:scale:'
    '--yarn-ext-factor=[YaRN extrapolation factor]:factor:'
    '--yarn-attn-factor=[YaRN attention factor]:factor:'
    '--yarn-beta-fast=[YaRN beta fast]:value:'
    '--yarn-beta-slow=[YaRN beta slow]:value:'
    '--yarn-orig-ctx=[YaRN original context size]:size:'
    '-nkvo[disable KV offloading]'
    '--no-kv-offload[disable KV offloading]'
    '--cache-type-k=[KV cache type for K]:type:(f16 f32 q8_0 q4_0 q4_1 q5_0 q5_1)'
    '--cache-type-v=[KV cache type for V]:type:(f16 f32 q8_0 q4_0 q4_1 q5_0 q5_1)'
    '--mlock[force system to keep model in RAM]'
    '--no-mmap[do not memory-map model]'
    '--numa=[NUMA strategy]:strategy:(distribute isolate numactl)'
    '-v[verbose output]'
    '--verbose[verbose output]'
    '--verbosity=[set verbosity level]:level:'
    '-s+[RNG seed]:seed:'
    '--seed=[RNG seed]:seed:'
    '(-h --help)'{-h,--help}'[display help]'
  )

  case $prog in
    llama-cli|main)
      _arguments -s -S $common_opts \
        '(-p --prompt)'{-p,--prompt}'[prompt string]:prompt:' \
        '-e[process prompt escapes]' \
        '--escape[process prompt escapes]' \
        '--no-escape[do not process prompt escapes]' \
        '(-f --file)'{-f,--file}'[prompt file]:file:_files' \
        '--in-file=[input file for prompt]:file:_files' \
        '-i[run in interactive mode]' \
        '--interactive[run in interactive mode]' \
        '--interactive-first[run in interactive mode and wait for input first]' \
        '-ins[run in instruction mode]' \
        '--instruct[run in instruction mode]' \
        '--chatml[run in ChatML mode]' \
        '-r+[halt generation at prompt]:reverse prompt:' \
        '--reverse-prompt=[halt generation at prompt]:reverse prompt:' \
        '--in-prefix=[string to prefix user inputs]:prefix:' \
        '--in-suffix=[string to suffix user inputs]:suffix:' \
        '--color[colorize output]' \
        '--temp=[temperature]:temperature:' \
        '--top-k=[top-k sampling]:k:' \
        '--top-p=[top-p sampling]:p:' \
        '--min-p=[min-p sampling]:p:' \
        '--tfs=[tail free sampling]:z:' \
        '--typical=[locally typical sampling]:p:' \
        '--repeat-penalty=[penalize repeat sequence]:penalty:' \
        '--repeat-last-n=[last n tokens to penalize]:n:' \
        '--frequency-penalty=[frequency penalty]:penalty:' \
        '--presence-penalty=[presence penalty]:penalty:' \
        '--mirostat=[use Mirostat sampling]:mode:(0 1 2)' \
        '--mirostat-lr=[Mirostat learning rate]:eta:' \
        '--mirostat-ent=[Mirostat target entropy]:tau:' \
        '--grammar=[BNF-like grammar to constrain output]:grammar:' \
        '--grammar-file=[file to read grammar from]:grammar file:_files' \
        '--json-schema=[JSON schema for structured output]:schema:' \
        '--cfg-negative-prompt=[negative prompt for classifier-free guidance]:prompt:' \
        '--cfg-scale=[classifier-free guidance scale]:scale:' \
        '--lora=[apply LoRA adapter]:LoRA file:_files -g "*.gguf"' \
        '--lora-base=[base model for LoRA]:base model file:_files -g "*.gguf"' \
        '--lora-scaled=[apply LoRA with scaling]:LoRA file:_files -g "*.gguf"' \
        '--mmproj=[multimodal projector file]:file:_files -g "*.gguf"' \
        '--image=[image file for multimodal]:image file:_files -g "*.{png,jpg,jpeg}"' \
        '--log-disable[disable trace logs]' \
        '--log-file=[log file]:log file:_files' \
        '--no-display-prompt[do not display the prompt]' \
        '-np+[number of parallel sequences]:count:' \
        '--parallel=[number of parallel sequences]:count:' \
        && ret=0
      ;;
    llama-server|server)
      _arguments -s -S $common_opts \
        '--host=[hostname to listen on]:hostname:_hosts' \
        '--port=[port to listen on]:port:' \
        '--path=[path to serve static files]:path:_files -/' \
        '--api-key=[API key for authentication]:key:' \
        '--api-key-file=[file containing API keys]:file:_files' \
        '--ssl-key-file=[SSL key file]:key file:_files' \
        '--ssl-cert-file=[SSL certificate file]:cert file:_files' \
        '--embedding[enable embedding endpoint]' \
        '--metrics[enable Prometheus metrics endpoint]' \
        '--log-format=[log format]:format:(json text)' \
        '-np+[number of parallel sequences]:count:' \
        '--parallel=[number of parallel sequences]:count:' \
        '--system-prompt-file=[system prompt file]:file:_files' \
        '--chat-template=[chat template]:template:' \
        '--lora=[apply LoRA adapter]:LoRA file:_files -g "*.gguf"' \
        '--mmproj=[multimodal projector file]:file:_files -g "*.gguf"' \
        '--temp=[temperature]:temperature:' \
        '--top-k=[top-k sampling]:k:' \
        '--top-p=[top-p sampling]:p:' \
        '--grammar=[BNF-like grammar]:grammar:' \
        '--grammar-file=[grammar file]:file:_files' \
        && ret=0
      ;;
    llama-quantize|quantize)
      _arguments -s -S \
        '--allow-requantize[allow requantizing already quantized tensors]' \
        '--leave-output-tensor[do not quantize output tensor]' \
        '--pure[disable mixed quantization]' \
        '--imatrix=[importance matrix file]:file:_files' \
        '--include-weights=[regex for weights to quantize]:regex:' \
        '--exclude-weights=[regex for weights to skip]:regex:' \
        '--output-tensor-type=[output tensor type]:type:' \
        '--token-embedding-type=[token embedding type]:type:' \
        '-t+[number of threads]:threads:' \
        '--threads=[number of threads]:threads:' \
        '1:input model:_files -g "*.gguf"' \
        '2:output model:_files -g "*.gguf"' \
        '3:quant type:(Q4_0 Q4_1 Q5_0 Q5_1 Q8_0 Q2_K Q3_K_S Q3_K_M Q3_K_L Q4_K_S Q4_K_M Q5_K_S Q5_K_M Q6_K IQ2_XXS IQ2_XS IQ2_S IQ3_XXS IQ3_XS IQ3_S IQ4_NL IQ4_XS F16 F32 BF16)' \
        && ret=0
      ;;
    llama-bench|bench)
      _arguments -s -S \
        '-m+[model file]:model file:_files -g "*.gguf"' \
        '--model=[model file]:model file:_files -g "*.gguf"' \
        '-p+[number of prompt tokens]:count:' \
        '-n+[number of generation tokens]:count:' \
        '-b+[batch size]:size:' \
        '-t+[threads]:threads:' \
        '-ngl+[GPU layers]:layers:' \
        '-r+[repetitions]:count:' \
        '-o+[output format]:format:(csv json md sql)' \
        '-v[verbose]' \
        && ret=0
      ;;
    *)
      _arguments -s -S $common_opts '*:files:_files' && ret=0
      ;;
  esac

  return ret
}

_llama-cpp "$@"
