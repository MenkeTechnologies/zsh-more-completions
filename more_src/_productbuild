#compdef productbuild
# Documentation: macOS man productbuild(1)
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--distribution[distribution file]:distribution file:_files -g "*.(xml|dist)"'
    '*--package-path[search path for packages]:package path:_directories'
    '--resources[resources directory]:resources directory:_directories'
    '--scripts[scripts directory]:scripts directory:_directories'
    '--plugins[plugins directory]:plugins directory:_directories'
    '--component[bundle and install path]:component:_files'
    '--component-compression[component compression]:algorithm:(legacy auto)'
    '--content[in-app content path]:content:_directories'
    '--root[destination root and install path]:root:_directories'
    '--ui[interface-type for choices-outline]:interface'
    '--product[requirements property list]:product plist:_files -g "*.plist"'
    '--synthesize[synthesize distribution instead of building archive]'
    '*--package[include package]:package:_files -g "*.pkg"'
    '--sign[sign with identity]:identity'
    '--keychain[keychain to search for signing identity]:keychain:_files'
    '--cert[certificate to include]:certificate:_files'
    '--timestamp[include a trusted timestamp]'
    '--timestamp=-[disable trusted timestamp when value is none]:value:(none)'
    '--identifier[product identifier]:identifier'
    '--version[product version]:version'
    '--large-payload[support payloads larger than 8GB]'
    '--quiet[suppress non-error output]'
    '*:product output:_files -g "*.pkg"'
)

_arguments -s -S $arguments
