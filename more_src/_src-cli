#compdef src
# Documentation: https://github.com/sourcegraph/src-cli/blob/main/cmd/src/main.go
# Reference accessed: 2026-05-21
# Verified: upstream source at the URL above (Usage string).
# Removed fabricated subcommand: lsif. Added confirmed subcommands: abc,
# auth, codeowners, gateway, search-jobs, teams.

# Zsh completion for src (Sourcegraph CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '-config=[path to config file]:config file:_files' \
  '-endpoint=[Sourcegraph endpoint URL]:URL' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case "$state" in
  subcmd)
    local -a subcmds=(
      'abc:manage agentic batch changes'
      'auth:authentication helper commands'
      'api:make Sourcegraph GraphQL API requests'
      'batch:manage batch changes'
      'code-intel:manage code intelligence data'
      'codeowners:manage code ownership information'
      'config:manage global, org, and user settings'
      'extensions:manage extensions (experimental)'
      'extsvc:manage external services'
      'gateway:interact with Cody Gateway'
      'login:authenticate with a Sourcegraph instance'
      'orgs:manage organizations'
      'teams:manage teams'
      'repos:manage repositories'
      'search:search for results on Sourcegraph'
      'search-jobs:manage search jobs'
      'serve-git:serve local git repositories over HTTP'
      'users:manage users'
      'version:display and compare src-cli version'
    )
    _describe -t subcommands 'src subcommand' subcmds && ret=0
    ;;
  args)
    case "${line[1]}" in
      search)
        _arguments -s -S \
          '-json[output as JSON]' \
          '-stream[stream results]' \
          '-display=[maximum results to display]:count' \
          '--get-curl[print equivalent curl command]' \
          '1:search query' && ret=0
        ;;
      repos)
        _arguments -s -S -C \
          '1:action:(list get add update delete)' \
          '-f=[output format]:format' \
          '--name-only[only show repository names]' \
          '--cloned-only[only show cloned repositories]' \
          '--not-cloned[only show uncloned repositories]' \
          '--first=[number of results to return]:count' \
          '*::arg' && ret=0
        ;;
      api)
        _arguments -s -S \
          '-query=[GraphQL query]:query' \
          '-vars=[query variables as JSON]:JSON' \
          '-f=[output format]:format' \
          '-get-curl[print equivalent curl command]' \
          '-insecure-skip-verify[skip TLS verification]' && ret=0
        ;;
      batch)
        _arguments -s -S -C \
          '1:action:(preview apply validate repositories exec)' \
          '*::arg:_files' && ret=0
        ;;
      login)
        _arguments -s -S \
          '--endpoint=[Sourcegraph URL]:URL' \
          '--token=[access token]:token' && ret=0
        ;;
      *)
        _arguments -s -S \
          '*:argument' && ret=0
        ;;
    esac
    ;;
esac

return ret
