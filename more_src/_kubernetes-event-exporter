#compdef kubernetes-event-exporter
# _kubernetes-event-exporter — export Kubernetes events to many sinks (resmoio/kubernetes-event-exporter)
# upstream: https://github.com/resmoio/kubernetes-event-exporter
# Flags from main.go (flag).

_kubernetes-event-exporter() {
    _arguments \
        '(- *)-h[show help]' \
        '-conf=[config file path]:file:_files -g "*.(yml|yaml)"' \
        '-metrics-address=[metrics HTTP bind address]:addr:' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-metrics-tls-config=[TLS config file for metrics]:file:_files'
}

_kubernetes-event-exporter "$@"
