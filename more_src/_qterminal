#compdef qterminal
# _qterminal — LXQt qterminal (Qt-based terminal emulator; --drop drops-down terminal mode, --workdir initial working directory, --execute runs a single command, --hold keeps window after command exits, --name window name, --profile loads a named profile)
# upstream: https://github.com/lxqt/qterminal
# Flags from lxqt/qterminal src/main.cpp on tip.

_qterminal() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-d[drop-down mode]' \
        '--drop[drop-down mode]' \
        '-w+[workdir]:dir:_files -/' \
        '--workdir+[workdir]:dir:_files -/' \
        '-e+[execute command]:command:_command_names -e' \
        '--execute+[execute command]:command:_command_names -e' \
        '--hold[keep window after exit]' \
        '--name+[window name]:name:' \
        '-p+[profile]:profile:' \
        '--profile+[profile]:profile:'
}

_qterminal "$@"
