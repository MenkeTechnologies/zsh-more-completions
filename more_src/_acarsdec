#compdef acarsdec

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-q[quiet]' \
  '-i+[station id]:id:' \
  '-A[show ACARS messages only]' \
  '-e[show only erroneous messages]' \
  '-b+[band 1-3]:band:(1 2 3)' \
  '-r+[RTL-SDR device index]:idx:' \
  '-d+[SoapySDR device string]:dev:' \
  '-g+[gain dB]:gain:' \
  '-p+[ppm error]:ppm:' \
  '-c+[center frequency Hz]:hz:' \
  '-f+[channel frequencies (comma-separated)]:freqs:' \
  '-l+[log file]:file:_files' \
  '-L+[log level]:level:(0 1 2 3 4 5 6 7)' \
  '-m+[output mode]:mode:(text monitor mqtt json native)' \
  '-o+[output format]:fmt:(text json native)' \
  '-j+[output JSON file]:file:_files' \
  '-J+[JSON network output host:port]:host:' \
  '-N+[StatsD host:port]:host:' \
  '-T+[time threshold seconds for unique messages]:sec:' \
  '-D+[idle disconnect minutes]:min:' \
  '*:input_file:_files' && ret=0

return ret
