#compdef vc-agent volcano-agent
# _vc-agent — Volcano per-node oversubscription/QoS agent (volcano-sh/volcano)
# upstream: https://github.com/volcano-sh/volcano
# Flags from cmd/agent/app/options/options.go on tip.

_vc-agent() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--healthz-address=[health-check bind address]:host:' \
        '--healthz-port=[health-check port]:port:' \
        '--kube-cgroup-root=[kubelet cgroup root path]:path:' \
        '--kube-node-name=[Kubernetes node name (defaults to $KUBE_NODE_NAME)]:name:' \
        '--kube-pod-name=[agent pod name (defaults to $KUBE_POD_NAME)]:name:' \
        '--kube-pod-namespace=[agent pod namespace (defaults to $KUBE_POD_NAMESPACE)]:ns:' \
        '--oversubscription-policy=[oversubscription policy]:policy:(extend native)' \
        '--oversubscription-ratio=[idle-resource oversubscription ratio (%)]:n:' \
        '--include-system-usage=[count system usage when calculating oversubscription]:bool:(true false)' \
        '--extend-resource-cpu-name=[extended CPU resource name]:name:' \
        '--extend-resource-memory-name=[extended memory resource name]:name:' \
        '-v[klog verbosity level]:n:'
}

_vc-agent "$@"
