#compdef sherlock

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-f --folderoutput)'{-f,--folderoutput}'[output directory]:dir:_directories' \
  '(-r --rank)'{-r,--rank}'[present in order of rank]' \
  '(-c --csv)'{-c,--csv}'[create CSV report]' \
  '(-x --xlsx)'{-x,--xlsx}'[create XLSX report]' \
  '--site[specific site to check]:site' \
  '(-p --proxy)'{-p,--proxy}'[proxy URL]:proxy' \
  '(-j --json)'{-j,--json}'[save results as JSON]:file:_files' \
  '(-t --timeout)'{-t,--timeout}'[request timeout in seconds]:seconds' \
  '--print-all[print all results]' \
  '--print-found[print found results only]' \
  '--no-color[disable colored output]' \
  '(-b --browse)'{-b,--browse}'[browse results in browser]' \
  '(-l --local)'{-l,--local}'[use local data file]' \
  '--nsfw[include NSFW sites]' \
  '*:username'
