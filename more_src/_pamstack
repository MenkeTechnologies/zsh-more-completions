#compdef pamstack
# Documentation: man pamstack (Netpbm)
# Source: Netpbm pamstack — stack planes of multiple PAM images into one PAM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-tupletype=[output tuple type]:tupletype:(BLACKANDWHITE GRAYSCALE GRAYSCALE_ALPHA RGB RGB_ALPHA CMYK BLACKANDWHITE_ALPHA)' \
    '(-firstmaxval -lcmmaxval)-firstmaxval[use first inputs maxval as output]' \
    '(-firstmaxval -lcmmaxval)-lcmmaxval[use LCM of input maxvals]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:input PAM/PNM file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
