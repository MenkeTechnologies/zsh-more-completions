#compdef benthos-cli redpanda-connect2
# _benthos-cli — Ashley Jeffs Redpanda Data benthos-cli CLI command-line frontend wrapping the Benthos now Redpanda Connect open-source declarative stream processor written in Go providing inputs outputs processors caches buffers metrics tracers rate-limits Bloblang BLOBL-mapping-language scripting echo run create list lint test template streams jq grok protobuf-arrow-avro-json-csv-xml ETL Kafka-NATS-Redis-MQTT-AMQP-AWS-GCP-Azure-Pulsar (Redpanda Data Ashley Jeffs team, Go); cobra
# upstream: https://www.benthos.dev/

_benthos-cli() {
    local -a sub=(
        'run:run a stream'
        'streams:run multiple streams'
        'echo:print config'
        'lint:lint config files'
        'test:run config tests'
        'create:scaffold a config'
        'list:list components'
        'blobl:Bloblang REPL'
        'template:template ops'
        'studio:open the cloud studio'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.json"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.json"' \
        '-r+[resource file]:file:_files -g "*.yml *.yaml"' \
        '--resources=+[file]:file:_files -g "*.yml *.yaml"' \
        '-t+[template file]:file:_files -g "*.yml *.yaml"' \
        '--templates=+[file]:file:_files -g "*.yml *.yaml"' \
        '--set=+[k=v]:str:' \
        '-s+[k=v]:str:' \
        '-w[watch config]' \
        '--watcher[watch config]' \
        '--prefix-stream-endpoints=+[prefix]:str:' \
        '--chilled[chilled lint]' \
        '--log.level=+[level]:l:(off fatal error warn info debug trace all)' \
        '--log.format=+[fmt]:f:(logfmt json)' \
        '-i+[stream id]:str:' \
        '--no-api[disable HTTP API]' \
        '--http.address=+[host:port]:_hosts' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'benthos subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments '*:components:' ;;
                list) _arguments '1:type:(inputs processors outputs caches buffers rate_limits metrics tracers scanners)' ;;
                lint|test) _arguments '*:file:_files -g "*.yml *.yaml"' ;;
                template) _arguments '1:op:(create lint)' '*:file:_files -g "*.yml *.yaml"' ;;
                streams) _arguments '*:file:_files -g "*.yml *.yaml"' ;;
            esac
            ;;
    esac
}

_benthos-cli "$@"
