#compdef ctr-remote

# ctr-remote: containerd CLI extension for remote snapshotters (stargz/eStargz)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'image:image management'
  'images:image management'
  'i:image management'
  'rpull:pull image with remote snapshotter'
  'optimize:optimize image to eStargz'
  'convert:convert image format'
  'completion:emit shell completion'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[debug logging]' \
  '--address=[containerd address]:addr:' \
  '-a[containerd address]:addr:' \
  '--namespace=[containerd namespace]:ns:' \
  '-n[containerd namespace]:ns:' \
  '--connect-timeout=[connect timeout]:duration:' \
  '--timeout=[command timeout]:duration:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ctr-remote command' commands && ret=0 ;;
esac
return ret
