#compdef ctr-remote
# Documentation: https://github.com/containerd/stargz-snapshotter
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ctr-remote: containerd CLI extension for remote snapshotters (stargz/eStargz).

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'image:image management (rpull/optimize/convert/push/rm)'
  'images:image management (alias)'
  'i:image management (alias)'
  'rpull:lazy pull with remote snapshotter'
  'run:run a container with stargz snapshotter'
  'completion:emit shell completion'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[debug logging]' \
  '--address=[containerd socket address]:addr' \
  '-a+[containerd socket address]:addr' \
  '--namespace=[containerd namespace]:ns' \
  '-n+[containerd namespace]:ns' \
  '--connect-timeout=[connect timeout]:duration' \
  '--timeout=[command timeout]:duration' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ctr-remote command' commands && ret=0 ;;
esac
return ret
