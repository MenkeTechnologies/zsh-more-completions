#compdef onnxsim onnx-sim

# onnx-simplifier: simplify ONNX graphs (constant folding etc.)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--input-shape=[explicit input shape]:shape:' \
  '--dynamic-input-shape[disable dynamic shape inference]' \
  '--skip-optimizer=[skip optimizers]:names:' \
  '--skip-shape-inference[skip shape inference]' \
  '--skip-fuse-bn[skip BN fuse]' \
  '--include-subgraph[include subgraphs]' \
  '--input-data=[input data files]:files:_files' \
  '--no-large-tensor[no large tensor]' \
  '--unused-output=[unused output names]:names:' \
  '--no-large-model[do not save as large model]' \
  '1:input .onnx:_files -g "*.onnx"' \
  '2:output .onnx:_files -g "*.onnx"' \
  '*::onnxsim args:_files' && ret=0
return ret
