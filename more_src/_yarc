#compdef yarc
# _yarc — yarc Yet Another REST Client; curl-like terminal REST client with response coloring + jq pipe support
# upstream: https://github.com/bcicen/yarc

_yarc() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-X --method)'{-X,--method}'+[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
        '(-H --header)'{-H,--header}'+[header]:header:' \
        '(-d --data)'{-d,--data}'+[body data]:data:' \
        '(-f --file)'{-f,--file}'+[body from file]:file:_files' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-i --include)'{-i,--include}'[include response headers]' \
        '(-k --insecure)'{-k,--insecure}'[skip TLS verify]' \
        '(-u --user)'{-u,--user}'+[basic auth]:user:pass:' \
        '(-A --user-agent)'{-A,--user-agent}'+[user agent]:ua:' \
        '(-r --raw)'{-r,--raw}'[do not pretty-print body]' \
        '(-j --jq)'{-j,--jq}'+[jq filter]:filter:' \
        '(-t --timeout)'{-t,--timeout}'+[timeout sec]:n:' \
        '*:URL:_urls'
}

_yarc "$@"
