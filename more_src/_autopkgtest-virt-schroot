#compdef autopkgtest-virt-schroot
# _autopkgtest-virt-schroot — schroot virtualisation backend for autopkgtest
# upstream: https://salsa.debian.org/ci-team/autopkgtest
# Flags from autopkgtest-virt-schroot(1) man page.

_autopkgtest-virt-schroot() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-s --session-id)'{-s+,--session-id=}'[custom schroot session ID]:id:' \
        '(-d --debug)'{-d,--debug}'[enable debugging output]' \
        '1:schroot name:'
}

_autopkgtest-virt-schroot "$@"
