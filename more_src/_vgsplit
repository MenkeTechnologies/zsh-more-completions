#compdef vgsplit
# _vgsplit — LVM2 vgsplit move PVs into new VG CLI (Red Hat / LVM2 team, C); custom argparse
# upstream: https://github.com/lvmteam/lvm2

_vgsplit() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--name=+[lv name to move]:str:' \
        '-n+[lv name to move]:str:' \
        '-A+[autobackup]:b:(y n)' \
        '--autobackup=+[autobackup]:b:(y n)' \
        '-c+[clustered]:b:(y n)' \
        '--clustered=+[clustered]:b:(y n)' \
        '-M+[metadata format]:f:(1 2 lvm1 lvm2)' \
        '--metadatatype=+[metadata format]:f:(1 2 lvm1 lvm2)' \
        '--alloc=+[alloc policy]:p:(contiguous cling cling_by_tags inherit normal anywhere)' \
        '--maxlogicalvolumes=+[max LVs]:n:' \
        '--maxphysicalvolumes=+[max PVs]:n:' \
        '--vgmetadatacopies=+[vg metadata copies]:n:' \
        '--poolmetadataspare=+[pool metadata spare]:b:(y n)' \
        '-d[debug]' \
        '--debug[debug]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-y[yes]' \
        '--yes[yes]' \
        '--config=+[config string]:str:' \
        '--devices=+[devices]:list:' \
        '--devicesfile=+[devices file]:file:_files' \
        '1:source-vg:' \
        '2:dest-vg:' \
        '*:pv:_files'
}

_vgsplit "$@"
