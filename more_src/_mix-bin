#compdef mix
# _mix-bin — Elixir mix project build tool (Elixir Lang team, Elixir); manage Elixir/OTP projects + deps + tasks
# upstream: https://github.com/elixir-lang/elixir

_mix-bin() {
    local -a sub=(
        'app.config:configure all apps'
        'app.start:start all apps'
        'app.tree:print app tree'
        'archive:list archives'
        'archive.build:build archive'
        'archive.install:install archive'
        'archive.uninstall:uninstall archive'
        'clean:clean build'
        'cmd:execute command'
        'compile:compile project'
        'compile.protocols:protocols'
        'deps:show deps'
        'deps.clean:clean deps'
        'deps.compile:compile deps'
        'deps.get:fetch deps'
        'deps.tree:show deps tree'
        'deps.unlock:unlock deps'
        'deps.update:update deps'
        'do:run multiple tasks'
        'docs:generate docs'
        'escript:list escripts'
        'escript.build:build escript'
        'escript.install:install escript'
        'escript.uninstall:uninstall escript'
        'eval:eval code'
        'format:format source'
        'hex:hex commands'
        'help:show help'
        'iex:start iex'
        'local:install + manage local'
        'local.hex:install hex'
        'local.rebar:install rebar'
        'loadconfig:load config'
        'loadpaths:add loadpaths'
        'new:create new project'
        'phx.new:create new Phoenix project'
        'phx.routes:list Phoenix routes'
        'phx.server:start Phoenix server'
        'profile.cprof:profile via cprof'
        'profile.eprof:profile via eprof'
        'profile.fprof:profile via fprof'
        'release:build release'
        'release.init:init release'
        'run:run code'
        'test:run tests'
        'test.coverage:test coverage'
        'xref:cross reference'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--app+[mix app]:str:' \
        '--env+[env]:env:(dev test prod)' \
        '--target+[target]:str:' \
        '--no-archives-check[no archives check]' \
        '--no-mix-exs[no mix.exs]' \
        '--quiet[quiet]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mix subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '--app+[app name]:str:' \
                    '--module+[module name]:str:' \
                    '--umbrella[create umbrella]' \
                    '--sup[supervised app]' \
                    '*:dir:_files -/' ;;
                test) _arguments \
                    '--cover[coverage]' \
                    '--export-coverage+[export coverage]:str:' \
                    '--force[force run]' \
                    '--include+[include tags]:tags:' \
                    '--exclude+[exclude tags]:tags:' \
                    '--only+[only tags]:tags:' \
                    '--seed+[random seed]:n:' \
                    '--max-cases+[parallel]:n:' \
                    '--max-failures+[max failures]:n:' \
                    '--no-compile[no compile]' \
                    '--no-deps-check[no deps check]' \
                    '--no-archives-check[no archives check]' \
                    '--partitions+[partitions]:n:' \
                    '--preload-modules[preload modules]' \
                    '--stale[stale only]' \
                    '--trace[trace]' \
                    '--listen-on-stdin[listen on stdin]' \
                    '--profile-require+[profile require]:profile:(time)' \
                    '*::file:_files -g "*.exs"' ;;
                deps) _arguments '*:dep:' ;;
                hex) _arguments '*:hex subcommand:' ;;
            esac
            ;;
    esac
}

_mix-bin "$@"
