#compdef showd
# Documentation: https://dragons.readthedocs.io/projects/recipe-system-users-manual/en/stable/supptools.html
# DRAGONS: display descriptor values for input files

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --descriptors)'{-d,--descriptors}'[comma-separated list of descriptor values to return]:descriptors:' \
  '--long[long format for the descriptor value]' \
  '--csv[format as CSV list]' \
  '--adpkg[specify instrument package]:pkg:' \
  '--debug[enable debug mode]' \
  '*:file:_files' && ret=0

return ret
