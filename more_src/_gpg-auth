#compdef gpg-auth
# Documentation: https://www.gnupg.org/documentation/manuals/gnupg/
# GnuPG: tool to authenticate a user using a smartcard

local ret=1

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[be somewhat more quiet]' \
  '--status-fd=[write status info to this FD]:fd' \
  '--version[print version information]' \
  '--help[show help]' && ret=0

return ret
