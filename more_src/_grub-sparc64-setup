#compdef grub-sparc64-setup

# grub-sparc64-setup: install GRUB on SPARC64 OBP devices
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --directory)'{-d,--directory=}'[GRUB directory]:dir:_files -/' \
  '(-f --force)'{-f,--force}'[install even on unknown filesystem]' \
  '(-s --skip-fs-probe)'{-s,--skip-fs-probe}'[do not probe filesystem]' \
  '--allow-floppy[install allowing floppy boot]' \
  '*:device name:_files' && ret=0
return ret
