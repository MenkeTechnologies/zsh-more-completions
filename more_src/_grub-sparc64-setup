#compdef grub-sparc64-setup

# grub-sparc64-setup: set up bootblock on sparc64
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '(- *)-V[show version]' \
  '-d[boot directory]:dir:_files -/' \
  '--directory=[boot directory]:dir:_files -/' \
  '-f[force install]' \
  '--force[force install]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-s[skip boot sector check]' \
  '--skip-fs-probe[skip boot sector check]' \
  '*:device:_files -g "/dev/*"' && ret=0
return ret
