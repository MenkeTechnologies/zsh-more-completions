#compdef tsk_dirstat
# Documentation: https://man.archlinux.org/search?q=tsk_dirstat
# Reference accessed: 2026-05-16

# tsk_dirstat: count files/dirs/special inodes per dir (Sleuth Kit)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-v[verbose]' \
  '-f[filesystem type]:fstype:(ntfs fat ext ufs hfs iso9660)' \
  '-i[image type]:imgtype:(raw split aff ewf)' \
  '-o[volume offset (sectors)]:n:' \
  '-b[block size]:bytes:' \
  '*:image file:_files' && ret=0
return ret
