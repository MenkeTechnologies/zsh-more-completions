#compdef alterx

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-l+[input list]:input file:_files' \
  '-list=[input list]:input file:_files' \
  '-p+[custom patterns]:patterns' \
  '-pattern=[custom patterns]:patterns' \
  '-pp+[payload file]:payload file:_files' \
  '-payload=[payload file]:payload file:_files' \
  '-en+[enrich wordlist]:wordlist file:_files' \
  '-enrich=[enrich wordlist]:wordlist file:_files' \
  '-limit=[limit output]:count' \
  '-o+[output file]:output file:_files' \
  '-output=[output file]:output file:_files' \
  '-silent[silent mode]' \
  '-v[verbose mode]' \
  '-verbose[verbose mode]' && return 0
