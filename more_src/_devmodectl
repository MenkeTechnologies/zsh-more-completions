#compdef devmodectl
# Documentation: https://developer.apple.com/documentation/xcode/enabling-developer-mode-on-a-device
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# macOS Ventura+ tool for enabling iOS Developer Mode on connected devices.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'info:show Developer Mode status of a device'
  'single:set up Developer Mode for a single device'
  'list:list connected devices and Developer Mode status'
  'streaming:perform setup in a streaming fashion'
)

_arguments -C \
  '1: :->subcommand' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'devmodectl subcommand' subcommands && ret=0
    ;;
esac

return ret
