#compdef wishlist

# Zsh completion for wishlist - Charm SSH app directory

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'serve:Start the SSH server'
  'list:List configured endpoints'
)

_arguments -s -S \
  '(-c --config)'{-c,--config}'=[path to config file]:file:_files' \
  '(-l --listen)'{-l,--listen}'=[address to listen on]:address:' \
  '(-p --port)'{-p,--port}'=[port to listen on]:port:' \
  '(-h --help)'{-h,--help}'[help for wishlist]' \
  '(-v --version)'{-v,--version}'[version for wishlist]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'=[path to config file]:file:_files' \
          '(-l --listen)'{-l,--listen}'=[address to listen on]:address:' \
          '(-p --port)'{-p,--port}'=[port to listen on]:port:' \
          '(-h --help)'{-h,--help}'[help for serve]' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'=[path to config file]:file:_files' \
          '(-h --help)'{-h,--help}'[help for list]' && ret=0
        ;;
    esac
    ;;
esac

return ret
