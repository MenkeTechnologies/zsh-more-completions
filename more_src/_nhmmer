#compdef nhmmer
# Documentation: https://man.archlinux.org/search?q=nhmmer
# Reference accessed: 2026-05-16

# HMMER nhmmer: search nucleic-acid query against nucleic-acid db
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output file]:file:_files' \
  '-A[save MSA of hits]:file:_files' \
  '--tblout[per-target hits table]:file:_files' \
  '--dfamtblout[Dfam-style table]:file:_files' \
  '--aliscoresout[per-alignment scores file]:file:_files' \
  '--hmmout[save HMM built from query]:file:_files' \
  '--acc[show accessions]' \
  '--noali[no alignments]' \
  '-E[reporting E-value]:Eval:' \
  '-T[reporting score]:bits:' \
  '--incE[inclusion E-value]:Eval:' \
  '--incT[inclusion score]:bits:' \
  '--cut_ga[GA cutoffs]' \
  '--cut_nc[NC cutoffs]' \
  '--cut_tc[TC cutoffs]' \
  '--max[no filters]' \
  '--F1[MSV threshold]:val:' \
  '--F2[Vit threshold]:val:' \
  '--F3[Fwd threshold]:val:' \
  '--nobias[no bias filter]' \
  '--toponly[only top strand]' \
  '--bottomonly[only bottom strand]' \
  '--seed[random seed]:n:' \
  '--qformat[query format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip)' \
  '--tformat[target format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip)' \
  '--cpu[CPU threads]:n:' \
  '*:HMM/seq query and target database:_files' && ret=0
return ret
