#compdef sysbox
# OCI runtime for rootless system containers

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--log[log file path]:file:_files' \
  '--log-level[log level]:level:(debug info warn error)' \
  '--log-format[log format]:format:(text json)' \
  && return 0
