#compdef kcat

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-b[broker list]:brokers' \
  '-t[topic]:topic' \
  '-p[partition]:partition' \
  '-o[offset]:offset' \
  '-G[consumer group]:group' \
  '-P[producer mode]' \
  '-C[consumer mode]' \
  '-L[metadata list mode]' \
  '-Q[query mode]' \
  '-K[key delimiter]:delimiter' \
  '-D[message delimiter]:delimiter' \
  '-c[message count]:count' \
  '-e[exit after last message]' \
  '-f[format string]:format' \
  '*-X[configuration property]:property=value' \
  '-F[configuration file]:file:_files' \
  '-d[enable debug]:context:(generic broker topic metadata feature queue msg protocol cgrp security fetch client)' \
  '-q[quiet mode]' \
  '-v[verbose mode]' \
  '-V[print version]' \
  '-h[print help]' \
  '*:file:_files' && ret=0
return ret
