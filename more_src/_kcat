#compdef kcat
# Documentation: https://github.com/edenhill/kcat/blob/master/kcat.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-P[producer mode]' \
  '-C[consumer mode]' \
  '-G+[high-level KafkaConsumer group id]:group' \
  '-L[metadata list mode]' \
  '-Q[query mode]' \
  '-M+[start mock cluster with N brokers]:broker count' \
  '-t+[topic]:topic' \
  '-p+[partition]:partition' \
  '-b+[bootstrap broker(s) host[:port]]:brokers' \
  '-z+[message compression]:codec:(snappy gzip lz4 zstd none)' \
  '-o+[offset to start consuming from]:offset' \
  '-e[exit successfully when last message received]' \
  '-E[do not exit on non-fatal error]' \
  '-D+[message delimiter string]:delimiter' \
  '-K+[key delimiter]:delimiter' \
  '-k+[fixed key for all messages]:key' \
  '-H+[add message header (header=value)]:header' \
  '-O[print message offset using -K delimiter]' \
  '-d+[enable librdkafka debugging]:context:(generic broker topic metadata feature queue msg protocol cgrp security fetch interceptor plugin consumer admin eos mock assignor conf all)' \
  '-q[be quiet (verbosity 0)]' \
  '-v[increase verbosity]' \
  '-F+[read configuration properties from file]:file:_files' \
  '*-X+[librdkafka configuration property, list or dump]:property' \
  '-c+[limit message count]:count' \
  '-T[output sent messages to stdout (tee)]' \
  '-u[unbuffered output]' \
  '-f+[output formatting string]:format' \
  '-Z[send/print empty messages as NULL]' \
  '-l[send messages from a file separated by delimiter]' \
  '(- *)-V[print version]' \
  '(- *)-h[print usage help]' \
  '-s+[serdes (de)serializer spec]:serdes' \
  '-r+[schema registry URL]:url' \
  '-J[output with JSON envelope]' \
  '-m+[metadata request timeout (seconds)]:seconds' \
  '-U[unit test mode]' \
  '*:file:_files' && ret=0
return ret
