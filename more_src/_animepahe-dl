#compdef animepahe-dl
# _animepahe-dl — animepahe.com anime downloader (KevCui/animepahe-dl)
# upstream: https://github.com/KevCui/animepahe-dl
# Flags from animepahe-dl.sh (getopts).

_animepahe-dl() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)--help[show help]' \
        '-a+[anime name]:name:' \
        '-s+[anime slug / uuid]:slug:' \
        '-e+[episode numbers (1,3-5,*)]:eps:' \
        '-r+[resolution]:resolution:(360 480 720 1080)' \
        '-o+[audio language]:lang:(eng jpn)' \
        '-l[show m3u8 playlist URL without downloading]' \
        '-d[enable debug mode]'
}

_animepahe-dl "$@"
