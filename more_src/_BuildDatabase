#compdef BuildDatabase
# Documentation: https://github.com/Dfam-consortium/RepeatModeler/blob/master/BuildDatabase
# RepeatModeler: build a sequence database for de-novo repeat identification

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[detailed help]' \
  '-name[name of the database to create]:dbname:' \
  '-dir[directory of fasta files to process (*.fa, *.fasta)]:directory:_files -/' \
  '-batch[file listing fasta files to process, one per line]:file:_files' \
  '*:fasta file:_files' && ret=0

return ret
