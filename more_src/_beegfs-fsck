#compdef beegfs-fsck
# Documentation: https://doc.beegfs.io/latest/advanced_topics/fscheck.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# beegfs-fsck: BeeGFS online filesystem check
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--checkfs[run all checks]' \
  '--enablequota[enable quota checks]' \
  '--automatic[automatically attempt repairs]' \
  '--readOnly[read-only mode]' \
  '--runOnline[enable online mode]' \
  '--nofetch[reuse existing database]' \
  '--databasePath=[database path]:dir:_files -/' \
  '--cfgFile=[client config file]:file:_files' \
  '--logOutFile=[log file]:file:_files' \
  '--logStdFile=[stdout log file]:file:_files' \
  '--logType=[log type]:type:(syslog logfile)' \
  '--tuneDbFragmentSize=[max RAM for fsck in bytes]:bytes' \
  '*::beegfs-fsck args:_files' && ret=0
return ret
