#compdef please plz

# Zsh completion for please (plz) - BUILD system

local curcontext="$curcontext" state line ret=1

local -a global_opts=(
  '(-h --help)'{-h,--help}'[show help information]'
  '--version[show version]'
  '(-c --config)'{-c,--config}'[set build config]:config name:'
  '(-n --num_threads)'{-n,--num_threads}'[number of parallel build threads]:n:'
  '(-v --verbosity)'{-v,--verbosity}'[set verbosity level]:level:(0 1 2 3 4)'
  '--show_all_output[show all output from build rules]'
  '--plain_output[do not use interactive output]'
  '--colour[enable coloured output]'
  '--no-colour[disable coloured output]'
  '--keep_going[continue as much as possible after an error]'
  '--keep_workdirs[do not clean work directories after build]'
  '--profile[write a CPU profile to the given file]:file:_files'
  '--arch[target architecture]:arch:'
  '--os[target operating system]:os:'
  '(-o --override)'{-o,--override}'[override a build config value]:key=value:'
  '--repo[override the repo root directory]:dir:_files -/'
  '(-i --include)'{-i,--include}'[include targets with this label]:label:'
  '(-e --exclude)'{-e,--exclude}'[exclude targets with this label]:label:'
  '--log_file[write logs to a file]:file:_files'
  '--log_file_level[set log level for log file]:level:(0 1 2 3 4)'
  '--interactive_output[show interactive output during build]'
)

local -a subcommands=(
  'build:build one or more targets'
  'test:build and test one or more targets'
  'run:build and run a single target'
  'clean:clean build artifacts'
  'query:query the build graph'
  'hash:hash one or more targets'
  'watch:watch targets and rebuild on change'
  'init:initialize a new please project'
  'update:update please to the latest version'
  'op:re-run the previous command'
  'gc:garbage collect unused artifacts'
  'export:export build artifacts'
  'tool:run a please tool'
  'generate:generate build rules'
  'help:show help for a subcommand'
)

_arguments -s -S \
  $global_opts \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'please subcommand' subcommands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (build)
        _arguments -s -S \
          $global_opts \
          '*:target:' && ret=0
        ;;
      (test)
        _arguments -s -S \
          $global_opts \
          '--rerun[rerun tests that have already been run]' \
          '--run_all[run all tests regardless of cached state]' \
          '--failed_only[only re-run failed tests]' \
          '--num_runs[run each test this many times]:n:' \
          '--test_results_file[write test results to file]:file:_files' \
          '--coverage[generate coverage data]' \
          '--debug[attach a debugger to the test]' \
          '--shell[open a shell in the test working directory]' \
          '*:target:' && ret=0
        ;;
      (run)
        _arguments -s -S \
          $global_opts \
          '(-p --parallel)'{-p,--parallel}'[run in parallel]' \
          '--env[set environment variable]:key=value:' \
          '--remote[run on a remote executor]' \
          '*:target:' && ret=0
        ;;
      (clean)
        _arguments -s -S \
          $global_opts \
          '--noremote[do not clean remote caches]' \
          '*:target:' && ret=0
        ;;
      (query)
        local -a query_cmds=(
          'alltargets:list all build targets'
          'completions:provide shell completions for targets'
          'deps:show dependencies of a target'
          'graph:show dependency graph'
          'input:show input files for a target'
          'print:print build rule definition'
          'revdeps:show reverse dependencies of a target'
          'somepath:find a path between two targets'
        )
        _describe -t subcommands 'query subcommand' query_cmds && ret=0
        ;;
      (init)
        _arguments -s -S \
          '--dir[directory to initialize in]:dir:_files -/' && ret=0
        ;;
      (gc)
        _arguments -s -S \
          '--noremove[do not actually remove anything]' \
          '--add[add a target as a root]:target:' \
          '--remove[remove a target as a root]:target:' && ret=0
        ;;
      (*)
        _arguments -s -S $global_opts '*:arguments:' && ret=0
        ;;
    esac
    ;;
esac

return ret
