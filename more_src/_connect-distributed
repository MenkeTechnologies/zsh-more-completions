local -a arguments

arguments=(
    '-daemon[Run as daemon]'
    '-name[Connector name]:name'
    '-loggingdir[Logging directory]:dir:_directories'
    '*:properties file:_files -g "*.properties"'
)

_arguments -s -S $arguments
