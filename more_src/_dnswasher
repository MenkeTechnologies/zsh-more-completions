#compdef dnswasher
# Documentation: https://doc.powerdns.com/authoritative/manpages/dnswasher.1.html
# Anonymize end-user IP addresses in PCAP files using IPCipher

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display option summary]' \
  '(-d --decrypt)'{-d,--decrypt}'[reverse IPCipher encryption of IP addresses]' \
  '(-k --key)'{-k,--key}'[Base64-encoded 128-bit IPCipher key]:key:' \
  '(-p --passphrase)'{-p,--passphrase}'[passphrase to generate IPCipher key]:passphrase:' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '*:pcap file:_files' && ret=0

return ret
