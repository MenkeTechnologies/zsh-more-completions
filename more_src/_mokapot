#compdef mokapot
# Documentation: https://mokapot.readthedocs.io/en/latest/cli.html
# mokapot: semi-supervised FDR estimation for proteomics PSMs.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --dest_dir)'{-d,--dest_dir}'=[directory to write result files]:dir:_files -/' \
  '(-w --max_workers)'{-w,--max_workers}'=[processes for model training]:n' \
  '(-r --file_root)'{-r,--file_root}'=[prefix added to all file names]:prefix' \
  '--proteins=[enable protein-level confidence with a FASTA]:file:_files' \
  '--decoy_prefix=[prefix indicating a decoy protein]:prefix' \
  '--enzyme=[regex defining enzyme specificity]:regex' \
  '--missed_cleavages=[allowed number of missed cleavages]:n' \
  '--clip_nterm_methionine[remove N-terminal methionine residues]' \
  '--min_length=[minimum peptide length]:n' \
  '--max_length=[maximum peptide length]:n' \
  '--semi[use semi-enzymatic digestion]' \
  '--train_fdr=[max FDR for a positive training example]:fdr' \
  '--test_fdr=[FDR at which to evaluate learned models]:fdr' \
  '--max_iter=[number of training iterations]:n' \
  '--seed=[random seed integer]:seed' \
  '--direction=[feature to use as initial ranking direction]:feature' \
  '--aggregate[aggregate PSMs from multiple PIN files]' \
  '--subset_max_train=[limit PSM count during fold training]:n' \
  '--override[use learned model even if worse than best feature]' \
  '--save_models[save learned models as pickled objects]' \
  '--load_models=[load previously saved models]:file:_files' \
  '*--plugin=[name of a plugin to use]:plugin' \
  '--keep_decoys[keep decoys in the output .txt files]' \
  '--folds=[number of cross-validation folds]:n' \
  '--open_modification_bin_size=[bin size for modification masses]:size' \
  '(-v --verbosity)'{-v,--verbosity}'=[verbosity level 0-3]:level:(0 1 2 3)' \
  '*:pin/pepxml files:_files' && ret=0

return ret
