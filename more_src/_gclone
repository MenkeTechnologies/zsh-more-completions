#compdef gclone
# Documentation: https://man.archlinux.org/search?q=gclone
# Reference accessed: 2026-05-16

_gclone() {
    local -a args
    args=(
        '--drive-service-account-file-path[Path to service account JSON files]:directory:_directories'
        '--drive-server-side-across-configs[Allow server-side copy across configs]'
        '--drive-rolling-sa[Use rolling service accounts]'
        '--drive-random-pick-sa[Randomly pick a service account]'
        '--help[Display help]'
        '--version[Show version]'
        '*:arguments:_files'
    )

    _arguments -s -S $args
}

_gclone "$@"
