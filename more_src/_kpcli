#compdef kpcli
# Documentation: https://manpages.debian.org/bookworm/kpcli/kpcli.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. All options confirmed
# present in the kpcli POD changelog (--kdb/--key/--pwfile/
# --histfile/--readonly/--no-recycle/--timeout/--nopwstars/
# --nopwprint/--xp*/--pw*/--command).

_arguments -s \
  '(- *)--help[show help]' \
  '--kdb=[KeePass database file]:file:_files -g "*.(kdb|kdbx)"' \
  '--key=[key file]:file:_files' \
  '--pwfile=[password file]:file:_files' \
  '--readonly[open read-only]' \
  '--histfile=[readline history file]:file:_files' \
  '--no-recycle[disable recycle bin]' \
  '--timeout=[inactivity lock timeout secs]:secs:' \
  '--nopwstars[disable password masking]' \
  '--nopwprint[suppress password printing]' \
  '--pwscmin=[min special chars]:n:' \
  '--pwscmax=[max special chars]:n:' \
  '--pwwords=[word-based password count]:n:' \
  '--pwlen=[generated password length]:n:' \
  '--pwsplchars=[special char set]:chars:' \
  '--xpxsecs=[clipboard auto-clear secs]:secs:' \
  '--xclipsel=[X clipboard selection]:sel:(primary secondary clipboard)' \
  '*--command=[run command non-interactively]:cmd:'
