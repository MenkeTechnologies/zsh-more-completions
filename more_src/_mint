#compdef mint
# Documentation: https://github.com/yonaskolb/Mint
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install a package'
  'uninstall:uninstall a package'
  'bootstrap:install packages from Mintfile'
  'list:list installed packages'
  'run:run an executable from a package'
  'which:print path to an executable'
  'outdated:show Mintfile packages with newer versions available'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'mint command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (install)
        _arguments \
          '--global[install globally]' \
          '--force[force reinstall]' \
          '--no-link[do not link after install]' \
          '1:package (repo@version)' && ret=0
        ;;
      (uninstall)
        _arguments '1:package name' && ret=0
        ;;
      (run)
        _arguments \
          '--executable=[which executable to run]:name' \
          '--silent[suppress mint output]' \
          '1:package or executable' \
          '*:arguments' && ret=0
        ;;
      (bootstrap)
        _arguments \
          '--link[link packages globally after installation]' && ret=0
        ;;
      (which)
        _arguments '1:executable name' && ret=0
        ;;
    esac
    ;;
esac

return ret
