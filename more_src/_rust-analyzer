#compdef rust-analyzer

local -a _ra_cmds

_ra_cmds=(
  'analysis-stats:batch analysis for benchmarking/debugging'
  'diagnostics:emit diagnostics for files'
  'highlight:highlight a file as HTML'
  'lsif:generate LSIF data'
  'parse:parse a file and dump syntax tree'
  'proc-macro:start proc-macro server'
  'run-tests:run integrated tests'
  'scip:generate SCIP data'
  'search:search for a pattern in the codebase'
  'ssr:structural search and replace'
  'symbols:list symbols in a file'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '-v[verbose output]' \
  '--log-file[write log to file]:log file:_files' \
  '--no-log-buffering[flush log records immediately]' \
  '--wait-dbg[wait until a debugger is attached]' \
  '1:command:->cmds' \
  '*:: :->args'

case "$state" in
  cmds)
    _describe -t commands 'rust-analyzer command' _ra_cmds
    ;;
  args)
    case $words[1] in
      analysis-stats)
        _arguments \
          '--parallel[run analysis in parallel]' \
          '--randomize[randomize order of analysis]' \
          '--memory-usage[print memory usage after analysis]' \
          '--source-root-only[only analyze the source root]' \
          '-o[only analyze items matching the filter]:filter:' \
          '--with-deps[also analyze dependencies]' \
          '--no-sysroot[do not load sysroot crates]' \
          '--disable-proc-macros[do not load proc macros]' \
          '--disable-build-scripts[do not run build scripts]' \
          '*:source path:_directories'
        ;;
      diagnostics)
        _arguments \
          '--disable-proc-macros[do not load proc macros]' \
          '--disable-build-scripts[do not run build scripts]' \
          '--no-sysroot[do not load sysroot crates]' \
          '*:source path:_directories'
        ;;
      highlight)
        _arguments \
          '--rainbow[use rainbow coloring for local variables]' \
          '*:source files:_files -g "*.rs"'
        ;;
      lsif|scip)
        _arguments \
          '--output[output file]:file:_files' \
          '*:source path:_directories'
        ;;
      parse)
        _arguments \
          '--no-dump[do not dump tree]' \
          '*:source files:_files -g "*.rs"'
        ;;
      ssr)
        _arguments \
          '--debug[debug SSR rules]:snippet:' \
          '1:rule:'
        ;;
      symbols)
        _arguments '*:source files:_files -g "*.rs"'
        ;;
      *)
        _arguments '*:files:_files'
        ;;
    esac
    ;;
esac
