#compdef zpool-set zpool-get
# _zpool-set — OpenZFS zpool set / zpool get (read or write pool properties: autoexpand, autoreplace, cachefile, bootfs, failmode, listsnapshots, readonly, dedupratio, ashift, autotrim, comment, delegation; -H scriptable output, -p parsable numeric values, -o columns)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_set / zpool_do_get) on tip.

_zpool-set() {
    _arguments \
        '-H[scriptable output]' \
        '-p[parsable numeric]' \
        '-o+[columns]:cols:' \
        '1:property[=value]:(all autoexpand autoreplace autotrim ashift cachefile bootfs comment dedupratio delegation failmode listsnapshots readonly version compatibility allocated capacity expandsize fragmentation free freeing health leaked size)' \
        '2:pool:'
}

_zpool-set "$@"
