#compdef ffilecat
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/ffilecat.txt
# Collect keyword values from input files into a binary FITS table

local ret=1

_arguments -s \
  "infile=[list of input FITS files]:" \
  "outfile=[output FITS file]:file:_files" \
  "keywords=[keywords to extract]:" \
  "maxlen=[maximum string length]:" \
  "minlen=[minimum string length]:" \
  "aform=[ASCII string format]:" \
  "eform=[floating point format]:" \
  "iform=[integer format]:" \
  "omit=[omit missing keywords]:bool:(yes no)" \
  "quiet=[suppress messages]:bool:(yes no)" \
  "*:file:_files" && ret=0

return ret
