#compdef nix-search-tv
# Documentation: https://github.com/3timeslazy/nix-search-tv
# fuzzy search across Nix packages, options and other indexes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:((
    print\:"output the searchable list of entries"
    preview\:"show detailed information about a selected entry"
    index\:"build or refresh the search indexes"
  ))' \
  '*::arg:_default' && ret=0

return ret
