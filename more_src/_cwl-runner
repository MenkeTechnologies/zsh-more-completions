#compdef cwl-runner
# Documentation: https://github.com/common-workflow-language/cwltool
# cwl-runner - portable entrypoint for the default CWL reference runner (cwltool)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--outdir=[output directory]:dir:_files -/' \
  '--parallel[run jobs in parallel]' \
  '--tmpdir-prefix=[path prefix for temporary directories]:prefix:_files' \
  '--tmp-outdir-prefix=[path prefix for intermediate output directories]:prefix:_files' \
  '--leave-tmpdir[do not delete temporary directories]' \
  '--rm-tmpdir[delete temporary directories on exit]' \
  '--move-outputs[move output files to the output directory]' \
  '--copy-outputs[copy output files to the output directory]' \
  '--no-container[do not execute jobs in a container]' \
  '--udocker[use udocker instead of docker]' \
  '--singularity[use Singularity runtime]' \
  '--preserve-environment=[preserve a specific environment variable]:var' \
  '--preserve-entire-environment[preserve all environment variables]' \
  '--custom-net=[pass network name to docker run --net]:net' \
  '--validate[validate CWL document only]' \
  '--pack[combine workflow into a single document]' \
  '--print-rdf[print RDF serialization of the document]' \
  '--print-dot[print workflow visualization in Graphviz dot format]' \
  '--print-targets[print targets (output parameters)]' \
  '--print-subgraph[print workflow subgraph that produces the target]' \
  '(-t --target)'{-t,--target}'[only run specified workflow step or output]:target' \
  '--debug[print even more logging]' \
  '--quiet[only print warnings and errors]' \
  '--enable-ext[enable cwltool extensions]' \
  '--on-error=[desired behavior on error (stop or continue)]:mode:(stop continue)' \
  '--basedir=[base directory for resolving relative paths]:dir:_files -/' \
  '--relax-path-checks[do not strictly enforce path syntax]' \
  '--no-match-user[do not map user to host id in container]' \
  '--fast-parser[use experimental fast schema-salad parser]' \
  '*:CWL document:_files' && ret=0

return ret
