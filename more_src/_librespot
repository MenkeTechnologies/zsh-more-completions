#compdef librespot
# Documentation: https://github.com/librespot-org/librespot/wiki/Options
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-n --name)'{-n+,--name=}'[device name advertised on Spotify Connect]:name:' \
  '--device-type=[device type]:type:(computer tablet smartphone speaker tv avr stb audiodongle gameconsole castaudio castvideo automobile smartwatch chromebook carthing)' \
  '(-b --bitrate)'{-b+,--bitrate=}'[stream bitrate]:bitrate:(96 160 320)' \
  '(-c --cache)'{-c+,--cache=}'[cache directory]:dir:_files -/' \
  '--cache-size-limit=[cache size limit]:size:' \
  '--disable-audio-cache[disable audio cache]' \
  '--disable-credential-cache[disable credential cache]' \
  '--system-cache=[system cache directory]:dir:_files -/' \
  '--enable-volume-normalisation[enable volume normalisation (British spelling)]' \
  '--normalisation-pregain=[normalisation pre-gain (dB)]:dB:' \
  '--normalisation-method=[normalisation method]:method:(basic dynamic)' \
  '--normalisation-gain-type=[normalisation gain type]:type:(track album auto)' \
  '--normalisation-threshold=[normalisation threshold (dBFS)]:dBFS:' \
  '--normalisation-attack=[normalisation attack (ms)]:ms:' \
  '--normalisation-release=[normalisation release (ms)]:ms:' \
  '--normalisation-knee=[normalisation knee (dB)]:dB:' \
  '--format=[output sample format]:format:(F64 F32 S32 S24 S24_3 S16)' \
  '--dither=[dither algorithm]:dither:(none gpdf tpdf tpdf_hp)' \
  '--backend=[audio backend]:backend:(alsa pulseaudio rodio jackaudio portaudio pipe subprocess)' \
  '--device=[audio output device]:device:' \
  '--mixer=[mixer]:mixer:(softvol alsa)' \
  '--mixer-name=[mixer control name (alsa)]:name:' \
  '--mixer-card=[mixer card (alsa)]:card:' \
  '--mixer-index=[mixer index (alsa)]:index:' \
  '--mixer-linear-volume[use linear volume scale]' \
  '--initial-volume=[initial volume (0-100)]:volume:' \
  '--volume-ctrl=[volume control curve]:type:(cubic fixed linear log)' \
  '--volume-range=[volume range (dB)]:dB:' \
  '--autoplay=[autoplay similar tracks]:autoplay:(on off)' \
  '--ap-port=[access point port]:port:' \
  '--proxy=[HTTP proxy URL]:url:' \
  '--zeroconf-port=[Zeroconf port]:port:' \
  '--disable-discovery[disable Zeroconf discovery]' \
  '--username=[Spotify username]:username:' \
  '--password=[Spotify password]:password:' \
  '--onevent=[event handler script]:script:_files' \
  '--emit-sink-events[emit audio sink events]' \
  '*:file:_files' && ret=0

return ret
