#compdef librespot

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-n --name)'{-n,--name}'=[device name]:name:' \
  '--device-type=[device type]:type:(computer tablet smartphone speaker tv avr stb audioDongle)' \
  '(-b --bitrate)'{-b,--bitrate}'=[bitrate]:bitrate:(96 160 320)' \
  '(-c --cache)'{-c,--cache}'=[cache directory]:dir:_files -/' \
  '--cache-size-limit=[cache size limit]:size:' \
  '--disable-audio-cache[disable audio cache]' \
  '--disable-credential-cache[disable credential cache]' \
  '--system-cache=[system cache directory]:dir:_files -/' \
  '--enable-volume-normalisation[enable volume normalization]' \
  '--normalisation-pregain=[normalization pre-gain in dB]:dB:' \
  '--normalisation-method=[normalization method]:method:(basic dynamic)' \
  '--normalisation-gain-type=[normalization gain type]:type:(track album auto)' \
  '--normalisation-threshold=[normalization threshold in dBFS]:dBFS:' \
  '--normalisation-attack=[normalization attack in ms]:ms:' \
  '--normalisation-release=[normalization release in ms]:ms:' \
  '--normalisation-knee=[normalization knee in dB]:dB:' \
  '--format=[audio output format]:format:(S16 S24 S24_3 S32 F32 F64)' \
  '--dither=[dither algorithm]:dither:(none gpdf tpdf tpdf_hp)' \
  '--backend=[audio backend]:backend:(alsa pulseaudio rodio pipe subprocess)' \
  '--device=[audio output device]:device:' \
  '--mixer=[audio mixer]:mixer:(alsa softvol)' \
  '--mixer-name=[mixer name]:name:' \
  '--mixer-card=[mixer card]:card:' \
  '--mixer-index=[mixer index]:index:' \
  '--mixer-linear-volume[use linear volume scale]' \
  '--initial-volume=[initial volume (0-100)]:volume:' \
  '--volume-ctrl=[volume control type]:type:(linear log fixed)' \
  '--volume-range=[volume range in dB]:dB:' \
  '--autoplay=[autoplay similar tracks]:autoplay:(on off)' \
  '--ap-port=[access point port]:port:' \
  '--proxy=[HTTP proxy]:proxy:' \
  '--zeroconf-port=[Zeroconf port]:port:' \
  '--username=[Spotify username]:username:' \
  '--password=[Spotify password]:password:' \
  '--onevent=[event handler script]:script:_files' \
  '--emit-sink-events[emit audio sink events]' \
  '*:file:_files' && ret=0

return ret
