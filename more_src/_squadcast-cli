#compdef squadcast-cli squadcast
# _squadcast-cli — SquadCast squadcast-cli CLI command-line frontend wrapping the Squadcast incident response on-call alerting reliability platform REST API providing user team squad service escalation-policy schedule rotation override incident runbook tag dedupkey postmortem SLO SLA alert-event source notification webhook routing-rule API-key (Squadcast team Anjali Arumugam Vishwas Anjali, Go); cobra
# upstream: https://www.squadcast.com/

_squadcast-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'user:user operations'
        'team:team operations'
        'squad:squad operations'
        'service:service operations'
        'escalation-policy:escalation policy operations'
        'schedule:schedule operations'
        'rotation:rotation operations'
        'override:override operations'
        'incident:incident operations'
        'runbook:runbook operations'
        'tag:tag operations'
        'postmortem:postmortem operations'
        'slo:SLO operations'
        'webhook:webhook operations'
        'routing-rule:routing rule operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--token=+[token]:str:' \
        '--organization=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'squadcast subcommand' sub ;;
        args)
            case $words[1] in
                user|team|squad|service|escalation-policy|schedule|rotation|override|incident|runbook|tag|postmortem|slo|webhook|routing-rule) _arguments '1:op:(list get create update delete acknowledge resolve reassign snooze)' '*:id:' ;;
            esac
            ;;
    esac
}

_squadcast-cli "$@"
