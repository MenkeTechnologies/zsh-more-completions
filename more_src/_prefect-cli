#compdef prefect-cli
# _prefect-cli — Prefect dataflow orchestration CLI alias (PrefectHQ, Python); typer
# upstream: https://github.com/PrefectHQ/prefect

_prefect-cli() {
    local -a sub=(
        'agent:start prefect agent'
        'artifact:manage artifacts'
        'block:manage blocks'
        'cloud:manage cloud workspace'
        'concurrency-limit:manage concurrency limits'
        'config:view/set CLI config'
        'dashboard:open dashboard'
        'deploy:deploy a flow'
        'deployment:manage deployments'
        'dev:dev tools'
        'flow:manage flows'
        'flow-run:manage flow runs'
        'kubernetes:k8s helpers'
        'profile:manage profiles'
        'project:manage projects'
        'server:start prefect server'
        'shell:run shell command as flow'
        'task-run:manage task runs'
        'variable:manage variables'
        'work-pool:manage work pools'
        'work-queue:manage work queues'
        'worker:start worker'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--profile=+[profile]:profile:' \
        '-p+[profile]:profile:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'prefect subcommand' sub ;;
        args)
            case $words[1] in
                agent|worker) _arguments \
                    'start' \
                    '--pool=+[work pool]:str:' \
                    '--work-queue=+[work queue]:str:' \
                    '--limit=+[concurrency limit]:n:' ;;
                deployment) _arguments \
                    '1:cmd:(apply build delete inspect ls pause resume run schedule set-schedule)' \
                    '*:arg:' ;;
                flow-run) _arguments \
                    '1:cmd:(cancel delete inspect ls logs)' \
                    '*:arg:' ;;
                work-pool) _arguments \
                    '1:cmd:(create delete inspect ls pause resume set-concurrency-limit)' \
                    '*:arg:' ;;
                block) _arguments \
                    '1:cmd:(create delete inspect ls register types)' \
                    '*:arg:' ;;
                profile) _arguments \
                    '1:cmd:(create delete inspect ls populate-defaults rename use)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_prefect-cli "$@"
