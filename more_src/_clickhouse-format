#compdef clickhouse-format
# Documentation: https://clickhouse.com/docs/operations/utilities/clickhouse-format
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--query=[query to format]:query:' \
  '--oneline[format on one line]' \
  '--hilite[colorize keywords]' \
  {-N,--obfuscate}'[obfuscate query]' \
  '--seed=[obfuscation seed]:seed:' \
  '--max_query_size=[max query size]:bytes:' \
  '--max_parser_depth=[max parser depth]:n:' \
  '--max_parser_backtracks=[max parser backtracks]:n:' \
  '--max_line_length=[oneline if under this length]:n:' \
  '--comments[keep comments in output]' \
  '--semicolons_inline[place semicolons on final query line]' \
  '(-q --quiet)'{-q,--quiet}'[check syntax only, no output on success]' \
  '(-n --multiquery)'{-n,--multiquery}'[multiple queries from input]' \
  '--backslash[print queries with backslash newlines]' && ret=0

return ret
