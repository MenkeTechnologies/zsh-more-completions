#compdef clickhouse-format

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-q+,--query=}'[query to format]:query:' \
  {-n,--oneline}'[format on one line]' \
  '--hilite[colorize keywords]' \
  {-N,--obfuscate}'[obfuscate query]' \
  '--seed=[obfuscation seed]:seed:' \
  '--max_query_size=[max query size]:bytes:' \
  '--max_parser_depth=[max parser depth]:n:' \
  '--max_parser_backtracks=[max parser backtracks]:n:' \
  '--multiquery[multiple queries from input]' \
  '--backslash[print queries with backslash newlines]' && ret=0

return ret
