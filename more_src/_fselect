#compdef fselect
# Documentation: https://man.archlinux.org/search?q=fselect
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--nocolor[disable colors]' \
  '--no-color[disable colors]' \
  '*:query' && ret=0

return ret
