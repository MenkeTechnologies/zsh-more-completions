#compdef VBoxNetNAT
# Documentation: https://man.archlinux.org/search?q=VBoxNetNAT
# Reference accessed: 2026-05-16

# VBoxNetNAT: VirtualBox NAT engine (NAT Network service)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--network=[network name]:name:' \
  '--trunk-name=[trunk name]:name:' \
  '--trunk-type=[trunk type]:type:(none whatever netflt netadp srvnat)' \
  '--mac-address=[server MAC]:mac:' \
  '--ip-address=[server IP]:ip:' \
  '--port-forward4=[IPv4 port forward]:spec:' \
  '--port-forward6=[IPv6 port forward]:spec:' \
  '--need-dhcp[needs DHCP]' \
  '*::VBoxNetNAT args:_files' && ret=0
return ret
