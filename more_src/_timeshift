#compdef timeshift

# Zsh completion for timeshift - system restore tool for Linux

_arguments -s -S \
  '--create[create snapshot]' \
  '--restore[restore snapshot]' \
  '--delete[delete snapshot]' \
  '--delete-all[delete all snapshots]' \
  '--list[list all snapshots]' \
  '--snapshot-device=[snapshot device]:device:_files -g "/dev/*"' \
  '--target-device=[target device for restore]:device:_files -g "/dev/*"' \
  '--grub-device=[device to install GRUB2]:device:_files -g "/dev/*"' \
  '--skip-grub[skip GRUB2 reinstall during restore]' \
  '--verbose[show rsync output]' \
  '--scripted[run in non-interactive mode]' \
  '--yes[answer yes to all confirmation prompts]' \
  '--tags=[snapshot tags]:tags:' \
  '--comments=[snapshot comments]:comments:' \
  '--debug[show additional debug messages]' \
  '--help[show help]'
