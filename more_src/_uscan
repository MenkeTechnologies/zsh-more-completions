#compdef uscan
# Documentation: https://manpages.debian.org/uscan
# Source: debian/devscripts scripts/uscan.pl — scan upstream sources for new releases (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(--conf-file --conffile)'{--conffile=-,--conf-file=-}'[configuration file]:file:_files' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '(--no-verbose -v --verbose)'{-v,--verbose}'[verbose output]' \
    '(--verbose -v --no-verbose)--no-verbose[disable verbose]' \
    '--debug[debug output (-vv)]' \
    '--extra-debug[extra debug output (-vvv)]' \
    '(--no-dehs)--dehs[DEHS output]' \
    '(--dehs)--no-dehs[no DEHS output]' \
    '(--no-download --nodownload -d --download)'{-d,--download}'[download new upstream]' \
    '--force-download[force download (-dd)]' \
    '--overwrite-download[overwrite-download (-ddd)]' \
    '(--download -d)'{--no-download,--nodownload}'[do not download]' \
    '(--no-signature --skip-signature)--signature[check OpenPGP signature]' \
    '(--signature --skip-signature)--no-signature[skip signature checking]' \
    '(--signature --no-signature)--skip-signature[skip signature retrieval and checking]' \
    '(--report)--safe[safe mode (report only)]' \
    '(--safe)--report[same as --safe]' \
    '--report-status[same as --report --verbose]' \
    '--download-version=-[download specific upstream version]:version:_default' \
    '--download-debversion=-[download specific Debian version]:version:_default' \
    '--download-current-version[download current package version]' \
    '--check-dirname-level=-[directory check level]:level:(0 1 2)' \
    '--check-dirname-regex=-[directory regex]:regex:_default' \
    '--destdir=-[destination directory]:dir:_files -/' \
    '--package=-[package name]:package:_default' \
    '--upstream-version=-[upstream version]:version:_default' \
    '--vcs-export-uncompressed[export uncompressed tarballs]' \
    '--watchfile=-[explicit watch file]:file:_files' \
    '--bare[run uupdate in bare mode]' \
    '--http-header=-[add HTTP header]:header:_default' \
    '--no-exclusion[ignore files=! lines in watch file]' \
    '(--symlink --copy --rename)--no-symlink[do not symlink]' \
    '(--no-symlink --copy --rename)--symlink[create symlink (default)]' \
    '(--no-symlink --symlink --rename)--copy[copy instead of symlink]' \
    '(--no-symlink --symlink --copy)--rename[rename instead of symlink]' \
    '--timeout=-[network timeout]:seconds:_default' \
    '(--useragent)--user-agent=-[HTTP User-Agent]:ua:_default' \
    '(--user-agent)--useragent=-[HTTP User-Agent]:ua:_default' \
    '(--no-repack)--repack[repack tarball]' \
    '--no-repack[do not repack]' \
    '--compression=-[repack compression]:method:(gzip bzip2 lzma xz zip)' \
    '--copyright-file=-[copyright file]:file:_files' \
    '1::path:_files -/' \
    && ret=0

return ret
