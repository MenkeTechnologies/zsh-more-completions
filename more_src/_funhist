#compdef funhist
# Documentation: https://github.com/ericmandel/funtools/blob/master/man/man1/funhist.1
# Create a 1D histogram of a column or image from Funtools data

local ret=1

_arguments -s -S \
  '-n[normalize bin value by the width of each bin]' \
  '-w[arg3 is bin width instead of number of bins]' \
  '-T[output in rdb/starbase format (tab separators)]' \
  '*:input file:_files' && ret=0

return ret
