#compdef mcp

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a commands=(
      'version:show the MCP version'
      'dev:run an MCP server with the MCP Inspector'
      'run:run an MCP server'
      'install:install an MCP server in the Claude desktop app'
    )
    _describe -t commands 'mcp command' commands && ret=0
    ;;
  args)
    case $words[1] in
      dev)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-e --with-editable)'{-e,--with-editable}'[directory containing pyproject.toml to install in editable mode]:directory:_directories' \
          '*--with[additional packages to install]:package' \
          '1:file spec (file.py or file.py\:object):_files -g "*.py"' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-t --transport)'{-t,--transport}'[transport protocol to use]:transport:(stdio sse)' \
          '1:file spec (file.py or file.py\:object):_files -g "*.py"' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-n --name)'{-n,--name}'[custom name for the server]:name' \
          '(-e --with-editable)'{-e,--with-editable}'[directory containing pyproject.toml to install in editable mode]:directory:_directories' \
          '*--with[additional packages to install]:package' \
          '*'{-v,--env-var}'[environment variables in KEY=VALUE format]:env var' \
          '(-f --env-file)'{-f,--env-file}'[load environment variables from a .env file]:env file:_files' \
          '1:file spec (file.py or file.py\:object):_files -g "*.py"' && ret=0
        ;;
      version)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
