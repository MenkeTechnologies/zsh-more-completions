#compdef pfsdisplayfunction
# Documentation: https://manpages.opensuse.org/Tumbleweed/pfstools/pfsdisplayfunction.1.en.html
# apply a display function to colour or gray-scale images in a pfs stream

local ret=1

_arguments -s \
  '(-l --to-luminance)'{-l,--to-luminance}'[convert pixel values to absolute luminance/radiance units]' \
  '(-p --to-pixels)'{-p,--to-pixels}'[convert absolute luminance/radiance units to pixel values]' \
  '(-d --display-function)'{-d+,--display-function=}'[display function spec (default pd=lcd)]:df-spec' \
  '--verbose[enable verbose output]' \
  '--help[display help information]' && ret=0

return ret
