#compdef gdlint
# _gdlint — GDScript linter from gdtoolkit (Scony/godot-gdscript-toolkit)
# upstream: https://github.com/Scony/godot-gdscript-toolkit
# Flags from gdtoolkit/linter/__main__.py (docopt).

_gdlint() {
    local -a args
    args=(
        '(-d --dump-default-config)'{-d,--dump-default-config}'[dump default config to gdlintrc and exit]'
        '(-v --verbose)'{-v,--verbose}'[show extra prints]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '*:GDScript file or directory:_files -g "*.gd"'
    )
    _arguments -s -S $args
}

_gdlint "$@"
