autoload -U is-at-least

_uu-mkfifo() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-m+[file permissions for the fifo]:MODE:_default' \
'--mode=[file permissions for the fifo]:MODE:_default' \
'--context=[like -Z, or if CTX is specified then set the SELinux or SMACK security context to CTX]::CTX:_default' \
'-Z[set the SELinux security context to default type]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::fifo:_files' \
&& ret=0
}

(( $+functions[_uu-mkfifo_commands] )) ||
_uu-mkfifo_commands() {
    local commands; commands=()
    _describe -t commands 'uu-mkfifo commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-mkfifo" ]; then
    _uu-mkfifo "$@"
else
    compdef _uu-mkfifo uu-mkfifo
fi
