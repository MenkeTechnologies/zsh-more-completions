#compdef draco_transcoder
# Documentation: https://github.com/google/draco
# Applies Draco compression to glTF (GLB) files

local ret=1

_arguments -s -S \
  '-h[show usage and options]' \
  '-i[input glTF file (GLB format)]:input:_files' \
  '-o[output glTF file with Draco compression applied]:output:_files' \
  '-qp[quantization bits for position attribute]:bits:' \
  '*:file:_files' && ret=0

return ret
