#compdef FEXRootFSFetcher
# _FEXRootFSFetcher — fetch / install FEX-Emu rootfs images (FEX-Emu/FEX)
# upstream: https://github.com/FEX-Emu/FEX
# Flags from Source/Tools/FEXRootFSFetcher/Main.cpp (cpp-optparse).

_FEXRootFSFetcher() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-y --assume-yes)'{-y,--assume-yes}'[assume yes to all prompts]'
        '(-x --extract)'{-x,--extract}'[extract a compressed rootfs image]'
        '(-a --as-is)'{-a,--as-is}'[use the compressed image as-is (mount via squashfs)]'
        '--distro-name=[distro name to select]:name:(ubuntu fedora arch debian)'
        '--distro-version=[distro version to select]:version:'
        '--distro-list-first[auto-select the first distro on no exact match]'
        '--force-ui=[override the selection UI]:ui:(default tty zenity)'
    )
    _arguments -s $args
}

_FEXRootFSFetcher "$@"
