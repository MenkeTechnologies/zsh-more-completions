#compdef hyprcursor-util
# _hyprcursor-util — compile / extract hyprcursor + xcursor themes (hyprwm/hyprcursor)
# upstream: https://github.com/hyprwm/hyprcursor
# Flags from hyprcursor-util/src/main.cpp.

_hyprcursor-util() {
    local -a args
    args=(
        '(- *)'{-v,--version}'[show version]'
        '(-c --create)'{-c+,--create=}'[compile a working-state directory into a hyprcursor theme]:dir:_files -/'
        '(-x --extract)'{-x+,--extract=}'[extract an xcursor theme into a working-state directory]:dir:_files -/'
        '(-o --output)'{-o+,--output=}'[parent directory to write the result into]:dir:_files -/'
        '--resize=[default resize algorithm (extract only)]:algo:(none bilinear nearest)'
    )
    _arguments -s $args
}

_hyprcursor-util "$@"
