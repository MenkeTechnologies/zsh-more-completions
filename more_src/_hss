#compdef hss
# Documentation: https://github.com/six-ddc/hss
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# six-ddc/hss — parallel interactive SSH (`hss --help`)

local ret=1
_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '-H+,--hosts-file=[host list file]:file:_files' \
  '-p+,--port=[SSH port]:port:' \
  '-l+,--login=[remote user]:user:' \
  '-i+,--identity=[private key]:key:_files' \
  '*::remote hosts:_hosts' && ret=0
return ret
