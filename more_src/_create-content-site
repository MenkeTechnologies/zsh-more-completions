#compdef create-content-site
# Documentation: https://www.npmjs.com/package/create-content-site
# Reference accessed: 2026-05-23
# Verified: npm view create-content-site bin; npm readme Usage section.

# Zsh completion for create-content-site - downstream content site scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--scaffold=[GitHub scaffold repository URL]:url:'   '--ref=[scaffold git ref]:ref:'   '--skip-install[create project without installing dependencies]'   '--skip-check[install dependencies but skip pnpm check]'   ':site name:' && ret=0

return ret
