#compdef llvm-tblgen
# _llvm-tblgen — LLVM TableGen code generator (LLVM project, C++); generate machine descriptions from .td DSL
# upstream: https://github.com/llvm/llvm-project

_llvm-tblgen() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '--write-if-changed[write if changed]' \
        '--print-records[print records]' \
        '--gen-emitter[gen emitter]' \
        '--gen-register-info[gen register info]' \
        '--gen-instr-info[gen instr info]' \
        '--gen-asm-writer[gen asm writer]' \
        '--gen-asm-matcher[gen asm matcher]' \
        '--gen-disassembler[gen disassembler]' \
        '--gen-pseudo-lowering[gen pseudo lowering]' \
        '--gen-callingconv[gen calling conv]' \
        '--gen-dag-isel[gen dag isel]' \
        '--gen-dfa-packetizer[gen dfa packetizer]' \
        '--gen-fast-isel[gen fast isel]' \
        '--gen-global-isel[gen global isel]' \
        '--gen-global-isel-combiner[gen global isel combiner]' \
        '--gen-intrinsic-enums[gen intrinsic enums]' \
        '--gen-intrinsic-impl[gen intrinsic impl]' \
        '--gen-pragma[gen pragma]' \
        '--gen-searchable-tables[gen searchable tables]' \
        '--gen-subtarget[gen subtarget]' \
        '--gen-x86-EVEX2VEX-tables[gen X86 EVEX2VEX tables]' \
        '--gen-x86-fold-tables[gen X86 fold tables]' \
        '-I+[include path]:dir:_files -/' \
        '-D+[define]:def:' \
        '--dump-json[dump json]' \
        '--print-detailed-records[print detailed records]' \
        '*:file:_files -g "*.td"'
}

_llvm-tblgen "$@"
