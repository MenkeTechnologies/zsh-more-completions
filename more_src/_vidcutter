#compdef vidcutter
# Documentation: https://man.archlinux.org/search?q=vidcutter
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(--debug)--debug[debug mode]' \
  '(--verbose)--verbose[verbose mode]' \
  '(--dev)--dev[development mode]' \
  '*:video:_files -g "*.{mp4,m4v,mov,avi,mkv,mpg,mpeg,vob,webm,flv,wmv,3gp,ts}"' && ret=0

return ret
