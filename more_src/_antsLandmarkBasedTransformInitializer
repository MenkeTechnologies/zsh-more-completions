local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:dimension:(2 3 4)' \
    '2:fixedImage (with labelled landmarks):_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:movingImage (with labelled landmarks):_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '4:transformType:(rigid affine similarity bspline)' \
    '5:outputTransform.{txt,mat,nii.gz}:_files' \
    '*:transform-specific args (e.g. BSpline meshSize numLevels order):_default' \
    && ret=0

return ret
