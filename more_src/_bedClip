#compdef bedClip
# remove lines from bed file that refer to off-chromosome locations

local ret=1

_arguments -s -S \
  '-truncate[truncate items that span ends of chrom instead of dropping]' \
  '1:input bed:_files -g "*.bed"' \
  '2:chrom sizes:_files' \
  '3:output bed:_files' && ret=0

return ret
