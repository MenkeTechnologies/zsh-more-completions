#compdef jet
# Documentation: https://github.com/borkdude/jet
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jet (Clojure data transformation tool by borkdude)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(--from -i)'{--from,-i}'=[input format]:format:(edn transit json yaml)' \
  '(--to -o)'{--to,-o}'=[output format]:format:(edn transit json yaml)' \
  '(--keywordize -k)'{--keywordize,-k}'=[keywordize JSON/YAML keys]:key-fn:' \
  '--no-pretty[disable pretty printing]' \
  '--colors=[colored output while pretty-printing]:mode:(auto true false)' \
  '(--func -f)'{--func,-f}'=[single-arg Clojure function or file path to transform input]:func:' \
  '(--thread-last -t)'{--thread-last,-t}'[implicit thread last]' \
  '(--thread-first -T)'{--thread-first,-T}'[implicit thread first]' \
  '(--collect -c)'{--collect,-c}'[collect separate values into a vector]' \
  '--edn-reader-opts=[options passed to the EDN reader]:options:' \
  '(--query -q)'{--query,-q}'=[DEPRECATED query expression]:expression:' \
  '(- *)'{--version,-v}'[show version]' \
  '(- *)'{--help,-h}'[show help]' \
  '*:file:_files' && ret=0

return ret
