#compdef jet

# Zsh completion for jet (Clojure data transformation tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--from=[input format]:format:(edn json transit yaml csv)' \
  '--to=[output format]:format:(edn json transit yaml csv)' \
  '--keywordize[keywordize JSON keys]' \
  '--no-keywordize[do not keywordize JSON keys]' \
  '--pretty[pretty print output]' \
  '--query=[query expression]:expression' \
  '--func=[function to apply]:function' \
  '--thread-last=[thread-last macro expression]:expression' \
  '--thread-first=[thread-first macro expression]:expression' \
  '--collect[collect results into a vector]' \
  '--colors[enable colored output]' \
  '--no-colors[disable colored output]' \
  '--edn-reader-opts=[EDN reader options]:options' \
  '--version[show version]' \
  '--help[show help]' \
  '*:file:_files' && ret=0

return ret
