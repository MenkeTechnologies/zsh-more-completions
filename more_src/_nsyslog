#compdef nsyslog
# ============================================================================
# nsyslog - Modular log forwarding agent (Node, MIT)
#
# Author : Eduardo Solorzano (solzimer)
# Upstream: https://github.com/solzimer/nsyslog
# npm    : nsyslog
#
# nsyslog is a Logstash-style log forwarding + transformation
# pipeline written entirely in Node. Operator declares input
# sources (file tail, syslog UDP/TCP, RELP, HTTP, MQTT, Kafka,
# Redis, etc.), processors (parse, filter, enrich), and output
# sinks (Elasticsearch, S3, Kafka, MongoDB, file, syslog
# forwarder) in a JSON config; nsyslog wires them into a streaming
# DAG and pushes events through end-to-end. The Snappy + GZip
# compression options are exposed on each compressing output
# sink (Kafka producer, S3 object writer, HTTP gzip-encoded POST).
#
# CLI flags:
#   -f, --file <file>     - config JSON
#   -t, --test            - validate config and exit
#   -m, --merge <files>   - additional config files to merge in (CSV)
#   -l, --log-file <path> - write logs to file
#   -L, --log-level <lvl> - debug verbosity
#   -v, --verbose         - verbose stats logging
#   --ssl-cert / --ssl-key / --ssl-key-pass - TLS material
#   --encrypt / --decrypt - on-disk config secret encryption helpers
#   --cli / --cli-start   - launch the interactive CLI session
#
# The Snappy compression lane is built on `snappy ^7.3.3` (declared
# verbatim at upstream package.json HEAD), the canonical Node
# Snappy library by Brooooooklyn (Long Yinan, github.com/Brooooooklyn/
# snappy). The package is the Node ecosystem's de-facto Snappy
# binding, exposing both the block format and the streaming
# framing format. As of v7+ the package switched its native
# backend from `kesla/node-snappy`'s C++ libsnappy binding to the
# napi-rs / `@node-rs/snappy` Rust-via-napi binding (which itself
# wraps `BurntSushi/rust-snappy` from the Axis 215 Rust slot).
# This makes the Node lane structurally interesting: Node's
# canonical Snappy is now a wrapper over the Rust lane's canonical
# Snappy, vs the historically common pattern of wrapping the C
# reference library.
#
# ----------------------------------------------------------------------------
# AXIS 215 :: SNAPPY COMPRESSION (Google block + framing format)  [CLOSES]
# Round 1345 :: TS-Node slot 3 of 4 :: CLOSES Axis 215 (208th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : BurntSushi/rust-snappy           [R1343 _influxdb3]
#   Go      : golang/snappy                    [R1344 _influx_inspect]
#   TS/Node : Brooooooklyn/snappy (napi-rs)    [R1345 THIS FILE]
#
# Notable: the Node lane's modern Snappy (v7+) is implemented via
# the napi-rs Rust-binding to BurntSushi/rust-snappy. Effectively
# the Rust lane's canonical now powers two of the three lanes -
# direct in Rust, and via N-API in Node. This is a recurring
# pattern in 2024-2026 napi-rs adoption: high-performance Node
# packages migrate from C++ bindings to Rust bindings (visible
# at @node-rs/argon2, @node-rs/snappy, @swc/core, @next/swc,
# @rspack/binding, etc.).
# ============================================================================

_nsyslog() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-f --file)'{-f,--file}'[config JSON file]:file:_files -g "*.json"' \
        '(-t --test)'{-t,--test}'[validate config and exit]' \
        '(-m --merge)'{-m,--merge}'[extra config files to merge (CSV)]:files:' \
        '(-l --log-file)'{-l,--log-file}'[write logs to file]:file:_files' \
        '(-L --log-level)'{-L,--log-level}'[log level]:level:(trace debug info warn error)' \
        '(-v --verbose)'{-v,--verbose}'[verbose stats logging]' \
        '--ssl-cert[SSL certificate file]:file:_files -g "*.(crt|pem)"' \
        '--ssl-key[SSL private key file]:file:_files -g "*.(key|pem)"' \
        '--ssl-key-pass[SSL private key passphrase]:password:' \
        '--encrypt[encrypt data using the config-key encryption helper]:data:' \
        '--decrypt[decrypt data using the config-key encryption helper]:data:' \
        '--cli[start the interactive CLI session]' \
        '--cli-start[start CLI session and run flows]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_nsyslog "$@"
