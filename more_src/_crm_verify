#compdef crm_verify

# Pacemaker crm_verify: check CIB syntax and configuration validity
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-Q --quiet)'{-Q,--quiet}'[quiet]' \
  '(-x --xml-file)'{-x,--xml-file=}'[XML file to verify]:file:_files' \
  '(-X --xml-text)'{-X,--xml-text=}'[XML text to verify]:xml:' \
  '(-p --xml-pipe)'{-p,--xml-pipe}'[read XML from stdin]' \
  '(-L --live-check)'{-L,--live-check}'[verify the live CIB]' \
  '*::crm_verify args:_files' && ret=0
return ret
