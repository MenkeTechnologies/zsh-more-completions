#compdef ip-macsec
# Documentation: https://man.archlinux.org/man/ip-macsec.8.en
# ip macsec - MACsec secure channel configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip macsec command' \
      'add[create secure association or channel]' \
      'set[modify secure association or channel]' \
      'del[remove secure association or channel]' \
      'show[display MACsec configuration]' 'offload[configure hardware offloading]' \
      'cipher[cipher suite]' 'icvlen[ICV length]' 'encrypt[encryption on/off]' \
      'send_sci[send SCI on/off]' 'end_station[end station on/off]' \
      'scb[single copy broadcast on/off]' 'protect[integrity protection on/off]' \
      'replay[replay protection on/off]' 'window[replay window]' \
      'validate[validation strict/check/disabled]' 'encodingsa[encoding SA]' \
      'tx[transmit secure association]' 'rx[receive secure channel]' \
      'sa[secure association number]' 'pn[packet number]' 'xpn[extended packet number]' \
      'salt[96-bit salt hex string]' 'ssci[short SCI value]' 'key[encryption key]' \
      'sci[secure channel identifier]' 'port[port identifier]' 'address[link-layer address]' \
      'on[enable]' 'off[disable]' && ret=0
    ;;
esac

return ret
