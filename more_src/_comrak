#compdef comrak
# Documentation: https://github.com/kivikakk/comrak
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o+,--output=}'[write results to file]:output file:_files' \
  '(-i --inplace)'{-i,--inplace}'[reformat files in-place]' \
  '(-c --config-file)'{-c+,--config-file=}'[config file for CLI arguments]:config file:_files' \
  '(-t --to)'{-t+,--to=}'[output format]:format:(html xml commonmark)' \
  '--hardbreaks[treat newlines as hard line breaks]' \
  '--smart[use smart punctuation]' \
  '--github-pre-lang[use GitHub-style <pre lang> for code blocks]' \
  '--full-info-string[include full info string in code blocks]' \
  '--gfm[enable GitHub-Flavored Markdown extensions]' \
  '--gfm-quirks[apply GFM-style output quirks]' \
  '--default-info-string=[default info string for fenced code]:string' \
  '*'{-e+,--extension=}'[enable an extension]:extension:(strikethrough tagfilter table autolink tasklist superscript footnotes description-lists front-matter math-code math-dollars shortcodes wikilinks-title-after-pipe wikilinks-title-before-pipe underline subscript spoiler greentext alerts)' \
  '--header-ids=[use header IDs with prefix]:prefix:' \
  '--width=[set the wrap column width]:width:' \
  '--unsafe[allow raw HTML and dangerous URLs]' \
  '--escape[escape raw HTML instead of clobbering]' \
  '--sourcepos[include source position attributes]' \
  '--list-style=[set list style]:style:(dash plus star)' \
  '*:file:_files' && ret=0

return ret
