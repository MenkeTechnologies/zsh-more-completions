#compdef glsl_analyzer
# Documentation: https://github.com/nolanderc/glsl_analyzer
# glsl_analyzer - language server for GLSL

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '--stdio[communicate over standard input/output]' \
  '(-p --port)'{-p,--port}'=[specify socket port for communication]:port' \
  '--clientProcessId=[client process id for LSP]:pid' \
  '--dev-mode[enable development mode with stderr redirection]:dir:_files -/' \
  '--parse-file=[parse a file and show diagnostics]:file:_files' \
  '--print-ast[display the parse tree, requires --parse-file]' \
  '--format=[format and output a file]:file:_files' && ret=0

return ret
