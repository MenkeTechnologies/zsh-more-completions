#compdef gmtconvert
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtconvert.html
# Source: GenericMappingTools/gmt classic-mode gmtconvert — combine / filter / transform table records.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[paste horizontally (not append vertically)]' \
    '-C+[segment record-count filter (min/max)]:opts:_default' \
    '-D+[dump each segment to separate file]:opts:_default' \
    '-E+[extract first/last record or stride]:opts:_default' \
    '-F+[connection / segmentation scheme]:opts:_default' \
    '-I+[reverse tables/segments/records order]:scope:_default' \
    '-L[output only segment headers]' \
    '-N+[numerical segment sort by column]:col:_default' \
    '-Q+[select segments by number/range]:opts:_default' \
    '-S+[filter segments by text pattern]:pattern:_default' \
    '-T+[suppress headers / duplicates]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[trailing text words → numeric columns]:opts:_default' \
    '-Z[transpose single-segment data]' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-q+[row selection]:opts:_default' \
    '*:input table:_files' \
    && ret=0

return ret
