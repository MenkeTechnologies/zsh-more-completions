#compdef wasm-strip
# Documentation: https://man.archlinux.org/search?q=wasm-strip
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-o+[output file]:file:_files' \
  '1:input wasm file:_files -g "*.wasm"' && ret=0

return ret
