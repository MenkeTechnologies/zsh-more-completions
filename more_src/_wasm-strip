#compdef wasm-strip
# Documentation: https://webassembly.github.io/wabt/doc/wasm-strip.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-o+[output file]:file:_files' \
  '1:input wasm file:_files -g "*.wasm"' && ret=0

return ret
