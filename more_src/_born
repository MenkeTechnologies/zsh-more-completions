# Calculate generalized Born forces and energies

local ret=1

_arguments -s \
  '-v[give per-atom information]' \
  '-f[calculate forces in addition to energies]' \
  '1:solvent dielectric constant:' \
  '2:molecule PQR file:_files -g "*.pqr"' && ret=0

return ret
