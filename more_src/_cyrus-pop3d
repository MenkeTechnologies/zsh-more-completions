#compdef cyrus-pop3d
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/pop3d.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org pop3d(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-pop3d: POP3 server process (run via Cyrus master)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-U[max process reuses before shutdown (default 250)]:n:' \
  '-T[idle timeout seconds before shutdown (default 60)]:seconds:' \
  '-D[run external debugger]' \
  '-H[expect HAProxy protocol header from sender]' \
  '-s[serve POP3 over SSL (pop3s)]' \
  '-p[external SSF security strength factor]:ssf:' && ret=0
return ret
