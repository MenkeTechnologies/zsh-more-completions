#compdef create-projx
# Documentation: https://www.npmjs.com/package/create-projx
# Reference accessed: 2026-05-23
# Verified: npx create-projx --help.

# Zsh completion for create-projx - fullstack project scaffolder (projx)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--components=[comma-separated stack components]:components:(fastapi fastify express frontend mobile e2e infra)' \
  '--orm=[Node backend ORM]:orm:(prisma drizzle sequelize typeorm)' \
  '--auth=[auth feature targets]:targets:' \
  '--no-git[skip git init]' \
  '--no-install[skip dependency installation]' \
  '(-y --yes)'{-y,--yes}'[accept defaults]' \
  '--local=[use local template repo path]:path:_files' \
  ':project name:' && ret=0

return ret
