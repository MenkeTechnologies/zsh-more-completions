#compdef showalign
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/showalign.html
# showalign - Display a multiple sequence alignment in pretty format

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-sequence[the sequence alignment to display]:file:_files' \
  '-outfile[output file name]:file:_files' \
  '-matrix[scoring matrix file]:file:_files' \
  '-refseq[reference sequence (number/name/0)]:refseq:' \
  '-bottom[display reference sequence at bottom]' \
  '-show[what to display]:show:(All Identities Non-identities Similarities Dissimilarities)' \
  '-order[output sequence order]:order:(Input Alphabetical Similarity)' \
  '-similarcase[change similar residues to lowercase]' \
  '-consensus[display the consensus line]' \
  '-uppercase[regions to display in uppercase]:regions:' \
  '-number[display position numbering line]' \
  '-ruler[display ruler marking positions]' \
  '-width[width of sequence display]:width:' \
  '-margin[left margin width for sequence names]:margin:' \
  '-html[format output as HTML]' \
  '-highlight[regions to color in HTML output]:regions:' \
  '-plurality[consensus cutoff percentage]:plurality:' \
  '-setcase[threshold for case of consensus]:setcase:' \
  '-identity[required identities for consensus]:identity:' \
  '-gaps[allow gap characters in consensus]' \
  '-auto[turn off prompts]' \
  '-version[display version number]' \
  '*:alignment file:_files' && ret=0

return ret
