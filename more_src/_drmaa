#compdef drmaa drmaa_run
# _drmaa — DRMAA distributed-resource-management-application-API command runner; submits a job to the DRMAA-compatible backend (SGE/PBS/Torque/SLURM)
# upstream: https://www.drmaa.org/

_drmaa() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-q+[queue]:queue:' \
        '-n+[job name]:name:' \
        '-W+[wall clock limit]:duration:' \
        '-l+[resource list]:resource:' \
        '-o+[stdout file]:file:_files' \
        '-e+[stderr file]:file:_files' \
        '-i+[stdin file]:file:_files' \
        '-d+[working dir]:dir:_files -/' \
        '-N+[task count]:n:' \
        '-j+[join stderr to stdout]' \
        '-M+[email]:email:' \
        '*:command:_command_names -e'
}

_drmaa "$@"
