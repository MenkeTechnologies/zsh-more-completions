#compdef tiddlywiki
# Documentation: https://man.archlinux.org/search?q=tiddlywiki
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  '--build:build target from tiddlywiki.info'
  '--clearpassword:clear current password'
  '--commands:list commands'
  '--deletetiddlers:delete tiddlers matching filter'
  '--editions:list available editions'
  '--fetch:fetch remote files'
  '--help:show help'
  '--import:import tiddler files'
  '--init:initialise wikifolder with edition'
  '--listen:start HTTP server'
  '--load:load tiddlers from file/dir'
  '--makelibrary:create plugin library'
  '--output:set output dir'
  '--password:set password'
  '--render:render tiddlers to files'
  '--save:save tiddlers raw'
  '--savewikifolder:save current state to wiki folder'
  '--setfield:set field on tiddler'
  '--unpackplugin:unpack plugin tiddlers'
  '--verbose:verbose output'
  '--version:show version'
)

_arguments -C \
  '1:wiki folder:_files -/' \
  '*::cmd-and-args:->args' && ret=0

case $state in
  (args) _describe -t cmds 'tiddlywiki command' commands && ret=0 ;;
esac

return ret
