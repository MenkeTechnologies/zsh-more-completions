#compdef xsel
# Documentation: https://man.archlinux.org/man/xsel.1.en
# Reference accessed: 2026-05-30
# xsel — manipulate X11 selections (PRIMARY/SECONDARY/CLIPBOARD) from the command line.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --append -f --follow -i --input -o --output -c --clear -d --delete -x --exchange)'{-a,--append}'[append stdin to the selection]' \
  '(-a --append -f --follow -i --input -o --output -c --clear -d --delete -x --exchange)'{-f,--follow}'[append to selection as stdin grows]' \
  '(-a --append -f --follow -i --input -o --output -c --clear -d --delete -x --exchange)'{-i,--input}'[read stdin into the selection]' \
  '(-a --append -f --follow -i --input -o --output -c --clear -d --delete -x --exchange)'{-o,--output}'[write the selection to stdout]' \
  '(-a --append -f --follow -i --input -o --output -c --clear -d --delete -x --exchange)'{-c,--clear}'[clear the selection]' \
  '(-a --append -f --follow -i --input -o --output -c --clear -d --delete -x --exchange)'{-d,--delete}'[request deletion of current selection]' \
  '(-a --append -f --follow -i --input -o --output -c --clear -d --delete -x --exchange)'{-x,--exchange}'[exchange PRIMARY + SECONDARY]' \
  '(-p --primary -s --secondary -b --clipboard)'{-p,--primary}'[operate on PRIMARY selection (default)]' \
  '(-p --primary -s --secondary -b --clipboard)'{-s,--secondary}'[operate on SECONDARY selection]' \
  '(-p --primary -s --secondary -b --clipboard)'{-b,--clipboard}'[operate on CLIPBOARD selection]' \
  '(-k --keep)'{-k,--keep}'[make PRIMARY + SECONDARY persist after programs exit]' \
  '--display=[X server display to use]:display:' \
  '--windowName=[X WM_NAME window property]:name:' \
  '(-t --selectionTimeout)'{-t,--selectionTimeout=}'[selection retrieval timeout (ms)]:ms:' \
  '(-l --logfile)'{-l,--logfile=}'[error log file]:file:_files' \
  '(-n --nodetach)'{-n,--nodetach}'[do not detach from controlling terminal]' \
  '(-v --verbose)'{-v,--verbose}'[print informative messages]' \
  && ret=0

return ret
