#compdef mris_smooth
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_smooth
# FreeSurfer smooth a cortical surface

local ret=1

_arguments -s -S \
  '-a[# of curvature averaging iterations (def 10)]:avgs:' \
  '-n[# of smoothing iterations (def 10)]:niter:' \
  '1:input surface:_files' \
  '2:output surface:_files' && ret=0

return ret
