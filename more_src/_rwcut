#compdef rwcut rwbag rwset rwscan rwresolve rwfglob rwaddrcount rwrecgenerator
# Documentation: upstream tools.netsa.cert.org/silk/ man pages and
# source code at github.com/bbayles/netsa-pkg (silk-src/src/).
# Reference accessed: 2026-05-30 via WebFetch of rw{cut,bag,set,scan,
# resolve,fglob}.html plus gh api inspection of */rwcutsetup.c,
# */rwaddrcount.c, */rwbag.c, */rwset.c, */rwscan.c, */rwresolve.c
# OPT_* tables and Makefile.am bin_PROGRAMS lines.
# CERT NetSA SiLK R90 — 8-stem multi-binary harvest covering core
# SiLK rw* analysis tools not previously covered (existing _rwfilter
# multi-stem covers rwfilter+rwstats+rwsort+rwuniq+rwcat+rwcount+
# rwfileinfo+rwgroup, _rwaggbag+_rwappend+_rwflowpack+_rwipfix2silk+
# _rwsetbuild from earlier rounds).

local curcontext="$curcontext" state line ret=1

# Shared SiLK common options (output formatting, plugin loading,
# config file resolution) — present on most rw* tools.
local -a _silk_common
_silk_common=(
  '--no-titles[suppress column headers]'
  '--no-columns[disable fixed-width columnar output]'
  '--column-separator=[column delimiter (default |)]:char:'
  '--no-final-delimiter[omit separator after final column]'
  '--delimited=[shorthand for --no-columns with custom delimiter]:char:'
  '--integer-tcp-flags[output TCP flags as integers]'
  '--integer-sensors[output sensors as integers]'
  '--integer-ips[output IPs as decimal integers]'
  '--icmp-type-and-code[combine icmp type+code into one field]'
  '--epoch-time[print times as Unix epoch]'
  '--output-path=[write output to file/pipe]:file:_files'
  '--pager=[paging command (default $SILK_PAGER or $PAGER)]:command:'
  '--site-config-file=[read site config from this file]:file:_files'
  '--plugin=[load plugin .so file]:file:_files'
  '--ipv6-policy=[IPv4/IPv6 policy]:policy:(ignore asv4 mix force only)'
  '--compression-method=[compression]:method:(none zlib lzo1x snappy best)'
  '--note-strip[do not copy notes from input files]'
  '*--note-add=[add annotation text (repeatable)]:text:'
  '*--note-file-add=[add annotation from file (repeatable)]:file:_files'
  '--invocation-strip[omit command-line history from output]'
  '--print-filenames[print input filenames to stderr as they open]'
  '--copy-input=[duplicate input records to this path]:file:_files'
  '--xargs=[read input filenames from file (or stdin)]:file:_files'
  '--dry-run[parse options but do not process records]'
  '(- *)--help[show help]'
  '(- *)--legacy-help[show help in legacy format]'
  '(- *)--version[show version and configuration]'
)

case $service in

  rwcut)
    # Cut and display specified columns from SiLK flow records.
    _arguments -s -S \
      $_silk_common \
      '--fields=[fields to display (comma-separated)]:fields:' \
      '--all-fields[display all available fields]' \
      '--help-fields[print help for available fields]' \
      '--num-recs=[print only the first N records]:N:' \
      '--start-rec-num=[start at this record number]:N:' \
      '--end-rec-num=[end at this record number]:N:' \
      '--tail-recs=[print only the last N records]:N:' \
      '--python-file=[load Python plugin file]:file:_files -g "*.py"' \
      '*:SiLK flow file:_files' && ret=0
    ;;

  rwbag)
    # Bin flow records into a Bag (key,counter) data structure.
    _arguments -s -S \
      $_silk_common \
      '*--bag-file=[KEY,COUNTER,OUTFILE - required, repeatable]:spec:' \
      '*--pmap-file=[prefix map file (optionally MAPNAME\:PATH)]:file:_files' \
      '*:SiLK flow file:_files' && ret=0
    ;;

  rwset)
    # Build IPset files from source/destination/next-hop addresses.
    _arguments -s -S \
      $_silk_common \
      '--sip-file=[IPset of unique source IPs]:file:_files' \
      '--dip-file=[IPset of unique destination IPs]:file:_files' \
      '--nhip-file=[IPset of unique next-hop IPs]:file:_files' \
      '--any-file=[IPset of unique source+destination IPs]:file:_files' \
      '--record-version=[IPset record format version]:version:(0 2 3 4 5)' \
      '*:SiLK flow file:_files' && ret=0
    ;;

  rwscan)
    # Statistical scan detection (TRW + BLR algorithms).
    _arguments -s -S \
      $_silk_common \
      '--scan-model=[detection algorithm (0=TRW+BLR, 1=TRW, 2=BLR)]:model:(0 1 2)' \
      '--trw-internal-set=[IPset of valid internal IPs]:file:_files' \
      '--trw-sip-set=[deprecated alias for --trw-internal-set]:file:_files' \
      '--trw-theta0=[benign-connection success probability (default 0.8)]:p:' \
      '--trw-theta1=[malicious-connection success probability (default 0.2)]:p:' \
      '--model-fields[display scan-model detail fields]' \
      '--scandb[format output for database loading]' \
      '--threads=[worker thread count]:N:' \
      '--queue-depth=[work queue size]:N:' \
      '--verbose-progress=[report progress by CIDR block]:cidr:' \
      '--verbose-flows[print detailed per-flow information]' \
      '--verbose-results=[show calculations for each source]:flow count:' \
      '*:SiLK flow file:_files' && ret=0
    ;;

  rwresolve)
    # Resolve IP-address columns in textual SiLK output to hostnames.
    _arguments -s -S \
      '--ip-fields=[column numbers (comma-separated) to resolve]:fields:' \
      '--delimiter=[input column delimiter (default |)]:char:' \
      '--column-width=[fixed width for resolved column]:N:' \
      '--resolver=[DNS resolver implementation]:resolver:(getnameinfo gethostbyaddr)' \
      '--max-requests=[maximum concurrent DNS requests]:N:' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '*:textual input file:_files' && ret=0
    ;;

  rwfglob)
    # rwfilter file-globber — preview which raw SiLK files rwfilter
    # would select for a given class/type/sensor/time-range.
    _arguments -s -S \
      '--class=[class of files to select]:class:' \
      '--type=[traffic types (comma-separated, or "all")]:types:' \
      '--flowtypes=[class/type pairs (alternate syntax)]:pairs:' \
      '--sensors=[sensor names/IDs/ranges/groups]:sensors:' \
      '--start-date=[start date (YYYY/MM/DD[\:HH] or epoch)]:date:' \
      '--end-date=[end date (YYYY/MM/DD[\:HH] or epoch)]:date:' \
      '--data-rootdir=[override repository root directory]:dir:_directories' \
      '--site-config-file=[site config file]:file:_files' \
      '--print-missing-files[print missing filenames to stderr]' \
      '--no-block-check[skip tape storage detection]' \
      '--no-file-names[suppress individual file pathnames]' \
      '--no-summary[suppress summary line]' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' && ret=0
    ;;

  rwaddrcount)
    # Count records (and byte/packet totals) per address.
    _arguments -s -S \
      $_silk_common \
      '--print-recs[print per-record summary]' \
      '--print-stat[print overall statistics line]' \
      '--print-ips[print IPs only (no counters)]' \
      '--use-dest[count by destination IP instead of source]' \
      '--min-bytes=[minimum byte count]:N:' \
      '--byte-min=[alias for --min-bytes]:N:' \
      '--min-packets=[minimum packet count]:N:' \
      '--min-records=[minimum record count]:N:' \
      '--max-bytes=[maximum byte count]:N:' \
      '--max-packets=[maximum packet count]:N:' \
      '--max-records=[maximum record count]:N:' \
      '--set-file=[write an IPset of matching addresses]:file:_files' \
      '--sort-ips[sort by IP rather than by count]' \
      '*:SiLK flow file:_files' && ret=0
    ;;

  rwrecgenerator)
    # Synthetic SiLK record generator (for testing and benchmarks).
    _arguments -s -S \
      $_silk_common \
      '--silk-output-path=[output SiLK file]:file:_files' \
      '--text-output-path=[output text file]:file:_files' \
      '--seed=[random seed]:N:' \
      '--num-recs=[number of records to generate]:N:' \
      '--start-time=[start timestamp]:time:' \
      '--end-time=[end timestamp]:time:' \
      '--sensor-prefix-map=[sensor prefix map]:file:_files' \
      '--time-step=[per-record time step]:duration:' \
      && ret=0
    ;;

esac

return ret
