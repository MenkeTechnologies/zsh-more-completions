#compdef unscd
# Micro name service caching daemon

local ret=1

_arguments -s -S \
  '-d[debug mode, stay in foreground]' \
  '-t[self-terminate after resolving]' \
  '-v[verbose output]' \
  '-i[invalidate cache]' \
  '-C[configuration file]:config file:_files' \
  '-h[show help]' && ret=0

return ret
