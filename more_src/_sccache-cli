#compdef sccache-cli
# _sccache-cli — Mozilla sccache shared cloud compilation cache CLI alias (Mozilla / sccache team, Rust); clap-rs
# upstream: https://github.com/mozilla/sccache

_sccache-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--show-stats[show statistics]' \
        '-s[show statistics]' \
        '--show-adv-stats[show advanced statistics]' \
        '-S[show advanced statistics]' \
        '--start-server[start server]' \
        '--stop-server[stop server]' \
        '--zero-stats[zero statistics]' \
        '-z[zero statistics]' \
        '--dist-auth=+[dist auth]:str:' \
        '--dist-status[show dist status]' \
        '--package-toolchain=+[package toolchain]:str:' \
        '--debug[debug logging]' \
        '--stats-format=+[stats format]:fmt:(text json)' \
        '--info-bug[print bug info]' \
        '--info[print info]' \
        '*:cmd:_command_names -e'
}

_sccache-cli "$@"
