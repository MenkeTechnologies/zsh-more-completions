#compdef sequelize

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'db\:migrate:run pending migrations'
  'db\:migrate\:schema\:timestamps\:add:update migration table to have timestamps'
  'db\:migrate\:status:list status of all migrations'
  'db\:migrate\:undo:revert most recent migration'
  'db\:migrate\:undo\:all:revert all migrations'
  'db\:seed:run specified seeder'
  'db\:seed\:undo:revert most recent seed'
  'db\:seed\:all:run all seeders'
  'db\:seed\:undo\:all:revert all seeds'
  'db\:create:create database from config'
  'db\:drop:drop database from config'
  'init:initialize project'
  'init\:config:initialize configuration'
  'init\:migrations:create migrations directory'
  'init\:models:create models directory'
  'init\:seeders:create seeders directory'
  'migration\:generate:generate a new migration file'
  'model\:generate:generate a model and migration'
  'seed\:generate:generate a new seed file'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--env=[environment]:environment:(development test staging production)' \
  '--config=[config file]:config:_files' \
  '--options-path=[options file]:file:_files' \
  '--migrations-path=[migrations directory]:directory:_directories' \
  '--seeders-path=[seeders directory]:directory:_directories' \
  '--models-path=[models directory]:directory:_directories' \
  '--url=[database URL]:url' \
  '--debug[show debug information]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sequelize command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (model:generate)
        _arguments \
          '--name=[model name]:name' \
          '--attributes=[model attributes]:attributes' \
          '--force[overwrite existing model]' \
          '--underscored[use snake_case column names]' && ret=0
        ;;
      (migration:generate|seed:generate)
        _arguments '--name=[migration/seed name]:name' && ret=0
        ;;
      (db:migrate:undo)
        _arguments '--name=[specific migration name]:migration name' && ret=0
        ;;
      (db:seed)
        _arguments '--seed=[specific seed name]:seed name' && ret=0
        ;;
      (db:migrate)
        _arguments '--to=[migration to run to]:migration name' && ret=0
        ;;
    esac
    ;;
esac

return ret
