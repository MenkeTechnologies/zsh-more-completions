#compdef mImgtbl
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mImgtbl.html
# Build an image metadata table from FITS files in a directory

local ret=1

_arguments -s -S \
  '-r[search directory and subdirectories recursively]' \
  '-c[add RA/Dec coordinates of image corners]' \
  '-a[include _area images normally excluded]' \
  '-d[enable debugging]' \
  '-b[output each invalid FITS file with error details]' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '-f+[file of additional FITS keywords to extract]:fieldlistfile:_files' \
  '-t+[process only files named in this table]:imglist:_files -g "*.tbl"' \
  '1:directory:_files -/' \
  '2:output table:_files -g "*.tbl"' && ret=0

return ret
