#compdef pal
# Documentation: https://palcal.sourceforge.net/
# Calendar program for Unix

_arguments -s -S \
  '-d[show events for a specific date]:date (yyyymmdd):' \
  '-r[show events for the next N days]:days:' \
  '-s[search for events matching a pattern]:pattern:' \
  '-c[use a different configuration file]:file:_files' \
  '-f[use a different calendar file]:file:_files' \
  '-m[show a specific month]:month:' \
  '--color[enable color output]' \
  '--nocolor[disable color output]' \
  '--mail[generate output suitable for email]' \
  '--html[generate HTML output]' \
  '--latex[generate LaTeX output]' \
  '-v[verbose output]' \
  '-h[show help]' \
  '--version[show version]' \
  && return 0
