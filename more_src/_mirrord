#compdef mirrord

# Zsh completion for mirrord - run local processes in k8s context

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'exec:execute a binary with mirrord'
      'ext:extension commands'
      'intproxy:start internal proxy'
      'ls:list available targets'
      'operator:manage mirrord operator'
      'verify-config:verify mirrord config file'
      'completions:generate shell completions'
      'diagnose:diagnose mirrord setup'
    )
    _describe -t commands 'mirrord command' commands && ret=0
    ;;
  args)
    case $line[1] in
      exec)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-t+[target to mirror]:target' \
          '--target=[target to mirror]:target' \
          '-n+[target namespace]:namespace' \
          '--target-namespace=[target namespace]:namespace' \
          '-c+[config file]:config:_files -g "*.{json,yaml,yml,toml}"' \
          '--config-file=[config file]:config:_files -g "*.{json,yaml,yml,toml}"' \
          '-f+[feature set]:feature:(network fs env)' \
          '--feature=[feature set]:feature:(network fs env)' \
          '-a[accept TLS certificates]' \
          '--accept-invalid-certificates[accept TLS certificates]' \
          '-e[override environment variables]' \
          '--override-env-vars-exclude=[exclude env vars]:vars' \
          '--override-env-vars-include=[include env vars]:vars' \
          '--fs-mode=[filesystem mode]:mode:(local read write)' \
          '--no-fs[disable filesystem mirroring]' \
          '--no-env[disable environment mirroring]' \
          '--no-remote-dns[disable remote DNS]' \
          '--no-telemetry[disable telemetry]' \
          '--steal[steal traffic instead of mirror]' \
          '-s[steal traffic instead of mirror]' \
          '*:command and arguments' && ret=0
        ;;
      ls)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-n+[namespace]:namespace' \
          '--namespace=[namespace]:namespace' && ret=0
        ;;
      verify-config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:config file:_files -g "*.{json,yaml,yml,toml}"' && ret=0
        ;;
    esac
    ;;
esac

return ret
