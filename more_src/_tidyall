#compdef tidyall
# Documentation: https://metacpan.org/dist/Code-TidyAll/view/bin/tidyall
# tidyall - your all-in-one code tidier and validator (Code::TidyAll)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message]' \
  '(-a --all)'{-a,--all}'[process all files recursively from root]' \
  '*'{-i,--ignore}'+[ignore matching files (zglob, repeatable)]:glob' \
  '(-g --git)'{-g,--git}'[process added/modified files in git working dir]' \
  '(-l --list)'{-l,--list}'[list files with matching plugins, do not process]' \
  '(-m --mode)'{-m,--mode}'+[mode affecting which plugins run]:mode' \
  '(-p --pipe)'{-p,--pipe}'+[read from STDIN, write to STDOUT]:path:_files' \
  '(-r --recursive)'{-r,--recursive}'[recursively process directories on command-line]' \
  '(-j --jobs)'{-j,--jobs}'+[number of parallel jobs]:jobs' \
  '(-s --svn)'{-s,--svn}'[process added/modified files in svn working dir]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output except errors]' \
  '(-v --verbose)'{-v,--verbose}'[show extra output]' \
  '*-I+[add library path to @INC]:dir:_files -/' \
  '--backup-ttl=[duration before backup purge]:ttl' \
  '--check-only[check if files are tidied without modifying]' \
  '--plugins=[run only specified plugins]:plugins' \
  '--conf-file=[path to configuration file]:file:_files' \
  '--conf-name=[configuration filename to search for]:name' \
  '--data-dir=[directory for backups and cache]:dir:_files -/' \
  '--iterations=[times to run each tidier]:n' \
  '--no-backups[skip file backups]' \
  '--no-cache[process all files every time]' \
  '--no-cleanup[do not clean up temporary files]' \
  '--output-suffix=[suffix for modified output files]:suffix' \
  '--refresh-cache[erase and rewrite cache info]' \
  '--root-dir=[specify root directory explicitly]:dir:_files -/' \
  '--tidyall-class=[subclass instead of Code::TidyAll]:class' \
  '--version[show Code::TidyAll version]' \
  '*:file:_files' && ret=0

return ret
