#compdef spiff

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'merge:merge YAML layouts with references'
      'lint:validate spiff++ templates'
      'version:print version'
    )
    _describe -t commands 'spiff command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      merge)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--partial[enable partial merges]' \
          '--stub=[stub file]:file:_files' \
          '1:template:file:_files' \
          '*:overlay files:_files' \
          && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
