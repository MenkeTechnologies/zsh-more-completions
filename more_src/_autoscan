#compdef autoscan
# Documentation: autoscan --help (GNU Autoconf)
# Source: scan a source tree and emit a preliminary configure.scan.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-v,--verbose}'[verbosely report processing]' \
    {-d,--debug}'[do not remove temporary files]' \
    '*'{-B+,--prepend-include=}'[prepend directory to search path]:dir:_files -/' \
    '*'{-I+,--include=}'[append directory to search path]:dir:_files -/' \
    ':source dir:_files -/' \
    && ret=0

return ret
