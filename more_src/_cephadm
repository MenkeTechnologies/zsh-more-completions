#compdef cephadm

# Zsh completion for cephadm - Ceph cluster orchestrator

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'bootstrap:bootstrap a new Ceph cluster'
  'shell:launch a shell in a container with ceph tools'
  'install:install cephadm and/or ceph packages'
  'adopt:adopt daemon previously not managed by cephadm'
  'rm-daemon:remove a daemon'
  'rm-cluster:remove all daemons for a cluster'
  'ls:list daemon instances on this host'
  'logs:print log for a daemon'
  'enter:run an interactive shell inside a daemon container'
  'pull:pull a container image'
  'inspect-image:inspect a container image'
  'check-host:check host prerequisites'
  'prepare-host:prepare a host for cephadm'
  'add-repo:configure package repository'
  'rm-repo:remove package repository'
  'ceph-volume:run ceph-volume inside a container'
  'unit:operate on the daemon systemd unit'
  'gather-facts:gather information about the host'
  'maintenance:manage host maintenance mode'
  'list-networks:list IP networks'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '--image=[container image]:image' \
  '--docker[use docker instead of podman]' \
  '--data-dir=[path to cephadm data directory]:path:_files -/' \
  '--log-dir=[path to log directory]:path:_files -/' \
  '--logrotate-dir=[path to logrotate.d directory]:path:_files -/' \
  '--sysctl-dir=[path to sysctl.d directory]:path:_files -/' \
  '--unit-dir=[path to systemd unit directory]:path:_files -/' \
  '--verbose[show debug-level log messages]' \
  '--timeout=[timeout in seconds]:seconds' \
  '--retry=[max number of retries]:retries' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cephadm command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (bootstrap)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--mon-ip=[MON IP address]:IP address' \
          '--mon-addrv=[MON address vector]:address' \
          '--mon-id=[MON id]:id' \
          '--mgr-id=[MGR id]:id' \
          '--fsid=[cluster FSID]:fsid' \
          '--output-dir=[directory to write config and keyring]:dir:_files -/' \
          '--output-keyring=[keyring file]:file:_files' \
          '--output-config=[config file]:file:_files' \
          '--output-pub-ssh-key=[public SSH key file]:file:_files' \
          '--skip-mon-network[do not set mon_network]' \
          '--skip-dashboard[do not enable dashboard]' \
          '--dashboard-password-noupdate[do not update dashboard password]' \
          '--initial-dashboard-user=[initial dashboard admin user]:user' \
          '--initial-dashboard-password=[initial dashboard admin password]:password' \
          '--ssl-dashboard-port=[dashboard HTTPS port]:port' \
          '--dashboard-key=[SSL key for dashboard]:file:_files' \
          '--dashboard-crt=[SSL cert for dashboard]:file:_files' \
          '--ssh-config=[SSH config file]:file:_files' \
          '--ssh-private-key=[SSH private key]:file:_files' \
          '--ssh-public-key=[SSH public key]:file:_files' \
          '--ssh-user=[SSH user]:user' \
          '--skip-ssh[skip SSH key setup]' \
          '--skip-firewalld[do not configure firewalld]' \
          '--allow-overwrite[overwrite existing output files]' \
          '--allow-fqdn-hostname[allow FQDN as hostname]' \
          '--allow-mismatched-release[allow mismatched release]' \
          '--skip-pull[do not pull container image]' \
          '--single-host-defaults[adjust defaults for single-host cluster]' \
          '--cluster-network=[cluster network subnet]:subnet' && ret=0
        ;;
      (shell)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--fsid=[cluster FSID]:fsid' \
          '--name=[daemon name (type.id)]:name' \
          '--config=[ceph.conf file]:file:_files' \
          '--keyring=[ceph.keyring file]:file:_files' \
          '--mount=[directory to mount]:dir:_files -/' \
          '--env=[environment variable]:VAR=VALUE' \
          '*:command' && ret=0
        ;;
      (ls)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--no-detail[do not show detailed info]' && ret=0
        ;;
      (logs)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--fsid=[cluster FSID]:fsid' \
          '--name=[daemon name]:name' && ret=0
        ;;
      (rm-daemon)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--name=[daemon name]:name' \
          '--fsid=[cluster FSID]:fsid' \
          '--force[proceed even if daemon is running]' \
          '--force-delete-data[delete daemon data]' && ret=0
        ;;
      (rm-cluster)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--fsid=[cluster FSID]:fsid' \
          '--force[proceed without prompting]' \
          '--keep-logs[do not remove log files]' \
          '--zap-osds[zap OSD devices]' && ret=0
        ;;
      (check-host|prepare-host|gather-facts|list-networks)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (adopt)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--name=[daemon name]:name' \
          '--style=[daemon style]:style:(legacy)' \
          '--cluster=[cluster name]:name' \
          '--skip-pull[do not pull container image]' && ret=0
        ;;
      (pull|inspect-image)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (install)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:packages' && ret=0
        ;;
    esac
    ;;
esac

return ret
