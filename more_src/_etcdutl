#compdef etcdutl

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'backup:make a backup of an etcd data directory'
      'defrag:defragment an etcd data directory'
      'snapshot:manage etcd snapshots'
      'completion:generate shell completion script'
      'migrate:migrate etcd data'
    )
    _describe -t commands 'etcdutl command' commands && ret=0
    ;;
  args)
    case $line[1] in
      backup)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--data-dir=[path to etcd data directory]:directory:_directories' \
          '--backup-dir=[path to the backup directory]:directory:_directories' \
          '--wal-dir=[path to the WAL directory]:directory:_directories' \
          '--backup-wal-dir=[path to the backup WAL directory]:directory:_directories' \
          '--with-v3[backup v3 data]' && ret=0
        ;;
      defrag)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--data-dir=[path to etcd data directory]:directory:_directories' && ret=0
        ;;
      snapshot)
        local -a snap_commands=(
          'restore:restore an etcd snapshot'
          'status:show snapshot status'
        )
        _describe -t commands 'snapshot command' snap_commands && ret=0
        ;;
      migrate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--data-dir=[path to etcd data directory]:directory:_directories' \
          '--target-version=[target etcd version]:version:' \
          '--force[force migration]' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
