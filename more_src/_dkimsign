#compdef dkimsign dkimsign.pl
# Documentation: https://github.com/fastmail/mail-dkim/blob/master/scripts/dkimsign.pl
# sign an email message with a DKIM/DomainKeys signature

local ret=1

_arguments -s -S \
  '(--help --?)'{--help,--\?}'[show help]' \
  '--type=[signature type (dkim or domainkeys)]:type:(dkim domainkeys)' \
  '--algorithm=[signing algorithm]:algorithm:(rsa-sha1 rsa-sha256 ed25519-sha256)' \
  '--method=[canonicalization method]:method:(simple relaxed)' \
  '--selector=[selector for the signature]:selector' \
  '--domain=[domain to sign for]:domain' \
  '--expiration=[expiration time]:seconds' \
  '--identity=[signing identity]:identity' \
  '--key=[private key file]:file:_files' \
  '--key-protocol=[key protocol]:protocol' \
  '--debug-canonicalization=[write canonicalized message to file]:file:_files' \
  '*--extra-tag=[add an extra signature tag]:tag' \
  '--timestamp=[signature timestamp]:time' \
  '--binary[treat input as binary]' \
  '*:mail file:_files' && ret=0

return ret
