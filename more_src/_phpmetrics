#compdef phpmetrics

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--report-html=[generate HTML report]:directory:_directories' \
  '--report-csv=[generate CSV report]:file:_files -g "*.csv"' \
  '--report-json=[generate JSON report]:file:_files -g "*.json"' \
  '--report-violations=[generate violations report]:file:_files' \
  '--config=[configuration file]:file:_files -g "*.(yml|yaml|json)"' \
  '--extensions=[file extensions to parse]:extensions' \
  '--exclude=[exclude patterns]:patterns' \
  '--plugins=[enable plugins]:plugins' \
  '--git[enable git analysis]' \
  '--junit=[JUnit log file for unit testing]:file:_files -g "*.xml"' \
  '--composer=[composer.json file]:file:_files -g "*.json"' \
  '--quiet[suppress output]' \
  '-q[suppress output]' \
  '-v[verbose mode]' \
  '--offline[offline mode, no external resources]' \
  '*:source directory:_files -/' && ret=0

return ret
