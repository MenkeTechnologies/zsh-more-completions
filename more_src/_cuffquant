#compdef cuffquant
# Documentation: https://man.archlinux.org/search?q=cuffquant
# Reference accessed: 2026-05-16

# Cuffquant: pre-compute fragment counts for Cuffdiff/Cuffnorm
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '-h[help]' \
  '(-o --output-dir)'{-o,--output-dir=}'[output directory]:dir:_files -/' \
  '(-p --num-threads)'{-p,--num-threads=}'[threads]:n:' \
  '(-M --mask-file)'{-M,--mask-file=}'[mask GTF]:file:_files' \
  '(-b --frag-bias-correct)'{-b,--frag-bias-correct=}'[bias correction FASTA]:file:_files' \
  '(-u --multi-read-correct)'{-u,--multi-read-correct}'[multi-read correction]' \
  '--library-type=[library type]:type:(ff-firststrand ff-secondstrand ff-unstranded fr-unstranded fr-firststrand fr-secondstrand transfrags)' \
  '--max-frag-multihits=[max multihits]:n:' \
  '--no-update-check[skip update check]' \
  '*:GTF and BAM files:_files' && ret=0
return ret
