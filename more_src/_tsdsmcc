#compdef tsdsmcc
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tsdsmcc.cpp
# tsdsmcc - extract DSM-CC object carousel content from a transport stream

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:ts file:_files -g "*.ts *.m2ts *.mpg"' && ret=0

return ret
