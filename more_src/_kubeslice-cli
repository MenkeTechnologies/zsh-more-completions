#compdef kubeslice-cli
# Documentation: https://kubeslice.io/documentation/open-source/1.0.0/install-kubeslice/kubeslice-cli/command-reference/
# KubeSlice CLI - install and manage KubeSlice multi-cluster slices

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[path to the topology configuration file]:file:_files' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'install:install the KubeSlice controller and worker components'
      'uninstall:uninstall the KubeSlice components'
      'create:create a KubeSlice resource (project, sliceConfig, serviceExportConfig)'
      'delete:delete a KubeSlice resource'
      'register:register a new worker cluster with the controller'
      'get:get a KubeSlice resource'
      'describe:describe a KubeSlice resource'
      'edit:edit a KubeSlice resource'
      'help:help about any command'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (install)
        _arguments -s -S \
          '--profile=[demo profile (minimal-demo|full-demo|enterprise-demo)]:profile:(minimal-demo full-demo enterprise-demo)' \
          '--config=[path to the topology configuration file]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (uninstall)
        _arguments -s -S \
          '--config=[path to the topology configuration file]:file:_files' \
          '--all[uninstall all KubeSlice components]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (create|delete|get|describe|edit)
        _arguments -s -S \
          '--namespace=[project namespace]:namespace' \
          '--filename=[path to the configuration yaml]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:resource:(project sliceConfig serviceExportConfig)' && ret=0
        ;;
      (register)
        _arguments -s -S \
          '--namespace=[project namespace]:namespace' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:resource:(worker)' && ret=0
        ;;
    esac
    ;;
esac

return ret
