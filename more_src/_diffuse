#compdef diffuse
# Documentation: https://manpages.debian.org/bookworm/diffuse/diffuse.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-h --help -?)'{-h,--help,-\?}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--no-rcfile[skip init files]' \
  '--rcfile=[init file]:file:_files' \
  '(-c --commit)'{-c,--commit}'=[revision]:rev:' \
  '(-D --close-if-same)'{-D,--close-if-same}'[close if same]' \
  '(-e --encoding)'{-e,--encoding}'=[codec]:codec:' \
  '(-L --label)'{-L,--label}'=[label]:label:' \
  '(-m --modified)'{-m,--modified}'[all modified]' \
  '(-r --revision)'{-r,--revision}'=[revision]:rev:' \
  '(-s --separate)'{-s,--separate}'[separate tabs]' \
  '(-t --tab)'{-t,--tab}'[new tab]' \
  '(-V --vcs)'{-V,--vcs}'=[VCS list]:list:' \
  '--line=[line]:n:' \
  '--null-file[blank pane]' \
  '(-b --ignore-space-change)'{-b,--ignore-space-change}'[ignore space change]' \
  '(-B --ignore-blank-lines)'{-B,--ignore-blank-lines}'[ignore blank lines]' \
  '(-E --ignore-end-of-line)'{-E,--ignore-end-of-line}'[ignore EOL]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[ignore case]' \
  '(-w --ignore-all-space)'{-w,--ignore-all-space}'[ignore whitespace]' \
  '*:file:_files'
