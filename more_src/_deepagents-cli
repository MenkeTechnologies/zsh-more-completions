#compdef deepagents-cli
# Documentation: https://github.com/langchain-ai/deepagents
# Reference accessed: 2026-05-23
# Verified: npx deepagents-cli help (interactive agent CLI).

# Zsh completion for deepagents-cli - LangChain Deep Agents terminal CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--agent[agent identifier]:name:' \
  '--model[LLM model ID]:model:' \
  '--auto-approve[auto-approve tool usage]' \
  '--sandbox[remote sandbox type]:type:(none modal daytona runloop)' \
  '--sandbox-id[reuse existing sandbox]:id:' \
  '--sandbox-setup[sandbox setup command]:cmd:' \
  '--no-splash[disable splash screen]' \
  '1:command:->cmds' \
  '*:prompt:' && ret=0

case $state in
  cmds)
    _values 'deepagents command' \
      'list[list available agents]' \
      'reset[reset agent to default prompt]' \
      'skills[manage agent skills]' \
      'help[show help]' && ret=0
    ;;
esac

return ret
