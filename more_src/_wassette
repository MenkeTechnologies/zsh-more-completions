#compdef wassette
# =============================================================================
# wassette — microsoft/wassette's SECURITY-
#   ORIENTED Rust runtime that loads WebAssembly
#   COMPONENTS (not classic Wasm modules — the
#   newer WASI Preview 2 Component Model) and
#   exposes their exported interfaces as
#   MCP tools to AI agents.  Each loaded
#   component runs inside a Wasmtime sandbox
#   with explicit, agent-grantable capabilities
#   (filesystem / network / environment-
#   variable / memory).  Built on direct
#   `wasmtime 36.0.5` + `wasmtime-wasi 36.0.5`
#   + `wasmtime-wasi-http 36.0.5` +
#   `wasmtime-wasi-config 36.0.5` (the
#   BytecodeAlliance's canonical Rust WASM
#   runtime).  Rust=104 leader bump opening
#   Axis 49.
#
# AXIS 49 — WEBASSEMBLY RUNTIME — OPENS @ R785
# =============================================
# Establishes a new three-language axis covering
# CLI tools written in language X that ship a
# DIRECT library binding to a WebAssembly
# runtime.  Canonical implementations per
# language:
#   * Rust       : wasmtime (this entry)
#                  — BytecodeAlliance reference
#                    Wasm runtime with Cranelift
#                    JIT, WASI Preview 1+2,
#                    Component Model support,
#                    fuel + epoch-based
#                    interruption, pooling
#                    allocator
#                  — version 36.0.5 used here
#                  — direct dep at
#                    `microsoft/wassette`
#                    Cargo.toml line:
#                    `wasmtime = "36.0.5"`
#   * Go         : wazero — Tetrate's pure-Go
#                  Wasm runtime, zero-CGO,
#                  embedded interpreter +
#                  optimizing compiler.  R786
#                  will close the Go side
#   * TS-Node    : @bytecodealliance/preview2-
#                  shim or @bytecodealliance/
#                  jco — Component Model
#                  bindgen + WASI shims for
#                  Node.  R787 will close the
#                  TS-Node side
#
# Distinguishing the Component Model from
# classic core Wasm:
#   - CORE WASM (MVP / WASI Preview 1)        runs
#                                             single
#                                             flat
#                                             linear-
#                                             memory
#                                             modules
#                                             with
#                                             primitive-
#                                             only ABIs
#                                             (i32/i64/
#                                             f32/f64).
#                                             Used by
#                                             traditional
#                                             wasmtime/
#                                             wasmer
#                                             CLIs
#   - COMPONENT MODEL (WASI Preview 2)       wraps
#                                             core
#                                             modules
#                                             in a
#                                             type-
#                                             rich
#                                             interface
#                                             type
#                                             layer
#                                             with
#                                             records,
#                                             variants,
#                                             resources,
#                                             futures,
#                                             streams.
#                                             Wassette
#                                             ONLY
#                                             loads
#                                             Components
#                                             (it
#                                             does not
#                                             accept
#                                             plain
#                                             .wasm
#                                             modules)
#
# Distinguishing wassette from other corpus
# wasmtime-using tools (e.g. Shopify/function-
# runner, dphilla/boxer, exoticorn/microw8,
# microsoft/aici):
#   - MCP SERVER FRONTEND — `wassette run`
#     speaks the Model Context Protocol (MCP)
#     v2024-11-05 over stdio; `wassette serve
#     --sse` or `--streamable-http` exposes
#     the same surface over SSE / HTTP.
#     Each loaded Wasm Component becomes a
#     set of MCP tools that AI agents
#     (Claude Code, Cursor, Copilot, Gemini
#     CLI) can discover and invoke
#   - CAPABILITY-FIRST PERMISSION SYSTEM —
#     no ambient authority.  Components
#     start with ZERO capabilities and must
#     be explicitly granted access via
#     `wassette permission grant
#     {storage|network|environment-variable|
#     memory}`.  Even `fs://` filesystem
#     grants are scoped to specific paths
#     with read/write/read,write modes.
#     Network grants are per-host.  No
#     wildcard `--allow-all` flag
#   - OCI REGISTRY DISTRIBUTION — components
#     are pulled from container registries
#     using `oci://` URIs (e.g.
#     `oci://ghcr.io/microsoft/time-server-
#     js:latest`).  Direct deps on
#     `oci-client 0.16` + `oci-wasm 0.4`.
#     Distinguishes from boxer / function-
#     runner which load from local files
#   - SECRET STORE BUILT-IN — `wassette
#     secret set <component> KEY=VAL` writes
#     to per-component secret storage.
#     `--show-values` requires interactive
#     confirmation.  Secrets are NEVER
#     visible to the component unless
#     explicitly bound via environment-
#     variable permission
#   - XDG DIRS — components default to
#     `$XDG_DATA_HOME/wassette/components`
#     (e.g. `~/.local/share/wassette/
#     components` on Linux).  Override
#     globally with `--component-dir` or
#     per-command flag.  Direct dep on
#     `etcetera 0.11` for XDG resolution
#   - HOT RELOAD via BACKGROUND LOADER —
#     `wassette run` starts the MCP server
#     immediately + spawns a background
#     task that loads components from the
#     component directory.  New components
#     discovered later are auto-registered
#     and clients are notified via
#     `notify_tool_list_changed()`
#   - WASMTIME 36.0.5 SECURITY POSTURE —
#     uses Cranelift JIT with Spectre +
#     pooling-allocator hardening.
#     Default sandbox blocks all syscalls
#     not explicitly permitted by WASI
#     Preview 2 interfaces.  Browser-grade
#     isolation per upstream Wasmtime
#     security policy
#   - HTTP TRANSPORTS — `serve --sse`
#     uses SSE (the original MCP transport)
#     for legacy client compatibility.
#     `serve --streamable-http` uses the
#     newer Streamable HTTP transport with
#     resumable streams.  Bind address
#     defaults to `127.0.0.1:9001`
#
# WHEN TO USE WASSETTE vs WASMTIME (the CLI)
# vs aici / boxer / function-runner:
#   - `wasmtime <module.wasm>` — run a single
#     core Wasm module with command-line
#     args + stdin/stdout.  No persistence,
#     no permission grants, no MCP
#   - `wassette` — MCP server hosting MANY
#     components, each with persistent
#     capability grants + secrets + OCI
#     registry distribution.  AI-agent-
#     facing
#   - aici (microsoft/aici) — Wasm runtime
#     for INSIDE-LLM-INFERENCE control
#     (token-level constraints encoded as
#     Wasm controllers).  Different
#     embedding layer
#   - dphilla/boxer — Dockerfile -> single
#     Wasm Component compiler.  Build-time
#     tool not a runtime
#   - Shopify/function-runner — single-shot
#     Wasm function runner for Shopify
#     Functions.  No registry, no
#     permissions UI
#
# TOP-LEVEL SUBCOMMAND SURFACE (from
# `src/commands.rs`):
#   * run             start local MCP server
#                     over stdio (for
#                     direct-spawn integration
#                     with Cursor / Claude
#                     Code / Copilot)
#   * serve           start remote MCP server
#                     over HTTP (--sse or
#                     --streamable-http)
#   * component       {load,unload,list} Wasm
#                     Components from file:// /
#                     oci:// URIs
#   * policy          {get} component policy
#                     (the rendered current
#                     permission set)
#   * permission      grant / revoke / reset
#                     storage + network +
#                     environment-variable +
#                     memory capabilities
#   * secret          list / set / delete
#                     per-component secret
#                     values (with --show-
#                     values confirmation
#                     guard)
#   * inspect         dump a component's
#                     JSON schema (interfaces
#                     + types) for debugging
#   * tool            list / read / invoke
#                     MCP tools exposed by
#                     loaded components
#   * registry        {search,get} discover
#                     + pull components from
#                     OCI registries
#   * autocomplete    emit shell completion
#                     scripts (bash, zsh,
#                     fish, powershell,
#                     elvish)
#
# CRITICAL DIRECT DEPENDENCIES (from
# top-level Cargo.toml `[workspace.dependencies]`):
#   - wasmtime 36.0.5          — Wasm runtime
#                                [AXIS 49 LIBRARY]
#   - wasmtime-wasi 36.0.5     — WASI Preview 2
#                                shim
#   - wasmtime-wasi-http 36.0.5
#                              — wasi:http
#                                world impl
#   - wasmtime-wasi-config 36.0.5
#                              — wasi:config
#                                key/value
#                                interface
#   - rmcp 0.9.1               — Rust MCP
#                                server SDK
#                                (with server +
#                                transport-sse-
#                                server +
#                                transport-
#                                streamable-
#                                http-server +
#                                transport-io +
#                                macros features)
#   - mcp-sdk 0.0.3            — additional
#                                MCP types
#   - oci-client 0.16          — OCI registry
#                                pull client
#   - oci-wasm 0.4             — OCI artifact-
#                                type adapter
#                                for Wasm
#   - axum 0.8                 — HTTP server
#                                for SSE +
#                                streamable-http
#                                transports
#   - clap 4.5 (derive)        — CLI parser
#   - clap_complete 4.5        — shell
#                                completion
#                                generation
#                                (powers
#                                `wassette
#                                autocomplete`)
#   - figment 0.10 (env+toml)  — layered
#                                configuration
#                                loader
#   - etcetera 0.11            — XDG / Known
#                                Folders dir
#                                resolution
#   - tokio 1.49 (full)        — async runtime
#   - reqwest 0.13 (stream)    — HTTP client
#                                (OCI manifest
#                                + blob pulls)
#   - tracing 0.1 + tracing-   — structured
#     subscriber 0.3            logging
#                                (with env-
#                                filter)
#
# Rust 1.81+ MSRV per Cargo.lock + Cranelift
# requirements.
#
# UPSTREAM:
#   * Source             : https://github.com/microsoft/wassette
#   * Docs               : https://microsoft.github.io/wassette/latest/
#   * Wasmtime           : https://github.com/bytecodealliance/wasmtime
#   * Component Model    : https://github.com/WebAssembly/component-model
#   * MCP spec           : https://modelcontextprotocol.io
#   * License            : MIT
#   * Maintainer         : Microsoft Open Source
#
# INSTALL:
#   # Linux / macOS one-liner
#   curl -fsSL https://raw.githubusercontent.com/microsoft/wassette/main/install.sh | bash
#
#   # Homebrew (per upstream Formula/)
#   brew install microsoft/wassette/wassette
#
#   # Cargo
#   cargo install --git https://github.com/microsoft/wassette
#
#   # Docker
#   docker pull ghcr.io/microsoft/wassette:latest
#
# USAGE EXAMPLES:
#
#   # Print version + build info
#   wassette -V
#   wassette --version
#
#   # Start local stdio MCP server (for direct
#   # AI-agent spawn integration)
#   wassette run
#
#   # Start local stdio with an env-file
#   wassette run --env-file .env
#
#   # Start local stdio with inline env vars
#   wassette run --env API_KEY=sk-... --env DEBUG=1
#
#   # Start remote SSE MCP server
#   wassette serve --sse
#
#   # Start remote Streamable HTTP MCP server
#   # on a custom bind address
#   wassette serve --streamable-http \
#       --bind-address 0.0.0.0:9001
#
#   # Headless deployment with a provisioning
#   # manifest (auto-load components on boot)
#   wassette serve --streamable-http \
#       --manifest manifest.yaml
#
#   # Load a component from a file
#   wassette component load \
#       file:///opt/components/time.wasm
#
#   # Load a component from an OCI registry
#   wassette component load \
#       oci://ghcr.io/microsoft/time-server-js:latest
#
#   # List loaded components
#   wassette component list
#   wassette component list -o yaml
#
#   # Unload a component
#   wassette component unload time-server-js
#
#   # Grant storage permission (read+write)
#   wassette permission grant storage time-server-js \
#       fs:///tmp/cache --access read,write
#
#   # Grant network permission to a single host
#   wassette permission grant network time-server-js \
#       api.example.com
#
#   # Grant access to an environment variable
#   wassette permission grant environment-variable \
#       time-server-js OPENAI_API_KEY
#
#   # Set a memory limit
#   wassette permission grant memory time-server-js 512Mi
#
#   # Revoke network permission
#   wassette permission revoke network time-server-js \
#       api.example.com
#
#   # Reset all permissions for a component
#   wassette permission reset time-server-js
#
#   # Get the rendered policy for a component
#   wassette policy get time-server-js
#
#   # List, set, delete secrets
#   wassette secret list time-server-js
#   wassette secret list time-server-js --show-values --yes
#   wassette secret set time-server-js TOKEN=abc123
#   wassette secret delete time-server-js TOKEN
#
#   # List + read + invoke MCP tools
#   wassette tool list
#   wassette tool read get_current_time
#   wassette tool invoke get_current_time \
#       --args '{"timezone":"UTC"}'
#
#   # Search + fetch components from the
#   # registry
#   wassette registry search "time"
#   wassette registry get \
#       oci://ghcr.io/microsoft/time-server-js:latest
#
#   # Inspect a loaded component's JSON schema
#   wassette inspect time-server-js
#
#   # Emit zsh completion script
#   wassette autocomplete zsh > _wassette
#
# OPTIONS (sourced directly from
# https://github.com/microsoft/wassette/blob/main/src/commands.rs):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _wassette_commands
_wassette_commands=(
    'run:Run locally with stdio transport (for local development and testing)'
    'serve:Serve remotely over HTTP transports (SSE or StreamableHttp)'
    'component:Manage WebAssembly components (load/unload/list)'
    'policy:Manage component policies (get)'
    'permission:Manage component permissions (grant/revoke/reset)'
    'secret:Manage component secrets (list/set/delete)'
    'inspect:Inspect a WebAssembly component and display its JSON schema'
    'tool:Manage tools (list/read/invoke)'
    'registry:Search and fetch components from the registry (search/get)'
    'autocomplete:Generate shell completion scripts'
    'help:Print help for a subcommand'
)

local -a _wassette_component_actions
_wassette_component_actions=(
    'load:Load a WebAssembly component from a file path or OCI registry'
    'unload:Unload a WebAssembly component'
    'list:List all loaded components'
)

local -a _wassette_policy_actions
_wassette_policy_actions=(
    'get:Get policy information for a component'
)

local -a _wassette_permission_actions
_wassette_permission_actions=(
    'grant:Grant permissions to a component'
    'revoke:Revoke permissions from a component'
    'reset:Reset all permissions for a component'
)

local -a _wassette_perm_grant_kinds
_wassette_perm_grant_kinds=(
    'storage:Grant storage permission (fs:// URI + --access read/write)'
    'network:Grant network permission to a specific host'
    'environment-variable:Grant access to an environment variable key'
    'memory:Grant a memory limit (e.g. 512Mi, 1Gi)'
)

local -a _wassette_perm_revoke_kinds
_wassette_perm_revoke_kinds=(
    'storage:Revoke storage permission'
    'network:Revoke network permission'
    'environment-variable:Revoke environment variable permission'
)

local -a _wassette_secret_actions
_wassette_secret_actions=(
    'list:List secrets for a component'
    'set:Set secrets for a component (KEY=VALUE)'
    'delete:Delete secrets for a component'
)

local -a _wassette_tool_actions
_wassette_tool_actions=(
    'list:List all available tools'
    'read:Read details of a specific tool'
    'invoke:Invoke a tool with parameters'
)

local -a _wassette_registry_actions
_wassette_registry_actions=(
    'search:Search for components in the registry'
    'get:Fetch and load a component from the registry'
)

local -a _wassette_autocomplete_shells
_wassette_autocomplete_shells=(
    'bash:Bash shell'
    'zsh:Zsh shell'
    'fish:Fish shell'
    'powershell:PowerShell'
    'elvish:Elvish shell'
)

local -a _wassette_output_formats
_wassette_output_formats=(
    'json:JSON output (default)'
    'yaml:YAML output'
    'table:Human-readable table'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version + build info]' \
    '--component-dir=[directory where components are stored (default $XDG_DATA_HOME/wassette/components)]:dir:_files -/' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'wassette command' _wassette_commands && ret=0
        ;;
    args)
        case $line[1] in
            run)
                _arguments -C \
                    '--component-dir=[directory where components are stored]:dir:_files -/' \
                    '*--env=[set an environment variable (KEY=VALUE)]:KEY=VALUE: ' \
                    '--env-file=[load environment variables from a file]:file:_files -g "*.(env|envrc)"' \
                    '--disable-builtin-tools[disable built-in tools (load/unload/list/etc)]' \
                    && ret=0
                ;;
            serve)
                _arguments -C \
                    '--component-dir=[directory where components are stored]:dir:_files -/' \
                    '(--sse --streamable-http)--sse[serve with SSE transport]' \
                    '(--sse --streamable-http)--streamable-http[serve with Streamable HTTP transport]' \
                    '*--env=[set an environment variable (KEY=VALUE)]:KEY=VALUE: ' \
                    '--env-file=[load environment variables from a file]:file:_files -g "*.(env|envrc)"' \
                    '--disable-builtin-tools[disable built-in tools]' \
                    '--bind-address=[bind address for HTTP transports (default 127.0.0.1:9001)]:host:port: ' \
                    '--manifest=[provisioning manifest for headless deployment mode]:file:_files -g "*.(yaml|yml|toml)"' \
                    && ret=0
                ;;
            component)
                _arguments -C \
                    '(-): :->compaction' \
                    '(-)*:: :->compargs' \
                    && ret=0
                case $state in
                    compaction)
                        _describe -t actions 'wassette component action' _wassette_component_actions && ret=0 ;;
                    compargs)
                        case $line[1] in
                            load)
                                _arguments \
                                    '--component-dir=[components directory]:dir:_files -/' \
                                    '1:component path (file:// or oci://):' \
                                    && ret=0 ;;
                            unload)
                                _arguments \
                                    '--component-dir=[components directory]:dir:_files -/' \
                                    '1:component id:' \
                                    && ret=0 ;;
                            list)
                                _arguments \
                                    '--component-dir=[components directory]:dir:_files -/' \
                                    '(-o --output-format)'{-o+,--output-format=}'[output format]:format:->outfmt' \
                                    && ret=0 ;;
                        esac
                        ;;
                esac
                ;;
            policy)
                _arguments -C \
                    '1:action:(get)' \
                    '*:: :->polargs' \
                    && ret=0
                ;;
            permission)
                _arguments -C \
                    '(-): :->permaction' \
                    '(-)*:: :->permargs' \
                    && ret=0
                case $state in
                    permaction)
                        _describe -t actions 'wassette permission action' _wassette_permission_actions && ret=0 ;;
                    permargs)
                        case $line[1] in
                            grant)
                                _arguments -C \
                                    '(-): :->grantkind' \
                                    '(-)*:: :->grantargs' \
                                    && ret=0
                                case $state in
                                    grantkind)
                                        _describe -t kinds 'permission grant kind' _wassette_perm_grant_kinds && ret=0 ;;
                                esac
                                ;;
                            revoke)
                                _arguments -C \
                                    '(-): :->revokekind' \
                                    && ret=0
                                case $state in
                                    revokekind)
                                        _describe -t kinds 'permission revoke kind' _wassette_perm_revoke_kinds && ret=0 ;;
                                esac
                                ;;
                            reset)
                                _arguments \
                                    '--component-dir=[components directory]:dir:_files -/' \
                                    '1:component id:' \
                                    && ret=0 ;;
                        esac
                        ;;
                esac
                ;;
            secret)
                _arguments -C \
                    '1:action:->secretaction' \
                    && ret=0
                case $state in
                    secretaction)
                        _describe -t actions 'wassette secret action' _wassette_secret_actions && ret=0 ;;
                esac
                ;;
            tool)
                _arguments -C \
                    '1:action:->toolaction' \
                    && ret=0
                case $state in
                    toolaction)
                        _describe -t actions 'wassette tool action' _wassette_tool_actions && ret=0 ;;
                esac
                ;;
            registry)
                _arguments -C \
                    '1:action:->regaction' \
                    && ret=0
                case $state in
                    regaction)
                        _describe -t actions 'wassette registry action' _wassette_registry_actions && ret=0 ;;
                esac
                ;;
            inspect)
                _arguments \
                    '--component-dir=[components directory]:dir:_files -/' \
                    '1:component id:' \
                    && ret=0
                ;;
            autocomplete)
                _arguments -C \
                    '1:shell:->shell' \
                    && ret=0
                case $state in
                    shell)
                        _describe -t shells 'shell' _wassette_autocomplete_shells && ret=0 ;;
                esac
                ;;
        esac
        ;;
    outfmt)
        _describe -t formats 'output format' _wassette_output_formats && ret=0
        ;;
esac

return ret
