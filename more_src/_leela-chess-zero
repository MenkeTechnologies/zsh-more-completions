#compdef leela-chess-zero lc0
# Documentation: https://github.com/LeelaChessZero/lc0/blob/master/FLAGS.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Leela Chess Zero (lc0): UCI chess engine; also has CLI subcommands
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'selfplay:play games with itself'
  'benchmark:quick benchmark'
  'bench:very quick benchmark'
  'backendbench:benchmark only the backend'
  'leela2onnx:convert Leela network to ONNX'
  'onnx2leela:convert ONNX network to Leela'
  'describenet:show details about a Leela network'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)--show-hidden[also show hidden options in help]' \
  '(- *)-v[print version]' \
  '(-w --weights)'{-w,--weights=}'[network weights file]:weights:_files' \
  '(-b --backend)'{-b,--backend=}'[neural network backend]:backend:(cuda cuda-fp16 cudnn cudnn-fp16 onnx-cuda onnx-dml onnx-trt eigen blas opencl trivial random check multiplexing demux roundrobin)' \
  '--backend-opts=[backend-specific options]:opts:' \
  '(-t --threads)'{-t,--threads=}'[number of search threads]:threads:' \
  '--minibatch-size=[batch size for NN evaluation]:size:' \
  '--max-prefetch=[max prefetch positions]:n:' \
  '--cpuct=[CPUCT exploration constant]:value:' \
  '--temperature=[move-selection temperature]:value:' \
  '--temp-decay-moves=[temperature decay in N moves]:moves:' \
  '(-n --noise)'{-n,--noise}'[add Dirichlet exploration noise]' \
  '--verbose-move-stats[print detailed per-move stats]' \
  '--syzygy-paths=[Syzygy tablebases path]:paths:_files -/' \
  '--logfile=[engine log file]:file:_files' \
  '--config=[load config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'lc0 command' commands && ret=0 ;;
esac

return ret
