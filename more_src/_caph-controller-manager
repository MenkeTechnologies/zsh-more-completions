#compdef caph-controller-manager
# _caph-controller-manager — Cluster API Hetzner provider controller manager (CAPH)
# upstream: https://github.com/syself/cluster-api-provider-hetzner
# Flags from main.go (pflag) on tip.

_caph-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics bind address]:host\:port:' \
        '--health-probe-bind-address=[health probe bind address]:host\:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-namespace=[leader-election lease namespace]:ns:' \
        '--disable-csr-approval[disable workload-cluster CSR auto-approval]' \
        '--watch-filter=[watch-filter label value]:value:' \
        '--namespace=[restrict CAPH to a single namespace]:ns:' \
        '--hetznercluster-concurrency=[HetznerCluster concurrent reconciles]:n:' \
        '--hcloudmachine-concurrency=[HCloudMachine concurrent reconciles]:n:' \
        '--hetznerbaremetalmachine-concurrency=[HetznerBareMetalMachine concurrent reconciles]:n:' \
        '--hetznerbaremetalhost-concurrency=[HetznerBareMetalHost concurrent reconciles]:n:' \
        '--log-level=[log level]:level:(debug info error)' \
        '--sync-period=[informer resync period]:dur:' \
        '--rate-limit=[HCloud client rate-limit window]:dur:' \
        '--debug-hcloud-api-calls[log all HCloud API calls]' \
        '--pre-provision-command=[rescue-system health check command path]:path:_files' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_caph-controller-manager "$@"
