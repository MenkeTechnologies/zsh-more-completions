#compdef imageworsener imagew
# Documentation: https://man.archlinux.org/search?q=imageworsener
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-w+[width pixels]:px:' \
  '-h+[height pixels]:px:' \
  '-quiet[quiet]' \
  '-noinfo[no info]' \
  '-version[show version]' \
  '-noopt[no optimizations]' \
  '-grayscale[grayscale]' \
  '-cs+[colorspace]:cs:(srgb linear)' \
  '-cc+[output color count]:n:' \
  '-bestfit[best fit scaling]' \
  '-nobestfit[no best fit]' \
  '-pixelformat+[output pixel format]:format:(auto rgb rgba gray graya)' \
  '-depth+[bit depth]:bits:(1 2 4 8 16)' \
  '-dpi+[output dpi]:dpi:' \
  '-bgcolor+[background color]:color:' \
  '-resize+[width,height]:dim:' \
  '-jpegquality+[JPEG quality]:q:' \
  '-jpegsamp+[JPEG sampling]:samp:' \
  '-pngfilter+[PNG filter]:filter:(none sub up average paeth)' \
  '-compress+[compression level]:level:' \
  '-page+[page number]:page:' \
  '-firstframe+[first frame]:frame:' \
  '-frames+[max frames]:frames:' \
  '*:input_output:_files' && ret=0

return ret
