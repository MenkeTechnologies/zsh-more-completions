#compdef oct-help
# Documentation: https://www.octopus-code.org/documentation/main/manual/utilities/oct-help/
# Octopus: search and print documentation for octopus input variables

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help and exit]' \
  '(-v --version)'{-v,--version}'[print octopus version]' \
  '(-l --list)'{-l,--list}'[list all available variables]' \
  '(-s --search)'{-s,--search}'=[search variables whose names contain STRING]:string' \
  '(-p --print)'{-p,--print}'=[print description of variable VARNAME]:varname' && ret=0

return ret
