#compdef gff2bed
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/file-management/conversion/gff2bed.html
# convert GFF3 annotations to sorted BED (bedops)

local ret=1

_arguments -s -S \
  '--keep-header[preserve header data as BED elements named _header]' \
  '--do-not-sort[output converted data without sorting]' \
  '--max-mem[limit sort memory usage]:mem' \
  '--attribute-key=[attribute to use for the ID field]:key:(gene_id gene_name transcript_id exon_id protein_id hgnc_id mgi_id)' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
