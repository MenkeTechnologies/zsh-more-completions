#compdef t2mf
# Documentation: https://pieter.vanoostrum.org/en/midi2text-mf2t-t2mf/
# translate a text file back into a Standard MIDI File

local ret=1

_arguments -s -S \
  '-r[be more relaxed about errors in the input]' \
  '::text file:_files' \
  '::midi file:_files -g "*.(mid|midi)"' && ret=0

return ret
