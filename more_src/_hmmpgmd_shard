#compdef hmmpgmd_shard
# Documentation: http://hmmer.org/documentation.html
# HMMER: sharded daemon for database search web services

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '--master[run as the master server]' \
  '--worker=[run as a worker, connecting to master at IP]:ip' \
  '--cport=[port for client/master communication (default 51371)]:port' \
  '--wport=[port for worker/master communication (default 51372)]:port' \
  '--ccncts=[max client connections (default 16)]:n' \
  '--wcncts=[max worker connections (default 32)]:n' \
  '--pid=[file to write the process id into]:file:_files' \
  '--seqdb=[hmmpgmd-format sequence file to cache]:file:_files' \
  '--hmmdb=[HMM database file to cache]:file:_files' \
  '--cpu=[number of parallel threads (for --worker)]:n' \
  '--num_shards=[number of shards to divide sequence database into]:n' && ret=0

return ret
