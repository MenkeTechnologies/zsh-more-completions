#compdef hledger
# Documentation: https://hledger.org/hledger.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'accounts:list account names'
  'activity:posting count chart'
  'add:interactive transaction entry'
  'aregister:account transactions with running balance'
  'areg:alias for aregister'
  'balance:report balance changes and end balances'
  'bal:alias for balance'
  'balancesheet:assets and liabilities'
  'bs:alias for balancesheet'
  'balancesheetequity:full balance sheet incl. equity'
  'bse:alias for balancesheetequity'
  'cashflow:liquid asset changes'
  'cf:alias for cashflow'
  'check:correctness verification'
  'close:balance adjustment transactions'
  'codes:list transaction codes'
  'commands:show command list'
  'commodities:list commodities'
  'demo:show terminal demonstrations'
  'descriptions:list transaction descriptions'
  'diff:compare account transactions'
  'files:list referenced files'
  'help:access manual'
  'import:load transactions from external files'
  'incomestatement:revenues and expenses'
  'is:alias for incomestatement'
  'notes:list transaction notes'
  'payees:list payees'
  'prices:list market prices'
  'print:full transaction entries'
  'register:postings with running total'
  'reg:alias for register'
  'repl:interactive prompt'
  'rewrite:add postings to transactions'
  'roi:return on investment'
  'run:execute command scripts'
  'setup:installation status'
  'stats:journal statistics'
  'tags:list tags'
  'test:self tests'
  'ui:terminal interface'
  'web:web interface'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--tldr=[command examples]:command:' \
  '--info=[show info manual]:topic:' \
  '--man=[show man page]:topic:' \
  '(-f --file)'{-f+,--file=}'[journal file]:file:_files' \
  '--rules-file=[CSV rules file]:file:_files' \
  '--separator=[CSV field separator]:char:' \
  '--alias=[account alias]:alias:' \
  '--anon[obfuscate names]' \
  '--pivot=[pivot postings on field]:field:' \
  '--auto[apply auto postings]' \
  '--forecast=[generate forecast txns]:period:' \
  '--ignore-assertions[ignore balance assertions]' \
  '(-b --begin)'{-b+,--begin=}'[start date]:date:' \
  '(-e --end)'{-e+,--end=}'[end date]:date:' \
  '(-D --daily)'{-D,--daily}'[daily report]' \
  '(-W --weekly)'{-W,--weekly}'[weekly report]' \
  '(-M --monthly)'{-M,--monthly}'[monthly report]' \
  '(-Q --quarterly)'{-Q,--quarterly}'[quarterly report]' \
  '(-Y --yearly)'{-Y,--yearly}'[yearly report]' \
  '(-p --period)'{-p+,--period=}'[period expr]:period:' \
  '(-U --unmarked)'{-U,--unmarked}'[unmarked postings]' \
  '(-P --pending)'{-P,--pending}'[pending postings]' \
  '(-C --cleared)'{-C,--cleared}'[cleared postings]' \
  '(-R --real)'{-R,--real}'[real postings only]' \
  '--depth=[max account depth]:n:' \
  '--date2[use secondary date]' \
  '(-E --empty)'{-E,--empty}'[show empty accounts]' \
  '(-B --cost)'{-B,--cost}'[convert to cost]' \
  '(-V --market)'{-V,--market}'[convert to market value]' \
  '(-X --exchange)'{-X+,--exchange=}'[convert to commodity]:comm:' \
  '--value=[show values as]:type:(then end now)' \
  '--infer-market-prices[infer prices from txn prices]' \
  '--pretty[unicode boxes]' \
  '(-o --output-file)'{-o+,--output-file=}'[output file]:file:_files' \
  '(-O --output-format)'{-O+,--output-format=}'[output format]:fmt:(txt csv tsv json html sql)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'hledger command' commands && ret=0 ;;
esac

return ret
