#compdef netlify ntl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'agents:manage Netlify AI agent tasks'
  'api:run any Netlify API method'
  'blobs:manage objects in Netlify Blobs'
  'build:build on your local machine'
  'claim:claim an anonymously deployed site'
  'clone:clone a remote repository and link to project'
  'completion:generate shell completion script'
  'create:create a new Netlify project using AI agent'
  'database:provision Postgres database'
  'deploy:deploy project to Netlify'
  'dev:run local dev server'
  'env:control environment variables'
  'functions:manage Netlify functions'
  'init:configure continuous deployment'
  'link:link local repo to existing project'
  'login:login to Netlify account'
  'logout:logout of Netlify account'
  'logs:view logs from project'
  'open:open settings for linked project'
  'recipes:create or modify files via recipes'
  'serve:build for production and serve locally'
  'sites:handle project operations'
  'status:print status information'
  'switch:switch active Netlify account'
  'teams:handle team operations'
  'unlink:unlink local folder from project'
  'watch:watch for project deploy to finish'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--auth=[Netlify auth token]:token:' \
  '--debug[print debug info]' \
  '--filter=[site in monorepo]:site:' \
  '--json[JSON output]' \
  '--plain[plain text output]' \
  '--telemetry-enable[enable telemetry]' \
  '--telemetry-disable[disable telemetry]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'netlify subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (deploy)
        _arguments \
          '(-p --prod)'{-p,--prod}'[deploy to production]' \
          '--alias=[deploy alias]:alias:' \
          '--allow-anonymous[allow anonymous deploy]' \
          '--dir=[publish directory]:dir:_files -/' \
          '--functions=[functions directory]:dir:_files -/' \
          '--dry[dry run]' \
          '--context=[deploy context]:context:' \
          '--scope=[scope]:scope:' \
          '--secret=[deploy secret]:secret:' && ret=0
        ;;
      (env)
        _values 'env action' 'clone' 'get' 'import' 'list' 'set' 'unset' && ret=0
        ;;
      (functions)
        _values 'functions action' 'build' 'create' 'invoke' 'list' 'serve' && ret=0
        ;;
      (sites)
        _values 'sites action' 'create' 'delete' 'list' 'search' && ret=0
        ;;
      (blobs)
        _values 'blobs action' 'delete' 'get' 'list' 'set' && ret=0
        ;;
      (database)
        _values 'database action' 'status' 'init' 'connect' 'reset' 'migrations' && ret=0
        ;;
      (open)
        _values 'open target' 'admin' 'site' && ret=0
        ;;
      (status)
        _values 'status target' 'hooks' && ret=0
        ;;
      (teams)
        _values 'teams action' 'list' && ret=0
        ;;
      (agents)
        _values 'agents action' 'create' 'list' 'show' 'stop' && ret=0
        ;;
      (recipes)
        _values 'recipes action' 'list' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' && ret=0
        ;;
    esac
    ;;
esac

return ret
