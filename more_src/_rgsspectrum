#compdef rgsspectrum
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/rgsspectrum/node4.html
# Generate source and background spectra for a single RGS exposure

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--evlist=[input filtered event dataset]:file:_files' \
  '--srclist=[input source definition dataset]:file:_files' \
  '--source=[INDEX number of an entry in the SRCLIST table]:n' \
  '--order=[reflection order number]:n' \
  '--withspectrum=[output the source spectrum dataset]:bool:(yes no)' \
  '--bkgcorrect=[background-correct the source spectrum]:bool:(yes no)' \
  '--spectrumset=[output source spectrum dataset]:file:_files' \
  '--spectrumbinning=[spectrum accumulation binning]:binning:(lambda beta)' \
  '--withbkgset=[output the background spectrum dataset]:bool:(yes no)' \
  '--bkgset=[output background spectrum dataset]:file:_files' \
  '--rebin=[channel rebinning factor]:n' \
  '--edgechannels=[mark edge channels as bad in QUALITY]:bool:(yes no)' \
  '--exposed=[mark insufficient-exposure channels as bad]:value' \
  '--withfracexp=[add non-standard FRAC_EXP column]:bool:(yes no)' \
  '--badquality=[QUALITY column value indicating a bad channel]:value' \
  '*:param=value:_default' && ret=0

return ret
