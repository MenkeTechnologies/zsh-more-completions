#compdef rsgisproj
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# Find projection information for a given input.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--image[The GDAL image file for which the projection will be outputted.]:value:_files' \
  '--vecfile[The GDAL vector file for which the projection will be outputted.]:value:_files' \
  '--veclyr[The layer within the --vecfile, if specified, for which the]:value:_files' \
  '--epsg[Provide an inputted EPSG code to define the projection.]:value:_files' \
  '--epsga[Provide an inputted EPSGA code to define the projection.]:value:_files' \
  '--wktfile[Provide an inputted WKT string as a text file to define the projection.]:value:_files' \
  '--wkt[Provide an inputted WKT string to define the projection.]:value:_files' \
  '--proj4file[Provide an inputted Proj4 string as a text]:value:_files' \
  '--proj4[Provide an inputted Proj4 string to define the projection.]:value:_files' \
  '--esrifile[Provide an inputted ESRI .prj file to define the projection.]:value:_files' \
  '--utm[Provide a UTM zone format must be, XXH, where XX are the zone]:value:_files' \
  '(-o --output)'{-o,--output}'[The output format of the projection. Multiple options can be]:value:(EPSG WKT WKTPretty PROJ4)' \
  '*:file:_files' && ret=0

return ret
