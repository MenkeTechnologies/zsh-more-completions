#compdef syz-bq.sh
# _syz-bq — query syzbot BigQuery coverage data (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-bq.sh (getopts).

_syz-bq.sh() {
    _arguments \
        '-w+[workdir]:dir:_files -/' \
        '-d+[duration]:duration:' \
        '-t+[to-date]:date:' \
        '-n+[namespace]:ns:' \
        '-r+[repo]:url:_urls' \
        '-b+[branch]:branch:' \
        '-c+[client name]:name:'
}

_syz-bq.sh "$@"
