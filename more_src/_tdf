#compdef tdf

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-p+[page number to open]:page:' \
  '--page=[page number to open]:page:' \
  '--summary[show document summary]' \
  '1:pdf file:_files -g "*.pdf"' && ret=0

return ret
