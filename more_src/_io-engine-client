#compdef io-engine-client mayastor-client
# _io-engine-client — Mayastor I/O engine gRPC client (CLI tool for managing pools/nexuses/replicas/snapshots/perf/rebuild/stats on an io-engine)
# upstream: https://github.com/openebs/mayastor
# Global flags + subcommands from io-engine/src/bin/io-engine-client/v1/mod.rs on tip (clap); v0/v1 dispatch via API_VERSION env var.

_io-engine-client() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-b --bind)'{-b,--bind}'=[URI of the io-engine instance]:url:_urls' \
        '(-q --quiet)'{-q,--quiet}'[suppress all output except for list records]' \
        '*'{-v,--verbose}'[increase output verbosity]' \
        '(-u --units)'{-u,--units}'=[output units base]:base:(b i d)' \
        '(-o --output)'{-o,--output}'=[output format]:fmt:(default json yaml)' \
        '1: :->cmd'
    case $state in
        cmd)
            local -a subs=(
                pool:'manage Mayastor pools'
                nexus:'manage Mayastor nexuses'
                replica:'manage Mayastor replicas'
                bdev:'manage SPDK bdevs'
                device:'manage block devices'
                perf:'show performance metrics'
                rebuild:'manage rebuild jobs'
                'snapshot-rebuild':'manage snapshot rebuilds'
                snapshot:'manage snapshots'
                stats:'show I/O statistics'
                controller:'manage NVMe controllers'
                jsonrpc:'send a raw SPDK JSON-RPC call'
                test:'internal test helpers'
            )
            _describe -t commands 'io-engine-client subcommand' subs
            ;;
    esac
}

_io-engine-client "$@"
