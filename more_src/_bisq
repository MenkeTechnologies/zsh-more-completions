#compdef bisq bisq-cli
# Documentation: https://github.com/bisq-network/bisq (cli/src/main/java/bisq/cli/CliMain.java)
# Reference accessed: 2026-05-29
# Bisq — decentralized P2P Bitcoin exchange gRPC CLI.

local curcontext="$curcontext" state line ret=1

local -a _methods
_methods=(
  'getbalance:get wallet balances (BTC/BSQ)'
  'getaddressbalance:get balance for an address'
  'getfundingaddresses:list funding addresses for the BTC wallet'
  'getunusedbsqaddress:get an unused BSQ address'
  'gettransactions:list wallet transactions'
  'gettransaction:get a single transaction by txid'
  'gettxfeerate:get current TX fee rate'
  'settxfeerate:override TX fee rate (sats/byte)'
  'unsettxfeerate:reset TX fee rate to default'
  'sendbsq:send BSQ to an address'
  'sendbtc:send BTC to an address'
  'verifybsqsenttoaddress:verify BSQ was sent to an address'
  'createoffer:create a new BTC fiat/crypto offer'
  'editoffer:edit an existing offer'
  'canceloffer:cancel an offer by id'
  'getoffer:get a single offer by id'
  'getoffers:list all offers for a market'
  'getmyoffers:list offers created by me'
  'takeoffer:take an existing offer'
  'gettrade:get a single trade by id'
  'gettrades:list trades (open/closed/failed)'
  'confirmpaymentstarted:confirm payment started for a trade'
  'confirmpaymentstartedxmr:confirm Monero payment started (XMR auto-confirm)'
  'confirmpaymentreceived:confirm payment received for a trade'
  'closetrade:close a completed trade'
  'withdrawfunds:withdraw trade funds to an external address'
  'failtrade:mark a trade as failed (mediator)'
  'unfailtrade:re-open a failed trade (mediator)'
  'getpaymentmethods:list supported payment methods'
  'getpaymentacctform:get the form schema for a payment-method id'
  'createpaymentacct:create a payment account from a JSON form'
  'createcryptopaymentacct:create a crypto-currency payment account'
  'getpaymentaccts:list saved payment accounts'
  'lockwallet:lock the encrypted wallet'
  'unlockwallet:unlock the encrypted wallet'
  'removewalletpassword:remove encryption password from wallet'
  'setwalletpassword:set encryption password on wallet'
  'getcycleinfo:get info about a DAO cycle'
  'getcycles:list past DAO cycles'
  'getproposals:list DAO proposals'
  'getballots:list ballots'
  'getmyvotes:list my votes'
  'getvoteresults:list vote results'
  'getbondedroles:list bonded roles'
  'getdaoparam:get a DAO parameter value'
  'createcompensationproposal:create a compensation request proposal'
  'createreimbursementproposal:create a reimbursement proposal'
  'createchangeparamproposal:create a parameter-change proposal'
  'createbondedroleproposal:create a bonded-role proposal'
  'createconfiscatebondproposal:create a confiscate-bond proposal'
  'creategenericproposal:create a generic proposal'
  'createremoveassetproposal:create a remove-asset proposal'
  'setvote:set vote on a proposal'
  'publishblindvote:publish blind vote for current cycle'
  'getversion:show daemon version'
  'getnetwork:show network info'
  'getdaostatus:get DAO sync status'
  'getavgbsqprice:get average BSQ trade price'
  'getbtcprice:get current BTC price for a currency'
  'registerdisputeagent:register a dispute agent (mediator/refund agent)'
  'stop:shut down the Bisq daemon'
  'help:show help for a method'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--password=[gRPC password (also BISQ_RPC_PASSWORD env)]:password:' \
  '--host=[daemon host (default localhost)]:host:_hosts' \
  '--port=[daemon gRPC port (default 9998)]:port:' \
  '1: :->method' \
  '*:: :->args' && ret=0

case $state in
  method)
    _describe -t methods 'bisq method' _methods && ret=0
    ;;
  args)
    case $line[1] in
      getbalance)
        _arguments '--currency-code=[BTC|BSQ]:currency:(BTC BSQ)' && ret=0
        ;;
      gettrades)
        _arguments '--category=[trade category]:category:(open closed failed)' && ret=0
        ;;
      createoffer|editoffer)
        _arguments \
          '--direction=[BUY or SELL]:dir:(BUY SELL)' \
          '--currency-code=[fiat/crypto code]:code:' \
          '--amount=[amount in BTC]:btc:' \
          '--min-amount=[min amount in BTC]:btc:' \
          '--use-market-based-price=[use market-based price]:bool:(true false)' \
          '--fixed-price=[fixed price]:price:' \
          '--market-price-margin=[market price margin %]:pct:' \
          '--security-deposit=[security deposit %]:pct:' \
          '--payment-account=[payment account id]:id:' \
          '--maker-fee-currency-code=[fee currency]:code:(BTC BSQ)' && ret=0
        ;;
      takeoffer)
        _arguments \
          '--offer-id=[offer id]:id:' \
          '--payment-account=[payment account id]:id:' \
          '--taker-fee-currency-code=[fee currency]:code:(BTC BSQ)' && ret=0
        ;;
      getbtcprice|getavgbsqprice)
        _arguments '--currency-code=[fiat code]:code:' && ret=0
        ;;
      sendbtc|sendbsq)
        _arguments \
          '--address=[destination address]:addr:' \
          '--amount=[amount]:amt:' \
          '--tx-fee-rate=[TX fee rate (sats/byte)]:rate:' \
          '--memo=[transaction memo]:memo:' && ret=0
        ;;
    esac
    ;;
esac

return ret
