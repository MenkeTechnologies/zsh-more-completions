#compdef mutt
# _mutt — Michael Elkins's Mutt text-mode MUA (curses-based mail user agent reading mbox/Maildir/MH/MMDF; supports IMAP/POP3/SMTP with PGP/GPG/S/MIME)
# upstream: https://gitlab.com/muttmua/mutt (mirror: https://github.com/muttmua/mutt)
# Flags from main.c getopt + doc/mutt.man on tip.

_mutt() {
    _arguments \
        '(- *)-h[show short option help and exit]' \
        '*-v[show version (-vv shows license and copyright)]' \
        '-A+[print expanded alias and exit]:alias:' \
        '*-a+[attach file via MIME (must be last; recipients after --)]:file:_files' \
        '-b+[BCC address]:bcc:_email_addresses' \
        '-c+[CC address]:cc:_email_addresses' \
        '-d+[debug level -5..5]:level:' \
        '-D[print all configuration variables to stdout]' \
        '-E[edit the draft/include file]' \
        '-e+[run a config command after init files]:cmd:' \
        '-f+[mailbox to open]:mailbox:_files' \
        '-F+[rcfile to use instead of ~/.muttrc]:file:_files' \
        '-H+[draft file (or - for stdin)]:file:_files' \
        '-i+[include file (or - for stdin)]:file:_files' \
        '-m+[default mailbox type for new folders]:type:(mbox MMDF MH Maildir)' \
        '-n[skip system-wide Muttrc]' \
        '-p[resume postponed message]' \
        '-Q+[query configuration variable]:var:' \
        '-R[read-only]' \
        '-s+[message subject]:subject:' \
        '-x[mailx(1) compose-mode emulation]' \
        '-y[start with listing of mailboxes config command]' \
        '-z[exit 1 if -f mailbox has no messages]' \
        '-Z[open first mailboxes-entry that has new mail (exit 1 if none)]' \
        '*:to-addr:_email_addresses'
}

_mutt "$@"
