#compdef acpi_listen
# Documentation: man acpi_listen(8)
# Source: tedfelix/acpid2 acpi_listen.c (master) — listen for ACPI events from acpid (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-c --count)'{-c+,--count=}'[max number of events]:N:_default' \
    '(-s --socketfile)'{-s+,--socketfile=}'[acpid socket file]:file:_files' \
    '(-t --time)'{-t+,--time=}'[listen time in seconds]:seconds:_default' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    && ret=0

return ret
