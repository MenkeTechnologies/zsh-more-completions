#compdef gltf-pipeline
# Documentation: https://github.com/CesiumGS/gltf-pipeline
# Optimizes and converts glTF/glb assets, with Draco mesh compression

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-i --input)'{-i,--input}'[path to the glTF or glb file]:input:_files' \
  '(-o --output)'{-o,--output}'[output path for the glTF or glb file]:output:_files' \
  '(-b --binary)'{-b,--binary}'[convert input glTF to glb format]' \
  '(-a --allowAbsolute)'{-a,--allowAbsolute}'[permit glTF files to reference external file URLs]' \
  '(-j --json)'{-j,--json}'[convert input glb to glTF format]' \
  '(-s --separate)'{-s,--separate}'[write buffers, shaders, and textures as separate files]' \
  '(-t --separateTextures)'{-t,--separateTextures}'[write textures as separate files only]' \
  '--stats[print output glTF file statistics to console]' \
  '--keepUnusedElements[retain unused materials, nodes, and meshes]' \
  '--keepLegacyExtensions[preserve legacy extension materials without PBR conversion]' \
  '(-d --draco.compressMeshes)'{-d,--draco.compressMeshes}'[apply Draco mesh compression with KHR extension]' \
  '--draco.compressionLevel[set Draco compression intensity (0-10)]:level:' \
  '--draco.quantizePositionBits[position attribute quantization bits]:bits:' \
  '--draco.quantizeNormalBits[normal attribute quantization bits]:bits:' \
  '--draco.quantizeTexcoordBits[texture coordinate quantization bits]:bits:' \
  '--draco.quantizeColorBits[color attribute quantization bits]:bits:' \
  '--draco.quantizeGenericBits[skinning and custom attribute quantization bits]:bits:' \
  '--draco.unifiedQuantization[apply uniform quantization across all mesh primitives]' \
  '--draco.uncompressedFallback[include uncompressed mesh versions alongside compressed ones]' \
  '--baseColorTextureNames[uniform names for base color texture references]:names:' \
  '--baseColorFactorNames[uniform names for base color factor references]:names:' \
  '*:file:_files' && ret=0

return ret
