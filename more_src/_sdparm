#compdef sdparm

# Zsh completion for sdparm - access SCSI device parameters

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[list all known fields for given page]' \
  '(-b --bellowong)'{-b,--bellowong}'[output in bellowong format]' \
  '(-B --binary)'{-B,--binary}'[output in binary format]' \
  '(-c --clear)'{-c,--clear}'[clear (zero) field value]:field=value:' \
  '(-C --command)'{-C,--command}'[perform given command]:command:(capacity eject idle load ready sense start standby stop sync unlock)' \
  '(-d --defaults)'{-d,--defaults}'[set default page values]' \
  '(-D --dummy)'{-D,--dummy}'[do not write back modified pages]' \
  '(-e --enumerate)'{-e,--enumerate}'[enumerate known pages and fields]' \
  '(-f --flexible)'{-f,--flexible}'[be flexible with transport type]' \
  '(-g --get)'{-g,--get}'[get (fetch) field value]:field:' \
  '(-H --hex)'{-H,--hex}'[output response in hexadecimal]' \
  '(-i --inquiry)'{-i,--inquiry}'[output INQUIRY VPD page fields]' \
  '(-I --inhex)'{-I,--inhex}'[read data from file instead of device]:file:_files' \
  '(-l --long)'{-l,--long}'[extra information in output]' \
  '(-M --manufacturer)'{-M,--manufacturer}'[manufacturer specific page code]' \
  '(-n --num-desc)'{-n,--num-desc}'[number of descriptors for multi-descriptor pages]:number:' \
  '(-p --page)'{-p,--page}'[page code and optional subpage code]:page code:' \
  '(-q --quiet)'{-q,--quiet}'[reduce output verbosity]' \
  '(-r --readonly)'{-r,--readonly}'[open device read-only]' \
  '(-s --set)'{-s,--set}'[set field value]:field=value:' \
  '(-S --save)'{-S,--save}'[set saved page as well]' \
  '(-t --transport)'{-t,--transport}'[transport specific page code]:transport:(fcp spi srp sas spl fc sop pcie)' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-6 --six)'{-6,--six}'[use 6-byte MODE SENSE/SELECT]' \
  '--ws[set window size]:size:' \
  '*:device:_files -g "/dev/sd*"'
