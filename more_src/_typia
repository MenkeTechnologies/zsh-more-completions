#compdef typia
# =============================================================================
# typia — Jeongho "Samchon" Nam's "Super-fast Runtime Validators
#         (and Serializers) for TypeScript" — a transformer-
#         based code generator that compiles TypeScript type
#         declarations into highly optimized validation /
#         serialization / cloning / equality / random-mock
#         routines.  Unlike runtime-schema validators (zod,
#         io-ts, ajv) which evaluate type info at runtime,
#         typia EMITS specialized JavaScript at TypeScript
#         compile time so the per-call cost is a hand-written
#         level of overhead.
#
#         Distinguishing from zod (Colin McDonnell, runtime
#         schema DSL), io-ts (gcanti, Either-based decoders),
#         ajv (Evgeny Poberezkin, JSON-Schema runtime checker),
#         class-validator (Khoa Pham, decorator validation
#         driven by reflect-metadata), valibot (Fabian Hiller,
#         tree-shakeable runtime schemas), and arktype
#         (David Blass, embedded TS-DSL runtime schemas) by:
#           - PURE TYPE-DRIVEN — `typia.is<T>(value)` /
#             `typia.assert<T>(value)` / `typia.validate<T>
#             (value)` take a TypeScript type as the type
#             parameter; no parallel schema declaration
#           - TRANSFORMER OUTPUT — at compile time a custom
#             TypeScript transformer rewrites each call into
#             an inlined check graph specialized to the
#             concrete type; the runtime cost is near-hand-
#             rolled
#           - JSON STRINGIFY/PARSE — `typia.json.stringify<T>`
#             / `typia.json.assertParse<T>` produce optimized
#             serializers that beat JSON.stringify on
#             measured benchmarks for known-shape types
#           - PROTOBUF — `typia.protobuf.encode<T>` /
#             `typia.protobuf.decode<T>` generate schema-less
#             protobuf serializers driven entirely by TS
#             types
#           - LLM SCHEMA / FUNCTION CALLING — `typia.llm.
#             schema<T>` / `typia.llm.application<Cls>` emit
#             OpenAI / Anthropic / Gemini-flavoured function-
#             calling schemas from TypeScript class methods,
#             targeting Structured Output + tool-use APIs
#           - RANDOM MOCK — `typia.random<T>()` synthesizes
#             values that satisfy the type for test
#             fixtures + property-based testing seed input
#           - SHARED INTERFACE WITH NESTIA — feeds the
#             nestia framework (same author) which uses
#             typia transformers to derive NestJS-controller
#             validation + Swagger schemas + SDK clients
#             from controller signatures
#           - TTSC BACKING — depends on `ttsc` (TypeScript
#             compiler wrapper that loads transformer
#             plugins) since stock `tsc` does not load
#             custom transformer plugins
#           - NATIVE-PREVIEW PATH — recent versions can
#             optionally load `@typescript/native-preview`
#             (the Microsoft Go-based TypeScript compiler)
#             instead of `ttsc` for faster transforms
#           - GENERATE WIZARD — `npx typia generate
#             --input DIR --output DIR --project tsconfig.json`
#             walks a template directory and emits
#             validator implementations to an output dir
#
# Author:   Jeongho Nam (samchon on GitHub) — Korean
#           TypeScript open-source author; also author of
#           nestia (NestJS extension), nestia-editor,
#           @samchon/openapi, and tgrid (TypeScript Grid
#           Computing Framework).
# Source:   https://github.com/samchon/typia
#           https://github.com/samchon/typia/blob/master/packages/typia/src/executable/typia.ts
#           https://github.com/samchon/typia/blob/master/packages/typia/src/executable/TypiaGenerateWizard.ts
# Homepage: https://typia.io
# License:  MIT
# Status:   13.x current; >9k GitHub stars; actively
#           maintained.
# Reference accessed: 2026-06-01
#
# -----------------------------------------------------------------------------
#
# THE typia CLI
#
# typia is invoked as:
#   npx typia <command> [options...]
#
# Commands:
#   generate                       Run the Generate Wizard:
#                                  walk an --input template
#                                  directory, emit validator
#                                  implementations into the
#                                  --output directory,
#                                  driven by the tsconfig
#                                  at --project.
#                                  Missing options are
#                                  prompted interactively
#                                  via inquirer.
#
# Options for `generate`:
#   --input [path]                 input directory of templates
#   --output [directory]           output directory for emitted
#                                  validator implementations
#   --project [project]            tsconfig.json file location
#                                  (auto-discovered if a single
#                                  tsconfig.json exists; prompted
#                                  if multiple)
#
# Common invocations:
#   # Interactive wizard
#   npx typia generate
#
#   # Fully-specified non-interactive
#   npx typia generate \
#     --input src/templates \
#     --output src/functional \
#     --project tsconfig.json
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _typia_cmds
_typia_cmds=(
    'generate:walk --input template dir + emit validators to --output'
)

_arguments -C \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'typia command' _typia_cmds && ret=0
        ;;
    args)
        case $line[1] in
            generate)
                _arguments -s -S \
                    '--input=[input templates directory]:dir:_files -/' \
                    '--output=[output directory for generated validators]:dir:_files -/' \
                    '--project=[tsconfig.json file location]:tsconfig:_files -g "tsconfig*.json"' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
