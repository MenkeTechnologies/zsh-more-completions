#compdef sa1
# _sa1 — sysstat sa1 shell script to launch sadc CLI (Sebastien Godard / sysstat team, Bash); custom argparse
# upstream: https://github.com/sysstat/sysstat

_sa1() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-D[append date to default file name]' \
        '-I[force collection of interrupt stats]' \
        '-L[lock data file]' \
        '-S+[modules to enable]:list:(DISK INT IPV6 POWER SNMP XDISK ALL XALL)' \
        '*:interval-count:'
}

_sa1 "$@"
