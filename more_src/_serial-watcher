#compdef serial-watcher
# _serial-watcher — serial-watcher CLI for the serial-port event monitor printing rs232 baud parity stop bits data CTS RTS DSR DTR DCD RI line-state changes timestamping hex display capture file rotation (linux team, Python); argparse
# upstream: https://github.com/serial-watcher/serial-watcher

_serial-watcher() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-p+[port]:file:_files -g "/dev/tty* /dev/cu* /dev/ttyACM* /dev/ttyUSB*"' \
        '--port=+[port]:file:_files -g "/dev/tty* /dev/cu* /dev/ttyACM* /dev/ttyUSB*"' \
        '-b+[baud]:n:(75 110 300 600 1200 2400 4800 9600 19200 38400 57600 115200 230400 460800 921600 1500000)' \
        '--baud=+[baud]:n:(75 110 300 600 1200 2400 4800 9600 19200 38400 57600 115200 230400 460800 921600 1500000)' \
        '-d+[data bits]:n:(5 6 7 8)' \
        '--databits=+[data bits]:n:(5 6 7 8)' \
        '-r+[parity]:p:(none even odd mark space)' \
        '--parity=+[parity]:p:(none even odd mark space)' \
        '-s+[stop bits]:s:(1 1.5 2)' \
        '--stopbits=+[stop bits]:s:(1 1.5 2)' \
        '-f+[flow control]:f:(none xonxoff rtscts dsrdtr)' \
        '--flow=+[flow control]:f:(none xonxoff rtscts dsrdtr)' \
        '-l+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '-x[hex display]' \
        '--hex[hex display]' \
        '-t[timestamps]' \
        '--timestamps[timestamps]' \
        '-c+[capture file]:file:_files' \
        '--capture=+[capture file]:file:_files' \
        '--no-echo[no echo]' \
        '--local-echo[local echo]' \
        '--auto-reconnect[auto reconnect]' \
        '--reset-on-open[reset on open]'
}

_serial-watcher "$@"
