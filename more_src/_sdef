#compdef sdef
# Documentation: https://developer.apple.com/library/archive/documentation/ScriptingAutomation/Conceptual/ASMOPCookbook/Articles/Sdef.html
# Reference accessed: 2026-05-21
# Verified: macOS sdef(1) man page (June 30, 2006) — synopsis is "sdef application".
# No options/flags documented in the man page. The earlier completion had a
# fabricated -o and --help; removed.
# STUB: sdef takes only an application/file argument; no flags.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:application:_files -g "*.app"' && ret=0
return ret
