#compdef openebsctl
# Documentation: https://github.com/openebs/openebsctl/blob/develop/README.md
# kubectl plugin to manage OpenEBS storage components

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help for openebs]' \
  '(-c --kubeconfig)'{-c,--kubeconfig=}'[path to config file]:kubeconfig:_files' \
  '(-v --version)'{-v,--version}'[version for openebs]' \
  '1:command:(cluster-info describe get completion version help)' \
  '*::arg:_default' && ret=0

return ret
