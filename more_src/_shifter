#compdef shifter

# Shifter: NERSC container runtime for HPC
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '-i[image]:image:' \
  '--image=[image]:image:' \
  '-v[volume mapping]:mapping:' \
  '--volume=[volume mapping]:mapping:' \
  '-e[set env var]:key=value:' \
  '--env=[set env var]:key=value:' \
  '-w[working dir]:dir:_files -/' \
  '--workdir=[working dir]:dir:_files -/' \
  '-m[module]:module:' \
  '--module=[module]:module:' \
  '-N[hostname for the container]:host:' \
  '--clearenv[clear environment]' \
  '*::shifter args:_files' && ret=0
return ret
