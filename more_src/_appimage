#compdef appimage *.AppImage
# Documentation: https://docs.appimage.org/user-guide/run-appimages.html
# Documentation: https://github.com/AppImage/type2-runtime/blob/main/src/runtime/runtime.c
# Reference accessed: 2026-05-27
# Verified: upstream type2-runtime runtime.c print_help() string

# Zsh completion for AppImage runtime arguments.
# Note: there is no canonical `appimage` binary; AppImages are
# self-contained executables (*.AppImage) whose embedded type2
# runtime understands the --appimage-* options below.

_arguments \
  '--appimage-extract[extract embedded filesystem (optional glob pattern)]:pattern:' \
  '--appimage-extract-and-run[temporarily extract, run, then delete]' \
  '--appimage-help[print AppImage runtime help]' \
  '--appimage-mount[mount embedded filesystem, print mount point, wait for Ctrl-C]' \
  '--appimage-offset[print byte offset to embedded filesystem image]' \
  '--appimage-portable-home[create a portable home folder used as $HOME]' \
  '--appimage-portable-config[create a portable config folder used as $XDG_CONFIG_HOME]' \
  '--appimage-signature[print digital signature embedded in AppImage]' \
  '--appimage-updateinformation[print update info embedded in AppImage]' \
  '--appimage-updateinfo[print update info embedded in AppImage (short form)]' \
  '--appimage-version[print version of AppImage runtime]' \
  '*:AppImage or arg:_files -g "*.AppImage(-.)"'
