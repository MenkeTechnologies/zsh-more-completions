#compdef tex4ht

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '-d+[output dir]:dir:_files -/' \
  '-f+[footnote settings]:opts:' \
  '-m+[mathml/math style]:opts:' \
  '-s+[stylesheet]:file:_files -g "*.css"' \
  '*:tex file:_files -g "*.{tex,dvi}"' && ret=0

return ret
