#compdef plasmo

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create a new Plasmo extension project'
  'dev:start development server'
  'build:build extension for production'
  'package:package extension into distributable zip'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'plasmo command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments \
          '--entry=[entry file]:file:_files' \
          '--with-src[use src directory layout]' \
          '1:project name' && ret=0
        ;;
      (dev)
        _arguments \
          '--target=[browser target]:target:(chrome-mv3 firefox-mv2 firefox-mv3 edge-mv3)' \
          '--port=[dev server port]:port' \
          '--verbose[verbose output]' && ret=0
        ;;
      (build)
        _arguments \
          '--target=[browser target]:target:(chrome-mv3 firefox-mv2 firefox-mv3 edge-mv3)' \
          '--zip[create zip after build]' \
          '--source-maps[generate source maps]' \
          '--verbose[verbose output]' && ret=0
        ;;
      (package)
        _arguments \
          '--target=[browser target]:target:(chrome-mv3 firefox-mv2 firefox-mv3 edge-mv3)' \
          '--zip[create zip file]' && ret=0
        ;;
    esac
    ;;
esac

return ret
