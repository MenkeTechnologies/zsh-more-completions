#compdef plasmo
# Documentation: https://docs.plasmo.com/framework/workflows/build
# Reference accessed: 2026-05-20
# Verified: upstream docs and source at https://github.com/PlasmoHQ/plasmo.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create a new Plasmo extension project'
  'dev:start the development server with HMR'
  'build:create a production build of the extension'
  'package:package the extension into a distributable archive'
  'start:start a built extension'
  'help:show help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'plasmo command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments \
          '--entry=[comma-separated entry files]:entries' \
          '--exp[example extension (with- prefix required)]' \
          '1:project name' && ret=0
        ;;
      (dev)
        _arguments \
          '--target=[browser-name and manifest version]:target:(chrome-mv3 firefox-mv2 firefox-mv3 edge-mv3 safari-mv3)' \
          '--tag=[build tag]:tag' \
          '--serve-port=[dev server port (default 1012)]:port' \
          '--serve-host=[dev server host (default localhost)]:host' \
          '--hmr-port=[HMR port (default 1815)]:port' \
          '--hmr-host=[HMR host (default localhost)]:host' \
          '--verbose[enable verbose logging]' && ret=0
        ;;
      (build)
        _arguments \
          '--target=[browser-name and manifest version]:target:(chrome-mv3 firefox-mv2 firefox-mv3 edge-mv3 safari-mv3)' \
          '--tag=[build tag (default prod)]:tag' \
          '--zip[combine build and packaging]' \
          '--hoist[scope-hoist optimization]' \
          '--no-minify[disable minification]' \
          '--source-maps[generate source maps]' \
          '--bundle-buddy[generate Bundle Buddy report]' && ret=0
        ;;
      (package)
        _arguments \
          '--target=[browser target]:target:(chrome-mv3 firefox-mv2 firefox-mv3 edge-mv3 safari-mv3)' \
          '--tag=[build tag]:tag' \
          '--zip[create zip file]' && ret=0
        ;;
    esac
    ;;
esac

return ret
