#compdef quart-cli
# _quart-cli — Quart async Flask-compatible framework CLI alias (Pallets community, Python); click
# upstream: https://github.com/pallets/quart

_quart-cli() {
    local -a sub=(
        'run:run development server'
        'shell:run python shell with app context'
        'routes:show routes'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--app=+[application]:str:' \
        '-A+[application]:str:' \
        '--env=+[environment]:env:(production development)' \
        '-e+[environment]:env:(production development)' \
        '--debug[debug]' \
        '--no-debug[no debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'quart subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '--host=+[bind host]:host:_hosts' \
                    '-h+[bind host]:host:_hosts' \
                    '--port=+[bind port]:port:' \
                    '-p+[bind port]:port:' \
                    '--certfile=+[ssl cert]:file:_files' \
                    '--keyfile=+[ssl key]:file:_files' \
                    '--keyfile-password=+[ssl key password]:str:' \
                    '--reload[reload on change]' \
                    '--no-reload[no reload]' \
                    '--debugger[enable debugger]' \
                    '--no-debugger[disable debugger]' \
                    '--ca-certs=+[ca certs]:file:_files' \
                    '--ciphers=+[ciphers]:str:' ;;
                shell) _arguments '*:arg:' ;;
                routes) _arguments \
                    '--sort=+[sort key]:k:(endpoint methods rule match)' \
                    '--all-methods[include hidden methods]' ;;
            esac
            ;;
    esac
}

_quart-cli "$@"
