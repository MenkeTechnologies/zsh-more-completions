#compdef diceware

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-n --num)'{-n,--num}'[number of words in passphrase]:number' \
  '(-c --caps)'{-c,--caps}'[capitalize first letter of each word]' \
  '--no-caps[do not capitalize words]' \
  '(-d --delimiter)'{-d,--delimiter}'[delimiter between words]:delimiter' \
  '(-s --specials)'{-s,--specials}'[number of special characters to insert]:count' \
  '(-r --rolls)'{-r,--rolls}'[provide manual dice rolls]:rolls' \
  '(-w --wordlist)'{-w,--wordlist}'[wordlist to use]:wordlist:(en en_eff en_orig en_securedrop de de_8k es fr it pt)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' && ret=0

return ret
