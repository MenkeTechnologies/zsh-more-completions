#compdef e1s
# Documentation: https://github.com/keidarcy/e1s
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# keidarcy/e1s — AWS ECS TUI (`cmd/e1s/main.go` rootCmd)

local ret=1
_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '--version[show version]' \
  '(-c)'{-c+,--config-file=}'[config YAML]:config:_files' \
  '(-d)'{-d,--debug}'[debug logging]' \
  '(-j)'{-j,--json}'[JSON logs]' \
  '--read-only[disable mutating actions]' \
  '(-l)'{-l+,--log-file=}'[log file path]:file:_files' \
  '(-s)'{-s+,--shell=}'[ECS exec shell]:shell:_command_names -e' \
  '(-r)'{-r+,--refresh=}'[auto-refresh seconds (-1 = manual)]:seconds:' \
  '--profile=[AWS profile]:profile:' \
  '--region=[AWS region]:region:' \
  '--theme=[UI theme name]:theme:' \
  '--cluster=[default ECS cluster]:cluster:' \
  '--service=[default ECS service]:service:' \
  '(service)--cluster=[required when --service set]:cluster:' \
  '--splash[splash screen while loading AWS metadata (default on)]' \
  '*:: :_default' && ret=0
return ret
