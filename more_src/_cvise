#compdef cvise
# Documentation: https://manpages.debian.org/bookworm/cvise/cvise.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm cvise(1) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --no-default-passes and --add-pass (cvise has --remove-pass
# and --start-with-pass instead); incorrect --clang-delta-std values
# (real are c++98/c++11/c++14/c++17/c++20/c++2b plus C variants).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--n=[number of cores to use]:cores' \
  '--tidy[ensure the test case is tidy]' \
  '--not-c[do not assume input is C/C++]' \
  '--timeout=[timeout per test in seconds]:seconds' \
  '--remove-pass=[remove a pass]:pass:' \
  '--start-with-pass=[start with a specific pass]:pass:' \
  '--skip-initial-passes[skip initial passes]' \
  '--no-kill[do not kill test processes on timeout]' \
  '--sllooww[try harder, at the expense of speed]' \
  '--print-diff[print diff of each reduction step]' \
  '--save-temps[save temporary files]' \
  '--clang-delta-std=[C++ standard for clang_delta]:standard:(c++98 c++11 c++14 c++17 c++20 c++2b)' \
  '--clang-delta-preserve-routine=[preserve routine name]:name:' \
  '--pass-group=[pass group]:group:(opencl-120 delta binary all)' \
  '--pass-group-file=[pass group file]:file:_files' \
  '--log-level=[log level]:level:(INFO DEBUG WARNING ERROR)' \
  '--log-file=[log file]:file:_files' \
  '--no-cache[disable cache]' \
  '--no-timing[disable timing]' \
  '--timestamp[show timestamps]' \
  '--max-improvement=[max improvement bytes]:bytes:' \
  '--also-interesting=[additional interesting exit code]:code:' \
  '--debug[debug mode]' \
  '--die-on-pass-bug[abort on pass bug]' \
  '--skip-key-off[skip key-off prompt]' \
  '--no-give-up[do not give up]' \
  '--skip-after-n-transforms=[skip after N transforms]:n:' \
  '--list-passes[list available passes]' \
  '(-c --commands)'{-c+,--commands=}'[comma-separated commands]:commands:' \
  '(-s --skip-interestingness-test-check)'{-s,--skip-interestingness-test-check}'[skip check]' \
  '--renaming[enable renaming]' \
  '--to-utf8[convert to UTF-8]' \
  '1:interestingness test script:_files' \
  '*:files to reduce:_files' && ret=0

return ret
