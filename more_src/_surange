#compdef surange
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/surange.c
# SURANGE - get max and min values for non-zero header entries

local ret=1

_arguments -s -S \
  'key=[header key(s) to range (default all)]:k:' \
  'dim=[dim seismic flag]:d:(0 1 2 3)' \
  '*:SU file:_files' && ret=0

return ret
