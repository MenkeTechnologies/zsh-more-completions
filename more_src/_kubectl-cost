#compdef kubectl-cost

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-n --namespace)'{-n,--namespace}'=[Namespace]:namespace:' \
  '(-k --kubeconfig)'{-k,--kubeconfig}'=[Kubeconfig path]:file:_files' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      allocation:'show allocation costs'
      assets:'list cluster assets'
      cloud:'cloud integration commands'
      namespace:'namespace cost breakdown'
      deployment:'deployment cost breakdown'
      controller:'controller cost breakdown'
      label:'label cost breakdown'
      version:'print version'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
