#compdef ncgen

_arguments -s \
  '-1[classic]' \
  '-3[netCDF3 classic]' \
  '-4[netCDF4 HDF5]' \
  '-5[netCDF5]' \
  '-6[64-bit offset]' \
  '-7[netCDF4 classic-model]' \
  '-b[binary .nc output]' \
  '-c[generate C source]' \
  '-d[debug level 1]' \
  '-D[debug level]:level:' \
  '-f[FORTRAN 77 source]' \
  '-h[help]' \
  '-H[header only]' \
  '-k[output kind]:kind:(classic nc3 nc6 cdf5 nc5 nc4 nc7)' \
  '-l[output language]:lang:(c f77 java b)' \
  '-L[log level]:level:' \
  '-M[main function name]:name:' \
  '-N[dataset name]:name:' \
  '-o[output file]:file:_files' \
  '-P[NC_DISKLESS]' \
  '-x[skip fill init]' \
  '-W[size threshold]:n:' \
  '*:cdl file:_files -g "*.cdl"'
