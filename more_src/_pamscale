#compdef pamscale
# Documentation: man pamscale (Netpbm)
# Source: Netpbm pamscale — scale a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-xyfit -xyfill -xysize)-xyfit[scale to fit cols×rows preserving aspect]' \
    '(-xyfit -xyfill -xysize)-xyfill[scale to fill cols×rows preserving aspect]' \
    '(-xyfit -xyfill -xysize)-xysize[scale to exactly cols×rows (legacy)]' \
    '-reduce=[integer reduction factor]:factor:' \
    '(-xsize -width -xscale)-xsize=[output cols]:cols:' \
    '(-xsize -width -xscale)-width=[output cols (alias for -xsize)]:cols:' \
    '(-xsize -width -xscale)-xscale=[X scale factor]:factor:' \
    '(-ysize -height -yscale)-ysize=[output rows]:rows:' \
    '(-ysize -height -yscale)-height=[output rows (alias for -ysize)]:rows:' \
    '(-ysize -height -yscale)-yscale=[Y scale factor]:factor:' \
    '-pixels=[target pixel count]:n:' \
    '(-nomix -filter)-nomix[do not mix neighbor samples]' \
    '(-nomix -filter)-filter=[filter function]:functionName:(point box triangle quadratic cubic catrom mitchell gauss sinc bessel hanning hamming blackman kaiser normal hermite lanczos)' \
    '-window=[window function (for filter)]:functionName:(hanning hamming blackman kaiser normal)' \
    '-linear[work in linear (not gamma-corrected) space]' \
    '-reportonly[only report what would be done]' \
    '-verbose[print progress messages]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:scale factor (or cols rows) and PNM file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
