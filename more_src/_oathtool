#compdef oathtool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--hotp[use event-based HOTP]' \
  '--totp=[use time-based TOTP]:hash:(sha1 sha256 sha512)' \
  '-b[decode base32 encoded secret]' \
  '--base32[decode base32 encoded secret]' \
  '-c[HOTP counter value]:counter' \
  '--counter=[HOTP counter value]:counter' \
  '-s[TOTP time step in seconds]:seconds' \
  '--time-step-size=[TOTP time step in seconds]:seconds' \
  '-S[TOTP start time]:time' \
  '--start-time=[TOTP start time]:time' \
  '-N[use specific time as current time]:time' \
  '--now=[use specific time as current time]:time' \
  '-d[number of digits in OTP]:digits:(6 7 8)' \
  '--digits=[number of digits in OTP]:digits:(6 7 8)' \
  '-w[window of counter values to test]:window' \
  '--window=[window of counter values to test]:window' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '1:secret key' && ret=0

return ret