#compdef metaflac libflac flac-libs flacencoder flacdecoder
# _libflac — Xiph.Org FLAC reference Free Lossless Audio Codec metaflac utility for inspecting and modifying FLAC metadata (xiph team, C); getopt
# upstream: https://github.com/xiph/flac

_libflac() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '--list[list metadata blocks]' \
        '--append[append metadata block]' \
        '--remove[remove metadata block]' \
        '--block-number=+[N]:n:' \
        '--block-type=+[type]:t:(STREAMINFO PADDING APPLICATION SEEKTABLE VORBIS_COMMENT CUESHEET PICTURE)' \
        '--except-block-type=+[type]:t:(STREAMINFO PADDING APPLICATION SEEKTABLE VORBIS_COMMENT CUESHEET PICTURE)' \
        '--remove-all[remove all metadata blocks]' \
        '--remove-all-tags[remove all tags]' \
        '--remove-tag=+[name]:str:' \
        '--remove-first-tag=+[name]:str:' \
        '--set-tag=+[name=value]:str:' \
        '--set-tag-from-file=+[name=file]:str:' \
        '--import-tags-from=+[file]:file:_files' \
        '--export-tags-to=+[file]:file:_files' \
        '--import-cuesheet-from=+[file]:file:_files -g "*.cue"' \
        '--export-cuesheet-to=+[file]:file:_files -g "*.cue"' \
        '--import-picture-from=+[spec]:str:' \
        '--export-picture-to=+[file]:file:_files -g "*.jpg *.jpeg *.png *.bmp *.gif"' \
        '--add-seekpoint=+[spec]:str:' \
        '--add-replay-gain[add ReplayGain]' \
        '--scan-replay-gain[scan ReplayGain]' \
        '--remove-replay-gain[remove ReplayGain]' \
        '--add-padding=+[bytes]:n:' \
        '--with-filename[print with filename]' \
        '--no-utf8-convert[no UTF-8 convert]' \
        '--dont-use-padding[no padding]' \
        '--no-cued-seekpoints[no cued seekpoints]' \
        '--data-format=+[format]:f:(binary binary-headerless application)' \
        '*:FLAC file:_files -g "*.flac *.oga"'
}

_libflac "$@"
