#compdef rd rundeck-cli

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run a job'
  'jobs:job operations'
  'projects:project operations'
  'executions:execution operations'
  'system:system operations'
  'tokens:API token operations'
  'scheduler:scheduler operations'
  'keys:key storage operations'
  'repo:plugin repository operations'
  'plugins:plugin operations'
  'nodes:node operations'
  'schedulestate:scheduler state'
  'nodemanagement:node management'
  'healthcheck:run health check'
  'retry:retry an execution'
  'follow:follow execution output'
  'abort:abort an execution'
  'kill:kill an execution'
  'queue:list queued executions'
  'adhoc:run an ad-hoc command'
  'users:user operations'
  'metrics:metrics operations'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rd subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (jobs)
        _values 'jobs action' \
          'list' 'info' 'load' 'purge' 'forecast' \
          'enable' 'disable' 'enableschedule' 'disableschedule' 'files' && ret=0
        ;;
      (projects)
        _values 'projects action' \
          'list' 'info' 'create' 'delete' 'configure' 'archives' 'acls' && ret=0
        ;;
      (executions)
        _values 'executions action' \
          'query' 'info' 'delete' 'deletebulk' 'follow' && ret=0
        ;;
      (tokens)
        _values 'tokens action' \
          'create' 'list' 'info' 'reveal' 'delete' && ret=0
        ;;
      (system)
        _values 'system action' \
          'info' 'acls' 'mode' 'logstorage' 'executions' && ret=0
        ;;
      (keys)
        _values 'keys action' \
          'create' 'update' 'delete' 'list' 'get' && ret=0
        ;;
      (nodes)
        _values 'nodes action' 'list' 'info' && ret=0
        ;;
      (scheduler)
        _values 'scheduler action' 'jobs' 'takeover' && ret=0
        ;;
      (repo)
        _values 'repo action' \
          'list' 'install' 'uninstall' 'upload' 'list-installed' && ret=0
        ;;
      (plugins)
        _values 'plugins action' 'list' 'info' && ret=0
        ;;
      (users)
        _values 'users action' 'list' 'info' 'modify' 'roles' && ret=0
        ;;
      (metrics)
        _values 'metrics action' 'list' 'data' 'healthcheck' 'metrics' 'ping' 'threads' && ret=0
        ;;
    esac
    ;;
esac

return ret
