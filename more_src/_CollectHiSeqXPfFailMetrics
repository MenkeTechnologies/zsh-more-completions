#compdef CollectHiSeqXPfFailMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectHiSeqXPfFailMetrics
# Picard: classify PF-failing reads from a HiSeq X run by failure mode

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  '--BASECALLS_DIR=[Illumina basecalls directory]:dir:_files -/' \
  {-O=,--OUTPUT=}'[basename for the metrics file]:basename:' \
  '--PROB_EXPLICIT_READS=[fractional probability of PF-failed reads to output]:float:' \
  '--LANE=[lane number]:int:' \
  '--NUM_PROCESSORS=[number of parallel processors to run]:int:' \
  '--N_CYCLES=[number of cycles to look at]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:directory:_files -/' && ret=0

return ret
