#compdef startree
# Documentation: http://astrometry.net/doc/build-index.html
# build a star kdtree from a FITS reference catalog

local ret=1

_arguments -s \
  '-h[show help]' \
  '-i+[input FITS catalog name]:input:_files' \
  '-o+[output star-kdtree name]:output:_files' \
  '-R+[name of RA column in FITS table (default RA)]:ra column:' \
  '-D+[name of DEC column in FITS table (default DEC)]:dec column:' \
  '-b[build bounding boxes (default: splitting planes)]' \
  '-L+[number of points in a kdtree leaf node (default 25)]:nleaf:' \
  '-t+[tree type]:tree type:(double float u32 u16)' \
  '-d+[data type]:data type:(double float u32 u16)' \
  '-S[include separate splitdim array]' \
  '-c[run kdtree_check on the resulting tree]' \
  '-P[unpermute tree + tag-along data]' \
  '-T[write tag-along table as first extension HDU]' \
  '-k[keep RA,Dec columns in tag-along table]' \
  '-n+[kd-tree name (default "stars")]:name:' \
  '-v[verbose]' && ret=0

return ret
