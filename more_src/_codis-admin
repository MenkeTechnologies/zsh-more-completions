#compdef codis-admin
# Documentation: https://github.com/CodisLabs/codis/blob/master/cmd/admin/main.go
# Codis admin CLI — control Codis proxies and dashboard

local ret=1

_arguments -s -S \
  '-v[verbose output]' \
  '--proxy=[proxy address to operate on]:addr:' \
  '--dashboard=[dashboard address to operate on]:addr:' \
  '--auth=[auth token for the proxy]:auth:' \
  '--start[start the proxy]' \
  '--shutdown[shut down the proxy or dashboard]' \
  '--reload[reload dashboard config]' \
  '--reset-stats[reset proxy stats]' \
  '--forcegc[force garbage collection on the proxy]' \
  '--log-level=[set the log level]:level:(INFO WARN DEBUG ERROR)' \
  '--fillslots=[fill slots from a file]:file:_files' \
  '--locked[mark slots as locked when filling]' \
  '--slots-assign[assign a range of slots]' \
  '--slots-status[show slots status]' \
  '--list-proxy[list proxies]' \
  '--create-proxy[create a proxy]' \
  '--online-proxy[bring a proxy online]' \
  '--remove-proxy[remove a proxy]' \
  '--reinit-proxy[reinitialize a proxy]' \
  '--proxy-status[show proxy status]' \
  '--list-group[list groups]' \
  '--create-group[create a group]' \
  '--remove-group[remove a group]' \
  '--resync-group[resync a group]' \
  '--group-add[add a server to a group]' \
  '--group-del[remove a server from a group]' \
  '--group-status[show group status]' \
  '--replica-groups[enable/disable replica groups]' \
  '--promote-server[promote a server in a group]' \
  '--sync-action[create or remove a sync action]' \
  '--slot-action[create or remove a slot action]' \
  '--rebalance[rebalance slots across groups]' \
  '--sentinel-add[add a sentinel]' \
  '--sentinel-del[remove a sentinel]' \
  '--addr=[server/proxy/sentinel address]:addr:' \
  '--token=[proxy token]:token:' \
  '--pid=[proxy pid]:pid:' \
  '--gid=[group id]:gid:' \
  '--sid=[slot id]:sid:' \
  '--beg=[begin slot id]:id:' \
  '--end=[end slot id]:id:' \
  '--gid-from=[source group id]:id:' \
  '--gid-to=[destination group id]:id:' \
  '--num-slots=[number of slots]:n:' \
  '--datacenter=[datacenter label]:dc:' \
  '--interval=[slot action interval]:value:' \
  '--disabled=[slot action disabled flag]:value:' \
  '--all[apply to all]' \
  '--enable[enable]' \
  '--disable[disable]' \
  '--offline[mark offline]' \
  '--create[create]' \
  '--remove[remove]' \
  '--force[force the operation]' \
  '--confirm[confirm a destructive operation]' \
  '*::action:(config model stats slots group proxy)' && ret=0

return ret
