#compdef bloaty

# Zsh completion for Bloaty McBloatface - binary size profiler

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*-d+[data sources to scan (comma-separated)]:sources:(compileunits inputfiles sections segments symbols armembers inlines)' \
  '-n+[maximum number of rows to show]:rows' \
  '--debug-file=[file with separate debug info]:file:_files' \
  '-s+[sort by]:order:(vm file both)' \
  '-w[wide output mode]' \
  '--demangle=[demangle mode]:mode:(short full none)' \
  '--disassemble=[disassemble specified function]:function name' \
  '--domain=[show sizes from domain]:domain:(vm file both)' \
  '--source-filter=[show only sources matching regex]:regex' \
  '--raw-map[output raw memory map]' \
  '--csv[output in CSV format]' \
  '--tsv[output in TSV format]' \
  '-c+[use custom data source config file]:config file:_files' \
  '*:binary file:_files' && ret=0

return ret
