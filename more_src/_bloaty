#compdef bloaty

# Zsh completion for Bloaty McBloatface - binary size profiler

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-d+[data sources to scan]:sources:(compileunits inputfiles inlines sections segments symbols)' \
  '--domain=[data sources to scan]:sources:(compileunits inputfiles inlines sections segments symbols)' \
  '-n+[maximum number of rows]:rows' \
  '--num=[maximum number of rows]:rows' \
  '-s+[sort order]:order:(vm file both)' \
  '--sort=[sort order]:order:(vm file both)' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-w[wide output]' \
  '--wide[wide output]' \
  '--csv[output CSV format]' \
  '--tsv[output TSV format]' \
  '-c+[use custom data source config]:config file:_files' \
  '--config=[use custom data source config]:config file:_files' \
  '--debug-file=[debug info file for analysis]:file:_files' \
  '--raw-map=[output a raw memory map]:file:_files' \
  '--source-filter=[show only sources matching regex]:regex' \
  '--dump-raw-map[dump raw map to stdout]' \
  '--list-sources[list available data sources]' \
  '*:binary file:_files' && ret=0

return ret
