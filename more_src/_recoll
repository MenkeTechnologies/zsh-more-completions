#compdef recoll

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c[configuration directory]:dir:_directories' \
  '--config[configuration directory]:dir:_directories' \
  '-q[query string]:query' \
  '--query[query string]:query' \
  '-t[do not start GUI, use command line]' \
  '--no-gui[do not start GUI, use command line]' \
  '-l[language for stemming]:language' \
  '--language[language for stemming]:language' \
  '-a[all terms must match (AND logic)]' \
  '--all[all terms must match (AND logic)]' \
  '-o[any terms may match (OR logic)]' \
  '--or[any terms may match (OR logic)]' \
  '-f[filter by file type]:mime type' \
  '--filter[filter by file type]:mime type' \
  '-d[date range]:date range' \
  '--date[date range]:date range' \
  '-s[sort by field]:field:(relevancy date filename size)' \
  '--sort[sort by field]:field:(relevancy date filename size)' \
  '-S[ascending sort]' \
  '--sortasc[ascending sort]' \
  '-D[descending sort]' \
  '--sortdesc[descending sort]' \
  '-n[maximum number of results]:count' \
  '--results[maximum number of results]:count' \
  '-i[index immediately, then search]' \
  '--index[index immediately, then search]' \
  '-m[monitor indexing]' \
  '--monitor[monitor indexing]' \
  '-w[output snippet context words]:count' \
  '--context[output snippet context words]:count' \
  '-e[open first result URL]' \
  '-b[raw output]' \
  '--raw[raw output]' \
  '-p[print results as table]' \
  '--table[print results as table]' \
  '*:query terms:' && ret=0

return ret