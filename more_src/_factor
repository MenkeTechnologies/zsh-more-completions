#compdef factor
# Documentation: factor --help (GNU coreutils)
# Source: GNU coreutils factor — print prime factors of integers.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --exponents)'{-h,--exponents}'[print repeated factors as p^e]' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '*:integer:' \
    && ret=0

return ret
