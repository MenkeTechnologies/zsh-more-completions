#compdef swift-get-nodes
# Documentation: https://man.archlinux.org/search?q=swift-get-nodes
# Reference accessed: 2026-05-16

# swift-get-nodes: show storage nodes for a path
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-a[print all available nodes]' \
  '--all[print all available nodes]' \
  '-q[quiet (no fadvise)]' \
  '--quiet[quiet (no fadvise)]' \
  '-p[partition]:n:' \
  '--partition=[partition]:n:' \
  '-d[swift_dir]:dir:_files -/' \
  '--swift-dir=[swift_dir]:dir:_files -/' \
  '-P[storage policy name]:name:' \
  '--policy-name=[storage policy name]:name:' \
  '*:ring file / path:_files' && ret=0
return ret
