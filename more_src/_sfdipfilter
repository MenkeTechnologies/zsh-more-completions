#compdef sfdipfilter
# Documentation: https://github.com/ahay/src/blob/master/system/generic/Mdipfilter.c
# Madagascar: filter data based on dip in 2-D or 3-D

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'dim=[dimensionality: filter 2-D planes or 3-D cubes]:dim:(2 3)' \
  'angle=[filter based on angle (or velocity)]:flag:(y n)' \
  'v=[constant velocity (if angle=y)]:velocity' \
  'ang1=[angle gate (in degrees)]:degrees' \
  'ang2=[angle gate (in degrees)]:degrees' \
  'ang3=[angle gate (in degrees)]:degrees' \
  'ang4=[angle gate (in degrees)]:degrees' \
  'v1=[velocity gate]:velocity' \
  'v2=[velocity gate]:velocity' \
  'v3=[velocity gate]:velocity' \
  'v4=[velocity gate]:velocity' \
  'pass=[pass or reject band]:flag:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
