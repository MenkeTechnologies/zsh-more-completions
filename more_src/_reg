#compdef reg
# Documentation: https://github.com/genuinetools/reg
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above.
# Fixed subcommands: `list`/`remove` replaced with documented `ls`/`rm`.
# Added missing `version` subcommand.

# genuinetools/reg — Docker registry v2 client

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-k --insecure)'{-k,--insecure}'[do not verify TLS certificates]' \
  '(-f --force-non-ssl)'{-f,--force-non-ssl}'[force allow non-SSL]' \
  '--skip-ping[skip registry ping during connect]' \
  '--timeout=[HTTP client timeout]:duration:' \
  '--auth-url=[registry auth base URL]:url:' \
  '(-u --username)'{-u+,--username=}'[registry username]:user:' \
  '(-p --password)'{-p+,--password=}'[registry password]:password:' \
  '-d[debug logging]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'reg command' compadd -- digest layer ls manifest rm server tags vulns version
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
