#compdef reg

# genuinetools/reg — global flags `main.go`; subcommands digest/layer/list/manifest/remove/server/tags/vulns

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '-k[do not verify TLS certificates]' \
  '--insecure[do not verify TLS certificates]' \
  '-f[force allow non-SSL]' \
  '--force-non-ssl[force allow non-SSL]' \
  '--skip-ping[skip registry ping during connect]' \
  '--timeout=[HTTP client timeout]:duration:' \
  '--auth-url=[token auth base URL]:url:' \
  '-u+[registry username]:user:' \
  '-p+[registry password]:password:' \
  '-d[debug logging]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'reg command' compadd -- digest layer list manifest remove server tags vulns
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
