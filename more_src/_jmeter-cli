#compdef jmeter
# Documentation: https://jmeter.apache.org/usermanual/get-started.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-?[show help]' \
  '-v[show version]' \
  '-n[non-GUI mode]' \
  '-t+[test plan file]:file:_files -g "*.jmx"' \
  '-l+[log results to file]:file:_files -g "*.jtl"' \
  '-j+[jmeter log file]:file:_files' \
  '-r[run remote slaves]' \
  '-R+[remote slaves csv]:list:' \
  '-X[stop remotes after run]' \
  '-H+[proxy host]:host:_hosts' \
  '-P+[proxy port]:port:' \
  '-N+[non-proxy hosts]:list:' \
  '-u+[proxy user]:user:_users' \
  '-a+[proxy password]:p:' \
  '-J+[k=v JMeter property]:v:' \
  '-G+[k=v global property]:v:' \
  '-D+[k=v Java system property]:v:' \
  '-S+[properties file]:file:_files -g "*.properties"' \
  '-q+[additional properties file]:file:_files -g "*.properties"' \
  '-d+[home dir]:dir:_files -/' \
  '-L+[loglevel category=level]:l:' \
  '-i+[jmeter.log]:file:_files' \
  '-s[server mode]' \
  '-e[generate dashboard report after run]' \
  '-o+[output report dir]:dir:_files -/' \
  '-f[force overwrite]' \
  '-Z+[server engine port]:port:' \
  '-X[exit on error]' \
  '*: :_files' && ret=0

return ret
