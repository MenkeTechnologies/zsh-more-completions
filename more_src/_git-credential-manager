#compdef git-credential-manager

# Zsh completion for git-credential-manager - Git Credential Manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'get:fill a credential request'
      'store:store a credential'
      'erase:erase a stored credential'
      'configure:configure GCM as Git credential helper'
      'unconfigure:remove GCM as Git credential helper'
      'diagnose:run diagnostic checks'
      'github:manage GitHub authentication'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    case "$words[1]" in
      configure|unconfigure)
        _arguments -s -S \
          '--system[configure for the system]' \
          '--global[configure for the current user]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      diagnose|get|store|erase|github)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
