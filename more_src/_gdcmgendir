#compdef gdcmgendir
# Documentation: https://gdcm.sourceforge.net
# Source: malaterre/GDCM Applications/Cxx/gdcmgendir.cxx — generate DICOMDIR (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input)'{-i+,--input=}'[input DICOM file or directory]:file:_files' \
    '(-o --output)'{-o+,--output=}'[output DICOM file or directory]:file:_files' \
    '(-r --recursive)'{-r,--recursive}'[recursive]' \
    '--descriptor=[descriptor]:desc:_default' \
    '--root-uid=[Root UID]:uid:_default' \
    '(-V --verbose)'{-V,--verbose}'[verbose]' \
    '(-W --warning)'{-W,--warning}'[print warnings]' \
    '(-D --debug)'{-D,--debug}'[print debug info]' \
    '(-E --error)'{-E,--error}'[print errors]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version]' \
    '*:DICOM file:_files' \
    && ret=0

return ret
