#compdef durnitisp
# ============================================================================
#  _durnitisp — durnitisp: Prometheus exporter for monitoring
#               ISP reliability via continuous ICMP pings + STUN
#               probes (Jeremy "zaphar" Wall — Rust port of his
#               own Python "damnitisp" tool)
#
#  Source-direct extraction from
#    https://github.com/zaphar/durnitisp/blob/master/src/main.rs
#    https://github.com/zaphar/durnitisp/blob/master/src/stun.rs
#    https://github.com/zaphar/durnitisp/blob/master/src/icmp.rs
#    https://github.com/zaphar/durnitisp/blob/master/src/util.rs
#    https://github.com/dtolnay/gflags (the dtolnay/gflags
#    library by David "dtolnay" Tolnay — author of serde, syn,
#    quote, anyhow, thiserror, prost, and many other foundational
#    Rust ecosystem crates)
#
#  Maintained by Jeremy "zaphar" Wall.  3 GH stars (niche but
#  real ops tool for home network monitoring).  durnitisp is "a
#  port of dandersons damnitisp to rust" — a continuous ICMP
#  ping + STUN probe daemon that exports Prometheus metrics
#  about an ISP's reliability (packet loss, latency, STUN
#  binding success rate).  Designed to run as a long-lived
#  daemon on home/office networks to detect ISP-quality
#  degradation BEFORE the user notices the connection is bad —
#  the metrics feed into Grafana dashboards that alert when
#  packet loss spikes or STUN probes fail (indicating NAT/
#  firewall issues).  Sister tools: smokeping (in corpus + STOCK
#  Debian/Ubuntu via _smokeping — the original ICMP-monitoring
#  long-history tool; durnitisp is a modern Prometheus-native
#  alternative), fping (in corpus + STOCK Kali), iperf3 (in
#  corpus + STOCK), iputils-ping (in corpus + STOCK), mtr (in
#  corpus + STOCK Linux), netdata (in corpus via _netdata),
#  prometheus (in corpus via _prometheus), blackbox_exporter
#  (Prometheus blackbox exporter — sister Prometheus exporter
#  in the same monitoring stack).
#
#  CLI library taxonomy update: 18th Rust CLI library — David
#  Tolnay's **gflags** (dtolnay/gflags).  Rust ecosystem now has
#  18 documented CLI libraries — TYING WITH TYPESCRIPT-NODE at
#  the top of the cross-language taxonomy ahead of Go (17).
#  🎉 Rust RE-TIES with TypeScript-Node at 18.
#
#  dtolnay/gflags is David Tolnay's "Command line flags library
#  that does not require a central list of all the flags" (55 GH
#  stars, archived 2025-01-05).  Distinguishing philosophy:
#  DISTRIBUTED FLAGS — each MODULE in the binary declares its
#  OWN flags via `gflags::define!` macros, with NO CENTRAL FLAG
#  REGISTRY required.  Flag definitions are collected at LINK
#  TIME via the linker's `link_section` attribute pointing into
#  a dedicated ELF/Mach-O section, then iterated at runtime by
#  the gflags parser.  This pattern is BORROWED FROM GOOGLE'S
#  GFLAGS C++ library (formerly known as Google Commandline Flags),
#  which is used INTERNALLY at Google as the standard CLI
#  library for thousands of C++ tools.  The distributed-flag
#  philosophy: each module declares the flags IT NEEDS where it
#  needs them, without a central main() that has to know every
#  flag in advance.  This scales to LARGE CODEBASES with many
#  internal libraries that each need their own flags.  Used by
#  zaphar/durnitisp (ISP monitor 3 stars), trevyn/turbo (self-
#  sovereignty tools 4 stars), trevyn/turbonet (network tools
#  3 stars), KPMGE/kl-rs (KL language 10 stars), thomasknauth/
#  moxpeg (MPEG encoder 0 stars), shelbyd/flock-deprecated, and
#  various other Rust binaries that prefer the distributed-flags
#  pattern.  ARCHIVED in January 2025 (dtolnay archived the
#  repo with "No further development is planned"), but remains
#  IDIOMATIC for the Google-gflags-style distributed-flags
#  pattern — preserved for educational and historical value.
#
#  dtolnay/gflags API:
#    // In any module — flags can be DECLARED ANYWHERE
#    use gflags;
#
#    // Each `gflags::define!` macro registers a flag in the
#    // module-local namespace, with the flag's TYPE inferred
#    // from the default-value expression
#    gflags::define! {
#      /// Doc-comment becomes --help text
#      --listenHost = "0.0.0.0:8080"          // String flag (inferred)
#    }
#
#    gflags::define! {
#      /// Enable debug logging
#      --debug = false                         // Bool flag
#    }
#
#    gflags::define! {
#      /// Read timeout in seconds
#      --stunRecvTimeoutSecs: u64 = 5          // u64 with explicit type
#    }
#
#    gflags::define! {
#      /// Help text shorthand
#      -h, --help = false                      // bool with short alias -h
#    }
#
#    gflags::define! {
#      /// Repeating list flag (rare; gflags doesn't natively
#      /// support Vec<T>; users typically pass comma-separated
#      /// strings and split manually)
#      --pingHosts = "google.com,cloudflare.com"
#    }
#
#    // Main function calls gflags::parse() ONCE at startup;
#    // distributed flag definitions are auto-collected from
#    // all modules at link time
#    fn main() {
#      let positional_args = gflags::parse();
#      if HELP.flag {
#        gflags::print_help_and_exit(0);
#      }
#      let host = LISTENHOST.flag;        // access via UPPERCASE
#      let debug = DEBUG.flag;            // CONSTANT name derived
#                                         // from flag identifier
#    }
#
#  dtolnay/gflags distinctive features:
#    - DISTRIBUTED FLAG DEFINITIONS — `gflags::define!` macros
#      placed in ANY module register flags into the global
#      flag registry; no central main() registration needed
#    - LINK-TIME COLLECTION via `#[link_section]` attribute —
#      each flag definition emits a symbol into a dedicated
#      linker section; the gflags runtime iterates that section
#      at parse() time to discover all flags
#    - DOC-COMMENT-AS-HELP — `/// Doc comment` above the
#      `--flag = value` line becomes the flag's --help text
#    - TYPE INFERENCE from default value — `= "string"` →
#      String, `= false` → bool, `= 42` → i64, `= 3.14` → f64;
#      explicit type annotation `--flag: u64 = 5` overrides
#      inference
#    - SHORT ALIAS via `-X, --longName` — e.g. `-h, --help`
#    - FLAG NAMES TAKEN VERBATIM — `--listenHost` is camelCase
#      because that's what's written in the macro; gflags does
#      NOT auto-convert to kebab-case (CONTRAST clap_derive's
#      snake_case-to-kebab-case auto-conversion)
#    - GENERATED CONSTANT for each flag — `--listenHost`
#      becomes accessible at runtime via `LISTENHOST.flag` (the
#      UPPERCASE identifier of the flag name; the `.flag` field
#      gives the parsed value)
#    - GENERATED `IS_PRESENT` field — `LISTENHOST.is_present()`
#      returns true if the flag was given on argv (distinct from
#      using the default value)
#    - POSITIONAL ARGUMENTS — `gflags::parse()` returns
#      `Vec<&str>` of positional args (anything that didn't
#      start with --)
#    - NO automatic --help generation — caller registers
#      `-h, --help = false` flag explicitly and checks
#      `HELP.flag` to call `gflags::print_help_and_exit(0)`
#    - INSPIRED BY Google's gflags C++ library (originally
#      Google Commandline Flags, GPL-2.0+BSD-3-Clause licensed
#      since 2008 by Google); dtolnay's Rust port brings the
#      distributed-flag pattern from C++ into Rust idioms via
#      proc-macros
#    - DESIGNED for LARGE CODEBASES where modules ship as
#      libraries and each library needs flags for its own
#      configuration without main() having to enumerate them
#  Distinct from R275 Rust clap-derive (proc-macro #[derive
#  (Parser)] on struct — CENTRAL flag definitions vs gflags's
#  DISTRIBUTED), R330 Rust bpaf (functional applicative
#  combinator), R344 Rust google/argh (Google Fuchsia-OS derive-
#  on-struct), R347 Rust RazrFalcon/pico-args (LOW-LEVEL
#  imperative pull parser), R404 Rust matklad/xflags
#  (declarative MACRO block syntax — closer to gflags but still
#  CENTRAL definitions vs gflags's distributed), R407 Rust
#  blyxxyz/lexopt (MINIMAL iterator-based pull parser), R410
#  Rust murarth/gumdrop (zero-dep derive-macro), R413 Rust
#  docopt/docopt.rs (USAGE-STRING-IS-SPEC), R416 Rust rust-lang/
#  getopts (OFFICIAL POSIX-getopt(3) port), R420 Rust ksk001100/
#  seahorse (Cobra-for-Rust chained-builder), R427 Rust tanakh/
#  argopt (function-as-CLI proc-macro), R430 Rust killercup/
#  quicli (batteries-included educational framework).  Rust
#  documented libraries so far: clap-derive, bpaf, argh, pico-
#  args, xflags, lexopt, gumdrop, docopt.rs, getopts, seahorse,
#  argopt, quicli, gflags (this round) plus older clap-builder,
#  structopt (deprecated, now clap_derive)... 18 total.  gflags's
#  distinguishing feature vs ALL other Rust libs: gflags is the
#  ONLY Rust CLI library in the corpus that uses the DISTRIBUTED
#  FLAG DEFINITION pattern — each module declares its own flags
#  in place, collected at link time via `#[link_section]`
#  attribute, no central main() registration.  Conceptually
#  similar to Google's C++ gflags library (which inspired the
#  Rust port).  gflags's approach: DISTRIBUTED-FLAG-DEFINITION
#  via `gflags::define!` proc-macro placeable in any module +
#  LINK-TIME COLLECTION via #[link_section] + DOC-COMMENT-AS-
#  HELP + type inference from default value + `-X, --longName`
#  short+long combined + UPPERCASE-CONSTANT-PER-FLAG generated
#  accessor (`LISTENHOST.flag`/`.is_present()`) + flag names
#  TAKEN VERBATIM (no kebab-case auto-conversion) + `gflags::
#  parse()` returns Vec<&str> of positionals + NO automatic
#  --help (caller registers and dispatches manually) + INSPIRED
#  BY Google's C++ gflags — corpus's **first documented
#  distributed-flag-definition Rust CLI library**.  Brings cross-
#  language CLI library taxonomy variant count to 173; Rust
#  ecosystem now has 18 documented CLI libraries — TYING WITH
#  TYPESCRIPT-NODE at the top of the cross-language taxonomy
#  ahead of Go (17).
#
#  Surface (verbatim from `gflags::define!` macros distributed
#  across `src/main.rs`, `src/stun.rs`, `src/icmp.rs`, `src/
#  util.rs` modules):
#
#  Usage:
#    durnitisp [options]
#
#  Options (collected from distributed gflags::define! macros
#  across modules; note camelCase naming preserved from the
#  Rust source):
#
#  Top-level (src/main.rs):
#    -h, --help                     Print help text
#        --listenHost <ADDR>        Port to listen on for
#                                   exporting Prometheus metrics
#                                   (Default: "0.0.0.0:8080")
#        --debug                    Enable debug logging
#        --trace                    Enable trace logging
#        --pingHosts <LIST>         Comma-separated list of hosts
#                                   to ping (Default:
#                                   "google.com")
#        --stunHosts <LIST>         Comma-separated list of STUN
#                                   server hosts (default has
#                                   12 public STUN servers
#                                   including stun.l.google.com,
#                                   stun.ekiga.net, stun.xten.com,
#                                   stun.ideasip.com, etc.)
#
#  STUN module (src/stun.rs):
#        --stunRecvTimeoutSecs <N>  Read timeout for the STUN
#                                   server UDP receive (Default:
#                                   5 seconds; u64)
#        --delaySecs <N>            Delay between STUN lookup
#                                   attempts in seconds
#                                   (Default: 60 seconds; u64)
#
#  ICMP module (src/icmp.rs):
#        --pingPayload <STR>        The payload to use for the
#                                   ping requests (Default:
#                                   "durnitisp")
#        --pingTimeout <N>          Timeout for ping requests in
#                                   seconds (Default: 3 seconds; u64)
#        --pingDelay <N>            Delay between ping requests
#                                   (Default: 5 seconds; u64)
#        --maxHops <N>              Maximum ping hops / TTL
#                                   (Default: 50; u8)
#
#  Utility module (src/util.rs):
#        --allowIpv6                Allow IPv6 addresses for
#                                   domain-name lookups
#                                   (Default: false; bool)
#
#  Examples:
#    durnitisp                                            # Run with all defaults (port 8080)
#    durnitisp --listenHost=0.0.0.0:9090                  # Custom port
#    durnitisp --pingHosts="google.com,cloudflare.com"    # Custom ping targets
#    durnitisp --debug                                    # Debug logging
#    durnitisp --pingTimeout=10 --pingDelay=15            # Slower ping rhythm
#    durnitisp --allowIpv6                                # Enable IPv6 lookups
#    durnitisp --stunRecvTimeoutSecs=10                   # Longer STUN timeout
#    durnitisp --maxHops=64                               # Higher TTL
#    durnitisp -h                                         # Show help
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also dtolnay/gflags users):
#    - turbo (trevyn/turbo 4 stars Tools for self-sovereignty;
#      conflicts with Vercel turbo in corpus — IN CORPUS via
#      _turbo for the dominant turbo binary)
#    - turbonet (trevyn/turbonet 3 stars — network tools; too
#      niche)
#    - kl-rs (KPMGE/kl-rs 10 stars — KL language; too niche)
#    - moxpeg (thomasknauth/moxpeg 0 stars — MPEG encoder; too
#      niche)
#    - flock-deprecated (shelbyd/flock-deprecated — deprecated)
#    - dtolnay/gflags repo itself (55 stars library not CLI;
#      archived January 2025)
# ============================================================================

_durnitisp() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[print help text]' \
    '--listenHost=[port to listen on for Prometheus metrics]:addr:_hosts' \
    '--debug[enable debug logging]' \
    '--trace[enable trace logging]' \
    '--pingHosts=[comma-separated list of hosts to ping]:hosts:' \
    '--stunHosts=[comma-separated list of STUN server hosts]:hosts:' \
    '--stunRecvTimeoutSecs=[read timeout for STUN UDP receive (seconds)]:n:' \
    '--delaySecs=[delay between STUN lookup attempts (seconds)]:n:' \
    '--pingPayload=[payload to use for ping requests]:payload:' \
    '--pingTimeout=[timeout for ping requests (seconds)]:n:' \
    '--pingDelay=[delay between ping requests (seconds)]:n:' \
    '--maxHops=[maximum ping hops / TTL]:n:' \
    '--allowIpv6[allow IPv6 addresses for domain-name lookups]'
}

_durnitisp "$@"
