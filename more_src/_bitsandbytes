#compdef bitsandbytes bnb
# _bitsandbytes — Tim Dettmers bitsandbytes CUDA quantization and 8-bit/4-bit optimizer library CLI for inspecting installed CUDA setup verifying GPU quantization (TimDettmers team, Python); argparse
# upstream: https://github.com/TimDettmers/bitsandbytes

_bitsandbytes() {
    local -a sub=(
        'env:show CUDA env info'
        'check-cuda:check CUDA setup'
        'check-install:verify installation'
        'list-modules:list optimizer modules'
        'list-quant-types:list quant types'
        'help:show help'
        'version:show version'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--device=+[d]:d:(auto cpu cuda cuda:0 cuda:1 cuda:2 cuda:3 mps)' \
        '--cuda-version=+[v]:v:(10.2 11.0 11.1 11.2 11.3 11.4 11.5 11.6 11.7 11.8 12.0 12.1 12.2 12.3 12.4)' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bitsandbytes subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_bitsandbytes "$@"
