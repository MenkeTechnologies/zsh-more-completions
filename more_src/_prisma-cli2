#compdef prisma-cli2 prisma2
# _prisma-cli2 — Prisma Inc prisma-cli2 CLI command-line frontend wrapping the Prisma CLI command-line interface for the Prisma ORM and platform open-source written in TypeScript Node next-generation Node.js and TypeScript ORM build modern apps for any database Prisma-ORM-Migrate-Studio-Pulse-Optimize-Accelerate-DataPlatform schema migrate generate studio db format validate init introspect debug version platform sync mcp deploy migrate-resolve migrate-status migrate-diff migrate-reset migrate-mark-applied db-pull db-push db-seed db-execute platform-environment-project-workspace-apikey (Prisma Inc team Søren Bramer Schmidt, TypeScript); commander
# upstream: https://www.prisma.io/

_prisma-cli2() {
    local -a sub=(
        'init:setup a new project'
        'generate:generate Prisma Client'
        'studio:open Prisma Studio'
        'migrate:migration operations'
        'db:database operations'
        'format:format the schema'
        'validate:validate the schema'
        'version:show version'
        'debug:show env info'
        'platform:Prisma Platform operations'
        'mcp:Model Context Protocol commands'
        'help:show help'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--schema=+[file]:file:_files -g "*.prisma"' \
        '--datasource=+[name]:str:' \
        '--datasource-provider=+[p]:p:(sqlite postgresql mysql sqlserver mongodb cockroachdb)' \
        '--db=+[url]:str:' \
        '--url=+[url]:str:' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--accept-data-loss[accept data loss]' \
        '--force-reset[force reset]' \
        '--force[force]' \
        '--create-only[create only]' \
        '--apply[apply pending]' \
        '--applied=+[name]:str:' \
        '--rolled-back=+[name]:str:' \
        '--from-empty[from empty]' \
        '--from-schema-datamodel=+[file]:file:_files' \
        '--from-schema-datasource=+[file]:file:_files' \
        '--from-migrations=+[dir]:dir:_files -/' \
        '--from-url=+[url]:str:' \
        '--to-empty[to empty]' \
        '--to-schema-datamodel=+[file]:file:_files' \
        '--to-schema-datasource=+[file]:file:_files' \
        '--to-migrations=+[dir]:dir:_files -/' \
        '--to-url=+[url]:str:' \
        '--script[script output]' \
        '--shadow-database-url=+[url]:str:' \
        '--exit-code[exit code only]' \
        '--skip-generate[skip generate]' \
        '--skip-seed[skip seed]' \
        '--skip-push[skip push]' \
        '--ignore-env-var-errors[ignore env var errors]' \
        '--data-proxy[data proxy]' \
        '--accelerate[use accelerate]' \
        '--no-engine[no engine]' \
        '--engine-type=+[t]:t:(library binary)' \
        '--no-hints[no hints]' \
        '--allow-no-models[allow no models]' \
        '--print[print]' \
        '--browser=+[name]:str:' \
        '-b+[browser]:str:' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--host=+[host]:_hosts' \
        '--hostname=+[host]:_hosts' \
        '--file=+[file]:file:_files' \
        '-f+[file]:file:_files' \
        '--stdin[read SQL from stdin]' \
        '--output=+[fmt]:f:(json yaml)' \
        '-o+[output]:f:(json yaml)' \
        '--telemetry-information=+[info]:str:' \
        '--watch[watch]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'prisma subcommand' sub ;;
        args)
            case $words[1] in
                migrate) _arguments '1:op:(dev deploy reset resolve status diff mark-applied)' '*:arg:' ;;
                db) _arguments '1:op:(pull push seed execute)' '*:arg:' ;;
                platform) _arguments '1:op:(login logout auth workspace project environment apikey accelerate pulse optimize service-token)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_prisma-cli2 "$@"
