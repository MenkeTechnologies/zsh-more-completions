#compdef tinyprog
# Documentation: https://github.com/tinyfpga/TinyFPGA-Bootloader
# Programmer for TinyFPGA boards using the USB bootloader

local ret=1

_arguments -s -S \
  '--version[print the tinyprog version]' \
  '(-l --list)'{-l,--list}'[list connected and active FPGA boards]' \
  '(-p --program)'{-p,--program}'[program FPGA board with the given user bitstream]:file:_files' \
  '(-u --program-userdata)'{-u,--program-userdata}'[program FPGA board with the given user data]:file:_files' \
  '--program-image[program FPGA board with combined bitstream and data]:file:_files' \
  '(-b --boot)'{-b,--boot}'[command the board to exit the bootloader and load user config]' \
  '(-c --com)'{-c,--com}'[serial port name]:port:_files' \
  '(-i --id)'{-i,--id}'[FPGA board ID]:id' \
  '(-d --device)'{-d,--device}'[device id (vendor:product)]:device' \
  '(-a --addr)'{-a,--addr}'[force the address to write the bitstream to]:addr' \
  '(-m --meta)'{-m,--meta}'[dump metadata for all connected boards in JSON]' \
  '--security[update the security page in the flash at address addr]:addr' \
  '--update-bootloader[check for new bootloader and update eligible boards]' \
  '--libusb[try using libusb to connect without a serial driver]' \
  '--pyserial[use pyserial to connect to boards]' && ret=0

return ret
