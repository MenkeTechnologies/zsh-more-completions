#compdef gpg-card
# Documentation: gpg-card --help on gpg-card (GnuPG) 2.5.20
# Source: GnuPG gpg-card — manage smartcards and security tokens.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'help:list all commands'
    'list:list information about the card'
    'verify:verify the PIN'
    'name:set the name'
    'url:set the URL for public key retrieval'
    'fetch:fetch key via URL'
    'login:set login data'
    'lang:set language preferences'
    'salutation:set salutation'
    'cafpr:set CA fingerprint'
    'forcesig:toggle require-PIN-each-signature'
    'generate:generate a new key on the card'
    'passwd:change a PIN'
    'unblock:unblock the PIN'
    'factory-reset:reset the card to factory defaults'
    'kdf-setup:set up KDF for use with the card'
    'uif:set UIF (User Interaction Flag) for a key'
    'yubikey:Yubikey-specific commands'
    'apdu:send raw APDU to the card'
    'gpg:switch to OpenPGP application'
    'gpgsm:switch to S/MIME application'
    'history:show command history'
    'quit:leave the program'
)

_arguments -C \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-q --quiet)'{-q,--quiet}'[somewhat more quiet]' \
    '--status-fd=[write status info to FD]:fd:' \
    '--no-key-lookup[use --no-key-lookup for "list"]' \
    '--no-history[do not use command history file]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:: :->cmd' \
    && ret=0

case $state in
    cmd)
        _describe -t card-cmds 'gpg-card command' verbs && ret=0
        ;;
esac

return ret
