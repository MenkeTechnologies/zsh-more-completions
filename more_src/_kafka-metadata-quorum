#compdef kafka-metadata-quorum
# Documentation: https://kafka.apache.org/documentation/ (kafka-metadata-quorum.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '(- *)'{-h,--help}'[Show this help message and exit]'
    '--bootstrap-server[Comma-separated list of host:port pairs to connect to the Kafka cluster]:host\:port:'
    '--bootstrap-controller[Comma-separated list of host:port pairs to connect to the Kafka controllers]:host\:port:'
    '--command-config[Property file containing configs to be passed to Admin Client]:file:_files'
    '--status[describe: a short summary of the quorum status]'
    '--replication[describe: detailed information about the status of replication]'
    '--human-readable[describe: human-readable output]'
    '1:command:(describe add-controller remove-controller)'
)

_arguments -s -S $arguments
