#compdef pgbench
# Documentation: https://man.archlinux.org/search?q=pgbench
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --initialize)'{-i,--initialize}'[initialize tables]' \
  '(-I --init-steps)'{-I+,--init-steps=}'[init steps]:steps:' \
  '(-s --scale)'{-s+,--scale=}'[scaling factor]:n:' \
  '(--foreign-keys)--foreign-keys[create foreign keys]' \
  '(-n --no-vacuum)'{-n,--no-vacuum}'[no vacuum]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--unlogged-tables)--unlogged-tables[unlogged tables]' \
  '(--tablespace)--tablespace=[tablespace]:ts:' \
  '(--index-tablespace)--index-tablespace=[index tablespace]:ts:' \
  '(--partition-method)--partition-method=[partition method]:m:(range hash)' \
  '(--partitions)--partitions=[partitions]:n:' \
  '(-c --client)'{-c+,--client=}'[clients]:n:' \
  '(-j --jobs)'{-j+,--jobs=}'[threads]:n:' \
  '(-t --transactions)'{-t+,--transactions=}'[transactions per client]:n:' \
  '(-T --time)'{-T+,--time=}'[run for seconds]:s:' \
  '(-S --select-only)'{-S,--select-only}'[SELECT only]' \
  '(-N --skip-some-updates)'{-N,--skip-some-updates}'[skip some updates]' \
  '(-r --report-per-command)'{-r,--report-per-command}'[report per cmd]' \
  '*'{-D+,--define=}'[set var=val]:var:' \
  '(-l --log)'{-l,--log}'[log per transaction]' \
  '(--log-prefix)--log-prefix=[log prefix]:p:' \
  '(--latency-limit)--latency-limit=[latency limit ms]:ms:' \
  '(--aggregate-interval)--aggregate-interval=[agg interval s]:s:' \
  '(--sampling-rate)--sampling-rate=[sampling rate]:r:' \
  '(--max-tries)--max-tries=[max retry]:n:' \
  '(--failures-detailed)--failures-detailed[detail failures]' \
  '(--show-script)--show-script=[show script]:n:' \
  '(--verbose-errors)--verbose-errors[verbose errors]' \
  '(--exit-on-abort)--exit-on-abort[exit on abort]' \
  '(-f --file)*'{-f+,--file=}'[file weight]:file:_files -g "*.sql"' \
  '(-b --builtin)*'{-b+,--builtin=}'[builtin script]:s:(tpcb-like simple-update select-only)' \
  '(--connect)--connect[connect every txn]' \
  '(--rate)--rate=[rate per sec]:n:' \
  '(--progress)--progress=[progress sec]:s:' \
  '(--protocol)--protocol=[protocol]:p:(simple extended prepared)' \
  '(--random-seed)--random-seed=[seed]:n:' \
  '(--debug)--debug[debug]' \
  '(-h --host)'{-h+,--host=}'[host]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[port]:port:' \
  '(-U --username)'{-U+,--username=}'[user]:user:_users' \
  '(--service)--service=[service]:s:' \
  '*: :' && ret=0

return ret
