#compdef usdresolve
# Documentation: https://openusd.org/release/toolset.html
# Resolves asset paths using a fully configured USD Asset Resolver

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--createContextForAsset[create context from asset path]:asset:_files' \
  '--createContextFromString[create context from configuration string]:string:' \
  '--anchorPath[use specified anchor path for identifier creation]:path:_files' \
  '*:input path:_files' && ret=0

return ret
