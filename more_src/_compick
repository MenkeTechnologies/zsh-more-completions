#compdef compick
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss26.html
# KAPPA: reduces the size of an NDF by picking equally spaced pixels

local ret=1

_arguments -s \
  'IN=[input NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'COMPRESS=[compression factors per axis]:factors' \
  'ORIGIN=[pixel indices of first selected pixel]:origin' \
  'TITLE=[title for the output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
