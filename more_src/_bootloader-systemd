#compdef bootloader-systemd

# bootloader-systemd: distro wrapper around bootctl/systemd-boot
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--install[install systemd-boot to ESP]' \
  '--update[update systemd-boot binaries]' \
  '--remove[remove systemd-boot]' \
  '--status[show boot status]' \
  '*::bootloader-systemd args:_files' && ret=0
return ret
