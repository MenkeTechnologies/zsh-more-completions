#compdef libinput-replay
# Documentation: https://man.archlinux.org/man/libinput-replay.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--once[replay the recording once and exit]' \
  '--replay-after=[wait N seconds before replaying]:seconds:' \
  '1:recording file:_files' && ret=0

return ret
