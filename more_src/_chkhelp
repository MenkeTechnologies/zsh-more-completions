#compdef chkhelp
# Documentation: https://man.archlinux.org/man/chkhelp.1.en
# Check Performance Co-Pilot help text database

local ret=1

_arguments -s -S \
  '-\?[show help]' \
  '-e[report metrics with no help text]' \
  '-H[display verbose help text and exit]' \
  '-i[process all the instance domains]' \
  '-n+[load an alternative PMNS from file]:pmnsfile:_files' \
  '-O[display the one line help summary]' \
  '-p[process all the metrics (PMIDs)]' \
  '-D+[enable additional diagnostic output]:debug' \
  '*:file:_files' && ret=0

return ret
