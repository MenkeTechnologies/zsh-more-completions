#compdef twine-cli
# _twine-cli — PyPA Twine PyPI uploader CLI alias (PyPA, Python); argparse
# upstream: https://github.com/pypa/twine

_twine-cli() {
    local -a sub=(
        'upload:upload distributions'
        'check:check distributions'
        'register:register project'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'twine subcommand' sub ;;
        args)
            case $words[1] in
                upload) _arguments \
                    '--repository=+[repository]:r:' \
                    '-r+[repository]:r:' \
                    '--repository-url=+[repository url]:url:_urls' \
                    '--attestations[include PEP740 attestations]' \
                    '--sign[sign with gpg]' \
                    '-s[sign with gpg]' \
                    '--sign-with=+[sign with program]:str:' \
                    '--identity=+[identity]:str:' \
                    '-i+[identity]:str:' \
                    '--username=+[username]:str:_users' \
                    '-u+[username]:str:_users' \
                    '--password=+[password]:str:' \
                    '-p+[password]:str:' \
                    '--non-interactive[non-interactive]' \
                    '--config-file=+[config file]:file:_files' \
                    '--comment=+[comment]:str:' \
                    '-c+[comment]:str:' \
                    '--skip-existing[skip existing]' \
                    '--cert=+[ssl cert]:file:_files' \
                    '--client-cert=+[client cert]:file:_files' \
                    '--verbose[verbose]' \
                    '--disable-progress-bar[disable progress bar]' \
                    '*:dist:_files -g "*.(whl|tar.gz|zip)"' ;;
                check) _arguments \
                    '--strict[strict]' \
                    '*:dist:_files -g "*.(whl|tar.gz|zip)"' ;;
                register) _arguments \
                    '--repository=+[repository]:r:' \
                    '-r+[repository]:r:' \
                    '--repository-url=+[repository url]:url:_urls' \
                    '--username=+[username]:str:_users' \
                    '-u+[username]:str:_users' \
                    '--password=+[password]:str:' \
                    '-p+[password]:str:' \
                    '--non-interactive[non-interactive]' \
                    '--config-file=+[config file]:file:_files' \
                    '--cert=+[ssl cert]:file:_files' \
                    '--client-cert=+[client cert]:file:_files' \
                    '*:dist:_files' ;;
            esac
            ;;
    esac
}

_twine-cli "$@"
