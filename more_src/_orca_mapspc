#compdef orca_mapspc
# Documentation: https://www.faccts.de/docs/orca/6.0/manual/contents/detailed/utilities.html
# ORCA utility to convert calculated spectra into plottable .dat/.stk files

local ret=1

_arguments -s -S \
  '-o+[output filename]:file:_files' \
  '-cm[use cm^-1 units (default)]' \
  '-eV[use eV units]' \
  '-g[use Gaussian lineshape (default)]' \
  '-l[use Lorentzian lineshape]' \
  '-v[use Voigt lineshape]' \
  '-x0+[initial point of spectrum]:value:' \
  '-x1+[final point of spectrum]:value:' \
  '-w+[line width (FWHM)]:value:' \
  '-q+[Gaussian part line width for Voigt]:value:' \
  '-kw+[coefficient for energy-dependent line width]:value:' \
  '-n+[number of plot points]:value:' \
  '1:output/hess file:_files' \
  '*:spectrum type:(ABS ABSV CD IR VCD RAMAN NRVS VDOS MCD XES XAS XESSOC XASSOC RIXS SOCABS SOCCD)' && ret=0

return ret
