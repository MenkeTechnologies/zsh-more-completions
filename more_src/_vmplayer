#compdef vmplayer
# _vmplayer — VMware Workstation Player (free desktop VMware engine; positional argument is a .vmx file; -X enter VMX maintenance mode, -q quit guest after power-off, -h help, -v version, --version; supports passthrough of standard VMware command-line knobs like -enableDevice, -startState)
# upstream: closed source (Broadcom/VMware)
# Flags from VMware Workstation Player release notes on tip.

_vmplayer() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-X[VMX maintenance mode]' \
        '-q[quit after guest power off]' \
        '1:vmx file:_files -g "*.vmx"'
}

_vmplayer "$@"
