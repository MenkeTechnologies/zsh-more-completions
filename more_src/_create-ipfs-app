#compdef create-ipfs-app
# Documentation: https://github.com/alexbakers/create-ipfs-app#readme
# Reference accessed: 2026-05-24
# Verified: npm view create-ipfs-app bin; GitHub README Params section at the URL above.

# Zsh completion for create-ipfs-app - IPFS web app scaffolder (create-react-app style)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--web3=[Web3.Storage API token]:token:' \
  '--moralis=[Moralis Web3 API key]:key:' \
  '--pinata=[Pinata API key and secret as key:secret]:credentials:' \
  '--filebase=[Filebase key:secret:bucket]:credentials:' \
  ':project name:' && ret=0

return ret
