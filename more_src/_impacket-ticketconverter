#compdef impacket-ticketconverter
# Documentation: https://github.com/fortra/impacket/blob/master/examples/ticketConverter.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-ticketconverter: convert Kerberos tickets between ccache and kirbi formats
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --base64)'{-b,--base64}'[decode input ticket from base64 (with unwrap)]' \
  '1:input file:_files -g "*.(ccache|kirbi)"' \
  '2:output file:_files' && ret=0
return ret
