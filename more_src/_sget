#compdef sget
# Documentation: https://github.com/sigstore/sget
# sigstore safer fetch with Rekor signature verification

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--rm[remove identities from the trusted list]' \
  '--host=[scope trusted identities to a URL hostname]:hostname:' \
  '1:url or oci ref:' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _values 'sget command' \
      'sign[sign a URL and append a record to Rekor]' \
      'trust[add identities to the trusted list]' && ret=0
    ;;
esac

return ret
