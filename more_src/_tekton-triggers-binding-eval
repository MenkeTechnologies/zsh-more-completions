#compdef tekton-triggers-binding-eval binding-eval
# _tekton-triggers-binding-eval — Tekton Triggers TriggerBinding offline evaluator (tektoncd/triggers)
# upstream: https://github.com/tektoncd/triggers
# Flags from cmd/binding-eval/cmd/root.go on tip.

_tekton-triggers-binding-eval() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-b --binding)'{-b,--binding=}'[path to TriggerBinding YAML]:file:_files' \
        '(-r --http_request)'{-r,--http_request=}'[path to HTTP-request fixture]:file:_files'
}

_tekton-triggers-binding-eval "$@"
