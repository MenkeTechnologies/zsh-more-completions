#compdef cxx2flow
# ============================================================================
# cxx2flow - Convert C/C++ code to control-flow flowchart (Rust, MIT)
#
# Author : mgt (Enter-tainer) <mgt@oi-wiki.org>
# Upstream: https://github.com/Enter-tainer/cxx2flow
# crates : cxx2flow (binary: cxx2flow)
#
# `cxx2flow` parses a C or C++ source file with tree-sitter,
# extracts the control-flow graph for a chosen function (or
# `main` by default), and emits the graph in Graphviz DOT,
# d2, or TikZ format. The DOT output is then typically piped
# through `dot -Tsvg` or `dot -Tpng` to produce an actual
# image. Useful for teaching control-flow analysis, code-
# review of complex branching logic, and reverse-engineering
# unfamiliar code.
#
# Pipeline:
#   src.cpp (tree-sitter-cpp) -> AST (tree-sitter)
#         -> per-function statement list (cxx2flow_lib)
#         -> control-flow graph (petgraph DiGraph<Node, Edge>)
#         -> backend render (DOT / d2 / TikZ)
#
# Usage:
#   cxx2flow [options] [<input>] [<function>]
#   cat main.cpp | cxx2flow | dot -Tsvg -o test.svg
#   cxx2flow test.cpp | dot -Tpng -o test.png
#   cxx2flow main.cpp my_custom_func | dot -Tsvg -o test.svg
#
# Flags (clap derive):
#   -o, --output <file>     - output destination (default stdout)
#   -c, --curly             - curly connection-line style
#       --cpp               - run the C preprocessor first
#   -t, --tikz              - emit TikZ instead of DOT
#   -d, --d2                - emit d2 instead of DOT
#       --dump-ast          - dump the parsed AST (debug)
#   -V, --version           - print version + build info
#   -h, --help              - print help
#
# Positional:
#   <input>                 - input file (default: stdin)
#   <function>              - function name to analyze (default: "main")
#
# The petgraph lane is built on `petgraph = "0.8.3"` (declared
# verbatim at upstream Cargo.toml HEAD), the canonical Rust
# graph data-structure + algorithms library by bluss (Ulrik
# Sverdrup) - github.com/petgraph/petgraph, 3400+ stars.
# petgraph is the uncontested Rust graph library: every Rust
# project that needs a typed Graph<N, E>, dijkstra, bellman-
# ford, tarjan-SCC, topological sort, graphviz dot export, or
# isomorphism checking imports petgraph. The library covers
# DiGraph/UnGraph/StableGraph variants, ~30 graph algorithms,
# and a dot export that drives roughly every Rust "your code
# as a diagram" project on crates.io.
#
# ----------------------------------------------------------------------------
# AXIS 230 :: Graph data structures + algorithms (typed graphs + traversal)
# Round 1388 :: Rust slot 1 of 4 :: OPENS Axis 230 (round-number landmark)
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : petgraph/petgraph            - typed graphs + algorithms
#   Go      : gonum/graph                  - gonum's graph subpackage,
#                                            de-facto Go graph algorithms
#   TS/Node : jacomyal/graphology          - typed JS graph library
#                                            with companion gephi-ecosystem
#                                            algorithm packages
#
# Axis 230 is the round-number landmark - each lane lands at
# the *uncontested canonical graph library* for its host
# language. The cross-language structural commentary: graph
# libraries are one of the rare categories where every major
# ecosystem has converged on a single dominant library
# rather than fragmenting into per-application implementations.
# The reason: graph algorithms (dijkstra, bellman-ford,
# tarjan, kosaraju, johnson, prim, kruskal, ford-fulkerson)
# are well-defined enough that any correct implementation
# is interchangeable - so the network effect of "everyone
# uses the same library" beats the fragmentation pressure of
# per-application optimization.
#
# The use-case spectrum for graph libraries in this hunt:
#   - Rust slot (cxx2flow): control-flow graph of parsed
#     code, traversal for emit
#   - Go slot (TBD): network topology / DAG scheduler /
#     dependency graph
#   - Node slot (TBD): visualization-driven (gephi-style),
#     network analysis
#
# All three share the typed-graph abstraction: a graph is a
# pair (nodes, edges) where nodes have a user-defined type
# and edges have a user-defined type. The library provides
# the algorithms that operate on this shape without caring
# about the user's domain semantics. petgraph's
# DiGraph<NodeWeight, EdgeWeight> maps directly onto
# gonum/graph's interface-driven `graph.Node` /
# `graph.Edge` model and onto graphology's
# `MultiGraph<NodeAttributes, EdgeAttributes>`.
#
# Round 1388 opens Axis 230 - the 230th axis is a meaningful
# landmark, demonstrating that the cross-language canonical-
# library pattern continues to hold across 230 distinct
# problem domains so far.
# ============================================================================

_cxx2flow() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-o --output)'{-o,--output}'[output file (default stdout)]:file:_files' \
        '(-c --curly)'{-c,--curly}'[curly connection-line style]' \
        '--cpp[run the C preprocessor first]' \
        '(-t --tikz)'{-t,--tikz}'[emit TikZ backend]' \
        '(-d --d2)'{-d,--d2}'[emit d2 backend]' \
        '--dump-ast[dump the parsed AST (debug)]' \
        '(- *)'{-V,--version}'[print version]' \
        '(- *)'{-h,--help}'[print help]' \
        '1:input file (default stdin):_files -g "*.(c|cc|cpp|cxx|h|hpp|hh|hxx)"' \
        '2:function name (default "main"):'
}

_cxx2flow "$@"
