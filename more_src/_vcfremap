#compdef vcfremap
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfremap.md
# vcflib: realign reads to a reference using Smith-Waterman, normalizing variant representation

local ret=1

_arguments -s -S \
  '(-w --ref-window-size)'{-w,--ref-window-size}'[align using this many bases flanking each side of the reference allele]:N' \
  '(-s --alt-window-size)'{-s,--alt-window-size}'[align using this many flanking bases around each alternate allele]:N' \
  '(-r --reference)'{-r,--reference}'[FASTA reference file]:reference:_files' \
  '(-m --match-score)'{-m,--match-score}'[match score for SW algorithm]:N' \
  '(-x --mismatch-score)'{-x,--mismatch-score}'[mismatch score for SW algorithm]:N' \
  '(-o --gap-open-penalty)'{-o,--gap-open-penalty}'[gap open penalty for SW algorithm]:N' \
  '(-e --gap-extend-penalty)'{-e,--gap-extend-penalty}'[gap extension penalty for SW algorithm]:N' \
  '(-z --entropy-gap-open)'{-z,--entropy-gap-open}'[use entropy scaling for the gap open penalty]' \
  '(-R --repeat-gap-extend)'{-R,--repeat-gap-extend}'[penalize non-repeat-unit gaps in repeat sequence]:N' \
  '(-a --adjust-vcf)'{-a,--adjust-vcf}'[supply a new cigar as TAG in the output VCF]:tag' \
  '*:vcf file:_files' && ret=0

return ret
