#compdef rpmdev-md5 rpmdev-sha1 rpmdev-sha224 rpmdev-sha256 rpmdev-sha384 rpmdev-sha512
# Documentation: https://github.com/rsrchboy/rpmdevtools/blob/master/rpmdev-md5
# Reference accessed: 2026-05-16
# Verified: upstream rsrchboy/rpmdevtools. Multi-name symlink dispatch -
# same script accessed as rpmdev-md5/sha1/sha224/sha256/sha384/sha512.
# Removed from prior file: fabricated -h/-V short flags and bogus
# man.archlinux.org search URL.

# rpmdev-md5: print sums of source files referenced by a spec file
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '*:spec file:_files -g "*.spec(-.)"' && ret=0
return ret
