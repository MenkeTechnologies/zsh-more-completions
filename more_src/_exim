#compdef exim exim4 sendmail.exim
# _exim — Exim MTA (giant command-line surface: -bd run as daemon, -bdf foreground daemon, -bp print queue, -bpr print queue (no recipients), -Mvb/-Mvc/-Mvh inspect specific message, -M deliver specific message, -Mrm remove message, -Mc continue retry attempt, -q runner (qq quick, qf force), -d debug level, -C alt config, -DMACRO=VAL define macro, -v verbose, -ftrans forced transport)
# upstream: https://github.com/Exim/exim
# Flags from Exim/exim src/src/exim.c on tip.

_exim() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-bd[run as daemon]' \
        '-bdf[daemon foreground]' \
        '-bp[print queue]' \
        '-bpr[print queue (no recipients)]' \
        '-bpa[print queue with addresses]' \
        '-bV[show version]' \
        '-be[expand string + exit]' \
        '-bP+[print config option]:option:' \
        '-bt+[test routers]:address:' \
        '-bv+[verify address]:address:' \
        '-bh+[host check]:host:_hosts' \
        '-bs[SMTP mode on stdin]' \
        '-bm[deliver mail received on stdin]' \
        '*-Mvh+[view headers]:msgid:' \
        '*-Mvb+[view body]:msgid:' \
        '*-Mvc+[view content]:msgid:' \
        '*-M+[deliver message]:msgid:' \
        '*-Mc+[continue retry]:msgid:' \
        '*-Mrm+[remove message]:msgid:' \
        '*-Mt+[try delivery]:msgid:' \
        '-q[run queue]' \
        '-qf[force queue run]' \
        '-qff[forceFlush queue]' \
        '-qq[quick queue summary]' \
        '-d+[debug level]:level:' \
        '-C+[config file]:file:_files' \
        '*-D+[MACRO=VAL]:macro:' \
        '-v[verbose]' \
        '-t[take recipients from headers]' \
        '-i[no dot terminates]' \
        '-oem[exit normally on error]' \
        '-odq[queue mail]' \
        '-odb[background delivery]' \
        '-odi[immediate delivery]' \
        '-f+[envelope from]:from:' \
        '-r+[from address]:from:' \
        '-F+[full name]:fullname:'
}

_exim "$@"
