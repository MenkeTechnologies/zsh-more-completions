#compdef operator-sdk

# Zsh completion for operator-sdk - Kubernetes Operator SDK

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:Initialize a new project'
  'create:Scaffold a Kubernetes API or webhook'
  'generate:Invokes a specific generator'
  'bundle:Manage operator bundle metadata'
  'cleanup:Clean up an Operator deployed with OLM'
  'completion:Generate shell completion scripts'
  'envtest:Manage binaries for envtest'
  'olm:Manage the Operator Lifecycle Manager installation'
  'pkgman-to-bundle:Migrate packagemanifests to bundles'
  'run:Run an Operator in a variety of environments'
  'scorecard:Runs scorecard tests'
  'version:Print the operator-sdk version'
  'help:Help about any command'
)

_arguments -s -S \
  '--verbose[enable verbose logging]' \
  '(-h --help)'{-h,--help}'[help for operator-sdk]' \
  '--version[print version information]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          '--domain=[domain for groups]:domain:' \
          '--repo=[name to use for go module]:module:' \
          '--project-name=[project name]:name:' \
          '--plugins=[plugin keys]:plugins:' \
          '(-h --help)'{-h,--help}'[help for init]' && ret=0
        ;;
      create)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help for create]' \
          ':scaffold type:(api webhook)' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help for generate]' \
          ':generator:(bundle kustomize)' && ret=0
        ;;
      bundle)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help for bundle]' \
          ':subcommand:(validate)' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help for completion]' \
          ':shell:(bash zsh fish powershell)' && ret=0
        ;;
      olm)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help for olm]' \
          ':subcommand:(install uninstall status)' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help for run]' \
          ':subcommand:(bundle)' && ret=0
        ;;
      scorecard)
        _arguments -s -S \
          '--config=[path to scorecard config file]:file:_files' \
          '--namespace=[namespace to run scorecard tests in]:namespace:' \
          '--output=[output format]:format:(text json)' \
          '--selector=[label selector]:selector:' \
          '--service-account=[service account to use]:account:' \
          '--wait-time=[seconds to wait for tests to complete]:seconds:' \
          '(-h --help)'{-h,--help}'[help for scorecard]' \
          ':bundle:_files' && ret=0
        ;;
      cleanup)
        _arguments -s -S \
          '--namespace=[namespace]:namespace:' \
          '--timeout=[cleanup timeout]:duration:' \
          '(-h --help)'{-h,--help}'[help for cleanup]' \
          ':operator name:' && ret=0
        ;;
      envtest)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help for envtest]' && ret=0
        ;;
    esac
    ;;
esac

return ret
