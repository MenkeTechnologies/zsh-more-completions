#compdef packetbeat2
# _packetbeat2 — Elastic packetbeat2 CLI command-line frontend wrapping the Packetbeat lightweight network packet analyzer from the Elastic Beats family providing run setup test export keystore version completion device-list dns http mysql memcache redis pgsql sip thrift cassandra mongodb amqp icmp tls flows network-protocol-analysis transaction-correlation real-time-pcap network-flow-aggregation (Elastic Beats team, Go); cobra
# upstream: https://www.elastic.co/beats/packetbeat

_packetbeat2() {
    local -a sub=(
        'run:run packetbeat'
        'setup:setup index pipelines templates'
        'test:test config or output'
        'export:export config or template'
        'keystore:keystore operations'
        'devices:list network devices'
        'version:show version'
        'help:show help'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "packetbeat.yml *.yml *.yaml"' \
        '-d+[selectors]:str:' \
        '-e[log to stderr]' \
        '-E+[k=v]:str:' \
        '-I+[pcap file]:file:_files -g "*.pcap *.pcapng"' \
        '-N[disable publishing]' \
        '-O[run once on pcap file then exit]' \
        '-l+[loop N]:n:' \
        '--path.home=+[dir]:dir:_files -/' \
        '--path.config=+[dir]:dir:_files -/' \
        '--path.data=+[dir]:dir:_files -/' \
        '--path.logs=+[dir]:dir:_files -/' \
        '--strict.perms[strict perms]' \
        '-devices[show device list]' \
        '-t[disable normal logging]' \
        '-waitstop+[sec]:n:' \
        '--httpprof=+[host:port]:_hosts' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'packetbeat subcommand' sub ;;
        args)
            case $words[1] in
                setup) _arguments '1:target:(--index-management --pipelines --dashboards --machine-learning --policy)' '*:arg:' ;;
                test) _arguments '1:target:(config output)' ;;
                export) _arguments '1:target:(config ilm-policy index-pattern template dashboard)' ;;
                keystore) _arguments '1:op:(add create list remove)' '*:key:' ;;
            esac
            ;;
    esac
}

_packetbeat2 "$@"
