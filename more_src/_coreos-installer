#compdef coreos-installer
# Documentation: https://github.com/coreos/coreos-installer (src/cmdline/mod.rs + src/cmdline/install.rs)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'install:install Fedora CoreOS or RHEL CoreOS'
  'download:download a CoreOS image'
  'list-stream:list available images in a Fedora CoreOS stream'
  'iso:commands to manage a CoreOS live ISO image'
  'pxe:commands to manage a CoreOS live PXE image'
  'pack:metadata packing commands used when building an OS image'
  'dev:development commands (unstable)'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'coreos-installer subcommand' _subcmds && ret=0
    ;;
  args)
    local -a _iso _iso_ignition _iso_network _iso_kargs _iso_extract \
             _pxe _pxe_ignition _pxe_network _pack _dev _dev_show _dev_extract
    _iso=(
      'embed:embed Ignition config (deprecated)'
      'show:show embedded Ignition config (deprecated)'
      'remove:remove embedded Ignition config (deprecated)'
      'customize:customize a live ISO image'
      'ignition:manage embedded Ignition config'
      'network:manage embedded network configuration'
      'kargs:manage embedded kernel arguments'
      'extract:extract files from ISO'
      'reset:reset ISO to original state'
    )
    _iso_ignition=(
      'embed:embed Ignition config in ISO'
      'show:show embedded Ignition config'
      'remove:remove embedded Ignition config'
    )
    _iso_network=(
      'embed:embed NetworkManager keyfiles in ISO'
      'extract:extract NetworkManager keyfiles from ISO'
      'remove:remove NetworkManager keyfiles from ISO'
    )
    _iso_kargs=(
      'modify:modify default kernel args in ISO'
      'reset:reset kernel args in ISO'
      'show:show current and default kernel args in ISO'
    )
    _iso_extract=(
      'pxe:extract PXE artifacts'
      'minimal-iso:extract minimal ISO'
    )
    _pxe=(
      'customize:customize a live PXE image'
      'ignition:manage Ignition config in PXE initrd'
      'network:manage network configuration in PXE initrd'
    )
    _pxe_ignition=(
      'wrap:wrap Ignition config in initrd image'
      'unwrap:show wrapped Ignition config from initrd'
    )
    _pxe_network=(
      'wrap:wrap network keyfiles in initrd image'
      'unwrap:show wrapped network keyfiles from initrd'
    )
    _pack=(
      'osmet:create an osmet file'
      'minimal-iso:pack a minimal ISO'
      'man:generate man pages'
      'example-config:generate example config'
    )
    _dev=(
      'show:show internal state'
      'extract:extract internal state'
    )
    _dev_show=(
      'iso:show ISO internal state'
      'initrd:show initrd internal state'
      'fiemap:show file extent map'
    )
    _dev_extract=(
      'osmet:extract osmet contents'
      'initrd:extract initrd contents'
    )
    case $line[1] in
      install)
        _arguments \
          '(-s --stream)'{-s,--stream=}'[Fedora CoreOS stream name]:stream:(stable testing next)' \
          '(-u --image-url)'{-u,--image-url=}'[manual image URL]:url:_urls' \
          '(-f --image-file)'{-f,--image-file=}'[local image file path]:file:_files' \
          '(-i --ignition-file)'{-i,--ignition-file=}'[embed Ignition config from file]:file:_files' \
          '(-I --ignition-url)'{-I,--ignition-url=}'[fetch and embed Ignition config from URL]:url:_urls' \
          '--ignition-hash=[verify Ignition config digest (<type>-<hexvalue>)]:hash:' \
          '(-a --architecture)'{-a,--architecture=}'[target CPU architecture]:arch:(x86_64 aarch64 ppc64le s390x)' \
          '(-p --platform)'{-p,--platform=}'[Ignition platform ID override]:platform:' \
          '*--console=[kernel and bootloader console]:console:' \
          '*--append-karg=[add kernel argument]:karg:' \
          '*--delete-karg=[remove default kernel argument]:karg:' \
          '(-n --copy-network)'{-n,--copy-network}'[copy NetworkManager config from install environment]' \
          '--network-dir=[override NetworkManager keyfile directory]:dir:_directories' \
          '*--save-partlabel=[preserve partitions matching label glob]:glob:' \
          '*--save-partindex=[preserve partitions by number or range]:index:' \
          '(-c --config-file)'{-c,--config-file=}'[YAML configuration file]:file:_files' \
          '--offline[force offline installation]' \
          '--insecure[allow unsigned images]' \
          '--insecure-ignition[allow Ignition URLs without HTTPS or hash]' \
          '--stream-base-url=[override CoreOS metadata base URL]:url:_urls' \
          '--preserve-on-error[skip partition table clearing on failure]' \
          '--fetch-retries=[network fetch retry count or "infinite"]:n:' \
          '--secure-ipl[enable IBM Secure IPL]' \
          ':destination device:_files -g "/dev/*"' && ret=0
        ;;
      download)
        _arguments \
          '(-s --stream)'{-s,--stream=}'[stream name]:stream:(stable testing next)' \
          '(-a --architecture)'{-a,--architecture=}'[target architecture]:arch:(x86_64 aarch64 ppc64le s390x)' \
          '(-p --platform)'{-p,--platform=}'[platform]:platform:' \
          '(-f --format)'{-f,--format=}'[image format]:format:' \
          '(-C --directory)'{-C,--directory=}'[destination directory]:dir:_directories' \
          '--decompress[decompress downloaded artifact]' \
          '--insecure[allow unsigned images]' \
          '--stream-base-url=[override stream metadata URL]:url:_urls' \
          '--fetch-retries=[fetch retry count]:n:' && ret=0
        ;;
      iso) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'iso' _iso && ret=0 ;;
      pxe) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'pxe' _pxe && ret=0 ;;
      pack) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'pack' _pack && ret=0 ;;
      dev) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'dev' _dev && ret=0 ;;
    esac
    ;;
esac

return ret
