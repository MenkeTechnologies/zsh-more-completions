#compdef pest

# Zsh completion for Pest - PHP testing framework

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--filter=[filter tests by name]:pattern:' \
  '--coverage[generate code coverage report]' \
  '--min=[minimum coverage percentage required]:percentage:' \
  '--parallel[run tests in parallel]' \
  '--processes=[number of parallel processes]:count:' \
  '--profile[show top slow tests]' \
  '--bail[stop on first failure]' \
  '--retry[retry failed tests]' \
  '--order-by=[order test execution]:order:(default random defects)' \
  '--group=[only run tests in specified group]:group:' \
  '--exclude-group=[exclude tests in specified group]:group:' \
  '--compact[compact output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--colors=[colorize output]:when:(never auto always)' \
  '--init[initialize Pest in the current project]' \
  '--test-directory=[directory containing tests]:directory:_directories' \
  '(-c --configuration)'{-c,--configuration}'=[path to configuration file]:file:_files -g "*.xml"' \
  '--no-coverage[disable code coverage]' \
  '--stop-on-failure[stop on first failure]' \
  '--stop-on-error[stop on first error]' \
  '--stop-on-defect[stop on first defect]' \
  '--teamcity[output in TeamCity format]' \
  '--testdox[output in TestDox format]' \
  '--list-groups[list available test groups]' \
  '--list-suites[list available test suites]' \
  '--list-tests[list available tests]' \
  '--list-tests-xml[list available tests in XML format]' \
  '--generate-configuration[generate configuration file]' \
  '--cache-result[cache test results]' \
  '--do-not-cache-result[do not cache test results]' \
  '--type-coverage[run type coverage analysis]' \
  '*:test files:_files -g "*.php"'
