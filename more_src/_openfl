#compdef openfl
# Documentation: https://www.openfl.org/learn/haxelib/docs/tools/
# OpenFL command-line tools (front-end for Lime)

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '2:target:->targets' \
  '*::options:->opts' && ret=0

case $state in
  cmds)
    _values 'openfl command' \
      'setup[configure environment]' \
      'update[update frameworks and tools]' \
      'build[compile a project]' \
      'run[launch the application]' \
      'test[build and run a project]' \
      'create[generate a new project]' \
      'process[convert SWF assets]' \
      'help[display help]' && ret=0
    ;;
  targets)
    _values 'target' \
      windows mac linux html5 flash android ios neko air && ret=0
    ;;
  opts)
    _arguments -s -S \
      '-debug[perform a debug build]' \
      '-verbose[get verbose output]' \
      '-clean[remove output directory and perform a clean build]' \
      '-32[compile for 32-bit (mac|linux)]' \
      '-64[compile for 64-bit (mac|linux)]' \
      '-neko[build with Neko (windows|mac|linux)]' \
      '-simulator[target device simulator (ios|tvos)]' \
      '-emulator[target device emulator (android)]' \
      '*:project:_files' && ret=0
    ;;
esac

return ret
