#compdef cjpeg djpeg jpegtran rdjpgcom wrjpgcom libjpeg cjpeg-static djpeg-static jpegtran-static jpegoptim jpeginfo
# _libjpeg — IJG and libjpeg-turbo cjpeg djpeg jpegtran reference JPEG encoder decoder and transform utility (libjpeg-turbo team, C); getopt
# upstream: https://github.com/libjpeg-turbo/libjpeg-turbo

_libjpeg() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-V[show version]' \
        '-quality+[N]:n:' \
        '-baseline[baseline JPEG]' \
        '-arithmetic[arithmetic coding]' \
        '-fastcrush[fast crush]' \
        '-targa[targa input]' \
        '-rle[RLE input]' \
        '-bmp[BMP input]' \
        '-gif[GIF input]' \
        '-icc+[ICC profile file]:file:_files -g "*.icc *.icm"' \
        '-restart+[N]:n:' \
        '-smooth+[N]:n:' \
        '-maxmemory+[N]:n:' \
        '-outfile+[output file]:file:_files -g "*.jpg *.jpeg *.bmp *.gif *.tga *.ppm"' \
        '-progressive[progressive JPEG]' \
        '-fast[fast decompression]' \
        '-scale+[N/M]:str:' \
        '-grayscale[grayscale]' \
        '-fp[fixed-point math]' \
        '-fast-upsample[fast upsample]' \
        '-fancy-upsample[fancy upsample]' \
        '-block-smoothing[block smoothing]' \
        '-no-block-smoothing[no block smoothing]' \
        '-rgb[RGB output]' \
        '-bmp[BMP output]' \
        '-gif[GIF output]' \
        '-pnm[PNM output]' \
        '-tga[Targa output]' \
        '-dct+[mode]:m:(int fast float)' \
        '-debug[debug output]' \
        '-copy+[copy mode]:m:(none comments all)' \
        '-flip+[axis]:a:(horizontal vertical)' \
        '-rotate+[degrees]:n:(90 180 270)' \
        '-perfect[perfect transform]' \
        '-transpose[transpose]' \
        '-transverse[transverse]' \
        '-trim[trim edges]' \
        '-crop+[WxH+X+Y]:str:' \
        '-wipe+[WxH+X+Y]:str:' \
        '-drop+[N WxH]:str:' \
        '-optimize[optimize Huffman tables]' \
        '*:input file:_files -g "*.jpg *.jpeg *.bmp *.gif *.tga *.ppm *.pgm *.pbm *.tif *.tiff"'
}

_libjpeg "$@"
