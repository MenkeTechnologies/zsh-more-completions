#compdef atomtype
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools atomtype: assign force field atom types from an ac file

local ret=1

_arguments -s -S \
  '-i[input file name]:file:_files' \
  '-o[output file name (ac)]:file:_files' \
  '-f[input file format]:format:(ac mol2)' \
  '-p[atom type set]:set:(gaff amber bcc abcg2 gas sybyl)' \
  '-d[atom type definition file]:file:_files' \
  '-a[do post atom type adjustment]:flag:(0 1)' \
  '*:file:_files' && ret=0

return ret
