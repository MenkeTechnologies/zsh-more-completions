#compdef mbuffer
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mbuffer.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mbuffer - measuring buffer

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-i+[use filename as input instead of stdin]:input:_files' \
  '-o+[use filename as output instead of stdout (repeatable)]:output:_files' \
  '-I+[use network port as input]:port' \
  '-O+[write output to hostname:port]:host\:port' \
  '-b+[number of blocks for buffer]:blocks' \
  '-s+[block size in bytes]:size' \
  '-m+[total buffer size]:size' \
  '-L[lock buffer in memory]' \
  '-t[use memory-mapped temporary file as buffer]' \
  '-T+[use file as memory-mapped temporary buffer]:file:_files' \
  '-d[use device block-size for output]' \
  '-D+[assume output volume size]:size' \
  '-n+[number of volumes in input device]:number' \
  '-f[overwrite output file if it exists]' \
  '-P+[start writing after buffer fill percent]:percent' \
  '-p+[start reading after buffer drops below percent]:percent' \
  '-r+[set maximum read rate]:rate' \
  '-R+[set maximum write rate]:rate' \
  '-u+[pause microseconds after each write]:microseconds' \
  '-c[write with synchronous data integrity support]' \
  '-A+[autoloader command to load next volume]:command' \
  '-a+[autoloader load time (seconds)]:seconds' \
  '-l+[log messages to file]:file:_files' \
  '-v+[verbose level]:level:(0 1 2 3 4 5 6)' \
  '-q[quiet mode - no status on stderr]' \
  '-Q[quiet mode - do not log status in file]' \
  '(-H --md5)'{-H,--md5}'[generate MD5 hash of transferred data]' \
  '--hash=[use specified hash algorithm]:algorithm' \
  '-4[force IPv4 mode]' \
  '-6[force IPv6 mode]' \
  '-0[choose IPv4/IPv6 on demand]' \
  '--append[open next output file in append mode]' \
  '--truncate[truncate next output file when opening]' \
  '--tapeaware[keep writing to tape end on no-space errors]' \
  '-W+[watchdog timeout in seconds]:seconds' \
  '--pid[print PID of current process]' \
  '(-V --version)'{-V,--version}'[output version information and exit]' \
  '(-h --help)'{-h,--help}'[output help information and exit]' && ret=0

return ret
