#compdef mbuffer

# Zsh completion for mbuffer - measuring buffer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-i[input file or device]:input:_files' \
  '-o[output file or device (may be specified multiple times)]:output:_files' \
  '-I[input from network (host\:port)]:host\:port' \
  '-O[output to network (host\:port)]:host\:port' \
  '-b[number of blocks for buffer]:blocks' \
  '-s[block size]:size' \
  '-m[total buffer size]:size' \
  '-n[number of volumes]:number' \
  '-t[use memory-mapped temporary file for buffer]' \
  '-T[set temporary directory for buffer file]:directory:_files -/' \
  '-p[set buffer fill percentage to start writing]:percent' \
  '-P[set buffer fill percentage to restart writing]:percent' \
  '-l[log to file]:file:_files' \
  '-c[use asynchronous I/O for writing]' \
  '-f[overwrite output file if it exists]' \
  '-A[use append mode for output]' \
  '-v[verbosity level]:level:(0 1 2 3 4 5 6)' \
  '-q[quiet mode - no status output]' \
  '-d[enable debug mode]' \
  '-e[stop on write errors]' \
  '-r[set maximum read rate]:rate' \
  '-R[set maximum write rate]:rate' \
  '-W[set timeout for write]:seconds' \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  '-H[enable hashing (compute MD5 hash)]' \
  '--hash=[set hash algorithm]:algorithm:(md5 sha256 sha512)' \
  '--md5[calculate MD5 hash of transferred data]' \
  '--sha256[calculate SHA256 hash of transferred data]' \
  '--sha512[calculate SHA512 hash of transferred data]' \
  '--tapeaware[enable tape awareness for multiple volumes]' \
  '--tcpbuffer=[set TCP buffer size]:size' \
  '--direct[use direct I/O]' \
  '-V[display version]' \
  '-h[display help message]' && ret=0

return ret
