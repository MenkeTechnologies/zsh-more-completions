#compdef pbuilder
# _pbuilder — personal package builder for Debian packages (Debian/pbuilder)
# upstream: https://salsa.debian.org/pbuilder-team/pbuilder
# Flags from pbuilder(8) man page.

_pbuilder() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--basetgz=[base tarball]:file:_files -g "*.{tgz,tar.gz}"' \
        '--buildplace=[build chroot location]:dir:_files -/' \
        '--buildresult=[result directory]:dir:_files -/' \
        '--mirror=[mirror URL]:url:' \
        '--othermirror=[additional mirror lines]:lines:' \
        '--components=[apt components]:components:' \
        '--distribution=[target distribution]:dist:(stable testing unstable experimental)' \
        '--architecture=[architecture]:arch:' \
        '--arch=[architecture]:arch:' \
        '--host-arch=[host arch (cross)]:arch:' \
        '--no-auto-cross[do not try to set host-arch]' \
        '--debootstrap=[debootstrap variant tool]:tool:' \
        '*--debootstrapopts=[option to debootstrap]:opt:' \
        '--keyring=[apt keyring file]:file:_files' \
        '--allow-untrusted[trust unsigned apt source]' \
        '*--bindmounts=[paths to bind into chroot]:path:_files -/' \
        '--aptcache=[apt cache directory]:dir:_files -/' \
        '--aptconfdir=[apt conf directory]:dir:_files -/' \
        '--autocleanaptcache[autoclean apt cache before each build]' \
        '*--extrapackages=[extra packages to install in chroot]:pkg:' \
        '*--removepackages=[packages to remove from chroot]:pkg:' \
        '--hookdir=[hook script directory]:dir:_files -/' \
        '--logfile=[log file]:file:_files' \
        '--pkgname-logfile[name logfile after pkg+version]' \
        '--loglevel=[log level]:level:(E W I D)' \
        '--debug[enable shell traces inside chroot scripts]' \
        '*--debbuildopts=[options for dpkg-buildpackage]:opts:' \
        '--debdelta[use debdelta where possible]' \
        '--debemail=[DEBEMAIL value]:email:' \
        '--save-after-exec[save chroot after execute]' \
        '--save-after-login[save chroot after login]' \
        '--use-network[allow network access during build]' \
        '--use-pdebuild-internal[use pdebuild-internal helper]' \
        '--preserve-buildplace[do not remove build chroot after build]' \
        '--http-proxy=[HTTP proxy]:url:' \
        '--inputfile=[input file]:file:_files' \
        '*--option=[set arbitrary option=value]:opt:' \
        '--configfile=[pbuilder config file]:file:_files' \
        '*--override-config[override config rather than merge]' \
        '*--profiles=[build profiles]:profiles:' \
        '--source-only-changes[also produce source-only changes file]' \
        '--no-source-only-changes[skip source-only changes file]' \
        '--bin-nmu=[bin-NMU rationale string]:string:' \
        '--bin-nmu-maintainer=[bin-NMU maintainer]:maint:' \
        '--bin-nmu-timestamp=[bin-NMU timestamp]:ts:' \
        '--bin-nmu-version=[bin-NMU version]:ver:' \
        '--binary-arch[build arch-dependent binary]' \
        '--binary-indep[build arch-independent binary]' \
        '--no-targz[do not save chroot as tarball]' \
        '--compressprog=[compression program]:prog:(gzip pigz xz zstd)' \
        '--timeout=[command timeout]:duration:' \
        '--twice[run build twice]' \
        '--update[update chroot before build]' \
        '--variant=[chroot variant]:variant:(buildd minbase fakechroot)' \
        '1: :->cmd' \
        '*:: :->args'

    if [[ $state == cmd ]]; then
        _values 'command' \
            'create[create base.tgz]' \
            'update[update chroot]' \
            'build[build a Debian source package]' \
            'clean[clean cache / chroot]' \
            'login[interactive login to chroot]' \
            'execute[run a command inside chroot]' \
            'debuild[build via debuild]' \
            'dumpconfig[print resolved configuration]'
    fi
}

_pbuilder "$@"
