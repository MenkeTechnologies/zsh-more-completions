#compdef dh-php dh_php
# Documentation: https://manpages.debian.org/testing/dh-php/dh_php.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dh_php is the debhelper helper provided by the dh-php package for PHP
# extension/module/web app maintainer script handling.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--php-version=[version PHP calls (e.g. php-config<ver>)]:php_version' \
  '--error-handler=[shell function to call on maintainer script failure]:function' \
  '(-e --noenable)'{-e,--noenable}'[install scripts but do not enable by default]' \
  '(-n --noscripts)'{-n,--noscripts}'[do not modify maintainer scripts]' \
  '--conditional=[conditional expression]:expression' \
  '*:argument:' && ret=0

return ret
