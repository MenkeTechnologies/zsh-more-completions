#compdef dh-php
# Documentation: https://man.archlinux.org/search?q=dh-php
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-O --option)'{-O,--option}'+[debhelper option]:opt:' \
  '--with-php=+[PHP version]:ver:' \
  '*:argument:' && ret=0

return ret
