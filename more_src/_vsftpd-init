#compdef vsftpd-init

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start vsftpd'
  'stop:stop vsftpd'
  'restart:restart vsftpd'
  'reload:reload configuration'
  'status:show status'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vsftpd-init command' commands && ret=0 ;;
esac

return ret
