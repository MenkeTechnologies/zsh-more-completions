#compdef kx

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --current)'{-c,--current}'[show current context]' \
  '(-u --unset)'{-u,--unset}'[unset current context]' \
  '*:context name:' && ret=0

return ret
