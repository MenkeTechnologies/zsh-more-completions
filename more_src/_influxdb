#compdef influxd

# Zsh completion for influxd - InfluxDB server daemon

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run the InfluxDB server'
  'backup:download a snapshot of a data node'
  'restore:restore a backup to a data node'
  'config:display merged configuration'
  'version:display the version'
  'help:show help'
  'inspect:inspect database'
  'recovery:recovery tools for InfluxDB'
  'downgrade:downgrade metadata'
  'upgrade:upgrade from InfluxDB 1.x to 2.x'
  'print-config:print the InfluxDB config'
)

_arguments -s -S \
  '--bolt-path=[path to boltdb database]:path:_files' \
  '--engine-path=[path to engine directory]:directory:_files -/' \
  '--http-bind-address=[HTTP bind address]:address:' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--reporting-disabled[disable usage reporting]' \
  '--store=[type of backing store]:store:(bolt disk memory)' \
  '--tls-cert=[TLS certificate file]:cert file:_files' \
  '--tls-key=[TLS key file]:key file:_files' \
  '--secret-store=[secret store type]:type:(bolt vault)' \
  '--assets-path=[path to web assets]:directory:_files -/' \
  '--flux-log-enabled[enable Flux query logging]' \
  '--no-tasks[disable scheduled tasks]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'influxd command' commands && ret=0
    ;;
esac

return ret
