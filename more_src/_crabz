#compdef crabz

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d[decompress]' \
  '--decompress[decompress]' \
  '-c[write to stdout]' \
  '--stdout[write to stdout]' \
  '-f[force overwrite output]' \
  '--force[force overwrite output]' \
  '-k[keep input files]' \
  '--keep[keep input files]' \
  '-l+[compression level (1-12)]:level:' \
  '--level=[compression level (1-12)]:level:' \
  '-p+[number of threads]:threads:' \
  '--threads=[number of threads]:threads:' \
  '-o+[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '-F+[compression format]:format:(gzip bgzf mgzip deflate zlib snap bz2 xz lzma zstd lz4)' \
  '--format=[compression format]:format:(gzip bgzf mgzip deflate zlib snap bz2 xz lzma zstd lz4)' \
  '*:file:_files' && ret=0

return ret
