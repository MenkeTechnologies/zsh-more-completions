#compdef avscale
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/registration/flirt/user_guide.html
# FSL: extract scale, skew, rotation and translation from an affine matrix

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--allparams[output all decomposed parameters]' \
  '1:matrix file:_files' \
  '2:reference image:_files' && ret=0

return ret
