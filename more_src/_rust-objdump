#compdef rust-objdump
# Documentation: https://github.com/rust-embedded/cargo-binutils
# Reference accessed: 2026-05-16
# Verified: cargo-binutils wrapper invoking llvm-objdump.
# Removed from prior file: bogus man.archlinux.org search URL.

# rust-objdump: cargo-binutils wrapper for llvm-objdump
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-d[disassemble executable sections]' \
  '-D[disassemble all sections]' \
  '-S[intermix source and disassembly]' \
  '-h[display section headers]' \
  '-x[display all available headers]' \
  '*:object file:_files' && ret=0
return ret
