#compdef ranger
# _ranger-bin — Ranger vim-style console file manager (Roman Zimbelmann, Python); curses miller-column file browser
# upstream: https://github.com/ranger/ranger

_ranger-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --debug)'{-d,--debug}'[debug log]' \
        '(-c --clean)'{-c,--clean}'[do not save state]' \
        '(-r --confdir)'{-r,--confdir}'+[config dir]:dir:_files -/' \
        '--copy-config+[copy config to ~/.config/ranger]:what:(all commands commands_full rc rifle scope)' \
        '--choosefile+[write path of file]:file:_files' \
        '--choosefiles+[write paths of selected files]:file:_files' \
        '--choosedir+[write dir path]:file:_files' \
        '--selectfile+[select file]:file:_files' \
        '--list-unused-keys[list unused keys]' \
        '--list-tagged-files+[list tagged files]:tag:' \
        '--profile[run with cProfile]' \
        '--cmd+[execute command]:cmd:' \
        '--show-only-dirs[only show dirs]' \
        '*:path:_files'
}

_ranger-bin "$@"
