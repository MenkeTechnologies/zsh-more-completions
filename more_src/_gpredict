#compdef gpredict
# Documentation: https://github.com/csete/gpredict
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# GTK application — standard GTK/GApplication switches (--help, --help-all, --display).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help-all[show all options]' \
  '--display=[X display]:display:' && ret=0

return ret
