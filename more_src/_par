#compdef par
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/par.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. par options use single-dash
# and values typically join with no separator (e.g. -w72, -p1).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-help[show usage]' \
  '(- *)-version[show version]' \
  '-w-[max line width]:width:' \
  '-p-[prefix character count]:prefix:' \
  '-s-[suffix character count]:suffix:' \
  '-h-[hang amount]:hang:' \
  '-r-[repeat handling]:repeat:' \
  '-T-[tab stop width]:tab width:' \
  '-b-[body chars restriction (0 or 1)]:body:(0 1)' \
  '-c-[treat all words as capitalized (0 or 1)]:cap:(0 1)' \
  '-d-[divide blocks by indentation (0 or 1)]:div:(0 1)' \
  '-E-[send messages to stderr (0 or 1)]:err:(0 1)' \
  '-e-[remove superfluous lines (0 or 1)]:expel:(0 1)' \
  '-f-[minimize line length variance (0 or 1)]:fit:(0 1)' \
  '-g-[handle sentence boundaries (0 or 1)]:guess:(0 1)' \
  '-i-[hide inserted quote lines (0 or 1)]:invis:(0 1)' \
  '-j-[justify output (0 or 1)]:just:(0 1)' \
  '-l-[match last line length (0 or 1)]:last:(0 1)' \
  '-q-[handle quote prefixes (0 or 1)]:quote:(0 1)' \
  '-R-[error on oversized words (0 or 1)]:report:(0 1)' \
  '-t-[shorten lines for suffix placement (0 or 1)]:touch:(0 1)' \
  '-B-[body charset (= + or - operator)]:bodychars:' \
  '-P-[protective charset (= + or - operator)]:protchars:' \
  '-Q-[quote charset (= + or - operator)]:quotechars:' && ret=0

return ret
