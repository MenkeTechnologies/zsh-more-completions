#compdef par

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-w+[set output width]:width' \
  '-p+[set prefix characters]:prefix' \
  '-s+[set suffix characters]:suffix' \
  '-h+[enable hanging indentation]:hang' \
  '-r+[repeat prefix/suffix on every line]:repeat' \
  '-e+[expel trailing whitespace]:expel' \
  '-f+[fit lines to width]:fit' \
  '-l+[treat last line specially]:last' \
  '-q+[handle quotation characters]:quote' \
  '-d+[use dividers between paragraphs]:div' \
  '-b+[body characters]:body' \
  '-T+[set tab stop width]:tab width' \
  '-R+[report errors]:report' \
  '-E+[send errors to stderr]:error' \
  '(- *)--version[show version]' \
  '(- *)--help[show help]' && ret=0

return ret
