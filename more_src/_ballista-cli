#compdef ballista-cli ballista2
# _ballista-cli — Apache Ballista ballista-cli CLI command-line frontend wrapping the Apache Ballista distributed SQL query engine built on Apache Arrow DataFusion targeting Kubernetes managing scheduler executor cluster jobs queries SQL parquet DataFrame logical-plan physical-plan partition stages exchange shuffle (Apache Ballista team, Rust); clap
# upstream: https://github.com/apache/datafusion-ballista

_ballista-cli() {
    local -a sub=(
        'scheduler:start scheduler'
        'executor:start executor'
        'query:run a SQL query'
        'cluster:cluster operations'
        'job:job operations'
        'show:show schedulers and executors'
        'load:load configuration'
        'shutdown:shutdown cluster'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--scheduler-host=+[host]:_hosts' \
        '--scheduler-port=+[port]:n:' \
        '--executor-host=+[host]:_hosts' \
        '--executor-port=+[port]:n:' \
        '--bind-host=+[host]:_hosts' \
        '--bind-port=+[port]:n:' \
        '--concurrent-tasks=+[N]:n:' \
        '--external-host=+[host]:_hosts' \
        '--external-port=+[port]:n:' \
        '--namespace=+[name]:str:' \
        '--cluster-storage=+[s]:s:(in-memory sled redis)' \
        '--scheduler-name=+[name]:str:' \
        '--task-scheduling-policy=+[p]:p:(push-staged pull-staged)' \
        '--log-level=+[l]:l:(trace debug info warn error)' \
        '--log-format=+[f]:f:(default json)' \
        '-c+[config file]:file:_files -g "*.toml *.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.toml *.yaml *.yml *.json"' \
        '-f+[format]:f:(table tsv csv json yaml)' \
        '--format=+[format]:f:(table tsv csv json yaml)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ballista-cli subcommand' sub ;;
        args)
            case $words[1] in
                query) _arguments '*:SQL or file:_files -g "*.sql"' ;;
                job|cluster) _arguments '1:op:(list show status cancel)' '*:id:' ;;
            esac
            ;;
    esac
}

_ballista-cli "$@"
