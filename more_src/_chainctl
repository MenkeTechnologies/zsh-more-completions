#compdef chainctl
# Documentation: https://edu.chainguard.dev/chainguard/chainctl/chainctl-docs/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (Chainguard chainctl reference).

local curcontext="$curcontext" state line ret=1
local -a top

top=(
  'actions:Chainguard Actions product'
  'agent:agent-powered commands'
  'auth:authentication for the Chainguard platform'
  'config:local chainctl configuration file'
  'events:events for the Chainguard platform'
  'iam:IAM for the Chainguard platform'
  'images:container images'
  'libraries:ecosystem libraries'
  'packages:Chainguard packages'
  'starter:catalog starter organizations'
  'update:update chainctl'
  'version:print chainctl version'
)

_arguments -C -s -S \
  '(--api)'--api='[Chainguard platform API URL]:url:' \
  '(--audience)'--audience='[token audience URL]:url:' \
  '(--config)'--config='[chainctl config file]:config file:_files' \
  '(--console)'--console='[Chainguard Console URL]:url:' \
  '--force-color[force color even when stdout is not a TTY]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--issuer)'--issuer='[Chainguard STS URL]:url:' \
  '--log-level=[log level]:level:(debug info error)' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(csv env go-template id json markdown none table terse tree wide)' \
  '(-v --v)'{-v+,--v=}'[log verbosity]:verbosity:' \
  '1: :->top' \
  '*::arg:->args' && ret=0

case $state in
  (top) _describe -t commands 'chainctl command' top && ret=0 ;;
  (args) _default && ret=0 ;;
esac

return ret
