#compdef fgbio
# Documentation: https://fulcrumgenomics.github.io/fgbio/tools/latest/
# fgbio - tools for working with genomic and sequencing data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:tool:(CallMolecularConsensusReads CallDuplexConsensusReads GroupReadsByUmi AnnotateBamWithUmis SortBam FilterBam ClipBam SetMateInformation FastqToBam DemuxFastqs TrimFastq FilterSomaticVcf DownsampleVcf FixVcfPhaseSet FilterConsensusReads CallOverlappingConsensusBases CollectDuplexSeqMetrics)' \
  '*::args:_files' && ret=0

return ret
