#compdef intelmq intelmqctl intelmqsetup
# _intelmq — CERT.at intelmq intelmqctl CLI orchestration tool for the IntelMQ python-based open-source incident response automation pipeline managing collectors parsers experts outputs bots through botnet config-yaml redis-pipelines aggregation enrichment notification deduplication-classification expert (CERT.at team, Python); click
# upstream: https://intelmq.readthedocs.io/

_intelmq() {
    local -a sub=(
        'start:start a bot or whole pipeline'
        'stop:stop a bot'
        'restart:restart a bot'
        'status:show bot status'
        'list:list bots or queues'
        'log:show bot logs'
        'check:check configuration'
        'enable:enable a bot'
        'disable:disable a bot'
        'reload:reload a bot'
        'run:run a bot once'
        'debug:debug a bot'
        'upgrade-config:upgrade configuration to new schema'
        'clear:clear pipeline queues'
        'queue-status:show queue status'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '--type=+[t]:t:(text json yaml)' \
        '-t+[type]:t:(text json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'intelmq subcommand' sub ;;
        args)
            case $words[1] in
                start|stop|restart|status|enable|disable|reload|log|debug) _arguments '*:bot:' ;;
                run) _arguments \
                    '--message=+[msg]:str:' \
                    '*:bot:' ;;
                clear|queue-status) _arguments '*:queue:' ;;
            esac
            ;;
    esac
}

_intelmq "$@"
