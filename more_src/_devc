#compdef devc devcontainer
# _devc — Microsoft devcontainer-cli VS Code Dev Container CLI alias (Microsoft, TypeScript); yargs
# upstream: https://github.com/devcontainers/cli

_devc() {
    local -a sub=(
        'up:create dev container'
        'build:build dev container'
        'run-user-commands:run user commands'
        'read-configuration:read merged config'
        'outdated:show outdated features'
        'upgrade:upgrade features'
        'features:features commands'
        'templates:templates commands'
        'exec:exec command in container'
        'set-up:set up workspace'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--workspace-folder=+[workspace folder]:dir:_files -/' \
        '-w+[workspace folder]:dir:_files -/' \
        '--config=+[config file]:file:_files -g "devcontainer.json *.json"' \
        '-c+[config file]:file:_files -g "devcontainer.json *.json"' \
        '--override-config=+[override config]:file:_files' \
        '--log-level=+[log level]:level:(debug info warning)' \
        '-l+[log level]:level:(debug info warning)' \
        '--log-format=+[log format]:fmt:(json text)' \
        '--terminal-rows=+[terminal rows]:n:' \
        '--terminal-columns=+[terminal columns]:n:' \
        '--docker-path=+[docker path]:file:_files' \
        '--docker-compose-path=+[docker-compose path]:file:_files' \
        '--container-data-folder=+[container data folder]:dir:_files -/' \
        '--container-system-data-folder=+[container system data folder]:dir:_files -/' \
        '--id-label=+[id label]:list:' \
        '--default-user-env-probe=+[user env probe]:p:(none loginInteractiveShell interactiveShell loginShell)' \
        '--remove-existing-container[remove existing container]' \
        '--build-no-cache[build no cache]' \
        '--expect-existing-container[expect existing]' \
        '--skip-post-create[skip post create]' \
        '--skip-non-blocking-commands[skip non-blocking commands]' \
        '--prebuild[prebuild]' \
        '--user-data-folder=+[user data folder]:dir:_files -/' \
        '--mount-workspace-git-root[mount workspace git root]' \
        '--include-configuration[include configuration]' \
        '--include-merged-configuration[include merged configuration]' \
        '--additional-features=+[additional features json]:str:' \
        '--gpu-availability=+[gpu availability]:str:' \
        '--update-remote-user-uid-default=+[update remote user uid]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'devcontainer subcommand' sub ;;
        args)
            case $words[1] in
                exec) _arguments '*:cmd:_command_names -e' ;;
                features|templates) _arguments \
                    '1:cmd:(test publish package info generate-docs metadata add-tag delete-tag resolve-dependencies info)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_devc "$@"
