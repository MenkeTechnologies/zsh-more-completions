#compdef claircli
# _claircli — CLI client for Quay Clair container vulnerability scanner (joelee2012/claircli)
# upstream: https://github.com/joelee2012/claircli
# Flags from README usage.

_claircli() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --clair)'{-c+,--clair=}'[clair URL (default http://localhost:6060)]:url:' \
        '*'{-f+,--formats=}'[output report format]:format:(html json)' \
        '(-T --threshold)'{-T+,--threshold=}'[CVE severity threshold]:level:(Defcon1 Critical High Medium Low Negligible Unknown)' \
        '(-w --white-list)'{-w+,--white-list=}'[whitelist file]:file:_files -g "*.{yml,yaml}"' \
        '(-l --local-ip -r --regex)'{-l+,--local-ip=}'[local IP address]:ip:' \
        '(-l --local-ip -r --regex)'{-r,--regex}'[treat image refs as regex]' \
        '(-i --insecure-registry)'{-i+,--insecure-registry=}'[insecure registry domain]:domain:' \
        '*'{-k+,--registry-token=}'[registry:token credential]:credential:' \
        '(-L --log-file)'{-L+,--log-file=}'[save log to file]:file:_files' \
        '(-d --debug)'{-d,--debug}'[print more logs]' \
        '*:docker image:'
}

_claircli "$@"
