#compdef gomega
# _gomega — Gomega matcher library helper (Onsi Fakhouri); BDD-style matchers, mostly used inside Ginkgo, with optional `gomega` cli scaffolds
# upstream: https://github.com/onsi/gomega

_gomega() {
    local -a sub=(
        'help:show help'
        'version:show version'
        'matchers:print bundled matchers'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gomega subcommand' sub ;;
    esac
}

_gomega "$@"
