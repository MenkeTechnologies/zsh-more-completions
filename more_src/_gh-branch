#compdef gh-branch gh-grep gh-label gh-projects
# Documentation: upstream READMEs at github.com/{mislav/gh-branch,k1LoW/gh-grep,heaths/gh-label,heaths/gh-projects}
# Reference accessed: 2026-05-30
# gh-extension family round 17. Tooling-staple harvest — branch
# management, repo-search, label-CRUD, project-CRUD.
# Hunt-note: this round revisits gh-grep — earlier rounds had deferred
# it under what became known as the "gh-grep precedent" (no flag
# enumeration upstream). The current README documents 16 flags
# explicitly, so coverage is now appropriate. The precedent name
# itself stays useful as a label for the general pattern.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-branch)
    # mislav/gh-branch — interactive fzf-based branch switcher.
    # Bare invocation launches fzf picker; no documented CLI flags.
    _arguments -s -S \
      && ret=0
    ;;

  gh-grep)
    # k1LoW/gh-grep — search patterns across GitHub repos via the API.
    _arguments -s -S \
      '(-e --strings)-e+[match pattern]:pattern:' \
      '(-e --strings)--strings=[match pattern]:pattern:' \
      '--branch=[branch name to search]:branch:__git_branch_names' \
      '(-c --count)-c[display match count instead of matching lines]' \
      '(-c --count)--count[display match count instead of matching lines]' \
      '--exclude=[skip files matching pattern]:pattern:' \
      '(-h --help)-h[show help]' \
      '(-h --help)--help[show help]' \
      '(-i --ignore-case)-i[case insensitive matching]' \
      '(-i --ignore-case)--ignore-case[case insensitive matching]' \
      '--include=[search only matching files (default **/*)]:pattern:' \
      '(-n --line-number)-n[display line numbers]' \
      '(-n --line-number)--line-number[display line numbers]' \
      '--name-only[show only repository:filenames]' \
      '(-o --only-matching)-o[show only matching parts of lines]' \
      '(-o --only-matching)--only-matching[show only matching parts of lines]' \
      '--owner=[repository owner or organization]:owner:' \
      '--repo=[repository name]:repo:' \
      '--repo-only[show only repositories]' \
      '--tag=[tag name to search]:tag:' \
      '--url[display URLs to matched lines]' \
      '(-v --version)-v[show version]' \
      '(-v --version)--version[show version]' \
      && ret=0
    ;;

  gh-label)
    # heaths/gh-label — CRUD for repository labels via 6 subcommands.
    local -a _subcmds
    _subcmds=(
      'create:create a label in a repository'
      'delete:delete a label from a repository'
      'edit:edit a label in a repository'
      'export:export labels to CSV or JSON'
      'import:import labels from CSV or JSON'
      'list:list labels in a repository (optional substring filter)'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-label subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          create)
            _arguments \
              '--color=[label color (hex, # optional; random if omitted)]:color:' \
              '--description=[label description]:text:' \
              '1:label name:' && ret=0
            ;;
          edit)
            _arguments \
              '--color=[new color]:color:' \
              '--description=[new description]:text:' \
              '--new-name=[rename label]:name:' \
              '1:label name:' && ret=0
            ;;
          delete)
            _arguments \
              '1:label name:' && ret=0
            ;;
          export|import)
            _arguments \
              '--format=[file format]:format:(csv json)' \
              '1:path (or - for stdin/stdout):_files' && ret=0
            ;;
          list)
            _arguments \
              '1:substring filter:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-projects)
    # heaths/gh-projects — CRUD for GitHub Projects V2 via 4 subcommands.
    local -a _subcmds
    _subcmds=(
      'clone:duplicate an existing project'
      'edit:modify project settings'
      'list:list projects (optional search)'
      'view:show project details'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-projects subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          clone)
            _arguments \
              '(-t --title)-t+[new project title]:title:' \
              '(-t --title)--title=[new project title]:title:' \
              '--private[make the cloned project private]' \
              '-d+[description]:text:' && ret=0
            ;;
          edit)
            _arguments \
              '-d+[update description]:text:' \
              '--public[change visibility to public]' \
              '--add-issue=[include issues (comma-separated)]:issues:' \
              '*-f+[set custom field (FieldName=Value)]:field:' && ret=0
            ;;
          list)
            _arguments \
              '--search=[filter projects by search term]:query:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
