#compdef ufraw
# Documentation: https://man.archlinux.org/search?q=ufraw
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--wb=[white balance]:mode:(camera auto manual)' \
  '--temperature=[color temperature]:K:' \
  '--green=[green level]:val:' \
  '--gamma=[gamma]:val:' \
  '--linearity=[linearity]:val:' \
  '--saturation=[saturation]:val:' \
  '--curve=[base curve]:name:(manual linear custom)' \
  '--curve-file=[curve file]:file:_files' \
  '--exposure=[exposure compensation EV]:ev:' \
  '--restore=[highlight restoration]:method:(clip lch hsv)' \
  '--clip=[clipping mode]:mode:(digital film)' \
  '--auto-bright[apply auto bright]' \
  '--no-auto-bright[disable auto bright]' \
  '--interpolation=[demosaic interpolation]:type:(ahd vng four-color ppg bilinear half)' \
  '--smoothing=[smoothing]:val:' \
  '--black-point=[black point]:val:' \
  '--shrink=[shrink size]:val:' \
  '--size=[output WxH]:WxH:' \
  '--out-type=[output type]:type:(ppm tiff tif jpeg jpg fits jp2)' \
  '--out-depth=[output depth]:depth:(8 16)' \
  '--noise-reduction=[noise reduction]:val:' \
  '--despeckle-window=[despeckle window]:val:' \
  '--despeckle-strength=[despeckle strength]:val:' \
  '--rotate=[rotate degrees]:deg:' \
  '--crop-left=[crop left]:px:' \
  '--crop-top=[crop top]:px:' \
  '--crop-right=[crop right]:px:' \
  '--crop-bottom=[crop bottom]:px:' \
  '--output=[output file]:file:_files' \
  '--overwrite[overwrite]' \
  '--silent[silent]' \
  '--create-id=[create ID file]:mode:(yes no)' \
  '--embedded-image[extract embedded JPEG]' \
  '--zip[ZIP output]' \
  '*:raw_file:_files -g "*.{cr2,nef,arw,dng,raw,raf,orf,rw2,pef,srw,x3f}"' && ret=0

return ret
