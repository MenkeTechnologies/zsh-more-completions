#compdef ufraw ufraw-batch
# Documentation: https://manpages.org/ufraw/1
# Reference accessed: 2026-05-21
# Verified: upstream ufraw(1) man page.
# Removed from prior file: fabricated --auto-bright/--no-auto-bright,
# --smoothing (real: --color-smoothing), --despeckle-window/-strength,
# --noise-reduction, --interpolation half, --out-type jp2, --create-id
# yes/no (real: no|also|only), --curve custom (real: manual|linear|CURVE).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--maximize-window[maximize the window]' \
  '--silent[silent operation]' \
  '--conf=[ID file]:file:_files' \
  '--wb=[white balance]:mode:(camera auto)' \
  '--temperature=[color temperature]:K:' \
  '--green=[green level]:val:' \
  '--gamma=[gamma]:val:' \
  '--linearity=[linearity]:val:' \
  '--exposure=[exposure compensation]:ev:' \
  '--restore=[highlight restoration]:method:(clip lch hsv)' \
  '--clip=[clipping mode]:mode:(digital film)' \
  '--saturation=[saturation]:val:' \
  '--wavelet-denoising-threshold=[wavelet denoising threshold]:val:' \
  '--hotpixel-sensitivity=[hot-pixel sensitivity]:val:' \
  '--base-curve=[base curve]:name:(manual linear custom camera)' \
  '--base-curve-file=[base curve file]:file:_files' \
  '--curve=[curve]:name:(manual linear)' \
  '--curve-file=[curve file]:file:_files' \
  '--black-point=[black point]:val:' \
  '--interpolation=[demosaic interpolation]:type:(ahd vng four-color ppg bilinear)' \
  '--color-smoothing[color smoothing]' \
  '--grayscale=[grayscale conversion]:mode:(none lightness luminance value mixer)' \
  '--grayscale-mixer=[grayscale mixer R,G,B]:rgb:' \
  '--darkframe=[dark frame file]:file:_files' \
  '--shrink=[shrink factor]:val:' \
  '--size=[output size]:size:' \
  '--rotate=[rotate]:rot:(camera no)' \
  '--crop-left=[crop left]:px:' \
  '--crop-top=[crop top]:px:' \
  '--crop-right=[crop right]:px:' \
  '--crop-bottom=[crop bottom]:px:' \
  '--auto-crop[auto-crop]' \
  '--aspect-ratio=[aspect ratio X:Y]:ratio:' \
  '--lensfun=[lensfun correction]:mode:(none auto)' \
  '--out-type=[output type]:type:(ppm tiff tif png jpeg jpg fits)' \
  '--out-depth=[output depth]:depth:(8 16)' \
  '--compression=[compression value]:val:' \
  '--exif[include EXIF]' \
  '--noexif[exclude EXIF]' \
  '--zip[ZIP output]' \
  '--nozip[no ZIP output]' \
  '--out-path=[output path]:dir:_directories' \
  '--output=[output file]:file:_files' \
  '--overwrite[overwrite]' \
  '--create-id=[create ID file]:mode:(no also only)' \
  '--embedded-image[extract embedded JPEG]' \
  '*:raw_file:_files -g "*.(cr2|nef|arw|dng|raw|raf|orf|rw2|pef|srw|x3f)"' && ret=0

return ret
