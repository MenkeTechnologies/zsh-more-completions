#compdef fimgtrim
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/fimgtrim.html
# Reset image pixels below/above thresholds to constant values

local ret=1

_arguments -s -S \
  'infile=[input image file]:infile:_files' \
  'threshlo=[lower threshold, INDEF to skip]:threshlo:' \
  'threshup=[upper threshold, INDEF to skip]:threshup:' \
  'const_lo=[replacement for pixels below lower]:const_lo:' \
  'const_up=[replacement for pixels above upper]:const_up:' \
  'type=[resetting mode]:type:(absolute percentage)' \
  'outfile=[output file]:outfile:_files' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:file:_files' && ret=0

return ret
