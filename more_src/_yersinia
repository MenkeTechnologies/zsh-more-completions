#compdef yersinia
# _yersinia — Yersinia layer-2 attack framework (interactive ncurses / D-Bus daemon performing STP/CDP/DHCP/HSRP/802.1Q/MPLS/ARP/Dot1X/VTP attacks; -I run ncurses UI, -G GTK UI, -D daemon, -d debug, -c config file, -i interface, -l log file, -V version, -h help; per-protocol attack subcommands run inside the UI)
# upstream: https://github.com/tomac/yersinia
# Flags from tomac/yersinia src/yersinia.c on tip.

_yersinia() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-I[interactive ncurses]' \
        '-G[GTK GUI]' \
        '-D[daemon]' \
        '-d+[debug level]:level:' \
        '-c+[config file]:file:_files' \
        '-i+[interface]:interface:_net_interfaces' \
        '-l+[log file]:file:_files'
}

_yersinia "$@"
