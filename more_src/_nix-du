#compdef nix-du

# Zsh completion for nix-du (disk usage analysis for nix store)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-s --store)'{-s,--store}'[nix store path]:path:_files -/' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-g --graph)'{-g,--graph}'[output graph in dot format]:file:_files -g "*.dot"' \
  '(-r --root)'{-r,--root}'[analyze from specific root]:root:_files' \
  '--optimize[show optimization potential]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
