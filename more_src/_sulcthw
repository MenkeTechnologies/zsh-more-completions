#compdef sulcthw
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/sulcthw.c
# linear coordinate transformation of header words

local ret=1

_arguments -s -S \
  'xt=[translation of X]:xt' \
  'yt=[translation of Y]:yt' \
  'zt=[translation of Z]:zt' \
  'xr=[rotation around X in degrees]:xr' \
  'yr=[rotation around Y in degrees]:yr' \
  'zr=[rotation around Z in degrees]:zr' \
  '*:file:_files' && ret=0


return ret
