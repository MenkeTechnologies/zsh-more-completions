#compdef archmage
# Documentation: https://man.archlinux.org/search?q=archmage
# Reference accessed: 2026-05-16

_arguments -s \
  '(-x --extract -c --convert -d --dump)'{-x,--extract}'[extract CHM]' \
  '(-x --extract -c --convert -d --dump)'{-c,--convert=}'[convert CHM]:format:(text html pdf)' \
  '(-x --extract -c --convert -d --dump)'{-d,--dump}'[dump HTML]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  ':chm file:_files -g "*.chm"' \
  ':output:_files'
