#compdef zsteg

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[try all known methods]' \
  '(-c --channels)'{-c,--channels}'=[channels to check]:channels:' \
  '(-l --limit)'{-l,--limit}'=[limit bytes to check]:bytes:' \
  '(-b --bits)'{-b,--bits}'=[bits to check]:bits:' \
  '--lsb[check LSB only]' \
  '--msb[check MSB only]' \
  '(-o --order)'{-o,--order}'=[pixel order]:order:(auto row column)' \
  '(-E --extract)'{-E,--extract}'=[extract data by description]:description:' \
  '--strings[show printable strings only]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--no-color[disable color output]' \
  '--min-str-len=[minimum string length]:length:' \
  '*:PNG/BMP file:_files -g "*.(png|bmp)"' && ret=0

return ret
