#compdef haktrails
# _haktrails — Luke Stephens haktrails CLI for querying the SecurityTrails API to enumerate subdomains DNS history WHOIS records associated domains SSL certificates IP geolocation with concurrent batch processing (hakluke team, Go); flag
# upstream: https://github.com/hakluke/haktrails

_haktrails() {
    local -a sub=(
        'subdomains:enumerate subdomains'
        'tags:show domain tags'
        'whois:show WHOIS'
        'associateddomains:show associated domains'
        'historicalwhois:show WHOIS history'
        'historicaldns:show DNS history'
        'sslcerts:show SSL certificates'
        'ipinfo:show IP information'
        'subdomainscount:count subdomains'
        'company:show company info'
        'usage:show API usage'
        'ping:test API connectivity'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml"' \
        '-k+[api key]:str:' \
        '--key=+[api key]:str:' \
        '-t+[N threads]:n:' \
        '--threads=+[N threads]:n:' \
        '-o+[output format]:f:(plain json csv)' \
        '--output=+[output format]:f:(plain json csv)' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'haktrails subcommand' sub ;;
        args)
            case $words[1] in
                subdomains|tags|whois|associateddomains|historicalwhois|historicaldns|sslcerts|subdomainscount|company) _arguments '*:domain:' ;;
                ipinfo) _arguments '*:IP address:' ;;
            esac
            ;;
    esac
}

_haktrails "$@"
