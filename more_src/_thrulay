#compdef thrulay
# Documentation: https://www.gsp.com/cgi-bin/man.cgi?section=1&topic=THRULAY
# thrulay - network capacity tester (client part)

local ret=1

_arguments -s -S \
  '(-h)-h[display help and exit]' \
  '-v[output version information and exit]' \
  '-b[busy wait in UDP test]' \
  '-D[DSCP value for TOS byte]:dscp' \
  '-m[number of TCP test streams (default 1)]:count' \
  '-t[test duration in seconds (default 60)]:seconds' \
  '-i[reporting interval in seconds (default 1)]:seconds' \
  '-w[window in bytes (default 4194304)]:bytes' \
  '-l[block size (default 8192)]:bytes' \
  '-p[server port (default 5003)]:port' \
  '-u[UDP mode with given rate (bps, suffix kMGT)]:rate' \
  '-T[TTL field for multicast (default 1)]:ttl' \
  '-g[multicast group to send test data to]:group' \
  '*::host:_hosts' && ret=0

return ret
