#compdef portkey

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'setup:setup an integration (claude-code/codex)'
  'login:authenticate to Portkey'
  'logout:clear stored credentials'
  'config:manage gateway configs'
  'virtual-key:manage virtual keys (list/create/delete)'
  'mcp:install/sync MCP servers'
  'skills:install/sync workspace skills'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--portkey-key=[Portkey API key]:key:' \
  '--provider=[provider]:provider:(openai anthropic google azure cohere groq mistral together perplexity)' \
  '--virtual-key=[virtual key id]:vkey:' \
  '--workspace=[workspace id]:id:' \
  '(-y --yes)'{-y,--yes}'[non-interactive mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'portkey command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (setup)
        local -a setup_targets=(
          'claude-code:setup Claude Code integration'
          'codex:setup OpenAI Codex integration'
          'cursor:setup Cursor integration'
          'continue:setup Continue.dev integration'
        )
        _describe -t st 'setup target' setup_targets && ret=0
        _arguments \
          '--skip-mcp[skip MCP server setup]' \
          '--skip-skills[skip skill sync]' \
          '--portkey-key=[Portkey API key]:key:' \
          '--provider=[provider]:provider:(openai anthropic google azure)' && ret=0 ;;
      (config|virtual-key)
        _arguments '*::sub:(list create get update delete)' && ret=0 ;;
      (mcp)
        _arguments '*::sub:(install list sync remove)' && ret=0 ;;
      (skills)
        _arguments '*::sub:(install list sync remove)' && ret=0 ;;
      (login)
        _arguments \
          '--portkey-key=[Portkey API key]:key:' \
          '--workspace=[workspace id]:id:' && ret=0 ;;
    esac ;;
esac

return ret
