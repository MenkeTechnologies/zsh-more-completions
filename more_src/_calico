#compdef calico

# Zsh completion for Calico CLI (calicoctl)

local curcontext="$curcontext" state line ret=1

local -a calico_commands
calico_commands=(
  'apply:apply a resource by file or stdin'
  'create:create a resource by file or stdin'
  'delete:delete a resource by file or stdin'
  'get:get a resource'
  'ipam:IP address management'
  'label:add or update labels on resources'
  'node:Calico node management'
  'patch:patch a resource'
  'replace:replace a resource by file or stdin'
  'version:display the version'
  'datastore:Calico datastore management'
  'convert:convert config files between formats'
)

local -a calico_global_flags
calico_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--allow-version-mismatch[allow client/cluster version mismatch]'
  '--context=[kubectl context to use]:context:'
  '--kubeconfig=[path to kubeconfig]:kubeconfig:_files'
  '-l=[log level]:level:(panic fatal error warn info debug)'
  '--log-level=[log level]:level:(panic fatal error warn info debug)'
)

_arguments -s -S \
  $calico_global_flags \
  '1:command:_describe -t commands command calico_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      create)
        _arguments -s -S \
          $calico_global_flags \
          '-f=[file to use for resource creation]:file:_files' \
          '--filename=[file to use for resource creation]:file:_files' \
          '--skip-exists[skip creating resources that already exist]' \
          '-R[process the directory recursively]' \
          '--recursive[process the directory recursively]' && ret=0
        ;;
      apply)
        _arguments -s -S \
          $calico_global_flags \
          '-f=[file to use for resource apply]:file:_files' \
          '--filename=[file to use for resource apply]:file:_files' \
          '-R[process the directory recursively]' \
          '--recursive[process the directory recursively]' && ret=0
        ;;
      replace)
        _arguments -s -S \
          $calico_global_flags \
          '-f=[file to use for resource replace]:file:_files' \
          '--filename=[file to use for resource replace]:file:_files' \
          '-R[process the directory recursively]' \
          '--recursive[process the directory recursively]' && ret=0
        ;;
      delete)
        _arguments -s -S \
          $calico_global_flags \
          '-f=[file to use for resource deletion]:file:_files' \
          '--filename=[file to use for resource deletion]:file:_files' \
          '--skip-not-exists[skip deleting resources that do not exist]' \
          '-R[process the directory recursively]' \
          '--recursive[process the directory recursively]' \
          '-n=[namespace]:namespace:' \
          '--namespace=[namespace]:namespace:' \
          '1:resource type:(bgpConfiguration bgpPeer felixConfiguration globalNetworkPolicy globalNetworkSet hostEndpoint ipPool ipReservation kubeControllersConfiguration networkPolicy networkSet node profile workloadEndpoint)' \
          '2:resource name:' && ret=0
        ;;
      get)
        _arguments -s -S \
          $calico_global_flags \
          '-f=[file to use for resource get]:file:_files' \
          '--filename=[file to use for resource get]:file:_files' \
          '-o=[output format]:format:(yaml json ps wide go-template custom-columns)' \
          '--output=[output format]:format:(yaml json ps wide go-template custom-columns)' \
          '-n=[namespace]:namespace:' \
          '--namespace=[namespace]:namespace:' \
          '-a[list all instances of resource]' \
          '--all-namespaces[list all instances across all namespaces]' \
          '--export[strip cluster-specific information]' \
          '-R[process the directory recursively]' \
          '--recursive[process the directory recursively]' \
          '1:resource type:(bgpConfiguration bgpPeer felixConfiguration globalNetworkPolicy globalNetworkSet hostEndpoint ipPool ipReservation kubeControllersConfiguration networkPolicy networkSet node profile workloadEndpoint)' \
          '2:resource name:' && ret=0
        ;;
      patch)
        _arguments -s -S \
          $calico_global_flags \
          '-p=[patch document]:patch:' \
          '--patch=[patch document]:patch:' \
          '-n=[namespace]:namespace:' \
          '--namespace=[namespace]:namespace:' \
          '1:resource type:(bgpConfiguration bgpPeer felixConfiguration globalNetworkPolicy globalNetworkSet hostEndpoint ipPool ipReservation kubeControllersConfiguration networkPolicy networkSet node profile workloadEndpoint)' \
          '2:resource name:' && ret=0
        ;;
      label)
        _arguments -s -S \
          $calico_global_flags \
          '-n=[namespace]:namespace:' \
          '--namespace=[namespace]:namespace:' \
          '--overwrite[allow label overwrites]' \
          '--remove[remove label]' \
          '1:resource type:(bgpConfiguration bgpPeer felixConfiguration globalNetworkPolicy globalNetworkSet hostEndpoint ipPool ipReservation kubeControllersConfiguration networkPolicy networkSet node profile workloadEndpoint)' \
          '2:resource name:' \
          '*:label key=value:' && ret=0
        ;;
      ipam)
        local -a ipam_commands
        ipam_commands=(
          'check:check IPAM consistency'
          'configure:configure IPAM'
          'release:release an IP address'
          'show:show IPAM utilization and allocation'
          'split:split an IP pool'
        )
        _arguments -s -S \
          $calico_global_flags \
          '1:ipam command:_describe -t commands command ipam_commands' \
          '*::ipam args:->ipam_args' && ret=0
        case "$state" in
          ipam_args)
            case "${line[1]}" in
              release)
                _arguments -s -S \
                  $calico_global_flags \
                  '--ip=[IP address to release]:ip address:' \
                  '--force[force release]' && ret=0
                ;;
              show)
                _arguments -s -S \
                  $calico_global_flags \
                  '--ip=[show allocation for a specific IP]:ip:' \
                  '--show-blocks[show IP pool blocks]' \
                  '--show-borrowed[show borrowed IPs]' \
                  '--show-configuration[show IPAM configuration]' && ret=0
                ;;
              check)
                _arguments -s -S \
                  $calico_global_flags \
                  '--fix[fix any inconsistencies]' \
                  '--show-all-ips[show all IP allocations]' \
                  '--show-problem-ips[show only problematic IPs]' \
                  '-o=[output format]:format:(report json yaml)' \
                  '--output=[output format]:format:(report json yaml)' && ret=0
                ;;
              *)
                _arguments -s -S $calico_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      node)
        local -a node_commands
        node_commands=(
          'checksystem:check system requirements'
          'diags:collect diagnostic information'
          'run:run the Calico node container'
          'status:display the status of the Calico node'
        )
        _arguments -s -S \
          $calico_global_flags \
          '1:node command:_describe -t commands command node_commands' \
          '*::node args:->node_args' && ret=0
        case "$state" in
          node_args)
            case "${line[1]}" in
              status)
                _arguments -s -S \
                  $calico_global_flags && ret=0
                ;;
              diags)
                _arguments -s -S \
                  $calico_global_flags \
                  '--log-dir=[log directory]:directory:_directories' && ret=0
                ;;
              run)
                _arguments -s -S \
                  $calico_global_flags \
                  '--backend=[backend to use]:backend:(bird gobgp none)' \
                  '--dryrun[dry run mode]' \
                  '--init-system[run node as an init system]' \
                  '--ip=[IP address for the node]:ip:' \
                  '--ip6=[IPv6 address for the node]:ipv6:' \
                  '--ip-autodetection-method=[method for IP autodetection]:method:' \
                  '--ip6-autodetection-method=[method for IPv6 autodetection]:method:' \
                  '--log-dir=[log directory]:directory:_directories' \
                  '--name=[node name]:name:' \
                  '--node-image=[Docker image for calico/node]:image:' \
                  '--no-default-ippools[do not create default IP pools]' \
                  '--use-docker-networking-bridge-plugin[use Docker bridge plugin]' && ret=0
                ;;
              *)
                _arguments -s -S $calico_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      datastore)
        local -a datastore_commands
        datastore_commands=(
          'migrate:migrate datastore'
        )
        _arguments -s -S \
          $calico_global_flags \
          '1:datastore command:_describe -t commands command datastore_commands' \
          '*::datastore args:' && ret=0
        ;;
      convert)
        _arguments -s -S \
          $calico_global_flags \
          '-f=[input file]:file:_files' \
          '--filename=[input file]:file:_files' \
          '-o=[output format]:format:(yaml json)' \
          '--output=[output format]:format:(yaml json)' && ret=0
        ;;
      *)
        _arguments -s -S $calico_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
