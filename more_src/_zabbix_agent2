#compdef zabbix_agent2
# Documentation: https://man.archlinux.org/search?q=zabbix_agent2
# Reference accessed: 2026-05-16

local -a runtime_opts

runtime_opts=(
  userparameter_reload log_level_increase log_level_decrease
  help metrics version
)

_arguments -s \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '(-R --runtime-control)'{-R,--runtime-control}"=[runtime option]:opt:($runtime_opts)" \
  '(-p --print)'{-p,--print}'[print supported items]' \
  '(-t --test)'{-t,--test}'=[test item key]:key:' \
  '(-T --test-config)'{-T,--test-config}'[test config and exit]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
