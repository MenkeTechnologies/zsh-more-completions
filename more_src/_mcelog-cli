#compdef mcelog-cli mcelog

# mcelog: Machine Check Exception logger (Linux x86)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--daemon[run as daemon]' \
  '--client[run as client to running daemon]' \
  '--ignorenodev[ignore missing /dev/mcelog]' \
  '--filter[filter known broken events]' \
  '--no-filter[disable filter]' \
  '--dmi[use DMI for board info]' \
  '--no-dmi[no DMI lookup]' \
  '--num-errors=[number of errors before action]:n:' \
  '--cpu=[cpu type]:cpu:(generic p4 core2 nehalem westmere xeon74xx tulsa dunnington sandybridge ivybridge haswell broadwell skylake)' \
  '--logfile=[log file]:file:_files' \
  '--syslog[log to syslog]' \
  '--syslog-error[errors to syslog]' \
  '--no-syslog[no syslog]' \
  '--syslog-only[syslog only]' \
  '--pidfile=[pid file]:file:_files' \
  '--debug-numerrors[debug error count]' \
  '--no-imc-log[no IMC log]' \
  '--user=[run as user]:user:_users' \
  '--group=[run as group]:group:_groups' \
  '--foreground[run in foreground]' \
  '--config-file=[config file]:file:_files' \
  '--is-cpu-supported[check if CPU is supported]' \
  '--raw[raw output]' \
  '--ascii[ASCII output]' \
  '--file=[log file to process]:file:_files' \
  '*::mcelog args:_files' && ret=0
return ret
