#compdef setfattr-cli
# _setfattr-cli — attr setfattr set extended attributes on a filesystem object CLI alias (attr team, C); custom argparse
# upstream: https://savannah.nongnu.org/projects/attr

_setfattr-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-n+[name]:str:' \
        '--name=+[name]:str:' \
        '-v+[value]:str:' \
        '--value=+[value]:str:' \
        '-x+[remove name]:str:' \
        '--remove=+[remove name]:str:' \
        '--restore=+[file]:file:_files' \
        '-B+[from file]:file:_files' \
        '-d[dump]' \
        '-h[no follow symlinks]' \
        '--no-dereference[no follow symlinks]' \
        '*:files:_files'
}

_setfattr-cli "$@"
