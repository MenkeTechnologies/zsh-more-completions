#compdef sugroll
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/noise/sugroll.c
# Ground roll suppression using Karhunen-Loeve transform

local ret=1

_arguments -s -S \
  'dt=[time sampling interval (secs)]:dt' \
  'nx=[number of horizontal samples (traces)]:nx' \
  'sb=[1 for the ground-roll]:sb:(0 1)' \
  'verbose=[=1 echoes information]:verbose:(0 1)' \
  'nrot=[principal components for the m largest eigenvalues]:nrot' \
  'tmpdir=[directory path prefix for storing temporary files]:tmpdir:_files -/' \
  '*:file:_files' && ret=0

return ret
