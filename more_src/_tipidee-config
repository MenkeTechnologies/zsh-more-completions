#compdef tipidee-config
# _tipidee-config — skarnet tipidee config compiler (parse a tipidee text config file and write a cdb suitable for tipideed -f)
# upstream: https://github.com/skarnet/tipidee
# Flags from src/config/tipidee-config.c on tip.

_tipidee-config() {
    _arguments \
        '-i+[input text config file]:file:_files' \
        '-o+[output cdb file]:file:_files' \
        '-m+[output file mode (octal)]:mode:'
}

_tipidee-config "$@"
