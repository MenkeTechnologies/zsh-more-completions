#
# WHAT IS gajus/table AND WHY IS IT THE 61ST TS-NODE CLI LIBRARY?
#
# table (https://github.com/gajus/table, 978+ stars) is **Gajus
# Kuizinas's "Formats data into a string table"** — the dominant
# Node.js JSON-CONFIG-DRIVEN table renderer.  Where cli-table3 (R608)
# uses imperative push-row API with chars-override style, table uses
# a SINGLE FUNCTION CALL `table(data, config)` where ALL configuration
# is a JSON object validated against an internal JSON Schema via Ajv.
#
# table's distinguishing characteristics:
#
#   1. JSON-CONFIG-DRIVEN API — table's central feature is the
#      functional `table(data, config)` call:
#
#          import { table, TableUserConfig } from 'table';
#
#          const data = [
#              ['File', 'Original', 'Optimized', 'Savings'],
#              ['index.html', '24.5 KB', '12.3 KB', '49.8%'],
#              ['main.css',   '8.7 KB',  '4.1 KB',  '52.9%'],
#              ['app.js',     '156.2 KB', '47.8 KB', '69.4%'],
#          ];
#
#          const config: TableUserConfig = {
#              border: {
#                  topBody: '─', topJoin: '┬', topLeft: '┌', topRight: '┐',
#                  bottomBody: '─', bottomJoin: '┴',
#                  bottomLeft: '└', bottomRight: '┘',
#                  bodyLeft: '│', bodyRight: '│', bodyJoin: '│',
#                  joinBody: '─', joinLeft: '├', joinRight: '┤',
#                  joinJoin: '┼',
#              },
#              columns: [
#                  { alignment: 'left',  width: 16 },
#                  { alignment: 'right', width: 12 },
#                  { alignment: 'right', width: 12 },
#                  { alignment: 'right', width: 10 },
#              ],
#              header: { content: 'PASS 2 — Compression Report' },
#          };
#
#          console.log(table(data, config));
#          // ┌──────────────────────────────────────────────────────┐
#          // │            PASS 2 — Compression Report               │
#          // ├──────────────────┬────────────┬────────────┬──────────┤
#          // │ File             │   Original │  Optimized │  Savings │
#          // ├──────────────────┼────────────┼────────────┼──────────┤
#          // │ index.html       │    24.5 KB │    12.3 KB │    49.8% │
#          // │ main.css         │     8.7 KB │     4.1 KB │    52.9% │
#          // │ app.js           │   156.2 KB │    47.8 KB │    69.4% │
#          // └──────────────────┴────────────┴────────────┴──────────┘
#
#      Compare:
#         * cli-table3 (R608): new Table({...}).push(row) imperative
#         * text-table: minimal positional auto-align
#         * as-table: auto-from-array-of-objects
#         * easy-table: builder methods on Table instance
#         * ascii-table: ASCII-only with builder methods
#         * Rust tabled (R609): #[derive(Tabled)] struct-as-row
#         * Rust comfy-table (R613): imperative builder + presets
#         * Go go-pretty (R610): composable Writer
#         * Go tablewriter (R614): setter-method imperative
#         * table: FUNCTIONAL `table(data, config)` with JSON config
#      FIRST documented Node.js Axis 10 library with purely
#      JSON-config-driven functional API.
#
#   2. AJV-VALIDATED TableUserConfig — table validates its config
#      object at runtime via Ajv against an internal JSON Schema:
#
#          import { table } from 'table';
#
#          try {
#              const output = table(data, {
#                  invalidKey: 'foo',   // not in TableUserConfig schema
#              });
#          } catch (error) {
#              // Error: Invalid config.
#              //   /columns/0: must NOT have additional properties
#              //   /border: invalidKey is required
#          }
#
#      The schema is exported publicly so external tools can validate
#      configs WITHOUT invoking table itself.  Compare:
#         * cli-table3 (R608): silently ignores invalid options
#         * text-table: no config validation
#         * as-table: no config validation
#         * table: AJV JSON Schema validation with structured errors
#      FIRST documented Node.js Axis 10 library with runtime config
#      validation via Ajv JSON Schema.
#
#   3. 17-KEY BorderUserConfig — table exposes a 17-key border config
#      that maps every joint type in the rendered ASCII art:
#
#          {
#              topBody:    '─',  topJoin:  '┬',
#              topLeft:    '┌',  topRight: '┐',
#              bottomBody: '─',  bottomJoin: '┴',
#              bottomLeft: '└',  bottomRight: '┘',
#              bodyLeft:   '│',  bodyRight:  '│',  bodyJoin: '│',
#              headerJoin: '┴',
#              joinBody:   '─',  joinLeft:   '├',
#              joinRight:  '┤',  joinJoin:   '┼',
#          }
#
#      Compare:
#         * cli-table3 (R608): 17-key chars object (SAME idea but
#                                imperative API instead of JSON)
#         * text-table: NO border characters at all
#         * Rust tabled (R609): pre-defined Style values
#         * Rust comfy-table (R613): presets + modifiers
#         * Go go-pretty (R610): predefined Style.Box values
#         * Go tablewriter (R614): SetCenterSeparator + SetColumn-
#                                    Separator + SetRowSeparator
#         * table: 17-key JSON BorderUserConfig
#      The 17-key approach mirrors cli-table3's chars object BUT
#      delivered via JSON config rather than imperative options.
#
#   4. createStream() FOR STREAMING OUTPUT — table provides an
#      alternative `createStream(config)` API for ROW-BY-ROW
#      emission to stdout (no full-data buffering):
#
#          import { createStream } from 'table';
#
#          const stream = createStream({
#              columnDefault: { width: 20 },
#              columnCount: 4,
#          });
#
#          // Emit rows one at a time
#          for (const file of largeFileList) {
#              stream.write([
#                  file.name,
#                  formatBytes(file.original),
#                  formatBytes(file.optimized),
#                  `${file.savings}%`,
#              ]);
#          }
#          // Each .write() prints a row immediately
#
#      Compare:
#         * cli-table3 (R608): full-buffer via push() + toString()
#         * text-table: full-buffer via array
#         * as-table: full-buffer via function
#         * Rust tabled (R609): full-buffer .to_string()
#         * Rust comfy-table (R613): full-buffer .to_string()
#         * Go go-pretty (R610): Writer.Render returns string
#         * Go tablewriter (R614): Render writes io.Writer (closest)
#         * table: createStream for ROW-BY-ROW streaming emission
#      FIRST documented Node.js Axis 10 library with explicit
#      streaming-table API for memory-bounded large datasets.
#
#   5. GAJUS KUIZINAS DOUBLE-AXIS PROVENANCE — table is Gajus
#      Kuizinas's SECOND library in the taxonomy after roarr (R604,
#      Axis 9 logging).  Gajus's design philosophy spans:
#         * roarr (Axis 9) — JSON-line structured logger
#                              ("emit JSON, delegate processing")
#         * table (Axis 10) — JSON-config table renderer
#                               ("emit data + config, get string")
#         * Slonik — PostgreSQL client with structured queries
#         * global-agent — HTTP/HTTPS proxy via env vars
#         * turbowatch (R604) — file watcher + task orchestrator
#         * fastify-webpack-hot — Webpack HMR via Fastify
#         * 100+ more Node.js / TypeScript libraries
#      Common Gajus design themes: structured-data-first,
#      JSON-Schema-validated configs, distributed-systems philosophy,
#      explicit error structures.  Downstream users of table:
#         * teambit/bit (component dev tool, 18k stars)
#         * elastic/kibana (benchmark report tables)
#         * ceph/ceph (dashboard tooling)
#         * divriots/jampack (THIS — static-site optimizer)
#         * jeemok/better-npm-audit
#         * SmartThingsCommunity/smartthings-cli (341 stars)
#         * electric-sql/d2ts (DataFrame for TypeScript)
#         * firemanjs/fireman (Firebase CLI alt)
#         * shepherd-tools/shepherd (multi-repo automation)
#         * 800+ more Node.js CLIs
#      FIRST documented Node.js Axis 10 library with this specific
#      Gajus-double-documented-library + JSON-Schema-first design
#      provenance.
#
# table's relationship to other documented Axis 10 libraries:
#
#   * Unlike cli-table3 (R608) — cli-table3 is imperative push();
#                                  table is functional table(data,
#                                  config)
#   * Closest cross-language analogs:
#         * Rust tabled (R609) — derive-based (different style)
#         * Rust comfy-table (R613) — imperative builder + presets
#         * Go go-pretty (R610) — composable Writer
#         * Go tablewriter (R614) — setter-method imperative
#         * Python tabulate — list-of-lists with auto-headers
#                              (closest analog — function call style)
#         * Python rich.table — builder API (different style)
#     table is the FIRST documented Node.js Axis 10 library
#     providing purely JSON-config-driven functional API with Ajv-
#     validated TableUserConfig + 17-key BorderUserConfig +
#     createStream for streaming output.
#
# -----------------------------------------------------------------------------
#
# THE jampack CLI — @commander-js/extra-typings + table + kleur + sharp
#
# jampack's CLI is in src/index.ts.  Uses @commander-js/extra-typings
# (TypeScript-inferring commander wrapper):
#
#     import { Command } from '@commander-js/extra-typings';
#     import { table, TableUserConfig } from 'table';
#
#     const program = new Command();
#     program
#         .name('jampack')
#         .description('Static website Optimizer')
#         .version(VERSION);
#
#     program
#         .command('pack', { isDefault: true })
#         .description('todo')
#         .argument('<dir>', 'Directory to pack')
#         .option('--include <include>', 'Glob to include')
#         .option('--exclude <exclude>', 'Glob to exclude')
#         .option('--nowrite', 'No write')
#         .option('--fast', 'Go fast. Mostly no compression just checks for issues.')
#         .option('--fail', 'Exits with a non-zero return code if issues.')
#         .option('--onlyoptim', 'Only optimize (PASS 1).')
#         .option('--onlycomp', 'Only compress (PASS 2).')
#         .option('--cache_folder <cache_folder>', 'Default: .jampack/cache')
#         .option('--sequential_compress',
#                 'Whether to perform folder compression sequentially. Reduces memoru footprint on compress. Default: false')
#         .option('--cleancache', 'Clean cache before running')
#         .option('--nocache', 'Run with no use of cache')
#         .action(async (dir, options) => { ... });
#
# `pack` is the DEFAULT subcommand — invoking `jampack <dir>` is
# equivalent to `jampack pack <dir>`.
#
# table is used in src/optimize.ts + src/compress.ts to render the
# PASS 1 / PASS 2 reports — every file processed gets a row with
# original size + optimized size + savings percentage, output to
# stdout via `table(data, TableUserConfig)`.
#
# Five-axis distinctness from every other Node.js Axis 10 library:
#
#   1. PURELY JSON-CONFIG FUNCTIONAL API — table(data, config) call
#      vs cli-table3's imperative push() API.
#
#   2. AJV JSON-SCHEMA VALIDATION — TableUserConfig validated at
#      runtime via Ajv against published schema; no other Node.js
#      Axis 10 library validates config.
#
#   3. 17-KEY BorderUserConfig — same idea as cli-table3's chars
#      object but delivered as JSON config rather than instance
#      property; AJV-validated.
#
#   4. createStream() FOR STREAMING OUTPUT — only Node.js Axis 10
#      library with explicit row-by-row streaming-table API for
#      memory-bounded large datasets.
#
#   5. GAJUS-DOUBLE-AXIS PROVENANCE — table is Gajus Kuizinas's
#      SECOND library in the taxonomy (first was roarr R604 Axis 9).
#      No other library author has documented entries across
#      multiple axes.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/divriots/jampack/blob/main/src/index.ts
# @commander-js/extra-typings .command()/.option() definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _jampack_cmds
_jampack_cmds=(
    'pack:optimize a static website directory (default subcommand)'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--include=[glob to include]:glob:_default' \
    '--exclude=[glob to exclude]:glob:_default' \
    '--nowrite[do not write any files (dry-run)]' \
    '--fast[fast mode: mostly no compression, just check for issues]' \
    '--fail[exit non-zero on any issues (CI gate)]' \
    '--onlyoptim[only run PASS 1 (image/asset optimization)]' \
    '--onlycomp[only run PASS 2 (file compression)]' \
    '--cache_folder=[cache folder (default .jampack/cache)]:dir:_directories' \
    '--sequential_compress[run folder compression sequentially (lower memory)]' \
    '--cleancache[clean cache before running]' \
    '--nocache[do not use cache]' \
    '1: :->cmd_or_dir' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd_or_dir)
        local -a _cmd_or_dir
        _cmd_or_dir=("${_jampack_cmds[@]}")
        _alternative \
            "commands:subcommand:_describe -t commands 'jampack subcommand' _cmd_or_dir" \
            'directories:directory to pack:_directories' \
            && ret=0
        ;;
    args)
        case $words[1] in
            pack)
                _arguments \
                    '--include=[glob to include]:glob:_default' \
                    '--exclude=[glob to exclude]:glob:_default' \
                    '--nowrite[do not write any files (dry-run)]' \
                    '--fast[fast mode: mostly no compression, check only]' \
                    '--fail[exit non-zero on issues (CI gate)]' \
                    '--onlyoptim[only run PASS 1]' \
                    '--onlycomp[only run PASS 2]' \
                    '--cache_folder=[cache folder]:dir:_directories' \
                    '--sequential_compress[run sequentially]' \
                    '--cleancache[clean cache before running]' \
                    '--nocache[do not use cache]' \
                    '1:directory to pack:_directories' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
