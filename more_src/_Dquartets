#compdef Dquartets
# Documentation: https://github.com/millanek/Dsuite
# Dsuite Dquartets (experimental): D and f4-ratio for population quartets (no outgroup).

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-k --JKnum)'{-k+,--JKnum=}'[number of jackknife blocks (default 20)]:num:' \
  '(-j --JKwindow)'{-j+,--JKwindow=}'[jackknife block size in SNPs]:snps:' \
  '(-r --region)'{-r+,--region=}'[process VCF subset start,length]:start,length:' \
  '(-t --tree)'{-t+,--tree=}'[Newick tree file]:file:_files' \
  '(-o --out-prefix)'{-o+,--out-prefix=}'[output file prefix]:prefix:' \
  '(-n --run-name)'{-n+,--run-name=}'[run name for output files]:name:' \
  '*:file:_files' && ret=0

return ret
