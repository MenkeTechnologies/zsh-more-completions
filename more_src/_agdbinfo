#compdef agdbinfo
# Documentation: https://github.com/libyal/libagdb
# Source: libyal/libagdb manuals/agdbinfo.1 — display info about a Windows Application Compatibility / Shim Database (AGDB).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[show allocation information]' \
    '-h[show help]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:AGDB file:_files' \
    && ret=0

return ret
