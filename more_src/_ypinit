#compdef ypinit
# _ypinit — OpenBSD ypinit (bootstrap a YP server; -m initialises a master server, -s a slave (specifying the master), -u updates the ypservers map on an existing master)
# upstream: https://github.com/openbsd/src (usr.sbin/ypserv)
# Flags from usr.sbin/ypserv/ypinit/ypinit.8 on tip.

_ypinit() {
    _arguments \
        '(-s -u)-m[set up as master server]' \
        '(-m -u)-s+[set up as slave of master server]:master:_hosts' \
        '(-m -s)-u[update ypservers map]' \
        '*:domainname:'
}

_ypinit "$@"
