#compdef backintime
# _backintime — Back In Time Team backintime CLI for the Linux desktop incremental snapshot rsync-based backup tool managing profiles snapshot creation removal restoration with notifications schedule profile-list (bit-team team, Python); argparse
# upstream: https://github.com/bit-team/backintime

_backintime() {
    local -a sub=(
        'backup:run backup'
        'backup-job:run backup job'
        'restore:restore from snapshot'
        'snapshots-list:list snapshots'
        'snapshots-path:show snapshot path'
        'snapshots-remove:remove snapshot'
        'last-snapshot:show last snapshot'
        'last-snapshot-path:show last snapshot path'
        'pw-cache:password cache management'
        'check-config:check configuration'
        'unmount:unmount all'
        'remount:remount all'
        'decode:decode encrypted path'
        'shutdown:shutdown after backup'
        'benchmark-cipher:benchmark cipher'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--profile=+[name]:str:' \
        '--profile-id=+[id]:n:' \
        '--config=+[file]:file:_files -g "config *.ini"' \
        '--debug[debug]' \
        '--license[show license]' \
        '--share-path=+[dir]:dir:_files -/' \
        '--keep-mount[keep mount]' \
        '--quiet-progress[quiet progress]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'backintime subcommand' sub ;;
        args)
            case $words[1] in
                restore) _arguments \
                    '--no-confirm[no confirm]' \
                    '--delete[delete extra files]' \
                    '*:snapshot id path:' ;;
                snapshots-remove|snapshots-path) _arguments '*:snapshot id:' ;;
            esac
            ;;
    esac
}

_backintime "$@"
