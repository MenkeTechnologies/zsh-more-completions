#compdef retext
# Documentation: https://man.archlinux.org/search?q=retext
# Reference accessed: 2026-05-16

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--preview[open in preview mode]' \
  '--new-window[create new window]' \
  '*:file:_files -g "*.(md|markdown|rst|txt)"'
