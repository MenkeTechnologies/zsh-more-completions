#compdef retext
# Documentation: https://github.com/retext-project/retext
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--preview[open in preview mode]' \
  '--new-window[create new window]' \
  '*:file:_files -g "*.(md|markdown|rst|txt)"'
