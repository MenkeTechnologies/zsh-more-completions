#compdef viem viem-cli
# _viem — Wagmi viem TypeScript Ethereum library and CLI for ABI encoding/decoding wallet creation public client interaction and contract code generation (wevm team, TypeScript); commander.js
# upstream: https://github.com/wevm/viem

_viem() {
    local -a sub=(
        'generate:generate types from ABI'
        'init:initialize project'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r+[root]:dir:_files -/' \
        '--root=+[root]:dir:_files -/' \
        '-c+[config file]:file:_files -g "*.ts *.js *.mjs"' \
        '--config=+[config file]:file:_files -g "*.ts *.js *.mjs"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'viem subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments \
                    '--watch[watch mode]' \
                    '-w[watch mode]' \
                    '--out=+[dir]:dir:_files -/' \
                    '-o+[dir]:dir:_files -/' ;;
                init) _arguments \
                    '--language=+[lang]:l:(ts js)' \
                    '--package-manager=+[pm]:p:(npm yarn pnpm bun)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_viem "$@"
