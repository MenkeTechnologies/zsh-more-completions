#compdef kuma-dp

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:launch the dataplane'
  'wait:wait for control plane readiness'
  'version:show version'
)

_arguments -C \
  '--log-level=[log level]:level:(off info debug)' \
  '--log-output-path=[log output path]:file:_files' \
  '--log-max-retained-files=[max retained log files]:n:' \
  '--log-max-size=[max log file MB]:mb:' \
  '--log-max-age=[max log age days]:days:' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'kuma-dp subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--name=[dataplane name]:name:' \
          '--mesh=[mesh name]:mesh:' \
          '--proxy-type=[proxy type]:type:(dataplane ingress)' \
          '--drain-time=[drain time]:duration:' \
          '--cp-address=[control plane URL]:url:' \
          '--ca-cert-file=[CA cert file]:file:_files' \
          '--binary-path=[envoy binary]:file:_files' \
          '--concurrency=[envoy worker threads]:n:' \
          '--config-dir=[config dir (deprecated)]:dir:_files -/' \
          '--work-dir=[work dir]:dir:_files -/' \
          '--dataplane-token-file=[token file]:file:_files' \
          '--dataplane-token=[token literal]:token:' \
          '--dataplane=[inline dataplane YAML]:yaml:' \
          '(-d --dataplane-file)'{-d,--dataplane-file=}'[dataplane template]:file:_files' \
          '*'{-v,--dataplane-var=}'[template var]:key=val:' \
          '--envoy-log-level=[envoy log level]:level:(trace debug info warning error critical off)' \
          '*--envoy-component-log-level=[component log level]:spec:' \
          '--metrics-cert-path=[metrics cert]:file:_files' \
          '--metrics-key-path=[metrics key]:file:_files' \
          '--bind-outbounds[bind outbounds to real addresses]' \
          '--dns-enabled[enable builtin DNS]' \
          '--dns-envoy-port=[envoy DNS port]:port:' \
          '--dns-coredns-port=[CoreDNS port]:port:' \
          '--dns-coredns-path=[CoreDNS binary]:file:_files' \
          '--dns-coredns-config-template-path=[CoreDNS template]:file:_files' \
          '--dns-server-config-dir=[DNS config dir]:dir:_files -/' \
          '--dns-prometheus-port=[Prometheus stats port]:port:' \
          '--dns-enable-logging[enable CoreDNS logging]' \
          '--transparent-proxy[enable transparent proxy]' && ret=0
        ;;
      (version)
        _arguments '--detailed[show detailed version]' && ret=0
        ;;
    esac
    ;;
esac

return ret
