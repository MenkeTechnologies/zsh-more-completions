#compdef grov
# Documentation: https://github.com/vdsmon/grov
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

autoload -U is-at-least

_grov() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_grov_commands" \
"*::: :->grov" \
&& ret=0
    case $state in
    (grov)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:grov-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'--path=[Parent directory to clone into (defaults to current directory)]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
'--base=[Base branch for new branches (defaults to the default branch)]:BASE:_default' \
'--path=[Custom path for the worktree]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
'::branch -- Branch name to check out or create (prompted if not provided):_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'--compact[Show only branch names, one per line]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
'--match=[How to interpret the name when resolving a worktree]:MATCH_MODE:((auto\:"Match by branch or directory name, and fail on ambiguity"
branch\:"Match only by branch name"
dir\:"Match only by worktree directory name"))' \
'--delete-branch[Also delete the local branch]' \
'--force[Force removal even if worktree has uncommitted changes]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::name -- Worktree name or branch to remove (prompted if not provided):_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_grov__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:grov-help-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_grov_commands] )) ||
_grov_commands() {
    local commands; commands=(
'init:Clone a repo as bare and create an initial worktree' \
'add:Create a new worktree for a branch' \
'list:List all worktrees' \
'remove:Remove a worktree' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'grov commands' commands "$@"
}
(( $+functions[_grov__add_commands] )) ||
_grov__add_commands() {
    local commands; commands=()
    _describe -t commands 'grov add commands' commands "$@"
}
(( $+functions[_grov__completions_commands] )) ||
_grov__completions_commands() {
    local commands; commands=()
    _describe -t commands 'grov completions commands' commands "$@"
}
(( $+functions[_grov__help_commands] )) ||
_grov__help_commands() {
    local commands; commands=(
'init:Clone a repo as bare and create an initial worktree' \
'add:Create a new worktree for a branch' \
'list:List all worktrees' \
'remove:Remove a worktree' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'grov help commands' commands "$@"
}
(( $+functions[_grov__help__add_commands] )) ||
_grov__help__add_commands() {
    local commands; commands=()
    _describe -t commands 'grov help add commands' commands "$@"
}
(( $+functions[_grov__help__completions_commands] )) ||
_grov__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'grov help completions commands' commands "$@"
}
(( $+functions[_grov__help__help_commands] )) ||
_grov__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'grov help help commands' commands "$@"
}
(( $+functions[_grov__help__init_commands] )) ||
_grov__help__init_commands() {
    local commands; commands=()
    _describe -t commands 'grov help init commands' commands "$@"
}
(( $+functions[_grov__help__list_commands] )) ||
_grov__help__list_commands() {
    local commands; commands=()
    _describe -t commands 'grov help list commands' commands "$@"
}
(( $+functions[_grov__help__remove_commands] )) ||
_grov__help__remove_commands() {
    local commands; commands=()
    _describe -t commands 'grov help remove commands' commands "$@"
}
(( $+functions[_grov__init_commands] )) ||
_grov__init_commands() {
    local commands; commands=()
    _describe -t commands 'grov init commands' commands "$@"
}
(( $+functions[_grov__list_commands] )) ||
_grov__list_commands() {
    local commands; commands=()
    _describe -t commands 'grov list commands' commands "$@"
}
(( $+functions[_grov__remove_commands] )) ||
_grov__remove_commands() {
    local commands; commands=()
    _describe -t commands 'grov remove commands' commands "$@"
}

if [ "$funcstack[1]" = "_grov" ]; then
    _grov "$@"
else
    compdef _grov grov
fi
