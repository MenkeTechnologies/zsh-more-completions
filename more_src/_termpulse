#compdef termpulse
# Documentation: https://man.archlinux.org/search?q=termpulse
# Reference accessed: 2026-05-16
# Source: cargo binstall termpulse-cli@0.1.0
# Probed via: completions zsh
# Repository: https://github.com/justinhuangcode/termpulse

autoload -U is-at-least

_termpulse() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--json[Output in JSON format for machine consumption]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_termpulse_commands" \
"*::: :->termpulse" \
&& ret=0
    case $state in
    (termpulse)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:termpulse-command-$line[1]:"
        case $line[1] in
            (set)
_arguments "${_arguments_options[@]}" : \
'-l+[Optional label text]:LABEL:_default' \
'--label=[Optional label text]:LABEL:_default' \
'--json[Output in JSON format for machine consumption]' \
'-h[Print help]' \
'--help[Print help]' \
':percent -- Progress percentage (0-100):_default' \
&& ret=0
;;
(start)
_arguments "${_arguments_options[@]}" : \
'-l+[Optional label text]:LABEL:_default' \
'--label=[Optional label text]:LABEL:_default' \
'--json[Output in JSON format for machine consumption]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(done)
_arguments "${_arguments_options[@]}" : \
'-l+[Optional label text]:LABEL:_default' \
'--label=[Optional label text]:LABEL:_default' \
'--json[Output in JSON format for machine consumption]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(fail)
_arguments "${_arguments_options[@]}" : \
'-l+[Optional label text]:LABEL:_default' \
'--label=[Optional label text]:LABEL:_default' \
'--json[Output in JSON format for machine consumption]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(wrap)
_arguments "${_arguments_options[@]}" : \
'-l+[Label shown during execution]:LABEL:_default' \
'--label=[Label shown during execution]:LABEL:_default' \
'--done-label=[Label shown on success]:DONE_LABEL:_default' \
'--fail-label=[Label shown on failure]:FAIL_LABEL:_default' \
'--json[Output in JSON format for machine consumption]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'*::command -- The command to run (everything after `--`):_default' \
&& ret=0
;;
(pipe)
_arguments "${_arguments_options[@]}" : \
'-t+[Total expected bytes (enables percentage progress). Without this, shows indeterminate progress]:TOTAL:_default' \
'--total=[Total expected bytes (enables percentage progress). Without this, shows indeterminate progress]:TOTAL:_default' \
'--buffer-size=[Read buffer size in bytes]:BUFFER_SIZE:_default' \
'-l+[Label shown during piping]:LABEL:_default' \
'--label=[Label shown during piping]:LABEL:_default' \
'--lines[Count lines instead of bytes]' \
'--json[Output in JSON format for machine consumption]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(clear)
_arguments "${_arguments_options[@]}" : \
'--json[Output in JSON format for machine consumption]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(detect)
_arguments "${_arguments_options[@]}" : \
'--json[Output in JSON format for machine consumption]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--json[Output in JSON format for machine consumption]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- The shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_termpulse__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:termpulse-help-command-$line[1]:"
        case $line[1] in
            (set)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(start)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(done)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(fail)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(wrap)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(pipe)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clear)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(detect)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_termpulse_commands] )) ||
_termpulse_commands() {
    local commands; commands=(
'set:Set progress to a specific percentage' \
'start:Start indeterminate progress (spinner-like)' \
'done:Signal successful completion (emits 100% then clears)' \
'fail:Signal failure (emits error state then clears)' \
'wrap:Wrap a command with automatic progress indication' \
'pipe:Track progress of piped data (bytes or lines)' \
'clear:Clear/remove the progress indicator' \
'detect:Detect terminal capabilities and show support info' \
'completions:Generate shell completions for the given shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'termpulse commands' commands "$@"
}
