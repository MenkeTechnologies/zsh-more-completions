#compdef remix
# _remix-cli — Remix full-stack React framework CLI (Shopify); build/dev/routes for Remix apps
# upstream: https://github.com/remix-run/remix

_remix-cli() {
    local -a sub=(
        'build:build the app for production'
        'dev:run dev server with HMR'
        'routes:print the route table'
        'setup:setup runtime (deno node cloudflare)'
        'vite:dev vite plugin command'
        'reveal:reveal hidden internal config'
        'gen:generate scaffolding'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'remix subcommand' sub ;;
        args)
            case $words[1] in
                build|dev) _arguments \
                    '--config+[config file]:file:_files -g "remix.config*"' \
                    '--sourcemap[generate sourcemaps]' \
                    '(-p --port)'{-p,--port}'+[port]:port:' \
                    '--manual[disable HMR]' \
                    '*:dir:_files -/' ;;
                routes) _arguments '--json[JSON output]' ;;
                setup) _arguments '1:runtime:(node cloudflare deno)' ;;
            esac
            ;;
    esac
}

_remix-cli "$@"
