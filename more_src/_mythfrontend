#compdef mythfrontend
# Documentation: https://github.com/MythTV/mythtv/blob/master/mythtv/programs/mythfrontend/mythfrontend_commandlineparser.cpp
# Reference accessed: 2026-05-16
# Verified: upstream mythfrontend_commandlineparser.cpp.

# mythfrontend: MythTV TV/media front-end
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--version[show version]' \
  '(-nw --no-windowed)'{-nw,--no-windowed}'[do not run in window]' \
  '(-w --windowed)'{-w,--windowed}'[force windowed]' \
  '--mouse-cursor[force mouse cursor visible]' \
  '--no-mouse-cursor[force mouse cursor hidden]' \
  '-geometry[window WxH+X+Y]:geom:' \
  '--geometry=[window WxH+X+Y]:geom:' \
  '-display[X11 display]:display:' \
  '--display=[X11 display]:display:' \
  '-platform[Qt QPA platform]:platform:' \
  '--platform=[Qt QPA platform]:platform:' \
  '--noupnp[disable UPnP]' \
  '(-r --reset)'{-r,--reset}'[reset appearance and language]' \
  '(-p --prompt)'{-p,--prompt}'[always prompt for backend selection]' \
  '(-d --disable-autodiscovery)'{-d,--disable-autodiscovery}'[disable UPnP autodiscovery]' \
  '--jumppoint=[start at jump point]:point:' \
  '--runplugin=[start running plugin]:plugin:' \
  '(-vrr --vrr)'{-vrr,--vrr}'[enable Variable Refresh Rate]' \
  '(-v --verbose)'{-v,--verbose=}'[log filtering]:level:' \
  '--logpath=[log to file]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[reduce logging]' \
  '--loglong[long log format]' \
  '--loglevel=[logging level]:level:(emerg alert crit err warning notice info debug trace)' \
  '--syslog=[syslog facility]:facility:' && ret=0
return ret
