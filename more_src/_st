#compdef st

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-a[disable alt screens]' \
  '-c+[WM_CLASS]:class:' \
  '-f+[font (Xft)]:font:' \
  '-g+[geometry COLSxROWS+X+Y]:geom:' \
  '-i[fixed geometry]' \
  '-n+[window name]:name:' \
  '-o+[log all output to file]:file:_files' \
  '-T+[window title]:title:' \
  '-t+[window title (alias)]:title:' \
  '-w+[embed in X window ID]:win_id:' \
  '-l+[line/serial device]:tty:' \
  '-e[execute remainder as command]:command:_command_names' \
  '*::passthrough:' && ret=0

return ret
