#compdef openct openct-control
# Documentation: https://man.archlinux.org/search?q=openct
# Reference accessed: 2026-05-16

# openct(-control): smart card reader middleware control
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'init:initialise reader drivers'
  'shutdown:shutdown drivers'
  'attach:attach a reader by driver/device'
  'detach:detach a reader by index'
  'status:show reader status'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-d[debug level]:level:' \
  '-f[ifdhandler config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'openct command' commands && ret=0 ;;
esac
return ret
