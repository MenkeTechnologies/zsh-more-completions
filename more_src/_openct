#compdef openct openct-control
# Documentation: https://github.com/OpenSC/openct/blob/master/src/tools/openct-control.c
# Reference accessed: 2026-05-20
# Verified: upstream src/tools/openct-control.c source.

# openct-control: smart card reader middleware control
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'init:initialise OpenCT'
  'attach:attach a hotplug device (driver type device)'
  'status:display status of all readers present'
  'shutdown:shutdown OpenCT'
)
_arguments -C \
  '-d[enable debugging (repeat to increase verbosity)]' \
  '-n[disable coldplugging]' \
  '-f[config file]:file:_files' \
  '-h[display help]' \
  '-v[display version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'openct command' commands && ret=0 ;;
esac
return ret
