#compdef polymer-cli
# _polymer-cli — Polymer Project Polymer CLI alias (Google Polymer Team, JavaScript); command-line-args
# upstream: https://github.com/Polymer/tools

_polymer-cli() {
    local -a sub=(
        'analyze:analyze project'
        'build:build for production'
        'init:scaffold project from template'
        'install:install web components / bower deps'
        'lint:lint code'
        'serve:run dev server'
        'test:run tests'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'polymer subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '--config-file=+[config file]:file:_files -g "polymer.json"' \
                    '--add-service-worker[add service worker]' \
                    '--add-push-manifest[add push manifest]' \
                    '--add-manifest-link[add manifest link]' \
                    '--bundle[bundle]' \
                    '--insert-prefetch-links[insert prefetch links]' \
                    '--browser-capabilities=+[browser caps]:list:' \
                    '--present[present mode]' \
                    '--name=+[name]:str:' \
                    '--js-compile[js compile]' \
                    '--js-minify[js minify]' \
                    '--js-transform-modules-to-amd[js modules to amd]' \
                    '--css-minify[css minify]' \
                    '--html-minify[html minify]' \
                    '--auto-base-path[auto base path]' \
                    '--moduleResolution=+[module resolution]:m:(none node)' \
                    '--rollupConfig=+[rollup config]:file:_files' ;;
                serve) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--hostname=+[hostname]:host:_hosts' \
                    '-H+[hostname]:host:_hosts' \
                    '--component-dir=+[component dir]:dir:_files -/' \
                    '-c+[component dir]:dir:_files -/' \
                    '--package-name=+[package name]:str:' \
                    '--open[open browser]' \
                    '-o[open browser]' \
                    '--browser=+[browser]:str:' \
                    '-b+[browser]:str:' \
                    '--open-path=+[open path]:str:' \
                    '--module-resolution=+[module resolution]:m:(none node)' \
                    '--npm[use npm]' \
                    '--protocol=+[protocol]:p:(h2 http/1.1)' \
                    '--key=+[ssl key]:file:_files' \
                    '--cert=+[ssl cert]:file:_files' \
                    '--manifest=+[manifest]:file:_files' ;;
                test) _arguments \
                    '--config-file=+[config file]:file:_files -g "wct.conf.json"' \
                    '--browsers=+[browsers]:list:' \
                    '--persistent[persistent]' \
                    '--root=+[root]:dir:_files -/' \
                    '--module-resolution=+[module resolution]:m:(none node)' \
                    '--npm[use npm]' \
                    '--package-name=+[package name]:str:' \
                    '--component-dir=+[component dir]:dir:_files -/' ;;
                init) _arguments \
                    '*:template:(element application polymer-3-application starter-kit)' ;;
                install) _arguments \
                    '--variants[install variants]' \
                    '*:arg:' ;;
                analyze) _arguments \
                    '--input=+[input]:list:_files' \
                    '-i+[input]:list:_files' \
                    '*:file:_files' ;;
                lint) _arguments \
                    '--config-file=+[config file]:file:_files' \
                    '--input=+[input]:list:_files' \
                    '-i+[input]:list:_files' \
                    '--rules=+[rules]:list:' \
                    '-r+[rules]:list:' \
                    '--fix[fix lints]' \
                    '--watch[watch]' \
                    '-w[watch]' ;;
            esac
            ;;
    esac
}

_polymer-cli "$@"
