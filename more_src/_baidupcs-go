#compdef baidupcs-go
# Documentation: https://man.archlinux.org/search?q=baidupcs-go
# Reference accessed: 2026-05-16

# Zsh completion for baidupcs-go
# Upstream: Terminal utility for Baidu Network Disk
# Conservative fallback — run `baidupcs-go --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
