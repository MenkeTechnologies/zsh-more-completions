#compdef leaf
# Documentation: https://man.archlinux.org/search?q=leaf
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-help[show help]' \
  '-version[show version]' \
  '-verbose[verbose output]' \
  '-config=[config file]:config:_files' \
  '-listen=[listen address]:address:' \
  '-dns=[DNS server address]:address:' \
  '-loglevel=[log level]:level:(trace debug info warn error none)' \
  '-logoutput=[log output]:output:_files' \
  '-interface=[outbound interface]:interface:_net_interfaces' \
  '-proxygroup=[proxy group name]:group:' \
  '*:config file:_files' && ret=0

return ret
