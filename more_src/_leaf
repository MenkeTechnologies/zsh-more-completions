#compdef leaf
# Documentation: https://docs.legato.io/latest/toolsLeaf.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'help:Displays help'
  'version:Display the version of Leaf'
  'search:Locate packages for your target'
  'setup:Initialize workspace and download packages'
  'shell:Access shell with profile configuration'
  'status:View current profiles and their conditions'
  'select:Switch between multiple profiles'
  'update:Upgrade or downgrade package versions'
  'profile:Rename, delete, or sync profiles'
  'getsrc:Switch to the source version of a package'
  'colors:Change color theme'
  'env:Manage environment variables'
  'config:Manage the configuration of leaf'
  'remote:Add, remove, and manage remote repositories'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase logging output]' \
  '(-q --quiet)'{-q,--quiet}'[minimal output]' \
  '--non-interactive[auto-select defaults]' \
  '(-w --workspace)'{-w+,--workspace=}'[workspace path]:path:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'leaf command' commands && ret=0 ;;
esac

return ret
