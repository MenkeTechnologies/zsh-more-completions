_automerge() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'export:output current state of an Automerge document in JSON/TOML'
        'import:import a JSON/TOML document and write Automerge changes'
        'examine:read an Automerge document and print JSON of changes'
        'examine-sync:read an Automerge sync message and print JSON'
        'merge:merge one or more Automerge documents into a compacted version'
        'help:show help for a subcommand'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'automerge subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                export)
                    _arguments \
                        '(-f --format)'{-f,--format}'=[output format (default json)]:format:(json toml)' \
                        '(-o --out)'{-o,--out}'=[output file (omit = stdout)]:output file:_files' \
                        '--skip-verifying-heads[skip head-hash verification of compressed document]' \
                        '1:changes file (omit = stdin):_files' && ret=0
                    ;;
                import)
                    _arguments \
                        '(-f --format)'{-f,--format}'=[input format (default json)]:format:(json toml)' \
                        '(-o --out)'{-o,--out}'=[output Automerge changes file (omit = stdout)]:changes file:_files' \
                        '1:input file (omit = stdin):_files' && ret=0
                    ;;
                examine)
                    _arguments \
                        '--skip-verifying-heads[skip head-hash verification]' \
                        '1:input file (omit = stdin):_files' && ret=0
                    ;;
                examine-sync)
                    _arguments \
                        '1:input sync message file (omit = stdin):_files' && ret=0
                    ;;
                merge)
                    _arguments \
                        '(-o --out)'{-o,--out}'=[output merged file (omit = stdout)]:output file:_files' \
                        '*:input automerge files:_files' && ret=0
                    ;;
                help)
                    _describe -t commands 'subcommand' subcmds && ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_automerge "$@"
