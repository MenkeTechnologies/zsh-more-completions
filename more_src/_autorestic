#compdef autorestic

# Zsh completion for autorestic - high-level config-based wrapper for restic

local curcontext="$curcontext" state line ret=1

_autorestic_commands() {
  local -a commands=(
    'backup:perform backups for all locations (or --location flag)'
    'check:initialize backends'
    'cron:run cron jobs as defined in config'
    'exec:execute a restic command for a specific backend'
    'forget:forget and optionally prune old backups'
    'info:display info about running backups'
    'install:install restic on your machine'
    'uninstall:uninstall restic'
    'restore:restore a location'
    'completion:generate shell completion'
    'help:show help'
    'version:show version'
  )
  _describe -t commands 'autorestic command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --all)'{-a,--all}'[apply to all locations]' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '--ci[CI mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-l --location)'{-l,--location}'[limit to these locations]:location' \
  '(-b --backend)'{-b,--backend}'[limit to these backends]:backend' \
  '--cron[run only cron-configured locations]' \
  '--lean[lean logging]' \
  '1: :_autorestic_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      restore)
        _arguments \
          '(-l --location)'{-l,--location}'[location name]:location' \
          '--from[backend to restore from]:backend' \
          '--to[target directory]:dir:_directories' \
          '--force[overwrite existing files]' && ret=0
        ;;
      forget)
        _arguments \
          '--prune[prune snapshots after forgetting]' \
          '--dry-run[dry run]' && ret=0
        ;;
      exec)
        _arguments \
          '(-b --backend)'{-b,--backend}'[backend name]:backend' \
          '*:restic command' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
