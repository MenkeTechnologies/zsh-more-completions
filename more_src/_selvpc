#compdef selvpc
# Documentation: https://pythonhosted.org/python-selvpcclient/usage/cli.html
# Selectel VPC API command line client

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--url=[API endpoint]:url' \
  '--token=[API authentication token]:token' \
  '(-v --verbose --debug)'{-v,--verbose,--debug}'[display API-level communication]' \
  '*-c[specify displayed columns]:column' \
  '*:command:((capabilities\:"show capabilities" limits\:"show domain limits" project\:"manage projects" quota\:"manage quotas" user\:"manage users" role\:"manage roles" license\:"manage licenses" floatingip\:"manage floating IPs" subnet\:"manage subnets" vrrp\:"manage VRRP subnets" token\:"manage tokens"))' && ret=0

return ret
