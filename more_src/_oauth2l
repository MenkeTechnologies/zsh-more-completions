#compdef oauth2l
# Documentation: https://github.com/google/oauth2l
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--credentials=[OAuth credential file]:file:_files' \
  '--type=[authentication type]:type:(oauth jwt sso)' \
  '--scope=[required scopes for authorization]:scope:' \
  '--sts[exchange access token with STS token]' \
  '--audience=[audience for JWT or STS]:audience:' \
  '--quota_project=[quota project for STS claims]:project:' \
  '--email=[email for SSO or domain-wide delegation]:email:' \
  '--ssocli=[path to SSO CLI]:file:_files' \
  '--cache=[path to token cache file]:file:_files' \
  '--refresh[attempt to refresh expired tokens]' \
  '--impersonate-service-account=[exchange token for service account]:account:' \
  '--disableAutoOpenConsentPage[disable automatic consent page opening]' \
  '--consentPageInteractionTimeout=[wait time for consent page interaction]:duration:' \
  '--consentPageInteractionTimeoutUnits=[units for timeout]:units:(seconds minutes)' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      'fetch:fetch and print an access token for the specified OAuth scopes'
      'header:print Authorization header'
      'curl:fetch a token and make a curl request'
      'info:print information about a valid token'
      'test:test a token (exit code 0 if valid, 1 if invalid)'
      'reset:reset all tokens cached locally'
      'web:launch the OAuth2l Playground web application'
    )
    _describe -t commands 'oauth2l command' cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
