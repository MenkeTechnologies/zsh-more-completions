#compdef oauth2l
# Documentation: https://man.archlinux.org/search?q=oauth2l
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[Show help]' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      fetch:'print OAuth access token'
      header:'print Authorization header'
      print:'print token info'
      verify:'verify a token'
      reset:'clear cached tokens'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
