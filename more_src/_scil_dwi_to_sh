#compdef scil_dwi_to_sh
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_dwi_to_sh.html
# Scilpy: fit spherical harmonics (SH) coefficients to a DWI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--sh_order=[SH order to fit]:order' \
  '--sh_basis=[SH basis]:basis:(descoteaux07 tournier07 descoteaux07_legacy tournier07_legacy)' \
  '--smooth=[lambda regularization coefficient]:smooth' \
  '--use_attenuation[use signal attenuation before fitting]' \
  '--mask=[binary mask]:mask:_files' \
  '--b0_threshold=[b0 threshold]:thr' \
  '--skip_b0_check[skip b0 existence validation]' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_dwi:_files' \
  '2:in_bval:_files' \
  '3:in_bvec:_files' \
  '4:out_sh:_files' && ret=0

return ret
