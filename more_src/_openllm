#compdef openllm
# Documentation: https://github.com/bentoml/OpenLLM
# Reference accessed: 2026-05-17
# Verified: bentoml/OpenLLM upstream — run open-source LLMs as
# OpenAI-compatible API endpoints. Subcommands: serve, run, start,
# repo (add/get/list/remove/update), model (get/list/get-bento),
# build, deploy, chat, import, prune, update, version, hello.
# `_OPENLLM_COMPLETE=zsh_source openllm` generates canonical
# click-based completion.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'hello:interactive setup'
  'serve:run a model server'
  'run:start a chat session'
  'model:manage models'
  'repo:manage model repositories'
  'deploy:deploy a model to BentoCloud'
)

_arguments -C \
  '(- *)--version[show version]' \
  '--debug[debug]' \
  '--quiet[quiet]' \
  '--do-not-track[disable usage tracking]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'openllm subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (model)
        _values 'model action' list get && ret=0
        ;;
      (repo)
        _values 'repo action' add update list remove && ret=0
        ;;
    esac
    ;;
esac

return ret
