#compdef openllm

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'hello:interactive setup'
  'serve:run a model server'
  'run:start a chat session'
  'model:manage models'
  'repo:manage model repositories'
  'deploy:deploy a model to BentoCloud'
)

_arguments -C \
  '(- *)--version[show version]' \
  '--debug[debug]' \
  '--quiet[quiet]' \
  '--do-not-track[disable usage tracking]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'openllm subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (model)
        _values 'model action' list get && ret=0
        ;;
      (repo)
        _values 'repo action' add update list remove && ret=0
        ;;
    esac
    ;;
esac

return ret
