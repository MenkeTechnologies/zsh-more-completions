#compdef clickhouse
# Documentation: https://man.archlinux.org/search?q=clickhouse
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'client:run interactive client'
  'server:run server'
  'local:run local query engine'
  'keeper:run ClickHouse Keeper'
  'keeper-client:keeper admin client'
  'copier:run copier'
  'extract-from-config:extract value from config'
  'format:format SQL queries'
  'install:install ClickHouse'
  'restart:restart server'
  'stop:stop server'
  'start:start server'
  'status:server status'
  'su:run as user'
  'hash-binary:print binary hash'
  'library-bridge:run library bridge'
  'odbc-bridge:run ODBC bridge'
  'disks:disks utility'
  'git-import:import git repo to ClickHouse'
  'obfuscator:data obfuscator'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'clickhouse subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (local)
        _arguments \
          '(-S --structure)'{-S,--structure}'=[input structure]:struct:' \
          '--input-format=[input format]:fmt:' \
          '(-F --file)'{-F,--file}'=[input file]:file:_files' \
          '(-q --query)'{-q,--query}'=[query]:sql:' \
          '--queries-file=[query file]:file:_files' \
          '(-n --multiquery)'{-n,--multiquery}'[multiple queries]' \
          '(-N --table)'{-N,--table}'=[table name]:name:' \
          '(-f --format --output-format)'{-f,--format,--output-format}'=[output format]:fmt:' \
          '(-d --database)'{-d,--database}'=[database]:db:' \
          '--stacktrace[print stack trace on errors]' \
          '--echo[echo queries]' \
          '--verbose[verbose]' \
          '--logger.console[log to console]' \
          '--logger.log=[log file]:file:_files' \
          '--logger.level=[log level]:level:' \
          '--ignore-error[ignore errors]' \
          '(-c --config-file)'{-c,--config-file}'=[config file]:file:_files' \
          '--no-system-tables[disable system tables]' && ret=0
        ;;
    esac
    ;;
esac

return ret
