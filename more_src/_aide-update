#compdef aide-update
# Documentation: https://manpages.ubuntu.com/manpages/questing/en/man1/aide.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# aide-update: update AIDE database (check + new baseline)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-B[config option (override)]:setting:' \
  '-l[limit to entries matching regex]:regex:' \
  '-V[verbosity level]:level:' \
  '*::aide-update args:_files' && ret=0
return ret
