#compdef pforth
# Documentation: https://github.com/philburk/pforth
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-i[init kernel without loading a dictionary]' \
  '-d+[dictionary file (no space after -d)]:file:_files -g "*.dic"' \
  '*:script:_files -g "*.{fs,fth}"' && ret=0

return ret
