#compdef pforth
# Documentation: https://man.archlinux.org/search?q=pforth
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-i+[init file]:file:_files' \
  '-d+[dictionary file]:file:_files -g "*.pfd"' \
  '-q[quiet]' \
  '*:script:_files -g "*.{fs,fth}"' && ret=0

return ret
