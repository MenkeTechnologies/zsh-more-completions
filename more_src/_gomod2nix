#compdef gomod2nix

# Zsh completion for gomod2nix - converts Go modules to Nix expressions

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --dir)'{-d,--dir}'[Go source directory]:path:_directories' \
  '(-o --outdir)'{-o,--outdir}'[output directory]:path:_directories' \
  '--max-workers[max concurrent workers]:number'
