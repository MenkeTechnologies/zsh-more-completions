#compdef drone

# Zsh completion for drone - Drone CI command line client

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_drone_global_flags=(
  '(-s --server)'{-s,--server}'[Server address]:server URL:'
  '(-t --token)'{-t,--token}'[Server auth token]:token:'
  '--autoscaler[Autoscaler address]:autoscaler URL:'
  '(-h --help)'{-h,--help}'[Show help]'
  '(-v --version)'{-v,--version}'[Show version]'
)

_arguments -s -S -C \
  "${_drone_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'build:Manage builds'
      'log:Manage build logs'
      'deploy:Trigger a deployment'
      'exec:Execute a local build'
      'info:Show information about the current user'
      'repo:Manage repositories'
      'user:Manage users'
      'secret:Manage secrets'
      'cron:Manage cron jobs'
      'orgsecret:Manage organization secrets'
      'server:Manage servers'
      'queue:Manage the build queue'
      'convert:Convert configuration file formats'
      'lint:Lint a configuration file'
      'sign:Sign a configuration file'
      'starlark:Execute a Starlark script'
      'jsonnet:Execute a Jsonnet script'
    )
    _describe -t commands 'drone commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      build)
        _arguments -s -S -C \
          "${_drone_global_flags[@]}" \
          '1:subcommand:((
            ls\:"list builds"
            info\:"show build details"
            stop\:"stop a build"
            start\:"start a build"
            approve\:"approve a build"
            decline\:"decline a build"
            promote\:"promote a build"
          ))' && ret=0
        ;;
      repo)
        _arguments -s -S -C \
          "${_drone_global_flags[@]}" \
          '1:subcommand:((
            ls\:"list repositories"
            info\:"show repository details"
            enable\:"enable a repository"
            disable\:"disable a repository"
            update\:"update a repository"
            sync\:"synchronize the repository list"
            chown\:"change repository ownership"
            repair\:"repair repository webhooks"
          ))' && ret=0
        ;;
      secret)
        _arguments -s -S -C \
          "${_drone_global_flags[@]}" \
          '1:subcommand:((
            ls\:"list secrets"
            info\:"show secret details"
            add\:"add a secret"
            update\:"update a secret"
            rm\:"remove a secret"
          ))' && ret=0
        ;;
      user)
        _arguments -s -S -C \
          "${_drone_global_flags[@]}" \
          '1:subcommand:((
            ls\:"list users"
            info\:"show user details"
            add\:"add a user"
            rm\:"remove a user"
          ))' && ret=0
        ;;
      cron)
        _arguments -s -S -C \
          "${_drone_global_flags[@]}" \
          '1:subcommand:((
            ls\:"list cron jobs"
            info\:"show cron job details"
            add\:"add a cron job"
            rm\:"remove a cron job"
          ))' && ret=0
        ;;
      exec)
        _arguments -s -S \
          "${_drone_global_flags[@]}" \
          '--pipeline[Name of the pipeline to execute]:pipeline:' \
          '--include[Include a pipeline step]:step:' \
          '--exclude[Exclude a pipeline step]:step:' \
          '--trusted[Enable privileged mode]' \
          '1:config file:_files -g "*.yml"' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          "${_drone_global_flags[@]}" \
          '1:repo (owner/name):' \
          '2:build number:' \
          '3:environment:' && ret=0
        ;;
      lint|sign|convert)
        _arguments -s -S \
          "${_drone_global_flags[@]}" \
          '1:config file:_files -g "*.yml"' && ret=0
        ;;
      starlark)
        _arguments -s -S \
          "${_drone_global_flags[@]}" \
          '1:starlark file:_files -g "*.star"' && ret=0
        ;;
      jsonnet)
        _arguments -s -S \
          "${_drone_global_flags[@]}" \
          '1:jsonnet file:_files -g "*.jsonnet"' && ret=0
        ;;
      log)
        _arguments -s -S -C \
          "${_drone_global_flags[@]}" \
          '1:subcommand:((
            view\:"view build logs"
            purge\:"purge build logs"
          ))' && ret=0
        ;;
      *)
        _arguments -s -S \
          "${_drone_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
