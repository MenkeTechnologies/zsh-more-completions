#compdef systemd_exporter
# Documentation: https://github.com/prometheus-community/systemd_exporter
# Prometheus exporter for systemd unit metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--systemd.collector.enable-restart-count[enable service restart count metrics]' \
  '--systemd.collector.enable-file-descriptor-size[enable file descriptor size metrics]' \
  '--systemd.collector.enable-ip-accounting[enable service IP accounting metrics]' \
  '--systemd.collector.unit-include=[regex of units to monitor]:regex' \
  '--systemd.collector.unit-exclude=[regex of units to exclude]:regex' \
  '--web.config.file=[path to TLS/basic-auth config file]:file:_files' \
  '--web.listen-address=[address to listen on for web interface and telemetry]:addr' \
  '--web.telemetry-path=[path under which to expose metrics]:path' \
  '--log.level=[only log messages with given severity or above]:level' \
  '--log.format=[output format of log messages]:format:(logfmt json)' \
  '--version[show application version]' && ret=0

return ret
