#
#   No completion for `cloudypad` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_cloudypad() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'=[verbosity level 0-6]:level:(0 1 2 3 4 5 6)' \
        '1: :_cloudypad_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                create|update)
                    _arguments \
                        '1:provider:(aws azure gcp paperspace scaleway ssh)' \
                        '*::arg:' && ret=0 ;;
                list)
                    _arguments \
                        '--format=[output format]:format:(plain json)' && ret=0 ;;
                start|stop|restart)
                    _arguments \
                        '--wait[wait for instance state change]' \
                        '--timeout=[wait timeout in seconds (with --wait)]:secs:' \
                        '--retries=[retry count]:n:' \
                        '--retry-delay=[retry delay in seconds]:secs:' \
                        '--force-pulumi-cancel[force-cancel a Pulumi update in flight]' \
                        '--ansible-args-override=[Ansible args override]:args:' \
                        ':instance name:' && ret=0 ;;
                get)
                    _arguments ':instance name:' && ret=0 ;;
                provision|destroy)
                    _arguments \
                        '--yes[auto-approve]' \
                        '--retries=[retry count]:n:' \
                        '--retry-delay=[retry delay in seconds]:secs:' \
                        '--force-pulumi-cancel[force-cancel Pulumi update]' \
                        ':instance name:' && ret=0 ;;
                configure|deploy)
                    _arguments \
                        '--retries=[retry count]:n:' \
                        '--retry-delay=[retry delay in seconds]:secs:' \
                        '--force-pulumi-cancel[force-cancel Pulumi update]' \
                        '--ansible-args-override=[Ansible args override]:args:' \
                        ':instance name:' && ret=0 ;;
                pair)
                    _arguments ':instance name:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_cloudypad_commands] )) ||
_cloudypad_commands() {
    local -a commands
    commands=(
        'create:create a new instance'
        'update:update an existing instance'
        'list:list all instances'
        'start:start an instance'
        'stop:stop an instance'
        'restart:restart an instance'
        'get:get state + status of an instance'
        'provision:deploy or update Cloud resources'
        'configure:install drivers / packages via Ansible'
        'deploy:combined provision + configure'
        'destroy:destroy the cloud instance'
        'pair:pair Moonlight client to Sunshine host'
    )
    _describe -t commands 'cloudypad command' commands
}

_cloudypad "$@"
