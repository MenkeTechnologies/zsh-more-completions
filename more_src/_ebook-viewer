#compdef ebook-viewer
# Documentation: https://manual.calibre-ebook.com/generated/en/ebook-viewer.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--detach[detach from controlling terminal (Linux only)]' \
  '(-f --full-screen --fullscreen)'{-f,--full-screen,--fullscreen}'[start in full-screen mode]' \
  '--continue[continue reading at last saved position]' \
  '--open-at=[open at given location/toc/ref/search]:pos:' \
  '--raise-window[raise window on startup if already open]' \
  '--force-reload[force reload of all opened books]' \
  '--new-instance[launch a new viewer window regardless of single-window settings]' \
  '*:ebook file:_files -g "*.epub *.mobi *.azw *.azw3 *.azw4 *.fb2 *.lit *.pdb *.pdf *.lrf *.lrx *.rb *.rtf *.cbz *.cbr *.cbc *.djvu *.txt"' && ret=0

return ret
