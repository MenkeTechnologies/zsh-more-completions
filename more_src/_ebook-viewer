#compdef ebook-viewer
# Documentation: https://man.archlinux.org/search?q=ebook-viewer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--detach[detach from controlling terminal]' \
  '--full-screen[start in full screen mode]' \
  '--continue-reading[continue reading at saved position]' \
  '--open-at=[open at position]:pos:' \
  '--raise-window[raise window if already open]' \
  '--force-reload[force reload of book]' \
  '--with-debug=[debug logging file]:file:_files' \
  '--manage-account[manage user accounts]' \
  '--profile[profile startup]' \
  '*:ebook file:_files -g "*.epub *.mobi *.azw *.azw3 *.azw4 *.fb2 *.lit *.pdb *.pdf *.lrf *.lrx *.rb *.rtf *.cbz *.cbr *.cbc *.djvu *.txt"' && ret=0

return ret
