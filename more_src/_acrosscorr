#compdef acrosscorr
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/acrosscorr.html
# Cross-correlate two N-dimensional images or autocorrelate an image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile1=[first input image file]:file:_files' \
  'infile2=[second input image file (NONE for autocorrelation)]:file:_files' \
  'outfile=[output image file]:file:_files' \
  'crop=[crop output to the size of infile1]:crop:(yes no)' \
  'pad=[pad data to the size of infile1 + infile2]:pad:(yes no)' \
  'center=[zero-offset point in center of output array]:center:(yes no)' \
  'clobber=[clobber existing output files]:clobber:(yes no)' \
  'verbose=[processing verbosity level]:verbose:(0 1 2 3 4 5)' && ret=0

return ret
