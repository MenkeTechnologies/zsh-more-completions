#compdef rokit
# Documentation: https://github.com/rojo-rbx/rokit
# rokit - toolchain manager for Roblox and Luau projects

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-v,--verbose}'[increase logging verbosity]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a cmds
    cmds=(
      'init:initialize a new project in the current directory'
      'add:add and install a tool'
      'list:list all currently installed tools'
      'install:install all project-specific tools'
      'update:update a tool or all project-specific tools'
      'authenticate:authenticate with GitHub or other artifact providers'
      'trust:mark a tool as trusted'
      'system-info:show system information'
      'self-install:install Rokit itself and update tool links'
      'self-update:update Rokit itself to the latest version'
    )
    _describe -t commands 'rokit command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments -s \
          '--global[add this tool globally instead of the nearest manifest]' \
          '--force[force add and install even if already present]' \
          '1:tool spec:' \
          '2:alias:' && ret=0
        ;;
      install)
        _arguments -s \
          '--no-trust-check[skip checking if tools have been trusted]' \
          '--force[force install all tools even if already installed]' && ret=0
        ;;
      update)
        _arguments -s \
          '--global[update tools globally instead of the nearest manifest]' \
          '--check[check for updates without updating]' \
          '*:tool:' && ret=0
        ;;
      list)
        _arguments -s '1:tool id:' && ret=0
        ;;
      init)
        _arguments -s '--force[overwrite an existing project]' && ret=0
        ;;
      authenticate)
        _arguments -s \
          '--token=[token to use for authentication]:token:' \
          '--remove[remove the stored token]' \
          '--skip-parse[skip parse validation when adding a token]' \
          '--skip-verify[skip live API verification when adding a token]' \
          '1:provider:(github)' && ret=0
        ;;
    esac
    ;;
esac

return ret
