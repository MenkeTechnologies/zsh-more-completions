#compdef kubectl-grep

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-A[search all namespaces]' \
  '-i[case-insensitive search]' \
  '-n[search in namespace]:namespace:' \
  '-l[label selector]:selector:' \
  '-F[field selector]:fields:' \
  '-o[output format]:format:(wide yaml json name)' \
  '1:regular expression:' \
  '2:resource type:(pods deployments configmaps secrets services namespaces nodes customresourcedefinitions)' \
  '*:resource names: _default'
