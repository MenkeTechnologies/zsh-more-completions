#compdef aliyunpan
# Documentation: https://github.com/tickstep/aliyunpan
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# tickstep/aliyunpan — main.go app.Commands (urfave/cli v1)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--verbose[enable debug logs]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd)
    local -a cmds=(
      login logout loglist drive su who quota cd pwd ls tree mkdir rm cp mv
      rename sync upload download config tool share album xcp sharew save recycle
      history clear update quit run env
    )
    _describe -t commands 'aliyunpan command' cmds && ret=0
    ;;
  (rest)
    _arguments '*:arguments:_default' && ret=0
    ;;
esac

return ret
