#compdef parse
# _parse — Parse Server CLI (parse-community/parse-cli)
# upstream: https://github.com/parse-community/parse-cli

_parse() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_parse_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                new)
                    _arguments \
                        '1:app name:' \
                        '--help[show help]' && ret=0 ;;
                deploy)
                    _arguments \
                        '--description=[deploy description]:desc:' \
                        '--help[show help]' && ret=0 ;;
                develop)
                    _arguments \
                        '1:app name:' \
                        '--help[show help]' && ret=0 ;;
                add)
                    _arguments \
                        '1:app name:' \
                        '--help[show help]' && ret=0 ;;
                *)
                    _arguments '--help[show help]' '*:args:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_parse_commands] )) ||
_parse_commands() {
    local -a commands
    commands=(
        'add:add an existing Parse app'
        'configure:configure Parse CLI'
        'default:set default Parse app'
        'deploy:deploy cloud code'
        'develop:start cloud code development server'
        'functions:list cloud functions'
        'generate:generate a sample express app'
        'jssdk:set JavaScript SDK version'
        'list:list connected Parse apps'
        'logs:show cloud code logs'
        'migrate:migrate Parse app to self-hosted'
        'new:create a new Parse app'
        'releases:list recent releases'
        'rollback:rollback to a previous release'
        'symbols:upload iOS symbol files'
        'triggers:list cloud triggers'
        'update:update Parse CLI'
        'version:show version'
    )
    _describe -t commands 'parse command' commands
}

_parse "$@"
