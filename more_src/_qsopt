#compdef qsopt
# Documentation: https://www.math.uwaterloo.ca/~bico/qsopt/
# QSopt linear programming solver

local ret=1

_arguments -s \
  '-v[print QSopt version number]' \
  '-L[input file is in LP format (default: MPS)]' \
  '-O[write the final solution to file (append .gz/.bz2 to compress)]:file:_files' \
  '-b[write basis to file]:file:_files' \
  '-B[read initial basis from file]:file:_files' \
  '-p[run primal simplex with pricing rule (1-4)]:rule:(1 2 3 4 5)' \
  '-d[run dual simplex with pricing rule (6-9)]:rule:(6 7 8 9)' \
  '-P[number of bits for float representation (default 128)]:bits' \
  '-S[do NOT scale the initial LP]' \
  '-R[maximum running time allowed]:seconds' \
  '-m[maximum memory usage allowed]:bytes' \
  '*:file:_files' && ret=0

return ret
