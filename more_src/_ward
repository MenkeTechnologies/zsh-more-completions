#compdef ward

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--search=[search query for tests]:query' \
  '--tags=[filter by test tags]:tags' \
  '--exclude-tags=[exclude by test tags]:tags' \
  '-p+[path to look for tests in]:directory:_directories' \
  '--path=[path to look for tests in]:directory:_directories' \
  '--order=[execution order]:order:(standard random)' \
  '--fail-limit=[stop after N failures]:count' \
  '--dry-run[do not execute tests]' \
  '--show-diff-symbols[show diff symbols on failure]' \
  '--test-output-style=[test output style]:style:(test-per-line dots-global dots-module)' \
  '--progress-style=[progress bar style]:style:(bar inline)' \
  '--config=[path to config file]:config file:_files' \
  '--hook-module=[module containing lifecycle hooks]:module' \
  '-W+[set number of workers]:count' \
  '--num-workers=[set number of workers]:count' \
  '--capture-output[capture stdout and stderr]' \
  '--no-capture-output[do not capture stdout and stderr]' && ret=0

return ret
