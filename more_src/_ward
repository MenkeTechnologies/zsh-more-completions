#compdef ward
# _ward — Ward Python test framework (darrenburns/ward)
# upstream: https://github.com/darrenburns/ward

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --path)'{-p,--path}'=[test path]:path:_files -/' \
  '--exclude=[exclude pattern]:pattern:' \
  '(-s --search)'{-s,--search}'=[search query]:query:' \
  '(-t --tags)'{-t,--tags}'=[filter by tags]:tags:' \
  '--fail-limit=[stop after N failures]:count:' \
  '--test-output-style=[output style]:style:(test-per-line dots-global dots-module live)' \
  '--order=[test order]:order:(standard random)' \
  '--show-slowest=[show N slowest tests]:count:' \
  '--dry-run[list tests without running]' \
  '--config-path=[config file]:file:_files' \
  '--progress-style=[progress bar style]:style:(inline bar)'
