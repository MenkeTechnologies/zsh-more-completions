#compdef cozo

local curcontext="$curcontext" state line ret=1
local -a commands engines

commands=(
  'server:start the Cozo HTTP server'
  'repl:start an interactive REPL'
  'help:show help for a subcommand'
)

engines=(mem sqlite rocksdb tikv sled)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cozo command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (server)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-e --engine)'{-e+,--engine=}'[storage engine]:engine:(mem sqlite rocksdb tikv sled)' \
          '(-p --path)'{-p+,--path=}'[database file path]:file:_files' \
          '--restore=[restore from backup]:file:_files' \
          '(-c --config)'{-c+,--config=}'[engine config (JSON)]:json:' \
          '(-b --bind)'{-b+,--bind=}'[bind address]:address:_hosts' \
          '(-P --port)'{-P+,--port=}'[bind port]:port:' \
          '--token_table=[name of token table for auth]:table:' && ret=0 ;;
      (repl)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-e --engine)'{-e+,--engine=}'[storage engine]:engine:(mem sqlite rocksdb tikv sled)' \
          '(-p --path)'{-p+,--path=}'[database file path]:file:_files' \
          '(-c --config)'{-c+,--config=}'[engine config (JSON)]:json:' && ret=0 ;;
    esac ;;
esac

return ret
