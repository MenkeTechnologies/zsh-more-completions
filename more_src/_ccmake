#compdef ccmake
# _ccmake — CMake ncurses interactive config (Kitware, C++); curses-based CMake cache editor
# upstream: https://github.com/Kitware/CMake

_ccmake() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-S+[source dir]:dir:_files -/' \
        '-B+[build dir]:dir:_files -/' \
        '-C+[initial cache]:file:_files' \
        '-D+[cache entry]:KEY=VAL:' \
        '-U+[remove cache entry]:str:' \
        '-G+[generator]:generator:(Ninja Unix\\ Makefiles MSYS\\ Makefiles MinGW\\ Makefiles)' \
        '-T+[toolset]:str:' \
        '-A+[platform]:str:' \
        '*:path:_files'
}

_ccmake "$@"
