#compdef mafGene
# UCSC kent: output protein alignments using maf and genePred

local ret=1

_arguments -s -S \
  '-twoBit=[use 2bit file to fill alignment gaps instead of database]:file:_files -g "*.2bit"' \
  '-geneName=[gene name as it appears in genePred]:name' \
  '-geneList=[file containing list of genes]:file:_files' \
  '-geneBeds=[bed file with genes and positions]:file:_files -g "*.bed"' \
  '-chrom=[chromosome name for gene retrieval]:chr' \
  '-useFile[treat genePredTable as a file]' \
  '-exons[output exons]' \
  '-noTrans[skip amino acid translation]' \
  '-uniqAA[unique pseudo-AA for each codon]' \
  '-includeUtr[include UTRs (requires -noTrans)]' \
  '-delay=[delay N seconds between genes (default 0)]:n' \
  '-noDash[omit lines containing only dashes]' \
  '1:database:' \
  '2:maf table:' \
  '3:genePred table or file:_files' \
  '4:species list:_files' \
  '5:output:_files' && ret=0

return ret
