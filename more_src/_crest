#compdef crest
# Documentation: https://crest-lab.github.io/crest-docs/
# Source: crest-lab/crest (Grimme group conformer/rotamer ensemble search via xTB).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-T+[CPU threads]:n:_default' \
    '--T=[CPU threads]:n:_default' \
    '--dry[preview settings without running]' \
    '--niceprint[inline progress bars]' \
    '--scratch=[run in scratch directory]:dir:_directories' \
    '--keepdir[preserve subdirectories]' \
    '--chrg=[molecular charge]:int:_default' \
    '--uhf=[unpaired electrons]:int:_default' \
    '--gfn1[use GFN1-xTB]' \
    '--gfn2[use GFN2-xTB]' \
    '--gff[use GFN-FF force field]' \
    '--alpb=[ALPB implicit solvation]:solvent:_default' \
    '--opt=[geometry optimization level]:level:_default' \
    '--optlev=[optimization convergence level]:level:(crude vloose loose normal tight vtight extreme)' \
    '--mdlen=[metadynamics length (ps)]:ps:_default' \
    '--tstep=[MD timestep (fs)]:fs:_default' \
    '--shake=[SHAKE constraint]:level:(0 1 2)' \
    '--tnmd=[post-MTD MD temperature (K, default 400)]:K:_default' \
    '--hflip[enable XH group rotation enhancement]' \
    '--noflip[disable XH group rotation enhancement]' \
    '--quick[reduced-setting search]' \
    '--squick[smaller reduced-setting search]' \
    '--mquick[medium reduced-setting search]' \
    '--nci[non-covalent complex mode]' \
    '--ewin=[energy threshold (kcal/mol)]:kcal:_default' \
    '--rthr=[RMSD threshold (angstrom)]:angstrom:_default' \
    '--cluster=[PCA clustering arg]:arg:_default' \
    '--cregen=[ensemble file to process]:file:_files' \
    '--for=[ensemble file]:file:_files' \
    '--noheavy[skip heavy-atom MD]' \
    '--restart[restart from previous run]' \
    '1:input structure:_files -g "*.(xyz|coord|sdf|mol)(-.)"' \
    && ret=0

return ret
