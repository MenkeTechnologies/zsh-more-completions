#compdef phenix.ligand_identification
# Documentation: https://phenix-online.org/documentation/reference/ligand_identification.html
# phenix.ligand_identification - identify unknown ligand density against a library

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'mtz_in=[MTZ file containing structure factors]:file:_files' \
  'model=[PDB file with protein model (no ligand)]:file:_files' \
  'mtz_type=[type of input map]:type:(F diffmap)' \
  'input_labels=[column labels for data]:labels:' \
  'work_dir=[top-level directory for job execution]:dir:_files -/' \
  'output_dir=[output directory for results]:dir:_files -/' \
  'temp_dir=[temporary work directory]:dir:_files -/' \
  'ligand_list=[specific ligands in 3-letter codes]:codes:' \
  'ligand_dir=[directory with custom ligand library]:dir:_files -/' \
  'use_pdb_ligand=[use ligands from homologous structures]:bool:(True False)' \
  'function=[filter by protein function description]:str:' \
  'EC=[filter by Enzyme Classification number]:ec:' \
  'pfam=[filter by Pfam accession]:acc:' \
  'scop_fold=[filter by SCOP terms]:term:' \
  'cath=[filter by CATH terms]:term:' \
  'go=[filter by Gene Ontology number]:go:' \
  'ipro=[filter by InterPro ID]:id:' \
  'natom_min=[minimum ligand atom count]:n:' \
  'natom_max=[maximum ligand atom count]:n:' \
  'search_center=[search region center coordinates]:xyz:' \
  'ligand_near_res=[target protein residue for search]:res:' \
  'high_resolution=[high-resolution cutoff]:val:' \
  'low_resolution=[low-resolution limit]:val:' \
  'nproc=[number of processors/threads]:n:' \
  'restart_run=[continue unfinished runs]:bool:(True False)' \
  'verbose=[enable verbose output]:bool:(True False)' \
  'debug=[enable debugging output]:bool:(True False)' \
  'open_in_coot=[auto-launch Coot with results]:bool:(True False)' \
  'dry_run=[check parameters without running]:bool:(True False)' \
  '*:file:_files' && ret=0

return ret
