#compdef create-elit
# Documentation: https://www.npmjs.com/package/create-elit
# Reference accessed: 2026-05-23
# Verified: npm view create-elit bin; npm readme CLI flags section.

# Zsh completion for create-elit - Elit template-based app scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-t --template)'{-t,--template=}'[template to scaffold]:template:' \
  '(-l --list-templates)'{-l,--list-templates}'[list available templates]' \
  '(-h --help)'{-h,--help}'[show usage and template options]' \
  ':project name:' && ret=0

return ret
