#compdef valkey-server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--port=[listen port]:port:' \
  '--bind=[bind address]:address:_hosts' \
  '--unixsocket=[Unix socket path]:socket:_files' \
  '--unixsocketperm=[Unix socket permissions]:permissions:' \
  '--daemonize[run as daemon]::(yes no)' \
  '--pidfile=[PID file]:file:_files' \
  '--loglevel=[log level]:level:(debug verbose notice warning)' \
  '--logfile=[log file]:file:_files' \
  '--databases=[number of databases]:count:' \
  '--maxmemory=[max memory]:bytes:' \
  '--maxclients=[max number of clients]:count:' \
  '--hz=[server frequency in hz]:hz:' \
  '--tcp-backlog=[TCP backlog]:size:' \
  '--timeout=[client timeout in seconds]:seconds:' \
  '--tcp-keepalive=[TCP keepalive interval]:seconds:' \
  '--maxmemory-policy=[eviction policy]:policy:(volatile-lru allkeys-lru volatile-lfu allkeys-lfu volatile-random allkeys-random volatile-ttl noeviction)' \
  '--requirepass=[password]:password:' \
  '--dir=[working directory]:directory:_directories' \
  '--dbfilename=[RDB filename]:filename:' \
  '--appendonly[enable AOF]::(yes no)' \
  '--appendfilename=[AOF filename]:filename:' \
  '--appendfsync=[AOF sync policy]:policy:(always everysec no)' \
  '--save=[RDB save schedule]:schedule:' \
  '--slaveof=[replicate from master]:host port:' \
  '--replicaof=[replicate from master]:host port:' \
  '--masterauth=[master authentication]:password:' \
  '--cluster-enabled[enable cluster mode]::(yes no)' \
  '--cluster-config-file=[cluster config file]:file:_files' \
  '--cluster-node-timeout=[cluster node timeout]:milliseconds:' \
  '--io-threads=[number of IO threads]:threads:' \
  '--io-threads-do-reads[use IO threads for reads]::(yes no)' \
  '--tls-port=[TLS listen port]:port:' \
  '--tls-cert-file=[TLS certificate file]:file:_files' \
  '--tls-key-file=[TLS key file]:file:_files' \
  '--tls-ca-cert-file=[TLS CA certificate file]:file:_files' \
  '--supervised=[supervision mode]:mode:(no upstart systemd auto)' \
  '--sentinel[run in sentinel mode]' \
  '--test-memory=[test memory with specified megabytes]:megabytes:' \
  '--check-system[check system configuration]' \
  '--protected-mode[enable protected mode]::(yes no)' \
  '--loadmodule=[load module]:module:_files' \
  '1:config file:_files -g "*.conf"' \
  '*:config overrides:' && ret=0

return ret
