#compdef mtr-ng
# Documentation: https://crates.io/crates/mtr-ng
# Source: https://github.com/edejong-dbc/mtr-ng/blob/main/src/args.rs
# Reference accessed: 2026-06-01
# Modern My Traceroute clone in Rust with sparklines + jitter analysis.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _mng_cols
_mng_cols=(hop host loss sent last avg ema jitter jitter-avg best worst graph)

_arguments -s -S \
    '(-c --count)'{-c+,--count=}'[number of probes (continuous if omitted)]:n:_default' \
    '(-i --interval)'{-i+,--interval=}'[probe interval ms (default 1000)]:ms:_default' \
    '(-M --max-hops)'{-M+,--max-hops=}'[maximum hops (default 30)]:n:_default' \
    '(-r --report)'{-r,--report}'[report mode (non-interactive)]' \
    '(-n --numeric)'{-n,--numeric}'[do not resolve hostnames]' \
    '--sparkline-scale=[sparkline scaling]:scale:(linear logarithmic)' \
    '--ema-alpha=[EMA smoothing alpha (default 0.1)]:alpha:_default' \
    '--fields=[comma-separated columns to display]:columns:_default' \
    '--show-all[display all available columns]' \
    '--simulate[simulation mode with fake network data]' \
    '(-P --protocol)'{-P+,--protocol=}'[probe protocol]:proto:(icmp udp tcp)' \
    '--force-simulate[force simulation mode even with root]' \
    '--timing[include timing statistics in output]' \
    '(-q --quiet)'{-q,--quiet}'[quiet mode - minimal output]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:target host:_hosts' \
    && ret=0

return ret
