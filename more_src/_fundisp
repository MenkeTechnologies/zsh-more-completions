#compdef fundisp
# Documentation: https://github.com/ericmandel/funtools/blob/master/man/man1/fundisp.1
# Display data in a Funtools data file

local ret=1

_arguments -s -S \
  '-f+[format string for display output]:format' \
  '-l[display image data as X, Y, VAL list]' \
  '-n[suppress header output]' \
  '-F+[column separator character]:char' \
  '-T[output in rdb/starbase format (tab separators)]' \
  '*:input file:_files' && ret=0

return ret
