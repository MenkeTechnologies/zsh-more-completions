#compdef odhcpd
# Documentation: https://man.archlinux.org/search?q=odhcpd
# Reference accessed: 2026-05-16

# odhcpd: lightweight DHCPv4/v6 + RA daemon (OpenWrt)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[debug / foreground]' \
  '-S[disable scripting]' \
  '-T[take down all interfaces]' \
  '*::odhcpd args:_files' && ret=0
return ret
