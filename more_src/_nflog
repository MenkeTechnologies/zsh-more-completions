#compdef nflog
# _nflog — netfilter NFLOG target helper (small wrapper around iptables -j NFLOG used in some distros to push every accepted packet to a numbered NFLOG group; -g group, -r prefix message, -t threshold packets, -q quiet, -V version, -h help; positional argument is the chain to instrument)
# upstream: distro-shipped (Debian iptables NFLOG companion)
# Common flag shape from iptables NFLOG xtables-extensions.

_nflog() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-g+[group]:group:' \
        '-r+[prefix message]:prefix:' \
        '-t+[threshold packets]:n:' \
        '-q[quiet]'
}

_nflog "$@"
