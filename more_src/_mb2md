#compdef mb2md mbox2maildir
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mb2md.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. mb2md uses only short single-letter
# options; no long-form (--source/--dest/--version/--help) options exist.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help]' \
  '-c[use Content-Length headers to locate next message]' \
  '-m[convert a single system mailbox to destination]' \
  '-s+[source directory or mbox file]:src:_files' \
  '-d+[destination directory]:dest:_files -/' \
  '-l+[file listing subscribed folders for migration]:file:_files' \
  '-R[recursively process subdirectories]' \
  '-f+[specific folder within source dir]:folder:' \
  '-r+[file extension to strip before creating maildir]:ext:' \
  '*: :_files' && ret=0

return ret
