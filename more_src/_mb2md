#compdef mb2md mbox2maildir
# Documentation: https://man.archlinux.org/search?q=mb2md
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-s+[source mbox/dir]:src:_files' \
  '--source=[source mbox/dir]:src:_files' \
  '-d+[destination Maildir]:dest:_files -/' \
  '--dest=[destination Maildir]:dest:_files -/' \
  '-l+[mbox file list]:file:_files' \
  '-R+[recurse subdirs]:b:(yes no)' \
  '-m[Mutt-style mbox]' \
  '-n+[new prefix]:p:' \
  '-S+[sub-folders prefix]:p:' \
  '-r[remove existing]' \
  '*: :_files' && ret=0

return ret
