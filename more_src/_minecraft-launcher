#compdef minecraft-launcher
# Documentation: https://help.minecraft.net/hc/en-us/sections/360002715551
# Reference accessed: 2026-05-16

# minecraft-launcher: official Minecraft Java Edition launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--debug[enable debug logging]' \
  '--lang=[language]:lang:(en-us en-gb de-de es-es fr-fr it-it ja-jp ko-kr pt-br ru-ru zh-cn zh-tw)' \
  '--workDir=[working directory]:dir:_files -/' \
  '--launcherUrl=[launcher download URL]:url:' \
  '--launchInGame[launch directly into the game]' \
  '--username=[Mojang username]:user:' \
  '--accessToken=[access token]:token:' \
  '--launcherVersion=[launcher version]:ver:' \
  '*::minecraft-launcher args:_files' && ret=0
return ret
