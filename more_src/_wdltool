#compdef wdltool
# Documentation: https://github.com/broadinstitute/wdltool
# wdltool - Broad Institute WDL parsing and validation tool

local ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:action:(validate inputs parse highlight)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      highlight)
        _arguments -s -S \
          '1:WDL file:_files -g "*.wdl"' \
          '2:output type:(html console)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '*:WDL file:_files -g "*.wdl"' && ret=0
        ;;
    esac
    ;;
esac

return ret
