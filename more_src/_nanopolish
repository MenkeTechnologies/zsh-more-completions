#compdef nanopolish
# Documentation: https://github.com/jts/nanopolish
# nanopolish: signal-level analysis of Oxford Nanopore sequencing data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'nanopolish subcommand' \
      'index[index signal files from the sequencer]' \
      'call-methylation[predict genomic bases that may be methylated]' \
      'variants[detect SNPs and indels with respect to a reference]' \
      'eventalign[align signal-level events to k-mers of a reference]' \
      'polya[estimate poly-A tail lengths on direct RNA reads]' \
      'phase-reads[phase reads using variants]' \
      'vcf2fasta[generate polished genome from VCF output]' \
      'methyltrain[train methylation model]' && ret=0
    _files
    ;;
esac

return ret
