#compdef rivertile

# Zsh completion for rivertile - tiled layout generator for river

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-view-padding)'-view-padding'[set padding between views]:pixels' \
  '(-outer-padding)'-outer-padding'[set outer padding]:pixels' \
  '(-main-location)'-main-location'[main area location]:location:(left right top bottom)' \
  '(-main-count)'-main-count'[number of main views]:count' \
  '(-main-ratio)'-main-ratio'[main area ratio (0.0-1.0)]:ratio'
