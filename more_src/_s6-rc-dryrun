#compdef s6-rc-dryrun s6-rc-fdholder-filler s6-rc-format-upgrade s6-rc-oneshot-run
# Documentation: source-direct extraction from upstream skarnet/s6-rc
# src/s6-rc/s6-rc-{dryrun,fdholder-filler,format-upgrade,oneshot-run}.c
# USAGE strings + subgetopt_r option-string specs / skalibs GOL_main
# gol_bool + gol_arg tables.
# Reference accessed: 2026-05-30 via gh api.
# Skarnet s6-rc tail R124 — 4-stem multi-binary harvest of the
# s6-rc service-manager binaries not previously covered. Sister
# tools to the existing s6-rc/s6-rc-bundle/s6-rc-compile/s6-rc-db/
# s6-rc-init/s6-rc-update completions. s6-rc layers atomic
# state-transition planning on top of the s6 supervision framework
# (R117-R123).

case $service in

  s6-rc-dryrun)
    # Simulate what s6-rc would do without actually executing the
    # transition. Reads the same args (-u/-d/-a/etc + service names)
    # as s6-rc itself, but prints the transition plan to stdout
    # instead of running it.
    _arguments -s -S \
      '-v+[verbosity level (default 1)]:level:' \
      '-t+[transition timeout in ms (default 0=infinite)]:ms:' \
      '*:s6-rc args:'
    ;;

  s6-rc-fdholder-filler)
    # Bootstrap helper invoked by s6-rc-init: populates an
    # s6-fdholderd server with pre-bound socket fds for services
    # that need them (typically inet sockets bound by root before
    # privilege drop). Reads filenames + ids from stdin (the
    # `autofilled-filename` file written by s6-rc-init).
    _arguments -s -S \
      '-1[notify readiness by writing newline + closing fd 1]' \
      '-t+[per-fd-handoff timeout in ms]:ms:'
    ;;

  s6-rc-format-upgrade)
    # Upgrade an existing s6-rc live state directory from an older
    # compiled-db format to the current one. Used during s6-rc
    # version upgrades.
    _arguments -s -S \
      '-v+[verbosity level (default 1)]:level:' \
      '-t+[transition timeout in ms]:ms:' \
      '-l+[s6-rc live state directory (default /run/s6-rc)]:livedir:_directories' \
      '-b[block on the lock if another s6-rc is running]' \
      '1:new compiled-db directory:_directories'
    ;;

  s6-rc-oneshot-run)
    # Internal helper invoked by s6-rc to run a oneshot service's
    # up or down script with the right environment. Not typically
    # called directly.
    _arguments -s -S \
      '(--no-block)'{-b,--block}'[block on the s6-rc live-state lock]' \
      '(-b --block)--no-block[do NOT block on the lock (default)]' \
      '(-l --livedir)'{-l+,--livedir=}'[s6-rc live state directory]:livedir:_directories' \
      '1:transition direction:(up down)' \
      '2:service number in compiled db:'
    ;;

esac
