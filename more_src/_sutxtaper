#compdef sutxtaper
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/tapering/sutxtaper.c
# taper in (X,T) the edges of a data panel to zero

local ret=1

_arguments -s -S \
  'low=[minimum amplitude factor of taper]:low' \
  'tbeg=[length of taper (ms) at trace start]:tbeg' \
  'tend=[length of taper (ms) at trace end]:tend' \
  'taper=[taper type 1..5]:taper:(1 2 3 4 5)' \
  'key=[key to compute x-domain taper weights]:key' \
  'tr1=[number of traces to taper at beg]:tr1' \
  'tr2=[number of traces to taper at end]:tr2' \
  'min=[minimum key value where taper starts]:min' \
  'max=[maximum key value where taper starts]:max' \
  'dx=[length of taper (in key units)]:dx' \
  '*:file:_files' && ret=0


return ret
