#compdef netperf

# Zsh completion for netperf - network performance benchmark

_arguments -s -S \
  '-H[specify remote host]:remote host:_hosts' \
  '-l[set test length in seconds]:seconds' \
  '-t[set test type]:test type:(TCP_STREAM TCP_MAERTS TCP_RR TCP_CRR UDP_STREAM UDP_RR)' \
  '-p[specify remote port]:port' \
  '-f[set output format]:format:(k m g K M G)' \
  '-P[specify local port]:port' \
  '-i[set maximum confidence iterations]:iterations' \
  '-I[set confidence level]:confidence level' \
  '-c[set local CPU rate]:CPU rate' \
  '-C[set remote CPU rate]:CPU rate' \
  '-v[set verbosity level]:verbosity:(0 1 2)' \
  '-o[set output selector list]:output selector' \
  '-O[set output selector list with headers]:output selector' \
  '-j[keep additional timing statistics]' \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  '-B[set local IP address]:local address' \
  '-F[specify fill file]:fill file:_files' \
  '-n[do not establish a control connection first]' \
  '-N[set TCP_NODELAY on data socket]' \
  '-T[set processor affinity]:processor' \
  '-L[set local IP TOS value]:TOS value' \
  '-d[enable debug output]' \
  '-D[set demo mode interval]:interval' \
  '(- *)-V[show version]' \
  '(- *)-h[show help]'
