#compdef netperf

# completions for netperf - network performance benchmark

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-H[remote host]:remote host:_hosts' \
  '-l[test length in seconds]:seconds' \
  '-t[test type]:test type:(TCP_STREAM TCP_MAERTS TCP_RR TCP_CRR UDP_STREAM UDP_RR DLCO_STREAM DLCO_RR)' \
  '-p[remote port]:port' \
  '-f[output format]:format:(k m g K M G)' \
  '-P[local port]:port' \
  '-i[confidence iterations]:iterations' \
  '-I[confidence level]:level' \
  '-c[measure local CPU usage]' \
  '-C[measure remote CPU usage]' \
  '-v[verbosity level]:level:(0 1 2)' \
  '-o[output selector]:selector' \
  '-O[output selector with headers]:selector' \
  '-j[keep additional timing stats]' \
  '-4[use IPv4]' \
  '-6[use IPv6]' \
  '-B[local address]:local address' \
  '-F[fill file]:fill file:_files' \
  '-s[send socket buffer size]:size' \
  '-S[recv socket buffer size]:size' \
  '-n[no control connection]' \
  '-N[set TCP_NODELAY]' \
  '-T[processor affinity]:processor' \
  '-L[local IP TOS]:TOS' \
  '-d[debug mode]' \
  '-D[demo mode interval]:interval'
