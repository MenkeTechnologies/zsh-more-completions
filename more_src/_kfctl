#compdef kfctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'alpha:experimental subcommands'
  'apply:apply a Kubeflow config'
  'build:build manifests from a config'
  'delete:tear down deployment'
  'generate:generate config files'
  'init:initialize project (deprecated)'
  'mirror:image mirroring helper'
  'mirror-build:build image mirror'
  'mirror-overwrite:overwrite mirrored images'
  'set-image-name:rewrite image names'
  'show:print config or status'
  'version:print kfctl version'
  'completion:generate shell completion'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*'{-V,--verbose}'[verbose output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'kfctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (apply|build|delete)
        _arguments \
          '(-f --file)'{-f,--file=}'[KfDef file]:file:_files -g "*.(yaml|yml)"' \
          '--delete_storage[delete persistent storage]' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
