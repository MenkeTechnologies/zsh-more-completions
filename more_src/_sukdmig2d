#compdef sukdmig2d
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/migration_inversion/sukdmig2d.c
# 2D prestack Kirchhoff depth migration of SU data

local ret=1

_arguments -s -S \
  'infile=[input SU data file]:file:_files' \
  'outfile=[output migrated file]:file:_files' \
  'ttfile=[input traveltime tables file]:file:_files' \
  'fzt=[first depth sample in traveltime table]:fzt' \
  'nzt=[number of depth samples in traveltime table]:nzt' \
  'dzt=[depth interval in traveltime table]:dzt' \
  'fxt=[first lateral sample in traveltime table]:fxt' \
  'nxt=[number of lateral samples in traveltime table]:nxt' \
  'dxt=[lateral interval in traveltime table]:dxt' \
  'fs=[first source coordinate]:fs' \
  'ns=[number of sources]:ns' \
  'ds=[source coordinate interval]:ds' \
  'dt=[time sampling interval]:dt' \
  'ft=[first time sample]:ft' \
  'dxm=[midpoint sampling interval]:dxm' \
  'fzo=[first depth sample in output]:fzo' \
  'dzo=[depth interval in output]:dzo' \
  'nzo=[number of depth samples in output]:nzo' \
  'fxo=[first lateral sample in output]:fxo' \
  'dxo=[lateral interval in output]:dxo' \
  'nxo=[number of lateral samples in output]:nxo' \
  'off0=[first offset]:off0' \
  'doff=[offset interval]:doff' \
  'noff=[number of offsets]:noff' \
  'absoff=[1 to use absolute offset]:absoff:(0 1)' \
  'limoff=[1 to limit offset]:limoff:(0 1)' \
  'fmax=[maximum frequency]:fmax' \
  'offmax=[maximum offset]:offmax' \
  'aperx=[migration lateral aperture]:aperx' \
  'angmax=[maximum migration angle]:angmax' \
  'v0=[reference velocity at surface]:v0' \
  'dvz=[velocity vertical gradient]:dvz' \
  'ls=[1 for line source]:ls:(0 1)' \
  'jpfile=[job print file]:file:_files' \
  'mtr=[print verbose info every mtr traces]:mtr' \
  'ntr=[max number of input traces]:ntr' \
  'npv=[1 to output additional data]:npv:(0 1)' \
  'rscale=[scale for migrated output]:rscale' \
  'tvfile=[traveltime variation file]:file:_files' \
  'csfile=[cosine file]:file:_files' \
  'outfile1=[additional output file]:file:_files' \
  '*:file:_files' && ret=0

return ret
