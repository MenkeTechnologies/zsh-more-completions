#compdef SrumECmd
# Documentation: https://github.com/EricZimmerman/Srum
# SrumECmd - Windows SRUM database parser

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[SRUDB.dat file to parse]:file:_files' \
  '-r[SOFTWARE hive to process]:file:_files' \
  '-d[directory to recursively process]:directory:_directories' \
  '--csv=[directory to save CSV results to]:directory:_directories' \
  '--dt=[custom date/time format]:format' \
  '--debug[show debug information]' \
  '--trace[show trace information]' && ret=0

return ret
