#compdef playwright-cli2
# Documentation: https://playwright.dev/docs/test-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'codegen:open codegen'
  'install:install browsers'
  'install-deps:install OS dependencies'
  'open:open browser inspector'
  'screenshot:take screenshot'
  'pdf:save URL as PDF'
  'show-trace:open trace viewer'
  'merge-reports:merge sharded reports'
  'test:run tests'
  'list-files:list test files'
  'show-report:open last HTML report'
  'find-config:find config'
  'uninstall:uninstall browsers'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'playwright command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (test)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "playwright.config.*"' \
          '(--browser)--browser=[browser]:b:(chromium firefox webkit all)' \
          '(--bail)--bail[bail on first failure]' \
          '(-x)-x[bail]' \
          '(--debug)--debug[debug mode]' \
          '(--forbid-only)--forbid-only[no .only]' \
          '(--fully-parallel)--fully-parallel[fully parallel]' \
          '(--global-timeout)--global-timeout=[ms]:ms:' \
          '(--grep -g)'{-g+,--grep=}'[regex]:re:' \
          '(--grep-invert)--grep-invert=[regex invert]:re:' \
          '(--headed)--headed[headed mode]' \
          '(--ignore-snapshots)--ignore-snapshots[ignore snapshot mismatch]' \
          '(--last-failed)--last-failed[last failed only]' \
          '(--list)--list[list tests]' \
          '(--max-failures)--max-failures=[N]:n:' \
          '(--no-deps)--no-deps[no project deps]' \
          '(--output)--output=[output dir]:dir:_files -/' \
          '(--pass-with-no-tests)--pass-with-no-tests[pass with no tests]' \
          '(--project)*--project=[project]:p:' \
          '(--quiet -q)'{-q,--quiet}'[quiet]' \
          '(--repeat-each)--repeat-each=[N]:n:' \
          '(--reporter)--reporter=[reporter csv]:list:(list line dot html json junit blob github null)' \
          '(--retries)--retries=[N]:n:' \
          '(--shard)--shard=[N/M]:s:' \
          '(--timeout)--timeout=[ms]:ms:' \
          '(--trace)--trace=[trace mode]:m:(on off retain-on-failure on-first-retry)' \
          '(--ui)--ui[UI mode]' \
          '(--ui-host)--ui-host=[host]:h:_hosts' \
          '(--ui-port)--ui-port=[port]:p:' \
          '(--update-snapshots -u)'{-u,--update-snapshots}'[update snapshots]' \
          '(--workers -j)'{-j+,--workers=}'[workers]:n:' \
          '*: :_files' && ret=0 ;;
      (codegen)
        _arguments \
          '(-b --browser)'{-b+,--browser=}'[browser]:b:(chromium firefox webkit)' \
          '(--channel)--channel=[channel]:c:(chrome chrome-beta msedge msedge-beta)' \
          '(--color-scheme)--color-scheme=[scheme]:s:(light dark no-preference)' \
          '(--device)--device=[device]:d:' \
          '(--geolocation)--geolocation=[lat,long]:g:' \
          '(--ignore-https-errors)--ignore-https-errors[ignore HTTPS errors]' \
          '(--load-storage)--load-storage=[storage file]:file:_files' \
          '(--lang)--lang=[locale]:l:' \
          '(--proxy-server)--proxy-server=[proxy URL]:url:' \
          '(--proxy-bypass)--proxy-bypass=[bypass]:b:' \
          '(--save-storage)--save-storage=[storage file]:file:_files' \
          '(--save-har)--save-har=[har file]:file:_files' \
          '(--save-har-glob)--save-har-glob=[har glob]:p:' \
          '(--target)--target=[target lang]:l:(javascript java python python-async python-pytest csharp csharp-mstest csharp-nunit playwright-test)' \
          '(--test-id-attribute)--test-id-attribute=[attr]:a:' \
          '(--user-agent)--user-agent=[UA]:ua:' \
          '(--viewport-size)--viewport-size=[WxH]:s:' \
          '(--block-service-workers)--block-service-workers[block SW]' \
          '(--timezone)--timezone=[tz]:tz:' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '*:url:_urls' && ret=0 ;;
      (install)
        _arguments \
          '(--with-deps)--with-deps[install OS deps]' \
          '(--dry-run)--dry-run[dry run]' \
          '(--force)--force[force]' \
          '(--only-shell)--only-shell[chromium-headless-shell only]' \
          '(--no-shell)--no-shell[no shell]' \
          '*:browser:(chromium chromium-headless-shell firefox webkit msedge chrome ffmpeg)' && ret=0 ;;
      (install-deps)
        _arguments \
          '(--dry-run)--dry-run[dry run]' \
          '*:browser:(chromium firefox webkit chrome msedge)' && ret=0 ;;
      (uninstall)
        _arguments \
          '(--all)--all[all]' \
          '*:browser:(chromium firefox webkit chrome msedge)' && ret=0 ;;
      (show-trace|show-report|merge-reports)
        _arguments '*: :_files' && ret=0 ;;
      (screenshot|pdf)
        _arguments \
          '(-b --browser)'{-b+,--browser=}'[browser]:b:(chromium firefox webkit)' \
          '(--full-page)--full-page[full page]' \
          '(--viewport-size)--viewport-size=[WxH]:s:' \
          '(--device)--device=[device]:d:' \
          '(--wait-for-timeout)--wait-for-timeout=[ms]:ms:' \
          '(--wait-for-selector)--wait-for-selector=[sel]:s:' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
