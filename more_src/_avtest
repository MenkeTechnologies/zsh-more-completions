#compdef avtest
# Documentation: https://github.com/bluez/bluez/blob/master/tools/avtest.c
# Source: BlueZ tools/avtest.c — AVDTP/AVCTP A2DP/AVRCP test harness.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '--device=[HCI device]:hcidev:' \
    '--reject=[reject command]:command:' \
    '--reject-code=[reject code to use]:code:' \
    '--send=[send command]:command:' \
    '--preconf[configure stream before actual command]' \
    '--wait=[wait N seconds before exiting]:seconds:' \
    '--fragment[use minimum MTU and fragmented messages]' \
    '--invalid=[send invalid command]:command:' \
    '--aac[MPEG2,4 AAC LC codec]' \
    '--avctp[use AVCTP transport]' \
    && ret=0

return ret
