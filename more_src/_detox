#compdef detox

# Zsh completion for detox - clean up filenames

_arguments -s -S \
  '(-s --sequence)'{-s+,--sequence=}'[use specified sequence]:sequence name:' \
  '(-f --special)'{-f+,--special=}'[use specified config file]:config file:_files' \
  '(-n --dry-run)'{-n,--dry-run}'[do a dry run (no changes))]' \
  '(-r --recurse)'{-r,--recurse}'[recurse into subdirectories]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:files:_files'
