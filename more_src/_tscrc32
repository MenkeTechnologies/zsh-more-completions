#compdef tscrc32
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tscrc32.cpp
# tscrc32 - compute MPEG-style CRC32 values

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-a --accelerated)'{-a,--accelerated}'[check if CRC32 computation is accelerated]' \
  '(-d --data)'{-d,--data}'=[raw input data as hexadecimal digits]:hex:' \
  '*:input file:_files' && ret=0

return ret
