#compdef mace_create_lammps_model
# Documentation: https://mace-docs.readthedocs.io/en/latest/guide/lammps.html
# MACE: compile a trained model into a LAMMPS-deployable model

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--head=[model head to convert]:head' \
  '--dtype=[data type]:dtype:(float64 float32)' \
  '--format=[output format]:format:(libtorch mliap)' \
  '1:model_path:_files' \
  '*:arg:_files' && ret=0

return ret
