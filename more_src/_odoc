#compdef odoc
# Documentation: https://man.archlinux.org/search?q=odoc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'compile:produce a .odoc file from input'
  'compile-deps:print compile dependencies'
  'compile-asset:compile a binary asset file'
  'compile-impl:produce a .odoc-impl file'
  'compile-index:produce a sidx index'
  'compile-occur:occurrences index'
  'compile-source:compile source code reference'
  'count-occurrences:count occurrences'
  'errors:errors module'
  'extract-code:extract code from .mld'
  'html:legacy html generation'
  'html-deps:dependencies for html generation'
  'html-fragment:html fragment generation'
  'html-generate:generate html from odocl files'
  'html-generate-asset:generate html for assets'
  'html-generate-source:generate source html'
  'html-targets:print html targets'
  'html-url:print html url'
  'index:produce a .odoc-index file'
  'index-targets:print index targets'
  'latex:legacy latex generation'
  'latex-generate:generate latex'
  'latex-targets:print latex targets'
  'link:produce a .odocl file'
  'link-deps:print link dependencies'
  'links-up:link with extra search index'
  'man:legacy man generation'
  'man-generate:generate man pages'
  'man-targets:print man targets'
  'occurrences:occurrences module'
  'odoc-link:link a .odoc'
  'reference-resolution:print reference resolution'
  'sidebar-generate:generate sidebar JSON'
  'source-html:produce src.html files'
  'support-files:copy support files'
  'support-files-targets:print support files targets'
  'targets:print targets'
  'targets-source:print source targets'
  'classify:classify .ml/.mli files'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'odoc command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (compile)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output odoc file]:file:_files -g "*.odoc"' \
          '*-I+[search path for cmti files]:dir:_files -/' \
          '--parent=[parent identifier]:id:' \
          '--package=[package name]:name:' \
          '--source-name=[source name]:name:' \
          '--source-id=[source id]:id:' \
          '--source-parent-file=[source parent file]:file:_files' \
          '--child=[child child]:child:' \
          '--cmti=[input cmti]:file:_files -g "*.cmti"' \
          '--cmt=[input cmt]:file:_files -g "*.cmt"' \
          '--cmi=[input cmi]:file:_files -g "*.cmi"' \
          '--mld=[input mld]:file:_files -g "*.mld"' \
          '*: :_files -g "*.cmti *.cmt *.cmi *.mld *.ml *.mli"' && ret=0 ;;
      (html-generate|html|man-generate|latex-generate)
        _arguments \
          '(-o --output-dir)'{-o+,--output-dir=}'[output directory]:dir:_files -/' \
          '--theme-uri=[CSS/JS URI]:uri:' \
          '--support-uri=[support files URI]:uri:' \
          '--search-uri=[search uri]:uri:' \
          '--flat[flat output]' \
          '--indent[indent generated HTML]' \
          '--as-json[output as JSON]' \
          '--asset=[asset file]:file:_files' \
          '*: :_files -g "*.odocl *.odoc"' && ret=0 ;;
      (link)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output odocl]:file:_files -g "*.odocl"' \
          '*-I+[search path]:dir:_files -/' \
          '--current-package=[package]:pkg:' \
          '--open=[open module]:mod:' \
          '*: :_files -g "*.odoc"' && ret=0 ;;
      (support-files)
        _arguments \
          '(-o --output-dir)'{-o+,--output-dir=}'[output directory]:dir:_files -/' \
          '--without-theme[do not copy theme]' && ret=0 ;;
    esac ;;
esac

return ret
