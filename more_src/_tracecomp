#compdef tracecomp
# Documentation: https://github.com/bayesiancook/pbmpi/blob/master/sources/TraceComp.cpp
# PhyloBayes tracecomp: compares trace-file summary statistics across chains. Flags mirror TraceComp.cpp.

local ret=1

_arguments -s -S \
  '-x[burn-in (number of points to discard)]:burnin:' \
  '-o[output base name]:output:' \
  '*:chain name:' && ret=0

return ret
