#compdef hgLoadMaf
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: load a MAF multiple alignment into the database

local ret=1

_arguments -s -S \
  '-warn[warn instead of error upon empty/incomplete alignments]' \
  '-WARN[warn instead of error, with detail]' \
  '-test=[use infile as input and suppress loading]:file:_files' \
  '-pathPrefix=[load files from specified directory]:dir:_files -/' \
  '-tmpDir=[directory for temporary .tab file]:dir:_files -/' \
  '-loadFile=[use file as input]:file:_files' \
  '-maxNameLen=[max chromosome name length to avoid chromInfo lookup]:n' \
  '-defPos=[file to put default position in]:file:_files' \
  '-custom[loading a custom track, do not use history or extFile tables]' \
  '1:database:' \
  '2:table:' && ret=0

return ret
