#compdef langflow
# Documentation: https://man.archlinux.org/search?q=langflow
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:start the Langflow server'
  'api-key:create a Langflow API key'
  'copy-db:copy database files from the cache directory'
  'migration:manage database schema migrations'
  'superuser:create a superuser account'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--install-completion[install shell completion]' \
  '--show-completion[show completion config location]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'langflow command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--host=[server host address]:host:_hosts' \
          '--port=[server port (default 7860)]:port:' \
          '--workers=[worker process count]:n:' \
          '--worker-timeout=[worker timeout in seconds]:n:' \
          '--log-level=[logging level]:level:(debug info warning error critical)' \
          '--log-file=[log file path]:file:_files' \
          '--log-rotation=[log rotation]:rotation:' \
          '--cache=[cache storage type]:type:(async redis memory disk)' \
          '--auto-saving[enable flow auto-saving]' \
          '--no-auto-saving[disable flow auto-saving]' \
          '--auto-saving-interval=[auto-save interval (ms)]:n:' \
          '--backend-only[run backend without UI]' \
          '--dev[development mode]' \
          '--env-file=[.env file path]:file:_files' \
          '--components-path=[custom components directory]:dir:_files -/' \
          '--frontend-path=[frontend build directory]:dir:_files -/' \
          '--health-check-max-retries=[health check retries]:n:' \
          '--max-file-size-upload=[max upload size in MB]:n:' \
          '--open-browser[open browser on startup]' \
          '--remove-api-keys[remove API keys from saved flows]' \
          '--ssl-cert-file-path=[SSL certificate file]:file:_files' \
          '--ssl-key-file-path=[SSL key file]:file:_files' && ret=0 ;;
      (superuser)
        _arguments \
          '--username=[username]:username:' \
          '--password=[password]:password:' \
          '--log-level=[log level]:level:(debug info warning error critical)' && ret=0 ;;
      (api-key)
        _arguments \
          '--log-level=[log level]:level:(debug info warning error critical)' && ret=0 ;;
      (migration)
        _arguments \
          '--fix[apply migrations (write changes)]' \
          '--test[run in test mode]' \
          '--log-level=[log level]:level:(debug info warning error critical)' && ret=0 ;;
      (copy-db)
        _arguments \
          '--log-level=[log level]:level:(debug info warning error critical)' && ret=0 ;;
    esac ;;
esac

return ret
