#compdef kubectl-fuzzy
# Documentation: https://man.archlinux.org/search?q=kubectl-fuzzy
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '*:kubectl subcommand and arguments:_default'
