#compdef kubectl-fuzzy
# Documentation: https://github.com/d-kuro/kubectl-fuzzy
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:' \
  '(-P --preview)'{-P,--preview}'[display YAML/JSON of objects in the selector]' \
  '--preview-format=[preview display format]:format:(yaml json)' \
  '--raw-preview[show unsimplified objects (preserve metadata and status)]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'create:create a resource'
      'delete:select and delete an object'
      'describe:select and show resource details'
      'exec:select a Pod and execute a command'
      'logs:select a Pod and view logs'
      'version:display version information'
    )
    _describe -t commands 'kubectl-fuzzy command' commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
