#compdef smbspool
# Documentation: https://www.samba.org/samba/docs/current/man-html/smbspool.8.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# smbspool: CUPS backend that sends print jobs to SMB printers.
# Positional args: job user title copies options [filename]
# No command-line flags are documented; printer is selected via DEVICE_URI
# environment variable or smb:// URI argument.

local curcontext="$curcontext" ret=1

_arguments -C \
  '1:job id:' \
  '2:user:_users' \
  '3:title:' \
  '4:copies:' \
  '5:options:' \
  '6:filename:_files' && ret=0

return ret
