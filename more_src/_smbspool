#compdef smbspool
# Documentation: https://man.archlinux.org/search?q=smbspool
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '1:job_id:' \
  '2:user:_users' \
  '3:title:' \
  '4:copies:' \
  '5:options:' \
  '6:filename:_files' && ret=0

return ret
