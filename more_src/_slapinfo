#compdef slapinfo
# _slapinfo — OpenLDAP slapinfo (read-only inspector that prints backend metadata for each database in slapd.conf or the cn=config tree; -F config dir, -f slapd.conf, -b suffix, -n database number, -d debug, -v verbose, -V version; useful to confirm which backend (mdb, hdb, bdb, sql) is configured for which suffix)
# upstream: https://git.openldap.org/openldap/openldap (servers/slapd/slapinfo)
# Flags from OpenLDAP servers/slapd/slapcommon.c on tip.

_slapinfo() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-F+[config dir]:dir:_files -/' \
        '-f+[slapd.conf]:file:_files' \
        '-b+[suffix]:dn:' \
        '-n+[database number]:n:' \
        '-d+[debug level]:level:' \
        '-v[verbose]'
}

_slapinfo "$@"
