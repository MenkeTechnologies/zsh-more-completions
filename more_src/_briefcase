#compdef briefcase

# Zsh completion for briefcase - BeeWare app packaging tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new:create a new application'
  'dev:run the application in dev mode'
  'create:create application scaffold'
  'build:build the application'
  'update:update an existing application'
  'run:run a packaged application'
  'package:package the application for distribution'
  'publish:publish a packaged application'
  'upgrade:upgrade tools managed by briefcase'
  'convert:convert an existing project to use briefcase'
)

local -a global_opts=(
  '(-v --verbosity)'{-v,--verbosity}'[set verbosity level]:level:(1 2)'
  '--log[save a detailed log to file]'
  '--no-input[do not prompt for user input]'
  '(-h --help)'{-h,--help}'[show help message and exit]'
  '--version[show version and exit]'
)

_arguments -s -S \
  "${global_opts[@]}" \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'briefcase command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      dev)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--no-run[do not run the application, just install dependencies]' \
          '(-r --update-requirements)'{-r,--update-requirements}'[update requirements in the dev environment]' \
          '(-d --update-resources)'{-d,--update-resources}'[update application resources]' \
          '--no-update[do not update the dev environment]' \
          '--test[run in test mode]' \
          '(-a --app-name)'{-a,--app-name}'[application name]:app name:' && ret=0
        ;;
      create)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--no-docker[do not use Docker for build]' \
          '(-a --app-name)'{-a,--app-name}'[application name]:app name:' && ret=0
        ;;
      build)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--no-docker[do not use Docker for build]' \
          '(-u --update)'{-u,--update}'[update the application before building]' \
          '(-r --update-requirements)'{-r,--update-requirements}'[update requirements before building]' \
          '(-d --update-resources)'{-d,--update-resources}'[update application resources before building]' \
          '--no-update[do not update before building]' \
          '--test[build in test mode]' \
          '(-a --app-name)'{-a,--app-name}'[application name]:app name:' && ret=0
        ;;
      run)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--no-docker[do not use Docker]' \
          '(-u --update)'{-u,--update}'[update the application before running]' \
          '(-r --update-requirements)'{-r,--update-requirements}'[update requirements before running]' \
          '(-d --update-resources)'{-d,--update-resources}'[update application resources before running]' \
          '--no-update[do not update before running]' \
          '--test[run in test mode]' \
          '(-a --app-name)'{-a,--app-name}'[application name]:app name:' && ret=0
        ;;
      package)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--no-docker[do not use Docker for packaging]' \
          '(-u --update)'{-u,--update}'[update the application before packaging]' \
          '(-r --update-requirements)'{-r,--update-requirements}'[update requirements before packaging]' \
          '(-d --update-resources)'{-d,--update-resources}'[update application resources before packaging]' \
          '--no-update[do not update before packaging]' \
          '--adhoc-sign[use ad-hoc code signing]' \
          '--identity[signing identity to use]:identity:' \
          '(-a --app-name)'{-a,--app-name}'[application name]:app name:' && ret=0
        ;;
      update)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--no-docker[do not use Docker]' \
          '(-r --update-requirements)'{-r,--update-requirements}'[update requirements]' \
          '(-d --update-resources)'{-d,--update-resources}'[update application resources]' \
          '(-a --app-name)'{-a,--app-name}'[application name]:app name:' && ret=0
        ;;
      new|publish|upgrade|convert)
        _arguments -s -S \
          "${global_opts[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
