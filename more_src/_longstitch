#compdef longstitch
# Documentation: https://github.com/bcgsc/LongStitch
# LongStitch: correct and scaffold genome assembly drafts using long reads

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'longstitch command' \
      'run[default pipeline: Tigmint then ntLink]' \
      'tigmint-ntLink[same as run: Tigmint then ntLink]' \
      'tigmint-ntLink-arks[full pipeline with ARCS scaffolding]' \
      'ntLink-arks[ntLink followed by ARCS]' && ret=0
    ;;
esac

return ret
