#compdef keepalived

# Zsh completion for keepalived (Linux HA / VRRP daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --use-file)'{-f,--use-file}'=[Use the specified configuration file]:config file:_files' \
  '(-P --vrrp)'{-P,--vrrp}'[Only run the VRRP subsystem]' \
  '(-C --check)'{-C,--check}'[Only run the healthchecker subsystem]' \
  '(-B --bfd)'{-B,--bfd}'[Only run the BFD subsystem]' \
  '--all[Force all child processes to run]' \
  '(-l --log-console)'{-l,--log-console}'[Log to console]' \
  '(-D --log-detail)'{-D,--log-detail}'[Detailed log messages]' \
  '(-S --log-facility)'{-S,--log-facility}'=[Set syslog facility]:facility:(0 1 2 3 4 5 6 7)' \
  '(-G --no-syslog)'{-G,--no-syslog}'[Do not log to syslog]' \
  '(-g --log-file)'{-g,--log-file}'=[Log to specified file]:log file:_files' \
  '--flush-log-file[Flush log file on write]' \
  '(-d --dump-conf)'{-d,--dump-conf}'[Dump the configuration data]' \
  '(-R --dont-release-vrrp)'{-R,--dont-release-vrrp}'[Do not release VRRP VIPs and VROUTEs on daemon stop]' \
  '(-I --dont-release-ipvs)'{-I,--dont-release-ipvs}'[Do not remove IPVS topology on daemon stop]' \
  '--dont-fork[Do not fork the daemon process]' \
  '(-r --release-vips)'{-r,--release-vips}'[Release any VIPs before terminating]' \
  '(-n --dont-respawn)'{-n,--dont-respawn}'[Do not respawn child processes]' \
  '-x+[Override namespace with specified name]:namespace' \
  '(-p --pid)'{-p,--pid}'=[Use specified pidfile for parent]:pidfile:_files' \
  '(-c --checkers-pid)'{-c,--checkers-pid}'=[Use specified pidfile for checkers]:pidfile:_files' \
  '--vrrp-pid=[Use specified pidfile for VRRP child]:pidfile:_files' \
  '--bfd-pid=[Use specified pidfile for BFD child]:pidfile:_files' \
  '(-t --config-test)'{-t,--config-test}'[Check the configuration and exit]' \
  '(-s --namespace)'{-s,--namespace}'=[Run in a network namespace]:namespace' \
  '(-i --config-id)'{-i,--config-id}'=[Use specified config-id]:config id' \
  '(-v --version)'{-v,--version}'[Display version]' \
  '(-h --help)'{-h,--help}'[Display help]' && ret=0

return ret
