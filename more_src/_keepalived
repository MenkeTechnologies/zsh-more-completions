#compdef keepalived
# Documentation: https://www.mankier.com/8/keepalived
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# keepalived: Linux HA / VRRP daemon. Corrected from prior file: -B is
# --no_bfd (don't run BFD, not "only run BFD"); -n is --dont-fork; -R
# is --dont-respawn; -V is --dont-release-vrrp; -X is --release-vips;
# -r/-c/-b are vrrp/checkers/bfd pidfiles; long opts use underscores;
# added -T -a -e -x -A -u -m -M --signum --perf --debug --no-mem-check;
# removed invented --dont-fork-long and -x-namespace mapping.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-f --use-file)'{-f,--use-file}'=[use the specified configuration file]:config file:_files' \
  '(-P --vrrp)'{-P,--vrrp}'[only run the VRRP subsystem]' \
  '(-C --check)'{-C,--check}'[only run the healthcheck subsystem]' \
  '(-B --no_bfd)'{-B,--no_bfd}'[do not run the BFD subsystem]' \
  '--all[run all subsystems even if they have no configuration]' \
  '(-n --dont-fork)'{-n,--dont-fork}'[do not fork the daemon process]' \
  '(-d --dump-conf)'{-d,--dump-conf}'[dump the configuration data]' \
  '(-R --dont-respawn)'{-R,--dont-respawn}'[do not respawn child processes]' \
  '(-l --log-console)'{-l,--log-console}'[log messages to the local console]' \
  '(-D --log-detail)'{-D,--log-detail}'[detailed log messages]' \
  '(-S --log-facility)'{-S,--log-facility}'=[set syslog facility]:facility:(0 1 2 3 4 5 6 7 local0 local1 local2 local3 local4 local5 local6 local7 user daemon)' \
  '(-g --log-file)'{-g,--log-file}'=[write log entries to specified file]:log file:_files' \
  '--flush-log-file[flush log file stream after each write]' \
  '(-G --no-syslog)'{-G,--no-syslog}'[do not write log entries to syslog]' \
  '(-X --release-vips)'{-X,--release-vips}'[drop VIP on transition from signal]' \
  '(-V --dont-release-vrrp)'{-V,--dont-release-vrrp}'[do not remove VRRP VIPs and VROUTEs on daemon stop]' \
  '(-I --dont-release-ipvs)'{-I,--dont-release-ipvs}'[do not remove IPVS topology on daemon stop]' \
  '(-p --pid)'{-p,--pid}'=[use specified pidfile for parent process]:pidfile:_files' \
  '(-r --vrrp_pid)'{-r,--vrrp_pid}'=[use specified pidfile for VRRP child process]:pidfile:_files' \
  '(-c --checkers_pid)'{-c,--checkers_pid}'=[use specified pidfile for checkers child process]:pidfile:_files' \
  '(-b --bfd_pid)'{-b,--bfd_pid}'=[use specified pidfile for BFD child process]:pidfile:_files' \
  '(-T --genhash)'{-T,--genhash}'[enter genhash utility mode]' \
  '(-a --address-monitoring)'{-a,--address-monitoring}'[log all address additions/deletions reported by netlink]' \
  '(-s --namespace)'{-s,--namespace}'=[run keepalived in a network namespace]:namespace:' \
  '(-e --all-config)'{-e,--all-config}'[do not load if any configuration file is missing]' \
  '(-i --config-id)'{-i,--config-id}'=[use configuration id for conditional configuration]:config id:' \
  '(-x --snmp)'{-x,--snmp}'[enable the SNMP subsystem]' \
  '(-A --snmp-agent-socket)'{-A,--snmp-agent-socket}'=[socket for SNMP master agent connection]:socket:_files' \
  '(-u --umask)'{-u,--umask}'=[set umask in numeric way]:umask:' \
  '(-m --core-dump)'{-m,--core-dump}'[enable core dumps on segfault or failure]' \
  '(-M --core-dump-pattern)'{-M,--core-dump-pattern}'=-[enable core dumps and update core_pattern]:pattern:' \
  '--signum=[return signal number for the specified function]:sigfunc:' \
  '(-t --config-test)'{-t,--config-test}'=-[check configuration file and exit]:config file:_files' \
  '--perf=-[record perf data for vrrp process]:when:(all run end)' \
  '--debug=-[enable compiled debug options]:debug-options:' \
  '--no-mem-check[disable malloc() memory checks]' \
  '(-v --version)'{-v,--version}'[display the version and exit]' \
  '(-h --help)'{-h,--help}'[display help message and exit]' && ret=0

return ret
