#compdef @SUMA_Make_Spec_FS
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@SUMA_Make_Spec_FS.html
# Build a SUMA spec file from FreeSurfer surface output

local ret=1

_arguments -s \
  '-sid[subject ID for file naming]:id' \
  '-fspath[path to surface and orig directories]:dir:_files -/' \
  '-fs_setup[source FreeSurfer setup script]' \
  '-debug[debug level 0-2]:level' \
  '-extra_annot_labels[convert extra annotation files]:labels' \
  '-extra_fs_dsets[include extra FreeSurfer datasets]:datasets' \
  '-make_rank_dsets[create rank datasets]' \
  '-use_mgz[use MGZ volumes]' \
  '-neuro[use neurological orientation]' \
  '-NIFTI[produce NIFTI volumes and GIFTI surfaces]' \
  '-GNIFTI[equivalent to -NIFTI]' \
  '-GIFTI[equivalent to -NIFTI]' \
  '-IFTI[equivalent to -NIFTI]' \
  '-inflate[create inflated surfaces]:iterations' \
  '-set_space[set volume space]:space:(orig MNI TLRC MNIa)' \
  '-ld[standard mesh linear depth]:depth' \
  '-ldpref[prefix for MapIcosahedron output]:prefix' \
  '-no_ld[skip MapIcosahedron]' \
  '-help[display help]' && ret=0

return ret
