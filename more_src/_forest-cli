#compdef forest-cli
# Documentation: https://man.archlinux.org/search?q=forest-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '(-t --token)'{-t,--token}'=[JSON-RPC JWT bearer token]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'chain:Interact with the Filecoin chain'
      'auth:Manage RPC JWT permissions'
      'net:Inspect or change libp2p networking'
      'sync:Chain synchronizer commands'
      'mpool:Message pool commands'
      'state:Inspect or query chain state'
      'config:Read or write node configuration'
      'snapshot:Import, export, or verify chain snapshots'
      'info:Print node version and runtime info'
      'shutdown:Shut down the Forest node'
      'healthcheck:Print health probe information'
      'f3:Fast finality (F3) tooling'
      'wait-api:Block until the JSON-RPC API is reachable'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
