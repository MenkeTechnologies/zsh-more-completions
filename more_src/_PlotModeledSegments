#compdef PlotModeledSegments
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/plotting/PlotModeledSegments.java
# Creates plots of denoised and segmented copy-ratio and minor-allele-fraction estimates

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--denoised-copy-ratios=[Input file containing denoised copy ratios (output of DenoiseReadCounts).]:value:_files' \
  '--allelic-counts=[Input file containing allelic counts at heterozygous sites (.hets.tsv output of ModelSe...]:value:_files' \
  '--segments=[Input file containing modeled segments (output of ModelSegments).]:value:_files' \
  '--sequence-dictionary=[sequence-dictionary]:value:_files' \
  '--output-prefix=[Prefix for output filenames.]:value:_files' \
  '(--output -O)'{--output,-O}'[Output directory. This will be created if it does not exist.]:value:_files' \
  '*:argument:_files' && ret=0

return ret
