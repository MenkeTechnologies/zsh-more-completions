#compdef pass-audit
# Documentation: https://man.archlinux.org/search?q=pass-audit
# Reference accessed: 2026-05-16

# Zsh completion for pass-audit - audit passwords in pass

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '*:path in password store:_files -W "${PASSWORD_STORE_DIR:-$HOME/.password-store}" -g "*.gpg(.:r)"'
