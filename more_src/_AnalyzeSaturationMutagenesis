#compdef AnalyzeSaturationMutagenesis
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/AnalyzeSaturationMutagenesis.java
# (EXPERIMENTAL) Processes reads from a MITESeq or other saturation mutagenesis experiment

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output-file-prefix -O)'{--output-file-prefix,-O}'=[prefix for output files]:value:_files' \
  '--orf=[open reading frame description]:value:' \
  '--min-q=[minimum base quality]:value:' \
  '--min-length=[minimum read length]:value:' \
  '--min-flanking-length=[minimum flanking length]:value:' \
  '--min-mapq=[minimum mapping quality]:value:' \
  '--min-variant-obs=[minimum variant observations]:value:' \
  '--min-alt-length=[minimum alt allele length]:value:' \
  '--find-large-deletions=[search for large deletions]:value:(true false)' \
  '--codon-translation=[codon translation scheme]:value:' \
  '--paired-mode=[treat reads as paired]:value:(true false)' \
  '--dont-ignore-disjoint-pairs=[do not ignore disjoint read pairs]:value:(true false)' \
  '--write-rejected-reads=[write rejected reads to output]:value:(true false)' \
  '*:argument:_files' && ret=0

return ret
