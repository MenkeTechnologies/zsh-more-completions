#compdef cargo-deadlinks
# check cargo doc output for broken links

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--dir[directory to check]:directory:_files -/' \
  '--cargo-dir[directory to look in for the Cargo manifest]:directory:_files -/' \
  '--check-http[check http and https scheme links]' \
  '--forbid-http[error if HTTP links are found]' \
  '--check-intra-doc-links[check for broken intra-doc links]' \
  '--ignore-fragments[do not check URL fragments]' \
  '--no-build[do not call cargo doc before checking]' \
  '--debug[use debug output (deprecated)]' \
  '(-v --verbose)'{-v,--verbose}'[use verbose output (deprecated)]' \
  '(-V --version)'{-V,--version}'[print version info and exit]' \
  '*::cargo args:_default' && ret=0

return ret
