#compdef hb-vector
# Documentation: https://man.archlinux.org/search?q=hb-vector
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-face[show face options]' \
  '(- *)--help-font[show font options]' \
  '*:font file:_files -g "*.(otf|ttf|ttc|woff|woff2)"' && ret=0

return ret
