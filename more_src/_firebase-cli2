#compdef firebase-cli2
# _firebase-cli2 — Google Firebase firebase-cli2 CLI command-line frontend wrapping the Firebase CLI command-line tools for managing your Firebase projects open-source written in TypeScript Node deploy and host serve deploy functions hosting firestore realtime-database remoteconfig auth use logout login projects apps init experimental open dataconnect appdistribution remoteconfig extensions emulators start hosting:channel hosting:disable hosting:sites hosting:clone target:apply target:remove target:clear functions:secrets database:get database:set database:push database:remove database:update database:profile auth:export auth:import auth:disable functions:list functions:delete functions:shell functions:config:get firestore:delete firestore:indexes (Google Firebase team, TypeScript); commander
# upstream: https://firebase.google.com/

_firebase-cli2() {
    local -a sub=(
        'apphosting:Firebase App Hosting'
        'appdistribution:App Distribution operations'
        'apps:app operations'
        'auth:auth user operations'
        'completion:generate shell completion'
        'crashlytics:Crashlytics operations'
        'database:Realtime Database operations'
        'dataconnect:Data Connect operations'
        'deploy:deploy to Firebase'
        'emulators:emulator operations'
        'experimental:experimental ops'
        'experiments:experiment operations'
        'extensions:extension operations'
        'firestore:Firestore operations'
        'frameworks:framework operations'
        'functions:Cloud Functions ops'
        'help:show help'
        'hosting:Hosting operations'
        'init:initialize Firebase project'
        'list:list projects'
        'login:authenticate'
        'logout:revoke session'
        'open:open Firebase Console'
        'projects:project operations'
        'remoteconfig:Remote Config ops'
        'serve:serve project locally'
        'setup:setup project'
        'target:deploy target operations'
        'use:use a project alias'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-c+[config]:file:_files -g "firebase.json *.json"' \
        '--config=+[file]:file:_files -g "firebase.json *.json"' \
        '-P+[project]:str:' \
        '--project=+[id]:str:' \
        '-a+[account]:str:' \
        '--account=+[email]:str:' \
        '--token=+[token]:str:' \
        '--non-interactive[non interactive]' \
        '--interactive[interactive]' \
        '--json[JSON output]' \
        '--no-color[no color]' \
        '-f[force]' \
        '--force[force]' \
        '--only=+[targets]:str:' \
        '--except=+[targets]:str:' \
        '--public=+[dir]:dir:_files -/' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '--host=+[host]:_hosts' \
        '--ui[start emulator UI]' \
        '--import=+[dir]:dir:_files -/' \
        '--export-on-exit=+[dir]:dir:_files -/' \
        '--inspect-functions=+[port]:n:' \
        '--export[export]' \
        '-m+[message]:str:' \
        '--message=+[text]:str:' \
        '--alias=+[name]:str:' \
        '--add[add project alias]' \
        '--remove[remove alias]' \
        '--unalias=+[name]:str:' \
        '--clear[clear alias]' \
        '--site=+[name]:str:' \
        '--channel=+[name]:str:' \
        '--ttl=+[d]:str:' \
        '--versions=+[N]:n:' \
        '--no-localhost[no localhost]' \
        '--reauth[force reauth]' \
        '--gcp-token=+[token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'firebase subcommand' sub ;;
        args)
            case $words[1] in
                deploy|serve) _arguments '*:arg:' ;;
                hosting|firestore|functions|database|auth|remoteconfig|appdistribution|extensions|frameworks|dataconnect|apps|projects|crashlytics) _arguments '1:op:(channel:deploy disable list sites clone secret config:get config:set delete get set push remove update profile export import shell list-runtimes deploy use)' '*:arg:' ;;
                target) _arguments '1:op:(apply remove clear)' '*:arg:' ;;
                emulators) _arguments '1:op:(start exec)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_firebase-cli2 "$@"
