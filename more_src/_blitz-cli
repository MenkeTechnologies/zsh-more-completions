#compdef blitz-cli
# _blitz-cli — Blitz.js fullstack Next.js toolkit CLI alias (Blitz.js, TypeScript); yargs
# upstream: https://github.com/blitz-js/blitz

_blitz-cli() {
    local -a sub=(
        'new:scaffold project'
        'dev:start dev server'
        'start:start production server'
        'build:build for production'
        'export:export static site'
        'lint:lint code'
        'test:run tests'
        'codegen:run generator'
        'generate:generate code'
        'g:generate code (alias)'
        'console:start REPL'
        'c:start REPL (alias)'
        'install:install recipe'
        'prisma:run prisma'
        'db:db helpers'
        'manifest:print manifest'
        'routes:print routes'
        'autocomplete:setup autocompletion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'blitz subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:name:' \
                    '--template=+[template]:t:(full minimal)' \
                    '--language=+[language]:lang:(typescript javascript)' \
                    '--form=+[form library]:f:(react-final-form react-hook-form formik)' \
                    '--package-manager=+[package manager]:pm:(npm pnpm yarn bun)' \
                    '--skip-git[skip git init]' \
                    '--no-git[no git init]' \
                    '--skip-install[skip install]' \
                    '--no-install[no install]' \
                    '--dry-run[dry run]' ;;
                generate|g) _arguments \
                    '1:thing:(all resource model crud query queries mutation mutations form page pages component)' \
                    '*:name:' ;;
                dev|start) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--hostname=+[hostname]:host:_hosts' \
                    '-H+[hostname]:host:_hosts' \
                    '--inspect[node inspector]' \
                    '--no-incremental-build[no incremental build]' ;;
                build) _arguments \
                    '--no-incremental-build[no incremental build]' ;;
                prisma|db) _arguments \
                    '*:arg:' ;;
                install) _arguments \
                    '1:recipe:' \
                    '*:arg:' ;;
                routes) _arguments '*:arg:' ;;
                console|c) _arguments '*:arg:' ;;
                autocomplete) _arguments \
                    '1:shell:(bash zsh fish)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_blitz-cli "$@"
