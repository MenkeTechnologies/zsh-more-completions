#compdef mkinstmap
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/mkinstmap.html
# Generate a Chandra instrument map (effective area vs. detector position)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'outfile=[the name of the output instrument map file]:file:_files' \
  'spectrumfile=[input spectral weights file]:file:_files' \
  'monoenergy=[energy in keV for which the map will be computed]:monoenergy:' \
  'pixelgrid=[detector region and resolution of output map]:pixelgrid:' \
  'obsfile=[FITS file with mission, detector, observation date keywords]:file:_files' \
  'detsubsys=[detector subsystem for which to compute the map]:detsubsys:' \
  'grating=[zeroth order instrument map computation]:grating:(NONE HETG LETG)' \
  'maskfile=[mask file (msk1.fits) for the observation]:file:_files' \
  'pbkfile=[deprecated parameter]:file:_files' \
  'mirror=[mirror specification for Chandra]:mirror:' \
  'dafile=[ACIS dead area coefficients file]:dafile:' \
  'ardlibparfile=[parameter file for ARDLIB calibration]:file:_files' \
  'geompar=[Pixlib Geometry parameter file]:file:_files' \
  'verbose=[verbosity level for messages]:verbose:(0 1 2 3 4 5)' \
  'clobber=[overwrite existing output files]:clobber:(yes no)' && ret=0

return ret
