#compdef tcc tinycc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-vv[show included files]' \
  '-vvv[show more information]' \
  '-c[compile only, do not link]' \
  '-o+[set output file]:output file:_files' \
  '-E[preprocess only]' \
  '-S[output assembly]' \
  '-run[run compiled source immediately]' \
  '-I+[add include directory]:directory:_directories' \
  '-L+[add library search directory]:directory:_directories' \
  '-l+[link with library]:library name' \
  '-D+[define preprocessor symbol]:name[=value]' \
  '-U+[undefine preprocessor symbol]:name' \
  '-W+[enable warnings]:warning:(all error unsupported implicit-function-declaration write-strings)' \
  '-w[suppress all warnings]' \
  '-g[generate debug information]' \
  '-O+[optimization level]:level:(0 1 2 3 s)' \
  '-m32[generate 32-bit code]' \
  '-m64[generate 64-bit code]' \
  '-shared[generate a shared library]' \
  '-soname=[set shared library name]:name' \
  '-rdynamic[export all global symbols to dynamic linker]' \
  '-r[generate relocatable output]' \
  '-static[link statically]' \
  '-nostdinc[do not search standard include directories]' \
  '-nostdlib[do not search standard library directories]' \
  '-Wl,[pass option to linker]:linker option' \
  '-Wp,[pass option to preprocessor]:preprocessor option' \
  '-std=[C standard]:standard:(c89 c99 c11 gnu89 gnu99 gnu11)' \
  '-b[generate additional support code for tcc -g]' \
  '-bt=[set number of callers in bt]:count' \
  '-bench[output compilation statistics]' \
  '-B+[set tcc internal library path]:directory:_directories' \
  '-MD[generate dependency file]' \
  '-MF+[set dependency output file]:file:_files' \
  '-dumpversion[display version and exit]' \
  '-print-search-dirs[print search directories]' \
  '-dt[display type when --help argument is provided]' \
  '-pthread[use pthread library]' \
  '-f+[set option]:option:(PIC pic unsigned-char signed-char leading-underscore ms-extensions)' \
  '*:source file:_files -g "*.(c|h|i|s|S|o|a|so)"' && ret=0

return ret
