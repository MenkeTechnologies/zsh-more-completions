#compdef goldrush
# Documentation: https://github.com/bcgsc/goldrush
# GoldRush: linear-time de novo long read genome assembler

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'goldrush command' \
      'run[default pipeline execution]' \
      'goldrush-path[path selection only]' \
      'path-polish[path plus polishing]' \
      'path-tigmint[path, polish, and correction]' \
      'path-tigmint-ntLink[full pipeline with scaffolding]' && ret=0
    ;;
esac

return ret
