#compdef wcsremove
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss208.html
# KAPPA: remove coordinate Frames from the WCS component of an NDF

local ret=1

_arguments -s \
  'NDF=[NDF whose WCS is to be modified]:NDF:_files' \
  'FRAMES=[coordinate Frames to remove]:frames' \
  '*:NDF:_files' && ret=0

return ret
