#compdef dh-make-perl
# _dh-make-perl — convert CPAN module to Debian source package (Debian)
# upstream: https://salsa.debian.org/perl-team/modules/packages/dh-make-perl
# Flags from dh-make-perl(1p) man page.

_dh-make-perl() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-verbose[non-verbose]' \
        '--arch=[arch type]:type:(any all)' \
        '(--backups --no-backups)--backups[create debian/copyright + rules backups]' \
        '(--backups --no-backups)--no-backups[skip backups]' \
        '--basepkgs=[comma-separated base packages]:list:' \
        '--bdepends=[build-depends string]:str:' \
        '--bdependsi=[arch-indep build-depends string]:str:' \
        '--build[build binary package after setup]' \
        '--build-script=[script for building binary package]:path:_files' \
        '--build-source[build source package after setup]' \
        '--closes=[ITP bug number this package closes]:bug:' \
        '--core-ok[allow building core Perl modules]' \
        '--cpan=[CPAN module / dist name]:module:' \
        '--cpan-mirror=[CPAN mirror URL]:url:' \
        '--cache-dir=[cache directory]:dir:_files -/' \
        '--config-dir=[config directory]:dir:_files -/' \
        '--data-dir=[data directory]:dir:_files -/' \
        '--home-dir=[home directory]:dir:_files -/' \
        '--depends=[runtime depends string]:str:' \
        '--desc=[short description]:desc:' \
        '--dh=[debhelper compat level]:level:' \
        '--dist=[distribution]:dist:(unstable testing experimental)' \
        '--email=[maintainer email]:email:' \
        '*--exclude=[exclude file pattern]:pattern:' \
        '--force-depends=[force a specific runtime dependency]:dep:' \
        '(--guess-nocheck --no-guess-nocheck)--guess-nocheck[skip tests on autopkgtest fail]' \
        '(--guess-nocheck --no-guess-nocheck)--no-guess-nocheck[always include tests]' \
        '--install[install built package]' \
        '--install-build-deps[install build dependencies]' \
        '--install-deps[install runtime dependencies]' \
        '--install-with=[install with apt-get/aptitude]:tool:(apt apt-get aptitude)' \
        '--intrusive[allow building broken module]' \
        '--network[allow network access]' \
        '--notest[skip running tests during build]' \
        '--only=[only do this action]:action:(make refresh refresh-cache dump-config)' \
        '--packagename=[Debian source package name]:name:' \
        '--pkg-perl[use pkg-perl distribution defaults]' \
        '--recursive[also process recursively-found modules]' \
        '--requiredeps[fail if dependencies unresolved]' \
        '--revision=[Debian package revision]:rev:' \
        '--source-format=[source package format]:fmt:(1.0 3.0\ (quilt) 3.0\ (native))' \
        '--vcs=[VCS to use]:vcs:(git svn)' \
        '-i[install built package]' \
        '--dump-config[print effective config and exit]' \
        '1: :->cmd' \
        '*:: :->args'

    if [[ $state == cmd ]]; then
        _values 'command' \
            'make[create a new Debian package source dir]' \
            'refresh[refresh existing Debian package]' \
            'refresh-cache[refresh APT contents cache]' \
            'locate[locate which Debian package ships a Perl module]' \
            'install[install the built package]'
    fi
}

_dh-make-perl "$@"
