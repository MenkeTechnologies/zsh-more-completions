#compdef carbondata
# _carbondata — Apache CarbonData columnar file format CLI (Apache Software Foundation, Java/Scala); custom argparse
# upstream: https://github.com/apache/carbondata

_carbondata() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-cmd+[command]:cmd:(summary benchmark)' \
        '-p+[table path]:path:_files -/' \
        '-t+[table name]:str:' \
        '-d+[database]:str:' \
        '-a+[all]' \
        '-c+[column]:str:' \
        '-s+[show segment]' \
        '-m+[show meta]' \
        '-v+[verbose]' \
        '*:arg:'
}

_carbondata "$@"
