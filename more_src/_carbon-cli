#compdef carbon
# Documentation: https://github.com/carbon-language/carbon-lang
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Carbon language toolchain driver; subcommands include compile, link, etc.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'compile:compile a Carbon source'
  'help:show help'
  'link:link object files'
  'lower:lower SemIR'
  'parse:parse source'
  'tokenize:tokenize source'
  'lex:lex source'
  'check:semantic check source'
  'codegen:codegen from SemIR'
  'install:show install info'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--verbose[verbose]' \
  '*--version[show version]' \
  '*--vlog-level=[vlog level]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'carbon command' commands && ret=0 ;;
  (args) _files -g "*.carbon" ;;
esac

return ret
