#compdef mwcontam
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/mwcontam.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# EMBOSS mwcontam: find common contaminant masses across mass lists
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-files=[mass list file(s) to compare]:file:_files' \
  '-tolerance=[ppm tolerance for mass matching]:ppm:' \
  '-outfile=[output file]:file:_files' \
  '-odirectory2=[output directory]:dir:_files -/' \
  '*:mass file:_files' && ret=0
return ret
