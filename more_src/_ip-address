#compdef ip-address
# Documentation: https://man.archlinux.org/man/ip-address.8.en
# ip address - protocol address management

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip address command' \
      'add[establish new protocol address]' 'delete[remove protocol address]' \
      'show[display protocol addresses]' 'flush[remove addresses by criteria]' \
      'save[store address configuration]' 'restore[recover address configuration]' \
      'change[modify existing address]' 'replace[substitute address]' \
      'showdump[output address dump]' \
      'dev[target network interface]' 'local[interface address]' \
      'peer[remote endpoint address]' 'broadcast[broadcast address]' \
      'label[identifier tag]' 'scope[address validity area]' \
      'metric[prefix route priority]' 'valid_lft[address validity duration]' \
      'preferred_lft[preferred usage duration]' 'proto[protocol identifier]' \
      'home[IPv6 home address]' 'mngtmpaddr[manage temporary IPv6 addresses]' \
      'nodad[skip Duplicate Address Detection]' 'optimistic[RFC 4429 DAD variant]' \
      'noprefixroute[prevent automatic prefix route]' \
      'autojoin[enable multicast group joining]' && ret=0
    ;;
esac

return ret
