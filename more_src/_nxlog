#compdef nxlog
# Documentation: https://docs.nxlog.co/
# NXLog multi-platform log collection and processing agent

local ret=1

_arguments -s -S \
  '(-c --conf)'{-c,--conf}'[use alternate configuration file]:file:_files' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground rather than as a service]' \
  '(-q --quiet)'{-q,--quiet}'[minimize console output]' \
  '(-r --reload)'{-r,--reload}'[reload configuration of a running instance]' \
  '(-s --stop)'{-s,--stop}'[stop a running instance]' \
  '(-v --verify)'{-v,--verify}'[validate config file syntax without executing]' \
  '(-h --help)'{-h,--help}'[display usage information]' && ret=0

return ret
