#compdef kextutil
# Documentation: man kextutil(8) (macOS, deprecated; use kmutil load / kmutil print-diagnostics)
# Source: macOS kextutil — load, diagnose, and generate symbols for kernel extensions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*'{-a,-address=}'[treat KEXT (CFBundleIdentifier) as loaded at address]:identifier@address:' \
    '-arch=[architecture for symbol gen / kernel match]:arch:(i386 x86_64 x86_64h arm64 arm64e)' \
    '(-A -use-load-addresses)'{-A,-use-load-addresses}'[lookup dep addresses in running kernel]' \
    '*'{-b,-bundle-id=}'[load by CFBundleIdentifier]:identifier:' \
    '(-c -no-caches)'{-c,-no-caches}'[ignore repository cache files]' \
    '*'{-d,-dependency=}'[add KEXT and plugins to known set]:kext:_files' \
    '(-e -no-system-extensions)'{-e,-no-system-extensions}'[skip /System/Library/Extensions and /Library/Extensions defaults]' \
    '(-h -help)'{-h,-help}'[show help]' \
    '(-i -interactive)'{-i,-interactive}'[interactive: pause after each kext loads]' \
    '(-I -interactive-all)'{-I,-interactive-all}'[interactive for kexts + dependencies]' \
    '(-k -kernel)'{-k,-kernel=}'[link against this kernel file (with -no-load)]:kernel:_files' \
    '(-l -load-only)'{-l,-load-only}'[load only; do not start kext]' \
    '(-L -lint)'{-L,-lint}'[lint mode (validation only, no loading)]' \
    '(-m -match-only)'{-m,-match-only}'[send only personalities; do not load]' \
    '(-n -no-load)'{-n,-no-load}'[do not load; just generate symbols]' \
    '*'{-p,-personality=}'[send only named personality]:name:' \
    '(-q -quiet)'{-q,-quiet}'[quiet]' \
    '*'{-r,-repository=}'[add directory as kext repository]:dir:_files -/' \
    '(-s -symbols)'{-s,-symbols=}'[output directory for symbol files]:dir:_files -/' \
    '(-t -print-diagnostics)'{-t,-print-diagnostics}'[print diagnostics about load failures]' \
    '(-v -verbose)'{-v,-verbose=-}'[verbose level (0-6)]::level:(0 1 2 3 4 5 6)' \
    '(-x -safe-boot)'{-x,-safe-boot}'[require safe-boot eligibility]' \
    '(-z -no-authentication)'{-z,-no-authentication}'[skip auth checks (root only)]' \
    '*:kext bundle:_files -g "*.kext"' \
    && ret=0

return ret
