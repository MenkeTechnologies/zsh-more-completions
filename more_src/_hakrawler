#compdef hakrawler

# Zsh completion for hakrawler - web crawler for gathering URLs and endpoints

local -a arguments

arguments=(
  {-url,-u}'[target URL to crawl]:URL'
  {-depth,-d}'[maximum crawl depth]:depth'
  {-scope,-s}'[crawl scope]:scope:(strict fuzzy subs)'
  {-plain,-p}'[output URLs in plain text]'
  {-insecure,-i}'[skip TLS certificate verification]'
  '-subs[include subdomains in crawl]'
  '-t[number of threads]:threads'
  '-h[custom headers]:header'
  '-proxy[proxy URL]:proxy URL'
  '-timeout[request timeout in seconds]:seconds'
  '-json[output results as JSON]'
)

_arguments -s -S $arguments
