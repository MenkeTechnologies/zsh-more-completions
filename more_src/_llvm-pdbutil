#compdef llvm-pdbutil
# _llvm-pdbutil — LLVM PDB inspection tool (LLVM project, C++); read/write/explore Microsoft PDB debug info
# upstream: https://github.com/llvm/llvm-project

_llvm-pdbutil() {
    local -a sub=(
        'dump:dump PDB streams'
        'pretty:pretty-print PDB contents'
        'bytes:dump raw bytes'
        'merge:merge PDBs'
        'diff:diff PDBs'
        'pdb2yaml:convert PDB to YAML'
        'yaml2pdb:convert YAML to PDB'
        'export:export single stream'
        'explain:explain PDB at offset'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'llvm-pdbutil subcommand' sub ;;
        args)
            case $words[1] in
                dump) _arguments \
                    '--all[dump everything]' \
                    '--summary[dump summary]' \
                    '--streams[dump streams]' \
                    '--stream-blocks[dump stream blocks]' \
                    '--symbols[dump symbols]' \
                    '--types[dump types]' \
                    '--ids[dump ids]' \
                    '--modules[dump modules]' \
                    '--files[dump source files]' \
                    '--globals[dump globals]' \
                    '--publics[dump publics]' \
                    '--lines[dump line info]' \
                    '--inlinees[dump inlinees]' \
                    '--xmi[dump cross module imports]' \
                    '--xme[dump cross module exports]' \
                    '--injected-sources[dump injected sources]' \
                    '--natvis[dump natvis]' \
                    '--module-syms[dump module symbols]' \
                    '*:file:_files -g "*.pdb"' ;;
                pretty) _arguments \
                    '--all[print everything]' \
                    '--compilands[print compilands]' \
                    '--enums[print enums]' \
                    '--externals[print externals]' \
                    '--funcs[print functions]' \
                    '--symbols[print symbols]' \
                    '--typedefs[print typedefs]' \
                    '--types[print types]' \
                    '--no-enum-definitions[no enum definitions]' \
                    '--module-syms[print module symbols]' \
                    '*:file:_files -g "*.pdb"' ;;
                bytes|export|explain|merge|diff|pdb2yaml|yaml2pdb) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_llvm-pdbutil "$@"
