#compdef tpipe
# Documentation: https://www.star.bris.ac.uk/~mbt/stilts/sun256/tpipe-usage.html
# STILTS: perform pipeline processing on a single table

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '*cmd=[processing/filter commands]:cmds:' \
  'script=[file containing processing steps]:file:_files' \
  'ifmt=[input table format]:fmt:' \
  'istream=[read input as a stream]:bool:(true false)' \
  'omode=[output mode]:mode:(out meta stats count checksum cgi discard topcat samp plastic tosql gui)' \
  'ofmt=[output table format]:fmt:' \
  'out=[output table location]:out:_files' \
  '*:in:_files' && ret=0

return ret
