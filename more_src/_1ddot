#compdef 1ddot
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1ddot.html
# Print correlation matrix of 1D files and their inverse correlation matrix

local ret=1

_arguments -s -S \
  '(-dem)-one[make the first vector be all 1s]' \
  '(-one)-dem[remove mean from all vectors]' \
  '-cov[compute with covariance matrix instead of correlation]' \
  '-inn[compute with inner product matrix instead]' \
  '-rank[compute Spearman rank correlation (implies -terse)]' \
  '-terse[output only the correlation or covariance matrix]' \
  '-okzero[do not quit if a vector is all zeros]' \
  '*:file:_files' && ret=0

return ret
