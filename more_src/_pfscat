#compdef pfscat
# Documentation: https://resources.mpi-inf.mpg.de/pfstools/man1/pfscat.1.html
# concatenate frames in a pfs stream

local ret=1

_arguments -s \
  '(-H --horizontal)'{-H,--horizontal}'[stitch frames horizontally]' \
  '(-V --vertical)'{-V,--vertical}'[stitch frames vertically]' \
  '-j+[frame alignment type]:type:(min max center)' \
  '-R+[red channel value for extra space (default 0.0)]:val' \
  '-G+[green channel value for extra space (default 0.0)]:val' \
  '-B+[blue channel value for extra space (default 0.0)]:val' \
  '-Y+[colour of extra space in luminance mode]:val' \
  '(-h --help)'{-h,--help}'[print list of command-line options]' && ret=0

return ret
