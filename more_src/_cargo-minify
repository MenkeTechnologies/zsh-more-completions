#compdef cargo-minify
# Documentation: https://github.com/tweedegolf/cargo-minify
# Remove unused code from a Rust project

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--apply[apply the minification changes to your code]' \
  '--ignore=[exclude files matching wildcard pattern]:wildcard' \
  '--kinds=[unused code types to remove]:kinds:(FUNCTION ASSOCIATED_FUNCTION STRUCT ENUM UNION TYPE_ALIAS CONST STATIC)' \
  '--allow-no-vcs[override the version control requirement]' \
  '--allow-dirty[override checks for uncommitted changes]' \
  '--allow-staged[override checks for staged changes]' \
  '*:arg:_default' && ret=0

return ret
