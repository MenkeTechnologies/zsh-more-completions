#compdef rsgisshepsegment
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# Run the Shepherd et al segmentation algorithm.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '(-i --input)'{-i,--input}'[Specify the input image file.]:value:_files' \
  '(-o --output)'{-o,--output}'[Specify the output clump image file.]:value:_files' \
  '(-m --outmeanimg)'{-m,--outmeanimg}'[Specify the output mean image file.]:value:_files' \
  '(-t --tmpath)'{-t,--tmpath}'[Specify the file path for intermediate files.]:value:_files' \
  '(-k --numclusters)'{-k,--numclusters}'[Specify the number of clusters within the KMeans clustering.]:value:_files' \
  '(-n --minpxls)'{-n,--minpxls}'[Specify the minimum number pixels within a segments.]:value:_files' \
  '(-s --sampling)'{-s,--sampling}'[Specify the subsampling of the image for the data used]:value:_files' \
  '--maxiter[Specify the maximum number of iterations]:value:_files' \
  '(-d --distthres)'{-d,--distthres}'[Specify the distance threshold for joining the segments]:value:_files' \
  '(-b --band)'{-b,--band}'[An integer specifying the selected image bands.]:value:_files' \
  '--nodata[Specify a no data value for the input image (default is 0).]:value:_files' \
  '(-f --format)'{-f,--format}'[Specify the image output format (GDAL name).]:value:_files' \
  '--nostats[Specifies that no image statistics and]' \
  '--nostretch[Specifies that the input image bands should not be stretched.]' \
  '--nodelete[Specifies that the temporary images created during processing]' \
  '--inmem[Specifies that processing should be undertaken in memory]' \
  '*:file:_files' && ret=0

return ret
