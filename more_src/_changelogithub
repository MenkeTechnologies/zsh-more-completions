#compdef changelogithub

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--from=[starting tag or commit]:ref' \
  '--to=[ending tag or commit]:ref' \
  '--github=[GitHub repository]:owner/repo' \
  '--token=[GitHub token]:token' \
  '--name=[release name]:name' \
  '--prerelease[mark as prerelease]' \
  '--draft[create as draft]' \
  '--dry[dry run, print to stdout]' \
  '--capitalize[capitalize first letter of commits]' \
  '--emoji[use emojis in changelog]' \
  '--group[group commits by scope]' \
  '--no-contributors[hide contributors section]' \
  '--no-emoji[disable emojis]' && ret=0

return ret
