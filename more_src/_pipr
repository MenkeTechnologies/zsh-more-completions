#compdef pipr
# Documentation: https://github.com/elkowar/pipr
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --default)'{-d+,--default=}'[insert text into the textfield on startup]:text:' \
  '(-o --out-file)'{-o+,--out-file=}'[write final command to file]:file:_files' \
  '(-r --raw-mode)'{-r,--raw-mode}'[keep linebreaks in finished command]' \
  '--in-file=[read initial command from file]:file:_files' \
  '--no-isolation[disable isolation (run without bubblewrap sandbox)]' \
  '--config-reference[print the default configuration file]'
