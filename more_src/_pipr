#compdef pipr

# Zsh completion for pipr (live preview tool for piped shell commands)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --cmd)'{-c,--cmd}'[start with a command pre-filled]:command' \
  '(-p --prefix)'{-p,--prefix}'[set the pipeline prefix command]:prefix command' \
  '--config-dir[configuration directory]:dir:_files -/' \
  '--shell[shell to use for execution]:shell:(bash zsh fish sh)' \
  '*:input file:_files'
