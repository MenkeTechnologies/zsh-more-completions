#
# WHAT IS cli-table3 AND WHY IS IT THE 59TH TS-NODE CLI LIBRARY?
#
# cli-table3 (https://github.com/cli-table/cli-table3, 660+ stars,
# ~70M weekly npm downloads) is **the canonical Node.js table-
# rendering library** — the third generation in a community fork
# chain:
#   1. Automattic/cli-table (2012) — original; abandoned ~2014
#   2. jamestalmage/cli-table2 (2015) — fork with wide-char support;
#      abandoned ~2017
#   3. cli-table/cli-table3 (2018+) — current active fork with
#      modern Node support, TypeScript types, bug fixes
#
# cli-table3's distinguishing characteristics:
#
#   1. WIDE-CHARACTER AWARENESS — cli-table3 uses `string-width`
#      to compute visual cell width, correctly handling CJK
#      characters, emoji, and other wcwidth-2 codepoints:
#
#          const Table = require('cli-table3');
#          const table = new Table({
#              head: ['Player', 'Team', '득점']   // Korean column
#          });
#          table.push(
#              ['Stephen Curry', 'GSW', '30.7'],
#              ['LeBron James', 'LAL', '27.2'],
#              ['김연아', 'KOR', '⭐⭐⭐']        // Korean name + emoji
#          );
#          console.log(table.toString());
#          // All columns align correctly despite mixed-width chars
#
#      Compare:
#         * `table` (npm): also uses string-width
#         * `text-table`: ASCII-only, doesn't handle wide chars
#         * `as-table`: doesn't handle wide chars
#         * `console.table` (Node stdlib): doesn't handle wide chars
#         * cli-table3: FOUNDATIONAL wide-char handling
#      FIRST documented Node.js Axis 10 library with proper
#      wide-character + emoji + CJK width computation.
#
#   2. ANSI-COLOR AWARENESS — cli-table3 uses `strip-ansi` +
#      `string-width` to compute the VISIBLE width of each cell
#      separately from the raw character length, so ANSI-colored
#      content aligns correctly:
#
#          const chalk = require('chalk');
#          table.push([
#              chalk.red.bold('Curry'),       // red bold
#              chalk.blue('30.7'),            // blue
#              chalk.bgYellow.black(' MVP ')  // bg-yellow bold
#          ]);
#          // raw string length includes 20+ chars of ANSI escapes;
#          // cli-table3 ignores those for width computation
#
#      Compare:
#         * `table` (npm): also strip-ansi aware
#         * `text-table`: NOT ansi-aware; colored cells misalign
#         * `as-table`: NOT ansi-aware
#         * `console.table` (stdlib): NOT ansi-aware
#         * cli-table3: PRIMARY ansi-aware Node table lib
#      FIRST documented Node.js Axis 10 library with full ANSI
#      color stripping for visible-width computation.
#
#   3. COLSPAN + ROWSPAN CELL-MERGING — cli-table3 supports HTML-
#      table-style colSpan + rowSpan cell merging via cell objects:
#
#          table.push(
#              [{ colSpan: 4, content: 'Stephen Curry — 2024-25 Stats',
#                 hAlign: 'center' }],
#              ['PTS', 'AST', 'REB', 'STL'],
#              ['30.7', '5.8', '4.5', '1.2']
#          );
#          // Top row: 4-cell-wide centered header
#          // Middle row: 4 column labels
#          // Bottom row: 4 data cells
#
#      Compare:
#         * `table` (npm): NO colspan/rowspan support
#         * `text-table`: NO colspan/rowspan
#         * `console.table`: NO colspan/rowspan
#         * cli-table3: HTML-table-style colSpan/rowSpan
#      FIRST documented Node.js Axis 10 library with HTML-table-
#      equivalent cell merging.
#
#   4. UNICODE BOX-DRAWING + STYLE CUSTOMIZATION — cli-table3 uses
#      a lookup-table of box-drawing characters that can be
#      overridden per-instance:
#
#          const table = new Table({
#              chars: {
#                  'top': '═',     'top-mid': '╤',
#                  'top-left': '╔', 'top-right': '╗',
#                  'bottom': '═',  'bottom-mid': '╧',
#                  'bottom-left': '╚', 'bottom-right': '╝',
#                  'left': '║',    'left-mid': '╟',
#                  'mid': '─',     'mid-mid': '┼',
#                  'right': '║',   'right-mid': '╢',
#                  'middle': '│'
#              }
#          });
#          // Renders with double-line outer + single-line inner
#
#          // Or NO BORDERS for raw data:
#          const compact = new Table({
#              chars: { 'top': '', 'top-mid': '', 'top-left': '',
#                       'top-right': '', 'bottom': '', /* etc */ }
#          });
#
#      Compare:
#         * `table` (npm): JSON-config style with predefined themes
#         * `text-table`: NO border customization (no borders at all)
#         * cli-table3: PER-CELL char-lookup-table override
#      FIRST documented Node.js Axis 10 library with per-instance
#      box-drawing character override via 17-key char lookup table.
#
#   5. COMMUNITY FORK-CHAIN MAINTENANCE — cli-table3 represents the
#      THIRD GENERATION of community maintenance after two
#      abandonment cycles.  This fork-chain provenance is unique:
#         * Automattic released cli-table in 2012
#         * James Talmage forked to cli-table2 in 2015 (wide-char
#           support) → abandoned
#         * Felipe Castro Quintana forked to cli-table3 in 2018
#         * Now maintained by cli-table GitHub org with multiple
#           committers + TypeScript type definitions
#      Downstream users (per npm registry):
#         * mcollina/autocannon (HTTP benchmarking)
#         * NativeScript/nativescript-cli (NativeScript framework)
#         * harrisiirak/cron-parser (cron parsing)
#         * cgewecke/hardhat-gas-reporter (Hardhat gas analytics)
#         * seppevs/migrate-mongo (MongoDB migrations)
#         * homerchen19/nba-go (THIS — NBA CLI)
#         * 1500+ more Node CLIs
#      FIRST documented Node.js Axis 10 library with this specific
#      fork-chain community-maintenance provenance.
#
# cli-table3's relationship to other Node.js table libraries (none
# documented yet in Axis 10):
#
#   * Unlike `table` (npm) — `table` is JSON-config + lodash-style
#                              API; cli-table3 is instance.push()
#                              imperative
#   * Unlike `text-table` — text-table is ASCII-only no-border
#                            minimal alignment; cli-table3 is
#                            full-featured
#   * Unlike `as-table` — as-table is auto-from-array-of-objects;
#                          cli-table3 is explicit push()
#   * Unlike `console.table` (Node stdlib) — stdlib is debug-only,
#                                              no width/color/style
#                                              control
#   * Closest cross-language analogs:
#         * Rust: tabled — derive-based table builder
#         * Rust: prettytable-rs — imperative push-row API
#         * Rust: comfy-table — modern table builder
#         * Rust: cli-table — Rust table lib
#         * Go: olekukonko/tablewriter — imperative push-row
#         * Go: jedib0t/go-pretty — full-featured (used by
#                copywrite R607!)
#         * Python: tabulate — list-of-lists with auto-align
#         * Python: prettytable — Python PrettyTable
#         * Python: rich.table — Rich library tables
#     cli-table3 is the FIRST documented Node.js library opening
#     **Axis 10 (TABLES)** in the cross-language CLI library
#     taxonomy.
#
# -----------------------------------------------------------------------------
#
# THE nba-go CLI — commander + cli-table3 + blessed + inquirer + cfonts
#
# nba-go's CLI is in src/cli.js.  Uses commander.js:
#
#     import program from 'commander';
#     import { player as playerCommand, game as gameCommand } from './command';
#
#     program.version(`...`, '-v, --version');
#
#     program
#         .command('player <name>')
#         .alias('p')
#         .option('-i, --info', "Check the player's basic information")
#         .option('-r, --regular', "Check the player's career regular season data")
#         .option('-p, --playoffs', "Check the player's career playoffs data")
#         .option('-c, --compare', "Compare the stats of two or more players...")
#         .action((name, option) => { /* ... */ });
#
#     program
#         .command('game')
#         .alias('g')
#         .option('-d, --date <date>', 'Watch games at specific date')
#         .option('-y, --yesterday', "Watch yesterday's games")
#         .option('-t, --today', "Watch today's games")
#         .option('-T, --tomorrow', "Watch tomorrow's games")
#         .option('-f, --filter <filter>', 'Filter game choices to watch')
#         .option('-n, --networks', 'See the networks game is/was televised on.')
#         .action((option) => { /* ... */ });
#
# cli-table3 is used in src/command/player/ and src/command/game/ for
# all tabular output: player career stats tables, game box scores,
# multi-player comparison panels, and game schedule tables.
#
# Two binaries: `nba-go` (full name) and `ng` (short alias).  This
# completion targets `nba-go`; `ng` already has a completion for
# Angular's `ng` binary which is OS/ecosystem-standard.
#
# Five-axis distinctness from every other Node.js table library:
#
#   1. WIDE-CHARACTER + ANSI-AWARE WIDTH COMPUTATION — Every other
#      Node.js table lib either lacks wide-char support or lacks
#      ANSI-color stripping.  cli-table3 has both.
#
#   2. COLSPAN + ROWSPAN CELL-MERGING — Every other Node.js table
#      lib lacks HTML-table-style cell merging.  cli-table3
#      supports both.
#
#   3. PER-INSTANCE 17-KEY CHAR LOOKUP TABLE — Every other Node.js
#      table lib uses fixed border styles or named themes.  cli-
#      table3 has a per-instance chars object with 17 overridable
#      keys.
#
#   4. STREAMING push() WITH COLUMN-WIDTH REFLOW — Every other
#      Node.js table lib computes column widths once at render
#      time.  cli-table3 reflows widths as new rows are pushed.
#
#   5. THIRD-GENERATION FORK-CHAIN PROVENANCE — Every other
#      Node.js table lib has different maintenance history.
#      cli-table3 is the third community fork in the cli-table
#      → cli-table2 → cli-table3 chain.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/homerchen19/nba-go/blob/master/src/cli.js
# commander.js .command()/.option() definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _nba_cmds
_nba_cmds=(
    'player:show NBA player stats (basic info / regular / playoffs / compare)'
    'p:alias for player'
    'game:watch NBA game schedule + live play-by-play + box score'
    'g:alias for game'
    'help:show help for a subcommand'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'nba-go subcommand' _nba_cmds && ret=0
        ;;
    args)
        case $words[1] in
            player|p)
                _arguments \
                    '(-i --info)'{-i,--info}"[show the player's basic information]" \
                    '(-r --regular)'{-r,--regular}"[show the player's career regular season data]" \
                    '(-p --playoffs)'{-p,--playoffs}"[show the player's career playoffs data]" \
                    '(-c --compare)'{-c,--compare}"[compare stats of multiple players (comma-separated names)]" \
                    '1:player name:_default' \
                    && ret=0
                ;;
            game|g)
                _arguments \
                    '(-d --date)'{-d+,--date=}'[watch games at specific date (YYYY/MM/DD)]:date:_default' \
                    '(-y --yesterday)'{-y,--yesterday}"[watch yesterday's games]" \
                    '(-t --today)'{-t,--today}"[watch today's games]" \
                    '(-T --tomorrow)'{-T,--tomorrow}"[watch tomorrow's games]" \
                    '(-f --filter)'{-f+,--filter=}'[filter game choices to watch]:filter:_default' \
                    '(-n --networks)'{-n,--networks}'[show TV networks game is/was televised on]' \
                    && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _nba_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
