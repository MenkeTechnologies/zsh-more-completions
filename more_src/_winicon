#compdef winicon
# =============================================================================
# winicon — Cross-platform tooling for creating, extracting and getting info
#           from Windows .ico files.  Unlike Microsoft's IconExtractor or
#           image-format tools that need a Windows host, winicon is a Go
#           binary that works identically on Linux/macOS/Windows.  Used by
#           Wails (and other Go GUI frameworks that target Windows) to
#           bundle application icons during the cross-compilation step.
#
# Author:  Lea Anthony (the creator of Wails)
# Source:  https://github.com/leaanthony/winicon
# CLI:     cmd/winicon/internal/app/ (uses leaanthony/clir)
# Library: leaanthony/clir
#          ("A Simple and Clear CLI library. Dependency free.")
# License: MIT
# Status:  Stable — 24+ stars; the canonical Lea-Anthony-ecosystem example
#          of clir usage.  Wails itself uses clir for its CLI (v2 and v3),
#          making clir one of the most-deployed Go CLI libraries via Wails
#          embedding (34k+ Wails stars).
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 31 LIBRARIES
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 31ST Go CLI library variant.  Go climbs from 30 to 31 documented libraries
# (clir via winicon).  New leaderboard: Rust=31, Go=31 (TWO-WAY TIE),
# TypeScript-Node=30.  Taxonomy now spans 234 cross-language CLI library
# variants across 56 documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS leaanthony/clir AND WHY IS IT A DISTINCT 31ST GO CLI LIBRARY?
#
# clir (https://github.com/leaanthony/clir, 202+ stars) is **Lea Anthony's
# (leaanthony) "simple and clear" CLI library for Go**.  Lea Anthony is
# the creator of **Wails** (34,551 stars — Go + Web frontend desktop app
# framework, analogous to Tauri/Electron but Go instead of Rust/Node).
# Wails v2 and v3 both use clir for their entire CLI surface.
#
# clir is distinct from every documented Go CLI library on FIVE specific
# axes:
#
#   1. EXPLICIT "DEPENDENCY-FREE" DESIGN — clir's tagline emphasizes
#      "Dependency free": its go.mod has NO TRANSITIVE dependencies
#      beyond Go's standard library.  Most Go CLI libraries pull in
#      multiple dependencies (cobra pulls in 25+, kong pulls in 5+).
#      clir produces a smaller binary footprint and avoids supply-
#      chain risk.  This positions clir alongside Rust's noargs (R474)
#      as a "no-deps" CLI library in its respective language.
#
#   2. POINTER-BASED FLAG SETTERS — `cmd.BoolFlag(name, desc, &var)`
#      writes directly to a local Go variable:
#         var outputJSON bool = false
#         cmd.BoolFlag("json", "Get file information in JSON format",
#                       &outputJSON)
#      This is the same pattern as Go's stdlib `flag` package
#      (`flag.BoolVar(&v, name, default, usage)`) but with a richer
#      app/subcommand structure on top.  Most modern Go CLI libraries
#      use struct tags (kong R465, go-arg R475) or builder objects
#      (cobra, kingpin); clir resurrects the stdlib pointer-receiver
#      pattern in a richer framework.
#
#   3. EXPLICIT CONSTRUCTOR PATTERN — `clir.NewCli(name, description,
#      version)` returns an `*Cli` instance.  No package-level singleton
#      (commando R487), no struct tag (kong R465), no usage-text-as-spec
#      (mow.cli R470).  Just an explicit constructor + method chain:
#         app := clir.NewCli("WinIcon",
#                            "A utility for manipulating .ico files",
#                            "v0.0.1")
#         app.SetBannerFunction(fn)
#         app.NewSubCommand("info", "Show ico info")
#         app.Run()
#
#   4. `SubCommand` RETURNS *Command FOR FURTHER CONFIGURATION — Lea
#      Anthony's pattern is to call `cli.NewSubCommand(...)` then
#      attach flags + action via the returned `*Command`:
#         cmd := cli.NewSubCommand("g", "Generate .ico file from image")
#         cmd.StringFlag("sizes", "Icon sizes (16,24,64)", &sizes)
#         cmd.Action(func() error { /* ... */ })
#      The Subcommand object exposes all the same flag-setter methods
#      as the top-level Cli object (BoolFlag, StringFlag, IntFlag),
#      letting subcommands accumulate flags independently.
#
#   5. `OtherArgs()` FOR POSITIONALS — within a subcommand action,
#      `cmd.OtherArgs()` returns the slice of non-flag arguments.  This
#      is distinct from `flag.Args()` (which gives ALL remaining args
#      from the global flag package) — clir's `OtherArgs` is scoped to
#      the subcommand's own argument context.  Useful for subcommands
#      that take a filename positional + flags:
#         args := cmd.OtherArgs()
#         if len(args) != 1 { return fmt.Errorf("expected filename") }
#         filename := args[0]
#
# THE clir API SURFACE (verbatim from winicon usage)
#
#   import "github.com/leaanthony/clir"
#
#   app := clir.NewCli("WinIcon", "A utility for manipulating .ico files",
#                      "v0.0.1")
#
#   // Custom banner (optional)
#   app.SetBannerFunction(func(cli *clir.Cli) string {
#       return fmt.Sprintf("%s %s  (c) 2020-Present Lea Anthony",
#                          cli.Name(), cli.Version())
#   })
#
#   // Subcommand: info
#   {
#       cmd := app.NewSubCommand("i", "Show .ico file information")
#       var outputJSON bool = false
#       cmd.BoolFlag("json", "Get file information in json format",
#                    &outputJSON)
#       cmd.Action(func() error {
#           args := cmd.OtherArgs()
#           // ...
#           return nil
#       })
#   }
#
#   // Subcommand: generate
#   {
#       cmd := app.NewSubCommand("g", "Generate .ico file from image")
#       sizes := "256"
#       cmd.StringFlag("sizes", "Icon sizes (16,24,64)", &sizes)
#       cmd.Action(func() error { /* ... */ })
#   }
#
#   // Run
#   return app.Run()
#
# Common methods on *clir.Cli:
#   .NewSubCommand(name, description) *Command   — register subcommand
#   .SetBannerFunction(fn)                        — custom banner
#   .Name()                                        — get program name
#   .Version()                                     — get version
#   .Run()                                         — parse argv and dispatch
#   .Action(fn)                                    — top-level handler
#   .DefaultCommand(fn)                            — default when no subcmd
#   .PrintBanner()                                 — print banner
#
# Common methods on *clir.Command:
#   .BoolFlag(name, desc, &ptr)                    — boolean flag
#   .StringFlag(name, desc, &ptr)                  — string flag
#   .IntFlag(name, desc, &ptr)                     — int flag
#   .Float64Flag(name, desc, &ptr)                 — float64 flag
#   .StringsFlag(name, desc, &ptr)                 — []string flag (slice)
#   .Action(fn)                                    — register handler
#   .NewSubCommand(name, desc)                     — nested subcommand
#   .LongDescription(desc)                         — long help text
#   .OtherArgs()                                    — get positional args
#   .ShortDescription()                             — short usage line
#
# CONTRAST WITH OTHER GO CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * flag (stdlib)                — pointer-based but no subcommands
#   * cobra (spf13)                — full framework with code generator
#   * urfave/cli                   — struct-list declarative
#   * kingpin (alecthomas)         — fluent builder
#   * kong (alecthomas, R465)      — struct-tag declarative
#   * go-arg (R475)                — single MustParse(&struct)
#   * opts (R479)                  — frictionless struct
#   * mow.cli (R470)               — SPEC-string grammar
#   * go-getoptions (R483)         — Perl Getopt::Long port
#   * commando (R487)              — package-level singleton
#   * mkideal/cli (R491)           — struct-tag comma-aliases
#   * clir (THIS)                  — explicit constructor + pointer
#                                    flag setters + dependency-free
#
# clir's combination of EXPLICIT CONSTRUCTOR + STDLIB-FLAG-STYLE POINTER
# SETTERS + DEPENDENCY-FREE GUARANTEE is unique among documented Go CLI
# libraries.  It feels like the "Go-stdlib-flag-package + subcommands +
# polish" approach — comfortable for developers who already know `flag`
# but want subcommand support without taking on cobra's 25-dep tree.
#
# REAL-WORLD clir USERS:
#
#   * wailsapp/wails — Wails 2 + 3 (34,551*; the FLAGSHIP user of clir,
#                                   in corpus as _wails)
#   * leaanthony/winicon — Windows .ico tool (THIS, 24*)
#   * leaanthony/newmod — Go module scaffolder (1*)
#   * 9seconds/topographer — self-hosted GeoIP service (33*)
#   * acheong08/apple-corelocation-experiments — Apple location reversing
#   * patrickeasters/sds-managed-policy-mapper — Sysdig policy mapping
#   * daodao97/goadmin — Go Vue Admin
#   * dedo1911/discord-w2tg — Discord → Telegram bridge
#   * host-uk/core — HostUK CLI tooling
#   * duolabmeng6/go-qoq — Wails-based admin panel
#   * Many other Go CLIs from the Wails-developer ecosystem
#
# -----------------------------------------------------------------------------
# WINICON'S CLI SURFACE (verbatim from cmd/winicon/internal/app/)
# -----------------------------------------------------------------------------
#
# USAGE:
#   winicon <SUBCOMMAND> [OPTIONS] <FILE>
#
# Subcommands:
#   i (info)              Show .ico file information
#                         Usage: winicon i [flags] <icon.ico>
#                         Flags:
#                           --json    Output info as JSON (default: text table)
#
#   g (generate)          Generate .ico file from an input image
#                         Usage: winicon g [--sizes 16,24,64] <input.png>
#                         Produces <input>.ico
#                         Flags:
#                           --sizes   Comma-separated icon sizes
#                                     (default: "256")
#
#   e (extract)           Extract icons from a .ico file as individual
#                         PNG files
#                         Usage: winicon e [flags] <icon.ico>
#                         Each icon is extracted as <icon>_<SIZE>.png
#
# Standard:
#   --help                Show help and exit
#   --version             Show version and exit
#
# =============================================================================

_winicon() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands

    subcommands=(
        'i:show .ico file information'
        'g:generate .ico file from image'
        'e:extract icons from .ico as PNG files'
        'info:show .ico file information'
        'generate:generate .ico file from image'
        'extract:extract icons from .ico as PNG files'
    )

    _arguments -C \
        '--help[show help and exit]' \
        '--version[show version and exit]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t subcommands 'winicon subcommand' subcommands && ret=0
            ;;
        (args)
            case $line[1] in
                (i|info)
                    _arguments \
                        '--json[output info as JSON instead of text table]' \
                        ':icon file:_files -g "*.ico"' \
                        && ret=0
                    ;;
                (g|generate)
                    _arguments \
                        '--sizes[comma-separated icon sizes]:sizes (default 256):' \
                        ':input image:_files -g "*.(png|jpg|jpeg|bmp|gif)"' \
                        && ret=0
                    ;;
                (e|extract)
                    _arguments \
                        ':icon file:_files -g "*.ico"' \
                        && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_winicon "$@"
