#compdef cert_write

local curcontext="$curcontext" state line ret=1
local -a params

params=(
  'request_file=:certificate request file'
  'subject_key=:subject key file'
  'subject_pwd=:subject key password'
  'subject_name=:subject DN'
  'issuer_crt=:issuer certificate'
  'issuer_key=:issuer key file'
  'issuer_pwd=:issuer key password'
  'issuer_name=:issuer DN'
  'output_file=:output certificate file'
  'serial=:serial number'
  'serial_hex=:serial in hex'
  'not_before=:not before date'
  'not_after=:not after date'
  'is_ca=:is CA (0/1)'
  'max_pathlen=:max path length'
  'key_usage=:comma-separated key usage'
  'ns_cert_type=:Netscape cert type'
  'authority_identifier=:include authority identifier (0/1)'
  'subject_identifier=:include subject identifier (0/1)'
  'basic_constraints=:include basic constraints (0/1)'
  'md=:hash algorithm'
  'version=:cert version'
  'selfsign=:self-signed (0/1)'
)

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    if compset -P '(request_file|subject_key|issuer_crt|issuer_key|output_file)='; then
      _files && ret=0
    elif compset -P '(is_ca|authority_identifier|subject_identifier|basic_constraints|selfsign)='; then
      _values flag 0 1 && ret=0
    elif compset -P 'md='; then
      _values 'hash' MD5 SHA1 SHA224 SHA256 SHA384 SHA512 && ret=0
    else
      _describe -t params 'param' params -S '' && ret=0
    fi
    ;;
esac

return ret
