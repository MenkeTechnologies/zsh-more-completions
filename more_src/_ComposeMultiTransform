#compdef ComposeMultiTransform
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ComposeMultiTransform.cxx — compose ANTs transforms into a single warp (C++, positional + -R/-i).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-R+[reference template image (defines output geometry)]:file:_files -g "*.{nii,nii.gz}"' \
    '*-i[invert the next transform]' \
    '1:Dimension:(2 3 4)' \
    '2:outwarp.nii:_files' \
    '*:transform files (in order applied right-to-left):_files' \
    && ret=0

return ret
