#compdef codacy-cli codacy-analysis-cli
# Documentation: https://github.com/codacy/codacy-cli-v2
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'analyze:run code analysis locally'
  'analyse:run code analysis (alias)'
  'install:install Codacy CLI dependencies'
  'init:initialize Codacy CLI configuration'
  'update:update CLI components'
  'config:print/edit Codacy CLI configuration'
  'discover:auto-discover tools'
  'upload:upload analysis results to Codacy'
  'sarif:emit SARIF results'
  'plugins:plugin management'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--verbose[verbose logging]' \
  '--debug[debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'codacy command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (analyze|analyse)
        _arguments \
          '--project-token=[Codacy project token]:token:' \
          '--api-token=[Codacy API token]:token:' \
          '--organization-provider=[git provider]:provider:(GitHub Bitbucket GitLab BitbucketEnterprise)' \
          '--username=[organization username]:user:' \
          '--project=[Codacy project name]:project:' \
          '--codacy-api-base-url=[Codacy API base URL]:url:' \
          '*--tool=[tool short name]:tool:(eslint pylint pmd brakeman bandit shellcheck rubocop coverage metrics duplication issues hadolint stylelint trivy semgrep golangci-lint)' \
          '--directory=[source directory]:dir:_files -/' \
          '--commit-uuid=[commit UUID]:sha:' \
          '--skip-commit-uuid-validation[allow non-current-branch commit]' \
          '--skip-uncommitted-files-check[skip uncommitted file check]' \
          '--upload[upload results to Codacy]' \
          '--parallel=[max parallel tools]:n:' \
          '--max-allowed-issues=[fail above N issues]:n:' \
          '--fail-if-incomplete[fail if any tool errored]' \
          '--allow-network[allow tool network access]' \
          '--force-file-permissions[force file readable perms]' \
          '--tool-timeout=[per-tool timeout]:duration:' \
          '--max-tool-memory=[per-tool memory limit]:size:' \
          '--output=[results output directory or file]:dest:_files' \
          '--format=[output format]:format:(text json sarif)' && ret=0 ;;
      (sarif)
        _arguments \
          '--output=[SARIF output file]:file:_files' \
          '*::args:' && ret=0 ;;
      (install|update)
        _arguments \
          '--mode=[install mode]:mode:(local global system)' && ret=0 ;;
      (init|config)
        _arguments \
          '--force[overwrite existing config]' && ret=0 ;;
      (plugins)
        _arguments '*::sub:(list install update remove)' && ret=0 ;;
    esac ;;
esac

return ret
