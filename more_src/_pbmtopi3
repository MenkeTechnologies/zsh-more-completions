#compdef pbmtopi3
# Documentation: https://netpbm.sourceforge.net/doc/pbmtopi3.html
# convert a PBM image into an Atari Degas .pi3 file

local ret=1

_arguments -s \
  '-quiet[suppress libnetpbm chatter]' \
  '-version[print Netpbm version and exit]' \
  '1:pbm file:_files -g "*.(pbm|pnm|pam)"' && ret=0

return ret
