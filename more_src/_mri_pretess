#compdef mri_pretess
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_pretess
# FreeSurfer: remove ambiguous voxel configurations before tessellation

local ret=1

_arguments -s -S \
  '-debug_voxel[debug voxel coordinates]:C R S' \
  '-nocorners[no removal of corner configurations]' \
  '-w[enable diagnostic writing]' \
  '-keep[preserve WM edits]' \
  '-test[add a voxel that should be removed (testing)]' \
  '1:filled volume:_files' \
  '2:label string (127 rh, 255 lh)' \
  '3:norm volume:_files' \
  '4:new filled volume:_files' && ret=0

return ret
