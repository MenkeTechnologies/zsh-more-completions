#compdef amdgpu amdgpu-pro amdgpu-install
# _amdgpu — AMD GPU driver and SDK install helper CLI alias (AMD / amdgpu install team, Bash); custom argparse
# upstream: https://www.amd.com/en/support/linux-drivers

_amdgpu() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--usecase=+[install usecase]:u:(workstation graphics multimedia rocm hip hiplibsdk amf lrt opencl opencllegacy openclsdk wsbase)' \
        '--list-usecase[list usecases]' \
        '--no-32[no 32-bit packages]' \
        '--no-dkms[no DKMS]' \
        '--uninstall[uninstall]' \
        '-y[yes]' \
        '--yes[yes]' \
        '--accept-eula[accept EULA]' \
        '--proxy=+[proxy]:url:_urls' \
        '--apt-options=+[apt options]:str:' \
        '--dnf-options=+[dnf options]:str:' \
        '--rocmrelease=+[rocm release]:str:' \
        '--opencl=+[opencl runtime]:o:(rocr legacy)' \
        '--vulkan=+[vulkan driver]:v:(amdvlk pro)' \
        '--keep[keep cache]' \
        '--package-manager=+[package manager]:pm:(apt dnf yum zypper)' \
        '--use-driver-dir=+[driver dir]:dir:_files -/' \
        '*:arg:'
}

_amdgpu "$@"
