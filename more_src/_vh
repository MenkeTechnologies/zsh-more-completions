#compdef vh valohai-cli
# Documentation: https://docs.valohai.com/cli-commands
# Valohai machine learning platform command line client

local ret=1
local context state line
typeset -A opt_args

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug[enable debug logging]' \
  '--no-debug[disable debug logging]' \
  '--output-format=[set output format]:format:(human csv tsv scsv psv json)' \
  '--table-format=[set table format]:format:(human csv tsv scsv psv json)' \
  '--valohai-host=[override API host]:host:_hosts' \
  '--valohai-token=[use authentication token]:token:' \
  '--project=[override project id]:project:' \
  '--project-mode=[set project mode]:mode:' \
  '--project-root=[set project root directory]:dir:_files -/' \
  '--version[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'init:interactively initialize a Valohai project'
      'login:log in into Valohai'
      'logout:log out of Valohai'
      'lint:lint a valohai.yaml file'
      'execution:manage executions'
      'pipeline:manage pipelines'
      'project:manage projects'
      'task:manage tasks'
      'deployment:manage deployments'
      'notebook:run a notebook'
      'data:manage data'
      'alias:manage data aliases'
      'environments:list available environments'
      'parcel:manage parcels'
      'yaml:generate valohai.yaml'
      'update-check:check for CLI updates'
    )
    _describe -t commands 'vh command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      execution)
        local -a sub
        sub=(
          'run:start a new execution'
          'list:list executions'
          'info:show execution info'
          'logs:show execution logs'
          'outputs:list execution outputs'
          'open:open execution in browser'
          'stop:stop an execution'
          'delete:delete an execution'
          'ssh:open an SSH connection to an execution'
          'watch:watch an execution'
          'summarize:summarize executions'
        )
        if (( CURRENT == 2 )); then
          _describe -t subcommands 'execution subcommand' sub && ret=0
        elif [[ $line[2] == run ]]; then
          _arguments -s \
            '(-c --commit)'{-c,--commit}'=[specify commit SHA]:commit:' \
            '(-e --environment)'{-e,--environment}'=[environment UUID or slug]:env:' \
            '(-i --image)'{-i,--image}'=[override Docker image]:image:' \
            '(-t --title)'{-t,--title}'=[execution title]:title:' \
            '(-w --watch)'{-w,--watch}'[watch execution after start]' \
            '--open-browser[open browser to execution page]' \
            '*'{-v,--var}'=[add environment variable NAME=VALUE]:var:' \
            '*--tag=[tag the execution]:tag:' \
            '(-s --sync)'{-s,--sync}'=[download outputs to directory]:dir:_files -/' \
            '(-a --adhoc)'{-a,--adhoc}'[upload working directory for ad-hoc execution]' \
            '--yaml=[path to valohai.yaml]:file:_files' \
            '--priority=[job priority level]:priority:' \
            '*:step:' && ret=0
        else
          ret=0
        fi
        ;;
      pipeline)
        local -a sub
        sub=(
          'run:start a pipeline run'
          'list:list pipelines'
          'stop:stop a pipeline'
          'convert-to-api:convert a pipeline to API form'
        )
        _describe -t subcommands 'pipeline subcommand' sub && ret=0
        ;;
      project)
        local -a sub
        sub=(
          'create:create a project'
          'link:link a directory to a project'
          'unlink:unlink the current directory'
          'list:list projects'
          'status:show project status'
          'open:open the project in browser'
          'fetch:fetch project commits'
          'commits:list project commits'
          'environment-variables:manage project environment variables'
        )
        _describe -t subcommands 'project subcommand' sub && ret=0
        ;;
      task)
        local -a sub
        sub=('list:list tasks' 'stop:stop a task')
        _describe -t subcommands 'task subcommand' sub && ret=0
        ;;
      yaml)
        local -a sub
        sub=('step:generate steps' 'pipeline:generate pipeline')
        _describe -t subcommands 'yaml subcommand' sub && ret=0
        ;;
      *)
        ret=0
        ;;
    esac
    ;;
esac

return ret
