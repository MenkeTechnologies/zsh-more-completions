#compdef seqmatchall
# Documentation: https://man.archlinux.org/search?q=seqmatchall
# Reference accessed: 2026-05-16

# EMBOSS seqmatchall: find all word matches between every pair of
# sequences in a set (cross-correlation table).
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-wordsize=[word size for matching]:size:' \
  '-aformat=[alignment output format]:format:(simple srspair pair markx0 markx1 markx2 markx3 markx10 srs score)' \
  '-outfile=[alignment output file]:file:_files' \
  '*:sequence USA:_files' && ret=0

return ret
