#compdef vgdisplay
# _vgdisplay — LVM2 vgdisplay show VG attributes CLI (Red Hat / LVM2 team, C); custom argparse
# upstream: https://github.com/lvmteam/lvm2

_vgdisplay() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-A+[autobackup]:b:(y n)' \
        '--autobackup=+[autobackup]:b:(y n)' \
        '-a[all]' \
        '--all[all]' \
        '-c[columns]' \
        '-C[columns]' \
        '--columns[columns]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--ignorelockingfailure[ignore locking failure]' \
        '--ignoreskippedcluster[ignore skipped cluster]' \
        '--nosuffix[no unit suffix]' \
        '--units=+[units]:u:(h H b s k K m M g G t T p P e E)' \
        '--reportformat=+[report format]:fmt:(basic json json_std)' \
        '--noheadings[no headings]' \
        '--separator=+[field separator]:str:' \
        '--readonly[readonly]' \
        '--config=+[config string]:str:' \
        '--devices=+[devices]:list:' \
        '--devicesfile=+[devices file]:file:_files' \
        '--select=+[select expr]:str:' \
        '-s[short]' \
        '--short[short]' \
        '-S+[select expr]:str:' \
        '--foreign[foreign]' \
        '--shared[shared]' \
        '--activevolumegroups[only active]' \
        '*:vg:'
}

_vgdisplay "$@"
