#compdef graphicsmagick-cli gm-cli
# _graphicsmagick-cli — GraphicsMagick swiss-army-knife of image processing CLI alias (GraphicsMagick team, C); custom argparse
# upstream: https://sourceforge.net/projects/graphicsmagick/

_graphicsmagick-cli() {
    local -a sub=(
        'animate:animate sequence of images'
        'batch:batch mode'
        'benchmark:benchmark operations'
        'compare:compare two images'
        'composite:composite images'
        'conjure:execute MSL scripts'
        'convert:convert/transform images'
        'display:display image'
        'help:show help'
        'identify:identify image format/details'
        'import:capture screen'
        'mogrify:transform images in place'
        'montage:create image montage'
        'time:time operations'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gm subcommand' sub ;;
        args)
            case $words[1] in
                convert|mogrify) _arguments \
                    '-quality=+[level]:n:' \
                    '-resize=+[geometry]:str:' \
                    '-rotate=+[deg]:str:' \
                    '-flip[flip vertically]' \
                    '-flop[flip horizontally]' \
                    '-crop=+[geometry]:str:' \
                    '-thumbnail=+[geometry]:str:' \
                    '-blur=+[radius]:str:' \
                    '-sharpen=+[radius]:str:' \
                    '-colorspace=+[colorspace]:c:(RGB sRGB CMYK Gray HSL HSB YIQ YUV YCbCr XYZ)' \
                    '-depth=+[bits]:n:' \
                    '-density=+[dpi]:str:' \
                    '-strip[remove metadata]' \
                    '-format=+[format]:str:' \
                    '*:files:_files' ;;
                identify) _arguments \
                    '-format=+[fmt]:str:' \
                    '-verbose[verbose]' \
                    '-ping[ping]' \
                    '*:files:_files' ;;
                composite|compare|montage) _arguments \
                    '-quality=+[level]:n:' \
                    '-resize=+[geometry]:str:' \
                    '-geometry=+[geometry]:str:' \
                    '-tile=+[tile]:str:' \
                    '*:files:_files' ;;
                display|animate) _arguments '*:files:_files' ;;
            esac
            ;;
    esac
}

_graphicsmagick-cli "$@"
