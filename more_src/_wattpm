#compdef wattpm watt platformatic
# _wattpm — Platformatic / Watt application runtime CLI (platformatic/platformatic)
# upstream: https://github.com/platformatic/platformatic
# Subcommands from packages/wattpm/lib/commands/.

_wattpm() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[show more information]' \
        '(-S --socket)'{-S+,--socket=}'[control socket path]:path:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'create:create a new watt application'
                'build:build the watt application'
                'start:start the watt application'
                'dev:start in dev mode'
                'stop:stop a running application'
                'restart:restart a running application'
                'reload:reload application'
                'ps:list running applications'
                'logs:tail or filter application logs'
                'inject:inject a request into the running app'
                'metrics:retrieve runtime metrics'
                'pprof:capture pprof profile'
                'repl:open REPL connected to the runtime'
                'snapshot:take a heap snapshot'
                'admin:administrative commands'
                'applications\:add:add an application to a running runtime'
                'applications\:remove:remove an application'
                'help:show command help'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                applications:add) _arguments '(-s --save)'{-s,--save}'[save additions to config]' '1:id:' '2:path:_files' ;;
                applications:remove) _arguments '(-s --save)'{-s,--save}'[save removals to config]' '1:id:' '*:application:' ;;
            esac
            ;;
    esac
}

_wattpm "$@"
