#compdef devpi
# Documentation: https://devpi.net/docs/devpi/devpi/stable/+doc/userman/devpi_commands.html
# devpi - command line client for the devpi PyPI staging server

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a cmds
    cmds=(
      'use:show or configure the current index and target venv'
      'getjson:show remote server and index configuration as JSON'
      'login:login to a devpi-server with the specified user'
      'logoff:log out of the current devpi-server'
      'list:list project versions and files for the current index'
      'user:add, remove, modify or list user configuration'
      'index:create, delete and manage indexes'
      'push:push a release and release files to another index'
      'install:install packages through the current devpi index'
      'test:download and test a package against tox environments'
      'upload:build and upload packages to the current index'
      'remove:remove project info or files from the current index'
    )
    _describe -t commands 'devpi command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      login)
        _arguments -s '--password=[password to use]:password:' '1:user:' && ret=0
        ;;
      upload)
        _arguments -s \
          '--no-vcs[do not detect version control files]' \
          '--formats=[comma-separated list of formats to build]:formats:' \
          '--with-docs[build and upload documentation]' \
          '--only-docs[only build and upload documentation]' && ret=0
        ;;
      install)
        _arguments -s \
          '(-l --list)'{-l,--list}'[print list of currently installed packages]' \
          '(-e)'{-e}'[install in editable mode]:path:_files' \
          '*:package:' && ret=0
        ;;
      test)
        _arguments -s \
          '--tox-args=[extra arguments to pass to tox]:args:' \
          '*:package:' && ret=0
        ;;
      *)
        _arguments -s '*:arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
