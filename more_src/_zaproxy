#compdef zaproxy zap-cli zap.sh

_zaproxy_commands() {
    local -a commands
    commands=(
        'start:Start ZAP daemon'
        'shutdown:Shutdown ZAP daemon'
        'status:Check ZAP daemon status'
        'open-url:Open a URL in ZAP'
        'spider:Run the spider against a URL'
        'ajax-spider:Run the Ajax spider against a URL'
        'active-scan:Run an active scan against a URL'
        'alerts:Show alerts'
        'quick-scan:Run a quick scan against a URL'
        'session:Manage sessions'
        'context:Manage contexts'
        'scripts:Manage scripts'
        'report:Generate a report'
        'policies:Manage scan policies'
        'exclude:Exclude URL patterns from scans'
    )
    _describe -t commands 'zaproxy command' commands
}

_zaproxy() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --verbose)'{-v,--verbose}'[Enable verbose output]' \
        '--zap-url[ZAP API URL]:url:' \
        '--zap-path[Path to ZAP installation]:path:_directories' \
        '--port[Port to listen on]:port:' \
        '--api-key[ZAP API key]:key:' \
        '--log-path[Path to log file]:file:_files' \
        '1:command:_zaproxy_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                start)
                    _arguments \
                        '--start-options[Extra options for ZAP start]:options:' \
                        '-d[Start as daemon]'
                    ;;
                spider)
                    _arguments \
                        '-r[Recurse into subdomains]' \
                        '--context[Context name]:context:' \
                        '--user[User name]:user:' \
                        '--max-duration[Max duration in minutes]:minutes:' \
                        '1:url:'
                    ;;
                ajax-spider)
                    _arguments \
                        '--context[Context name]:context:' \
                        '--user[User name]:user:' \
                        '--subtree-only[Only spider subtree]' \
                        '1:url:'
                    ;;
                active-scan)
                    _arguments \
                        '-r[Recursive scan]' \
                        '--scanners[Scanner IDs to use]:scanners:' \
                        '--policy[Scan policy name]:policy:' \
                        '--context[Context name]:context:' \
                        '--user[User name]:user:' \
                        '1:url:'
                    ;;
                quick-scan)
                    _arguments \
                        '-s[Run spider before scan]' \
                        '-a[Run Ajax spider before scan]' \
                        '-r[Recursive scan]' \
                        '--scanners[Scanner IDs to use]:scanners:' \
                        '--policy[Scan policy name]:policy:' \
                        '--context[Context name]:context:' \
                        '1:url:'
                    ;;
                alerts)
                    _arguments \
                        '-l[Minimum alert level]:level:(Informational Low Medium High)' \
                        '--output[Output format]:format:(json xml html)' \
                        '--alert-url[Filter by URL]:url:'
                    ;;
                report)
                    _arguments \
                        '-o[Output file]:file:_files' \
                        '-f[Report format]:format:(html xml md json)' \
                        '--title[Report title]:title:' \
                        '--template[Report template]:template:'
                    ;;
                session)
                    _arguments \
                        '1:action:(new load save)' \
                        '2:file:_files'
                    ;;
                context)
                    _arguments \
                        '1:action:(list include exclude export import)' \
                        '--name[Context name]:name:' \
                        '--regex[URL regex pattern]:regex:'
                    ;;
                policies)
                    _arguments \
                        '1:action:(list)' \
                        '--policy[Policy name]:name:'
                    ;;
            esac
            ;;
    esac
}

_zaproxy "$@"
