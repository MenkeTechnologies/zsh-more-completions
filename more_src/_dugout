(( $+functions[_dugout_commands] )) ||
_dugout_commands() {
    local commands; commands=(
'setup:Generate global identity at ~/.dugout/identity' \
'whoami:Print your public key' \
'init:Initialize dugout in the current directory' \
'add:Add a secret interactively with hidden input' \
'set:Set a secret value' \
'get:Get a secret value' \
'rm:Remove a secret' \
'list:List all secret keys' \
'knock:Request access to a vault' \
'pending:List pending access requests' \
'admit:Approve an access request' \
'sync:Re-encrypt secrets for the current recipient set' \
'.:Auto-detect project and run with secrets' \
'run:Run a command with secrets injected as env vars' \
'env:Spawn a shell with secrets loaded as environment variables' \
'team:Manage team members' \
'secrets:Secret lifecycle operations (lock, unlock, import, export, diff, rotate)' \
'check:Run diagnostic checks (status, audit)' \
'vault:Vault management commands' \
'completions:Generate shell completions' \
'migrate-keychain:Migrate file-based identities to macOS Keychain (macOS only)' \
'reset-keychain:Remove identities from macOS Keychain (macOS only)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
