#compdef sueipofi
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/multicomponent/sueipofi.c
# eigenimage (SVD) based polarization filter for 3C data

local ret=1

_arguments -s -S \
  'dt=[time sampling interval in seconds]:dt' \
  'wl=[SVD time window length in seconds]:wl' \
  'pwr=[exponent of filter weights]:pwr' \
  'interp=[interpolation between weights]:interp:(cubic linear)' \
  'verbose=[1 = echo additional information]:verbose' \
  'file=[base name for filter weights output files]:file:_files' \
  'rl1=[1 = rectilinearity along first principal axis]:rl1' \
  'rl2=[1 = rectilinearity along second principal axis]:rl2' \
  'pln=[1 = planarity]:pln' \
  '*:file:_files' && ret=0


return ret
