#compdef pgstream

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--log-level=[Logger level]:level:(debug info warn error)' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'run:Start pgstream agent with config file'
      'init:Initialize database schemas for streaming'
      'validate-config:Check configuration syntax'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
