#compdef raxml-ng-mpi
# RAxML-NG (MPI build): next-generation ML phylogenetic inference
# Same options as raxml-ng; delegate to its completion.

local curcontext="$curcontext" ret=1
if (( $+functions[_raxml-ng] )); then
  _raxml-ng "$@" && ret=0
else
  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '--all[combined ML + bootstrap analysis]' \
    '--search[ML tree search only]' \
    '--evaluate[evaluate tree given alignment+model]' \
    '--bootstrap[bootstrap analysis only]' \
    '--check[validate alignment, no analysis]' \
    '--parse[parse alignment, write binary, no analysis]' \
    '--threads[total threads]:n:' \
    '--seed[random seed]:n:' \
    '--prefix[output prefix]:prefix:' \
    '--msa[MSA file]:file:_files' \
    '--model[evolutionary model spec or model file]:model:' \
    '--redo[overwrite previous output files]' \
    '*:alignment file:_files' && ret=0
fi
return ret
