#compdef windmill

_windmill_commands() {
    local -a commands
    commands=(
        'workspace:Manage workspaces'
        'script:Manage scripts'
        'flow:Manage flows'
        'app:Manage apps'
        'variable:Manage variables'
        'resource:Manage resources'
        'schedule:Manage schedules'
        'user:Manage users'
        'folder:Manage folders'
        'group:Manage groups'
        'hub:Interact with Windmill Hub'
        'sync:Sync local files with remote workspace'
        'dev:Run in development mode'
        'completion:Generate shell completion'
    )
    _describe -t commands 'windmill command' commands
}

_windmill() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-V --version)'{-V,--version}'[Show version]' \
        '--workspace[Workspace ID]:workspace:' \
        '--base-url[Base URL of Windmill instance]:url:' \
        '--token[Authentication token]:token:' \
        '1:command:_windmill_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                workspace)
                    _arguments \
                        '1:action:(add switch list whoami)' \
                        '--name[Workspace name]:name:' \
                        '--id[Workspace ID]:id:'
                    ;;
                script)
                    _arguments \
                        '1:action:(push create show update archive delete run list)' \
                        '--path[Script path]:path:' \
                        '--language[Script language]:language:(python3 deno go bash powershell nativets bun postgresql mysql bigquery snowflake mssql graphql)' \
                        '--summary[Script summary]:summary:' \
                        '--description[Script description]:description:'
                    ;;
                flow)
                    _arguments \
                        '1:action:(push create show update archive delete run list)' \
                        '--path[Flow path]:path:' \
                        '--summary[Flow summary]:summary:'
                    ;;
                variable)
                    _arguments \
                        '1:action:(push create update delete list get)' \
                        '--path[Variable path]:path:' \
                        '--value[Variable value]:value:' \
                        '--secret[Mark as secret]'
                    ;;
                resource)
                    _arguments \
                        '1:action:(push create update delete list get type)' \
                        '--path[Resource path]:path:' \
                        '--resource-type[Resource type]:type:'
                    ;;
                schedule)
                    _arguments \
                        '1:action:(push create update delete list enable disable)' \
                        '--path[Schedule path]:path:' \
                        '--schedule[Cron schedule]:cron:'
                    ;;
                sync)
                    _arguments \
                        '1:action:(push pull)' \
                        '--skip-variables[Skip variables]' \
                        '--skip-resources[Skip resources]' \
                        '--skip-secrets[Skip secrets]' \
                        '--include-schedules[Include schedules]' \
                        '--yes[Skip confirmation]' \
                        '--raw[Raw mode]'
                    ;;
                user)
                    _arguments \
                        '1:action:(create update delete list)' \
                        '--email[User email]:email:' \
                        '--role[User role]:role:(admin operator developer)'
                    ;;
                hub)
                    _arguments \
                        '1:action:(pull search)' \
                        '--kind[Resource kind]:kind:(script flow app)' \
                        '--query[Search query]:query:'
                    ;;
                completion)
                    _arguments '1:shell:(bash zsh fish powershell)'
                    ;;
            esac
            ;;
    esac
}

_windmill "$@"
