#compdef wmill windmill
# Documentation: https://github.com/windmill-labs/windmill/blob/main/cli/README.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_wmill_commands() {
    local -a commands
    commands=(
        'workspace:manage workspaces'
        'script:manage scripts'
        'flow:manage flows'
        'app:manage apps'
        'variable:manage variables'
        'resource:manage resources'
        'resource-type:manage resource types'
        'schedule:manage schedules'
        'user:manage users'
        'folder:manage folders'
        'group:manage groups'
        'hub:interact with Windmill Hub'
        'sync:sync local files with remote workspace'
        'pull:retrieve entire workspace'
        'push:deploy workspace contents'
        'init:initialize project'
        'upgrade:update to latest version'
        'completions:generate shell completions'
        'dev:run in development mode'
        'instance:manage instance settings'
    )
    _describe -t commands 'wmill command' commands
}

_wmill() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--workspace[workspace ID]:workspace:' \
        '--base-url[base URL of Windmill instance]:url:' \
        '--token[authentication token]:token:' \
        '1:command:_wmill_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                workspace)
                    _arguments \
                        '1:action:(add switch remove list whoami)' \
                        '--name[workspace name]:name:' \
                        '--id[workspace ID]:id:'
                    ;;
                script|flow|app)
                    _arguments \
                        '1:action:(push list run show generate-metadata bootstrap)' \
                        '--data[input data]:data:'
                    ;;
                variable|resource|schedule|folder|group|resource-type)
                    _arguments \
                        '1:action:(push list)'
                    ;;
                sync)
                    _arguments \
                        '1:action:(push pull)' \
                        '--yes[skip confirmation]' \
                        '--skip-variables[skip variables]' \
                        '--skip-resources[skip resources]' \
                        '--skip-secrets[skip secrets]' \
                        '--include-schedules[include schedules]' \
                        '--include-users[include users]' \
                        '--include-groups[include groups]' \
                        '--include-key[include encryption key]' \
                        '--raw[raw mode]' \
                        '--json-output[json output]' \
                        '--plain-secrets[plain text secrets]'
                    ;;
                user)
                    _arguments \
                        '1:action:(add remove list)' \
                        '--email[user email]:email:' \
                        '--role[user role]:role:(admin operator developer)'
                    ;;
                hub)
                    _arguments \
                        '1:action:(pull)'
                    ;;
                completions)
                    _arguments '1:shell:(bash zsh fish powershell)'
                    ;;
                init)
                    _arguments \
                        '--use-default[use defaults]'
                    ;;
            esac
            ;;
    esac
}

_wmill "$@"
