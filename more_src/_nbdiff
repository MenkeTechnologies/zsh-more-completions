#compdef nbdiff

# nbdiff: textual diff between two Jupyter notebooks
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-s[ignore source]' \
  '--sources[show only source diff]' \
  '-o[show only outputs]' \
  '--outputs[show only outputs]' \
  '-a[show only attachments]' \
  '--attachments[show only attachments]' \
  '-m[show metadata diff]' \
  '--metadata[show metadata diff]' \
  '--details[show all details]' \
  '--color-words[colorize word diff]' \
  '--no-color[no color]' \
  '--out=[output file]:file:_files' \
  '*:notebook:_files -g "*.ipynb"' && ret=0
return ret
