#compdef nbdiff
# Documentation: https://nbdime.readthedocs.io/en/latest/cli.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nbdiff: textual diff between two Jupyter notebooks
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-s --sources)'{-s,--sources}'[process source cells]' \
  '(-o --outputs)'{-o,--outputs}'[process output cells]' \
  '(-a --attachments)'{-a,--attachments}'[process attachments]' \
  '(-m --metadata)'{-m,--metadata}'[process metadata]' \
  '(-d --details)'{-d,--details}'[process details]' \
  '(-S --ignore-sources)'{-S,--ignore-sources}'[ignore source cells]' \
  '(-O --ignore-outputs)'{-O,--ignore-outputs}'[ignore output cells]' \
  '(-A --ignore-attachments)'{-A,--ignore-attachments}'[ignore attachments]' \
  '(-M --ignore-metadata)'{-M,--ignore-metadata}'[ignore metadata]' \
  '(-D --ignore-details)'{-D,--ignore-details}'[ignore details]' \
  '--color-words[colorize word diff]' \
  '--no-color[disable color output]' \
  '--out=[output file]:file:_files' \
  '*:notebook:_files -g "*.ipynb"' && ret=0
return ret
