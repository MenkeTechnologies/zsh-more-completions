#compdef giget

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d+[output directory]:directory:_directories' \
  '--dir=[output directory]:directory:_directories' \
  '-f[force clone even if directory exists]' \
  '--force[force clone even if directory exists]' \
  '--force-clean[clean target directory before cloning]' \
  '--offline[use cached version if available]' \
  '--prefer-offline[prefer cached version]' \
  '-s[silence output]' \
  '--silent[silence output]' \
  '--verbose[verbose output]' \
  '--auth=[auth token]:token' \
  '--cwd=[working directory]:directory:_directories' \
  '--install[install dependencies after clone]' \
  '--no-install[skip dependency installation]' \
  '--registry=[custom registry URL]:url' \
  '1:template (provider\:user/repo)' && ret=0

return ret
