#compdef csvprintf
# Documentation: https://github.com/archiecobbs/csvprintf
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# printf-like formatter for CSV records (archiecobbs/csvprintf).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-i+[format string]:format' \
  '-X[output as XML]' \
  '*:CSV file:_files -g "*.{csv,tsv,txt}"'
