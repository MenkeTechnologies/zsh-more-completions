#compdef gst gst-package gst-load gst-tool gst-blox gst-browser gst-doc gst-convert gst-reload gst-remote gst-sunit smalltalk
# Documentation: https://man.archlinux.org/search?q=gst
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --core-dir)'{-c,--core-dir}'+[core image directory]:dir:_files -/' \
  '(-D --declare-tracing)'{-D,--declare-tracing}'[trace declared methods]' \
  '(-E --execute-tracing)'{-E,--execute-tracing}'[trace executed methods]' \
  '(-V --execute-verbose)'{-V,--execute-verbose}'[verbose execution]' \
  '(-Q --quiet)'{-Q,--quiet}'[quiet]' \
  '(-I --image-file)'{-I,--image-file}'+[image file]:file:_files' \
  '(-K --kernel-file)'{-K,--kernel-file}'+[kernel file]:file:_files -g "*.st"' \
  '(-L --load-line)'{-L,--load-line}'+[load file line]:line:' \
  '(-r --regression-test)'{-r,--regression-test}'+[regression test file]:file:_files -g "*.st"' \
  '(-S --snapshot)'{-S,--snapshot}'[take snapshot on exit]' \
  '(-y --yacc-debugging)'{-y,--yacc-debugging}'[enable parser debugging]' \
  '(-a --smalltalk)'{-a,--smalltalk}'[evaluate Smalltalk args]' \
  '(-f --file)'{-f,--file}'+[file to evaluate]:file:_files -g "*.st"' \
  '(-e --eval)'{-e,--eval}'+[evaluate expression]:expr:' \
  '(--rebuild-image)--rebuild-image[rebuild image]' \
  '(--maybe-rebuild-image)--maybe-rebuild-image[rebuild image if needed]' \
  '(--no-init-file)--no-init-file[skip init file]' \
  '*:file:_files -g "*.st"' && ret=0

return ret
