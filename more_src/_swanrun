#compdef swanrun
# Documentation: https://swanmodel.sourceforge.io/online_doc/swanimp/node20.html
# SWAN wave model run script (Linux/UNIX).

local ret=1

_arguments -s -S \
  '-input[command file name without .swn extension]:filename:_files -g "*.swn"' \
  '-omp[parallel run on n cores via OpenMP]:n:' \
  '-mpi[parallel run on n processors via MPI]:n:' && ret=0

return ret
