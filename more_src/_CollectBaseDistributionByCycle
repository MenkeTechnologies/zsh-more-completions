#compdef CollectBaseDistributionByCycle
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectBaseDistributionByCycle
# Picard: chart the nucleotide distribution per cycle in a SAM/BAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM or BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output metrics file]:file:_files' \
  '--CHART_OUTPUT=[PDF file to write the chart to]:pdf:_files -g "*.pdf"' \
  '--ALIGNED_READS_ONLY=[calculate base distribution over aligned reads only]:bool:(true false)' \
  '--PF_READS_ONLY=[calculate base distribution over PF reads only]:bool:(true false)' \
  '--ASSUME_SORTED=[assume input is coordinate sorted]:bool:(true false)' \
  '--STOP_AFTER=[stop after processing N reads]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
