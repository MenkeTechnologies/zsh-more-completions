#compdef rstcheck rstcheck-core
# Documentation: https://rstcheck.readthedocs.io/en/latest/usage/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config=[config file or directory]:file:_files' \
  '--warn-unknown-settings[warn on unknown config settings]' \
  '(-r --recursive)'{-r,--recursive}'[recursively search directories]' \
  '--report-level=[min report severity]:level:(info warning error severe none INFO WARNING ERROR SEVERE NONE)' \
  '--log-level=[application logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--ignore-directives=[ignore directives (comma-separated)]:list:' \
  '--ignore-roles=[ignore roles (comma-separated)]:list:' \
  '--ignore-substitutions=[ignore substitutions (comma-separated)]:list:' \
  '--ignore-languages=[ignore code-block languages (comma-separated)]:list:' \
  '--ignore-messages=[regex of linting messages to ignore]:re:' \
  '--install-completion[install shell completion]' \
  '--show-completion[print shell completion]' \
  '*: :_files -g "*.rst *.txt"' && ret=0

return ret
