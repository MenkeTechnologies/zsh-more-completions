#compdef rstcheck rstcheck-core

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config+[config file]:file:_files' \
  '--warn-unknown-settings[warn unknown settings]' \
  '--report-level+[min severity]:l:(info warning error severe none 1 2 3 4 5)' \
  '--ignore-language+[ignored languages csv]:list:' \
  '--ignore-languages+[ignored languages csv]:list:' \
  '--ignore-messages+[ignore regex]:re:' \
  '--ignore-directives+[ignore directives csv]:list:' \
  '--ignore-roles+[ignore roles csv]:list:' \
  '--ignore-substitutions+[ignore substitutions csv]:list:' \
  '--report+[report level]:l:' \
  '--recursive[recursive]' \
  '-r[recursive]' \
  '*: :_files -g "*.rst *.txt"' && ret=0

return ret
