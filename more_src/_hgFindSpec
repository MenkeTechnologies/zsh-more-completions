#compdef hgFindSpec
# UCSC kent: create hgFindSpec table from trackDb.ra files

local ret=1

_arguments -s -S \
  '-strict[add spec only if its table(s) exist]' \
  '-raName=[alternate filename for .ra files]:name' \
  '-release=[include trackDb entries with this release tag only]:tag:(alpha beta public)' \
  '1:org dir:_files -/' \
  '2:database:' \
  '3:hgFindSpec table:' \
  '4:hgFindSpec.sql:_files -g "*.sql"' \
  '5:hgRoot:_files -/' && ret=0

return ret
