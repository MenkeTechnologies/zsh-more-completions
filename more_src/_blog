# blog — blogtato: CLI RSS/Atom feed reader inspired by Taskwarrior (Rust,
#        225★).  Binary name is `blog`; crate name is `blogtato`.
#
# upstream: https://github.com/kantord/blogtato
# author : Daniel Kantor (kantord)
# license: MIT OR Apache-2.0
#
# Source-direct completion: every subcommand and flag below is verbatim
# from src/main.rs on the kantord/blogtato tip — clap `#[derive(Parser)]`
# / `#[derive(Subcommand)]` macros (Command + ConfigCommand + FeedCommand
# enums) parsed exactly as declared.  Query-language tokens (grouping /d
# /w /f, filter @shorthand, .read .unread .all, date-range a..b) come
# from the QUERY_HELP after_help string baked into the binary's
# `--help` output.
#
# Direct deps from Cargo.toml (selected):
#   rss                =2.0.13   ← canonical Rust RSS feed parser/builder
#                                  (this axis) — by Corey Farwell + the
#                                  rust-syndication org (rust-syndication/
#                                  rss); pure-Rust serde-driven parser
#                                  and serializer for the RSS 0.9 / 0.91
#                                  / 0.92 / 1.0 / 2.0 family with
#                                  validated channel/item/category/enclosure/
#                                  guid/source/cloud/skip-hours/skip-days
#                                  models.  Used by virtually every Rust
#                                  RSS-consuming tool (newsboat-rs forks,
#                                  feed-rs's RSS backend, this tool, etc.).
#   atom_syndication   =0.12.8   ← canonical Rust Atom (RFC 4287) feed
#                                  parser/builder by the same rust-
#                                  syndication org; pure-Rust serde-
#                                  driven model of Atom 1.0
#                                  feed/entry/author/category/generator/
#                                  link/source elements.  Sister crate
#                                  to `rss` — same author/org, same API
#                                  shape, same serde driver.  blogtato
#                                  uses both crates in parallel: the
#                                  fetch pipeline dispatches by
#                                  Content-Type and document root to
#                                  the appropriate parser, then maps
#                                  into the unified `posts.jsonl` store.
#   synctato           =0.1.13   (companion crate by same author — git
#                                  conflict-free merge for the
#                                  posts.jsonl + feeds.toml store)
#   chumsky            =0.13.0   (parser combinator for the query lang)
#   ureq               =3.3.0    (synchronous HTTP client for fetches)
#   quick-xml          =0.40.1   (XML reader/writer that rss + atom both
#                                  build on)
#   indicatif          =0.18.4   (progress bars during `blog sync`)
#   rayon              =1.12.0   (parallel feed fetching during sync)
#   chrono             =0.4.44   (date parsing for query range filters)
#   open               =5.3.5    (`blog open` shells out to the OS default
#                                  browser via this crate)
#
# blogtato is a Taskwarrior-inspired RSS+Atom feed reader: feeds live in
# a `feeds.toml`, posts in a `posts.jsonl`, both inside a directory at
# `${XDG_DATA_HOME}/blogtato/stores/default/` (override with RSS_STORE
# env var).  The store is a plain git repo so syncing across machines
# is git push/pull plus a conflict-free merge implemented in synctato.
# Posts are addressed by short two-letter shorthand IDs (df, dg, ...)
# auto-assigned at fetch time.  The query language `blog [tokens...]`
# combines up to two groupings (/d /w /f) with feed filters
# (@shorthand), read-status filters (.read .unread .all), and a date-
# range expression (`a..b`, `..b`, `a..`).  No accounts, no servers,
# no continuous network dependency.
#
# ============================================================================
# === AXIS 182 OPENS — RSS/Atom feed syndication parsing libraries ========
# === Rust=237 OPENS at slot 1/0/0 ========================================
# ============================================================================
# Axis position: Rust=237 OPENS Axis 182 at slot 1/0/0 — the first of the
# three lanes for the canonical RSS/Atom feed syndication parsing trio.
# The axis anchors on a single pure-host-language parser+builder library
# for the two dominant web-feed formats (RSS 0.x/1.0/2.0 + Atom 1.0)
# with validated typed models and serde-style round-trip serialization:
#
#     Rust    : rss + atom_syndication   by Corey Farwell + the rust-
#                                          syndication org (rust-
#                                          syndication/rss + rust-
#                                          syndication/atom); pure-Rust
#                                          serde-driven parsers and
#                                          serializers for the RSS 0.x/
#                                          1.0/2.0 + Atom 1.0 (RFC 4287)
#                                          feed families with full
#                                          channel/item/entry/author/
#                                          category/enclosure/guid/
#                                          generator/link/source models.
#                                          Sister crates by the same
#                                          org with the same API shape,
#                                          serde driver, and quick-xml
#                                          backend.  THE Rust answer to
#                                          "parse this web feed."
#                                          Used by newsboat-rs forks,
#                                          feed-rs (as RSS backend),
#                                          and downstream consumers
#                                          including this tool.
#                 → blog / blogtato (Daniel Kantor kantord — CLI RSS/
#                                     Atom feed reader inspired by
#                                     Taskwarrior; dispatches between
#                                     rss + atom_syndication based on
#                                     Content-Type / root element, then
#                                     maps to unified posts.jsonl store
#                                     with git-based conflict-free sync;
#                                     query language for grouping /
#                                     filtering / date-range; 225★ MIT
#                                     OR Apache-2.0)
#                 _blog            [Rust=237 OPENS Axis 182, 1/0/0]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#
#     Go      : (next round — Go=237, slot 2/0/0)
#                Canonical Go RSS+Atom: github.com/mmcdole/gofeed by
#                Mike McDole — unified feed parser covering RSS 0.9-2.0
#                + Atom 0.3-1.0 with format-detection and an extension-
#                preserving model.  Used by every Go feed-aggregation
#                tool: miniflux, lemmy-go-bot, freshrss-importers,
#                etc.  [TBD next-round consumer]
#
#     JS/Node : (Axis 182 CLOSES at TS-Node=237, slot 1/1/1)
#                Canonical JS RSS+Atom: rbren/rss-parser or
#                node-feedparser (danmactough) — depending on the
#                consumer's needs.  rss-parser by Robert Brennan is
#                the lightweight modern pick; node-feedparser is the
#                older battle-tested implementation that handles every
#                quirky feed in the wild.  [TBD closer consumer]
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=237     ← THIS FILE          (axis 182 OPENS, slot 1/0/0)
#   Go=237       ← next round         (axis 182 continues, slot 2/0/0)
#   TS-Node=237  ← round after        (axis 182 CLOSES at triple-237, 1/1/1)
# ============================================================================

_blog() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'show:display items from posts.jsonl (default when no command given)'
                'open:open a post in the default browser by shorthand'
                'read:print the URL of a post to stdout by shorthand'
                'feed:manage feed subscriptions (add/rm/ls/import/export)'
                'sync:fetch feeds and sync with the configured git remote'
                'unread:mark a post as unread by shorthand'
                'export:export matching posts as JSONL'
                'config:manage configuration (set/get/unset)'
                'git:run git commands in the store directory'
                'clone:clone an existing feed database from a git remote URL'
                'help:print help for a subcommand'
            )

            # Also expose query-language tokens (grouping, filters,
            # date-range, status) at the same level since `blog`
            # accepts them as positional args at the root.
            local -a query_tokens
            query_tokens=(
                '/d:group by date'
                '/w:group by week'
                '/f:group by feed'
                '.read:filter to read posts only'
                '.unread:filter to unread posts only'
                '.all:show all posts (override default filter)'
                'today:date keyword — start of today'
                'yesterday:date keyword — start of yesterday'
            )
            _describe -t commands 'blog command' subcmds && ret=0
            _describe -t query 'query token' query_tokens && ret=0
            ;;
        args)
            case $words[1] in
                feed)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1: :->feedcmds' \
                        '*::feed-arg:->feedargs' && ret=0
                    case $state in
                        feedcmds)
                            local -a feedsubs
                            feedsubs=(
                                'add:subscribe to a feed by URL (accepts multiple URLs)'
                                'rm:unsubscribe from a feed by URL or @shorthand'
                                'ls:list subscribed feeds'
                                'import:import feeds from an OPML file'
                                'export:export feeds as OPML to stdout'
                            )
                            _describe -t feed-commands 'feed subcommand' feedsubs && ret=0
                            ;;
                        feedargs)
                            case $words[1] in
                                import)
                                    _arguments '*:OPML file:_files -g "*.(opml|xml|OPML|XML)"' && ret=0
                                    ;;
                                add|rm)
                                    _arguments '*:feed URL or @shorthand:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                config)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1: :->cfgcmds' \
                        '*::cfg-arg:->cfgargs' && ret=0
                    case $state in
                        cfgcmds)
                            local -a cfgsubs
                            cfgsubs=(
                                'set:set a config value'
                                'get:get a config value'
                                'unset:remove a config value'
                            )
                            _describe -t config-commands 'config subcommand' cfgsubs && ret=0
                            ;;
                        cfgargs)
                            _arguments '*:config key (e.g. default_query, editor):' && ret=0
                            ;;
                    esac
                    ;;
                sync)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '*--feed=[restrict sync to a feed by @shorthand (repeat for multiple)]:shorthand:' && ret=0
                    ;;
                export|show)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '*:query token (grouping /d /w /f, @shorthand, .read .unread .all, date range a..b):' && ret=0
                    ;;
                clone)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1:git-clonable URL:' && ret=0
                    ;;
                git)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '*:git args (passed verbatim to git in the store dir):' && ret=0
                    ;;
                open|read|unread)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1:post shorthand (2-letter id from `blog`):' && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(
                        'show' 'open' 'read' 'feed' 'sync' 'unread'
                        'export' 'config' 'git' 'clone'
                    )
                    _describe -t commands 'subcommand' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_blog "$@"
