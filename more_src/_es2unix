#compdef es2unix es

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'version:show es and Elasticsearch versions'
  'health:show cluster health status'
  'count:show document count (with optional query)'
  'search:search documents across indices'
  'master:show cluster master node'
  'indices:list indices with status and stats'
  'allocation:show shard allocation counts per node'
  'nodes:show node details (ports, roles)'
  'lifecycle:replay node join/leave events from logs'
  'heap:show cluster heap usage'
  'ids:show document IDs from an index'
  'shards:show shard allocation and state'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-u+[Elasticsearch URL]:url:' \
  '-v[print column headers]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'es subcommand' commands && ret=0 ;;
  (args)
    case $line[1] in
      (count|search|ids|indices|shards)
        _arguments \
          '*::index:' && ret=0 ;;
      (lifecycle)
        _arguments \
          '*::logfile:_files' && ret=0 ;;
    esac ;;
esac

return ret
