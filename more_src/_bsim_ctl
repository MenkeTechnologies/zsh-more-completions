#compdef bsim_ctl
# _bsim_ctl — start/stop/manage the BSim postgres database (NationalSecurityAgency/ghidra)
# upstream: https://github.com/NationalSecurityAgency/ghidra
# Subcommands from BSimControlLaunchable.java.

_bsim_ctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start the BSim postgres database'
                stop:'stop the BSim postgres database'
                status:'show database status'
                resetpassword:'reset a user password'
                changeprivilege:'change user privileges'
                adduser:'add a user to the database'
                dropuser:'remove a user from the database'
                changeauth:'change the authentication method'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                changeauth) _arguments '1:auth type:(pki password trust none)' ;;
                adduser|dropuser|resetpassword|changeprivilege) _arguments '1:user:_users' ;;
            esac
            ;;
    esac
}

_bsim_ctl "$@"
