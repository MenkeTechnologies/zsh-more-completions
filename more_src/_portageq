#compdef portageq
# Documentation: https://wiki.gentoo.org/wiki/Portageq
# Gentoo Portage query tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'best_version:return highest visible match for a package atom'
      'colormap:display color map'
      'config_protect_mask:return CONFIG_PROTECT_MASK'
      'contents:list files installed by a package'
      'distdir:return DISTDIR'
      'envvar:return an environment variable value'
      'envvar2:return environment variable for a specific EROOT'
      'expand_virtual:list packages that provide a virtual'
      'get_repo_path:return path of repository'
      'get_repos:return list of repositories'
      'gentoo_mirrors:return GENTOO_MIRRORS'
      'has_version:check if package version is installed'
      'is_protected:check if a file is config-protected'
      'list_preserved_libs:list preserved libraries'
      'mass_best_version:return best versions of multiple atoms'
      'mass_has_version:check if multiple packages are installed'
      'match:return list of matching packages'
      'metadata:return metadata for a package'
      'owners:list packages owning specified files'
      'pkgdir:return PKGDIR'
      'portdir:return PORTDIR'
      'portdir_overlay:return PORTDIR_OVERLAY'
      'pquery:advanced package query'
      'vdb_path:return VDB path'
    )
    _describe -t commands 'portageq command' commands && ret=0
    ;;
  args)
    case $line[1] in
      best_version|has_version|mass_best_version|mass_has_version|match|metadata)
        _arguments ':eroot:_files -/' ':atom:' && ret=0
        ;;
      contents|owners)
        _arguments ':eroot:_files -/' '*:file:_files' && ret=0
        ;;
      envvar|envvar2)
        _arguments ':variable:' && ret=0
        ;;
      get_repo_path|get_repos)
        _arguments ':eroot:_files -/' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
