#compdef timestamp-cli timestamp-server
# Documentation: upstream README at github.com/sigstore/timestamp-authority
# Reference accessed: 2026-05-30
# Sigstore timestamp-authority R49 — RFC 3161 timestamp service.
# Sister-binaries to existing _cosign/_rekor-cli/_rekor/_gitsign/
# _policy-tester (R48) Sigstore-family coverage.

local curcontext="$curcontext" state line ret=1

case $service in

  timestamp-cli)
    # sigstore/timestamp-authority timestamp-cli — client for interacting
    # with the RFC 3161 timestamp service.
    local -a _subcmds
    _subcmds=(
      'timestamp:request a timestamp'
      'verify:validate a timestamp'
      'inspect:examine timestamp details'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'timestamp-cli subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          timestamp)
            _arguments \
              '--timestamp_server=[timestamp server URL]:url:' \
              '--hash=[hash algorithm]:algorithm:(sha256 sha384 sha512)' \
              '--artifact=[file to timestamp]:file:_files' \
              '--out=[output file]:file:_files' && ret=0
            ;;
          verify)
            _arguments \
              '--certificate-chain=[verification cert chain file]:file:_files' \
              '--artifact=[original artifact file]:file:_files' \
              '--timestamp=[timestamp file]:file:_files' && ret=0
            ;;
          inspect)
            _arguments \
              '--timestamp=[timestamp file]:file:_files' \
              '--format=[output format]:format:(json)' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  timestamp-server)
    # sigstore/timestamp-authority timestamp-server — RFC 3161 timestamp
    # service. Issues cryptographically signed timestamps via KMS/Tink/file
    # signing backends.
    local -a _subcmds
    _subcmds=(
      'serve:launch the timestamp authority service'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'timestamp-server subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          serve)
            _arguments \
              '--port=[server port (e.g. 3000)]:port:' \
              '--timestamp-signer=[signing mechanism]:signer:(kms tink file)' \
              '--certificate-chain-path=[certificate chain file]:file:_files' \
              '--kms-key-resource=[KMS key URI (gcpkms://, azurekms://, awskms://, hashivault://)]:uri:' \
              '--tink-key-resource=[Tink signing-key path]:file:_files' \
              '--tink-keyset-path=[encrypted Tink keyset path]:file:_files' \
              '--tink-hcvault-token=[Vault authentication token]:token:' \
              '--enforce-intermediate-eku[validate intermediate cert EKU (default true)]' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
