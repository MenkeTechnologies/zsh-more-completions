_mxs() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '--profile=[active profile name]:profile:' \
    '--dry-run[dry-run mode (do not apply changes)]' \
    '--output=[output mode]:mode:(json yaml table text)' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'auth:authentication management'
        'category:manage post categories'
        'comment:manage comments'
        'config:get/set instance configuration keys'
        'note:manage notes (short-form public diary entries)'
        'page:manage standalone pages'
        'post:manage blog posts'
        'preview:preview rendered content before publishing'
        'profile:manage CLI profiles'
        'skill:manage author skills'
        'topic:manage post topics'
        'update:self-update the mxs CLI binary'
      )
      _describe -t subcommands 'mxs subcommand' subcmds
      ;;
    args)
      _arguments -s -S \
        '(-h --help)'{-h,--help}'[show subcommand help]'
      ;;
  esac
}

_mxs "$@"
