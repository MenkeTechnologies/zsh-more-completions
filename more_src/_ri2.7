#compdef ri2.7
# Documentation: https://www.mankier.com/1/ri
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. ri(1) Ruby RDoc reference
# manpage; the versioned binary `ri2.7` ships the same flag set as `ri`.

# ri2.7: Ruby 2.7 RDoc reference viewer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-i --interactive --no-interactive)'{-i,--interactive,--no-interactive}'[interactive mode]' \
  '(-a --all --no-all)'{-a,--all,--no-all}'[show all documentation]' \
  '(-l --list --no-list)'{-l,--list,--no-list}'[list classes ri knows about]' \
  '(-T --no-pager --pager)'{-T,--no-pager,--pager}'[disable/enable pager]' \
  '(-w --width)'{-w+,--width=}'[output width]:n:' \
  '(-f --format)'{-f+,--format=}'[formatter]:fmt:(ansi bs markdown rdoc)' \
  '(-d --doc-dir)'{-d+,--doc-dir=}'[doc directory]:dir:_files -/' \
  '--no-standard-docs[skip standard Ruby docs]' \
  '(--system --no-system)'{--system,--no-system}'[system docs]' \
  '(--site --no-site)'{--site,--no-site}'[site docs]' \
  '(--gems --no-gems)'{--gems,--no-gems}'[gem docs]' \
  '(--home --no-home)'{--home,--no-home}'[home docs]' \
  '(--list-doc-dirs --no-list-doc-dirs)'{--list-doc-dirs,--no-list-doc-dirs}'[list doc dirs]' \
  '--server=[run RDoc server (default port 8214)]:port:' \
  '(--profile --no-profile)'{--profile,--no-profile}'[profile]' \
  '--dump=[dump cache/data file]:cache:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:name:' && ret=0
return ret
