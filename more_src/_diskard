(( $+functions[_diskard_commands] )) ||
_diskard_commands() {
    local commands; commands=(
'scan:Scan for reclaimable disk space' \
'clean:Delete selected findings' \
'list:List available targets or configuration' \
'config:Manage configuration' \
'interactive:Interactive TUI mode — scan, select, and clean' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'diskard commands' commands "$@"
}
