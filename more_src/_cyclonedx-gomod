#compdef cyclonedx-gomod
# Documentation: https://github.com/CycloneDX/cyclonedx-gomod
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# CycloneDX SBOM generator for Go modules.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'app:generate SBOM for an application'
  'mod:generate SBOM for a module'
  'bin:generate rudimentary SBOM from a Go binary'
  'version:show version'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cyclonedx-gomod command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (app|mod|bin)
        _arguments \
          '-json[output as JSON instead of XML]' \
          '-output=[output file or STDOUT]:file:_files' \
          '-output-version=[CycloneDX spec version]:v:(1.0 1.1 1.2 1.3 1.4 1.5 1.6)' \
          '-licenses[enable license detection]' \
          '-assert-licenses[assert detected licenses directly]' \
          '-noserial[omit serial number]' \
          '-notimestamp[omit timestamp]' \
          '-verbose[verbose output]' \
          '-short-purls[remove PackageURL qualifiers]' \
          '-std[include Go standard library]' \
          '-packages[include packages (app)]' \
          '-files[include files (app)]' \
          '-main=[main package (app)]:dir:_files -/' \
          '-test[include test dependencies (mod)]' \
          '-type=[component type (mod)]:type:(application library framework container)' \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
