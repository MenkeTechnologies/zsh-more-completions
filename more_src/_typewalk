#compdef typewalk
# Documentation: https://dragons.readthedocs.io/projects/recipe-system-users-manual/en/stable/supptools.html
# DRAGONS: walk a directory tree and report AstroData tag classifications

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --dir)'{-d,--dir}'[walk this directory and report types]:dir:_files -/' \
  '(-f --filemask)'{-f,--filemask}'[show files matching regex]:regex:' \
  '(-n --norecurse)'{-n,--norecurse}'[do not recurse subdirectories]' \
  '--tags[find datasets matching these tag criteria]:tags:' \
  '--xtags[exclude these tags from reporting]:xtags:' \
  '--or[use OR logic for tag matching instead of AND]' \
  '(-o --out)'{-o,--out}'[write reported files to this file]:file:_files' \
  '(-b --batch)'{-b,--batch}'[number of files to process at a time]:num:' \
  '--adpkg[specify instrument package]:pkg:' \
  '*:file:_files' && ret=0

return ret
