autoload -U is-at-least

_rvpm() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_rvpm_commands" \
"*::: :->rvpm" \
&& ret=0
    case $state in
    (rvpm)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:rvpm-command-$line[1]:"
        case $line[1] in
            (sync)
_arguments "${_arguments_options[@]}" : \
'--rebuild=[Run each plugin'\''s \`build\` command even when git HEAD did not move. By default \`sync\` skips build for plugins whose pull was a no-op, which makes "nothing changed" syncs much faster. Use this when you need to rerun e.g. \`\:TSUpdate\` or a manual rebuild step]::QUERY:_default' \
'--prune[Delete unused plugin directories after syncing]' \
'--frozen[Error out if any non-dev plugin is missing from rvpm.lock (strict reproducibility for CI / fresh machines)]' \
'--no-lock[Ignore rvpm.lock entirely\: pull latest and do not write the lockfile]' \
'(--no-refresh)--refresh[Force-refresh every plugin'\''s git state regardless of the fetch cache (\`options.fetch_interval\`). Useful before checking for held-back plugins when you want a guaranteed fresh remote read]' \
'(--refresh)--no-refresh[Skip git fetch for every plugin regardless of the fetch cache (offline mode). Plugins whose local HEAD already matches the effective rev complete instantly; others fall through to a local checkout that errors if the commit isn'\''t already available]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(generate)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
'--name=[Friendly name (optional)]:NAME:_default' \
'--lazy=[Set lazy flag]:LAZY:(true false)' \
'--on-cmd=[Set on_cmd. Comma-separated or JSON array]:ON_CMD:_default' \
'--on-ft=[Set on_ft. Comma-separated or JSON array]:ON_FT:_default' \
'--on-map=[Set on_map. Comma-separated or JSON array/object]:ON_MAP:_default' \
'--on-event=[Set on_event. Comma-separated or JSON array]:ON_EVENT:_default' \
'--rev=[Set rev (branch/tag/commit)]:REV:_default' \
'(--no-ai)--ai=[AI backend for this \`add\`. Replaces the static-scan + auto-lazy path\: the chosen CLI (\`claude\` / \`gemini\` / \`codex\`) reads the plugin'\''s README + your config and proposes the full \`\[\[plugins\]\]\` block plus any per-plugin hook files. Overrides \`options.ai\` for this call]:AI:((off\:"Use the static scan + auto_lazy flow (default)"
claude\:"Spawn the \`claude\` CLI as a subprocess"
gemini\:"Spawn the \`gemini\` CLI as a subprocess"
codex\:"Spawn the \`codex\` CLI as a subprocess"
opencode\:"Spawn the \`opencode\` CLI as a subprocess"))' \
'(--no-lazy)--auto-lazy[Accept auto-scanned on_cmd / on_map without prompting. Overrides \`options.auto_lazy\` for this call (== "always"). Useful for non-TTY scripts that want lazy-by-default]' \
'--no-lazy[Skip the auto-scan entirely for this invocation. Overrides \`options.auto_lazy\` for this call (== "never"). This does not override explicit \`--lazy\` / \`--on-*\` flags — if the plugin is lazy via those, it stays lazy]' \
'--no-ai[Force the static-scan path even if \`options.ai\` is set in config]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':repo -- Plugin repo\: owner/repo, URL, or local path:_default' \
&& ret=0
;;
(tune)
_arguments "${_arguments_options[@]}" : \
'(--no-ai)--ai=[AI backend for this \`tune\`. Overrides \`options.ai\` for this call]:AI:((off\:"Use the static scan + auto_lazy flow (default)"
claude\:"Spawn the \`claude\` CLI as a subprocess"
gemini\:"Spawn the \`gemini\` CLI as a subprocess"
codex\:"Spawn the \`codex\` CLI as a subprocess"
opencode\:"Spawn the \`opencode\` CLI as a subprocess"))' \
'--no-ai[Force-disable AI for this call. \`tune\` is AI-only, so this effectively errors out — provided for symmetry with \`add\`]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::query -- Fuzzy match plugin url (omit to pick interactively):_default' \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
'--init[Open init.lua directly (per-plugin path, or Neovim'\''s own with --global)]' \
'--before[Open before.lua directly]' \
'--after[Open after.lua directly]' \
'--global[Edit global hooks instead of per-plugin files]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::query -- Fuzzy match plugin url (omit to pick interactively):_default' \
&& ret=0
;;
(set)
_arguments "${_arguments_options[@]}" : \
'--lazy=[Set lazy flag non-interactively]:LAZY:(true false)' \
'--merge=[Set merge flag non-interactively]:MERGE:(true false)' \
'--on-cmd=[Set on_cmd. Comma-separated (\`"Foo,Bar"\`) or JSON array (\`'\''\["Foo","Bar"\]'\''\`)]:ON_CMD:_default' \
'--on-ft=[Set on_ft. Comma-separated or JSON array]:ON_FT:_default' \
'--on-map=[Set on_map. Comma-separated lhs list, JSON array of strings, or JSON array/object with full \`{ lhs, mode, desc }\` form. Example\: --on-map '\''{"lhs"\:"<space>d","mode"\:\["n","x"\]}'\'']:ON_MAP:_default' \
'--on-event=[Set on_event. Comma-separated or JSON array. Supports the \`"User Xxx"\` shorthand for User events with patterns]:ON_EVENT:_default' \
'--on-path=[Set on_path glob list. Comma-separated or JSON array]:ON_PATH:_default' \
'--on-source=[Set on_source (plugin names). Comma-separated or JSON array]:ON_SOURCE:_default' \
'--rev=[Set rev (branch/tag/commit) non-interactively]:REV:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::query -- Fuzzy match plugin url (omit to pick interactively):_default' \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::query -- Fuzzy match plugin url (omit to update all):_default' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::query -- Fuzzy match plugin url (omit to pick interactively):_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'--no-tui[Print plain text instead of launching the TUI]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'--write[Append to init.lua (creates the file if missing)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(browse)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(profile)
_arguments "${_arguments_options[@]}" : \
'--runs=[Number of nvim runs to average (default 3, max 20)]:RUNS:_default' \
'--top=[Limit plain / JSON output to top N plugins (TUI ignores this)]:TOP:_default' \
'(--no-tui)--json[Emit the averaged report as JSON to stdout]' \
'--no-tui[Plain text output instead of the TUI]' \
'--no-merge[Treat all plugins as merge=false for this measurement, so each plugin'\''s files source from their own repos/<canonical>/ path instead of the shared merged/ dir. Lets you see per-plugin load time even for plugins that are normally merged, and compare the cost of merging. merged/ itself is not touched]' \
'--no-instrument[Skip phase-marker instrumentation. Faster and avoids swapping loader.lua during the profile run. You lose the phase timeline and per-plugin init/trig columns, but raw per-plugin self ms is still measured]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(log)
_arguments "${_arguments_options[@]}" : \
'--last=[How many recent runs to show (default\: 1, max\: 20)]:LAST:_default' \
'--full[Show full commit body in addition to subject (currently subject-only)]' \
'--diff[Inline \`git diff\` for changed README/CHANGELOG/doc files]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::query -- Case-insensitive substring filter on plugin display name:_default' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- Target shell (bash / zsh / fish / powershell / elvish):(bash elvish fish powershell zsh)' \
&& ret=0
;;
(self-update)
_arguments "${_arguments_options[@]}" : \
'-y[Skip the confirmation prompt]' \
'--yes[Skip the confirmation prompt]' \
'--check[Print availability and exit without installing]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_rvpm__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:rvpm-help-command-$line[1]:"
        case $line[1] in
            (sync)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(generate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(tune)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(set)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(browse)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(profile)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(log)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(self-update)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_rvpm_commands] )) ||
_rvpm_commands() {
    local commands; commands=(
'sync:Clone/pull plugins and regenerate loader.lua' \
'generate:Regenerate loader.lua only (no git)' \
'clean:Delete plugin directories no longer referenced by config.toml' \
'add:Add a plugin and sync' \
'tune:Tune an existing plugin'\''s config with the AI backend' \
'edit:Edit per-plugin or global hook files in \$EDITOR' \
'set:Tweak a plugin'\''s options interactively' \
'update:Update (git pull) installed plugins' \
'remove:Remove a plugin and delete its directory' \
'list:Show plugin list (TUI by default, plain text with --no-tui)' \
'config:Open config.toml in \$EDITOR' \
'init:Print or write the init.lua loader snippet' \
'browse:Browse and install Neovim plugins from GitHub' \
'doctor:Diagnose rvpm'\''s config, state, and environment' \
'profile:Profile Neovim startup time per plugin' \
'log:Show recent sync/update/add changes' \
'completion:Print a shell completion script to stdout (#114)' \
'self-update:Update the rvpm binary itself to the latest GitHub release (#125)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'rvpm commands' commands "$@"
}
