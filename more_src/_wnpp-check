#compdef wnpp-check
# Documentation: https://manpages.debian.org/wnpp-check
# Source: debian/devscripts scripts/wnpp-check.sh — check Debian WNPP bugs for given package(s) (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-e --exact)'{-e,--exact}'[exact name match]' \
    '*:package name:_default' \
    && ret=0

return ret
