#compdef otbcli_FusionOfClassifications
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_FusionOfClassifications.html
# Orfeo ToolBox: fuse several classification maps by voting or Dempster-Shafer

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-il[list of input classification maps to fuse]:images:_files' \
  '-out[output fused classification image]:output:_files' \
  '-method[fusion method]:method:(majorityvoting dempstershafer)' \
  '-method.dempstershafer.cmfl[list of confusion matrix CSV files]:files:_files' \
  '-method.dempstershafer.mob[measurement for masses of belief]:mob:(precision recall accuracy kappa)' \
  '-nodatalabel[label value for the NoData class]:value:' \
  '-undecidedlabel[label for undecided pixels]:value:' \
  '*::arg:_files' && ret=0

return ret
