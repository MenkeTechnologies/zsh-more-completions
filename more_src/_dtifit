#compdef dtifit
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/diffusion/fdt/index.html
# dtifit - fit a diffusion tensor model at each voxel

local ret=1

_arguments -s -S \
  '-k[diffusion weighted image]:file:_files' \
  '-o[output basename]:basename:_files' \
  '-m[brain binary mask]:file:_files' \
  '-r[b vectors file]:file:_files' \
  '-b[b values file]:file:_files' \
  '-x[min x ROI bound]:x:' \
  '-X[max x ROI bound]:X:' \
  '-y[min y ROI bound]:y:' \
  '-Y[max y ROI bound]:Y:' \
  '-z[min z ROI bound]:z:' \
  '-Z[max z ROI bound]:Z:' \
  '--cni[input confound regressors]:file:_files' \
  '--gradnonlin[gradient nonlinearity tensor file]:file:_files' \
  '--littlebit[only process small area of brain]' \
  '--save_tensor[save the elements of the tensor]' \
  '--sse[output sum of squared errors]' \
  '--wls[fit using weighted least squares]' \
  '--kurt[output mean kurtosis map (for multi-shell data)]' \
  '--kurtdir[output parallel/perpendicular kurtosis maps]' \
  '(-V --verbose)'{-V,--verbose}'[switch on diagnostic messages]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
