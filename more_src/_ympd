#compdef ympd
# Documentation: https://manned.org/man/alpine-3.9/ympd-doc/1.3.0-r7/ympd.1
# ympd - standalone MPD Web GUI

local ret=1

_arguments -s -S \
  '(-h --host)'{-h,--host}'[connect to mpd at host]:host:_hosts' \
  '(-p --port)'{-p,--port}'[connect to mpd at port]:port' \
  '(-w --webport)'{-w,--webport}'[port for the webserver to listen to]:port' \
  '(-u --user)'{-u,--user}'[drop privileges to username after socket binding]:user:_users' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '--help[print all valid options and exit]' && ret=0

return ret
