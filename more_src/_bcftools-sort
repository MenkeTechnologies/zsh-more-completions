#compdef bcftools-sort
# Documentation: http://www.htslib.org/doc/bcftools.html#sort
# bcftools sort: Sort VCF/BCF files

local ret=1

_arguments -s -S \
  '(-m --max-mem)'{-m,--max-mem}'[Maximum memory to use. Approximate, affects the number of temporary fi]:FLOAT: ' \
  '(-o --output)'{-o,--output}'[see Common Options]:FILE:_files' \
  '(-O --output-type)'{-O,--output-type}'[see Common Options]:b: ' \
  '(-T --temp-dir)'{-T,--temp-dir}'[Use this directory to store temporary files. If the last six character]:DIR:_files -/' \
  '(-v --verbosity)'{-v,--verbosity}'[see Common Options]:INT: ' \
  '(-W --write-index)'{-W,--write-index}'[Automatically index the output file. FMT is optional and can be one of]:arg: ' \
  '*:file:_files' && ret=0

return ret
