#compdef perflint

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--rcfile[configuration file]:file:_files' \
  '--errors-only[only show errors]' \
  '-E[only show errors]' \
  '--disable[disable checks]:checks:' \
  '-d[disable checks]:checks:' \
  '--enable[enable checks]:checks:' \
  '-e[enable checks]:checks:' \
  '--output-format[output format]:format:(text json)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:files:_files -g "*.py"' \
  && ret=0

return ret
