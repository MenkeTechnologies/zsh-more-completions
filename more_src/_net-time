#compdef net-time
# _net-time — Samba net time helper (legacy: queries / synchronises the local clock with a Windows host's time service through SMB; subcommands: time (default), system (set hardware clock too), zone (print remote tz), set (sync now); -S server, -U user, -W workgroup, -k Kerberos, -N no password, -d debug level, -h help, -V version)
# upstream: https://github.com/samba-team/samba
# Subcommands from samba/samba source3/utils/net_time.c on tip.

_net-time() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-S+[server]:host:_hosts' \
        '-U+[user]:user:_users' \
        '-W+[workgroup]:workgroup:' \
        '-k[Kerberos]' \
        '-N[no password]' \
        '-d+[debug level]:level:' \
        '1::subcommand:(time system zone set)'
}

_net-time "$@"
