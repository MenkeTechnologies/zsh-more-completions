#compdef qcc
# Documentation: http://basilisk.fr/src/qcc.c
# Basilisk qcc source-to-source compiler for CFD/PDE solvers

local ret=1

_arguments -s -S \
  '-grid=[select grid implementation]:grid:' \
  '-dimensions=[output dimensional analysis to file]:file:_files' \
  '-disable-dimensions[skip dimensional consistency checking]' \
  '-source[generate underscore-prefixed C99 source]' \
  '-prepost[generate source before postmacro expansion]' \
  '-python[generate Python wrapper via SWIG]' \
  '-tags[generate .tags file]' \
  '-MD[generate .d dependency file]' \
  '-autolink[auto-link required libraries via pragmas]' \
  '-nolineno[omit line-number information]' \
  '-cpu[compute on CPU (default)]' \
  '-gpu[compute on GPU]' \
  '-debug[enable internal debugging output]' \
  '-events[print event trace to stderr]' \
  '-catch[catch floating-point errors]' \
  '-progress[generate progress file]' \
  '-non-finite[include non-finite constants in dimension output]' \
  '-redundant[include redundant constants in dimension output]' \
  '-Wdimensions[treat dimensional errors as warnings]' \
  '-maxcalls=[max interpreter calls]:n:' \
  '-cadna[enable CADNA support]' \
  '-run=[run with interpreter at verbosity level]:level:' \
  '*:source file:_files -g "*.c"' && ret=0

return ret
