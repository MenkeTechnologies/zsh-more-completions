#compdef closest-features closestfeats
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/set-operations/closest-features.html
# Documentation: https://github.com/bedops/bedops/blob/master/applications/bed/closestfeats/src/Input.hpp
# Reference accessed: 2026-05-27
# Verified: upstream Input.hpp argument parser

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--help[show help message and exit]' \
  '--version[show program version and citation info]' \
  '--ec[perform error checking on input compliance]' \
  '--header[accept BED/VCF/GFF/SAM/WIG headers in input files]' \
  '--chrom=[restrict operations to specified chromosome]:chromosome:' \
  '--delim=[set delimiter between output columns]:delim:' \
  '--closest[report only one closest feature (no upstream/downstream pair)]' \
  '--dist[append signed base-pair distance to closest feature]' \
  '--no-overlaps[exclude overlapping features from closest results]' \
  '--no-ref[do not echo the reference element on output]' \
  '--no-query[do not echo the query element on output]' \
  '--shortest[when both upstream and downstream tie, report only the shorter]' \
  '*:bed/starch file:_files -g "*.(bed|bed.gz|starch)(-.)"' && ret=0

return ret
