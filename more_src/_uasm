#compdef uasm

# UASM: another MASM-compatible assembler (fork of JWasm/HJWasm)
# Documentation: https://www.terraspace.co.uk/uasm.html
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-?[show help]' \
  '-bin[binary output]' \
  '-coff[COFF output]' \
  '-elf[ELF32 output]' \
  '-elf64[ELF64 output]' \
  '-omf[OMF output]' \
  '-pe[PE output]' \
  '-mz[DOS MZ output]' \
  '-win64[Win64 COFF]' \
  '-Fo[output object file]:file:_files' \
  '-Fl[listing file]:file:_files' \
  '-D[predefine symbol]:symbol:' \
  '-I[include path]:dir:_files -/' \
  '-Sa[max syntax]' \
  '-q[quiet]' \
  '-WX[warnings as errors]' \
  '-w[warning level]:n:(0 1 2 3)' \
  '-Zd[line-number info]' \
  '-Zi[symbolic debug]' \
  '-Zp[align structures]:n:(1 2 4 8 16)' \
  '-Zm[MASM 5.10 compat]' \
  '*:source file:_files -g "*.(asm|s)"' && ret=0
return ret
