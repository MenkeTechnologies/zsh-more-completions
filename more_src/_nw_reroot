#compdef nw_reroot
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: (re)root tree on an outgroup.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-d[deroot: splice out root LCA]' \
  '-l[lax: reroot on ingroup if outgroup LCA is the root]' \
  '-s[treat inner node labels as support values]' \
  '*:newick file:_files' && ret=0

return ret
