#compdef awslogs

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'get:get log events'
  'groups:list log groups'
  'streams:list log streams'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'awslogs command' commands && ret=0
    ;;
  args)
    case $words[1] in
      get)
        _arguments \
          {-h,--help}'[show help]' \
          '--aws-region=[AWS region]:region' \
          '--aws-access-key-id=[AWS access key ID]:key' \
          '--aws-secret-access-key=[AWS secret access key]:secret' \
          '--aws-session-token=[AWS session token]:token' \
          '--profile=[AWS profile]:profile' \
          '-s+[start time]:start time' \
          '--start=[start time]:start time' \
          '-e+[end time]:end time' \
          '--end=[end time]:end time' \
          '-w[watch for new log events]' \
          '--watch[watch for new log events]' \
          '-G[enable color output]' \
          '--color=[color mode]:mode:(always auto never)' \
          '--no-group[do not display group name]' \
          '--no-stream[do not display stream name]' \
          '--timestamp[show event timestamp]' \
          '--ingestion-time[show event ingestion time]' \
          '-f+[filter pattern]:filter pattern' \
          '--filter-pattern=[CloudWatch filter pattern]:filter pattern' \
          '--query=[CloudWatch Insights query]:query' \
          '1:log group' \
          '2:log stream filter' && ret=0
        ;;
      groups)
        _arguments \
          {-h,--help}'[show help]' \
          '--aws-region=[AWS region]:region' \
          '--profile=[AWS profile]:profile' \
          '-p+[log group prefix]:prefix' \
          '--log-group-prefix=[log group prefix]:prefix' && ret=0
        ;;
      streams)
        _arguments \
          {-h,--help}'[show help]' \
          '--aws-region=[AWS region]:region' \
          '--profile=[AWS profile]:profile' \
          '1:log group' && ret=0
        ;;
    esac
    ;;
esac

return ret
