#compdef cog-cli
# Documentation: https://github.com/replicate/cog
# Reference accessed: 2026-05-27
# Verified: upstream pkg/cli/root.go AddCommand list and individual command
# files (build.go, predict.go, push.go, run.go, serve.go, train.go,
# login.go, debug.go, init.go, exec.go, doctor.go, weights.go).
# Note: the installed binary is `cog` but the existing _cog file in this
# repo targets cocogitto. This file targets the alternate `cog-cli` name
# reserved in the parent project's plan for replicate/cog.
# Deviations from spec: dropped `version` (Cobra exposes it as a persistent
# flag `--version`, not a subcommand); added the real `debug`, `doctor`,
# `exec`, `init`, `weights` subcommands.

local curcontext="$curcontext" state line ret=1

local -a _cog_subcommands
_cog_subcommands=(
  'build:build a Docker image from cog.yaml'
  'debug:print Dockerfile or other debugging information'
  'doctor:check the local environment for issues'
  'init:initialise a new cog project in the current directory'
  'login:sign in to the replicate registry'
  'predict:run a prediction inside the cog model container'
  'push:build and push a model to a remote registry'
  'run:run a command inside the cog model container'
  'exec:execute a command inside the cog environment'
  'serve:run a model as a long-running HTTP server'
  'train:run a fine-tune training run'
  'weights:manage model weights (pull, status)'
)

_arguments -C \
  '--debug[show debugging output]' \
  '--no-color[disable colored output]' \
  '(- *)--version[show version of cog]' \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'cog-cli subcommand' _cog_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments \
          '(-t --tag)'{-t+,--tag=}'[image tag]:tag:' \
          '--separate-weights[generate a separate image layer for weights]' \
          '--use-cuda-base-image=[use a CUDA base image]:value:(true false auto)' \
          '--use-cog-base-image=[use a Cog base image]:value:(true false)' \
          '--openapi-schema=[write the OpenAPI schema to a file]:file:_files' \
          '--progress=[progress output type]:type:(auto plain tty)' \
          '*:file:_files' && ret=0
        ;;
      predict)
        _arguments \
          '(-i --input)*'{-i+,--input=}'[input key=value or key=@file]:input:' \
          '(-o --output)'{-o+,--output=}'[output file path]:file:_files' \
          '--setup-timeout=[setup timeout in seconds]:seconds:' \
          '--gpus=[GPU specification]:gpus:' \
          '*:image:' && ret=0
        ;;
      push)
        _arguments \
          '--separate-weights[push weights as a separate layer]' \
          '--use-cuda-base-image=[use a CUDA base image]:value:(true false auto)' \
          '--use-cog-base-image=[use a Cog base image]:value:(true false)' \
          '--openapi-schema=[write the OpenAPI schema to a file]:file:_files' \
          '*:image:' && ret=0
        ;;
      run)
        _arguments \
          '(-p --publish)*'{-p+,--publish=}'[publish container ports]:port:' \
          '(-e --env)*'{-e+,--env=}'[set environment variable]:var:' \
          '--gpus=[GPU specification]:gpus:' \
          '*:command:_command_names -e' && ret=0
        ;;
      serve)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port to listen on]:port:' \
          '--gpus=[GPU specification]:gpus:' \
          '*:file:_files' && ret=0
        ;;
      train)
        _arguments \
          '(-i --input)*'{-i+,--input=}'[input key=value or key=@file]:input:' \
          '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
          '--gpus=[GPU specification]:gpus:' \
          '*:image:' && ret=0
        ;;
      login)
        _arguments \
          '--token-stdin[read token from stdin]' \
          '--registry-host=[registry host]:host:' && ret=0
        ;;
      init)
        _arguments '*:dir:_files -/' && ret=0
        ;;
      weights)
        local -a _cog_weights
        _cog_weights=(
          'pull:pull weights into the local cache'
          'status:show weight cache status'
        )
        _describe -t commands 'cog weights subcommand' _cog_weights && ret=0
        ;;
      debug)
        _arguments '*:file:_files' && ret=0
        ;;
      exec|doctor)
        _arguments '*:command:_command_names -e' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
