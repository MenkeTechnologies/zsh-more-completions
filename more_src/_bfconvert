#compdef bfconvert
# Documentation: https://bio-formats.readthedocs.io/en/stable/users/comlinetools/conversion.html
# bio-formats: convert a file to a different format

local ret=1

_arguments -s \
  '-option[pass writer options as key/value pairs]:key: :value:' \
  '-noflat[do not flatten resolutions into individual series]' \
  '-series[convert only the specified series]:series:' \
  '-timepoint[restrict conversion to a single timepoint]:timepoint:' \
  '-channel[limit output to a specific channel]:channel:' \
  '-z[convert only one Z-section]:z:' \
  '-range[convert images between indices (inclusive)]:start: :end:' \
  '-tilex[tile width in pixels]:tilex:' \
  '-tiley[tile height in pixels]:tiley:' \
  '-crop[convert a small tile]:x,y,width,height:' \
  '-compression[set compression mode]:compression:' \
  '-quality[set compression quality]:quality:' \
  '-overwrite[overwrite existing output files]' \
  '-nooverwrite[prevent overwriting existing files]' \
  '-nolookup[disable conversion of lookup tables]' \
  '-bigtiff[force BigTiff output]' \
  '-nobigtiff[disable automatic switching to BigTiff]' \
  '-padded[enforce zero padding on filename indexes]' \
  '-pyramid-resolutions[expected resolutions in output file]:resolutions:' \
  '-pyramid-scale[downsampling factor for pyramid levels]:scale:' \
  '-cache[cache the reader under the input file directory]' \
  '-cache-dir[directory for cached reader storage]:directory:_files -/' \
  '-no-sas[do not preserve OME-XML StructuredAnnotation elements]' \
  '-no-sequential[do not assume planes are written sequentially]' \
  '-swap[override default input dimension order]:dimension order:' \
  '-fill[fill value for undefined pixels]:value:' \
  '-precompressed[transfer compressed bytes without decompression]' \
  '-extra-metadata[write additional supplemental metadata]:file:_files' \
  '*:file:_files' && ret=0

return ret
