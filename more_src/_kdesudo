#compdef kdesudo
# Documentation: https://man.archlinux.org/search?q=kdesudo
# Reference accessed: 2026-05-16

# kdesudo: legacy KDE wrapper around sudo (replaced by kdesu)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-u[run as user]:user:_users' \
  '--user=[run as user]:user:_users' \
  '-c[command line]:cmd:_command_names' \
  '--cmd=[command line]:cmd:_command_names' \
  '-d[show debug output]' \
  '--debug[show debug output]' \
  '-n[no password (key auth)]' \
  '--no-password[no password (key auth)]' \
  '-i[icon]:name:' \
  '--icon=[icon]:name:' \
  '-t[set caption]:title:' \
  '--caption=[set caption]:title:' \
  '-r[do not show error message]' \
  '-f[required file]:file:_files' \
  '--attach=[X window id]:id:' \
  '*:command:_command_names' && ret=0
return ret
