#compdef svlint
# Documentation: https://man.archlinux.org/search?q=svlint
# Reference accessed: 2026-05-16
# Source: Homebrew bottle
# Formula: svlint
# Type: maintainer-shipped (Homebrew)
# Harvested: 2026-05-15

autoload -U is-at-least

_svlint() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'()*-f+[Filelist file(s)]:FILELISTS: ' \
'()*--filelist=[Filelist file(s)]:FILELISTS: ' \
'*-D+[Define macro for preprocessor, e.g. `-D FOO` or `-D FOO=123`]:DEFINES: ' \
'*--define=[Define macro for preprocessor, e.g. `-D FOO` or `-D FOO=123`]:DEFINES: ' \
'*-I+[Include directory for preprocessor, e.g. `-I path/to/headerfiles/`]:INCDIRS: ' \
'*--incdir=[Include directory for preprocessor, e.g. `-I path/to/headerfiles/`]:INCDIRS: ' \
'-c+[TOML configuration file, searched for hierarchically upwards]:CONFIG: ' \
'--config=[TOML configuration file, searched for hierarchically upwards]:CONFIG: ' \
'*-p+[Plugin file, e.g. `-p path/to/libfoo.so` or `-p path\\to\\foo.dll`]:PLUGINS: ' \
'*--plugin=[Plugin file, e.g. `-p path/to/libfoo.so` or `-p path\\to\\foo.dll`]:PLUGINS: ' \
'--dump-filelist=[Print data from filelists]:DUMP_FILELIST:(yaml files incdirs defines)' \
'--shell-completion=[Print shell completion script]:SHELL_COMPLETION:(bash elvish fish powershell zsh)' \
'-h[Print help information]' \
'--help[Print help information]' \
'-V[Print version information]' \
'--version[Print version information]' \
'--ignore-include[Ignore all preprocessor `include directives]' \
'-1[Print one rule failure message per line]' \
'--oneline[Print one rule failure message per line]' \
'-s[Suppress printing, useful for scripting]' \
'--silent[Suppress printing, useful for scripting]' \
'-v[Print verbose messages]' \
'--verbose[Print verbose messages]' \
'--github-actions[Format rule failure messages for GitHub Actions]' \
'--config-update[Update TOML configuration file in-place]' \
'--config-example[Print an example TOML configuration]' \
'--dump-syntaxtree[Print syntax trees, useful for debug or syntax analysis]' \
'-E[Print preprocessor output then exit before parsing syntax]' \
'--preprocess-only[Print preprocessor output then exit before parsing syntax]' \
'*::files -- Source file(s):' \
&& ret=0
}

(( $+functions[_svlint_commands] )) ||
_svlint_commands() {
    local commands; commands=()
    _describe -t commands 'svlint commands' commands "$@"
}

_svlint "$@"
