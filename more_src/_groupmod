#compdef groupmod
# _groupmod — OpenBSD groupmod (low-level binary behind group mod; renames a group via -n or changes its gid via -g; -o permits a duplicate gid)
# upstream: https://github.com/openbsd/src (usr.sbin/user)
# Flags from usr.sbin/user/groupmod.8 on tip.

_groupmod() {
    _arguments \
        '-o[allow duplicate gid]' \
        '-v[verbose]' \
        '-g+[new gid]:gid:' \
        '-n+[new name]:newname:' \
        '1:group:_groups'
}

_groupmod "$@"
