#compdef kivaToFoam
# Documentation: https://www.openfoam.com/documentation/guides/latest/man/
# Converts a KIVA grid to OpenFOAM format

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-file+[specify alternative input file name - default is otape17]:name:_files' \
  '-version+[specify kiva version - default is 3v]:version:(kiva3 kiva3v)' \
  '-zHeadMin+[minimum z-height for transferring liner faces to cylinder-head]:scalar:' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' && ret=0

return ret
