#compdef openmw openmw-launcher openmw-iniimporter openmw-essimporter openmw-wizard
# Documentation: https://openmw.readthedocs.io
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[config file]:file:_files' \
  '--user-data=[user data dir]:dir:_files -/' \
  '--resources=[resources dir]:dir:_files -/' \
  '--data=[data path]:dir:_files -/' \
  '--data-local=[local data path]:dir:_files -/' \
  '--content=[content file]:file:_files -g "*.{esm,esp,omwaddon,omwgame,omwscripts}"' \
  '--groundcover=[groundcover esm]:file:_files -g "*.{esm,esp}"' \
  '--bsa=[load BSA file]:file:_files -g "*.bsa"' \
  '--no-sound[disable sound]' \
  '--no-grab[do not grab mouse]' \
  '--export-fonts[export fonts]' \
  '--script-blacklist=[blacklist scripts]:list:' \
  '--script-blacklist-use=[apply blacklist]:flag:(true false)' \
  '--load-savegame=[load savegame]:file:_files -g "*.{omwsave,ess}"' \
  '--encoding=[text encoding]:enc:(win1250 win1251 win1252 win1253 win1254 win1255 win1256 win1257 win1258)' \
  '--fallback=[Morrowind.ini fallback]:opt:' \
  '--load-savegame=[load save]:file:_files -g "*.omwsave"' \
  '--skip-menu[skip main menu]' \
  '--new-game[start new game]' \
  '--fs-strict=[strict filesystem]:flag:' \
  '--debug[debug logging]' && ret=0

return ret
