#compdef gausmooth
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss65.html
# KAPPA: smooth a one- to three-dimensional NDF using a Gaussian filter

local ret=1

_arguments -s \
  'AXES=[pixel axis indices for the smoothing plane]:axes' \
  'BOX=[box dimensions over which the PSF is applied]:box' \
  'FWHM=[FWHM of the Gaussian PSF]:fwhm' \
  'IN=[input NDF to be smoothed]:NDF:_files' \
  'ORIENT=[orientation angle of elliptical PSF]:orient' \
  'OUT=[output smoothed NDF]:NDF:_files' \
  'TITLE=[title for the output NDF]:title' \
  'WLIM=[minimum fraction of good pixels]:wlim' \
  '*:NDF:_files' && ret=0

return ret
