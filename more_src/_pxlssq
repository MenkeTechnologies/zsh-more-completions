#compdef pxlssq
# Documentation: https://github.com/FePhyFoFum/phyx/wiki/Program-list
# phyx pxlssq: information about seqs in an alignment file (ls for alignments).

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-s+[input alignment file]:file:_files' \
  '-i[per-taxon statistics]' && ret=0

return ret
