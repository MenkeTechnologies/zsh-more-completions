#compdef tspin

_tspin() {
    _arguments \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-V --version)'{-V,--version}'[print version]' \
        '(-f --follow)'{-f,--follow}'[follow file for new content]' \
        '(-e --start-at-end)'{-e,--start-at-end}'[start at end of file]' \
        '(-p --print)'{-p,--print}'[print output without pager]' \
        '--config-path=[path to config file]:file:_files' \
        '--words-red=[highlight words in red]:words' \
        '--words-green=[highlight words in green]:words' \
        '--words-yellow=[highlight words in yellow]:words' \
        '--words-blue=[highlight words in blue]:words' \
        '--words-magenta=[highlight words in magenta]:words' \
        '--words-cyan=[highlight words in cyan]:words' \
        '--disable-builtin-keywords[disable builtin keyword highlighting]' \
        '--disable-builtin-date[disable builtin date highlighting]' \
        '--disable-builtin-ip[disable builtin IP highlighting]' \
        '--disable-builtin-url[disable builtin URL highlighting]' \
        '--disable-builtin-path[disable builtin path highlighting]' \
        '--disable-builtin-number[disable builtin number highlighting]' \
        '--disable-builtin-quotes[disable builtin quote highlighting]' \
        '--disable-builtin-uuid[disable builtin UUID highlighting]' \
        '--disable-builtin-pointer[disable builtin pointer highlighting]' \
        '--enable-builtin-http[enable builtin HTTP method highlighting]' \
        '*:file:_files'
}

_tspin "$@"
