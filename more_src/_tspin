#compdef tspin
# Documentation: https://github.com/bensadeh/tailspin
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Verified against README flag list. Only documented flags are included;
# previous --words-<color> / --disable-builtin-* / --enable-builtin-http were
# not documented in upstream tailspin and have been removed.

_arguments \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-f --follow)'{-f,--follow}'[follow the contents of the file]' \
  '(-p --print)'{-p,--print}'[print the output to stdout]' \
  '(-e --exec)'{-e,--exec}'=[run command and view output in pager]:command' \
  '--config-path=[use the configuration file from the provided path]:file:_files' \
  '--pager=[set a custom pager (must include [FILE])]:pager command' \
  '*--highlight=[highlight comma-separated words in a color (COLOR:WORDS)]:highlight spec' \
  '--enable=[enable one or more default highlight groups, disabling the rest]:group(s)' \
  '--disable=[disable one or more default highlight groups, enabling the rest]:group(s)' \
  '--extras=[enable extra highlight groups on top of current configuration]:extra' \
  '--disable-builtin-keywords[disable booleans, nulls, log severities and REST verb highlighting]' \
  '*:file:_files'
