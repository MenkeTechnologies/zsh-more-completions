#compdef continue-cli
# Documentation: https://docs.continue.dev/cli/quickstart
# Reference accessed: 2026-05-23
# Verified: same surface as cn (@continuedev/cli); see _cn.

# Zsh completion for continue-cli - Continue coding agent CLI (alternate binary name)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --print)'{-p,--print}'[print response and exit (headless)]' \
  '--format[output format for headless mode]:format:(json)' \
  '--silent[strip thinking tags from headless output]' \
  '--resume[resume from last session]' \
  '--fork[fork from session ID]:session:' \
  '--config[configuration file or hub slug]:config:' \
  '--org[organization slug (headless only)]:org:' \
  '--readonly[plan mode (read-only tools)]' \
  '--auto[auto-approve tool calls]' \
  '--allow[allow tool]:tool:' \
  '--ask[ask before tool use]' \
  '--exclude[exclude tool]:tool:' \
  '--mcp[enable MCP servers]' \
  '--model[model ID]:model:' \
  '--agent[agent slug]:agent:' \
  '--rule[additional rule file]:file:_files' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'continue-cli command' \
      'login[authenticate with Continue]' \
      'logout[remove stored credentials]' \
      'whoami[show current user]' \
      'serve[run headless API server]' \
      'remote-test[test remote agent connection]' && ret=0
    ;;
esac

return ret
