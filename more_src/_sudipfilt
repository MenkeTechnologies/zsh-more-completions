#compdef sudipfilt
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/filters/sudipfilt.c
# DIP (slope) FILTer of SU data in the f-k domain

local ret=1

_arguments -s -S \
  'dt=[time sampling interval]:dt' \
  'dx=[trace spacing]:dx' \
  'd2=[acceptable alias for dx]:d2' \
  'slopes=[monotonically increasing slopes]:slopes' \
  'amps=[amplitudes corresponding to slopes]:amps' \
  'bias=[slope made horizontal before filtering]:bias' \
  'verbose=[echoes information when set to 1]:verbose:(0 1)' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
