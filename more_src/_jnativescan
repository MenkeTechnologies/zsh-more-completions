#compdef jnativescan
# Documentation: https://download.java.net/java/early_access/jdk24/docs/specs/man/jnativescan.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# JDK static analysis tool for native access. Removed invented -cp
# short option (only --class-path is documented) and switched all
# option-args to space-separated (not =) per the upstream synopsis.
local -a arguments

arguments=(
    '--class-path[paths to jar files to scan]:path:_files -g "*.jar"'
    '--module-path[paths to modules to scan]:path:_directories'
    '--add-modules[comma-separated root modules to scan]:modules'
    '--release[Java SE release defining restricted methods]:release'
    '--print-native-access[print comma-separated list of modules using native access]'
    '(-h --help)'{-h,--help}'[show help]'
    '--version[show version]'
)

_arguments -s -S $arguments
