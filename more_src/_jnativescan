#compdef jnativescan

local -a arguments

arguments=(
    '--module-path=[module path]:path:_directories'
    '--class-path=[class path]:path:_files -g "*.{jar,class}"'
    '-cp[class path]:path:_files -g "*.{jar,class}"'
    '--add-modules=[modules to scan]:modules'
    '--release=[target release]:release'
    '--print-native-access[print modules using native access]'
    '-h[show help]'
    '--help[show help]'
    '--version[show version]'
)

_arguments -s -S $arguments
