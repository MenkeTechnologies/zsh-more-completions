#compdef chdman castool floptool imgtool

local curcontext="$curcontext" state line ret=1

case $service in
  (chdman)
    local -a commands
    commands=(
      'info:display info about CHD'
      'verify:verify CHD integrity'
      'createraw:create raw CHD'
      'createhd:create HD CHD'
      'createcd:create CD CHD'
      'createdvd:create DVD CHD'
      'createld:create laserdisc CHD'
      'extractraw:extract raw from CHD'
      'extracthd:extract HD from CHD'
      'extractcd:extract CD from CHD'
      'extractdvd:extract DVD from CHD'
      'extractld:extract LD from CHD'
      'copy:copy CHD'
      'addmeta:add metadata'
      'delmeta:delete metadata'
      'dumpmeta:dump metadata'
      'listtemplates:list templates'
      'help:show help'
    )
    _arguments -C \
      '1: :->cmd' \
      '*::arg:->args' && ret=0
    case $state in
      (cmd) _describe -t cmds 'chdman command' commands && ret=0 ;;
      (args)
        _arguments \
          '(-i --input)'{-i+,--input=}'[input file]:file:_files' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '(-c --compression)'{-c+,--compression=}'[compression types csv]:list:(none zlib zstd lzma huff cdzl cdlz cdfl cdzs)' \
          '(-f --force)'{-f,--force}'[force overwrite]' \
          '(-hs --hunksize)'{-hs+,--hunksize=}'[hunk size]:n:' \
          '(-us --unitsize)'{-us+,--unitsize=}'[unit size]:n:' \
          '(-chs --chs)'{-chs+,--chs=}'[CHS values]:c\,h\,s:' \
          '(-s --size)'{-s+,--size=}'[size bytes]:n:' \
          '(-sb --startbyte)'{-sb+,--startbyte=}'[start byte]:n:' \
          '(-sh --starthunk)'{-sh+,--starthunk=}'[start hunk]:n:' \
          '(-ss --sectorsize)'{-ss+,--sectorsize=}'[sector size]:n:' \
          '(-id --identfile)'{-id+,--identfile=}'[ident file]:file:_files' \
          '(-np --numprocessors)'{-np+,--numprocessors=}'[processors]:n:' \
          '(-fix)--fix[fix mode]' \
          '*: :_files' && ret=0 ;;
    esac ;;
  (castool|floptool|imgtool)
    _arguments -C \
      '(- *)-h[show help]' \
      '(- *)--help[show help]' \
      '1:command:(create dir extract identify ls put get del rm exists info list listdrivers help version)' \
      '*: :_files' && ret=0 ;;
esac

return ret
