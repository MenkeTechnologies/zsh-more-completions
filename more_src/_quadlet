#compdef quadlet
# Systemd generator for Podman containers

local ret=1

_arguments -s -S \
  '--dryrun[print results to stdout]' \
  '--no-kmsg-log[do not log to kernel message buffer]' \
  '--user[run for user units]' \
  '-v[verbose output]' \
  '--version[show version]' \
  '-h[show help]' \
  '--help[show help]' \
  '*:unit files:_files -g "*.(container|volume|network|kube|image)"' && ret=0

return ret
