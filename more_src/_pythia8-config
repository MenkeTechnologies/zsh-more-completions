#compdef pythia8-config
# Documentation: https://pythia.org/
# pythia8-config - query PYTHIA 8 build/link flags

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help message]' \
  '--config[print the argument(s) used to configure Pythia]' \
  '--prefix[installation prefix]' \
  '--bindir[PYTHIA binary directory]' \
  '--libdir[PYTHIA library directory]' \
  '--includedir[PYTHIA header directory]' \
  '--datadir[PYTHIA share directory]' \
  '--xmldoc[PYTHIA xmldoc directory]' \
  '--cxxflags[returns the PYTHIA -I flag string]' \
  '--cflags[returns the PYTHIA -I flag string]' \
  '--ldflags[returns the PYTHIA -L/-l flag string]' \
  '--libs[returns the PYTHIA -L/-l flag string]' \
  '--fastjet3[jet building using FastJet, version 3]' \
  '--hepmc[export PYTHIA events to HEPMC format, version 2]' \
  '--hepmc2[export PYTHIA events to HEPMC format, version 2]' \
  '--hepmc3[export PYTHIA events to HEPMC format, version 3]' \
  '--lhapdf5[external PDF sets via LHAPDF, version 5]' \
  '--lhapdf6[external PDF sets via LHAPDF, version 6]' \
  '--root[ROOT trees and histograms with PYTHIA]' \
  '--boost[required for GZIP or LHAPDF6]' \
  '--gzip[enable reading of GZIPPED files]' && ret=0

return ret
