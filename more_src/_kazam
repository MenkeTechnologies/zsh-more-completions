#compdef kazam
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/kazam.1.html
# Reference accessed: 2026-05-19
# Verified: Ubuntu jammy kazam(1) manpage.
# Removed invented -S/-W/-A capture flags and fake -f format
# enum; replaced with the real option set.

# Kazam: GTK screen recorder / screenshot tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show this help message and exit]' \
  '(- *)'{-v,--version}'[show version number and exit]' \
  '--debug[enable debug mode]' \
  '--silent[silent start, no UI shown]' \
  '--nosound[disable PulseAudio]' \
  '--test[generate test video signal]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[instant screenshot of a full screen]' \
  '(-a --area)'{-a,--area}'[instant screenshot of a preselected screen area]' \
  '(-s --select)'{-s,--select}'[instant screenshot of a preselected window]' \
  '(-w --window)'{-w,--window}'[instant screenshot of an active window]' \
  '(-p --preferences)'{-p,--preferences}'[show preferences window]' \
  '(-g --godmode)'{-g,--godmode}'[god mode of capture]' \
  '(-x --instance)'{-x,--instance}'[spawn new instance]' \
  '*::kazam args:_files' && ret=0
return ret
