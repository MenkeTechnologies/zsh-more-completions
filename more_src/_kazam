#compdef kazam

# Kazam: GTK screen recorder / screenshot tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-d[debug]' \
  '--debug[debug]' \
  '-s[show first-run dialog]' \
  '-S[fullscreen capture]' \
  '-W[window capture]' \
  '-A[area capture]' \
  '-f[file format]:fmt:(mp4 webm vp8 mkv)' \
  '*::kazam args:_files' && ret=0
return ret
