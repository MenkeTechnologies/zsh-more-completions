#compdef fairymax fairy-max
# Documentation: https://man.archlinux.org/search?q=fairymax
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-ini+[ini file (variant config)]:file:_files -g "*.ini"' \
  '-l+[log file]:file:_files' && ret=0

return ret
