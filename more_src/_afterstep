#compdef afterstep afterstep-classic
# Documentation: man afterstep(1)
# Source: afterstep/afterstep src/afterstep/afterstep.c + libAfterStep/asapp.c (master) — NeXTSTEP-like WM (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-c --config)'{-c,--config}'[show config info]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '--debug[run in synchronous (debug) mode]' \
    '(-s --single)'{-s,--single}'[run on single screen only]' \
    '(-r --restart)'{-r,--restart}'[restart-style startup]' \
    '(-d --display)'{-d+,--display=}'[X display]:display:_x_display' \
    '(-f --config-file)'{-f+,--config-file=}'[alternate config file]:file:_files' \
    '(-p --user-dir)'{-p+,--user-dir=}'[user config dir]:dir:_files -/' \
    '(-g --global-dir)'{-g+,--global-dir=}'[shared config dir]:dir:_files -/' \
    '(-V --verbosity-level)'{-V+,--verbosity-level=}'[verbosity 0-5]:level:(0 1 5)' \
    '--look=[look config file]:file:_files' \
    '--feel=[feel config file]:file:_files' \
    '--theme=[theme config file]:file:_files' \
    '(-l --log)'{-l+,--log=}'[log file]:file:_files' \
    '(-L --locale)'{-L+,--locale=}'[locale]:locale:_default' \
    '--bypass-autoexec[skip running autoexec on startup]' \
    '--sm-client-id=[session manager client ID]:id:_default' \
    && ret=0

return ret
