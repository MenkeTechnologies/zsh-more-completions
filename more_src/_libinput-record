#compdef libinput-record
# Documentation: https://man.archlinux.org/search?q=libinput-record
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--all[record all devices]' \
  '--autorestart[restart recording after timeout]:timeout:' \
  '-o[output file]:output file:_files' \
  '--multiple[record multiple devices]' \
  '--show-keycodes[show keycodes in output]' \
  '--with-libinput[also record libinput events]' \
  '*:device:_files -W /dev/input -g "event*"' && ret=0

return ret
