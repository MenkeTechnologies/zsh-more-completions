#compdef prosmart
# Documentation: https://www.ccp4.ac.uk/html/prosmart.html
# CCP4 ProSMART - generate external structure restraints and compare structures

local ret=1

_arguments -s -S \
  '-help[show command line argument list]' \
  '-a[run only ProSMART ALIGN, default method]' \
  '-a1[run only ProSMART ALIGN, alternative method 1 (faster)]' \
  '-a2[run only ProSMART ALIGN, alternative method 2 (slower)]' \
  '-r[run only ProSMART RESTRAIN, assumes alignment exists]' \
  '-o[output directory]:dir:_files -/' \
  '-f[external text file providing arguments]:file:_files' \
  '-threads[max number of threads]:n' \
  '-xml[output log file in XML format]' \
  '-refmac[name of REFMAC binary executable]:binary' \
  '-nmr[input structure is an NMR/MD ensemble]' \
  '-merge[treat oligomers/complexes as individual units]' \
  '-p1[location of target PDB file(s)]:file:_files' \
  '-p2[location of secondary reference PDB file(s)]:file:_files' \
  '-c1[chains of interest in PDB file 1]:chains' \
  '-c2[chains of interest in PDB file 2]:chains' \
  '-id[chains are sequence-identical]' \
  '-allonall[use full matrix of chain combinations]' \
  '-align[specify residue ranges to use]:ranges' \
  '-align_rm[specify individual residues to remove]:residues' \
  '-lib[align all fragments in the ProSMART library]' \
  '-helix[align only helix entry in library]' \
  '-strand[align only strand entry in library]' \
  '-library_config[alternate library configuration file]:file:_files' \
  '-library[location of alternate library directory]:dir:_files -/' \
  '-len[length of fragment in residues]:n' \
  '-score[Procrustes score dissimilarity threshold]:val' \
  '-superpose[score threshold for superposition fragments]:val' \
  '-no_reward_seq[pure structure-based alignment]' \
  '-reward_seq[fixed dissimilarity for identical residues]:val' \
  '-skip_refine[skip alignment refinement]' \
  '-cluster_skip[disable rigid substructure identification]' \
  '-cluster_score[Procrustes threshold for clustering]:val' \
  '-cluster_min[minimum number of fragments in cluster]:n' \
  '-quick[do not output superposed PDB files and PyMOL scripts]' \
  '-out_pdb[output superposed PDB files]' \
  '-out_color[output PyMOL colour code scripts]' \
  '-self_restrain[self-restraints ignoring secondary structures]' \
  '-restrain_all[restraints for all target chains]' \
  '-restrain_best[use only the best external reference chain]' \
  '-rmax[maximum restraint distance sphere]:val' \
  '-rmin[minimum restraint distance]:val' \
  '-sigma[default sigma for distance restraints]:val' \
  '-weight[scale sigmas for restraint weighting]:val' \
  '-main[restraints only for main chain atoms]' \
  '-side[restraints for main and side chain atoms]' \
  '-h[generate generic bond restraints (H-bonds)]' \
  '-bond[generate generic bond restraints]' \
  '-strict[require strict structural conservation]' \
  '-alpha[restraints for alpha-helices]' \
  '*:file:_files' && ret=0

return ret
