#compdef CometAdapter
# OpenMS TOPP: adapter for the Comet peptide identification engine

local ret=1

_arguments -s -S \
  '-in[MS/MS input file]:input file:_files' \
  '-out[output file (idXML)]:output file:_files' \
  '-database[FASTA protein sequence file]:fasta:_files' \
  '-comet_executable[path to Comet executable]:exe:_files' \
  '-pin_out[Percolator input file (TSV)]:file:_files' \
  '-precursor_mass_tolerance[monoisotopic mass tolerance]:value:' \
  '-precursor_error_units[tolerance units]:unit:(ppm amu Da)' \
  '-fragment_mass_tolerance[MS/MS bin size tolerance]:value:' \
  '-fragment_bin_offset[fragment bin offset]:value:' \
  '-isotope_error[account for isotope errors]:value:' \
  '-instrument[instrument type]:type:(high_res low_res)' \
  '-enzyme[protease for digestion]:enzyme:' \
  '-num_enzyme_termini[cleavage site specificity]:spec:' \
  '-missed_cleavages[allowed missed cleavage sites]:n:' \
  '-min_peptide_length[minimum length]:n:' \
  '-max_peptide_length[maximum length]:n:' \
  '-fixed_modifications[static modifications]:mods:' \
  '-variable_modifications[dynamic modifications]:mods:' \
  '-num_hits[PSMs to report per spectrum]:n:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
