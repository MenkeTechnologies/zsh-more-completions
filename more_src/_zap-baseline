#compdef zap-baseline
# Documentation: https://www.zaproxy.org/docs/docker/baseline-scan/
# Reference accessed: 2026-05-21
# Verified: upstream ZAP docs at the URL above.

# ZAP baseline: passive scan of target site (Docker entrypoint / standalone python)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-t[target URL (including protocol)]:url:' \
  '-c[config file]:file:_files' \
  '-u[remote config URL]:url:' \
  '-g[generate config file]:file:_files' \
  '-m[minutes for spidering (default 1)]:n:' \
  '-r[generate HTML report]:file:_files' \
  '-w[generate Markdown report]:file:_files' \
  '-x[generate XML report]:file:_files' \
  '-J[generate JSON report]:file:_files' \
  '-a[include alpha passive scan rules]' \
  '-d[debug]' \
  '-P[zap port]:port:' \
  '-D[delay (seconds) for passive scanning]:n:' \
  '-i[set unlisted rules to INFO level]' \
  '-I[suppress failure on warnings]' \
  '-j[use ajax spider]' \
  '-l[minimum alert level]:level:(PASS IGNORE INFO WARN FAIL)' \
  '-n[zap context file]:file:_files' \
  '-p[progress file]:file:_files' \
  '-s[short output (no PASSes)]' \
  '-T[max startup/scan time (mins)]:mins:' \
  '-U[username for authenticated scans]:user:' \
  '-z[zap options]:opts:' \
  '--hook=[custom Python hooks file]:file:_files' \
  '--auto[use automation framework if supported]' \
  '--autooff[disable automation framework]' \
  '--plan-only[generate automation plan without execution]' \
  '*::zap-baseline args:_files' && ret=0
return ret
