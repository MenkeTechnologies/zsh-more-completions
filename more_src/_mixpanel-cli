#compdef mixpanel-cli mixpanel
# _mixpanel-cli — Mixpanel mixpanel-cli CLI command-line frontend wrapping the Mixpanel product analytics platform REST API managing projects events users cohorts dashboards reports retention funnels insights flows people-profiles import-events service-account-API-secret data-export taxonomy lexicon group-analytics A-B experiments (Mixpanel team, Go); cobra
# upstream: https://mixpanel.com/

_mixpanel-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'project:project operations'
        'event:event operations'
        'user:user operations'
        'cohort:cohort operations'
        'dashboard:dashboard operations'
        'report:report operations'
        'retention:retention reports'
        'funnel:funnel operations'
        'flow:flow operations'
        'insight:insight operations'
        'people:people profiles'
        'group:group profile operations'
        'experiment:experiment operations'
        'lexicon:lexicon taxonomy operations'
        'import:import events'
        'export:export data'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--api-secret=+[secret]:str:' \
        '--service-account-username=+[user]:str:' \
        '--service-account-password=+[password]:str:' \
        '--api-url=+[url]:str:' \
        '--region=+[r]:r:(us eu)' \
        '--project-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table jsonlines)' \
        '--format=+[format]:f:(json yaml csv table jsonlines)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mixpanel-cli subcommand' sub ;;
        args)
            case $words[1] in
                project|event|user|cohort|dashboard|report|funnel|flow|insight|people|group|experiment|lexicon) _arguments '1:op:(list get create update delete)' '*:id:' ;;
                import|export) _arguments '*:file:_files -g "*.json *.csv *.gz *.jsonl"' ;;
            esac
            ;;
    esac
}

_mixpanel-cli "$@"
