#compdef ausearch
# _ausearch — Linux audit ausearch (search audit log file for matching events; -a auid, -ac comm, -e exit, -if input file, -k key, -m message type csv (e.g. SYSCALL,AVC), -p pid, -pp ppid, -r raw, -s success/failed, -se sentence, -sv valid timestamp, -te end time, -ts start time, -ui uid, -un username, -ua action, -ul login uid, -x executable, -v version, -hwid id, --tty)
# upstream: https://github.com/linux-audit/audit-userspace
# Flags from linux-audit/audit-userspace src/ausearch.c on tip.

_ausearch() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-a+[auid]:auid:' \
        '-ac+[comm]:comm:' \
        '-c+[checkpoint]:file:_files' \
        '-e+[exit]:exit:' \
        '-i[interpret]' \
        '-if+[input file]:file:_files' \
        '*-k+[key]:key:' \
        '-m+[message types csv]:types:' \
        '-p+[pid]:pid:_pids' \
        '-pp+[ppid]:ppid:_pids' \
        '-r[raw]' \
        '-sv+[valid]:bool:(yes no)' \
        '-w+[node]:node:' \
        '-ts+[start time]:time:' \
        '-te+[end time]:time:' \
        '-ui+[uid]:uid:' \
        '-un+[username]:user:_users' \
        '-ua+[action]:action:' \
        '-ul+[login uid]:auid:' \
        '-x+[executable]:exe:_command_names -e' \
        '-hi+[host id]:id:' \
        '--tty[tty events]' \
        '--just-one[first match only]' \
        '--checkpoint+[file]:file:_files' \
        '--success+[success]:bool:(yes no)' \
        '--format+[output format]:format:(raw default text interpret csv)' \
        '-l[show child events]'
}

_ausearch "$@"
