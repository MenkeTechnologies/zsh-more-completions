#compdef momento

# Zsh completion for Momento CLI
# https://github.com/momentohq/momento-cli

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'configure:Set up Momento API key and defaults'
  'cache:Manage caches'
  'topic:Work with Momento Topics (Pub/Sub)'
  'account:Manage Momento account'
)

_arguments -s -S \
  '--profile=[use a specific configuration profile]:profile:' \
  '--format=[output format]:format:(json text)' \
  '--help[show help message]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'momento command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (cache)
        _arguments -s -S \
          '1:subcommand:(create list delete set get delete-key)' \
          '--cache=[specify cache name]:cache:' \
          '--key=[key to operate on]:key:' \
          '--value=[value to store]:value:' \
          '--ttl=[time-to-live in seconds]:ttl:' && ret=0
        ;;
      (topic)
        _arguments -s -S \
          '1:subcommand:(publish subscribe)' \
          '--cache=[specify cache name]:cache:' \
          '--topic=[topic name]:topic:' \
          '--value=[value to publish]:value:' && ret=0
        ;;
      (account)
        _arguments -s -S '1:subcommand:(signup)' && ret=0
        ;;
    esac
    ;;
esac

return ret
