#compdef istioctl
# _istioctl-cli — Istio service mesh CLI (Istio project, Go); install/manage Istio control plane + envoy sidecars
# upstream: https://github.com/istio/istio

_istioctl-cli() {
    local -a sub=(
        'admin:istiod admin commands'
        'analyze:analyze configuration'
        'authz:authorization debugging'
        'bug-report:create bug report'
        'completion:print shell completion'
        'create-remote-secret:create remote cluster secret'
        'dashboard:open Istio dashboards'
        'd:alias for dashboard'
        'experimental:experimental commands'
        'install:install Istio'
        'kube-inject:inject Envoy sidecar'
        'manifest:operate on manifests'
        'profile:profile commands'
        'proxy-config:retrieve proxy config'
        'pc:alias for proxy-config'
        'proxy-status:get proxy status'
        'ps:alias for proxy-status'
        'remote-clusters:list remote clusters'
        'tag:manage revision tags'
        'uninstall:uninstall Istio'
        'upgrade:upgrade Istio'
        'validate:validate config files'
        'verify-install:verify install'
        'version:show version'
        'waypoint:waypoint proxy commands'
        'wait:wait for resources to sync'
        'workload:workload commands'
        'x:alias for experimental'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--context+[kube context]:context:' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '-i+[istio namespace]:ns:' \
        '--istioNamespace+[istio namespace]:ns:' \
        '-n+[namespace]:ns:' \
        '--namespace+[namespace]:ns:' \
        '--log_output_level+[log output level]:str:' \
        '--log_target+[log target]:targets:' \
        '--log_caller+[log caller]:caller:' \
        '--log_stacktrace_level+[log stacktrace level]:level:' \
        '--vklog+[vklog level]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'istioctl subcommand' sub ;;
        args)
            case $words[1] in
                proxy-config|pc) _arguments '1:config:(all bootstrap cluster endpoint listener log route secret)' '*:pod:' ;;
                proxy-status|ps) _arguments '*:pod:' ;;
                dashboard|d) _arguments '1:dashboard:(controlz envoy grafana jaeger kiali prometheus zipkin)' '*:pod:' ;;
                analyze) _arguments \
                    '-A[analyze all namespaces]' \
                    '--all-namespaces[all namespaces]' \
                    '--color+[color]:color:(always never auto)' \
                    '--failure-threshold+[failure threshold]:level:(Info Warning Error)' \
                    '-L+[suppress messages]:str:' \
                    '--list-analyzers[list analyzers]' \
                    '--output-threshold+[output threshold]:level:' \
                    '-o+[output format]:fmt:(json log sarif yaml)' \
                    '--output+[output format]:fmt:' \
                    '-R+[recursive]' \
                    '--recursive[recursive]' \
                    '--revision+[revision]:rev:' \
                    '-S+[suppress messages]:str:' \
                    '-t+[timeout]:duration:' \
                    '--timeout+[timeout]:duration:' \
                    '--use-kube[use kube state]' \
                    '--verbose[verbose]' \
                    '*:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_istioctl-cli "$@"
