#compdef qingcloud
# Documentation: https://github.com/yunify/qingcloud-cli
# Command Line Interface for QingCloud

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version information]' \
  '-f+[specify a custom configuration file path]:file:_files' \
  '-z+[set the zone/region]:zone' \
  '*:command:((iaas\:"manage infrastructure resources" qs\:"manage object storage services" configure\:"set up configuration"))' && ret=0

return ret
