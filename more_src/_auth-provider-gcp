#compdef auth-provider-gcp
# _auth-provider-gcp — Kubelet credential provider for GCR / Artifact Registry
# upstream: https://github.com/kubernetes/cloud-provider-gcp
# Flags from cmd/auth-provider-gcp/app/getcredentials.go on tip.

_auth-provider-gcp() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'get-credentials:retrieve auth credentials per Kubelet credential-provider protocol'
            )
            _describe -t commands command cmds
            ;;
        args)
            _arguments \
                '(-a --authFlow)'{-a,--authFlow=}'[authentication flow]:flow:(gcr-auth-flow dockerConfig dockerConfigUrl)' \
                '-v[klog verbosity level]:n:'
            ;;
    esac
}

_auth-provider-gcp "$@"
