#compdef kotori
# _kotori — Daniel Mussbach Kotori multi-channel multi-protocol generic data acquisition and telemetry storage platform (daq-tools team, Python); docopt
# upstream: https://github.com/daq-tools/kotori

_kotori() {
    local -a sub=(
        'serve:run the Kotori daemon'
        'init:create a sample configuration'
        'list:list channels'
        'subscribe:subscribe to a channel'
        'publish:publish to a channel'
        'show:show settings'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.ini *.conf"' \
        '-c+[config file]:file:_files -g "*.ini *.conf"' \
        '--profile=+[profile name]:str:' \
        '-p+[profile name]:str:' \
        '--debug[debug mode]' \
        '--debug-mqtt[debug mqtt]' \
        '--debug-influx[debug influx]' \
        '--debug-amqp[debug amqp]' \
        '--debug-grafana[debug grafana]' \
        '--debug-io[debug io]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--logfile=+[log file]:file:_files' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kotori subcommand' sub ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--http-port=+[port]:port:_ports' \
                    '--mqtt-host=+[host]:host:_hosts' \
                    '--mqtt-port=+[port]:port:_ports' \
                    '--influx-host=+[host]:host:_hosts' \
                    '--influx-port=+[port]:port:_ports' ;;
                subscribe|publish) _arguments \
                    '--channel=+[channel]:str:' \
                    '--topic=+[mqtt topic]:str:' \
                    '*:message:' ;;
                init) _arguments '*:dir:_files -/' ;;
            esac
            ;;
    esac
}

_kotori "$@"
