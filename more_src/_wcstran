#compdef wcstran
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss211.html
# KAPPA WCSTRAN - transform a position from one NDF coordinate Frame to another

local ret=1

_arguments -C \
  'NDF=[NDF containing the required coordinate Frames]:NDF file:_files' \
  'POSIN=[input coordinates to transform]:position:' \
  'FRAMEIN=[Frame in which the input position is supplied]:frame:' \
  'FRAMEOUT=[Frame in which the transformed position is required]:frame:' \
  'EPOCHIN=[epoch for the input celestial position]:epoch:' \
  'EPOCHOUT=[epoch for the output celestial position]:epoch:' \
  'QUIET=[do not write the transformed position to screen]:flag:(TRUE FALSE)' \
  'SKYDEG=[decimal-degree formatting for celestial axes]:flag:(TRUE FALSE)' \
  '*:NDF file:_files' && ret=0

return ret
