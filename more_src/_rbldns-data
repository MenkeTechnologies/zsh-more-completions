#compdef rbldns-data
# _rbldns-data — djbdns rbldns-data (compile the `data` text file into `data.cdb` for rbldns(8); zone is a flat list of CIDR ranges + TXT records used as a DNSBL)
# upstream: https://github.com/dterweij/ndjbdns
# Flags from rbldns-data.c on tip; no positional args — looks for ./data.

_rbldns-data() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]'
}

_rbldns-data "$@"
