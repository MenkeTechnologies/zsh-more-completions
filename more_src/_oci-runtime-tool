#compdef oci-runtime-tool
# Documentation: https://github.com/opencontainers/runtime-tools/blob/master/man/oci-runtime-tool-generate.1.md
# OCI (Open Container Initiative) runtime tooling - generate and validate runtime bundles

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--host-specific[generate or validate host-specific configuration]' \
  '--log-level=[set the logging level]:level:(debug info warn error fatal panic)' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'oci-runtime-tool command' \
      'generate[generate an OCI runtime spec configuration JSON]' \
      'validate[validate an OCI bundle]' && ret=0
    ;;
  args)
    case $line[1] in
      generate)
        _arguments -s \
          '*--args=[arguments to run within the container]:args' \
          '--domainname=[set the container domain name]:domainname' \
          '*--env=[set environment variables e.g. key=value]:env' \
          '--env-file=[load environment variables from a file]:file:_files' \
          '--hostname=[set the container host name]:hostname' \
          '*--hooks-poststart-add=[add a poststart hook]:hook' \
          '--hooks-poststart-remove-all[remove all poststart hooks]' \
          '*--hooks-poststop-add=[add a poststop hook]:hook' \
          '--hooks-poststop-remove-all[remove all poststop hooks]' \
          '*--hooks-prestart-add=[add a prestart hook]:hook' \
          '--hooks-prestart-remove-all[remove all prestart hooks]' \
          '*--label=[add annotations to the configuration e.g. key=value]:label' \
          '--output=[write configuration JSON to a file at PATH]:path:_files' \
          '--privileged[grant extended privileges to the container]' \
          '*--process-cap-add=[add a Linux capability]:cap' \
          '--process-cwd=[current working directory for the process]:cwd' \
          '--process-gid=[group ID for container processes]:gid' \
          '--process-terminal[attach a terminal to the process]' \
          '--process-uid=[UID used within the container]:uid' \
          '--rootfs-path=[path to the rootfs]:path:_files -/' \
          '--rootfs-readonly[mount the root filesystem as read only]' && ret=0
        ;;
      validate)
        _arguments -s \
          '--path=[path to bundle]:path:_files -/' \
          '--platform=[platform of the target bundle]:platform:(linux windows solaris)' && ret=0
        ;;
    esac
    ;;
esac

return ret
