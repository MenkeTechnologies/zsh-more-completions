#compdef petscmpiexec
# Documentation: https://gitlab.com/petsc/petsc/-/blob/main/lib/petsc/bin/petscmpiexec
# PETSc wrapper around mpiexec adding valgrind / debugger support

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage and exit]' \
  '-valgrind[run program under valgrind memcheck]' \
  '-debugger[run program under debugger]' \
  '(-n -np)'{-n,-np}'[number of processors]:numprocs' \
  '-hosts[comma-separated list of hosts]:hosts:_hosts' \
  '*:program:_files' && ret=0

return ret
