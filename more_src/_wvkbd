#compdef wvkbd
# Documentation: https://github.com/jjsullivan5196/wvkbd/blob/master/wvkbd.1.scd
# wvkbd: an on-screen keyboard for wlroots Wayland compositors

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage help]' \
  '--version[print version information]' \
  '-D[enable debug mode]' \
  '-o[print pressed keys to standard output]' \
  '-O[print intersected keys to standard output]' \
  '-l[comma separated list of layers in portrait mode]:layers:_default' \
  '--landscape-layers[comma separated list of layers in landscape mode]:layers:_default' \
  '--list-layers[print a list of all available layers]' \
  '-H[height of the keyboard in pixels (portrait)]:pixels:_default' \
  '-L[height of the keyboard in pixels (landscape)]:pixels:_default' \
  '--fn[set font and size]:font:_default' \
  '--hidden[start hidden (send SIGUSR2 to show)]' \
  '--non-exclusive[allow overlap, do not request exclusive zone]' \
  '--alpha[set alpha (transparency) for all colors 0-255]:int:_default' \
  '--bg[set color of background]:color:_default' \
  '--fg[set color of keys]:color:_default' \
  '--fg-sp[set color of special keys]:color:_default' \
  '--press[set color of pressed keys]:color:_default' \
  '--press-sp[set color of pressed special keys]:color:_default' \
  '--swipe[set color of swiped keys]:color:_default' \
  '--swipe-sp[set color of swiped special keys]:color:_default' \
  '--text[set color of text on keys]:color:_default' \
  '--text-sp[set color of text on special keys]:color:_default' && ret=0

return ret
