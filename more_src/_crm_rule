#compdef crm_rule
# Documentation: https://man.archlinux.org/search?q=crm_rule
# Reference accessed: 2026-05-16

# crm_rule: test rule expressions in CIB context
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '-c[check rule]' \
  '--check[check rule]' \
  '-r[rule id]:id:' \
  '--rule=[rule id]:id:' \
  '-X[supply CIB XML inline]:xml:' \
  '--xml-text=[supply CIB XML inline]:xml:' \
  '-x[supply CIB from file]:file:_files' \
  '--xml-file=[supply CIB from file]:file:_files' \
  '-p[supply CIB on stdin]' \
  '--xml-pipe[supply CIB on stdin]' \
  '-d[reference date for rule]:datetime:' \
  '--date=[reference date for rule]:datetime:' \
  '--output-as=[output format]:fmt:(text xml html)' \
  '*::crm_rule args:_files' && ret=0
return ret
