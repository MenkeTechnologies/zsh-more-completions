#compdef crm_rule
# Documentation: https://www.mankier.com/8/crm_rule
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crm_rule: test rule expressions against the Pacemaker CIB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-output[show output help]' \
  '(- *)--help-modes[show modes of operation]' \
  '(- *)--help-data[show data options]' \
  '(- *)--help-additional[show additional options]' \
  '(- *)'{-\$,--version}'[display software version]' \
  '*'{-V,--verbose}'[increase debug output]' \
  '--output-as=[output format]:fmt:(text xml)' \
  '--output-to=[output file (- for stdout)]:file:_files' \
  '(-c --check)'{-c,--check}'[check whether a rule is in effect]' \
  '(-X --xml-text)'{-X+,--xml-text=}'[use argument for XML (- for stdin)]:xml:' \
  '(-d --date)'{-d+,--date=}'[whether rule is in effect on given date]:date:' \
  '*'{-r+,--rule=}'[rule ID to check]:id:' && ret=0
return ret
