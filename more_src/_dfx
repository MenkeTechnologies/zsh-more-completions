#compdef dfx

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build canister from source'
  'cache:manage dfx version cache'
  'canister:manage canisters'
  'deploy:deploy canisters to the network'
  'generate:generate type declarations'
  'identity:manage identities'
  'info:show information about the project'
  'ledger:interact with the ledger canister'
  'new:create a new project'
  'nns:manage NNS canisters'
  'ping:ping the Internet Computer network'
  'quickstart:perform initial one-time setup'
  'schema:print dfx.json schema'
  'start:start the local replica'
  'stop:stop the local replica'
  'upgrade:upgrade dfx'
  'wallet:manage cycles wallet'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--identity=[identity to use]:identity' \
  '--network=[network to use]:network:(local ic)' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-q[quiet output]' \
  '--quiet[quiet output]' \
  '--log=[log level]:level:(stderr trace debug info warning error critical off)' \
  '--logfile=[log file]:file:_files' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'dfx command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (new)
        _arguments \
          '--type=[project type]:type:(motoko rust)' \
          '--frontend=[frontend framework]:framework:(vanilla react vue svelte none)' \
          '--dry-run[do not write files]' \
          '--no-frontend[do not include frontend]' \
          '1:project name' && ret=0
        ;;
      (deploy)
        _arguments \
          '--argument=[argument to pass to canister]:argument' \
          '--network=[network to deploy to]:network:(local ic)' \
          '--with-cycles=[cycles to use]:cycles' \
          '--yes[skip confirmation prompts]' \
          '--no-wallet[bypass wallet]' \
          '--mode=[install mode]:mode:(install reinstall upgrade auto)' \
          '*:canister name' && ret=0
        ;;
      (canister)
        local -a canister_cmds=(
          'call:call a canister method'
          'create:create a new canister'
          'delete:delete a canister'
          'deposit-cycles:deposit cycles to a canister'
          'id:show canister identifier'
          'info:show canister information'
          'install:install canister code'
          'logs:show canister logs'
          'metadata:show canister metadata'
          'request-status:request call status'
          'send:send a signed message'
          'sign:sign a message'
          'snapshot:manage canister snapshots'
          'start:start a canister'
          'status:show canister status'
          'stop:stop a canister'
          'uninstall-code:uninstall canister code'
          'update-settings:update canister settings'
          'url:show canister URL'
        )
        _arguments \
          '1:canister command:_describe -t canister-cmds "canister command" canister_cmds' \
          '*:arguments' && ret=0
        ;;
      (identity)
        local -a identity_cmds=(
          'deploy-wallet:deploy a wallet canister'
          'get-principal:show principal of identity'
          'get-wallet:show wallet canister'
          'import:import an identity'
          'list:list all identities'
          'new:create a new identity'
          'remove:remove an identity'
          'rename:rename an identity'
          'set-wallet:set wallet canister'
          'use:set active identity'
          'whoami:show active identity name'
        )
        _arguments \
          '1:identity command:_describe -t identity-cmds "identity command" identity_cmds' \
          '*:arguments' && ret=0
        ;;
      (start)
        _arguments \
          '--background[run in background]' \
          '--clean[clean state before starting]' \
          '--host=[host to listen on]:host' \
          '--enable-bitcoin[enable Bitcoin integration]' \
          '--enable-canister-http[enable HTTP outcalls]' \
          '--artificial-delay=[artificial delay in ms]:ms' && ret=0
        ;;
      (build)
        _arguments \
          '--all[build all canisters]' \
          '--check[check syntax only]' \
          '*:canister name' && ret=0
        ;;
      (generate)
        _arguments '*:canister name' && ret=0
        ;;
      (ledger)
        local -a ledger_cmds=(
          'account-id:show account identifier'
          'balance:show ICP balance'
          'create-canister:create canister from ICP'
          'fabricate-cycles:fabricate cycles (local only)'
          'notify:notify transfer'
          'show-subnet-types:show subnet types'
          'top-up:top up a canister with cycles'
          'transfer:transfer ICP'
        )
        _arguments \
          '1:ledger command:_describe -t ledger-cmds "ledger command" ledger_cmds' \
          '*:arguments' && ret=0
        ;;
      (wallet)
        local -a wallet_cmds=(
          'addresses:show wallet addresses'
          'balance:show wallet balance'
          'controllers:show wallet controllers'
          'custodians:show wallet custodians'
          'deauthorize:deauthorize a principal'
          'name:show or set wallet name'
          'send:send cycles to another wallet'
          'upgrade:upgrade wallet canister'
        )
        _arguments \
          '1:wallet command:_describe -t wallet-cmds "wallet command" wallet_cmds' \
          '*:arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
