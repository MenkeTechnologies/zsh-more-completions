# _bbmap — Brian Bushnell JGI BBTools BBMap fast split-read aligner with auxiliary BBDuk BBNorm Reformat utilities (jgi team, Java); custom argparse
# upstream: https://sourceforge.net/projects/bbmap/

_bbmap() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-Xmx+[Java max heap]:str:' \
        '-Xms+[Java min heap]:str:' \
        '-da[disable assertions]' \
        '-eoom[exit on out of memory]' \
        '-ea[enable assertions]' \
        'in=+[input file 1]:file:_files -g "*.fq *.fq.gz *.fastq *.fastq.gz *.fa *.fasta *.fa.gz *.fasta.gz *.sam *.bam"' \
        'in2=+[input file 2]:file:_files' \
        'out=+[output file]:file:_files' \
        'out1=+[output file 1]:file:_files' \
        'out2=+[output file 2]:file:_files' \
        'outm=+[mapped output]:file:_files' \
        'outu=+[unmapped output]:file:_files' \
        'ref=+[reference fasta]:file:_files -g "*.fa *.fasta *.fa.gz *.fasta.gz"' \
        'path=+[index path]:dir:_files -/' \
        'build=+[index id]:n:' \
        'k=+[kmer length]:n:' \
        'threads=+[N]:n:' \
        't=+[N]:n:' \
        'maxindel=+[N]:n:' \
        'minid=+[F]:f:' \
        'idfilter=+[F]:f:' \
        'minratio=+[F]:f:' \
        'midpad=+[N]:n:' \
        'usequality=+[bool]:b:(t f)' \
        'minreadlength=+[N]:n:' \
        'maxbasesout=+[N]:n:' \
        'maxbasesoutm=+[N]:n:' \
        'reads=+[N]:n:' \
        'startfromfirst=+[bool]:b:(t f)' \
        'fast=+[bool]:b:(t f)' \
        'slow=+[bool]:b:(t f)' \
        'vslow=+[bool]:b:(t f)' \
        'kfilter=+[N]:n:' \
        'samestrandpairs=+[bool]:b:(t f)' \
        'maxsites=+[N]:n:' \
        'overwrite=+[bool]:b:(t f)' \
        'ow=+[bool]:b:(t f)' \
        'append=+[bool]:b:(t f)' \
        'ambiguous=+[mode]:m:(random toss best all)' \
        'mapper=+[mode]:m:(bbmap bbmapskimmer)' \
        'qhdist=+[F]:f:' \
        'rqc=+[bool]:b:(t f)' \
        'qtrim=+[mode]:m:(lr l r f t)' \
        'trimq=+[N]:n:' \
        'minkmerhits=+[N]:n:' \
        'rescue=+[bool]:b:(t f)' \
        'nodisk=+[bool]:b:(t f)' \
        'pairlen=+[N]:n:' \
        'tip=+[N]:n:' \
        'pacbio=+[bool]:b:(t f)' \
        'ordered=+[bool]:b:(t f)' \
        'unpigz=+[bool]:b:(t f)' \
        'pigz=+[bool]:b:(t f)'
}

_bbmap "$@"
