#compdef kuberhealthy
# _kuberhealthy — Kuberhealthy v3 operator (synthetic-check runner for Kubernetes clusters; reconciles KuberhealthyCheck CRs into Jobs)
# upstream: https://github.com/kuberhealthy/kuberhealthy
# Source: cmd/kuberhealthy/{main,config}.go on tip; no CLI flags — runtime config is env-driven (KH_LISTEN_ADDRESS, KH_LISTEN_ADDRESS_TLS, KH_LOG_LEVEL, KH_MAX_JOB_AGE, KH_MAX_CHECK_POD_AGE, KH_MAX_COMPLETED_POD_COUNT, KH_MAX_ERROR_POD_COUNT, KH_ERROR_POD_RETENTION_TIME, KH_TARGET_NAMESPACE, KH_DEFAULT_RUN_INTERVAL, KH_DEFAULT_CHECK_TIMEOUT, KH_TERMINATION_GRACE_PERIOD, KH_TLS_CERT_FILE, KH_TLS_KEY_FILE, KH_LEADER_ELECTION_*, POD_NAMESPACE).

_kuberhealthy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_kuberhealthy "$@"
