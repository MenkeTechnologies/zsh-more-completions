#compdef pkdumpimg
# Documentation: https://pktools.nongnu.org/html/pkdumpimg.html
# dump raster image to ASCII

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[input image file]:file:_files' \
  '(-o --output)'{-o,--output}'[Output ascii file (Default is empty\: use stdout]:file:_files' \
  '(-of --oformat)'{-of,--oformat}'[Output format (matrix form or list (x,y,z) form. Default is matrix for]:value:' \
  '(-b --band)'{-b,--band}'[band index to crop]:value:' \
  '(-e --extent)'{-e,--extent}'[get boundary from extent from polygons in vector file]:value:' \
  '(-ulx --ulx)'{-ulx,--ulx}'[Upper left x value bounding box (in geocoordinates if georef is true)]:value:' \
  '(-uly --uly)'{-uly,--uly}'[Upper left y value bounding box (in geocoordinates if georef is true)]:value:' \
  '(-lrx --lrx)'{-lrx,--lrx}'[Lower left x value bounding box (in geocoordinates if georef is true)]:value:' \
  '(-lry --lry)'{-lry,--lry}'[Lower left y value bounding box (in geocoordinates if georef is true)]:value:' \
  '(-dx --dx)'{-dx,--dx}'[Output resolution in x (in meter) (0.0\: keep original resolution)]:value:' \
  '(-dy --dy)'{-dy,--dy}'[Output resolution in y (in meter) (0.0\: keep original resolution)]:value:' \
  '(-r --resampling-method)'{-r,--resampling-method}'[Resampling method (near\: nearest neighbour, bilinear\: bi-linear interp]:value:' \
  '(-srcnodata --srcnodata)'{-srcnodata,--srcnodata}'[set no data value(s) for input image]:value:' \
  '(-dstnodata --dstnodata)'{-dstnodata,--dstnodata}'[nodata value for output if out of bounds.]:value:' \
  '*:file:_files' && ret=0

return ret
