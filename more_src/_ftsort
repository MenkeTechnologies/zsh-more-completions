#compdef ftsort
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftsort.html
# Sort the rows in a FITS table

local ret=1

_arguments -s -S \
  'infile=[input FITS file with optional extension/filters]:infile:_files' \
  'outfile=[output sorted table file]:outfile:_files' \
  'columns=[columns to sort by, minus prefix for descending]:columns:' \
  'method=[sort algorithm]:method:(heap shell insert merge)' \
  'memory=[load whole table into RAM]:memory:(yes no)' \
  'unique=[remove duplicate sort-key rows]:unique:(yes no)' \
  'copyall=[copy all HDUs or just sorted table]:copyall:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'startrow=[first row to sort, 0 for first]:startrow:' \
  'nrows=[number of rows to sort, 0 for all]:nrows:' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[record parameters as HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
