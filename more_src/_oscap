#compdef oscap oscap-ssh oscap-vm oscap-podman oscap-docker oscap-chroot
# Documentation: https://man.archlinux.org/search?q=oscap
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (oscap)
    local -a modules
    modules=(
      'cpe:CPE module'
      'cvss:CVSS module'
      'cve:CVE module'
      'cvrf:CVRF module'
      'ds:datastream module'
      'info:show info on file'
      'oval:OVAL module'
      'xccdf:XCCDF module'
      'sce:SCE module'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '*--verbose=[verbosity]:l:(DEVEL INFO WARNING ERROR)' \
      '*--verbose-log-file=[log file]:file:_files' \
      '1: :->module' \
      '*::arg:->args' && ret=0
    case $state in
      (module) _describe -t mods 'oscap module' modules && ret=0 ;;
      (args)
        case $line[1] in
          (xccdf)
            _arguments \
              '1:cmd:(eval generate remediate resolve validate validate-xml export-oval-variables)' \
              '*--profile=[profile]:p:' \
              '*--results=[results file]:file:_files' \
              '*--results-arf=[ARF results]:file:_files' \
              '*--report=[report file]:file:_files' \
              '*--cpe=[CPE dictionary]:file:_files' \
              '*--oval-results[oval results]' \
              '*--check-engine-results[check engine results]' \
              '*--export-variables[export vars]' \
              '*--remediate[remediate]' \
              '*--datastream-id=[ds id]:id:' \
              '*--xccdf-id=[xccdf id]:id:' \
              '*--benchmark-id=[benchmark id]:id:' \
              '*--rule=[rule]:r:' \
              '*--skip-rule=[skip rule]:r:' \
              '*--tailoring-file=[tailoring file]:file:_files' \
              '*--tailoring-id=[tailoring id]:id:' \
              '*--without-syschar[no syschar]' \
              '*--fetch-remote-resources[fetch remote]' \
              '*--local-files=[local files dir]:dir:_files -/' \
              '*--progress[show progress]' \
              '*--stig-viewer=[STIG viewer]:file:_files' \
              '*: :_files' && ret=0 ;;
          (oval)
            _arguments \
              '1:cmd:(eval collect generate analyse list-probes validate validate-xml)' \
              '*--id=[def id]:id:' \
              '*--variables=[variables]:file:_files' \
              '*--results=[results]:file:_files' \
              '*--report=[report]:file:_files' \
              '*--datastream-id=[ds id]:id:' \
              '*--oval-id=[oval id]:id:' \
              '*--directives=[directives]:file:_files' \
              '*--without-syschar[no syschar]' \
              '*: :_files' && ret=0 ;;
          (ds)
            _arguments \
              '1:cmd:(sds-validate sds-add sds-compose rds-validate rds-create rds-split sds-decompose)' \
              '*: :_files' && ret=0 ;;
          (info)
            _arguments \
              '*--profiles[show profiles]' \
              '*--profile=[profile id]:id:' \
              '*--fetch-remote-resources[fetch remote]' \
              '*: :_files' && ret=0 ;;
          (cpe)
            _arguments \
              '1:cmd:(check match validate validate-xml gen)' \
              '*: :_files' && ret=0 ;;
          (cvss|cve|cvrf|sce)
            _arguments \
              '*: :_files' && ret=0 ;;
          (*) _files ;;
        esac ;;
    esac ;;
  (oscap-ssh|oscap-vm|oscap-podman|oscap-docker|oscap-chroot)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(--ssh-extra-options)--ssh-extra-options=[ssh opts]:opts:' \
      '(--ssh-additional-options)--ssh-additional-options=[ssh opts]:opts:' \
      '*: :_files' && ret=0 ;;
esac

return ret
