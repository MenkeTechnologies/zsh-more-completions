#compdef csvlinter
# ============================================================================
# csvlinter - modern streaming-first CSV
#              validator with JSON Schema support
#              (Go, MIT-style)
#
# Author : csvlinter contributors
# Upstream: https://github.com/csvlinter/csvlinter
#
# `csvlinter` is a CLI tool for validating CSV
# files against:
#   - Structural constraints (delimiter,
#     quoting, encoding correctness)
#   - JSON Schema constraints applied per row
#     (column types, ranges, regex patterns,
#     etc.)
#   - Conventions auto-discovered via schema
#     inference (when no schema is provided)
#
# Designed for CI/CD pipelines, editor
# integrations, and command-line usage.
# Differentiating features vs csvkit / xsv /
# csvtk / csvlens:
#   - Streaming validation (no full-file load
#     into memory; works on 100+ GB CSVs)
#   - JSON Schema-based row validation (each
#     CSV row checked against schema's
#     definitions)
#   - WASM target (browser + Cloudflare Workers
#     deployment)
#   - Auto-discovery of `<csv>.schema.json` or
#     `csvlinter.schema.json` in parent
#     directories
#   - JSON output mode for editor integration
#     (line/column error reporting)
#
# Use cases:
#   - Data ingestion pipelines validating CSV
#     payloads against business-rule schemas
#   - GitHub Actions / GitLab CI: fail build on
#     CSV schema violations
#   - Editor integration (VS Code + neovim) for
#     real-time CSV linting
#   - SBOM CSV data validation (financial
#     records, inventory exports, etc.)
#
# Usage:
#   csvlinter validate <csv-file|-> [flags]
#
# Subcommands (urfave/cli/v2):
#   validate <csv-file or - for STDIN>
#                                  - validate
#                                     a CSV
#                                     file or
#                                     STDIN
#                                     against
#                                     structure +
#                                     optional
#                                     JSON
#                                     Schema
#
# `validate` flags:
#   -s, --schema <file>            - path to
#                                     JSON
#                                     Schema
#                                     file
#                                     (auto-
#                                     discovers
#                                     <csv>.
#                                     schema.
#                                     json or
#                                     csvlinter.
#                                     schema.
#                                     json if
#                                     not
#                                     specified)
#   -o, --output <file>            - output
#                                     file for
#                                     structured
#                                     validation
#                                     results
#                                     (default
#                                     stdout)
#   -f, --format <fmt>             - output
#                                     format
#                                     (pretty/
#                                     json;
#                                     default
#                                     pretty)
#   -d, --delimiter <char>         - CSV
#                                     delimiter
#                                     character
#                                     (default
#                                     comma)
#   -ff, --fail-fast               - stop
#                                     after
#                                     first
#                                     error
#       --max-size <bytes>         - max input
#                                     size when
#                                     reading
#                                     from
#                                     STDIN
#                                     (default
#                                     10MB)
#       --filename <name>          - logical
#                                     filename
#                                     for
#                                     schema
#                                     resolution
#                                     + reporting
#                                     when
#                                     reading
#                                     from
#                                     STDIN
#       --infer-schema             - infer
#                                     JSON
#                                     Schema
#                                     from CSV
#                                     data when
#                                     no schema
#                                     file
#                                     provided
#       --infer-schema-output <file>
#                                  - write
#                                     inferred
#                                     schema to
#                                     file
#
# Global flags:
#   -h, --help                     - print help
#   -v, --version                  - print
#                                     version
#
# Example invocations:
#   csvlinter validate data.csv
#     # validate with auto-discovered schema
#
#   csvlinter validate data.csv -s data.schema.json
#     # explicit schema
#
#   cat data.csv | csvlinter validate -
#     # STDIN input
#
#   csvlinter validate data.csv -f json -o
#     errors.json
#     # JSON output to file
#
#   csvlinter validate data.csv --infer-schema \
#     --infer-schema-output inferred.schema.json
#     # auto-infer schema from data
#
#   csvlinter validate data.csv -d ';' -ff
#     # semicolon-delimited + stop on first
#     # error
#
# Example schema (data.schema.json):
#   {
#     "$schema": "http://json-schema.org/draft-07/schema#",
#     "type": "object",
#     "properties": {
#       "id": {"type": "integer", "minimum": 1},
#       "name": {"type": "string", "minLength": 1},
#       "email": {"type": "string", "format": "email"},
#       "age": {"type": "integer", "minimum": 0, "maximum": 150}
#     },
#     "required": ["id", "name", "email"]
#   }
#
# The santhosh-tekuri/jsonschema lane is built
# on `github.com/santhosh-tekuri/jsonschema/v5
# v5.3.1` (declared verbatim at upstream go.mod
# HEAD as a direct dep, imported by `internal/
# schema/` for JSON Schema compilation + per-
# row validation against the loaded schema),
# the canonical Go JSON Schema validator by
# Santhosh Tekuri - github.com/santhosh-tekuri/
# jsonschema.
#
# Santhosh Tekuri's santhosh-tekuri/jsonschema
# is the de-facto canonical Go JSON Schema
# validator:
#   - Multi-draft support (Draft 4 + 6 + 7 +
#     2019-09 + 2020-12)
#   - High-performance compilation pipeline
#     (schema compiled once + reused)
#   - $ref resolution (local + remote schemas
#     + relative + absolute URIs)
#   - Format validators (date-time + email +
#     uri + ipv4 + ipv6 + uuid + ...)
#   - Custom keyword + format extension
#   - YAML schema support
#   - 1,500+ reverse-deps on pkg.go.dev
#
# santhosh-tekuri/jsonschema's distinguishing
# position vs Go JSON Schema alternatives:
#   - santhosh-tekuri (Tekuri): canonical;
#     multi-draft; high-performance; THIS AXIS
#   - xeipuuv/gojsonschema: older Go JSON
#     Schema validator; primarily Draft 4 +
#     7 support; less actively maintained
#   - qri-io/jsonschema: alternative validator
#     by the qri-io data versioning team
#   - invopop/jsonschema: schema generator (not
#     validator) - generates JSON Schema from
#     Go structs; complementary to validators
#   - kaptinlin/jsonschema: newer alternative
#
# Tekuri's libraries are foundational to many
# Go-based schema-validation tools + spec-
# compliance testers + API gateway
# implementations.
#
# Santhosh Tekuri's broader Go ecosystem
# footprint:
#   - santhosh-tekuri/jsonschema (canonical
#     Go JSON Schema; THIS AXIS)
#   - santhosh-tekuri/raft (canonical Go Raft
#     consensus algorithm implementation;
#     used in distributed databases)
#   - santhosh-tekuri/jpath (JSONPath
#     implementation)
#   - santhosh-tekuri/jpe (JSON Path Editor)
#
# Tekuri's role in Go is *specialized data +
# protocol infrastructure* - similar to:
#   - Y. T. Chung (rust-ini at Axis 268;
#     Shadowsocks + bson) for Rust
#   - Dmitry Dygalo (jsonschema at Axis 277
#     Rust slot) for Rust + Python
#
# Both Tekuri (Go) + Dygalo (Rust/Python) own
# the JSON Schema validation vertical in their
# respective ecosystems. The cross-language
# *protocol/format-specific specialist* pattern
# remains the largest single cluster in
# foundational-library author classification.
#
# Multi-axis canonical-Go author/org cohort
# extension (now spanning 17 distinct
# individuals/orgs):
#   - + Santhosh Tekuri (santhosh-tekuri/
#     jsonschema + raft + jpath; THIS AXIS;
#     specialized JSON Schema + distributed
#     systems infrastructure)
#
# csvlinter uses santhosh-tekuri/jsonschema in
# internal/schema/:
#   ```go
#   import (
#       "github.com/santhosh-tekuri/jsonschema/v5"
#   )
#
#   compiler := jsonschema.NewCompiler()
#   schema, err := compiler.Compile(schemaPath)
#   if err != nil {
#       return err
#   }
#
#   // Validate each row
#   for record := range rowChan {
#       if err := schema.Validate(record); err != nil {
#           handleValidationError(err)
#       }
#   }
#   ```
# The schema is compiled once at startup +
# reused for each CSV row, providing high
# throughput for large CSV file validation.
#
# ----------------------------------------------------------------------------
# AXIS 277 :: JSON Schema validation libraries
#              (JSON Schema Draft 4-2020-12
#              spec compliance + $ref resolution
#              + format validators + custom
#              keyword extensions)
# Round 1530 :: Go slot 2 of 4 :: continues Axis 277
#
# Cross-language canonical library family for this axis:
#   Rust    : Stranger6667/jsonschema     [R1529 _spector]
#             (Dmitry Dygalo; cross-
#              language API testing +
#              validation; Draft 4-2020-12)
#   Go      : santhosh-tekuri/jsonschema   [R1530 THIS FILE]
#             (Santhosh Tekuri; canonical
#              Go JSON Schema; multi-draft;
#              high-performance compilation)
#   TS/Node : ajv-validator/ajv            [R1531 closing]
#             (Evgeny Poberezkin; canonical
#              Node JSON Schema; fastest +
#              most-used in any language;
#              60M+ weekly npm downloads)
#
# Notable parallel: Tekuri (Go) + Dygalo
# (Rust) + Poberezkin (Node) all occupy the
# JSON Schema validation canonical position
# in their respective ecosystems. This is the
# *parallel-individual-specialist canonicals*
# pattern where each language has a single
# canonical author maintaining the JSON
# Schema validator + that library has the
# broadest reverse-dep reach in its ecosystem.
#
# Use-case spectrum across the lanes (so far):
#   - spector (Rust, Stranger6667/jsonschema):
#     supply-chain attestation validation
#     (in-toto + SLSA + SPDX SBOM)
#   - csvlinter (Go, santhosh-tekuri/jsonschema):
#     CSV row-level validation against JSON
#     Schema + structural CSV linting
#
# Both use cases share the *per-record
# validation against a compiled schema*
# pattern - schema is compiled once + reused
# for high-throughput per-record validation.
# This is the canonical pattern for JSON
# Schema deployment in production data
# pipelines.
# ============================================================================

_csvlinter() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-v,--version}'[print version]' \
        '1: :_csvlinter_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                validate)
                    _arguments \
                        '(-s --schema)'{-s,--schema}'[JSON Schema file]:file:_files -g "*.json"' \
                        '(-o --output)'{-o,--output}'[output file for validation results]:file:_files' \
                        '(-f --format)'{-f,--format}'[output format]:format:(pretty json)' \
                        '(-d --delimiter)'{-d,--delimiter}'[CSV delimiter character]:char:' \
                        '(-ff --fail-fast)'{-ff,--fail-fast}'[stop after first error]' \
                        '--max-size=[max input size for STDIN (bytes)]:bytes:' \
                        '--filename=[logical filename for STDIN input]:name:' \
                        '--infer-schema[infer JSON Schema from CSV data]' \
                        '--infer-schema-output=[write inferred schema to file]:file:_files' \
                        '1:csv file:_files -g "*.csv"'
                    ;;
            esac
            ;;
    esac

    return ret
}

_csvlinter_cmds() {
    local -a cmds
    cmds=(
        'validate:validate a CSV file or STDIN against structure + optional schema'
    )
    _describe -t commands 'csvlinter command' cmds
}

_csvlinter "$@"
