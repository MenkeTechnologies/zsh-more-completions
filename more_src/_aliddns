#compdef aliddns
# Documentation: https://github.com/honwen/aliyun-ddns-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# aliddns — `aliddns -h` / `aliddns init --help`

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-v)-v[show version]' \
  '(-c)'{-c+,--config=}'[config path]:file:_files' \
  '*:args:_default' && ret=0

return ret
