#compdef aliddns
# Documentation: https://man.archlinux.org/search?q=aliddns
# Reference accessed: 2026-05-16

# aliddns — `aliddns -h` / `aliddns init --help`

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-v)-v[show version]' \
  '(-c)'{-c+,--config=}'[config path]:file:_files' \
  '*:args:_default' && ret=0

return ret
