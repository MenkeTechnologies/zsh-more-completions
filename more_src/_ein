#compdef ein

# Zsh completion for ein (gitoxide plumbing tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'tool:subcommands for various tools'
  'help:show help for a command'
)

local -a tool_commands=(
  'estimate-hours:estimate hours spent on a repo based on commit history'
  'find:find git repositories'
  'organize:move git repositories into a structured directory layout'
  'query:query information from a git repository'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--threads[number of threads]:count' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ein command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (tool|t)
        _arguments '1:subcommand:->tool_sub' '*:: :->tool_args' && ret=0
        case $state in
          (tool_sub)
            _describe -t commands 'tool command' tool_commands && ret=0
            ;;
          (tool_args)
            case $words[1] in
              (estimate-hours|hours)
                _arguments \
                  '--rev-spec[revision specification]:rev' \
                  '--no-bots[exclude bots from statistics]' \
                  '--file-stats[show file-level statistics]' \
                  '--line-stats[show line-level statistics]' \
                  '--show-pii[show personally identifiable information]' \
                  '--omit-unify-identities[do not unify identities]' \
                  '1:working directory:_files -/' && ret=0
                ;;
              (find)
                _arguments \
                  '1:root directory:_files -/' && ret=0
                ;;
              (organize)
                _arguments \
                  '--execute[actually perform the move]' \
                  '--repository-source[where to find repos]:source:_files -/' \
                  '1:destination:_files -/' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
