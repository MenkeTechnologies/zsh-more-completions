#compdef llama-export-lora
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/tools/export-lora/export-lora.cpp
# Reference accessed: 2026-05-27
# Verified: upstream common_params_parse with LLAMA_EXAMPLE_EXPORT_LORA in common/arg.cpp

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-m --model)'{-m+,--model=}'[base model path]:base model:_files -g "*.gguf"' \
  '(-o --output --output-file)'{-o+,--output=,--output-file=}'[output file]:output file:_files' \
  '--lora=[path to LoRA adapter (comma-separated for multiple)]:lora file:_files -g "*.gguf"' \
  '--lora-scaled=[LoRA adapter with user-defined scaling FNAME:SCALE,...]:lora file' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:threads' \
  '--log-disable[disable logging]' \
  '--log-file=[log to file]:log file:_files' \
  '--log-colors=[colored logging]:mode:(on off auto)' \
  '-v[verbose output]' \
  '--verbose[verbose output]' && ret=0

return ret
