#compdef devtunnel
# Documentation: https://learn.microsoft.com/en-us/azure/developer/dev-tunnels/cli-commands
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for devtunnel (Microsoft Dev Tunnels CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'host:host a dev tunnel'
      'connect:connect to a dev tunnel'
      'create:create a persistent dev tunnel'
      'update:update dev tunnel properties'
      'delete:delete a dev tunnel'
      'delete-all:delete all dev tunnels'
      'list:list dev tunnels'
      'show:show dev tunnel details'
      'token:issue dev tunnel access token'
      'port:manage dev tunnel ports'
      'access:manage access control entries'
      'clusters:list service clusters by location'
      'echo:run a diagnostic echo server'
      'ping:send diagnostic messages to a remote echo server'
      'login:shorthand for user login'
      'logout:shorthand for user logout'
      'set:set default dev tunnel'
      'unset:clear default dev tunnel'
      'user:manage user credentials'
    )
    _describe -t commands 'devtunnel command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (host)
        _arguments \
          '(-p --port)'{-p,--port}'[port to forward]:port' \
          '(-a --allow-anonymous)'{-a,--allow-anonymous}'[allow anonymous access]' \
          '--expiration[tunnel expiration (1h-30d)]:duration' \
          '--protocol[protocol]:protocol:(auto http https)' \
          ':tunnel id:' && ret=0
        ;;
      (create)
        _arguments \
          '(-a --allow-anonymous)'{-a,--allow-anonymous}'[allow anonymous access]' \
          '--expiration[tunnel expiration (1h-30d)]:duration' \
          '(-d --description)'{-d,--description}'[non-searchable description]:description' \
          '--tags[searchable tags]:tags' && ret=0
        ;;
      (port)
        local -a subcmds=(
          'create:create a port'
          'delete:delete a port'
          'list:list ports'
          'show:show port details'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (login)
        _arguments \
          '-d[login with device code]' \
          '-g[login with GitHub]' \
          '-m[login with Microsoft account]' && ret=0
        ;;
    esac
    ;;
esac

return ret
