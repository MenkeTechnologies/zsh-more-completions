#compdef devtunnel

# Zsh completion for devtunnel (VS Code Dev Tunnels CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'host:host a tunnel'
      'connect:connect to a tunnel'
      'create:create a tunnel'
      'delete:delete a tunnel'
      'delete-all:delete all tunnels'
      'list:list tunnels'
      'set:set tunnel properties'
      'show:show tunnel details'
      'token:get tunnel access token'
      'port:manage tunnel ports'
      'cluster:manage clusters'
      'echo:run echo server for testing'
      'limit:manage rate limits'
      'login:login to dev tunnels'
      'logout:logout from dev tunnels'
      'unset:unset tunnel properties'
      'user:manage user settings'
    )
    _describe -t commands 'devtunnel command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (host)
        _arguments \
          '--port[port to forward]:port' \
          '--allow-anonymous[allow anonymous access]' \
          '--expiration[tunnel expiration]:duration' \
          '--protocol[protocol]:protocol:(auto http https ssh)' \
          '--tunnel-id[tunnel ID]:id' && ret=0
        ;;
      (create)
        _arguments \
          '--allow-anonymous[allow anonymous access]' \
          '--expiration[tunnel expiration]:duration' \
          '--description[tunnel description]:description' \
          '--tags[tunnel tags]:tags' && ret=0
        ;;
      (port)
        local -a subcmds=(
          'create:create a port'
          'delete:delete a port'
          'list:list ports'
          'show:show port details'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (login)
        _arguments \
          '-d[login with device code]' \
          '-g[login with GitHub]' \
          '-m[login with Microsoft account]' && ret=0
        ;;
    esac
    ;;
esac

return ret
