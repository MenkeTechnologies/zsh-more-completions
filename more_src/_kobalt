local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 28 flags decoded source-direct from @Parameter
# annotations in Args.kt + Kotlin companion-
# object SEQUENTIAL constant.
_arguments -s -S \
  '(-bf --buildFile)'{-bf+,--buildFile=}'[build file (default: kobalt/src/Build.kt)]:build file:_files -g "*.kt"' \
  '--checkVersions[check if there are any newer versions of the dependencies]' \
  '--client[run as client connecting to existing server]' \
  '--dev[turn on dev mode (more verbose log output)]' \
  '--download[force a download from the downloadUrl in the wrapper]' \
  '--downloadSources[force download of sources and javadocs when resolving deps]' \
  '--dryRun[display all the tasks that will get run without running them]' \
  '--force[force a new server to be launched even if another is running]' \
  '--gc[delete old files]' \
  '(- *)'{--help,--usage}'[display the help]' \
  '(-i --init)'{-i+,--init=}'[invoke the templates named, comma-separated]:templates (comma-separated):' \
  '--listTemplates[list the available templates]' \
  '--log=[define the log level (0-3)]:level:(0 1 2 3)' \
  '--logTags=[comma-separated list of tags to enable logging for]:tags:' \
  '--forceIncremental[force the build to be incremental even if build file modified]' \
  '--noIncremental[turn off incremental builds]' \
  '--noIncrementalKotlin[disable incremental Kotlin compilation]' \
  '--offline[do not try to download dependencies]' \
  '--plugins=[comma-separated list of plug-in Maven ids]:plugin ids:' \
  '--pluginJarFiles=[comma-separated list of plug-in jar files]:jar files:_files -g "*.jar"' \
  '--port=[port number (with --server)]:port:' \
  '--profiles=[comma-separated list of profiles to run]:profiles:' \
  '--profiling[display task timings at the end of the build]' \
  '--projectInfo[display information about the current projects]' \
  '--resolve=[resolve the given dependency and display its tree]:dependency (groupId:artifactId:version):' \
  '--sequential[build all the projects in sequence]' \
  '--server[run in server mode]' \
  '--tasks[display the tasks available for this build]' \
  '--update[update to the latest version of Kobalt]' \
  '(- *)--version[display the current version of Kobalt]' \
  '*:build target:' && ret=0

return ret
