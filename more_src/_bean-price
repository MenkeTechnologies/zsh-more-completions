#compdef bean-price

_arguments -s \
  '(-e --expressions --expression)'{-e,--expressions,--expression}'[interpret as module/symbol]' \
  '*'{-v,--verbose}'[verbose]' \
  '(-d --date)'{-d,--date}'=[date]:date:' \
  '--update[fetch recent past]' \
  '--update-rate=[rate]:rate:(daily weekday weekly)' \
  '--update-compress=[days]:n:' \
  '(-i --inactive)'{-i,--inactive}'[include all commodities]' \
  '(-u --undeclared)'{-u,--undeclared}'=[default source]:source:' \
  '(-c --clobber)'{-c,--clobber}'[fetch even if cached]' \
  '(-a --all)'{-a,--all}'[--inactive --undeclared --clobber]' \
  '(-s --swap-inverted)'{-s,--swap-inverted}'[swap currencies]' \
  '(-w --workers)'{-w,--workers}'=[workers]:n:' \
  '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
  '--cache=[cache file]:file:_files' \
  '--no-cache[disable cache]' \
  '--clear-cache[clear cache]' \
  '*:source:_files'
