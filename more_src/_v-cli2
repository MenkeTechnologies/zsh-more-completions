#compdef v-cli2 vlang2
# _v-cli2 — Alexander Medvednikov V Lang v-cli2 CLI command-line frontend wrapping the V open-source simple fast safe compiled language for developing maintainable software written in V originally Alexander Medvednikov 2019 V is a statically typed compiled language with no global state immutability by default option/result types pattern matching generics interfaces inspired by Go Rust Swift Oberon zero-cost no-NULL-no-runtime-overhead V-package-manager vlib stdlib Vweb VTL UI gg embedded Lua Python C interop AOT V-AOT-compilation hot-code-reloading vmod vsh vab compile run repl test build test-all up vet symlink fmt cflags dep doc fork-pgsync watch -c2 -prod -shared -prealloc -native -compress (Alexander Medvednikov V Lang team, V); custom argparse
# upstream: https://vlang.io/

_v-cli2() {
    local -a sub=(
        'build:Build a V program'
        'build-examples:Build examples'
        'build-tools:Build V tools'
        'check-md:Check Markdown'
        'check:Check syntax'
        'complete:Generate shell completion'
        'crun:Run V program (compile if needed)'
        'doc:Generate documentation'
        'doctor:Show system info'
        'download:Download a package'
        'fmt:Format V source code'
        'help:show help'
        'install:Install a V module'
        'list:List installed modules'
        'missdoc:Find missing doc strings'
        'new:Scaffold a new project'
        'outdated:Show outdated packages'
        'pkgconfig:V pkgconfig'
        'remove:Remove a module'
        'repl:Open a V REPL'
        'retry:Retry failed checks'
        'run:Compile and run a V program'
        'search:Search V module registry'
        'self:Update V itself'
        'setup-freetype:Setup FreeType'
        'shader:V shader tool'
        'show:Show module info'
        'symlink:Symlink V to /usr/local/bin/v'
        'test:Run tests'
        'test-all:Run all tests'
        'test-cleancode:Test clean code'
        'test-fmt:Test formatting'
        'test-parser:Test parser'
        'test-self:Test V on itself'
        'tracev:Trace V'
        'tutorial:Open tutorials'
        'up:Upgrade V'
        'update:Update modules'
        'upgrade:Upgrade modules'
        'vab:V Android tool'
        'version:show version'
        'vet:Vet V code'
        'vlib-docs:Generate vlib docs'
        'vweb:V Web framework'
        'watch:Watch V program'
        'wipe-cache:Wipe cache'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-o+[output]:file:_files' \
        '-os+[os]:o:(linux mac windows freebsd openbsd netbsd dragonfly serenity solaris haiku android termux qnx vinix js js_browser js_node js_freestanding android_aab raw raw_zip)' \
        '-arch+[arch]:str:' \
        '-b+[backend]:b:(c js js_browser js_node js_freestanding native interp wasm gas asm)' \
        '-cc+[cmd]:str:' \
        '-cflags+[flags]:str:' \
        '*-cflags+[flags]:str:' \
        '-cmain=+[name]:str:' \
        '-d=+[define]:str:' \
        '*-d=+[define]:str:' \
        '-define=+[name]:str:' \
        '*-define=+[name]:str:' \
        '-cstrict[strict C]' \
        '-prod[production mode]' \
        '-debug[debug]' \
        '-g[debug info]' \
        '-gc=+[gc]:gc:(none boehm boehm_full boehm_leak boehm_full_opt boehm_leak_opt)' \
        '-keepc[keep C]' \
        '-keep-c[keep C]' \
        '-skip-running[skip running]' \
        '-N[no warnings]' \
        '-W[no warnings]' \
        '-no-warn[no warnings]' \
        '-no-warnings[no warnings]' \
        '-error-limit=+[N]:n:' \
        '-experimental[experimental]' \
        '-message-limit=+[N]:n:' \
        '-show-c-output[show C output]' \
        '-shared[shared library]' \
        '-static[static link]' \
        '-prealloc[prealloc]' \
        '-no-prealloc[no prealloc]' \
        '-no-bounds-checking[no bounds checking]' \
        '-no-builtin[no builtin]' \
        '-no-rsp[no rsp]' \
        '-no-skip-unused[no skip unused]' \
        '-no-stdlib[no stdlib]' \
        '-no-debug[no debug]' \
        '-no-debugger[no debugger]' \
        '-watch[watch mode]' \
        '-fast[fast]' \
        '-cflags[cflags]' \
        '-cstrict[strict cc]' \
        '-line-info=+[loc]:str:' \
        '-compress[compress]' \
        '-thread-stack-size=+[N]:n:' \
        '-coroutine-stack-size=+[N]:n:' \
        '-csrc[output C source only]' \
        '-cmain=+[name]:str:' \
        '-asm[asm output]' \
        '-c2v[C2V mode]' \
        '-print_v_files[print V files]' \
        '-stats[stats]' \
        '-color=+[c]:c:(auto always never)' \
        '-line-info=+[location]:str:' \
        '-translated[translated]' \
        '-v-doc[V doc]' \
        '-script[script]' \
        '-strict[strict]' \
        '-x86[x86 backend]' \
        '-show-asserts[show asserts]' \
        '-skip-unused[skip unused]' \
        '-show-callgraph[show callgraph]' \
        '-trace-checker[trace checker]' \
        '-stats[stats]' \
        '-output=+[file]:file:_files' \
        '-msvc[MSVC backend]' \
        '-livemain[live main]' \
        '-live[live reload]' \
        '-autofree[autofree]' \
        '-skip-warnings[skip warnings]' \
        '-no-parallel[no parallel]' \
        '-parallel[parallel]' \
        '-pkgconfig=+[lib]:str:' \
        '-bare-builtin-dir=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'v subcommand' sub ;;
        args)
            case $words[1] in
                build|run|test|fmt|check|crun|repl|watch|doc) _arguments '*:source:_files -g "*.v *.vsh *.vv"' ;;
                install|remove|update|upgrade|show|search) _arguments '*:module:' ;;
                new|init) _arguments '*:name:' ;;
                complete) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_v-cli2 "$@"
