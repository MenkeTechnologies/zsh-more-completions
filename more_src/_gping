#compdef gping
# _gping — Tom Forbes (orf) gping (terminal ping graph in Rust; multi-host overlay + command-execution-time mode + per-target color)
# upstream: https://github.com/orf/gping
# Flags from gping/src/main.rs on tip (clap-derive).

_gping() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '--cmd[graph command execution time instead of pings]' \
        '(-n --watch-interval)'{-n+,--watch-interval=}'[watch interval seconds (e.g. 0.5)]:sec:' \
        '(-b --buffer)'{-b+,--buffer=}'[graph history window (sec)]:sec:' \
        '(-4 -6)-4[force IPv4]' \
        '(-4 -6)-6[force IPv6]' \
        '(-i --interface)'{-i+,--interface=}'[interface to ping from]:iface:_net_interfaces' \
        '(-s --simple-graphics)'{-s,--simple-graphics}'[use dots instead of braille]' \
        '--vertical-margin=[top+bottom graph margin]:n:' \
        '--horizontal-margin=[left+right graph margin]:n:' \
        '*'{-c+,--color=}'[per-host graph color (repeatable, comma-sep)]:color:' \
        '--clear[clear graph from terminal on exit]' \
        '--ping-args=[extra args passed through to underlying ping (platform-dependent)]:args:' \
        '*:host-or-command:_hosts'
}

_gping "$@"
