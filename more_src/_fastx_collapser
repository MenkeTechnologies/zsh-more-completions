#compdef fastx_collapser
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fastx_collapser.1.en.html
# FASTX-Toolkit: collapse identical sequences into a single record with a count

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose: print short summary of input/output counts]' \
  '-i+[FASTA/Q input file (default STDIN)]:input file:_files' \
  '-o+[FASTA/Q output file (default STDOUT)]:output file:_files' && ret=0

return ret
