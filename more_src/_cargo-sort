#compdef cargo-sort

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[check if Cargo.toml is sorted without modifying]' \
  '-g[group dependencies by kind in sorted order]' \
  '-w[sort all workspace members]' \
  '-n[perform a dry run without writing changes]' \
  '-o[specify path to write sorted output]:output file:_files' \
  '-p[specify path to Cargo.toml]:path:_files -g "Cargo.toml"' \
  '*:path:_files -/' && ret=0

return ret
