#compdef hislist
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss73.html
# KAPPA: list the history component of an NDF

local ret=1

_arguments -s \
  'BRIEF=[summarized vs full history]:brief:(TRUE FALSE)' \
  'NDF=[NDF whose history is to be reported]:NDF:_files' \
  '*:NDF:_files' && ret=0

return ret
