#compdef knot-cli knotd knotc
# _knot-cli — CZ.NIC Knot DNS authoritative server CLI alias (CZ-NIC team, C); custom argparse
# upstream: https://github.com/CZ-NIC/knot

_knot-cli() {
    local -a sub=(
        'status:show daemon status'
        'stop:stop daemon'
        'reload:reload configuration'
        'stats:get server statistics'
        'zone-check:check zone'
        'zone-status:show zone status'
        'zone-reload:reload zone'
        'zone-refresh:refresh zone'
        'zone-retransfer:retransfer zone'
        'zone-notify:notify zone'
        'zone-flush:flush zone changes'
        'zone-backup:backup zones'
        'zone-restore:restore zones'
        'zone-sign:sign zone'
        'zone-key-rollover:roll keys'
        'zone-keys-load:reload keys'
        'zone-ksk-submitted:submit KSK'
        'zone-freeze:freeze zone'
        'zone-thaw:thaw zone'
        'zone-xfr-freeze:freeze xfr'
        'zone-xfr-thaw:thaw xfr'
        'zone-read:read zone'
        'zone-begin:begin transaction'
        'zone-commit:commit transaction'
        'zone-abort:abort transaction'
        'zone-diff:show transaction diff'
        'zone-get:get records'
        'zone-set:set records'
        'zone-unset:unset records'
        'zone-purge:purge zone'
        'zone-stats:show zone stats'
        'conf-init:initialize config'
        'conf-check:check config'
        'conf-import:import zone config'
        'conf-export:export zone config'
        'conf-list:list config items'
        'conf-read:read config item'
        'conf-begin:begin config transaction'
        'conf-commit:commit config transaction'
        'conf-abort:abort config transaction'
        'conf-diff:show config diff'
        'conf-get:get config item'
        'conf-set:set config item'
        'conf-unset:unset config item'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "knot.conf"' \
        '-C+[config dir]:dir:_files -/' \
        '-d[debug]' \
        '-D[run in debug]' \
        '-s+[socket]:file:_files' \
        '-t+[timeout seconds]:n:' \
        '-l+[backup label]:str:' \
        '-x[non-recursive]' \
        '-f[force]' \
        '-b[blocking mode]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'knotc subcommand' sub ;;
    esac
}

_knot-cli "$@"
