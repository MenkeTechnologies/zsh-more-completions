#compdef sqlite3rsync

# sqlite3rsync: rsync for SQLite databases (sync-via-WAL)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-V[version]' \
  '--version[version]' \
  '--ssh=[ssh program to use]:cmd:' \
  '--exe=[remote sqlite3rsync binary]:cmd:' \
  '--commit[commit changes after sync]' \
  '--debug=[debug option]:opt:' \
  '*:source destination:_files -g "*.(db|sqlite|sqlite3)"' && ret=0
return ret
