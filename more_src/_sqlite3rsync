#compdef sqlite3rsync sqlite3_rsync
# Documentation: https://sqlite.org/rsync.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# sqlite3_rsync: synchronize SQLite databases over SSH
local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)'{-help,--help,-\?}'[show help]' \
  '-v[verbose output]' \
  '--exe=[remote sqlite3_rsync binary path]:cmd:' \
  '--protocol=[wire protocol version]:n:(1)' \
  '*:source destination:_files -g "*.(db|sqlite|sqlite3)"' && ret=0
return ret
