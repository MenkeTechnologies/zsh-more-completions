#compdef weasyprint

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-e[character encoding]:encoding' \
  '--encoding=[character encoding]:encoding' \
  '-s[URL or filename of CSS stylesheet]:stylesheet:_files -g "*.css"' \
  '--stylesheet=[URL or filename of CSS stylesheet]:stylesheet:_files -g "*.css"' \
  '-m[media type]:media type:(print screen)' \
  '--media-type=[media type]:media type:(print screen)' \
  '-u[base URL]:base URL' \
  '--base-url=[base URL]:base URL' \
  '-a[attachment file]:file:_files' \
  '--attachment=[attachment file]:file:_files' \
  '-p[enable presentational hints]' \
  '--presentational-hints[enable presentational hints]' \
  '--optimize-images[optimize images]' \
  '-r[resolution for images in dpi]:dpi' \
  '--resolution=[resolution for images in dpi]:dpi' \
  '--pdf-identifier=[PDF identifier]:identifier' \
  '--pdf-variant=[PDF variant]:variant:(pdf/a-1b pdf/a-2b pdf/a-3b pdf/a-4b pdf/ua-1)' \
  '--pdf-version=[PDF version]:version' \
  '--pdf-forms[include PDF forms]' \
  '--uncompressed-pdf[uncompressed PDF output]' \
  '--custom-metadata[include custom HTML metadata]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-d[debug output]' \
  '--debug[debug output]' \
  '-q[quiet output]' \
  '--quiet[quiet output]' \
  '1:input (URL or filename):_files -g "*.{html,htm,xhtml}"' \
  '2:output file:_files -g "*.{pdf,png}"' && ret=0

return ret
