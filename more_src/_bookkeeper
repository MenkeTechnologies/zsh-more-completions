#compdef bookkeeper

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'bookie:start a bookie in foreground'
  'localbookie:start an ensemble of N bookies in single JVM'
  'autorecovery:run autorecovery service'
  'upgrade:upgrade bookie filesystem'
  'shell:run bookie admin shell'
  'help:show help'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'bookkeeper subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (upgrade)
        _arguments \
          '--upgrade[perform upgrade]' \
          '--rollback[perform rollback]' \
          '--finalize[mark upgrade complete]' && ret=0
        ;;
      (localbookie)
        _arguments \
          '1:number of bookies:' && ret=0
        ;;
      (shell)
        _arguments \
          '1:shell command:(queryautorecoverystatus autorecovery bookieformat initbookie bookieinfo bookiesanity decommissionbookie deleteledger endpointinfo expandstorage help lastmark ledger ledgermetadata listbookies listfilesondisc listledgers listunderreplicated metaformat initnewcluster nukeexistingcluster lostbookierecoverydelay readjournal readledger readlog recover simpletest triggeraudit updatecookie updateledgers updateBookieInLedger whoisauditor whatisinstanceid convert-to-db-storage convert-to-interleaved-storage rebuild-db-ledger-locations-index)' \
          '*::shell args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
