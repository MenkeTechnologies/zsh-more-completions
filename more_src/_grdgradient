#compdef grdgradient
# Documentation: https://docs.generic-mapping-tools.org/latest/grdgradient.html
# Source: GenericMappingTools/gmt classic-mode grdgradient — directional derivative / shaded relief.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[azimuth (deg from north, CW)]:azim:_default' \
    '-D+[direction of positive gradient]:opts:_default' \
    '-E+[Lambertian radiance for grdimage/grdview]:opts:_default' \
    '-G+[output grid file]:file:_files' \
    '-N+[normalization (amplitude/offset/sigma)]:opts:_default' \
    '-Q+[normalization stats across tiles]:opts:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[scalar-magnitude output grid file]:file:_files' \
    '*-V[verbose (stackable)]' \
    '-f+[I/O column data types]:types:_default' \
    '-n+[grid interpolation mode]:mode:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
