#compdef cppcheck
# Documentation: https://manpages.debian.org/bookworm/cppcheck/cppcheck.1.en.html
#                + cppcheck wiki / man-2.10 reference
# Reference accessed: 2026-05-30
# cppcheck — Daniel Marjamäki's C/C++ static analyzer. Operates as a single
# binary with a wide flag set covering preprocessing, language standards,
# library configuration, suppressions, and parallel analysis.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[print version]' \
  '(- *)--errorlist[print all possible error messages as XML]' \
  '--check-config[verify configuration; disables normal analysis]' \
  '--check-library[report incomplete library file information]' \
  '--check-level=[analysis depth/effort]:level:(reduced normal exhaustive)' \
  '*--enable=[turn on a check group]:check:(all warning style performance portability information unusedFunction missingInclude)' \
  '*--disable=[turn off a check group]:check:(all warning style performance portability information unusedFunction missingInclude)' \
  '--inconclusive[report results even when analysis is uncertain]' \
  '*-D-[define preprocessor variable]:macro:' \
  '*-U-[undefine preprocessor variable]:macro:' \
  '--std=[C/C++ language standard]:std:(c89 c99 c11 c17 c23 c++03 c++11 c++14 c++17 c++20 c++23)' \
  '--language=[force language]:lang:(c c++)' \
  '--platform=[target platform]:plat:(unix32 unix64 win32A win32W win64 native unspecified)' \
  '*-I+[add include search directory]:dir:_files -/' \
  '--includes-file=[file listing include paths]:file:_files' \
  '*--include=[force file inclusion before checked source]:file:_files' \
  '*-i+[ignore directory or file]:path:_files' \
  '*--library=[load library configuration]:lib:(std posix gnu microsoft_sal microsoft_atl microsoft_unittest boost qt python sdl gtk wxwidgets opengl openssl windows zlib bsd libcerror libcurl libstdcpp libsigc++ ruby tinyxml2 emscripten googletest catch2)' \
  '--template=[format error messages]:fmt:({simple,gcc,vs,edit,daca2,cppcheck1})' \
  '--template-location=[format error location lines]:fmt:' \
  '--xml[output in XML format]' \
  '--xml-version=[XML schema version]:ver:(2)' \
  '--output-file=[write output to FILE instead of stderr]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[only show errors]' \
  '(-v --verbose)'{-v,--verbose}'[detailed error reports]' \
  '--report-progress[display file-checking progress]' \
  '--error-exitcode=[exit code when errors found]:N:' \
  '*--suppress=[suppress: id\:file\:line]:spec:' \
  '--suppressions-list=[load suppressions from file]:file:_files' \
  '--suppress-xml=[XML-defined suppressions]:file:_files -g "*.xml"' \
  '--inline-suppr[honor inline `cppcheck-suppress` comments]' \
  '--exitcode-suppressions=[display msgs without non-zero exit]:file:_files' \
  '-j+[parallel analysis jobs]:N:' \
  '-l+[thread load threshold (UNIX only)]:load:' \
  '--max-configs=[max preprocessor configurations (default 12)]:N:' \
  '--max-ctu-depth=[whole-program analysis depth (default 2)]:N:' \
  '--max-template-recursion=[max template recursion depth]:N:' \
  '--force[force checking high-config files]' \
  '--file-list=[read source list from file]:file:_files' \
  '--config-exclude=[exclude path from config checking]:path:_files' \
  '--config-excludes-file=[file listing config exclusions]:file:_files' \
  '*--rule=[regex custom check]:regex:' \
  '*--rule-file=[XML rule file]:file:_files -g "*.xml"' \
  '*--addon=[run addon (misra/threadsafety/y2038/cert/naming)]:addon:(misra threadsafety y2038 cert naming)' \
  '*--addon-python=[python interpreter for addons]:python:_command_names -e' \
  '--plist-output=[Clang plist output directory]:dir:_files -/' \
  '--cppcheck-build-dir=[whole-program analysis cache dir]:dir:_files -/' \
  '*--project=[load Visual Studio sln/vcxproj or CMake compile_commands.json]:file:_files -g "*.(sln|vcxproj|json|cppcheck)"' \
  '--project-configuration=[VS project configuration to use]:cfg:' \
  '--inline-suppr[enable inline suppression comments]' \
  '--debug-warnings[print debug warnings]' \
  '--debug-simplified[print simplified token list]' \
  '--debug-symdb[dump symbol database]' \
  '--showtime=[print stats]:mode:(file file-total summary top5 top5_file top5_summary)' \
  '--bug-hunting[bug-hunting mode (premium)]' \
  '--safety[safety analysis mode]' \
  '*:source file or directory:_files' \
  && ret=0

return ret
