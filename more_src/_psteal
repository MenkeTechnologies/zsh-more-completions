#compdef psteal
# Zsh completion for Plaso psteal (super timeline extraction all-in-one tool)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--source=[path to source data]:source:_files' \
  '--output=[output format]:format:(dynamic json kml l2tcsv l2ttln opensearch timesketch xlsx)' \
  '--storage-file=[path to storage file]:file:_files' \
  '(-z --zone)'{-z,--zone}'[preferred time zone]:timezone:' \
  '--parsers=[comma separated list of parsers]:parsers:' \
  '--hasher=[type of hash to use]:hasher:(md5 sha1 sha256)' \
  '--hashers=[comma separated list of hashers]:hashers:' \
  '--yara-rules=[path to Yara rules file]:file:_files' \
  '(-w --write)'{-w,--write}'[output file]:file:_files' \
  '--status_view=[status view mode]:view:(linear none window)' \
  '--logfile=[path to log file]:file:_files' \
  '--workers=[number of worker processes]:workers:' \
  '--worker-memory-limit=[maximum memory per worker in bytes]:bytes:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:source:_files' && ret=0

return ret
