#compdef metapac

autoload -U is-at-least

_metapac() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--hostname=[specify a different hostname]:HOSTNAME:_default' \
'--config-dir=[specify a different config directory]:CONFIG_DIR:_files' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_metapac_commands" \
"*::: :->metapac" \
&& ret=0
    case $state in
    (metapac)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:metapac-command-$line[1]:"
        case $line[1] in
            (update)
_arguments "${_arguments_options[@]}" : \
'--backend=[the backend for the packages]:BACKEND:_default' \
'*--packages=[the package names]:PACKAGES:_default' \
'--no-confirm[do not ask for any confirmation]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(update-all)
_arguments "${_arguments_options[@]}" : \
'*--backends=[the backends to operate on]:BACKENDS:_default' \
'--no-confirm[do not ask for any confirmation]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
'--no-confirm[do not ask for any confirmation]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(sync)
_arguments "${_arguments_options[@]}" : \
'--no-confirm[do not ask for any confirmation]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(unmanaged)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(backends)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(clean-cache)
_arguments "${_arguments_options[@]}" : \
'*--backends=[the backends to operate on]:BACKENDS:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--shell=[the shell to generate completions for]:SHELL:(bash elvish fish powershell zsh nushell)' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_metapac__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:metapac-help-command-$line[1]:"
        case $line[1] in
            (update)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(update-all)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(sync)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(unmanaged)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(backends)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clean-cache)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_metapac_commands] )) ||
_metapac_commands() {
    local commands; commands=(
'update:update packages for the given backend' \
'update-all:update all packages for the given backends' \
'clean:uninstall unmanaged packages' \
'sync:install missing packages from groups' \
'unmanaged:show explicitly installed packages not required by metapac' \
'backends:show the backends found by metapac' \
'clean-cache:clean the caches for the given backends' \
'completions:generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'metapac commands' commands "$@"
}
