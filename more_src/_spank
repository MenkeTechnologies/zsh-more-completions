#compdef spank
# _spank — SchedMD Slurm SPANK plugin debugger (spank reads the configured spank.d files and prints the configured plugins; used for diagnosing the Slurm plugin loader; --conf overrides the plugin config dir; positional argument is an optional sequence name to filter (init|init_post_opt|local_user_init|task_init|exit))
# upstream: https://github.com/SchedMD/slurm
# Flags from SchedMD/slurm src/plugins/spank on tip.

_spank() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '--conf+[plugin conf dir]:dir:_files -/' \
        '1::sequence:(init init_post_opt local_user_init task_init exit job_prolog job_epilog srun_remote_local_init srun_remote_local_exit)'
}

_spank "$@"
