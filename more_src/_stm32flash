#compdef stm32flash

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-b+[baud rate]:baud rate:(1200 2400 4800 9600 19200 38400 57600 115200 230400 460800 921600)' \
  '-m+[serial mode]:mode:(8e1 8n1 8o1)' \
  '-r+[read flash to file]:output file:_files' \
  '-w+[write flash from file]:input file:_files' \
  '-u[disable flash write-protection]' \
  '-j[enable flash read-protection]' \
  '-k[disable flash read-protection]' \
  '-o[erase only]' \
  '-e+[erase pages]:pages:' \
  '-v[verify writes]' \
  '-n+[retry count]:count:' \
  '-g+[start execution at address]:address:' \
  '-s+[flash start page]:page:' \
  '-S+[flash start address\[:length\]]:address:' \
  '-F+[force flash layout]:RX\:FL:' \
  '-f[force binary parser]' \
  '-c[resume connection]' \
  '-i+[init GPIO]:spec:' \
  '-R[reset device on exit]' \
  '-C[compute CRC of flash]' \
  '1:serial port:_files -g "/dev/tty*"' && ret=0

return ret
