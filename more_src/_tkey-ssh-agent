#compdef tkey-ssh-agent
# Documentation: https://github.com/tillitis/tkey-ssh-agent
# SSH agent for the Tillitis TKey USB security key

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-a --agent-socket)'{-a,--agent-socket}'[socket path for the SSH agent to listen on]:socket:_files' \
  '--port[TKey device port]:port:_files' \
  '--list-ports[list available device ports]' \
  '--speed[serial port speed]:speed:_default' \
  '--uss[enable User Supplied Secret entry]' \
  '--uss-file[read User Supplied Secret from file]:secret file:_files' \
  '(-p --show-pubkey)'{-p,--show-pubkey}'[output only the public key to stdout]' && ret=0

return ret
