#compdef gcp-secret-manager gcp-secretmanager gsm-cli
# _gcp-secret-manager — Google Cloud gcp-secret-manager CLI alternative ergonomic command-line frontend wrapping the Google Cloud Secret Manager API providing create describe access get list versions enable disable destroy add-version add-iam-policy IAM-policy-cross-region-replication automatic-replication-CMEK customer-managed-encryption (Google team, Go); cobra
# upstream: https://cloud.google.com/secret-manager

_gcp-secret-manager() {
    local -a sub=(
        'create:create a secret'
        'describe:describe a secret'
        'access:fetch a secret version payload'
        'list:list secrets'
        'list-versions:list versions of a secret'
        'add-version:add a new version'
        'enable:enable a version'
        'disable:disable a version'
        'destroy:destroy a version'
        'delete:delete the secret'
        'update:update metadata'
        'add-iam-policy-binding:add IAM binding'
        'remove-iam-policy-binding:remove IAM binding'
        'set-iam-policy:set IAM policy'
        'get-iam-policy:get IAM policy'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--project=+[project]:str:' \
        '--location=+[loc]:str:' \
        '--data-file=+[file]:file:_files' \
        '--data=+[data]:str:' \
        '--replication-policy=+[p]:p:(automatic user-managed)' \
        '--locations=+[list]:str:' \
        '--kms-key-name=+[key]:str:' \
        '--member=+[member]:str:' \
        '--role=+[role]:str:' \
        '--policy-file=+[file]:file:_files -g "*.yaml *.json"' \
        '--secret-version=+[v]:str:' \
        '-f+[format]:f:(json yaml table)' \
        '--format=+[format]:f:(json yaml table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gcp-secret-manager subcommand' sub ;;
        args)
            case $words[1] in
                describe|access|delete|update|list-versions|add-version|enable|disable|destroy|add-iam-policy-binding|remove-iam-policy-binding|set-iam-policy|get-iam-policy) _arguments '*:secret name:' ;;
            esac
            ;;
    esac
}

_gcp-secret-manager "$@"
