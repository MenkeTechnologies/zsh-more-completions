#compdef csrfprobe csrf-probe
# _csrfprobe — Vishnuraj CSRF Probe advanced CSRF vulnerability tester with token replay and origin checks (vincentchavez team, Python); argparse
# upstream: https://github.com/vince-Tw/csrfprobe

_csrfprobe() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-u+[target url]:url:_urls' \
        '--url=+[target url]:url:_urls' \
        '-c+[cookies]:str:' \
        '--cookie=+[cookies]:str:' \
        '-H+[extra header]:str:' \
        '--header=+[extra header]:str:' \
        '-d+[post data]:str:' \
        '--data=+[post data]:str:' \
        '-m+[http method]:m:(GET POST PUT DELETE PATCH OPTIONS)' \
        '--method=+[http method]:m:(GET POST PUT DELETE PATCH OPTIONS)' \
        '--proxy=+[proxy URL]:url:_urls' \
        '--timeout=+[request timeout sec]:n:' \
        '--delay=+[delay between requests sec]:n:' \
        '--threads=+[N]:n:' \
        '-t+[threads]:n:' \
        '--user-agent=+[user agent]:str:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--format=+[output format]:f:(json csv txt html)' \
        '--ignore-token=+[token names csv]:str:' \
        '--check-referer[check referer]' \
        '--check-origin[check origin]' \
        '--check-samesite[check samesite cookie]' \
        '--check-token[check csrf token]' \
        '--check-double-submit[double-submit cookie check]' \
        '--check-custom-header[custom header check]' \
        '--bypass[try common bypasses]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--silent[silent]' \
        '--no-color[disable color]'
}

_csrfprobe "$@"
