#compdef pkextractogr
# Documentation: https://pktools.nongnu.org/html/pkextractogr.html
# extract pixel values to OGR vector sample

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-point[extract a single pixel within the polygon or on each point feature]' \
  '-allpoints[Extract all pixel values covered by the polygon]' \
  '-centroid[Extract pixel value at the centroid of the polygon]' \
  '-mean[Extract average of all pixel values within the polygon]' \
  '-stdev[Extract standard deviation of all pixel values within the polygon]' \
  '-median[Extract median of all pixel values within the polygon]' \
  '-min[Extract minimum value of all pixels within the polygon]' \
  '-max[Extract maximum value of all pixels within the polygon]' \
  '-sum[Extract sum of the values of all pixels within the polygon]' \
  '-mode[Extract the mode of classes within the polygon (classes must be set wi]' \
  '-proportion[Extract proportion of class(es) within the polygon (classes must be se]' \
  '-count[Extract count of class(es) within the polygon (classes must be set wit]' \
  '-percentile[Extract percentile as defined by option perc (e.g, 95th percentile of]' \
  '(-i --input)'{-i,--input}'[Raster input dataset containing band information]:file:_files' \
  '(-s --sample)'{-s,--sample}'[OGR vector dataset with features to be extracted from input data. Outp]:file:_files' \
  '(-ln --ln)'{-ln,--ln}'[Layer name(s) in sample (leave empty to select all)]:value:' \
  '(-rand --random)'{-rand,--random}'[Create simple random sample of points. Provide number of points to gen]' \
  '(-grid --grid)'{-grid,--grid}'[Create systematic grid of points. Provide cell grid size (in projected]:value:' \
  '(-o --output)'{-o,--output}'[Output sample dataset]:file:_files' \
  '(-c --class)'{-c,--class}'[Class(es) to extract from input sample image. Leave empty to extract a]:value:' \
  '(-t --threshold)'{-t,--threshold}'[Probability threshold for selecting samples (randomly). Provide probab]:value:' \
  '(-perc --perc)'{-perc,--perc}'[Percentile value used for rule percentile]:value:' \
  '(-f --f)'{-f,--f}'[Output sample dataset format]:value:' \
  '(-ft --ftype)'{-ft,--ftype}'[Field type (only Real or Integer)]:value:' \
  '(-b --band)'{-b,--band}'[Band index(es) to extract (0 based). Leave empty to use all bands]:value:' \
  '(-sband --startband)'{-sband,--startband}'[Start band sequence number]:value:' \
  '(-eband --endband)'{-eband,--endband}'[End band sequence number]:value:' \
  '(-r --rule)'{-r,--rule}'[Rule how to report image information per feature (only for vector samp]:value:' \
  '(-bndnodata --bndnodata)'{-bndnodata,--bndnodata}'[Band(s) in input image to check if pixel is valid (used for srcnodata)]:value:' \
  '(-srcnodata --srcnodata)'{-srcnodata,--srcnodata}'[Invalid value(s) for input image]:value:' \
  '(-tp --thresholdPolygon)'{-tp,--thresholdPolygon}'[(absolute) threshold for selecting samples in each polygon]:value:' \
  '(-buf --buffer)'{-buf,--buffer}'[Buffer for calculating statistics for point features (in number of pix]:value:' \
  '(-circ --circular)'{-circ,--circular}'[Use a circular disc kernel buffer (for vector point sample datasets on]' \
  '*:file:_files' && ret=0

return ret
