#compdef xsane
# Documentation: https://manpages.debian.org/bookworm/xsane/xsane.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: fabricated -V/--version (real is -v/--version)
# and bogus man.archlinux.org search URL.

# xsane: GTK frontend for the SANE scanner library
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-l --license)'{-l,--license}'[show license and exit]' \
  '(-d --device-settings)'{-d+,--device-settings=}'[default filename for device settings]:file:_files' \
  '(-V --viewer)'{-V,--viewer}'[force start in viewer mode]' \
  '(-s --save)'{-s,--save}'[force start in save mode]' \
  '(-c --copy)'{-c,--copy}'[force start in copy mode]' \
  '(-f --fax)'{-f,--fax}'[force start in fax mode]' \
  '(-m --mail)'{-m,--mail}'[force start in mail mode]' \
  '(-n --no-mode-selection)'{-n,--no-mode-selection}'[disable xsane mode selection menu]' \
  '(-F --Fixed)'{-F,--Fixed}'[use fixed non-resizable main window]' \
  '(-R --Resizable)'{-R,--Resizable}'[use scrolled resizable main window]' \
  '(-p --print-filenames)'{-p,--print-filenames}'[print created filenames to stdout]' \
  '(-N --force-filename)'{-N+,--force-filename=}'[default image filename]:name:' \
  '--display=[X11 display]:display:' \
  '--sync[synchronous X11 connection]' \
  '*:device:' && ret=0
return ret
