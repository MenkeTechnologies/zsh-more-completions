#compdef amd-smi
# Documentation: https://man.archlinux.org/search?q=amd-smi
# Reference accessed: 2026-05-16

# amd-smi: AMD System Management Interface CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'version:show version'
  'list:list GPUs'
  'static:static GPU info'
  'firmware:firmware info'
  'bad-pages:list bad pages'
  'metric:dynamic metrics'
  'monitor:live metrics monitor'
  'process:GPU process info'
  'profile:GPU profile management'
  'topology:GPU topology'
  'set:set GPU parameters'
  'reset:reset GPU/queues'
  'event:event subsystem'
  'xgmi:XGMI info'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-g[GPU indexes]:list:' \
  '--gpu=[GPU indexes]:list:' \
  '-U[CPU/socket index]:list:' \
  '-V[VF index]:list:' \
  '--json[JSON output]' \
  '--csv[CSV output]' \
  '--file=[output file]:file:_files' \
  '--loglevel=[log level]:level:(debug info warning error critical)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'amd-smi command' commands && ret=0 ;;
esac
return ret
