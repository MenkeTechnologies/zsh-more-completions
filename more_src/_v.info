#compdef v.info
# GRASS GIS: output basic information about a vector map

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '-c[print attribute table columns instead of info]' \
  '-h[print data history instead of info]' \
  '-e[print only metadata info]' \
  '-g[print only region info]' \
  '-t[print only topology info]' \
  '--verbose[verbose output]' \
  '--quiet[quiet output]' \
  '--map=[vector map name]:name:' \
  '--layer=[layer number or name]:layer:' \
  '--format=[output format]:format:(plain shell json csv)' && ret=0

return ret
