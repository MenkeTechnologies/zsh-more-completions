#compdef mtzdmp
# Documentation: https://www.ccp4.ac.uk/html/mtzdump.html
# mtzdmp - quick dump of an MTZ reflection file header/data (CCP4)

local ret=1

_arguments -s -S \
  '-h[listing of options]' \
  '-n[number of hkl reflections to dump (default 10)]:number:' \
  '-e[print header information only]' \
  '-b[dump BATCH headers]' \
  '-s[dump SYMMETRY info]' \
  '(-bs -sb)-bs[dump both SYMM and BATCH]' \
  '(-bs -sb)-sb[dump both SYMM and BATCH]' \
  '-r[resolution limits Rmax Rmin]:Rmax:' \
  '-i[interactive]' \
  '*:mtz file:_files' && ret=0

return ret
