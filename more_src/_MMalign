#compdef MMalign
# Documentation: https://github.com/pylelab/USalign
# MMalign - structure alignment of multiple-chain protein complexes

local ret=1

_arguments -s -S \
  '-a[normalise TM-score by the average length of the two structures]' \
  '-d[TM-score scaled by an assigned d0]:d0' \
  '-o[output the superposition to filename.sup and filename.sup_all]:file:_files' \
  '-m[output the rotation matrix to file]:file:_files' \
  '-fast[fast but slightly inaccurate fTM-align alignment]' \
  '*:structure:_files' && ret=0

return ret
