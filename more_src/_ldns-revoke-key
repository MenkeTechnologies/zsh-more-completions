#compdef ldns-revoke-key
# _ldns-revoke-key — NLnet Labs ldns-revoke-key (newer wrapper around ldns-revoke that takes the K-file pair (.key and .private) directly and rewrites both with the REVOKE flag set; -v verbose, -V version, -f force, --keep-old keep prior keys around as .bak; positional KSK K-file)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from NLnetLabs/ldns examples/ldns-revoke-key on tip.

_ldns-revoke-key() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-f[force]' \
        '--keep-old[keep prior keys as .bak]' \
        '1:KSK K-file:_files -g "K*.key"'
}

_ldns-revoke-key "$@"
