#compdef broot br
# _broot-bin — broot interactive file tree (Denys Séguret, Rust); tree-view file manager with fuzzy search + verbs
# upstream: https://github.com/Canop/broot

_broot-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --cmd)'{-c,--cmd}'+[command sequence]:cmd:' \
        '--color+[color]:when:(yes no auto)' \
        '--conf+[config file(s)]:files:' \
        '(-d --dates)'{-d,--dates}'[show dates]' \
        '(-D --no-dates)'{-D,--no-dates}'[hide dates]' \
        '(-f --only-folders)'{-f,--only-folders}'[only folders]' \
        '(-F --no-only-folders)'{-F,--no-only-folders}'[disable only folders]' \
        '(-g --show-git-info)'{-g,--show-git-info}'[show git info]' \
        '(-G --no-show-git-info)'{-G,--no-show-git-info}'[hide git info]' \
        '--git-status[only git changed]' \
        '(-h --hidden)'{-h,--hidden}'[show hidden]' \
        '(-H --no-hidden)'{-H,--no-hidden}'[hide hidden]' \
        '--height+[height]:n:' \
        '(-i --git-ignored)'{-i,--git-ignored}'[show gitignored]' \
        '(-I --no-git-ignored)'{-I,--no-git-ignored}'[hide gitignored]' \
        '--install[install shell function]' \
        '--listen+[listen socket]:str:' \
        '--get-root[print root]' \
        '--send+[send message to listening broot]:str:' \
        '--no-style[no style]' \
        '(-n --no-style)'{-n,--no-style}'[no style]' \
        '(-N --color)'{-N,--color}'[force color]' \
        '(-o --outcmd)'{-o,--outcmd}'+[output cmd file]:file:_files' \
        '(-p --permissions)'{-p,--permissions}'[show permissions]' \
        '(-P --no-permissions)'{-P,--no-permissions}'[hide permissions]' \
        '--print-shell-function+[shell function for]:shell:(bash zsh fish nushell)' \
        '(-s --sizes)'{-s,--sizes}'[compute sizes]' \
        '(-S --no-sizes)'{-S,--no-sizes}'[do not compute sizes]' \
        '(-T --trim-root)'{-T,--trim-root}'[trim root]' \
        '(-t --no-trim-root)'{-t,--no-trim-root}'[do not trim root]' \
        '(-V --verb-help)'{-V,--verb-help}'[print verbs help]' \
        '(-w --whale-spotting)'{-w,--whale-spotting}'[whale spotting mode]' \
        '(-W --no-whale-spotting)'{-W,--no-whale-spotting}'[disable whale spotting]' \
        '(-v --verbose)'{-v,--verbose}'[verbose log]' \
        '--write-default-conf+[write default config]:file:_files' \
        '*:path:_files -/'
}

_broot-bin "$@"
