#compdef FindBadGenomicKmersSpark
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/spark/sv/evidence/FindBadGenomicKmersSpark.java
# GATK Spark: find high-copy (ubiquitous) kmers in a reference

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  {-O,--output=}'[file for ubiquitous kmer output]:file:_files' \
  '--k-size=[kmer size]:int:' \
  '--kmer-max-dust-score=[maximum kmer DUST score]:int:' \
  '--high-copy-fasta=[additional high-copy kmers fasta file]:fasta:_files -g "*.(fa|fasta)"' \
  '*:argument:_files' && ret=0

return ret
