#compdef stansummary
# Documentation: https://mc-stan.org/docs/cmdstan-guide/stansummary.html
# stansummary - summarize statistics from Stan CSV sampler output files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[produce help message then exit]' \
  '(-a --autocorr)'{-a,--autocorr=}'[display chain autocorrelation for n-th input file]:n:' \
  '(-c --csv_filename)'{-c,--csv_filename=}'[write statistics to a CSV file]:file:_files' \
  '(-p --percentiles)'{-p,--percentiles=}'[comma-separated percentiles to report (default 5,50,95)]:percentiles:' \
  '(-s --sig_figs)'{-s,--sig_figs=}'[significant figures reported (1-18, default 2)]:n:' \
  '(-i --include_param)'{-i,--include_param=}'[include only the named parameter in summary]:name:' \
  '*:Stan CSV file:_files' && ret=0

return ret
