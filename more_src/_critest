#compdef critest
# _critest — kubernetes-sigs/cri-tools critest (conformance harness for the Container Runtime Interface; --runtime-endpoint and --image-endpoint point at a CRI socket, --benchmark runs perf tests, --focus/--skip filter ginkgo specs, --parallel runs N concurrently)
# upstream: https://github.com/kubernetes-sigs/cri-tools
# Flags from cri-tools cmd/critest on tip.

_critest() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--runtime-endpoint+[CRI runtime endpoint]:endpoint:' \
        '-r+[CRI runtime endpoint]:endpoint:' \
        '--image-endpoint+[CRI image endpoint]:endpoint:' \
        '-i+[CRI image endpoint]:endpoint:' \
        '--benchmark[run benchmark tests]' \
        '-b[run benchmark tests]' \
        '--parallel+[parallel processes]:n:' \
        '-p+[parallel processes]:n:' \
        '--focus+[focus regex]:regex:' \
        '-f+[focus regex]:regex:' \
        '--skip+[skip regex]:regex:' \
        '-s+[skip regex]:regex:' \
        '--ginkgo.v[ginkgo verbose]' \
        '--ginkgo.dryRun[ginkgo dry run]' \
        '--ginkgo.seed+[ginkgo seed]:seed:' \
        '--ginkgo.failFast[ginkgo stop on first failure]' \
        '--image+[test image]:image:'
}

_critest "$@"
