#compdef coqide
# Documentation: https://rocq-prover.org/doc/V8.19.0/refman/practical-tools/coqide.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-I+[add directory to ML load path]:dir:_files -/' \
  '-Q+[add LoadPath]:dir physical_path logical_path:' \
  '-R+[map logical_path to physical_path]:dir physical_path logical_path:' \
  '-async-proofs=[async proof mode]:mode:(off on lazy)' \
  '-async-proofs-j=[parallel proof workers]:n:' \
  '-async-proofs-tac-j=[parallel tactic workers]:n:' \
  '-load-ml-source+[load ML source file]:file:_files' \
  '-load-ml-object+[load ML object file]:file:_files' \
  '-l+[load script file]:file:_files -g "*.{v,vio}"' \
  '-lv+[load Coq library]:lib:' \
  '-debug[debug mode]' \
  '-emacs[run as a server (for ProofGeneral)]' \
  '-emacs-U[same as -emacs]' \
  '-noinit[do not load Init.Prelude]' \
  '*:file:_files -g "*.{v,vio}"' && ret=0

return ret
