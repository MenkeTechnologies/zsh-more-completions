#compdef iw-cli
# _iw-cli — Linux iw nl80211 wireless device CLI alias (netfilter team, C); custom argparse
# upstream: https://git.kernel.org/pub/scm/linux/kernel/git/jberg/iw.git

_iw-cli() {
    local -a sub=(
        'help:show help'
        'list:list devices'
        'event:monitor events'
        'commands:list available commands'
        'features:list supported features'
        'phy:show phy info'
        'dev:show device info'
        'reg:regulatory commands'
        'reg get:get regulatory domain'
        'reg set:set regulatory domain'
        'reg reload:reload regulatory'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--print-bcn-hex[print beacon hex]' \
        '-c[color]' \
        '--color[color]' \
        '--no-color[no color]' \
        '-n[no color]' \
        '-Z[show no header]' \
        '--no-header[show no header]' \
        '-t[temperature]' \
        '--timestamp[timestamp]' \
        '-T[timestamp]' \
        '-r[show rates as kbps]' \
        '--print-keys[print keys]' \
        '-p[print keys]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'iw subcommand' sub ;;
        args)
            case $words[1] in
                dev) _arguments \
                    '1:device:_net_interfaces' \
                    '2:command:(scan info link station survey connect disconnect get_power_save set_power_save set type set channel set freq set mac set ssid set txpower set monitor set mesh_param set bitrates set noack_map set 4addr cqm rssi_threshold cqm pktloss_thr mesh_join mesh_leave ibss join ibss leave ocb join ocb leave handle_4addr_frames mgmt_unsol_bcast_probe_resp set_unsol_bcast_probe_resp event)' \
                    '*:args:' ;;
                phy) _arguments '1:phy:' '*:args:' ;;
                reg) _arguments '1:cmd:(get set reload)' '*:args:' ;;
            esac
            ;;
    esac
}

_iw-cli "$@"
