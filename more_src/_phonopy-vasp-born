#compdef phonopy-vasp-born
# Documentation: https://phonopy.github.io/phonopy/auxiliary-tools.html
# Build BORN file (Born charges, dielectric tensor) from VASP output

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--dim=[same behavior as DIM tag]:dim' \
  '(--pa --primitive-axis --primitive-axes)'{--pa,--primitive-axis,--primitive-axes}'=[same as PRIMITIVE_AXES tag]:axes' \
  '(--nost --no-symmetrize-tensors)'{--nost,--no-symmetrize-tensors}'[disable symmetrization of tensors]' \
  '--tolerance=[symmetry tolerance to search]:tol' \
  '--outcar[read OUTCAR instead of vasprun.xml (requires POSCAR)]' \
  '*:file:_files' && ret=0

return ret
