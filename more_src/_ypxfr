#compdef ypxfr
# _ypxfr — OpenBSD ypxfr (transfer a YP map to the local host; commonly invoked from cron via ypxfr_1perhour/2perday/1perday scripts on slave servers)
# upstream: https://github.com/openbsd/src (usr.sbin/ypserv)
# Flags from usr.sbin/ypserv/ypxfr/ypxfr.8 on tip.

_ypxfr() {
    _arguments \
        '-c[force; do not clear local maps first]' \
        '-f[force transfer even if local copy fresh]' \
        '-C+[callback tid prog ipaddr port]:tid prog ipaddr port:' \
        '-d+[domain]:domain:' \
        '-h+[source host]:host:_hosts' \
        '-s+[source domain]:domain:' \
        '1:mapname:'
}

_ypxfr "$@"
