#compdef adrgen
# adrgen — Architecture Decision Records generator

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a subcommands=(
  'init:initialize ADR configuration'
  'new:create a new ADR'
  'list:list existing ADRs'
  'config:show configuration'
)

_arguments -s -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'adrgen command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (init)
        _arguments -s -S \
          '(-d --directory)'{-d,--directory=}'[ADR directory]:dir:_files -/' \
          '(-t --template)'{-t,--template=}'[template file]:file:_files' \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
      (new)
        _arguments -s -S \
          '(-s --supersedes)'{-s,--supersedes=}'[ID of superseded ADR]:id:' \
          '(-a --amends)'{-a,--amends=}'[ID of amended ADR]:id:' \
          '(-m --meta)'{-m,--meta=}'[metadata key=value]:meta:' \
          '(- *)'{-h,--help}'[show help]' \
          '*:title:' \
          && ret=0
        ;;
      (list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
      (config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
