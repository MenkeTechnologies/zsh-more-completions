#compdef pretzel
# Documentation: https://github.com/Code52/pretzel
# Pretzel .NET static site generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--engine=[templating engine]:engine:(liquid razor)' \
  '--port=[server port]:port:' \
  '1:command:(create bake taste recipe import version cleanup)' \
  '*::arg:_files' && ret=0

return ret
