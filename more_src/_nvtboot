#compdef nvtboot
# Documentation: https://man.archlinux.org/search?q=nvtboot
# Reference accessed: 2026-05-16

# nvtboot: Tegra Trusted boot helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-d[device]:dev:' \
  '-c[config]:file:_files' \
  '-i[image]:file:_files' \
  '*::nvtboot args:_files' && ret=0
return ret
