#compdef ghproxy
# _ghproxy — caching reverse-proxy in front of api.github.com (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/ghproxy/ghproxy.go (flag).

_ghproxy() {
    _arguments \
        '-cache-dir=[disk cache directory]:dir:_files -/' \
        '-cache-sizeGB=[disk cache size (GB) per token]:n:' \
        '-legacy-disable-disk-cache-partitions-by-auth-header=[disable partitioning disk cache by auth header]:val:(true false)' \
        '-redis-address=[redis cache address]:host\:port:' \
        '-redis-username=[redis username]:user:' \
        '-redis-secret-file=[redis secret file]:file:_files' \
        '-port=[listen port]:port:' \
        '-upstream=[upstream URL]:url:_urls' \
        '-concurrency=[max concurrent in-flight GitHub requests]:n:' \
        '-throttling-time-ms=[per-org throttling time spacing (ms)]:ms:' \
        '-throttling-time-v4-ms=[per-org throttling time spacing for APIv4 (ms)]:ms:' \
        '-get-throttling-time-ms=[per-org throttling time for GET (ms)]:ms:' \
        '-throttling-max-delay-duration-seconds=[max throttling delay (s)]:s:' \
        '-throttling-max-delay-duration-v4-seconds=[max throttling delay for APIv4 (s)]:s:' \
        '-push-gateway=[Prometheus push gateway URL]:url:_urls' \
        '-push-gateway-interval=[push gateway interval]:duration:' \
        '-log-level=[log level]:level:(debug info warn error)' \
        '-serve-metrics[serve Prometheus metrics]' \
        '-request-timeout=[request timeout (s)]:s:'
}

_ghproxy "$@"
