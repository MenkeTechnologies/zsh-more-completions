#compdef labwc
# Documentation: https://labwc.github.io/labwc.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for labwc - stacking Wayland compositor

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[specify config file]:file:_files' \
  '(-C --config-dir)'{-C+,--config-dir=}'[specify config directory]:directory:_files -/' \
  '(-d --debug)'{-d,--debug}'[enable full debug logging]' \
  '(-e --exit)'{-e,--exit}'[exit the compositor]' \
  '(-m --merge-config)'{-m,--merge-config}'[merge user and system config]' \
  '(-r --reconfigure)'{-r,--reconfigure}'[reload configuration]' \
  '(-s --startup)'{-s+,--startup=}'[run command on startup]:command:_command_names' \
  '(-S --session)'{-S+,--session=}'[run command on startup and exit on its termination]:command:_command_names' \
  '(-t --title)'{-t+,--title=}'[window title format for nested instances]:fmt:' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose logging]'
