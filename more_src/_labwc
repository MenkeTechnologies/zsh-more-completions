#compdef labwc

# Zsh completion for labwc - stacking Wayland compositor

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[specify config directory]:directory:_files -/' \
  '(-C --config-dir)'{-C,--config-dir}'[config directory]:directory:_files -/' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-e --exit)'{-e,--exit}'[exit after processing config]' \
  '(-m --merge-config)'{-m,--merge-config}'[merge user and system config]' \
  '(-r --reconfigure)'{-r,--reconfigure}'[send reconfigure signal]' \
  '(-s --startup)'{-s,--startup}'[startup command]:command:_command_names' \
  '(-R --renderer)'{-R,--renderer}'[set renderer]:renderer'
