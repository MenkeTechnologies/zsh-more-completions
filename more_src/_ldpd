#compdef ldpd
# Documentation: https://docs.frrouting.org/en/latest/basic.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (FRR Common Invocation Options
# plus ldpd-specific --ctl_socket per docs.frrouting.org/en/latest/ldpd.html).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[run in daemon mode]' \
  '(-f --config_file)'{-f+,--config_file=}'[set configuration file]:file:_files' \
  '(-i --pid_file)'{-i+,--pid_file=}'[write pid to file]:file:_files' \
  '(-A --vty_addr)'{-A+,--vty_addr=}'[VTY local bind address]:addr:' \
  '(-P --vty_port)'{-P+,--vty_port=}'[VTY TCP port]:port:' \
  '-u+[run as user]:user:_users' \
  '-N+[namespace]:namespace:' \
  '(-M --module)'{-M+,--module=}'[load module]:module:' \
  '--log=[log destination]:dest:(stdout syslog file)' \
  '--log-level=[default log level]:level:(emergencies alerts critical errors warnings notifications informational debugging)' \
  '--command-log-always[log every command]' \
  '--limit-fds=[file descriptor limit]:n:' \
  '--ctl_socket=[override ldpd.sock path]:file:_files' && ret=0

return ret
