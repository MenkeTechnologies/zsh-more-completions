#compdef expect

local -a arguments

arguments=(
    '-c[execute command before script]:command'
    '-d[enable diagnostics]'
    '-D[enable interactive debugger]'
    '-f[read commands from file]:script file:_files -g "*.{exp,tcl}"'
    '-i[interactively prompt for commands]'
    '-n[do not source ~/.expect.rc]'
    '-N[do not source system-wide expect.rc]'
    '-v[print version and exit]'
    '-b[read file line by line (unbuffered)]'
    '--[end of options]'
    '*:expect script:_files -g "*.{exp,tcl}"'
)

_arguments -s -S $arguments
