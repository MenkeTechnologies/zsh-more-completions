#compdef cuda-memcheck
# Documentation: (NVIDIA removed cuda-memcheck docs; deprecated CUDA 11, removed 12)
# Reference accessed: 2026-05-16
# Verified: NVIDIA docs page returns 404 - cuda-memcheck was
# deprecated in CUDA 11 and removed in CUDA 12. Users should
# migrate to compute-sanitizer (see _compute-sanitizer). Historical
# flag set kept here for legacy CUDA installations.
# Removed from prior file: bogus man.archlinux.org search URL.

# cuda-memcheck: deprecated CUDA memory checker (use compute-sanitizer)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--tool=[sanitizer tool]:tool:(memcheck racecheck initcheck synccheck)' \
  '--leak-check=[leak check mode]:mode:(full no)' \
  '--log-file=[log to file]:file:_files' \
  '--save=[save report to file]:file:_files' \
  '--print-level=[print level]:level:' \
  '--show-backtrace=[backtrace mode]:mode:(no host device yes)' \
  '--error-exitcode=[exit code on error]:n:' \
  '--prefix=[output prefix]:prefix:' \
  '--demangle=[name demangling]:mode:(full simple none)' \
  '*:cuda executable:_files' && ret=0
return ret
