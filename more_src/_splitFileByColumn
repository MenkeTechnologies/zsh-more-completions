#compdef splitFileByColumn
# Documentation: https://github.com/ucscGenomeBrowser/kent/blob/master/src/utils/splitFileByColumn/splitFileByColumn.c
# Split text input into files named by column value

local ret=1

_arguments -s -S \
  '-col=[use the Nth column value (default 1)]:n:' \
  '-head=[put head in front of each output]:file:_files' \
  '-tail=[put tail at end of each output]:file:_files' \
  '-chromDirs[split into subdirs of outDir distilled from chrom names]' \
  '-ending=[use XXX as the dot-suffix of split files]:suffix:' \
  '-tab[split by tab characters instead of whitespace]' \
  '*:source outDir:_files' && ret=0

return ret
