#compdef vifm
# _vifm-bin — Vifm Vim-style ncurses file manager (xaizek, C); two-pane file manager with vi keybindings
# upstream: https://github.com/vifm/vifm

_vifm-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-f[print last cwd on exit]' \
        '-c+[execute Vifm command]:cmd:' \
        '-+[execute command]:cmd:' \
        '--select+[select path]:file:_files' \
        '--choose-files+[file picker mode]:file:_files' \
        '--choose-dir+[dir picker mode]:file:_files' \
        '--delimiter+[picker delimiter]:str:' \
        '--logging+[logging file]:file:_files' \
        '--server-list[list active servers]' \
        '--server-name+[server name]:name:' \
        '--remote[send remote command to server]' \
        '--remote-expr+[send remote vimscript-like expr]:expr:' \
        '--on-choose+[run on choose]:cmd:' \
        '--no-configs[skip config files]' \
        '*:path:_files'
}

_vifm-bin "$@"
