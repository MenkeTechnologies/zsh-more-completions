#compdef mp4trackdump
# _mp4trackdump — dump samples from MP4 tracks (enzo1982/mp4v2)
# upstream: https://github.com/enzo1982/mp4v2
# Flags from util/mp4trackdump.cpp (prog::Option long_options).

_mp4trackdump() {
    _arguments \
        '(- *)'{-V,--version}'[show version]' \
        '(-t --track)'{-t+,--track=}'[track ID]:id:' \
        '(-s --sample)'{-s+,--sample=}'[sample ID]:id:' \
        '(-v --verbose)'{-v+,--verbose=}'[verbosity level (0-3)]:level:(0 1 2 3)' \
        '*:MP4 file:_files -g "*.(m4a|m4v|mp4)"'
}

_mp4trackdump "$@"
