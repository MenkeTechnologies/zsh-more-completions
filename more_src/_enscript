#compdef enscript
# _enscript — GNU enscript (pretty-print text -> PostScript/HTML/RTF; -2/-3 columns, -B no header, -G fancy header, -E pretty-printing language, -p output file, -P printer, -r landscape, -f font, -L lines per page, -T tab size)
# upstream: https://savannah.gnu.org/cvs/?group=enscript
# Flags from enscript src/main.c on tip.

_enscript() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-1[1 column]' \
        '-2[2 columns]' \
        '-3[3 columns]' \
        '-4[4 columns]' \
        '-5[5 columns]' \
        '-6[6 columns]' \
        '-7[7 columns]' \
        '-8[8 columns]' \
        '-9[9 columns]' \
        '-B[no page headers]' \
        '-G[fancy headers]' \
        '-r[landscape orientation]' \
        '-R[portrait orientation]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-Z[interpret form-feeds as new page]' \
        '-c[truncate long lines]' \
        '-E+[language to syntax-highlight]:lang:(asm awk bash c cpp changelog csharp delphi diff diffs diffu elisp forth fortran haskell html idl inf java javascript ksh lua m4 mail makefile matlab nroff objc outline pascal perl postscript pyrex python ruby rfc scheme sh sql states synopsys tcl tcsh tex vba verilog vhdl vrml wmlscript zsh)' \
        '-f+[font]:font:(Courier Courier-Bold Courier-Italic Times-Roman Helvetica)' \
        '-F+[header font]:font:' \
        '-p+[output file]:file:_files' \
        '-P+[printer]:printer:_printers' \
        '-L+[lines per page]:n:' \
        '-T+[tab size]:n:' \
        '-M+[paper size]:size:(A4 Letter Legal A3 A5 Tabloid Executive)' \
        '-t+[banner page title]:title:' \
        '-X+[input encoding]:encoding:(ascii latin1 latin2 latin3 latin4 latin5 latin6 ps mac koi8 hp8 vms)' \
        '-w+[output language]:lang:(PostScript html overstrike RTF MarkUp)' \
        '*:file:_files'
}

_enscript "$@"
