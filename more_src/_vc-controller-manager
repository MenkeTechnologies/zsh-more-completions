#compdef vc-controller-manager volcano-controller-manager
# _vc-controller-manager — Volcano Job/PodGroup/Queue controllers (volcano-sh/volcano)
# upstream: https://github.com/volcano-sh/volcano
# Flags from cmd/controller-manager/app/options/options.go on tip.

_vc-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--master=[apiserver URL override]:url:_urls' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--ca-cert-file=[CA cert file for HTTPS]:file:_files' \
        '--tls-cert-file=[TLS server cert]:file:_files' \
        '--tls-private-key-file=[TLS server key]:file:_files' \
        '--kube-api-qps=[Kubernetes API QPS]:f:' \
        '--kube-api-burst=[Kubernetes API burst]:n:' \
        '--worker-threads=[concurrent Job-sync threads]:n:' \
        '--worker-threads-for-cronjob=[concurrent CronJob-sync threads]:n:' \
        '--worker-threads-for-podgroup=[concurrent PodGroup-sync threads]:n:' \
        '*--scheduler-name=[handled scheduler names]:name:' \
        '--max-requeue-num=[max requeues before dropping]:n:' \
        '--listen-address=[HTTP server bind host\:port]:host\:port:' \
        '--healthz-address=[health-check bind host\:port]:host\:port:' \
        '--enable-healthz=[enable health check]:bool:(true false)' \
        '--enable-metrics=[enable metrics endpoint]:bool:(true false)' \
        '--inherit-owner-annotations=[inherit owner annotations to PodGroup]:bool:(true false)' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '--leader-elect-resource-namespace=[leader election namespace]:ns:' \
        '-v[klog verbosity level]:n:'
}

_vc-controller-manager "$@"
