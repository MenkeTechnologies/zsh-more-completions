#compdef espup

# Zsh completion for espup (ESP Rust development environment installer)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'completions:generate shell completions'
      'install:install the ESP Rust environment'
      'uninstall:uninstall the ESP Rust environment'
      'update:update the ESP Rust environment'
    )
    _describe -t commands 'espup command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (install|update)
        _arguments \
          '(-d --default-host)'{-d,--default-host}'[default host triple]:triple' \
          '(-f --export-file)'{-f,--export-file}'[export file]:file:_files' \
          '(-l --log-level)'{-l,--log-level}'[log level]:level:(debug info warn error)' \
          '(-a --name)'{-a,--name}'[toolchain name]:name' \
          '(-n --nightly-version)'{-n,--nightly-version}'[nightly version]:version' \
          '(-s --std)'{-s,--std}'[install esp-idf]:version' \
          '(-t --targets)'{-t,--targets}'[targets]:target:(esp32 esp32c2 esp32c3 esp32c6 esp32h2 esp32s2 esp32s3 all)' \
          '(-v --toolchain-version)'{-v,--toolchain-version}'[toolchain version]:version' \
          '--extended-llvm[install extended LLVM]' && ret=0
        ;;
      (uninstall)
        _arguments \
          '(-l --log-level)'{-l,--log-level}'[log level]:level:(debug info warn error)' \
          '(-a --name)'{-a,--name}'[toolchain name]:name' && ret=0
        ;;
      (completions)
        _arguments '1:shell:(bash elvish fish powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
