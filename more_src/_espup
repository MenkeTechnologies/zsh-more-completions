#compdef espup
# Documentation: https://github.com/esp-rs/espup
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for espup (ESP Rust development environment installer)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'completions:generate shell completions'
      'install:install the ESP Rust environment'
      'uninstall:uninstall the ESP Rust environment'
      'update:update the ESP Rust environment'
    )
    _describe -t commands 'espup command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (install)
        _arguments \
          '(-d --default-host)'{-d,--default-host}'=[host target triple]:triple' \
          '(-r --esp-riscv-gcc)'{-r,--esp-riscv-gcc}'[install Espressif RISC-V toolchain]' \
          '(-f --export-file)'{-f,--export-file}'=[export file path]:file:_files' \
          '--disable-timeouts[remove HTTP timeout restrictions]' \
          '(-e --extended-llvm)'{-e,--extended-llvm}'[install full LLVM]' \
          '(-l --log-level)'{-l,--log-level}'=[log level]:level:(debug info warn error)' \
          '(-a --name)'{-a,--name}'=[toolchain name]:name' \
          '(-b --stable-version)'{-b,--stable-version}'=[stable Rust version]:version' \
          '(-k --skip-version-parse)'{-k,--skip-version-parse}'[skip Xtensa version parsing]' \
          '(-s --std)'{-s,--std}'[install toolchains required for std]' \
          '(-t --targets)'{-t,--targets}'=[targets]:target:(esp32 esp32c2 esp32c3 esp32c6 esp32h2 esp32s2 esp32s3 all)' \
          '(-v --toolchain-version)'{-v,--toolchain-version}'=[toolchain version]:version' && ret=0
        ;;
      (update)
        _arguments \
          '(-d --default-host)'{-d,--default-host}'=[host target triple]:triple' \
          '(-f --export-file)'{-f,--export-file}'=[export file path]:file:_files' \
          '--disable-timeouts[remove HTTP timeout restrictions]' \
          '(-e --extended-llvm)'{-e,--extended-llvm}'[install full LLVM]' \
          '(-l --log-level)'{-l,--log-level}'=[log level]:level:(debug info warn error)' \
          '(-a --name)'{-a,--name}'=[toolchain name]:name' \
          '(-b --stable-version)'{-b,--stable-version}'=[stable Rust version]:version' \
          '(-k --skip-version-parse)'{-k,--skip-version-parse}'[skip Xtensa version parsing]' \
          '(-s --std)'{-s,--std}'[install toolchains required for std]' \
          '(-t --targets)'{-t,--targets}'=[targets]:target:(esp32 esp32c2 esp32c3 esp32c6 esp32h2 esp32s2 esp32s3 all)' \
          '(-v --toolchain-version)'{-v,--toolchain-version}'=[toolchain version]:version' && ret=0
        ;;
      (uninstall)
        _arguments \
          '(-l --log-level)'{-l,--log-level}'=[log level]:level:(debug info warn error)' \
          '(-a --name)'{-a,--name}'=[toolchain name]:name' && ret=0
        ;;
      (completions)
        _arguments \
          '(-l --log-level)'{-l,--log-level}'=[log level]:level:(debug info warn error)' \
          '1:shell:(bash elvish fish powershell zsh nushell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
