#compdef sbom4files
# Documentation: https://pypi.org/project/sbom4files/
# generate an SBOM for the files within a directory

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --directory)'{-d,--directory}'=[directory to scan]:directory:_files -/' \
  '(-p --project)'{-p,--project}'=[project name]:name:' \
  '-r[recurse into subdirectories]' \
  '(-i --ignore)'{-i,--ignore}'=[files to ignore]:pattern:' \
  '--debug[show debug information]' \
  '--sbom=[SBOM type]:type:(spdx cyclonedx)' \
  '--format=[output format]:format:(tag json yaml)' \
  '(-o --output-file)'{-o,--output-file}'=[output file]:file:_files' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
