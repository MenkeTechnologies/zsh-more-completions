#compdef owasp-zap zap
# Documentation: https://man.archlinux.org/search?q=owasp-zap
# Reference accessed: 2026-05-16

# OWASP ZAP: web app proxy/scanner (Java)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-cmd[command-line mode (no GUI)]' \
  '-daemon[run as daemon (headless)]' \
  '-host[host to bind]:host:_hosts' \
  '-port[port to listen]:port:' \
  '-config[set config key=value]:kv:' \
  '-configfile[config file]:file:_files' \
  '-dir[home directory]:dir:_files -/' \
  '-session[session file]:file:_files' \
  '-newsession[create new session]:file:_files' \
  '-installdir[ZAP install directory]:dir:_files -/' \
  '-quickurl[quick attack URL]:url:' \
  '-quickout[quick scan output file]:file:_files' \
  '-quickprogress[print quick scan progress]' \
  '-silent[disable telemetry]' \
  '-nostdout[disable stdout]' \
  '-no_default_user_agent[disable default user-agent]' \
  '-tunnel[set HTTP CONNECT tunnel]:host\\:port:' \
  '-suicide[exit after autoinstall]' \
  '*::owasp-zap args:_files' && ret=0
return ret
