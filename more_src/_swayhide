#compdef swayhide
# Documentation: https://man.archlinux.org/search?q=swayhide
# Reference accessed: 2026-05-16

# Zsh completion for swayhide Sway window swallower (NomisIV/swayhide).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[usage information]' \
  '(-t)-t[use tabbed layout before spawn]' \
  '*::command and arguments:_normal'
