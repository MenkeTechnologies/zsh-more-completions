#compdef hush-cli
# _hush-cli — Hush Project hush-cli JSON-RPC client CLI for the Hush privacy-focused Zcash fork hushd daemon issuing wallet z_sendmany z_getbalance z_listunspent z_shieldcoinbase shielded encrypted memo on-chain hush messenger contacts (HushProject team, C++); custom argparse
# upstream: https://git.hush.is/hush/hush3

_hush-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf HUSH3.conf hush.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-testnet[use testnet]' \
        '-regtest[use regtest]' \
        '-named[use named JSON-RPC]' \
        '-rpcconnect=+[host]:h:_hosts' \
        '-rpcport=+[port]:n:' \
        '-rpcwait[wait for RPC server]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcclienttimeout=+[seconds]:n:' \
        '-rpccookiefile=+[file]:file:_files' \
        '-ac_name=+[chain]:str:' \
        '-stdin[read input from stdin]' \
        '-stdinrpcpass[read RPC password from stdin]' \
        '-getinfo[print info]' \
        '*:rpc command:(getblockchaininfo getblockcount getblockhash getblock getnetworkinfo getmempoolinfo getbalance listunspent listtransactions sendtoaddress getnewaddress validateaddress dumpprivkey importprivkey importwallet dumpwallet generate getrawtransaction sendrawtransaction signrawtransactionwithwallet z_getbalance z_listunspent z_sendmany z_listoperationids z_getoperationresult z_shieldcoinbase z_mergetoaddress z_getnewaddress z_listaddresses z_exportviewingkey z_importviewingkey z_exportwallet z_importwallet z_validatepaymentdisclosure cc_address listblocksincnotarized z_messagesignaturenodename z_messagedecrypt z_messagesignature)'
}

_hush-cli "$@"
