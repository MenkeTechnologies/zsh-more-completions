#compdef ssadump
# _ssadump — Go x/tools SSA dumper (Alan Donovan); print SSA form of Go packages for offline inspection
# upstream: https://pkg.go.dev/golang.org/x/tools/cmd/ssadump

_ssadump() {
    _arguments \
        '-arg+[args to main]:args:' \
        '-build+[build flags]:flags:' \
        '-cpuprofile+[CPU profile]:file:_files' \
        '-interp+[interpreter mode flags]:flags:' \
        '-mode+[ssa.BuilderMode flags]:mode:' \
        '-run[also run the program]' \
        '-test[include tests]' \
        '*:packages:'
}

_ssadump "$@"
