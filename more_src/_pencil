#compdef pencil
# Documentation: https://github.com/pencil2d/pencil
# Reference accessed: 2026-05-20
# Verified: upstream Pencil2D GitHub. GUI-only Qt app; only accepts a
# .pclx project file as positional arg.

# pencil: Pencil2D 2D animation editor (GUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:project file:_files -g "*.pclx(-.)"' && ret=0
return ret
