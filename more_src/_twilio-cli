#compdef twilio
# Documentation: https://www.twilio.com/docs/twilio-cli/general-usage
# Reference accessed: 2026-05-21
# Verified: Twilio CLI general usage docs.
# NOTE: twilio CLI commands are extended dynamically via plugins; only
# the core command set is enumerated. See _twilio for the canonical
# completion.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'api:Twilio REST API access'
  'autocomplete:display autocomplete installation instructions'
  'config:CLI configuration'
  'debugger:webhook debugger events'
  'help:show help'
  'login:create a new profile'
  'logout:remove credentials'
  'phone-numbers:phone number commands'
  'plugins:plugin management'
  'profiles:profile commands'
  'update:update the CLI'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-l+[log level]:l:(debug info warn error)' \
  '*--logLevel=[log level]:l:(debug info warn error)' \
  '*-o+[output format]:f:(columns json tsv)' \
  '*--output=[output format]:f:(columns json tsv)' \
  '*-p+[profile]:p:' \
  '*--profile=[profile]:p:' \
  '*--silent[silence output]' \
  '*--no-color[disable colored output]' \
  '*--region=[Twilio region]:region:' \
  '*--edge=[Twilio edge location]:edge:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'twilio command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (api)
        _arguments '*: :' && ret=0 ;;
      (phone-numbers)
        _arguments \
          '1:subcommand:(buy list update)' \
          '*: :' && ret=0 ;;
      (profiles)
        _arguments \
          '1:subcommand:(add create list remove use)' \
          '*: :' && ret=0 ;;
      (plugins)
        _arguments \
          '1:subcommand:(install link uninstall update inspect)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
