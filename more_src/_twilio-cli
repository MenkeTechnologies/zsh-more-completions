#compdef twilio
# Documentation: https://github.com/twilio/twilio-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'access:access tokens'
  'api:Twilio REST API access'
  'autopilot:Autopilot tools'
  'bulk-sms:bulk SMS sender'
  'completion:generate completions'
  'config:CLI config'
  'conversations:Conversations API'
  'debugger:webhook debugger'
  'flex:Flex tools'
  'help:show help'
  'login:log in'
  'logout:log out'
  'phone-number:phone number commands'
  'phone-numbers:phone number commands'
  'plugins:plugin management'
  'profiles:profile commands'
  'serverless:serverless tools'
  'studio:Studio tools'
  'taskrouter:TaskRouter tools'
  'token:show token'
  'webhook-config:webhook config'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-l+[log level]:l:(debug info warn error)' \
  '*--logLevel=[log level]:l:(debug info warn error)' \
  '*-o+[output format]:f:(columns json tsv csv)' \
  '*--output=[output format]:f:(columns json tsv csv)' \
  '*-p+[profile]:p:' \
  '*--profile=[profile]:p:' \
  '*--no-truncate[no truncate]' \
  '*--no-header[no header]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'twilio command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (api)
        _arguments \
          '*: :' && ret=0 ;;
      (phone-number|phone-numbers)
        _arguments \
          '1:subcommand:(buy list update)' \
          '*: :' && ret=0 ;;
      (profiles)
        _arguments \
          '1:subcommand:(create list remove use)' \
          '*: :' && ret=0 ;;
      (plugins)
        _arguments \
          '1:subcommand:(install link uninstall update)' \
          '*: :' && ret=0 ;;
      (serverless)
        _arguments \
          '1:subcommand:(init deploy promote start list view list-templates)' \
          '*: :_files -/' && ret=0 ;;
      (flex)
        _arguments \
          '1:subcommand:(plugins config webchat)' \
          '*: :' && ret=0 ;;
      (login|logout|token|debugger|webhook-config)
        _arguments '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
