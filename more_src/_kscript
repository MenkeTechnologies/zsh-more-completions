#compdef kscript
# _kscript — kscript Kotlin scripting (kscripting/kscript)
# upstream: https://github.com/kscripting/kscript

_kscript() {
    _arguments -s -S \
        '(-i --interactive)'{-i,--interactive}'[start interactive REPL]' \
        '--idea[open script in IntelliJ IDEA]' \
        '--package[package script as standalone binary]' \
        '--add-cp=[add to classpath]:classpath:' \
        '(-t --text)'{-t,--text}'[enable stdin text processing mode]' \
        '--clear-cache[clear cached script jars]' \
        '--report[print script structure report]' \
        '--help[show help]' \
        '1:script file:_files -g "*.{kts,kt}"' \
        '*:script args:'
}

_kscript "$@"
