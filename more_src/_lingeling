#compdef lingeling
# Documentation: https://github.com/arminbiere/lingeling
# lingeling SAT solver

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print command line option summary]' \
  '--version[print version and exit]' \
  '-o[set output file]:output file:_files' \
  '-p[read options from file]:options file:_files' \
  '-t[set proof trace output file]:trace file:_files' \
  '(-f --force)'{-f,--force}'[force reading even without header]' \
  '-s[only simplify and print to output file]' \
  '-O+[set simplification level]:level' \
  '-T+[set time limit]:seconds' \
  '-a[use multiple assumptions]' \
  '-q[be quiet]' \
  '(-d --defaults)'{-d,--defaults}'[print default values of options]' \
  '(-r --ranges)'{-r,--ranges}'[print value ranges of options]' \
  '(-P --pcs)'{-P,--pcs}'[print full PCS file]' \
  '(-e --embedded)'{-e,--embedded}'[print embedded format]' \
  '-n[do not print solution]' \
  '-c[increase checking level]' \
  '-l[increase logging level]' \
  '-v[increase verbose level]' \
  '*:dimacs file:_files' && ret=0

return ret
