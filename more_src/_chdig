#compdef chdig
# Documentation: https://github.com/Altinity/chdig
# Reference accessed: 2026-05-17
# Verified: upstream repo at the URL above.
# Altinity/chdig - ClickHouse top-like UI for cluster inspection

local ret=1
_arguments -s \
  '(-h)'{-h,--help}'[help]' \
  '--host=[ClickHouse host]:host:' \
  '--port=[native TCP port]:port:' \
  '--user=[user]:user:' \
  '--password=[password]:password:' \
  '--secure[TLS]' \
  '*::query or options:_default' && ret=0
return ret
