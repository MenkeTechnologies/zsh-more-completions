#compdef chdig
# Documentation: https://man.archlinux.org/search?q=chdig
# Reference accessed: 2026-05-16

# azat/chdig — clickhouse top UI; Homebrew: Formula/c/chdig.rb

local ret=1
_arguments -s \
  '(-h)'{-h,--help}'[help]' \
  '--host=[ClickHouse host]:host:' \
  '--port=[native TCP port]:port:' \
  '--user=[user]:user:' \
  '--password=[password]:password:' \
  '--secure[TLS]' \
  '*::query or options:_default' && ret=0
return ret
