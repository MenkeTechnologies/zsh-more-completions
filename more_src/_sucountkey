#compdef sucountkey
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/sucountkey.c
# SUCOUNTKEY - count the number of unique values for a given key

local ret=1

_arguments -s -S \
  'key=[array of SU header keywords being counted]:k:' \
  'verbose=[=0 just print keyword number]:v:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
