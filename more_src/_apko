#compdef apko

_apko_subcommands() {
  local -a subcmds=(
    'build:Build an image from a YAML configuration file'
    'completion:Generate shell completion scripts'
    'dot:Generate a dot graph of the package dependencies'
    'login:Log in to a registry'
    'publish:Build and publish an image to a registry'
    'show-config:Show the parsed configuration'
    'show-packages:Show the packages that would be installed'
    'version:Print the version'
  )
  _describe -t commands 'apko subcommand' subcmds
}

_apko() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '--log-level[Set the log level]:level:(debug info warn error fatal panic)' \
    '--log-policy[Log policy for log entries]:policy:' \
    '--workdir[Set the working directory]:dir:_directories' \
    '1:subcommand:_apko_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        build)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--arch[Architectures to build for]:arch:' \
            '--build-date[Date for the build]:date:' \
            '--cache-dir[Directory for caching]:dir:_directories' \
            '--debug[Enable debug logging]' \
            '--lockfile[Path to lockfile]:file:_files' \
            '--no-network[Disable network access]' \
            '--sbom[Generate SBOM]' \
            '--sbom-path[Path for SBOM output]:dir:_directories' \
            '--timestamp[Timestamp for reproducibility]:timestamp:' \
            '1:config:_files -g "*.yaml"' \
            '2:output:_files -g "*.tar"'
          ;;
        publish)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--arch[Architectures to build for]:arch:' \
            '--build-date[Date for the build]:date:' \
            '--cache-dir[Directory for caching]:dir:_directories' \
            '--debug[Enable debug logging]' \
            '--image-refs[Path to write image refs]:file:_files' \
            '--lockfile[Path to lockfile]:file:_files' \
            '--no-network[Disable network access]' \
            '--sbom[Generate SBOM]' \
            '--sbom-path[Path for SBOM output]:dir:_directories' \
            '1:config:_files -g "*.yaml"' \
            '2:image-ref:'
          ;;
      esac
      ;;
  esac
}

_apko "$@"
