#compdef metadata openmetadata

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'ingest:run a metadata ingestion workflow'
  'ingest-dbt:ingest dbt metadata'
  'lineage:run a lineage workflow'
  'usage:run a usage workflow'
  'profile:run a profile workflow'
  'test:run a test/data-quality workflow'
  'app:run an OpenMetadata app workflow'
  'classify:run a classification workflow'
  'webhook:start a local webhook listener'
  'scaffold-connector:scaffold a custom connector'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-l --log-level)'{-l,--log-level=}'[log level]:level:(INFO DEBUG WARNING ERROR CRITICAL)' \
  '--debug[enable debug logging]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'metadata subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (ingest|lineage|usage|profile|test|app|classify)
        _arguments \
          '(-c --config)'{-c,--config=}'[config file]:file:_files -g "*.(yaml|yml|json)"' && ret=0
        ;;
      (ingest-dbt)
        _arguments \
          '(-c --dbt-project-path)'{-c,--dbt-project-path=}'[dbt project path]:dir:_files -/' && ret=0
        ;;
      (webhook)
        _arguments \
          '(-H --host)'{-H,--host=}'[host]:host:_hosts' \
          '(-p --port)'{-p,--port=}'[port]:port:' && ret=0
        ;;
    esac
    ;;
esac

return ret
