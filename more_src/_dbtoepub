#compdef dbtoepub

local -a arguments

arguments=(
    '-c[CSS stylesheet]:stylesheet:_files -g "*.css"'
    '-d[Enable debug output]'
    '-f[Font to embed]:font file:_files'
    '-h[Show help]'
    '-o[Output file]:output file:_files -g "*.epub"'
    '-s[Custom XSL stylesheet]:xsl file:_files -g "*.xsl"'
    '-v[Enable verbose output]'
    '*:DocBook file:_files -g "*.xml"'
)

_arguments -s -S $arguments
