#compdef obspy-plot
# Documentation: https://docs.obspy.org/
# ObsPy: plot seismogram waveform files

local ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --format)'{-f,--format}'+[waveform format]:format' \
  '(-o --outfile)'{-o,--outfile}'+[output filename]:file:_files' \
  '(-n --no-automerge)'{-n,--no-automerge}'[disable automatic merging of matching channels]' \
  '--full[disable min/max plot, always plot every sample]' \
  '*:files:_files' && ret=0

return ret
