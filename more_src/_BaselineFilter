#compdef BaselineFilter
# OpenMS TOPP: remove the baseline from profile MS data

local ret=1

_arguments -s -S \
  '-in[input raw data file (mzML)]:input file:_files' \
  '-out[output raw data file (mzML)]:output file:_files' \
  '-struc_elem_length[length of the structuring element]:value:' \
  '-struc_elem_unit[unit for structuring element]:unit:(Thomson DataPoints)' \
  '-method[morphological filter algorithm]:method:(identity erosion dilation opening closing gradient tophat bothat erosion_simple dilation_simple)' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
