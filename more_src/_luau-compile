#compdef luau-compile
# Documentation: https://github.com/luau-lang/luau/blob/master/CLI/src/Compile.cpp
# compile Luau source to bytecode or native code

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display usage information]' \
  '--binary[output bytecode in binary format]' \
  '--text[output bytecode in text format]' \
  '--remarks[display source remarks]' \
  '--codegen[show annotated native code with IR and assembly]' \
  '--codegenasm[show annotated native code assembly only]' \
  '--codegenir[show annotated native code IR only]' \
  '--codegenverbose[show annotated native code with IR, assembly and outlined code]' \
  '--codegennull[generate native code without output]' \
  '--null[compile without output]' \
  '-O+[optimization level (0-2)]:level:(0 1 2)' \
  '-g+[debug level (0-2)]:level:(0 1 2)' \
  '-t+[type info level (0-1)]:level:(0 1)' \
  '--target=[native architecture target]:target:(a64 x64 a64_nf x64_ms)' \
  '--timetrace[record compiler time tracing information into trace.json]' \
  '--record-stats=[set statistics granularity]:granularity:(total file function)' \
  '--bytecode-summary[compute bytecode operation distribution]' \
  '--dump-constants[dump constant table per function]' \
  '--stats-file=[output statistics file]:file:_files' \
  '--vector-lib=[vector type library name]:name' \
  '--vector-ctor=[vector constructor function name]:name' \
  '--vector-type=[vector type name]:name' \
  '--only-parse[parse input without compilation]' \
  '--parse-cst[parse CST in addition to AST]' \
  '--fflags=[comma-separated list of fast flags to enable/disable]:flags' \
  '*:lua file:_files -g "*.lua"' && ret=0

return ret
