#compdef vector

_vector_cmds() {
    local -a commands=(
        'config:manage Vector configuration'
        'generate:generate a Vector configuration'
        'graph:output the topology as a visual graph'
        'list:list available components'
        'tap:observe log events from a running Vector instance'
        'top:display running metrics from a Vector instance'
        'test:run unit tests'
        'validate:validate configuration files'
        'vrl:execute VRL programs'
        'help:print help information'
    )
    _describe -t commands 'vector command' commands
}

_vector() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-V --version)'{-V,--version}'[print version]' \
        '(-v --verbose)'{-v,--verbose}'[enable more detailed logging]' \
        '(-q --quiet)'{-q,--quiet}'[reduce detail of logging]' \
        '(-c --config)'{-c,--config}'=[configuration file]:file:_files' \
        '--config-dir=[configuration directory]:dir:_directories' \
        '--config-toml=[TOML configuration file]:file:_files' \
        '--config-json=[JSON configuration file]:file:_files' \
        '--config-yaml=[YAML configuration file]:file:_files' \
        '(-w --watch-config)'{-w,--watch-config}'[watch for config file changes]' \
        '--require-healthy[exit on health check failure]' \
        '--threads=[number of threads]:threads' \
        '--log-format=[log output format]:format:(text json)' \
        '--color=[color mode]:mode:(auto always never)' \
        '--openssl-no-probe[do not probe OpenSSL for configuration]' \
        '--graceful-shutdown-limit-secs=[graceful shutdown timeout]:seconds' \
        '--no-graceful-shutdown-limit[no shutdown timeout]' \
        '--internal-log-rate-limit=[internal log rate limit]:limit' \
        '1:command:_vector_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                validate)
                    _arguments \
                        '--no-environment[do not read from environment]' \
                        '--deny-warnings[treat warnings as errors]' \
                        '--config-yaml=[YAML config]:file:_files' \
                        '*:config-files:_files'
                    ;;
                test)
                    _arguments \
                        '*:config-files:_files'
                    ;;
                generate)
                    _arguments \
                        '--fragment[output fragment only]' \
                        '--format=[output format]:format:(toml yaml json)' \
                        '*:components'
                    ;;
                list)
                    _arguments \
                        '--format=[output format]:format:(text json avro)' \
                        '1:type:(sources transforms sinks)'
                    ;;
                tap)
                    _arguments \
                        '--url=[Vector GraphQL API URL]:url' \
                        '--interval=[refresh interval in ms]:interval' \
                        '--format=[output format]:format:(text json logfmt)' \
                        '--limit=[max events per interval]:limit' \
                        '--inputs-of=[observe inputs of component]:component' \
                        '--outputs-of=[observe outputs of component]:component' \
                        '*:components'
                    ;;
                top)
                    _arguments \
                        '--url=[Vector GraphQL API URL]:url' \
                        '--interval=[refresh interval in ms]:interval' \
                        '--human-metrics[human-readable metrics]'
                    ;;
                vrl)
                    _arguments \
                        '--input=[input event JSON]:json' \
                        '--program=[VRL program]:program' \
                        '--runtime=[runtime]:runtime:(ast)' \
                        '1:file:_files'
                    ;;
                graph)
                    _arguments \
                        '*:config-files:_files'
                    ;;
            esac
            ;;
    esac
}

_vector "$@"
