#compdef adr

# adr-tools — merged from `adr help` + subcommand-specific usage

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'help:show help for a command'
  'new:create a new ADR'
  'link:link two ADRs'
  'list:list all ADRs'
  'init:initialize an ADR directory'
  'config:emit config'
  'generate:generate summary documentation'
  'upgrade-repository:upgrade ADR layout'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'adr command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments '1:directory:_files -/' && ret=0
        ;;
      (new)
        _arguments -s -S \
          '*'{-s+}'[superseded ADR ref]:ref:' \
          '*'{-l+}'[TARGET:LINK:REVERSE-LINK]:spec:' \
          '*:title words:' && ret=0
        ;;
      (link)
        _arguments \
          '1:source ADR number:' \
          '2:link description:' \
          '3:target ADR number:' \
          '4:reverse link description:' && ret=0
        ;;
      (generate)
        _arguments '1:type:(toc graph)' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
