#compdef kerl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:build a release'
  'install:install build'
  'deploy:deploy to remote'
  'update:refresh release list'
  'list:list builds/releases/installations'
  'delete:delete build/installation'
  'active:show active'
  'status:show full state'
  'path:show install path'
  'build-install:build and install'
  'plt:Dialyzer PLT path'
  'prompt:prompt string'
  'cleanup:remove build artifacts'
  'emit-activate:emit activate script'
  'version:show version'
  'upgrade:self-upgrade'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'kerl subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (list) _arguments '1:type:(releases builds installations)' '2:filter:(all)' && ret=0 ;;
      (delete) _arguments '1:type:(build installation)' '2:name:' && ret=0 ;;
      (cleanup) _arguments '*:name or all:(all)' && ret=0 ;;
      (emit-activate) _arguments '1:release:' '2:build_name:' '3:directory:_files -/' '4:shell:(sh bash fish csh)' && ret=0 ;;
      (update) _arguments '1:what:(releases)' && ret=0 ;;
    esac
    ;;
esac

return ret
