#compdef img2imgcoord
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/registration/flirt/user_guide.html
# FSL: transform coordinates from one image space to another

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-src[source image]:src:_files' \
  '-dest[destination image]:dest:_files' \
  '-xfm[affine transformation matrix (source to dest)]:xfm:_files' \
  '-warp[non-linear warp field (source to dest)]:warp:_files' \
  '-premat[pre-warp affine transform]:premat:_files' \
  '-vox[output coordinates in voxels]' \
  '-mm[output coordinates in mm]' \
  '*:coordfile:_files' && ret=0

return ret
