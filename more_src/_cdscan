#compdef cdscan
# Documentation: https://cdms.readthedocs.io/en/latest/manual/cdms_7.html
# cdscan - CDMS utility to build an XML dataset metafile from netCDF files

local ret=1

_arguments -s \
  '-h[print a help message]' \
  '-a[change variable names to aliases defined in an alias file]:alias file:_files' \
  '-c[specify the dataset calendar attribute]:calendar:(gregorian julian noleap proleptic_gregorian standard 360_day)' \
  '-d[string identifier of the dataset]:dataset id' \
  '-e[add or modify attributes (var.attr=value)]:newattr' \
  '-f[file containing a list of absolute data file names]:file list:_files' \
  '-i[represent the time dimension as linear with given delta]:time delta' \
  '-j[scan time as a vector dimension (values listed individually)]' \
  '-l[files are partitioned by vertical level]:levels' \
  '-m[name of the vertical level dimension]:level id' \
  '-p[add a file template string (pre-V3.0 compatibility)]:template' \
  '-q[quiet mode]' \
  '-r[time units (units since yyyy-mm-dd hh:mi:ss)]:time units' \
  '-s[append a suffix to variable names based on directory]:suffix file:_files' \
  '-t[ID of the partitioned time dimension]:time id' \
  '-x[output XML file name (default stdout)]:xml file:_files' \
  '--exclude[exclude specified variables (comma-separated)]:variables' \
  '--include[only include specified variables (comma-separated)]:variables' \
  '--time-linear[override time with a linear dimension (tzero,delta,units[,calendar])]:spec' \
  '*:file:_files -g "*.(nc|cdf)"' && ret=0

return ret
