#compdef demucs
# Documentation: https://man.archlinux.org/search?q=demucs
# Reference accessed: 2026-05-16

# facebookresearch/demucs — torch.hub CLI `demucs` / `python -m demucs.separate`; common flags from `demucs -h`.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-n}"=[model name]:model:(htdemucs htdemucs_ft mdx_extra mdx_extra_q htdemucs_6s)" \
  {-s,--shifts}"=[random shifts for quality]:int" \
  {-o,--out}"=[output directory]:dir:_files -/" \
  '--filename=[output naming template]:pattern' \
  {-d,--device}"=[torch device]:device:(cpu cuda)" \
  '--float32[32-bit float inference]' \
  '--int24[24-bit wav output]' \
  '--clip[force clipping avoid denorm]' \
  '--flac[FLAC instead of wav]' \
  '--mp3[MP3 instead of wav]' \
  '--mp3-bitrate=[kbps]:rate' \
  '--verbose[verbose logging]' \
  '*:tracks or files:_files' && ret=0

return ret
