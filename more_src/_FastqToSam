#compdef FastqToSam
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/FastqToSam.java
# Picard: convert FASTQ file(s) to an unaligned BAM/SAM/CRAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-F1 --FASTQ)'{-F1,--FASTQ}'=[input FASTQ (read 1 for paired)]:file:_files' \
  '(-F2 --FASTQ2)'{-F2,--FASTQ2}'=[input FASTQ for read 2]:file:_files' \
  '--USE_SEQUENTIAL_FASTQS=[use sequentially numbered FASTQ files]:b:(true false)' \
  '(-V --QUALITY_FORMAT)'{-V,--QUALITY_FORMAT}'=[quality encoding format]:fmt:(Solexa Illumina Standard)' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output BAM/SAM/CRAM file]:file:_files' \
  '(-RG --READ_GROUP_NAME)'{-RG,--READ_GROUP_NAME}'=[read group identifier]:rg:' \
  '(-SM --SAMPLE_NAME)'{-SM,--SAMPLE_NAME}'=[sample name]:sm:' \
  '(-LB --LIBRARY_NAME)'{-LB,--LIBRARY_NAME}'=[library name]:lb:' \
  '(-PU --PLATFORM_UNIT)'{-PU,--PLATFORM_UNIT}'=[platform unit]:pu:' \
  '(-PL --PLATFORM)'{-PL,--PLATFORM}'=[platform type]:pl:(ILLUMINA SOLID LS454 HELICOS PACBIO IONTORRENT ONT)' \
  '(-CN --SEQUENCING_CENTER)'{-CN,--SEQUENCING_CENTER}'=[sequencing center]:cn:' \
  '(-PI --PREDICTED_INSERT_SIZE)'{-PI,--PREDICTED_INSERT_SIZE}'=[predicted median insert size]:pi:' \
  '(-PG --PROGRAM_GROUP)'{-PG,--PROGRAM_GROUP}'=[program group identifier]:pg:' \
  '(-PM --PLATFORM_MODEL)'{-PM,--PLATFORM_MODEL}'=[platform model]:pm:' \
  '(-CO --COMMENT)'{-CO,--COMMENT}'=[header comment]:co:' \
  '(-DS --DESCRIPTION)'{-DS,--DESCRIPTION}'=[read group description]:ds:' \
  '(-DT --RUN_DATE)'{-DT,--RUN_DATE}'=[run date]:dt:' \
  '(-SO --SORT_ORDER)'{-SO,--SORT_ORDER}'=[output sort order]:order:(queryname coordinate unsorted)' \
  '--MIN_Q=[minimum allowed quality score]:n:' \
  '--MAX_Q=[maximum allowed quality score]:n:' \
  '--ALLOW_AND_IGNORE_EMPTY_LINES=[permit empty lines in input]:b:(true false)' \
  '--ALLOW_EMPTY_FASTQ=[permit empty input FASTQ files]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
