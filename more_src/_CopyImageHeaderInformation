#compdef CopyImageHeaderInformation
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/CopyImageHeaderInformation.cxx — copy header fields from ref to target (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:refimage.ext:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:imagetocopyrefimageinfoto.ext:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:imageout.ext:_files' \
    '4:boolcopydirection:(0 1)' \
    '5:boolcopyorigin:(0 1)' \
    '6:boolcopyspacing:(0 1)' \
    '7::bool-Image2-IsTensor (default 0):(0 1)' \
    && ret=0

return ret
