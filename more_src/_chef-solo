#compdef chef-solo

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'+[config file path]:config:_files -g "*.rb(-.)"' \
  '(-d --daemonize)'{-d,--daemonize}'[run as a daemon]' \
  '(-E --environment)'{-E,--environment}'+[set the Chef environment]:environment:' \
  '(-f --fork)'{-f,--fork}'[fork a child process]' \
  '(-F --format)'{-F,--format}'+[output format]:format:(summary text doc min)' \
  '--force-formatter[use formatter output]' \
  '--force-logger[use logger output]' \
  '(-g --group)'{-g,--group}'+[group to set privilege to]:group:_groups' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --interval)'{-i,--interval}'+[run interval in seconds]:seconds:' \
  '(-j --json-attributes)'{-j,--json-attributes}'+[JSON file with attributes]:file:_files -g "*.json(-.)"' \
  '(-l --log_level)'{-l,--log_level}'+[log level]:level:(auto trace debug info warn error fatal)' \
  '(-L --logfile)'{-L,--logfile}'+[log file location]:file:_files' \
  '(-N --node-name)'{-N,--node-name}'+[node name]:name:' \
  '--no-color[disable color output]' \
  '(-o --override-runlist)'{-o,--override-runlist}'+[replace run list]:run list:' \
  '(-r --recipe-url)'{-r,--recipe-url}'+[URL to fetch recipes from]:URL:_urls' \
  '--once[run once and exit]' \
  '-R+[number of times to retry]:count:' \
  '(-s --splay)'{-s,--splay}'+[random splay time]:seconds:' \
  '(-u --user)'{-u,--user}'+[user to set privilege to]:user:_users' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-W[run in why-run mode]' \
  '--chef-license+[accept license]:action:(accept accept-no-persist accept-silent)' \
  '--chef-zero-host+[host for local mode]:host:_hosts' \
  '--chef-zero-port+[port for local mode]:port:' \
  '--minimal-ohai[only run minimum Ohai plugins]' && ret=0

return ret
