#compdef server-setup sstup
# Documentation: https://github.com/arian24b/scripts/blob/main/server-setup.sh
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: prior file contained the entire upstream bash source pasted in
# place of a completion. Restored as a minimal real completion based on
# the script's getopt usage block; full subcommand structure not exposed
# as a stable CLI spec, so kept narrow and accurate.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-U --update)'{-U,--update}'[self-update from source URL]' \
  '(-p --proxy)'{-p,--proxy}'[proxy URL (socks5/http/https)]:url:' \
  '(-i --install)'{-i,--install}'[non-apt installers to run]:set:' \
  '--apt-add=[extra apt packages]:pkgs:' \
  '--apt-remove=[apt packages to remove]:pkgs:' \
  '--print-apt[print default apt package list]' \
  '*:file:_files' && ret=0
return ret
