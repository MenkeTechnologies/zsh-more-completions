#compdef comb
# _comb — Tom Hudson comb CLI for combining two lists of values into all pairwise combinations from input files or stdin streams useful for building host:port permutations subdomain variants user/password lists (tomnomnom team, Go); flag
# upstream: https://github.com/tomnomnom/hacks

_comb() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s+[separator]:str:' \
        '--separator=+[separator]:str:' \
        '-p[suppress prefix]' \
        '--no-prefix[suppress prefix]' \
        '-S[skip empty line]' \
        '--skip-empty[skip empty line]' \
        '*:list files:_files'
}

_comb "$@"
