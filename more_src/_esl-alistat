#compdef esl-alistat

# Easel esl-alistat: summary statistics of an MSA
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-1[output one line per MSA - compact format]' \
  '--informat[input format]:fmt:(stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--amino[assume protein]' \
  '--dna[assume DNA]' \
  '--rna[assume RNA]' \
  '--small[memory-saving small mode]' \
  '--stall[stall until debugger attaches]' \
  '*:alignment file:_files' && ret=0
return ret
