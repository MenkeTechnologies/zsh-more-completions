#compdef nimble

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:install packages'
  'develop:clone packages for development'
  'check:verify validity of package in CWD'
  'init:initialize a new Nimble project'
  'publish:publish package on nim-lang/packages'
  'uninstall:uninstall packages'
  'build:build a package'
  'clean:clean build artifacts'
  'guide:open Nimble user guide in browser'
  'add:add packages to project dependencies'
  'run:build and run a package'
  'c:build single file with C backend'
  'cc:build single file with C backend'
  'js:build single file with JS backend'
  'test:compile and execute tests'
  'doc:build documentation'
  'doc2:build documentation (legacy)'
  'refresh:refresh package list'
  'search:search packages by tag/name'
  'list:list all packages'
  'tasks:list tasks defined in .nimble file'
  'path:show absolute path of installed package'
  'dump:dump package metadata'
  'lock:create or update lock file'
  'deps:show package dependency tree'
  'sync:sync develop file with lock file'
  'setup:setup nimble.paths and config.nims'
  'shellenv:print shell env activation script'
  'shell:spawn shell with package paths set'
  'task:run a custom task from the .nimble file'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-y --accept)'{-y,--accept}'[accept all prompts]' \
  '(-n --reject)'{-n,--reject}'[reject all prompts]' \
  '(-l --localdeps)'{-l,--localdeps}'[use local nimbleDeps directory]' \
  '(-t --tarballs)'{-t,--tarballs}'[enable tarball downloads]' \
  '*-p=[pass to nim compiler]:flag:' \
  '*--passNim=[pass to nim compiler]:flag:' \
  '--debug[show debug information]' \
  '--verbose[verbose output]' \
  '--silent[suppress output]' \
  '--offline[do not connect to network]' \
  '--noColor[disable color output]' \
  '--noSSLCheck[disable SSL cert checking]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'nimble subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '(-d --depsOnly)'{-d,--depsOnly}'[install dependencies only]' \
          '*'{-p,--passNim=}'[pass to nim]:flag:' \
          '--noRebuild[do not rebuild]' && ret=0
        ;;
      (init)
        _arguments \
          '--git[use git]' \
          '--hg[use hg]' && ret=0
        ;;
      (uninstall)
        _arguments \
          '(-i --inclDeps)'{-i,--inclDeps}'[include dependencies]' && ret=0
        ;;
      (test)
        _arguments \
          '(-c --continue)'{-c,--continue}'[continue on test failure]' && ret=0
        ;;
      (search)
        _arguments \
          '--ver[match by version]' \
          '--version=[version]:version:' && ret=0
        ;;
      (list)
        _arguments \
          '(-i --installed)'{-i,--installed}'[show only installed]' \
          '--ver[show with versions]' \
          '(-n --nimbinaries)'{-n,--nimbinaries}'[show Nim binaries]' && ret=0
        ;;
      (refresh)
        _arguments \
          ':url:' && ret=0
        ;;
      (develop)
        _arguments \
          '--withDependencies[include dependencies]' \
          '(-p --path)'{-p,--path=}'[path]:path:_files -/' \
          '*'{-a,--add=}'[add path]:path:_files -/' \
          '*'{-r,--removePath=}'[remove path]:path:_files -/' \
          '*'{-n,--removeName=}'[remove name]:name:' \
          '*'{-i,--include=}'[include file]:file:_files' \
          '*'{-e,--exclude=}'[exclude file]:file:_files' \
          '(-g --global)'{-g,--global}'[global develop file]' && ret=0
        ;;
    esac
    ;;
esac

return ret
