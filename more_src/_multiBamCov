#compdef multiBamCov
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/multicov.html
# count alignments from multiple BAMs over intervals (bedtools multicov)

local ret=1

_arguments -s -S \
  '*-bams[input BAM files (sorted and indexed)]:file:_files' \
  '-bed[input intervals (BED/GFF/VCF)]:file:_files' \
  '-split[treat split BAM/BED12 entries as distinct intervals]' \
  '-s[require same strandedness]' \
  '-S[require opposite strandedness]' \
  '-f[minimum overlap as fraction of each -bed record]:fraction' \
  '-r[require reciprocal overlap fraction]' \
  '-q[minimum mapping quality (MAPQ)]:mapq' \
  '-D[include duplicate reads]' \
  '-F[include failed-QC reads]' \
  '-p[only count proper pairs]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
