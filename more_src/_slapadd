#compdef slapadd
# _slapadd — OpenLDAP slapadd (offline LDIF importer that bypasses access control; -F config dir, -f slapd.conf, -b suffix, -l input LDIF, -n database number, -c continue on error, -g do not generate context CSN, -q quick mode (skip index updates), -u dry run, -w append (write after last entry), -d debug, -v verbose, -V version)
# upstream: https://git.openldap.org/openldap/openldap (servers/slapd/slapadd)
# Flags from OpenLDAP servers/slapd/slapcommon.c on tip.

_slapadd() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-F+[config dir]:dir:_files -/' \
        '-f+[slapd.conf]:file:_files' \
        '-b+[suffix]:dn:' \
        '-l+[input LDIF]:file:_files -g "*.ldif"' \
        '-n+[database number]:n:' \
        '-c[continue on error]' \
        '-g[skip context CSN]' \
        '-q[quick mode]' \
        '-u[dry run]' \
        '-w[append mode]' \
        '-d+[debug level]:level:' \
        '-v[verbose]' \
        '-s+[stop after N entries]:n:'
}

_slapadd "$@"
