#compdef opal_wrapper

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '--showme[show command without executing]' \
  '--showme:command[show wrapper command]' \
  '--showme:compile[show compile command]' \
  '--showme:link[show link command]' \
  '--showme:libdirs[show library directories]' \
  '--showme:libs[show libraries]' \
  '--showme:incdirs[show include directories]' \
  '--showme:version[show version]' \
  '*:source file:_files -g "*.(c|cc|cpp|cxx|f|f90|f95)"' && ret=0

return ret
