#compdef opal_wrapper
# Documentation: https://docs.open-mpi.org/en/v5.0.x/man-openmpi/man1/opal_wrapper.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s \
  '--showme[show full command that would be executed]' \
  '--showme:command[show underlying compiler command]' \
  '--showme:compile[show compile-time flags]' \
  '--showme:link[show link-time flags]' \
  '--showme:libdirs[show library directories]' \
  '--showme:libs[show libraries]' \
  '--showme:incdirs[show include directories]' \
  '--showme:version[show Open MPI version]' \
  '*:source file:_files -g "*.(c|cc|cpp|cxx|f|f90|f95)"' && ret=0

return ret
