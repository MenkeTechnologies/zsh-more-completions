#compdef tsbs_run_queries_questdb
# Documentation: https://github.com/timescale/tsbs#run-queries
# Time Series Benchmark Suite query runner for QuestDB

local ret=1

_arguments -s -S \
  '--urls=[daemon URLs, comma-separated (round-robin)]:urls' \
  '--db-name=[name of database to use for queries]:db name' \
  '--workers=[number of concurrent requests to make]:count' \
  '--max-queries=[limit the number of queries to send (0 = no limit)]:count' \
  '--max-rps=[limit the rate of queries per second (0 = no limit)]:rate' \
  '--burn-in=[number of queries to ignore before collecting statistics]:count' \
  '--print-interval=[print timing stats after this many queries]:count' \
  '--prewarm-queries[run each query twice so the warm query is a cache hit]' \
  '--print-responses[pretty print response bodies for correctness checking]' \
  '--debug=[whether to print debug messages]:level' \
  '--file=[file name to read queries from]:file:_files' \
  '--results-file=[write the test results summary json to this file]:file:_files' \
  '--memprofile=[write a memory profile to this file]:file:_files' \
  '--hdr-latencies=[write the HDR histogram of response latencies to this file]:file:_files' && ret=0

return ret
