#compdef kubecolor
# Documentation: https://man.archlinux.org/search?q=kubecolor
# Reference accessed: 2026-05-16

# Zsh completion for kubecolor (colorized kubectl)
# Delegates to kubectl completion since kubecolor wraps kubectl

_arguments -s -S \
  '--kubecolor-theme[color theme]:theme:' \
  '--light-background[use light background colors]' \
  '--force-colors[force color output]' \
  '--plain[disable colorizing]' \
  '*::kubectl args:_kubectl' && return 0
