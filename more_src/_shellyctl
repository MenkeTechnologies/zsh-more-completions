#compdef shellyctl
# Documentation: https://github.com/jcodybaker/shellyctl/blob/main/README.md
# Unofficial command line client for the Shelly Gen2/3 API

local ret=1

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[read flags from a YAML/JSON/TOML/INI file]:file:_files' \
  '--log-level=[set the logging level]:level' \
  '(-o --output-format)'{-o,--output-format}'=[set the output format]:format' \
  '--host=[address of a single device]:host' \
  '--auth=[password for device authentication]:password' \
  '--mdns-search[discover devices via mDNS]' \
  '--ble-search[discover devices via Bluetooth LE]' \
  '--ble-device=[MAC address of a single BLE device]:mac' \
  '--bind-addr=[local IP address to bind the metrics server]:addr' \
  '--bind-port=[port to bind the metrics server]:port' \
  '1:command:(ble cloud cover input light mqtt schedule script shelly switch sys wifi prometheus completion help)' \
  '*::arg:->args' && ret=0

return ret
