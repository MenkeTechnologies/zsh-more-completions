#compdef metadata-extractor
# Documentation: https://github.com/drewnoakes/metadata-extractor
# Reference accessed: 2026-05-16
# Verified: upstream drewnoakes/metadata-extractor is a Java/.NET library.
# The published JAR has Main-Class
# com.drew.imaging.ImageMetadataReader which only accepts positional
# file paths. There are no CLI flags upstream.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# metadata-extractor: Java/.NET image metadata library (positional files only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:image file:_files' && ret=0
return ret
