#compdef wmctrl
# _wmctrl — wmctrl (EWMH-aware X11 window manager controller; -l lists windows, -d desktops, -a activates a window by title, -c closes, -R moves+activates, -e moves+resizes (gravity,x,y,w,h), -r matches window by title, -i interpret arg as window-id, -b add/remove window states)
# upstream: https://github.com/dancor/wmctrl
# Flags from wmctrl wmctrl.c on tip.

_wmctrl() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-l[list managed windows]' \
        '-d[list desktops]' \
        '-p[include PID column in -l]' \
        '-x[include WM_CLASS column in -l]' \
        '-G[include geometry in -l]' \
        '-u[try to update windows]' \
        '-m[show window manager info]' \
        '-i[interpret args as window ids]' \
        '-v[verbose]' \
        '-a+[activate window by title]:title:' \
        '-c+[close window by title]:title:' \
        '-R+[move+activate window]:title:' \
        '-e+[move+resize "g,x,y,w,h"]:geom:' \
        '-r+[match window by title]:title:' \
        '-N+[new window title]:title:' \
        '-T+[new long title]:title:' \
        '-b+[states action]:action:(add,STATE remove,STATE toggle,STATE add,STATE,STATE2 remove,STATE,STATE2 toggle,STATE,STATE2)' \
        '-t+[move to desktop]:desktop:' \
        '-s+[switch to desktop]:desktop:' \
        '-n+[set number of desktops]:n:' \
        '-k[hide windows]' \
        '-F[full-string title match]' \
        '-w+[X window]:wid:' \
        '*:argument:'
}

_wmctrl "$@"
