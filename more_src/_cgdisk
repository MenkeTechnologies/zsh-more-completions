#compdef cgdisk
# _cgdisk — gptfdisk cgdisk CLI curses ncurses interactive text-mode GUID Partition Table GPT partition editor for managing creating deleting verifying GPT partitions on disks displaying a menu of partition operations alongside hex code type code GUID selection (Roderick W. Smith team, C++); getopt
# upstream: https://www.rodsbooks.com/gdisk/

_cgdisk() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a+[arrow keys]:str:' \
        '*:device:_files -g "/dev/sd* /dev/nvme* /dev/vd* /dev/mmcblk* /dev/loop* /dev/disk*"'
}

_cgdisk "$@"
