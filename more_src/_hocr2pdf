#compdef hocr2pdf
# Documentation: https://manpages.debian.org/unstable/exactimage/hocr2pdf.1.en.html
# hOCR to PDF converter of the ExactImage toolkit

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[read image from file]:file:_files' \
  '(-o --output)'{-o,--output}'[save output PDF to file]:file:_files' \
  '(-n --no-image)'{-n,--no-image}'[do not place image over the text]' \
  '(-s --sloppy-text)'{-s,--sloppy-text}'[sloppily place text, group words]' \
  '(-r --resolution)'{-r,--resolution}'[override input image resolution (dpi)]:dpi' \
  '--quality[quality for compressed images (0-100)]:quality' \
  '--compress[image compression method]:method:(ascii85 hex flate jpeg jpeg2000)' \
  '*:file:_files' && ret=0

return ret
