#compdef hgLoadSqlTab
# UCSC kent: load a table into the database from SQL and text files

local ret=1

_arguments -s -S \
  '-warn[warn instead of abort on mysql errors or warnings]' \
  '-notOnServer[file is not in a directory the mysql server can see]' \
  '(-oldTable -append)'{-oldTable,-append}'[add to existing table]' \
  '1:database:' \
  '2:table:' \
  '3:sql file:_files -g "*.sql"' \
  '*:tab file:_files -g "*.tab"' && ret=0

return ret
