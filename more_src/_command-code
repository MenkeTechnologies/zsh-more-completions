#compdef command-code cmd cmdc commandcode
# Documentation: https://commandcode.ai/docs
# Reference accessed: 2026-05-23
# Verified: npx command-code --help.

# Zsh completion for Command Code (cmd) - taste-learning coding agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-r --resume)'{-r+,--resume=}'[resume conversation by name]:session:' \
  '(-c --continue)'{-c,--continue}'[continue last conversation]' \
  '(-t --trust)'{-t,--trust}'[auto-trust project]' \
  '(-p --print)'{-p+,--print=}'[non-interactive mode]:query:' \
  '--max-turns[cap turns in print mode]:n:' \
  '(-m --model)'{-m+,--model=}'[model for this session]:model:' \
  '--list-models[list available models]' \
  '--plan[start in plan mode]' \
  '--permission-mode[permission mode]:(standard plan auto-accept)' \
  '--auto-accept[start in auto-accept mode]' \
  '--yolo[bypass all permission prompts]' \
  '--add-dir[add directory to workspace]:directory:_directories' \
  '--skip-onboarding[skip taste onboarding]' \
  '--ide-setup[connect IDE for open file context]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'command-code command' \
      'info[display system information]' \
      'status[show authentication status]' \
      'help[display help]' \
      'whoami[show current user]' \
      'update[update to latest version]' \
      'feedback[share feedback or report bugs]' \
      'taste[manage taste learning packages]' \
      'learn-taste[learn command structure from repositories]' \
      'mcp[manage MCP servers]' \
      'skills[manage skills from GitHub]' \
      'login[login with Command Code account]' \
      'logout[log out]' && ret=0
    ;;
  args)
    case $line[1] in
      taste)
        _arguments \
          '1:subcommand:(learn)' \
          '2:source:repository or GitHub source:' && ret=0
        ;;
      feedback)
        _arguments '*:title:title:' && ret=0
        ;;
    esac
    ;;
esac

return ret
