#compdef kubectl-clusternet
# Documentation: https://github.com/clusternet/kubectl-clusternet
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-clusternet (clusternet/kubectl-clusternet): wrap multiple kubectl
# calls to Clusternet. Forwards kubectl-style subcommands.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '1:command:->commands' \
  '*::arg:_default' && ret=0

case $state in
  commands)
    local -a commands=(
      'annotate:update the annotations on a resource'
      'api-resources:print the supported API resources on the server'
      'apply:apply a configuration to a resource by filename or stdin'
      'create:create a resource from a file or from stdin'
      'delete:delete resources'
      'edit:edit a resource on the server'
      'get:display one or many resources'
      'label:update the labels on a resource'
      'scale:set a new size for a Deployment/ReplicaSet/RC'
      'version:print the plugin version information'
    )
    _describe -t commands 'kubectl clusternet command' commands && ret=0
    ;;
esac

return ret
