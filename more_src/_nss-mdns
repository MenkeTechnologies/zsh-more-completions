#compdef nss-mdns
# _nss-mdns — Avahi nss-mdns libnss_mdns_minimal libnss_mdns4 libnss_mdns6 GNU C library NSS Name Service Switch module helper CLI plug-in resolving .local hostnames over multicast DNS 224.0.0.251:5353 querying gethostbyname routes through the system avahi-daemon for Bonjour-compat name resolution (Lennart Poettering team, C); getopt
# upstream: https://github.com/lathiat/nss-mdns

_nss-mdns() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '--minimal[no fallback]' \
        '--full[full mdns lookups]' \
        '--reverse[reverse lookup]' \
        '*:hostname or address:_hosts'
}

_nss-mdns "$@"
