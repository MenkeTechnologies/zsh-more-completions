#compdef c3d_affine_tool
# Documentation: https://github.com/pyushkevich/c3d/blob/master/utilities/AffineTransformTool.cxx
# c3d_affine_tool - Convert3D affine transform conversion utility

local ret=1

_arguments -s \
  '-ref[fixed/reference image (for -fsl2ras / -ras2fsl)]:reference:_files -g "*.{nii,nii.gz,mhd,mha,hdr,img}"' \
  '-src[moving/source image (for -fsl2ras / -ras2fsl)]:source:_files -g "*.{nii,nii.gz,mhd,mha,hdr,img}"' \
  '-mov[moving/source image (alias of -src)]:source:_files -g "*.{nii,nii.gz,mhd,mha,hdr,img}"' \
  '-fsl2ras[convert FSL-format transform to RAS coordinate system]' \
  '-ras2fsl[convert RAS-format transform to FSL coordinate system]' \
  '-itk[import an ITK transform file]:itk transform:_files' \
  '-oitk[export the matrix as an ITK transform file]:itk out:_files' \
  '-irtk[import an IRTK .dof transform]:irtk transform:_files -g "*.dof"' \
  '-oirtk[export the matrix as IRTK .dof transform]:irtk out:_files' \
  '-i[read a matrix file (2D or 3D)]:matrix:_files' \
  '-o[write the matrix to a file]:matrix out:_files' \
  '-inv[compute the matrix inverse]' \
  '-mult[multiply the two most recent matrices on the stack]' \
  '-sqrt[matrix square root (Denman-Beavers iteration)]' \
  '-det[print the determinant of the matrix]' \
  '-info[print the current matrix]' \
  '-info-full[print matrix with detailed decomposition and quaternion]' \
  '-sform[read affine matrix from a NIfTI sform header]:nifti:_files -g "*.{nii,nii.gz}"' \
  '-rot[generate a rotation matrix (angle and axis)]:angle axis:' \
  '-tran[generate a translation matrix (x y z)]:translation:' \
  '-scale[generate a scaling matrix (x y z)]:scale:' \
  '-shavg[shape average of matrices in log space]' \
  '*:matrix file:_files' && ret=0

return ret
