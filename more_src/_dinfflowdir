#compdef dinfflowdir DinfFlowDir
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/DInfinityFlowDirections.html
# TauDEM: compute D-infinity flow directions and slopes

local ret=1

_arguments -s -S \
  '-fel[input pit-filled elevation grid]:felfile:_files' \
  '-ang[output Dinf flow directions grid]:angfile:_files' \
  '-slp[output Dinf slopes grid]:slpfile:_files' \
  '*:file:_files' && ret=0

return ret
