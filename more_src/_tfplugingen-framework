#compdef tfplugingen-framework
# Documentation: https://github.com/hashicorp/terraform-plugin-codegen-framework
# tfplugingen-framework - generate Terraform Plugin Framework provider code from a specification

local ret=1
local curcontext="$curcontext" state line

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(generate scaffold)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      generate)
        _arguments -s -S \
          '--input=[path to the provider code specification]:file:_files' \
          '--output=[output directory for generated code]:dir:_files -/' \
          '1:subcommand:(all resources data-sources provider)' && ret=0
        ;;
      scaffold)
        _arguments -s -S \
          '--name=[name of the component to scaffold]:name' \
          '--force[overwrite existing files]' \
          '--output-dir=[output directory for generated code]:dir:_files -/' \
          '1:subcommand:(data-source resource provider)' && ret=0
        ;;
    esac
    ;;
esac

return ret
