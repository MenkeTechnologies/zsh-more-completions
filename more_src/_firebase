#compdef firebase

# Zsh completion for Firebase CLI

local curcontext="$curcontext" state line ret=1

local -a firebase_commands
firebase_commands=(
  'appdistribution\:distribute:upload a release binary'
  'appdistribution\:testers\:add:add testers'
  'appdistribution\:testers\:remove:remove testers'
  'apps\:create:create a new Firebase app'
  'apps\:list:list registered Firebase apps'
  'apps\:sdkconfig:print SDK configuration'
  'auth\:export:export user accounts'
  'auth\:import:import user accounts'
  'database\:get:fetch and print JSON data'
  'database\:instances\:create:create a realtime database instance'
  'database\:instances\:list:list realtime database instances'
  'database\:profile:profile the database'
  'database\:push:add a new JSON object'
  'database\:remove:remove data at specified path'
  'database\:set:replace data at specified path'
  'database\:update:update data at specified path'
  'deploy:deploy code and assets to Firebase'
  'emulators\:exec:start emulators and run a script'
  'emulators\:export:export emulator data'
  'emulators\:start:start the Firebase emulators'
  'experiments\:describe:describe an experiment'
  'experiments\:enable:enable an experiment'
  'experiments\:disable:disable an experiment'
  'experiments\:list:list available experiments'
  'ext:manage Firebase extensions'
  'ext\:configure:configure an extension instance'
  'ext\:info:display info about an extension'
  'ext\:install:install an extension'
  'ext\:list:list installed extension instances'
  'ext\:uninstall:uninstall an extension'
  'ext\:update:update an extension instance'
  'ext\:export:export installed extension instances'
  'firestore\:delete:delete data from Cloud Firestore'
  'firestore\:indexes:list indexes in Cloud Firestore'
  'functions\:config\:clone:clone environment config'
  'functions\:config\:get:get environment config'
  'functions\:config\:set:set environment config'
  'functions\:config\:unset:unset environment config'
  'functions\:delete:delete Cloud Functions'
  'functions\:log:read logs from deployed Cloud Functions'
  'functions\:secrets\:access:access a secret value'
  'functions\:secrets\:destroy:destroy a secret'
  'functions\:secrets\:get:get metadata for a secret'
  'functions\:secrets\:prune:destroy unused secrets'
  'functions\:secrets\:set:create or update a secret'
  'functions\:shell:launch interactive shell for functions'
  'hosting\:channel\:create:create a preview channel'
  'hosting\:channel\:delete:delete a preview channel'
  'hosting\:channel\:deploy:deploy to a preview channel'
  'hosting\:channel\:list:list preview channels'
  'hosting\:channel\:open:open a preview channel URL'
  'hosting\:clone:clone a version to another site'
  'hosting\:disable:stop serving Firebase Hosting'
  'hosting\:sites\:create:create a Hosting site'
  'hosting\:sites\:delete:delete a Hosting site'
  'hosting\:sites\:get:get info about a Hosting site'
  'hosting\:sites\:list:list Hosting sites'
  'init:set up a Firebase project in the current directory'
  'login:log in to Firebase'
  'login\:add:authorize an additional account'
  'login\:ci:generate a CI token'
  'login\:list:list authorized accounts'
  'login\:use:set the default account'
  'logout:log out of Firebase'
  'open:open a Firebase resource in a browser'
  'projects\:addfirebase:add Firebase resources to a GCP project'
  'projects\:create:create a new Firebase project'
  'projects\:list:list Firebase projects'
  'remoteconfig\:get:get the current Remote Config template'
  'remoteconfig\:rollback:rollback to a previous Remote Config version'
  'remoteconfig\:versions\:list:list Remote Config versions'
  'serve:start a local server for Hosting'
  'setup\:emulators\:database:set up the database emulator'
  'setup\:emulators\:firestore:set up the Firestore emulator'
  'setup\:emulators\:pubsub:set up the Pub/Sub emulator'
  'setup\:emulators\:storage:set up the Storage emulator'
  'setup\:emulators\:ui:set up the Emulator UI'
  'target:display configured deploy targets'
  'target\:apply:apply a deploy target'
  'target\:clear:clear a deploy target'
  'target\:remove:remove a deploy target'
  'use:set active Firebase project'
)

local -a firebase_global_flags
firebase_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '-V[output the version number]'
  '--version[output the version number]'
  '-P=[use the specified Firebase project]:project:'
  '--project=[use the specified Firebase project]:project:'
  '--account=[the Google account to use]:account:'
  '-j[output JSON]'
  '--json[output JSON]'
  '--token=[use a CI token]:token:'
  '--non-interactive[suppress prompts]'
  '--interactive[force interactive prompts]'
  '--debug[enable debug logging]'
  '-c=[path to firebase.json]:config file:_files'
  '--config=[path to firebase.json]:config file:_files'
)

_arguments -s -S \
  $firebase_global_flags \
  '1:command:_describe -t commands command firebase_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      deploy)
        _arguments -s -S \
          $firebase_global_flags \
          '-p=[override the Hosting public directory]:directory:_directories' \
          '--public=[override the Hosting public directory]:directory:_directories' \
          '-m=[optional deploy message]:message:' \
          '--message=[optional deploy message]:message:' \
          '-f[ignore any warnings]' \
          '--force[ignore any warnings]' \
          '--only=[only deploy specific targets]:targets:(hosting functions firestore database storage remoteconfig extensions)' \
          '--except=[deploy all except these targets]:targets:(hosting functions firestore database storage remoteconfig extensions)' && ret=0
        ;;
      init)
        _arguments -s -S \
          $firebase_global_flags \
          '1:feature:(database firestore functions hosting hosting\:github remoteconfig storage emulators extensions)' && ret=0
        ;;
      serve)
        _arguments -s -S \
          $firebase_global_flags \
          '-p=[port for the HTTP server]:port:' \
          '--port=[port for the HTTP server]:port:' \
          '-o=[host for the HTTP server]:host:' \
          '--host=[host for the HTTP server]:host:' \
          '--only=[only serve specific targets]:targets:(hosting functions)' \
          '--except=[serve all except]:targets:(hosting functions)' && ret=0
        ;;
      emulators\:start)
        _arguments -s -S \
          $firebase_global_flags \
          '--only=[only start specified emulators]:emulators:(auth database firestore functions hosting pubsub storage ui)' \
          '--inspect-functions=[inspect functions on port]:port:' \
          '--import=[import emulator data]:directory:_directories' \
          '--export-on-exit=[export data on exit]:directory:_directories' && ret=0
        ;;
      emulators\:exec)
        _arguments -s -S \
          $firebase_global_flags \
          '--only=[only start specified emulators]:emulators:(auth database firestore functions hosting pubsub storage)' \
          '--inspect-functions=[inspect functions on port]:port:' \
          '--import=[import emulator data]:directory:_directories' \
          '--export-on-exit=[export data on exit]:directory:_directories' \
          '--ui[run the Emulator UI]' \
          '1:script:_command_names' && ret=0
        ;;
      use)
        _arguments -s -S \
          $firebase_global_flags \
          '--add[add a project alias]' \
          '--alias=[alias for the project]:alias:' \
          '--unalias=[remove an alias]:alias:' \
          '--clear[clear the active project]' \
          '1:project or alias:' && ret=0
        ;;
      functions\:log)
        _arguments -s -S \
          $firebase_global_flags \
          '--only=[only show logs for these functions]:functions:' \
          '--lines=[number of lines to show]:lines:' && ret=0
        ;;
      hosting\:channel\:deploy)
        _arguments -s -S \
          $firebase_global_flags \
          '--expires=[duration until channel expires]:duration:' \
          '--only=[only deploy to specified sites]:sites:' \
          '--no-authorized-domains[do not sync authorized domains]' \
          '1:channel id:' && ret=0
        ;;
      *)
        _arguments -s -S $firebase_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
