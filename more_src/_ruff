#compdef ruff

# Zsh completion for ruff (Fast Python linter and formatter)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
  'check:run linting checks on the given files or directories'
  'format:run the formatter on the given files or directories'
  'rule:explain a rule or list all rules'
  'config:list or describe ruff configuration options'
  'linter:list all supported linters'
  'clean:clear any caches in the current directory and subdirectories'
  'version:display ruff version'
  'help:print help information'
  'server:run the language server'
  'analyze:run analysis on the given files or directories'
)

local -a global_flags=(
  '(-h --help)'{-h,--help}'[print help information]'
  '(-V --version)'{-V,--version}'[print version information]'
)

local -a output_formats=(
  'concise' 'full' 'json' 'json-lines' 'junit' 'github' 'gitlab'
  'pylint' 'rdjson' 'azure' 'sarif' 'text' 'grouped'
)

local -a target_versions=(
  'py37' 'py38' 'py39' 'py310' 'py311' 'py312' 'py313'
)

_arguments -s -S -C \
  $global_flags \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'ruff command' commands && ret=0
    ;;
  args)
    case $line[1] in
      check)
        _arguments -s -S \
          $global_flags \
          '--fix[attempt to automatically fix lint violations]' \
          '--no-fix[disable auto-fix]' \
          '--unsafe-fixes[enable fixes that may change program semantics]' \
          '--show-fixes[show an enumeration of all fixed lint violations]' \
          '--diff[avoid writing fixed files back; instead, output a diff]' \
          '--watch[run in watch mode]' \
          '--config[path to a ruff configuration file]:file:_files' \
          '*--select[comma-separated list of rule codes to enable]:rules:' \
          '*--ignore[comma-separated list of rule codes to disable]:rules:' \
          '*--extend-select[like --select but adds to default selection]:rules:' \
          '*--extend-ignore[like --ignore but adds to default ignores]:rules:' \
          '*--fixable[comma-separated list of rule codes to treat as fixable]:rules:' \
          '*--unfixable[comma-separated list of rule codes to treat as unfixable]:rules:' \
          '*--per-file-ignores[per-file rule exclusions]:pattern\:rules:' \
          '--respect-gitignore[respect .gitignore files]' \
          '--no-respect-gitignore[do not respect .gitignore files]' \
          '*--exclude[file patterns to exclude]:pattern:' \
          '*--extend-exclude[additional file patterns to exclude]:pattern:' \
          '--force-exclude[enforce exclusions even for explicitly passed paths]' \
          '--line-length[set the line length]:length:' \
          '--target-version[the minimum Python version to target]:version:('${(j: :)target_versions}')' \
          '--preview[enable preview mode]' \
          '--output-format[output serialization format]:format:('${(j: :)output_formats}')' \
          '--stdin-filename[the name of the file when reading from stdin]:filename:_files' \
          {-e,--exit-zero}'[exit with 0 even upon detecting lint violations]' \
          '--exit-non-zero-on-fix[exit with non-zero status if fixable violations found]' \
          {-n,--no-cache}'[disable cache reads]' \
          '--cache-dir[path to the cache directory]:dir:_files -/' \
          '--isolated[ignore all configuration files]' \
          {-q,--quiet}'[disable all output]' \
          {-v,--verbose}'[enable verbose logging]' \
          '--statistics[show counts for every rule with at least one violation]' \
          '--add-noqa[add noqa directives to all lines with violations]' \
          '--show-source[show source code snippets for violations]' \
          '--show-files[show the list of files to be checked]' \
          '--show-settings[show the resolved settings for the check]' \
          '*:file or directory:_files' && ret=0
        ;;
      format)
        _arguments -s -S \
          $global_flags \
          '--check[avoid writing formatted files back; exit with non-zero status if any files would be changed]' \
          '--diff[avoid writing formatted files back; instead output a diff]' \
          '--config[path to a ruff configuration file]:file:_files' \
          '--target-version[the minimum Python version to target]:version:('${(j: :)target_versions}')' \
          '--preview[enable preview mode]' \
          '--line-length[set the line length]:length:' \
          '--respect-gitignore[respect .gitignore files]' \
          '*--exclude[file patterns to exclude]:pattern:' \
          '--force-exclude[enforce exclusions even for explicitly passed paths]' \
          '--stdin-filename[the name of the file when reading from stdin]:filename:_files' \
          {-n,--no-cache}'[disable cache reads]' \
          '--cache-dir[path to the cache directory]:dir:_files -/' \
          '--isolated[ignore all configuration files]' \
          {-q,--quiet}'[disable all output]' \
          {-v,--verbose}'[enable verbose logging]' \
          '*:file or directory:_files' && ret=0
        ;;
      rule)
        _arguments -s -S \
          $global_flags \
          '--all[show all rules]' \
          '--output-format[output format]:format:(text json)' \
          ':rule code:' && ret=0
        ;;
      config)
        _arguments -s -S \
          $global_flags \
          ':config option:' && ret=0
        ;;
      server)
        _arguments -s -S \
          $global_flags \
          '--preview[enable preview mode]' && ret=0
        ;;
      analyze)
        _arguments -s -S \
          $global_flags \
          '--config[path to a ruff configuration file]:file:_files' \
          '*:file or directory:_files' && ret=0
        ;;
      clean|linter|version|help)
        _arguments -s -S $global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
