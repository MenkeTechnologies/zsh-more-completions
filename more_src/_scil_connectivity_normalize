#compdef scil_connectivity_normalize
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_connectivity_normalize.html
# Normalize a connectivity matrix

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--length=[length matrix for edge-wise multiplication]:matrix:_files -g "*.npy"' \
  '--inverse_length=[length matrix for edge-wise division]:matrix:_files -g "*.npy"' \
  '--bundle_volume=[volume matrix for edge-wise division]:matrix:_files -g "*.npy"' \
  '--parcel_volume[atlas and labels list for division by node volume]:atlas:_files:labels:_files' \
  '--parcel_surface[atlas and labels list for division by node surface]:atlas:_files:labels:_files' \
  '--max_at_one[scale matrix with maximum value at one]' \
  '--sum_to_one[scale matrix with sum of all elements at one]' \
  '--log_10[apply base 10 logarithm to the matrix]' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[force overwriting of output files]' \
  '1:in_matrix:_files -g "*.npy"' \
  '2:out_matrix:_files -g "*.npy"' && ret=0

return ret
