#compdef dh_php
# _dh_php — debhelper for PHP extensions / configs (Debian/dh-php)
# upstream: https://salsa.debian.org/php-team/dh-php
# Flags from dh_php(1) man page.

_dh_php() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '--php-version=[PHP version suffix for tooling]:version:' \
        '--error-handler=[shell function called on maint-script failure]:func:' \
        '(-e --noenable)'{-e,--noenable}'[install scripts but do not enable by default]' \
        '(-n --noscripts)'{-n,--noscripts}'[do not modify maintainer scripts]' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '-O+[option passed to the helper]:opt:'
}

_dh_php "$@"
