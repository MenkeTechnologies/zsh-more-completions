#compdef git-ftp
# Documentation: https://manpages.debian.org/unstable/git-ftp/git-ftp.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git-ftp (Git powered FTP client)

local curcontext="$curcontext" state line ret=1

local -a actions=(
  'init:upload all tracked files and create deployment log'
  'catchup:create/update remote log assuming files already uploaded'
  'push:upload changed files and delete removed files'
  'download:retrieve changes from remote host (experimental)'
  'pull:download changes into separate commit and merge (experimental)'
  'snapshot:download files into new Git repository (experimental)'
  'show:display last uploaded commit details'
  'log:show last uploaded commit history'
  'add-scope:create new configuration scope'
  'remove-scope:delete a scope'
  'help:display usage information'
)

_arguments -C -s -S \
  '(-u --user)'{-u,--user}'[FTP login name]:user:' \
  '(-p --passwd)'{-p,--passwd}'[FTP password]:password:' \
  '(-P --ask-passwd)'{-P,--ask-passwd}'[interactive password prompt]' \
  '(-k --keychain)'{-k,--keychain}'[macOS keychain password retrieval]:account:' \
  '(-a --all)'{-a,--all}'[upload all current files]' \
  '(-A --active)'{-A,--active}'[use FTP active mode]' \
  '(-b --branch)'{-b,--branch}'[push specific branch]:branch:' \
  '(-s --scope)'{-s,--scope}'[use named scope configuration]:scope:' \
  '(-l --lock)'{-l,--lock}'[enable remote locking]' \
  '(-D --dry-run)'{-D,--dry-run}'[test without uploading]' \
  '(-c --commit)'{-c,--commit}'[set deployed commit SHA1]:commit:' \
  '(-f --force)'{-f,--force}'[skip confirmations]' \
  '(-n --silent)'{-n,--silent}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[detailed output]' \
  '-vv[maximum verbosity/debug info]' \
  '--remote-root[remote deployment directory]:path:' \
  '--syncroot[local directory as project root]:path:_directories' \
  '--key[SSH private key for SFTP]:file:_files' \
  '--pubkey[SSH public key file]:file:_files' \
  '--insecure[skip certificate verification]' \
  '--cacert[CA certificate store file]:file:_files' \
  '--disable-epsv[disable EPSV for passive FTP]' \
  '--no-commit[interrupt merge during pull]' \
  '--changed-only[mirror only changed files]' \
  '--no-verify[bypass pre-ftp-push hook]' \
  '--enable-post-errors[fail on post-hook errors]' \
  '--auto-init[auto-initialize on push]' \
  '(-x --proxy)'{-x,--proxy}'[specify proxy server]:proxy:' \
  '--version[display version information]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:action:->action' \
  '*::arg:->args' && ret=0

case $state in
  (action)
    _describe -t actions 'git-ftp action' actions && ret=0
    ;;
esac

return ret
