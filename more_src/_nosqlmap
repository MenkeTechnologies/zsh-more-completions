# NoSQLMap - automated NoSQL database enumeration and exploitation

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--attack=[1=DB access attacks, 2=web app attacks, 3=scan anonymous access]:attack:(1 2 3)' \
  '--platform=[platform to attack]:platform:' \
  '--victim=[set target host/IP]:host:' \
  '--dbPort=[set shell listener port]:port:' \
  '--myIP=[set my local platform/shell IP]:ip:' \
  '--myPort=[set my local platform/shell port]:port:' \
  '--webPort=[set web app port]:port:' \
  '--uri=[set app path]:uri:' \
  '--httpMethod=[set HTTP request method]:method:(GET POST)' \
  '--https[toggle HTTPS]' \
  '--verb[toggle verbose mode]' \
  '--postData=[POST data as comma separated list]:data:' \
  '--requestHeaders=[request headers as comma separated list]:headers:' && ret=0

return ret
