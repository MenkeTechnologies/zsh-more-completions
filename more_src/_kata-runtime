#compdef kata-runtime

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:check environment for Kata compatibility'
  'create:create a container'
  'delete:delete a container'
  'env:display environment information'
  'exec:execute a command in a container'
  'factory:manage VM factory'
  'help:show help'
  'kill:send a signal to a container'
  'list:list containers'
  'pause:pause a container'
  'ps:list processes in a container'
  'resume:resume a paused container'
  'run:create and run a container'
  'spec:create a new OCI runtime spec'
  'start:start a created container'
  'state:output the state of a container'
  'update:update container resource constraints'
  'version:show version'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--log=[log file]:log file:_files' \
  '--log-format=[log format]:format:(text json)' \
  '--root=[root directory]:directory:_directories' \
  '--show-default-config-paths[show default config paths]' \
  '--kata-config=[config file]:config:_files -g "*.toml"' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'kata-runtime command' commands && ret=0
    ;;
esac

return ret
