#compdef kata-runtime
# Documentation: https://github.com/kata-containers/runtime/blob/master/cli/main.go
# Reference accessed: 2026-05-19
# Verified: upstream runtime cli/main.go command + flag tables.
# Fixed from prior file: check -> kata-check; env -> kata-env;
# added events, kata-network, kata-overhead; corrected
# --show-default-config-paths -> --kata-show-default-config-paths;
# added --rootless, --systemd-cgroup.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a container'
  'delete:delete any resources held by the container'
  'exec:enter a container by executing a command'
  'kill:send a signal to the container init process'
  'list:list containers started by kata-runtime'
  'pause:suspend all processes in a container'
  'ps:display processes running inside a container'
  'resume:resume all processes in a container'
  'run:create and run a container'
  'spec:create a new specification file'
  'start:start a created container'
  'state:output the state of a container'
  'update:update container resource constraints'
  'events:display container events and stats'
  'version:display version details'
  'kata-check:tests if system can run Kata Containers'
  'kata-env:display settings and metadata'
  'kata-network:manage interfaces and routes for a sandbox'
  'kata-overhead:display container overhead'
  'factory:manage vm factory'
  'help:show help'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--kata-config=[Kata Containers config file path]:config:_files -g "*.toml"' \
  '--kata-show-default-config-paths[show paths checked for config]' \
  '--log=[set log file path]:log file:_files' \
  '--log-format=[set log format]:format:(text json)' \
  '--root=[root directory for storage of container state]:directory:_directories' \
  '--rootless=[enable rootless mode]:mode:(true false auto)' \
  '--systemd-cgroup[enable systemd cgroup support]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'kata-runtime command' commands && ret=0
    ;;
esac

return ret
