#compdef pestpp-glm
# Documentation: https://github.com/usgs/pestpp/blob/master/documentation/pestpp_users_manual.md
# PEST++ GLM deterministic parameter estimation; runs a PEST control file

local ret=1

_arguments -s \
  '1:PEST control file:_files -g "*.pst"' \
  '*:PANTHER /h arg - :port for manager, host:port for agent:_default' && ret=0

return ret
