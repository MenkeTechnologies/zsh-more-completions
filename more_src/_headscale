#compdef headscale
# Documentation: https://headscale.net/stable/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'apikeys:Manage API keys'
  'completion:Generate shell completions'
  'configtest:Test the configuration'
  'debug:Debug operations'
  'dump-config:Dump configuration in JSON'
  'generate:Generate auxiliary resources'
  'help:Help about any command'
  'mockoidc:Run a mock OIDC server for testing'
  'nodes:Manage nodes'
  'policy:Manage HuJSON policy'
  'preauthkeys:Manage pre-authentication keys'
  'routes:Manage routes (legacy; prefer nodes routes)'
  'serve:Launch the headscale server'
  'users:Manage users'
  'version:Print version'
)

local -a global_flags
global_flags=(
  '(- *)--help[show help]'
  '(-c --config)'{-c,--config}'=[path to configuration file]:file:_files'
  '(-o --output)'{-o,--output}'=[output format]:format:(json json-line yaml)'
  '--force[disable prompts and force execution]'
)

_arguments -C \
  $global_flags \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'headscale command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      serve)
        _arguments \
          $global_flags \
          '--force[disable prompts]' && ret=0
        ;;
      users)
        local -a user_cmds
        user_cmds=(
          'list:List users'
          'create:Create a user'
          'rename:Rename a user'
          'destroy:Destroy a user'
          'delete:Alias for destroy'
        )
        _arguments -C \
          $global_flags \
          '1:subcommand:->usercmd' \
          '*::arg:->userargs' && ret=0
        case "$state" in
          usercmd)
            _describe -t commands 'users subcommand' user_cmds && ret=0
            ;;
          userargs)
            _arguments \
              $global_flags \
              '--output=[output format]:format:(json json-line yaml)' \
              '*:user name:' && ret=0
            ;;
        esac
        ;;
      nodes)
        local -a node_cmds
        node_cmds=(
          'list:List nodes'
          'register:Register a node'
          'delete:Delete a node'
          'expire:Expire a node'
          'tag:Manage node tags'
        )
        _arguments -C \
          $global_flags \
          '1:subcommand:->nodecmd' \
          '*::arg:->nodeargs' && ret=0
        case "$state" in
          nodecmd)
            _describe -t commands 'nodes subcommand' node_cmds && ret=0
            ;;
          nodeargs)
            case "${line[1]}" in
              list)
                _arguments \
                  $global_flags \
                  '--output=[output format]:format:(json json-line yaml)' \
                  '--user=[filter by user]:user:' \
                  '--tags=[filter by tags]:tags:' && ret=0
                ;;
              register)
                _arguments \
                  $global_flags \
                  '--user=[user to register under]:user:' \
                  '--key=[node key]:key:' \
                  '--output=[output format]:format:(json json-line yaml)' && ret=0
                ;;
              *)
                _arguments \
                  $global_flags \
                  '--output=[output format]:format:(json json-line yaml)' \
                  '*:identifier:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      apikeys)
        local -a apikey_cmds
        apikey_cmds=(
          'list:List API keys'
          'create:Create an API key'
          'expire:Expire an API key'
        )
        _arguments -C \
          $global_flags \
          '1:subcommand:->apikeycmd' \
          '*::arg:->apikeyargs' && ret=0
        case "$state" in
          apikeycmd)
            _describe -t commands 'apikeys subcommand' apikey_cmds && ret=0
            ;;
          apikeyargs)
            _arguments \
              $global_flags \
              '--output=[output format]:format:(json json-line yaml)' \
              '--prefix=[key prefix]:prefix:' \
              '--expiration=[expiration duration]:duration:' && ret=0
            ;;
        esac
        ;;
      preauthkeys)
        local -a preauth_cmds
        preauth_cmds=(
          'list:List pre-authentication keys'
          'create:Create a pre-authentication key'
          'expire:Expire a pre-authentication key'
        )
        _arguments -C \
          $global_flags \
          '1:subcommand:->preauthcmd' \
          '*::arg:->preauthargs' && ret=0
        case "$state" in
          preauthcmd)
            _describe -t commands 'preauthkeys subcommand' preauth_cmds && ret=0
            ;;
          preauthargs)
            _arguments \
              $global_flags \
              '--user=[user name]:user:' \
              '--reusable[make the key reusable]' \
              '--ephemeral[make the key ephemeral]' \
              '--expiration=[expiration duration]:duration:' \
              '--output=[output format]:format:(json json-line yaml)' && ret=0
            ;;
        esac
        ;;
      routes)
        local -a route_cmds
        route_cmds=(
          'list:List routes'
          'enable:Enable a route'
          'disable:Disable a route'
          'delete:Delete a route'
        )
        _arguments -C \
          $global_flags \
          '1:subcommand:->routecmd' \
          '*::arg:->routeargs' && ret=0
        case "$state" in
          routecmd)
            _describe -t commands 'routes subcommand' route_cmds && ret=0
            ;;
          routeargs)
            _arguments \
              $global_flags \
              '--output=[output format]:format:(json json-line yaml)' \
              '--identifier=[route identifier]:id:' && ret=0
            ;;
        esac
        ;;
      completion)
        _arguments \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments $global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
