#compdef headscale

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'serve:Launch the headscale server'
  'users:Manage users'
  'nodes:Manage nodes'
  'apikeys:Manage API keys'
  'preauthkeys:Manage pre-authentication keys'
  'routes:Manage routes'
  'debug:Debug operations'
  'completion:Generate shell completions'
  'version:Print version'
)

local -a global_flags
global_flags=(
  '(- *)--help[show help]'
  '(- *)--version[show version]'
  '--config=[path to configuration file]:file:_files'
  '--force[disable prompts]'
)

_arguments -C \
  $global_flags \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'headscale command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      serve)
        _arguments \
          $global_flags \
          '--force[disable prompts]' && ret=0
        ;;
      users)
        local -a user_cmds
        user_cmds=(
          'list:List users'
          'create:Create a user'
          'rename:Rename a user'
          'delete:Delete a user'
        )
        _arguments -C \
          $global_flags \
          '1:subcommand:->usercmd' \
          '*::arg:->userargs' && ret=0
        case "$state" in
          usercmd)
            _describe -t commands 'users subcommand' user_cmds && ret=0
            ;;
          userargs)
            _arguments \
              $global_flags \
              '--output=[output format]:format:(json yaml human)' \
              '*:user name:' && ret=0
            ;;
        esac
        ;;
      nodes)
        local -a node_cmds
        node_cmds=(
          'list:List nodes'
          'register:Register a node'
          'delete:Delete a node'
          'expire:Expire a node'
          'rename:Rename a node'
          'routes:Manage node routes'
          'tags:Manage node tags'
          'move:Move a node to another user'
        )
        _arguments -C \
          $global_flags \
          '1:subcommand:->nodecmd' \
          '*::arg:->nodeargs' && ret=0
        case "$state" in
          nodecmd)
            _describe -t commands 'nodes subcommand' node_cmds && ret=0
            ;;
          nodeargs)
            case "${line[1]}" in
              list)
                _arguments \
                  $global_flags \
                  '--output=[output format]:format:(json yaml human)' \
                  '--user=[filter by user]:user:' \
                  '--tags=[filter by tags]:tags:' && ret=0
                ;;
              register)
                _arguments \
                  $global_flags \
                  '--user=[user to register under]:user:' \
                  '--key=[node key]:key:' \
                  '--output=[output format]:format:(json yaml human)' && ret=0
                ;;
              *)
                _arguments \
                  $global_flags \
                  '--output=[output format]:format:(json yaml human)' \
                  '*:identifier:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      apikeys)
        local -a apikey_cmds
        apikey_cmds=(
          'list:List API keys'
          'create:Create an API key'
          'expire:Expire an API key'
        )
        _arguments -C \
          $global_flags \
          '1:subcommand:->apikeycmd' \
          '*::arg:->apikeyargs' && ret=0
        case "$state" in
          apikeycmd)
            _describe -t commands 'apikeys subcommand' apikey_cmds && ret=0
            ;;
          apikeyargs)
            _arguments \
              $global_flags \
              '--output=[output format]:format:(json yaml human)' \
              '--prefix=[key prefix]:prefix:' \
              '--expiration=[expiration duration]:duration:' && ret=0
            ;;
        esac
        ;;
      preauthkeys)
        local -a preauth_cmds
        preauth_cmds=(
          'list:List pre-authentication keys'
          'create:Create a pre-authentication key'
          'expire:Expire a pre-authentication key'
        )
        _arguments -C \
          $global_flags \
          '1:subcommand:->preauthcmd' \
          '*::arg:->preauthargs' && ret=0
        case "$state" in
          preauthcmd)
            _describe -t commands 'preauthkeys subcommand' preauth_cmds && ret=0
            ;;
          preauthargs)
            _arguments \
              $global_flags \
              '--user=[user name]:user:' \
              '--reusable[make the key reusable]' \
              '--ephemeral[make the key ephemeral]' \
              '--expiration=[expiration duration]:duration:' \
              '--output=[output format]:format:(json yaml human)' && ret=0
            ;;
        esac
        ;;
      routes)
        local -a route_cmds
        route_cmds=(
          'list:List routes'
          'enable:Enable a route'
          'disable:Disable a route'
          'delete:Delete a route'
        )
        _arguments -C \
          $global_flags \
          '1:subcommand:->routecmd' \
          '*::arg:->routeargs' && ret=0
        case "$state" in
          routecmd)
            _describe -t commands 'routes subcommand' route_cmds && ret=0
            ;;
          routeargs)
            _arguments \
              $global_flags \
              '--output=[output format]:format:(json yaml human)' \
              '--identifier=[route identifier]:id:' && ret=0
            ;;
        esac
        ;;
      completion)
        _arguments \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments $global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
