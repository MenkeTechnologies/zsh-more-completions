#compdef onefetch

# Zsh completion for onefetch - Git repository info

local -a image_protocols=(
  'kitty:Kitty terminal graphics protocol'
  'sixel:Sixel graphics'
  'iterm:iTerm2 image protocol'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--ascii-language[which language to show ASCII art for]:language:' \
  '--ascii-input[take custom ASCII art from file]:file:_files' \
  '--disabled-fields[disable fields]:field:' \
  '-e[hide token in commit authors]:token:' \
  '--exclude[exclude files/directories from analysis]:pattern:' \
  '--image[path to image for the logo]:file:_files -g "*.{png,jpg,jpeg,gif,bmp,svg}"' \
  '--image-protocol[which image protocol to use]:protocol:((${(j: :)image_protocols}))' \
  '--include-hidden[include hidden files and directories]' \
  '--no-bold[do not bold fields]' \
  '--no-color-palette[hide color palette]' \
  '--no-merges[ignore merge commits]' \
  '--no-bots[exclude bot commits]' \
  '--number-of-authors[number of authors to display]:number:' \
  '--number-of-file-churns[number of file churns to display]:number:' \
  '--number-of-languages[number of languages to display]:number:' \
  '--output[define output format]:format:(json yaml)' \
  '--show-email[show email address of each author]' \
  '--text-colors[set custom text colors]:colors:' \
  '--true-color[set true color terminal]:when:(auto always never)' \
  '--type[filter by language type]:type:(programming markup prose data)' \
  '--churn-pool-size[minimum commits for file churn]:size:' \
  '--completion[generate shell completion]:shell:(bash fish zsh powershell elvish)' \
  '*:repository:_directories' \
  && return 0
