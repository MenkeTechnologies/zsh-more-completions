#compdef controller-gen
# Documentation: https://github.com/kubernetes-sigs/controller-tools/blob/main/cmd/controller-gen/main.go
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# controller-gen: Kubernetes controller-tools code/CRD generator.
# Generators and output rules below verified against
# kubernetes-sigs/controller-tools cmd/controller-gen/main.go.

local curcontext="$curcontext" state line ret=1

_controller_gen_args() {
  local -a args
  args=(
    'crd'
    'rbac'
    'object'
    'webhook'
    'applyconfiguration'
    'schemapatch'
    'paths=./...'
    'paths=.'
    'output:dir='
    'output:none'
    'output:stdout'
    'output:crd:dir='
    'output:crd:artifacts:config='
    'output:rbac:dir='
    'output:rbac:artifacts:config='
    'output:webhook:dir='
    'output:webhook:artifacts:config='
    'output:object:dir='
    'output:applyconfiguration:dir='
    'output:schemapatch:dir='
  )
  compadd -S '' -a args
}

_arguments -s -S \
  '(- *)'{-h,--help}'[print help (repeat for more detail, -hh -hhh -hhhh)]' \
  '(- *)--version[print version]' \
  '*'{-w,--which-markers}'[print available markers for selected generators]' \
  '--detailed-help[print more detailed help]' \
  '--load-build-tags=[Go build tags when loading packages]:tags:' \
  '*:generator or option:_controller_gen_args' && ret=0

return ret
