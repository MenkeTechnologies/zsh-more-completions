#compdef controller-gen

# Zsh completion for controller-gen - Kubernetes controller-tools code generator

local curcontext="$curcontext" state line ret=1

_controller_gen_generators() {
  local -a generators
  generators=(
    'crd:Generate CustomResourceDefinition manifests'
    'rbac:Generate RBAC role manifests'
    'webhook:Generate webhook configurations'
    'object:Generate runtime.Object/DeepCopy implementations'
    'schemapatch:Patch existing CRD schemata with new schemata'
    'paths:Specify paths to scan for markers'
    'output:Specify output rules'
  )
  _describe -t generators 'generators' generators
}

_controller_gen_args() {
  local -a args
  args=(
    'crd'
    'crd\:trivialVersions=true'
    'crd\:trivialVersions=false'
    'crd\:crdVersions=v1'
    'crd\:crdVersions=v1beta1'
    'crd\:generateEmbeddedObjectMeta=true'
    'crd\:generateEmbeddedObjectMeta=false'
    'crd\:allowDangerousTypes=true'
    'crd\:allowDangerousTypes=false'
    'rbac'
    'rbac\:roleName='
    'webhook'
    'object'
    'object\:headerFile='
    'schemapatch'
    'schemapatch\:manifests='
    'paths=./...'
    'paths=.'
    'output\:crd\:artifacts\:config='
    'output\:rbac\:artifacts\:config='
    'output\:webhook\:artifacts\:config='
    'output\:crd\:dir='
    'output\:rbac\:dir='
    'output\:webhook\:dir='
    'output\:dir='
    'output\:none'
    'output\:stdout'
  )
  compadd -S '' -a args
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:generator or option:_controller_gen_args' && ret=0

return ret
