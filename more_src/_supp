(( $+functions[_supp_commands] )) ||
_supp_commands() {
    local commands; commands=(
'diff:Git diff with file tree, line counts, and full patch context' \
'tree:Project layout with git status markers (modified, added, untracked)' \
'completions:Generate shell completion scripts' \
'sym:Find functions, types, and constants by name across the codebase' \
'why:Explain a symbol\: definition, docs, who calls it, and what it depends on' \
'deps:Visualize file-level import/dependency relationships' \
'todo:Find TODO, FIXME, HACK, and XXX comments across the codebase' \
'pick:Interactively pick files with fzf for context generation' \
'version:Show version and check for updates' \
'update:Update supp to the latest release' \
'uninstall:Remove supp from your system' \
'clean-cache:Delete the symbol cache for a project' \
'perf:Set or check the global performance mode' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'supp commands' commands "$@"
}
(( $+functions[_supp__clean-cache_commands] )) ||
_supp__clean-cache_commands() {
    local commands; commands=()
    _describe -t commands 'supp clean-cache commands' commands "$@"
}
