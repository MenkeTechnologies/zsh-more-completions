#compdef hanko
# Documentation: https://man.archlinux.org/search?q=hanko
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'migrate:database migrations'
      'serve:run API server'
      'password:password utilities'
      'jwt:jwt utilities'
      'tenant:create/manage tenants'
      'version:print version'
    )
    _describe -t commands 'hanko command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-c --config)'{-c,--config}'=[config file]:file:_files' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
