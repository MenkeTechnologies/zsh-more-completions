#compdef hanko
# Documentation: https://github.com/teamhanko/hanko
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'migrate:database migrations'
      'serve:run API services (public, admin, all)'
      'user:user operations (import)'
      'password:password utilities'
      'jwt:jwt utilities'
      'tenant:create/manage tenants'
      'version:print version'
    )
    _describe -t commands 'hanko command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      (serve)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '1:scope:(public admin all)' && ret=0
        ;;
      (user)
        _arguments \
          '1:user action:(import)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
