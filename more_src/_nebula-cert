#compdef nebula-cert

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-version[print version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'ca:create a CA certificate and key'
      'sign:create and sign a certificate'
      'print:print details of a certificate'
      'verify:verify a certificate'
      'keygen:generate a keypair'
    )
    _describe -t commands 'nebula-cert command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (ca)
        _arguments -s -S \
          '-help[show help]' \
          '-name=[CA name]:name' \
          '-duration=[certificate validity duration]:duration' \
          '-groups=[groups for the CA]:groups' \
          '-ips=[IP addresses and networks]:ips' \
          '-subnets=[subnets]:subnets' \
          '-out-key=[output key file]:file:_files' \
          '-out-cert=[output certificate file]:file:_files' \
          '-out-qr=[output QR code image]:file:_files' \
          '-curve=[cryptographic curve]:curve:(25519 P256)' && ret=0
        ;;
      (sign)
        _arguments -s -S \
          '-help[show help]' \
          '-name=[certificate name]:name' \
          '-ip=[IP address and network in CIDR format]:ip' \
          '-groups=[comma-separated list of groups]:groups' \
          '-subnets=[comma-separated list of subnets]:subnets' \
          '-duration=[certificate validity duration]:duration' \
          '-ca-cert=[CA certificate file]:file:_files' \
          '-ca-key=[CA key file]:file:_files' \
          '-in-pub=[public key file to sign]:file:_files' \
          '-out-key=[output key file]:file:_files' \
          '-out-cert=[output certificate file]:file:_files' \
          '-out-qr=[output QR code image]:file:_files' && ret=0
        ;;
      (print)
        _arguments -s -S \
          '-help[show help]' \
          '-json[output as JSON]' \
          '-path=[certificate file to print]:file:_files' \
          '*:certificate file:_files' && ret=0
        ;;
      (verify)
        _arguments -s -S \
          '-help[show help]' \
          '-ca=[CA certificate file]:file:_files' \
          '-crt=[certificate file to verify]:file:_files' && ret=0
        ;;
      (keygen)
        _arguments -s -S \
          '-help[show help]' \
          '-out-key=[output key file]:file:_files' \
          '-out-pub=[output public key file]:file:_files' \
          '-curve=[cryptographic curve]:curve:(25519 P256)' && ret=0
        ;;
    esac
    ;;
esac

return ret
