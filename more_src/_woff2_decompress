#compdef woff2_decompress
# Documentation: https://github.com/google/woff2
# Reference accessed: 2026-05-21
# Verified: upstream main() accepts only one positional input filename, no flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:WOFF2 file:_files -g "*.woff2(-.)"' && ret=0

return ret
