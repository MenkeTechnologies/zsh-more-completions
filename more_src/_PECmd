#compdef PECmd
# Documentation: https://github.com/EricZimmerman/PECmd
# Prefetch Explorer Command Line edition

local ret=1

_arguments -s -S \
  '-d[directory to recursively process]:directory:_files -/' \
  '-f[file to process]:file:_files' \
  '-k[comma separated keywords to highlight]:keywords' \
  '-o[save prefetch file bytes to path]:path:_files -/' \
  '-q[do not dump full details about each file]' \
  '--json[directory for JSON output]:directory:_files -/' \
  '--jsonf[filename for JSON results]:filename' \
  '--csv[directory for CSV results]:directory:_files -/' \
  '--csvf[filename for CSV results]:filename' \
  '--html[directory for xhtml results]:directory:_files -/' \
  '--dt[custom date/time format]:format' \
  '--mp[display higher precision for timestamps]' \
  '--vss[process all Volume Shadow Copies]' \
  '--dedupe[deduplicate based on SHA-1]' \
  '--debug[show debug information]' \
  '--trace[show trace information]' && ret=0

return ret
