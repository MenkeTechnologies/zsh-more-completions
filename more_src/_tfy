#compdef tfy
# Documentation: https://www.truefoundry.com/docs/using-tfy-apply
# TrueFoundry tfy command line interface

local ret=1
local context state line
typeset -A opt_args

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'login:log in to TrueFoundry'
      'logout:log out of TrueFoundry'
      'register:sign up for TrueFoundry'
      'apply:create or update resources from a manifest'
    )
    _describe -t commands 'tfy command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      apply)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --dir --directory)-f[apply a single manifest file]:file:_files' \
          '(-d --dir --directory -f)'{-d,--dir,--directory}'=[apply all manifests from a directory]:dir:_files -/' \
          '--dry-run[simulate the apply without making changes]' \
          '--show-diff[show differences between manifest and deployed resources]' \
          '--diffs-only[apply only files changed in git]' \
          '--ref=[compare against a commit, branch, or tag]:ref:' \
          '--sync[clean up resources whose manifests were deleted]' && ret=0
        ;;
      *)
        ret=0
        ;;
    esac
    ;;
esac

return ret
