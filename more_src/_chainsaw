#compdef chainsaw

# Zsh completion for chainsaw - Kubernetes test framework (kyverno-chainsaw)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'test:run tests'
  'assert:evaluate assertions'
  'build:build test configuration'
  'create:create test resources'
  'docs:generate documentation'
  'export:export test resources'
  'lint:lint test definitions'
  'migrate:migrate test definitions'
  'version:show version'
  'completion:generate shell completions'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'chainsaw command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (test)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--config=[configuration file]:file:_files -g "*.yaml *.yml"' \
          '--test-dir=[test directory]:directory:_files -/' \
          '--test-file=[test file]:file:_files -g "*.yaml *.yml"' \
          '--selector=[label selector]:selector' \
          '--include-test-regex=[include tests matching regex]:regex' \
          '--exclude-test-regex=[exclude tests matching regex]:regex' \
          '--namespace=[target namespace]:namespace' \
          '--delete-namespace=[delete namespace after test]:enable:(true false)' \
          '--template=[use templating]:enable:(true false)' \
          '--skip-delete[skip deletion of test resources]' \
          '--no-color[disable color output]' \
          '--no-cluster[run without cluster]' \
          '--parallel=[number of parallel tests]:count' \
          '--repeat-count=[repeat tests N times]:count' \
          '--report-format=[report format]:format:(JSON XML)' \
          '--report-name=[report file name]:name' \
          '--report-path=[report output path]:path:_files -/' \
          '--full-name[use full test names in reports]' \
          '--pause-on-failure[pause on test failure]' \
          '--fail-fast[stop on first failure]' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '*:test files or directories:_files' && ret=0
        ;;
      (assert)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--namespace=[target namespace]:namespace' \
          '--timeout=[assertion timeout]:duration' \
          '1:resource file:_files -g "*.yaml *.yml"' && ret=0
        ;;
      (lint)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:test files:_files -g "*.yaml *.yml"' && ret=0
        ;;
      (migrate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--save[save migrated files]' \
          '--cleanup[remove old files after migration]' \
          '*:test files or directories:_files' && ret=0
        ;;
      (completion)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (build|create|docs|export|version)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
