'--help[Print help]' \
&& ret=0
;;
(logs)
_arguments "${_arguments_options[@]}" : \
'--tail=[Number of lines from end]:TAIL:_default' \
'--timeout=[Timeout in seconds (default\: 30 for --follow)]:TIMEOUT:_default' \
'--lines=[Max lines to stream (for --follow)]:LINES:_default' \
'--session=[Session name for isolating process groups (e.g. per-project)]:SESSION:_default' \
'--follow[Stream output in real-time]' \
'--stderr[Show stderr instead of stdout]' \
