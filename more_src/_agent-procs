'-h[Print help]' \
'--help[Print help]' \
':target -- Process name or ID:_default' \
&& ret=0
;;
(up)
_arguments "${_arguments_options[@]}" : \
'--only=[Start only these processes (comma-separated)]:ONLY:_default' \
'--config=[Config file path (default\: auto-discover)]:CONFIG:_default' \
'--session=[Session name for isolating process groups (e.g. per-project)]:SESSION:_default' \
'--proxy[Enable reverse proxy for this session]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(down)
