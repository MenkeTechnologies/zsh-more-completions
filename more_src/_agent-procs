    (agent-procs)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:agent-procs-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
'--name=[Process name (auto-generated if omitted)]:NAME:_default' \
'--port=[Assign a specific port (injected as PORT env var)]:PORT:_default' \
'--autorestart=[Auto-restart policy\: always, on-failure, or never]:AUTORESTART:_default' \
'--max-restarts=[Maximum number of restarts (unlimited if omitted)]:MAX_RESTARTS:_default' \
'--restart-delay=[Delay between crash and restart in milliseconds]:RESTART_DELAY:_default' \
'*--watch=[File glob patterns to watch for changes (repeatable)]:WATCH:_default' \
'*--watch-ignore=[Glob patterns to ignore when watching (repeatable)]:WATCH_IGNORE:_default' \
'--session=[Session name for isolating process groups (e.g. per-project)]:SESSION:_default' \
'--proxy[Enable reverse proxy for this session]' \
'-h[Print help]' \
'--help[Print help]' \
':command -- Command to execute:_default' \
&& ret=0
;;
(stop)
_arguments "${_arguments_options[@]}" : \
'--session=[Session name for isolating process groups (e.g. per-project)]:SESSION:_default' \
'-h[Print help]' \
'--help[Print help]' \
':target -- Process name or ID:_default' \
&& ret=0
;;
(stop-all)
_arguments "${_arguments_options[@]}" : \
'--session=[Session name for isolating process groups (e.g. per-project)]:SESSION:_default' \
'-h[Print help]' \
'--help[Print help]' \
