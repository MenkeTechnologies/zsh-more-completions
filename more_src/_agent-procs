'--session=[Session name for isolating process groups (e.g. per-project)]:SESSION:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_agent-procs_commands" \
"*::: :->agent-procs" \
&& ret=0
