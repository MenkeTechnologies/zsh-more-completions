#compdef cycles
# Documentation: https://developer.blender.org/docs/features/cycles/standalone/
# Cycles standalone physically based renderer

local ret=1

_arguments -s -S \
  '(-h --help)--help[print help message]' \
  '--version[print version number]' \
  '--device[devices to use]:device' \
  '--shadingsys[shading system to use]:system:(svm osl)' \
  '--background[render in background without user interface]' \
  '--quiet[in background mode, do not print progress messages]' \
  '--samples[number of samples to render]:samples' \
  '--output[file path to write output image]:file:_files' \
  '--threads[number of CPU rendering threads]:threads' \
  '--width[image width in pixels]:width' \
  '--height[image height in pixels]:height' \
  '--tile-size[tile size in pixels]:size' \
  '--list-devices[list information about all available devices]' \
  '--profile[enable profile logging]' \
  '--log-level[log verbosity level]:level:(fatal error warning info stats debug)' \
  '*:scene:_files -g "*.(xml|usd|usda|usdc|usdz)"' && ret=0

return ret
