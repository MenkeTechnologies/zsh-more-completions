#compdef mupdf mupdf-x11 mupdf-gl
# _mupdf — Artifex mupdf (lightweight PDF/XPS/EPUB viewer; -p password, -r resolution (DPI), -A AA quality (0-8), -W width, -H height, -X disable accel, -C tint color, -I invert; positional filename + optional starting page)
# upstream: https://github.com/ArtifexSoftware/mupdf
# Flags from mupdf platform/x11/x11_main.c on tip.

_mupdf() {
    _arguments \
        '-p+[document password]:password:' \
        '-r+[resolution (dpi)]:dpi:' \
        '-A+[anti-aliasing level 0-8]:level:(0 1 2 3 4 5 6 7 8)' \
        '-W+[viewport width]:px:' \
        '-H+[viewport height]:px:' \
        '-S+[font size]:px:' \
        '-U+[user stylesheet]:file:_files -g "*.css"' \
        '-X[disable hardware acceleration]' \
        '-I[invert colors]' \
        '-C+[tint color hex]:hex:' \
        '-T+[tile size]:size:' \
        '-V[show version]' \
        '1:document:_files -g "*.(pdf|xps|epub|cbz|fb2|svg)"' \
        '2:start page:'
}

_mupdf "$@"
