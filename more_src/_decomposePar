#compdef decomposePar
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/decomposePar.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# OpenFOAM decomposePar: domain decomposition for parallel run
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-case[case directory]:dir:_files -/' \
  '-region[mesh region]:region:' \
  '-decomposeParDict[decomposition dictionary]:file:_files' \
  '-allRegions[decompose all regions in regionProperties]' \
  '-cellDist[write cell distribution as labelList and volScalarField]' \
  '-copyUniform[copy uniform/ directories]' \
  '-copyZero[copy 0/ to processor*/ rather than decompose fields]' \
  '-constant[include constant/ in times list]' \
  '-fields[use existing geometry decomposition, convert fields only]' \
  '-force[remove existing processor*/ subdirs before decomposing]' \
  '-ifRequired[only decompose if domain count has changed]' \
  '-dry-run[test without writing the decomposition]' \
  '-noFields[do not decompose fields]' \
  '-noSets[skip cell/face/point sets]' \
  '-time[time range start[:end]]:range:' \
  '-fileHandler[file handler]:handler:(uncollated collated masterUncollated)' \
  '*::decomposePar args:_files' && ret=0
return ret
