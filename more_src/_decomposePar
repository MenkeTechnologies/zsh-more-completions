#compdef decomposePar

# OpenFOAM decomposePar: domain decomposition for parallel run
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-case[case directory]:dir:_files -/' \
  '-region[mesh region]:region:' \
  '-decomposeParDict[decomposition dictionary]:file:_files' \
  '-allRegions[decompose all regions]' \
  '-cellDist[output cell distribution map]' \
  '-copyUniform[copy 0/uniform directory]' \
  '-copyZero[copy 0/ directory]' \
  '-constant[also process constant/]' \
  '-fields[also decompose fields]' \
  '-force[overwrite existing decomposition]' \
  '-noFields[do not decompose fields]' \
  '-noSets[skip cell/face/point sets]' \
  '-time[time range start[:end]]:range:' \
  '-fileHandler[file handler]:handler:(uncollated collated masterUncollated)' \
  '*::decomposePar args:_files' && ret=0
return ret
