#compdef spotify
# Documentation: https://github.com/hnarayanan/shpotify
# shpotify: command-line interface to Spotify (macOS)

local ret=1
local -a cmds

cmds=(
  'play:resume playback / play a song'
  'next:skip to the next song'
  'prev:return to the previous song'
  'replay:restart the current track'
  'pos:jump to time (in seconds)'
  'pause:toggle pause/resume'
  'stop:stop playback'
  'quit:stop playback and quit Spotify'
  'vol:control or show the volume'
  'status:show the current playback status'
  'share:show the current song URL and URI'
  'toggle:toggle shuffle or repeat'
)

_arguments -s -S \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'spotify command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      play)
        _values 'play target' \
          'album[play an album by name]' \
          'artist[play an artist by name]' \
          'list[play a playlist by name]' \
          'uri[play from a Spotify URI]' && ret=0
        ;;
      vol)
        _values 'volume' \
          'up[increase volume by 10%]' \
          'down[decrease volume by 10%]' \
          'show[show current volume]' && ret=0
        ;;
      status)
        _values 'status field' \
          'artist[show current artist]' \
          'album[show current album]' \
          'track[show current track]' && ret=0
        ;;
      share)
        _values 'share' \
          'url[show and copy the song URL]' \
          'uri[show and copy the song URI]' && ret=0
        ;;
      toggle)
        _values 'toggle' \
          'shuffle[toggle shuffle mode]' \
          'repeat[toggle repeat mode]' && ret=0
        ;;
    esac
    ;;
esac

return ret
