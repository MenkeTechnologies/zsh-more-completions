#compdef s6-instance-delete
# _s6-instance-delete — s6 instance s6-instance-delete (delete a per-instance subdirectory from an instance-template service; default also stops the supervise process unless -X)
# upstream: https://github.com/skarnet/s6
# Flags from src/instance/s6-instance-delete.c on tip.

_s6-instance-delete() {
    _arguments \
        '-X[do not stop the supervise process; just remove the instance dir]' \
        '-t+[timeout (ms)]:ms:' \
        '1:service:_files -/' \
        '2:instance-name:'
}

_s6-instance-delete "$@"
