#compdef csshx

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)--version[display version]' \
  {-l,--login}'[SSH login name]:username:_users' \
  '--ssh[path to ssh binary]:ssh binary:_command_names' \
  '--ssh_args[additional SSH arguments]:args:' \
  '--screen[screen index to use]:screen number:' \
  '--tile_x[number of columns]:columns:' \
  '--tile_y[number of rows]:rows:' \
  '--sock[path to control socket]:socket:_files' \
  '--ping_test[ping hosts before connecting]' \
  '--ping_timeout[ping timeout in seconds]:seconds:' \
  '--config[configuration file]:config:_files' \
  '--debug[enable debug output]' \
  '--hosts[hosts file]:hosts file:_files' \
  '*:host:_hosts' && ret=0

return ret
