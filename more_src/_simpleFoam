#compdef simpleFoam

# OpenFOAM simpleFoam: steady-state RANS solver for incompressible flow
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-doc[browse online documentation]' \
  '-srcDoc[browse source documentation]' \
  '-case[OpenFOAM case directory]:dir:_files -/' \
  '-region[mesh region to run on]:region:' \
  '-decomposeParDict[parallel decomposition dictionary]:file:_files' \
  '-fileHandler[file format]:handler:(uncollated collated masterUncollated)' \
  '-listFunctionObjects[list available function objects]' \
  '-listFvOptions[list fvOptions]' \
  '-listRegisteredSwitches[list runtime switches]' \
  '-listScalarBCs[list scalar boundary conditions]' \
  '-listSwitches[list runtime switches]' \
  '-listTurbulenceModels[list turbulence models]' \
  '-listUnsetSwitches[list unset switches]' \
  '-listVectorBCs[list vector boundary conditions]' \
  '-noFunctionObjects[do not run function objects]' \
  '-parallel[run in parallel]' \
  '-postProcess[post-process previous time steps]' \
  '-roots[parallel roots]:list:' \
  '-hostRoots[host roots]:list:' \
  '*::case args:_files' && ret=0
return ret
