#compdef jack_lsp
# _jack_lsp — JACK Audio jack_lsp (list ports on a running JACK server; -A aliases, -c connections, -p properties, -t type, -l latency, -L libellic, -A1/-A2 alias depth, -s server name; with no flags lists all ports)
# upstream: https://github.com/jackaudio/jack2
# Flags from jack2 tools/lsp.c on tip.

_jack_lsp() {
    _arguments \
        '-A[also show aliases]' \
        '-A1[short alias]' \
        '-A2[long alias]' \
        '-c[show connections]' \
        '-p[show port properties]' \
        '-t[show port type]' \
        '-l[show port latency]' \
        '-L[show liblo URI]' \
        '-s+[JACK server name]:server:' \
        '-v[verbose]' \
        '-V[show version]' \
        '*:port pattern:'
}

_jack_lsp "$@"
