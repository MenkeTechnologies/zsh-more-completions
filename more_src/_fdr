#compdef fdr
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/statistics/fdr.html
# FSL: FDR-based multiple comparison correction of a p-value image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[input p-value image]:input:_files' \
  '-m[input mask image]:mask:_files' \
  '-q[q-value (FDR-corrected alpha) threshold]:q:' \
  '-o[output q-rate (FDR-adjusted p-value) image]:output:_files' \
  '--othresh=[output thresholded image filename]:thresh:_files' \
  '--oneminusp[treat input as 1-p image (e.g. from randomise)]' \
  '--order=[fdr order]:order:' \
  '--positivecorr[assume positively correlated samples (default)]' \
  '--independent[assume all samples are independent]' \
  '--conservative[use conservative normalisation for any dependence]' \
  '*:image:_files' && ret=0

return ret
