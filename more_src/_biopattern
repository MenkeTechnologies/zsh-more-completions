#compdef biopattern biopattern-bpfcc
# _biopattern — identify random / sequential disk I/O access patterns (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/biopattern.py (argparse).

_biopattern() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-d --disk)'{-d+,--disk=}'[only this disk (DEVNAME)]:disk:'
        '1:interval (seconds):'
        '2:output count:'
    )
    _arguments $args
}

_biopattern "$@"
