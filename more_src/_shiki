_shiki() {
    _arguments -s -S \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--theme=[color theme to use (default vitesse-dark)]:theme:(vitesse-dark vitesse-light dracula nord github-light github-dark monokai material-theme-darker material-theme one-dark-pro andromeeda aurora-x ayu-dark catppuccin-frappe catppuccin-latte catppuccin-macchiato catppuccin-mocha dark-plus everforest-dark everforest-light gruvbox-dark-hard gruvbox-dark-medium gruvbox-dark-soft gruvbox-light-hard gruvbox-light-medium gruvbox-light-soft houston kanagawa-dragon kanagawa-lotus kanagawa-wave laserwave light-plus material-theme-darker material-theme-lighter material-theme-ocean material-theme-palenight min-dark min-light night-owl nord one-light plastic poimandres red rose-pine rose-pine-dawn rose-pine-moon slack-dark slack-ochin snazzy-light solarized-dark solarized-light synthwave-84 tokyo-night vesper)' \
        '--lang=[programming language (auto-inferred from file extension if omitted)]:language:(text javascript typescript jsx tsx rust go python ruby java c cpp objective-c csharp swift kotlin scala haskell elixir erlang clojure lisp scheme ocaml f# fsharp lua perl r julia sql bash sh shell zsh fish powershell html css scss sass less stylus json yaml toml xml markdown md dockerfile makefile cmake gradle ini properties graphql diff git regex)' \
        '--format=[output format (default ansi)]:format:(ansi html)' \
        '--list-themes[list all available bundled themes and exit]' \
        '--list-langs[list all available bundled language grammars (~290) and exit]' \
        '*:input file or URL (omit to read from stdin when piped):_files'
}

_shiki "$@"
