#compdef shiki skat
# Documentation: https://shiki.style/packages/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for shiki syntax highlighter CLI (also exposed as skat)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--theme=[theme to use (default vitesse-dark)]:theme:' \
  '--lang=[language override (auto-inferred from extension)]:lang:' \
  '--format=[output format (default ansi)]:format:(ansi html)' \
  '*:source:_files' && ret=0

return ret
