#compdef shiki

# Zsh completion for shiki syntax highlighter CLI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-l+[TextMate grammar]:grammar' \
  '-t+[VS Code theme]:theme' \
  '-b[load defaults from languages.json]' \
  '*:source:_files' && ret=0

return ret
