#compdef kafka-log-dirs
# Documentation: https://man.archlinux.org/search?q=kafka-log-dirs
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--describe[Describe the specified log directories]'
    '--broker-list[Comma-separated list of broker IDs]:broker-ids:'
    '--topic-list[Comma-separated list of topic names]:topics:'
)

_arguments -s -S $arguments
