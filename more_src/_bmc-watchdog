#compdef bmc-watchdog

# bmc-watchdog: alternative IPMI watchdog control tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-s[start watchdog]' \
  '-S[stop watchdog]' \
  '-r[reset watchdog timer]' \
  '-c[clear watchdog]' \
  '-t[timeout (seconds)]:n:' \
  '*::bmc-watchdog args:_files' && ret=0
return ret
