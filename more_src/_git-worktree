#compdef git-worktree

# Zsh completion for git-worktree - Git worktree management

local curcontext="$curcontext" state line ret=1

local -a subcommands
subcommands=(
  'add:Create a new worktree'
  'list:List worktrees'
  'lock:Lock a worktree'
  'move:Move a worktree'
  'prune:Prune stale worktree information'
  'remove:Remove a worktree'
  'repair:Repair worktree administrative files'
  'unlock:Unlock a worktree'
)

_git_worktree_list() {
  local -a worktrees
  worktrees=(${${(f)"$(git worktree list --porcelain 2>/dev/null)"}[(R)worktree *]#worktree })
  _describe -t worktrees 'worktree' worktrees
}

_arguments -C \
  '1:subcommand:->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'git-worktree subcommand' subcommands
    ;;
  args)
    case $words[1] in
      add)
        _arguments \
          '-b[create a new branch]:branch name' \
          '-B[force create a new branch]:branch name' \
          '(-d --detach)'{-d,--detach}'[detach HEAD in new worktree]' \
          '--checkout[checkout after creating worktree]' \
          '--no-checkout[do not checkout after creating worktree]' \
          '--lock[lock worktree after creation]' \
          '--reason=[reason for locking]:reason' \
          '(-f --force)'{-f,--force}'[force creation even if path is on another disk]' \
          '--guess-remote[try to match branch name with remote branch]' \
          '--no-guess-remote[do not try to match with remote branch]' \
          '--track[set up tracking for new branch]' \
          '--no-track[do not set up tracking]' \
          '--orphan[create worktree with orphan branch]' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '1:path:_directories' \
          '2:commit-ish'
        ;;
      list)
        _arguments \
          '--porcelain[machine-readable output]' \
          '(-v --verbose)'{-v,--verbose}'[show extended annotations]' \
          '-z[NUL terminated output]'
        ;;
      lock)
        _arguments \
          '--reason=[reason for locking]:reason' \
          '1:worktree:_git_worktree_list'
        ;;
      move)
        _arguments \
          '(-f --force)'{-f,--force}'[force move]' \
          '1:worktree:_git_worktree_list' \
          '2:new path:_directories'
        ;;
      prune)
        _arguments \
          '(-n --dry-run)'{-n,--dry-run}'[do not remove anything]' \
          '(-v --verbose)'{-v,--verbose}'[report pruned worktrees]' \
          '--expire=[expire worktrees older than time]:time'
        ;;
      remove)
        _arguments \
          '(-f --force)'{-f,--force}'[force removal]' \
          '1:worktree:_git_worktree_list'
        ;;
      repair)
        _arguments '*:path:_directories'
        ;;
      unlock)
        _arguments '1:worktree:_git_worktree_list'
        ;;
    esac
    ;;
esac

return ret
