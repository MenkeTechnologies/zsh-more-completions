#compdef xcresulttool
# Documentation: https://keith.github.io/xcode-man-pages/xcresulttool.1.html
# xcrun xcresulttool - read and export Xcode .xcresult result bundles

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--path=[result bundle location]:bundle:_files -g "*.xcresult"' \
  '--output-path=[destination for exported files]:dir:_files' \
  '--id=[object hash value]:id:' \
  '--format=[output format]:format:(json raw text markdown typeHierarchy)' \
  '--type=[export target type]:type:(file directory)' \
  '--test-id=[reference a particular test]:testid:' \
  '--schema[output as JSON schema]' \
  '--compact[render results in condensed form]' \
  '--only-failures[limit exports to failure-related attachments]' \
  '1:command:(get export formatDescription merge metadata compare graph version)' && ret=0

return ret
