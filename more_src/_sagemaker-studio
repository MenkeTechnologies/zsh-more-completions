#compdef sagemaker-studio
# Documentation: https://github.com/aws/sagemaker-studio-cli
# Reference accessed: 2026-05-23
# Verified: sagemaker-studio --help (pip sagemaker-studio-cli).

# Zsh completion for sagemaker-studio - SageMaker Studio CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'sagemaker-studio command' \
      'credentials[manage Studio credentials]' \
      'execution[manage execution]' \
      'git[manage git]' \
      'project[manage project]' && ret=0
    ;;
esac

return ret
