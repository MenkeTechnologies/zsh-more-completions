#compdef mixtool
# Documentation: upstream cmd/mixtool/{main,lint,generate}.go at github.com/monitoring-mixins/mixtool
# Reference accessed: 2026-05-30
# monitoring-mixins/mixtool R55 — jsonnet-mixin helper for Prometheus
# rules + alerts + Grafana dashboards. Sister-binary to existing
# _tanka/_jb/_pint coverage within the Grafana observability family.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'generate:generate Prometheus alerts/rules + Grafana dashboards from jsonnet sources'
  'lint:validate jsonnet files and check Prometheus expression syntax'
  'new:scaffold template files for alerts/rules/dashboards'
  'server:provision Prometheus rule files via HTTP endpoint'
  'list:list installed mixin packages'
  'install:install a mixin package'
)

local -a _generate_subs
_generate_subs=(
  'alerts:generate Prometheus alerts file from mixin'
  'rules:generate Prometheus recording rules file from mixin'
  'dashboards:generate Grafana dashboards from mixin'
  'all:generate alerts + rules + dashboards in one step'
)

_arguments -C -s -S \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'mixtool subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      lint)
        _arguments \
          '--grafana[lint Grafana dashboards (default true)]' \
          '--prometheus[lint Prometheus alerts/rules (default true)]' \
          '(-J --jpath)*-J+[vendor directory (repeatable)]:directory:_directories' \
          '(-J --jpath)*--jpath=[vendor directory (repeatable)]:directory:_directories' \
          '*:jsonnet file:_files -g "*.jsonnet"' && ret=0
        ;;
      generate)
        _arguments -C \
          '(-): :->gcmd' \
          '(-)*:: :->gcmd_args' \
          '(-J --jpath)*-J+[vendor directory (repeatable)]:directory:_directories' \
          '(-J --jpath)*--jpath=[vendor directory (repeatable)]:directory:_directories' \
          '(-y --yaml)-y[YAML output]' \
          '(-y --yaml)--yaml[YAML output]' && ret=0
        case $state in
          gcmd)
            _describe -t commands 'mixtool generate subcommand' _generate_subs && ret=0
            ;;
          gcmd_args)
            case $words[1] in
              alerts)
                _arguments \
                  '(-a --output-alerts)-a+[alerts output file]:file:_files' \
                  '(-a --output-alerts)--output-alerts=[alerts output file]:file:_files' \
                  '1:jsonnet file:_files -g "*.jsonnet"' && ret=0
                ;;
              rules)
                _arguments \
                  '(-r --output-rules)-r+[rules output file]:file:_files' \
                  '(-r --output-rules)--output-rules=[rules output file]:file:_files' \
                  '1:jsonnet file:_files -g "*.jsonnet"' && ret=0
                ;;
              dashboards)
                _arguments \
                  '(-d --directory)-d+[output directory]:directory:_directories' \
                  '(-d --directory)--directory=[output directory]:directory:_directories' \
                  '1:jsonnet file:_files -g "*.jsonnet"' && ret=0
                ;;
              all)
                _arguments \
                  '(-a --output-alerts)-a+[alerts file (default alerts.yaml)]:file:_files' \
                  '(-a --output-alerts)--output-alerts=[alerts file (default alerts.yaml)]:file:_files' \
                  '(-r --output-rules)-r+[rules file (default rules.yaml)]:file:_files' \
                  '(-r --output-rules)--output-rules=[rules file (default rules.yaml)]:file:_files' \
                  '(-d --directory)-d+[dashboards directory (default dashboards_out)]:directory:_directories' \
                  '(-d --directory)--directory=[dashboards directory (default dashboards_out)]:directory:_directories' \
                  '1:jsonnet file:_files -g "*.jsonnet"' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
