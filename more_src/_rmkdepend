#compdef rmkdepend
# Documentation: https://linux.die.net/man/1/rmkdepend
# ROOT version of makedepend: create dependencies in makefiles

local ret=1

_arguments -s -S \
  '*-D-[define name in symbol table]:name=def' \
  '*-I-[prepend include directory to search list]:include dir:_files -/' \
  '-Y-[replace standard include dirs with single dir]:include dir:_files -/' \
  '-a[append dependencies instead of replacing them]' \
  '-f-[specify alternate makefile for output]:makefile:_files' \
  '-o-[object file suffix]:suffix' \
  '-p-[object file prefix]:prefix' \
  '-s-[starting string delimiter]:string' \
  '-w-[line width]:width' \
  '-v[verbose: emit list of included files]' \
  '-m[warn about multiple inclusion]' \
  '*:source file:_files' && ret=0

return ret
