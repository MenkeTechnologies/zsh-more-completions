#compdef sfkirchnew
# Documentation: http://www.ahay.org/RSF/sfkirchnew.html
# Madagascar: Kirchhoff 2-D post-stack time migration and modeling with antialiasing

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'adj=[yes: migration, no: modeling]' \
  'hd=[if y, apply half-derivative filter]' \
  'sw=[if > 0, select a branch of the antialiasing operation]' \
  'v0=[constant velocity if no velocity=]' \
  'velocity=[velocity input file]:file:_files' \
  '*:RSF file:_files' && ret=0

return ret
