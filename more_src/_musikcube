#compdef musikcube musikcubed

local curcontext="$curcontext" state line ret=1

case $service in
  musikcube)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '--disable-transparency[disable background transparency]' && ret=0
    ;;
  musikcubed)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '--start[start the daemon]' \
      '--stop[stop the daemon]' \
      '--status[check daemon status]' \
      '--foreground[run in foreground]' && ret=0
    ;;
esac

return ret
