#compdef litex_term
# Documentation: https://github.com/enjoy-digital/litex/blob/master/litex/tools/litex_term.py
# LiteX serial terminal with serial-boot image upload

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--speed=[serial baudrate]:baud:' \
  '--serial-boot[automatically initiate serial boot]' \
  '--kernel=[kernel image]:file:_files' \
  '--kernel-adr=[kernel address]:addr:' \
  '--images=[JSON description of images to load to memory]:file:_files' \
  '--safe[safe serial boot mode, disable upload speed optimizations]' \
  '--exit-on=[exit when this string is received from the device]:string:' \
  '--csr-csv=[SoC CSV file]:file:_files' \
  '--base-address=[CSR base address]:addr:' \
  '--crossover-name=[crossover UART name to use]:name:' \
  '--crossover-host=[crossover UART host address]:host:' \
  '--crossover-port=[crossover UART host port]:port:' \
  '--jtag-name=[JTAG UART type]:type:(jtag_uart)' \
  '--jtag-config=[OpenOCD JTAG configuration file]:file:_files' \
  '--jtag-chain=[JTAG chain]:chain:' \
  '*:serial port:_files' && ret=0

return ret
