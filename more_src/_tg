#compdef tg
# =============================================================================
# tg — Command-Line Interface for administering Twingate.  Twingate is a
#      commercial Zero-Trust Network Access (ZTNA) platform; this CLI
#      manages resources, groups, users, networks, connectors, devices,
#      services, and policies on a Twingate tenant via the Twingate
#      GraphQL Admin API.  Built with Deno + Cliffy for a single-binary
#      distribution that runs without Node.js installation.
#
# Author:  Twingate Labs (commercial team)
# Source:  https://github.com/Twingate-Labs/tg-cli
# CLI:     tg.js + cliCmd/ (uses c4spar/cliffy)
# Library: c4spar/cliffy
#          ("A TypeScript-first, runtime-agnostic command-line toolkit")
# License: MIT
# Status:  Active — 30+ stars, distributed by Twingate Labs as the
#          official admin tooling alternative to the Twingate web admin
#          console.  Used by Twingate's network admin customers for
#          declarative provisioning + CI-based policy management.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — TS-NODE CROSSES TO 29
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 29TH TypeScript-Node CLI library variant.  TypeScript-Node climbs from
# 28 to 29 documented libraries (cliffy via tg-cli).  New leaderboard:
# Rust=29, Go=29, TypeScript-Node=29 — THREE-WAY TIE RESTORED at the top.
# Taxonomy now spans 227 cross-language CLI library variants across 54
# documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS c4spar/cliffy AND WHY IS IT A DISTINCT 29TH TS-NODE CLI LIBRARY?
#
# cliffy (https://github.com/c4spar/deno-cliffy, 1,156+ stars) is **Caspar
# Casper's (c4spar) TypeScript-first, runtime-agnostic command-line
# toolkit**.  Originally built for Deno (the modern JavaScript/TypeScript
# runtime created by Ryan Dahl after Node.js), cliffy has grown into a
# comprehensive CLI ecosystem that ALSO supports Node.js and Bun via
# the npm `@cliffy/*` scoped packages.
#
# cliffy is more than an arg parser — it's a **CLI toolkit** that includes:
#
#   * @cliffy/command — the argument parser (the focus of this completion)
#   * @cliffy/prompt — interactive prompts (input, confirm, select,
#     checkbox, secret, number, etc.) similar to inquirer.js
#   * @cliffy/table — terminal table rendering with auto-fit columns
#   * @cliffy/keypress — raw keyboard input handling
#   * @cliffy/ansi — ANSI escape code utilities (cursor, color, text)
#   * @cliffy/flags — low-level argv parser (used internally by command)
#
# cliffy is DISTINCT from every other documented TS-Node CLI library on
# SIX specific axes:
#
#   1. DENO-FIRST DESIGN — cliffy was built for Deno before it had
#      Node.js compatibility.  This means it uses:
#        * ESM-only modules (no CommonJS)
#        * Deno.args / Deno.env (with Node.js compatibility shims)
#        * `https://deno.land/x/cliffy/...` URL imports (unique among
#          TS CLI libraries — every other one is npm-only)
#        * No TypeScript-compile step required (Deno runs .ts directly)
#      This makes cliffy the FIRST documented TS-Node CLI library
#      designed for the Deno runtime.  Cleye R472, citty R476, stricli
#      R466, clipanion R480, etc. were all built for Node.js with
#      varying degrees of Deno support added later.
#
#   2. CUSTOM TYPE REGISTRATION via `.type(name, TypeImpl)` — cliffy
#      lets you register CUSTOM ARGUMENT TYPES that participate in the
#      help-output generation, value parsing, and completion suggestions:
#         const LogLevelType = new EnumType(["DEBUG", "INFO", "WARN"]);
#         cmd.type("LogLevel", LogLevelType)
#            .option("-l, --log-level <level:LogLevel>", "...")
#      The `<level:LogLevel>` syntax in the option string refers to the
#      registered type.  Built-in types: StringType, NumberType,
#      IntegerType, BooleanType, EnumType (with values), ChoicesType,
#      ListType, ActionListType, ChildCommandType, FileType.  Users can
#      subclass `Type<T>` to define custom types with parse/complete/error
#      hooks.  No other documented TS-Node CLI library has this level
#      of TYPE EXTENSIBILITY.
#
#   3. OPTION STRING SYNTAX MIMICKING DENO'S FLAG STYLE — cliffy's
#      option declaration uses a STRUCTURED STRING that combines
#      short/long alias and value-syntax:
#         "-a, --account-name <string>"       — required string
#         "-v, --verbose"                      — boolean
#         "-l, --log-level [level:LogLevel]"  — optional typed value
#         "-p, --port <port:integer>"          — required typed value
#         "<input>"                            — positional required
#         "[output]"                           — positional optional
#         "[args...]"                          — variadic positional
#      Comma-separated short+long, `<...>` required value, `[...]`
#      optional value, `<name:type>` typed value, trailing `...`
#      variadic.  This syntax is more declarative than commander.js's
#      `-a, --account <type>` but with cliffy's optional type-annotation
#      extension.
#
#   4. `global: true` FOR INHERITED FLAGS — cliffy options can be marked
#      `global: true` which makes them AVAILABLE TO ALL SUBCOMMANDS:
#         .option("-l, --log-level <level>", "...", { global: true })
#      Subcommands inherit the option automatically and can read its
#      value via `options.logLevel`.  Compare commander.js's
#      `Command.prototype.optsWithGlobals()` which only EXPOSES global
#      options to handlers — cliffy makes globals an OPT-IN flag-level
#      property.
#
#   5. SUBCOMMAND COMPOSITION VIA `.command(name, anotherCmd)` —
#      cliffy subcommands are themselves Command instances:
#         const exportCmd = new Command()
#             .description("Export Twingate resources")
#             .option("--format <fmt>", "...")
#             .action(handler);
#         const cmd = new Command()
#             .name("tg")
#             .command("export", exportCmd);
#      This is COMPOSITIONAL — you can export Command instances from
#      separate modules and assemble them at the top level.  Compare
#      commander's `.command("name", "desc")` chain (in-place declaration)
#      or yargs' `.command(builder, handler)` (callback).
#
#   6. NPM + JSR DUAL DISTRIBUTION — cliffy ships as both:
#        * npm: @cliffy/command, @cliffy/prompt, @cliffy/table, etc.
#        * JSR: jsr:@cliffy/command (JSR is Deno's package registry)
#      The same source code works in both Node.js (via npm) and Deno
#      (via JSR or https URL imports).  This is the FIRST documented
#      TS-Node CLI library with DUAL-REGISTRY distribution.
#
# THE cliffy API SURFACE (verbatim from tg-cli usage)
#
#   import { Command, EnumType } from "https://deno.land/x/cliffy/command/mod.ts";
#
#   const LogLevelType = new EnumType(["DEBUG", "INFO", "WARN", "ERROR"]);
#
#   const cmd = new Command()
#       .name("tg")
#       .version(`CLI Version: ${VERSION}`)
#       .description("CLI for Twingate")
#       .type("LogLevel", LogLevelType)
#       .option("-a, --account-name <string>", "Twingate account name", {
#           global: true,
#           default: Deno.env.get("TG_ACCOUNT")
#       })
#       .option("-l, --log-level [logLevel:LogLevel]", "Log level", {
#           global: true,
#           default: Deno.env.get("LOG_LEVEL") || "INFO",
#           action: (options) => Deno.env.set("LOG_LEVEL", options.logLevel)
#       })
#       .action(async (options) => {
#           // top-level handler when no subcommand
#       })
#       .command("export", exportCmd)
#       .command("import", importCmd)
#       .command("deploy", deployCmd);
#
#   await cmd.parse(Deno.args);
#
# Common Command methods:
#   .name(string)                        — program name
#   .version(string)                     — version string for --version
#   .description(string)                 — description for --help
#   .option(spec, desc, opts)            — register option
#   .arguments(spec)                     — positional arguments
#   .action(handler)                     — register handler
#   .command(name, Command|builder)      — register subcommand
#   .type(name, TypeImpl)                — register custom type
#   .alias(name)                         — command alias
#   .reset()                             — reset internal state
#   .parse(argv)                         — parse arguments
#   .meta(name, value)                   — set metadata (e.g., for plugins)
#
# Option config object fields:
#   global:    boolean — inherit to subcommands
#   default:   any     — default value
#   required:  boolean — make mandatory
#   hidden:    boolean — exclude from help
#   action:    function — called when option is parsed
#   conflicts: string[] — incompatible option names
#   depends:   string[] — required-together option names
#   collect:   boolean — collect into array on repeat
#   value:     function — value transform on parse
#
# CONTRAST WITH OTHER TS-NODE CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * commander.js (fluent), yargs (chainable), minimist (pure parser),
#     arg (small), meow (yargs wrap), mri (minimist successor), caporal,
#     nopt, cmd-ts, clipanion R480 (class+decorator), citty R476
#     (defineCommand), cac, sade, type-flag, vorpal R442, gluegun,
#     stricli R466 (zero-dep), cleye R472 (TS-first Node-only),
#     command-line-args R484 (UNIX-decomposed), tact ArgParser R485
#     (parser-combinator), cliffy (THIS, Deno-first toolkit with
#                                  custom-type-registration and dual
#                                  npm/JSR distribution)
#
# cliffy is the FIRST documented TS-Node CLI library DESIGNED FOR DENO
# FIRST.  Other libraries either target Node.js only (cleye, stricli,
# clipanion) or have multi-runtime support added later.  cliffy was
# Deno-native from day one and Node.js-compatibility came via the
# @cliffy/* npm packages.
#
# REAL-WORLD cliffy USERS:
#
#   * Twingate-Labs/tg-cli — Twingate Zero-Trust admin CLI (THIS, 30*)
#   * quarto-dev/quarto-cli — Quarto scientific publishing system
#                              (5697*; already in corpus as _quarto)
#   * apexlang/apex — Apex Language CLI (43*; already in corpus as _apex)
#   * restake/ethereum-deposit-cli — ETH 2.0 staking deposit generator
#   * Hundreds of independent Deno-ecosystem CLIs at https://deno.land/x/*
#
# -----------------------------------------------------------------------------
# TG-CLI'S CLI SURFACE (verbatim from tg.js)
# -----------------------------------------------------------------------------
#
# USAGE:
#   tg [GLOBAL-OPTIONS] [SUBCOMMAND] [SUB-OPTIONS]
#
# Global options (inherited via global: true):
#   -a, --account-name <string>      Twingate account name (default: $TG_ACCOUNT)
#   -l, --log-level <LEVEL>           Log level (DEBUG/INFO/WARN/ERROR)
#                                     default: $LOG_LEVEL or INFO
#
# Subcommands:
#   export                            Export Twingate resources to JSON/YAML
#   import                            Import Twingate resources from JSON/YAML
#   remove-duplicate-resource         Remove duplicate resource entries
#   remove-all                        Remove all entries (dangerous!)
#   script                            Run a script against the Twingate API
#   deploy                            Deploy Twingate connector(s)
#
# Top-level entity commands:
#   resource                          Manage Twingate resources
#   group                             Manage Twingate groups
#   user                              Manage Twingate users
#   network                           Manage Twingate remote networks
#   connector                         Manage Twingate connectors
#   device                            Manage Twingate devices (BYOD)
#   service                           Manage Twingate service accounts
#   policy                            Manage Twingate policies
#
# Each entity command has its own sub-subcommands:
#   tg <entity> create [options]
#   tg <entity> list [options]
#   tg <entity> get <id>
#   tg <entity> update <id> [options]
#   tg <entity> delete <id>
#
# Standard:
#   -h, --help                        Show help
#   -V, --version                     Show version
#
# Environment variables:
#   TG_ACCOUNT                        Twingate account name (= --account-name)
#   TG_API_KEY                        Twingate API key (required for all ops)
#   LOG_LEVEL                         Log level (= --log-level)
#
# =============================================================================

_tg() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands log_levels entity_commands

    subcommands=(
        'export:export Twingate resources to JSON/YAML'
        'import:import Twingate resources from JSON/YAML'
        'remove-duplicate-resource:remove duplicate resource entries'
        'remove-all:remove all entries (DANGEROUS)'
        'script:run a script against the Twingate API'
        'deploy:deploy Twingate connector(s)'
        'resource:manage Twingate resources'
        'group:manage Twingate groups'
        'user:manage Twingate users'
        'network:manage Twingate remote networks'
        'connector:manage Twingate connectors'
        'device:manage Twingate devices (BYOD)'
        'service:manage Twingate service accounts'
        'policy:manage Twingate policies'
    )

    log_levels=(
        'DEBUG:debug-level logs'
        'INFO:informational logs (default)'
        'WARN:warnings only'
        'ERROR:errors only'
    )

    entity_commands=(
        'create:create entity'
        'list:list entities'
        'get:get entity by id'
        'update:update entity by id'
        'delete:delete entity by id'
    )

    _arguments -C \
        '(-a --account-name)'{-a,--account-name}'[Twingate account name]:account:' \
        '(-l --log-level)'{-l,--log-level}'[log level]:level:->log_level' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (log_level)
            _describe -t log_levels 'log level' log_levels && ret=0
            ;;
        (cmd)
            _describe -t subcommands 'tg subcommand' subcommands && ret=0
            ;;
        (args)
            case $line[1] in
                (resource|group|user|network|connector|device|service|policy)
                    _describe -t entity_commands 'entity action' entity_commands && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_tg "$@"
