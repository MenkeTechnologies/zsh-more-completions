#compdef react-native-cli rn
# _react-native-cli — React Native community CLI alias (Meta / react-native-community, JavaScript); commander
# upstream: https://github.com/react-native-community/cli

_react-native-cli() {
    local -a sub=(
        'init:scaffold project'
        'start:start metro bundler'
        'run-android:build/run android'
        'run-ios:build/run ios'
        'log-android:tail android logs'
        'log-ios:tail ios logs'
        'doctor:diagnose project'
        'info:show env info'
        'config:print config'
        'profile-hermes:profile hermes'
        'build-android:build android only'
        'build-ios:build ios only'
        'clean:clean build artifacts'
        'install:install dependency'
        'uninstall:uninstall dependency'
        'link:link native deps'
        'unlink:unlink native deps'
        'upgrade:upgrade react-native version'
        'autolink-ios:autolink ios deps'
        'autolink-android:autolink android deps'
        'codegen:run codegen'
        'bundle:bundle JS for prod'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--projectRoot=+[project root]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'react-native subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '1:project-name:' \
                    '--template=+[template]:str:' \
                    '--version=+[version]:str:' \
                    '--directory=+[directory]:dir:_files -/' \
                    '--npm[use npm]' \
                    '--pm=+[package manager]:pm:(npm pnpm yarn bun)' \
                    '--skip-install[skip install]' \
                    '--title=+[title]:str:' \
                    '--install-pods=+[install pods]:b:(true false)' \
                    '--platform-name=+[platform name]:str:' \
                    '--skip-git-init[skip git init]' \
                    '--replace-directory=+[replace directory]:b:(true false)' ;;
                start) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--reset-cache[reset cache]' \
                    '--no-interactive[no interactive]' \
                    '--client-logs[client logs]' \
                    '--max-workers=+[max workers]:n:' \
                    '--project-root=+[project root]:dir:_files -/' \
                    '--config=+[config]:file:_files' \
                    '--watchFolders=+[watch folders]:dir:_files -/' \
                    '--assetExts=+[asset exts]:list:' \
                    '--sourceExts=+[source exts]:list:' \
                    '--platforms=+[platforms]:list:' \
                    '--https[https]' \
                    '--key=+[ssl key]:file:_files' \
                    '--cert=+[ssl cert]:file:_files' \
                    '--terminal=+[terminal]:str:' \
                    '--transformer=+[transformer]:str:' ;;
                run-android) _arguments \
                    '--root=+[root]:dir:_files -/' \
                    '--variant=+[variant]:str:' \
                    '--appFolder=+[app folder]:dir:_files -/' \
                    '--appId=+[app id]:str:' \
                    '--appIdSuffix=+[app id suffix]:str:' \
                    '--main-activity=+[main activity]:str:' \
                    '--deviceId=+[device id]:str:' \
                    '--list-devices[list devices]' \
                    '--no-packager[no packager]' \
                    '--port=+[port]:port:' \
                    '--terminal=+[terminal]:str:' \
                    '--tasks=+[gradle tasks]:list:' \
                    '--active-arch-only[active arch only]' \
                    '--mode=+[mode]:m:(debug release)' \
                    '--no-debug-server[no debug server]' \
                    '--binary-path=+[binary path]:file:_files' ;;
                run-ios) _arguments \
                    '--simulator=+[simulator]:str:' \
                    '--mode=+[mode]:m:(Debug Release)' \
                    '--scheme=+[scheme]:str:' \
                    '--project-path=+[project path]:dir:_files -/' \
                    '--device=+[device]:str:' \
                    '--udid=+[udid]:str:' \
                    '--list-devices[list devices]' \
                    '--no-packager[no packager]' \
                    '--port=+[port]:port:' \
                    '--terminal=+[terminal]:str:' \
                    '--binary-path=+[binary path]:file:_files' \
                    '--workspace=+[workspace]:file:_files -g "*.xcworkspace"' \
                    '--xcconfig=+[xcconfig]:file:_files' ;;
                doctor|info|config) _arguments '*:arg:' ;;
                bundle) _arguments \
                    '--entry-file=+[entry file]:file:_files' \
                    '--platform=+[platform]:p:(android ios web)' \
                    '--dev=+[dev]:b:(true false)' \
                    '--bundle-output=+[bundle output]:file:_files' \
                    '--sourcemap-output=+[sourcemap output]:file:_files' \
                    '--assets-dest=+[assets dest]:dir:_files -/' \
                    '--minify=+[minify]:b:(true false)' \
                    '--reset-cache=+[reset cache]:b:(true false)' \
                    '--max-workers=+[max workers]:n:' \
                    '--unstable-transform-profile=+[transform profile]:str:' ;;
                clean) _arguments \
                    '--include=+[include]:list:(android cocoapods metro npm watchman yarn bun)' \
                    '--project-root=+[project root]:dir:_files -/' ;;
                upgrade) _arguments \
                    '1:version:' \
                    '--legacy=+[legacy upgrade]:b:(true false)' ;;
                codegen) _arguments \
                    '--path=+[path]:dir:_files -/' \
                    '--platform=+[platform]:p:(android ios)' \
                    '--outputPath=+[output path]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_react-native-cli "$@"
