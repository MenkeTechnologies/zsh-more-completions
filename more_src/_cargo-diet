#compdef cargo-diet
# Documentation: https://crates.io/crates/cargo-diet
# compute the smallest possible include directives for Cargo.toml

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --dry-run)'{-n,--dry-run}'[do not write changes to the manifest]' \
  '(-q --quiet)'{-q,--quiet}'[suppress informational output]' \
  '(-r --reset-manifest)'{-r,--reset-manifest}'[clear include/exclude before computing]' \
  '--package-size-limit[fail if the package exceeds this size]:size' && ret=0

return ret
