#compdef semgrep

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)--version[display version]' \
  '1:command:->command' \
  '*::arg:->args' \
  && ret=0

case $state in
  command)
    local -a commands=(
      'scan:run semgrep rules on files'
      'ci:run semgrep in CI environment'
      'login:obtain and save credentials'
      'logout:remove saved credentials'
      'publish:upload rules to the Semgrep Registry'
      'install-semgrep-pro:install Semgrep Pro Engine'
      'lsp:start the Semgrep LSP server'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      scan)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '(-f --config)'{-f,--config}'[YAML config file or directory or registry entry]:config:_files' \
          '(-e --pattern)'{-e,--pattern}'[code search pattern]:pattern' \
          '(-l --lang)'{-l,--lang}'[parse pattern and all files in specified language]:language' \
          '--replacement[autofix replacement text]:replacement' \
          '--autofix[apply autofixes]' \
          '--dryrun[do not write autofixes]' \
          '--severity[report only specified severity]:severity:(INFO WARNING ERROR)' \
          '--exclude[skip files matching pattern]:pattern' \
          '--include[only scan files matching pattern]:pattern' \
          '--max-target-bytes[maximum size for target files]:bytes' \
          '--use-git-ignore[respect .gitignore files]' \
          '--no-git-ignore[do not respect .gitignore files]' \
          '--scan-unknown-extensions[scan files even if language is unknown]' \
          '--json[output results in JSON format]' \
          '--emacs[output results in Emacs format]' \
          '--vim[output results in Vim format]' \
          '--sarif[output results in SARIF format]' \
          '--gitlab-sast[output results in GitLab SAST format]' \
          '--gitlab-secrets[output results in GitLab secrets format]' \
          '--junit-xml[output results in JUnit XML format]' \
          '(-o --output)'{-o,--output}'[save results to file]:output file:_files' \
          '(-q --quiet)'{-q,--quiet}'[only output findings]' \
          '--no-rewrite-rule-ids[do not rewrite rule IDs]' \
          '--time[show timing information]' \
          '--max-memory[maximum system memory to use]:memory in MB' \
          '--timeout[set per-rule timeout]:seconds' \
          '--timeout-threshold[skip rule after N timeouts]:count' \
          {-j,--jobs}'[number of parallel jobs]:jobs' \
          '--optimizations[turn on/off optimizations]:mode:(all none)' \
          '--verbose[show more details]' \
          '--debug[show debug output]' \
          '--test[run test suite]' \
          '--test-ignore-todo[ignore todo in test]' \
          '--metrics[configure metrics]:mode:(auto on off)' \
          '--disable-version-check[disable version check]' \
          '--baseline-commit[only show results not in baseline]:commit' \
          '--diff-depth[depth of git diff]:depth' \
          '*:path:_files' \
          && ret=0
        ;;
      ci)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '--config[YAML config file or registry entry]:config:_files' \
          '--json[output in JSON format]' \
          '--sarif[output in SARIF format]' \
          '--autofix[apply autofixes]' \
          '--dryrun[do not write autofixes]' \
          '--supply-chain[run supply chain analysis]' \
          '--code[run SAST analysis]' \
          '--secrets[run secrets analysis]' \
          '--max-memory[maximum system memory]:memory in MB' \
          '--timeout[set per-rule timeout]:seconds' \
          {-j,--jobs}'[number of parallel jobs]:jobs' \
          '--verbose[show more details]' \
          '--debug[show debug output]' \
          '--metrics[configure metrics]:mode:(auto on off)' \
          && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
