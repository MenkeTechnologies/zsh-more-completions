#compdef exiftran
# Documentation: https://manpages.debian.org/testing/exiftran/exiftran.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# exiftran: transform digital camera JPEG images (part of fbida).
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a[automatic rotate by EXIF orientation tag]' \
  '-9[rotate 90 degrees clockwise]' \
  '-1[rotate 180 degrees]' \
  '-2[rotate 270 degrees clockwise]' \
  '-f[mirror vertically (top/bottom)]' \
  '-F[mirror horizontally (left/right)]' \
  '-t[transpose across upper-left to lower-right corner]' \
  '-T[transverse across upper-right to lower-left corner]' \
  '-nt[skip thumbnail transformation]' \
  '-ni[skip JPEG image transformation]' \
  '-no[do not update orientation tag]' \
  '-np[preserve image size without cropping]' \
  '-c+[set JPEG comment tag]:comment:' \
  '-d[dump EXIF data to stdout]' \
  '-g[generate or regenerate EXIF thumbnail]' \
  '-o+[output file (single input only)]:file:_files' \
  '-i[in-place rewrite for multiple files]' \
  '-b[create backup during in-place edit]' \
  '-p[preserve file timestamps during in-place edit]' \
  '*:file:_files -g "*.(jpg|jpeg)"' && ret=0

return ret
