#compdef exiftran
# Documentation: https://man.archlinux.org/search?q=exiftran
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a[automatic rotate by EXIF orientation]' \
  '-9[rotate 90 degrees clockwise]' \
  '-1[rotate 180 degrees]' \
  '-2[rotate 270 degrees clockwise]' \
  '-f[flip horizontally]' \
  '-F[flip vertically]' \
  '-t[transpose]' \
  '-T[transverse]' \
  '-nb[do not touch thumbnail]' \
  '-no[do not touch orientation tag]' \
  '-c+[set comment]:comment:' \
  '-d[dump EXIF info to stdout]' \
  '-o+[output file]:file:_files' \
  '-i[in-place rewrite]' \
  '-g[GUI mode]' \
  '*:file:_files -g "*.{jpg,jpeg}"' && ret=0

return ret
