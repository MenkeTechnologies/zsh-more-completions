#compdef bootctl systemd-boot
# _systemd-boot — systemd bootctl (manage the systemd-boot EFI loader: install/update/remove on the ESP, status snapshot, list known boot entries, set-default / set-oneshot the chosen entry, set-timeout the menu wait, random-seed seeds /loader/random-seed)
# upstream: https://github.com/systemd/systemd (src/boot/bootctl.c)
# Subcommands from systemd src/boot/bootctl.c on tip.

_systemd-boot() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--esp-path+[ESP mountpoint]:dir:_files -/' \
        '--boot-path+[XBOOTLDR mountpoint]:dir:_files -/' \
        '-p+[ESP mountpoint]:dir:_files -/' \
        '-x+[XBOOTLDR mountpoint]:dir:_files -/' \
        '--no-variables[do not touch EFI vars]' \
        '--no-pager[no pager]' \
        '--graceful[graceful on missing files]' \
        '--root+[root prefix]:dir:_files -/' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'bootctl command' '(status install update remove list set-default set-oneshot random-seed reboot-to-firmware is-installed unlink cleanup)' ;;
        args) _arguments '*:argument:_files' ;;
    esac
}

_systemd-boot "$@"
