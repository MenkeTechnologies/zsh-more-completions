#compdef qbt
# Documentation: https://github.com/fedarovich/qbittorrent-cli/wiki/command-reference
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# qbt: qBittorrent CLI by fedarovich

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'category:manage torrent categories'
  'global:configure global settings'
  'inspect:examine torrent files'
  'network:handle network configuration'
  'peer:manage peer operations'
  'rss:control RSS feeds and rules'
  'search:manage search plugins'
  'server:configure server settings'
  'settings:manage CLI configuration'
  'tag:work with torrent tags'
  'torrent:manage active torrents'
  'help:show help for a command'
)

_arguments -C \
  '(-h --help -?)'{-h,--help,-\?}'[show help]' \
  '--version[show version]' \
  '--url=[qBittorrent server URL]:url:' \
  '--username=[user name]:user:' \
  '--password=[user password]:password:' \
  '--ask-for-password[prompt for password]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'qbt command' commands && ret=0 ;;
  (args) _files && ret=0 ;;
esac

return ret
