#compdef schemacrawler
# Documentation: https://www.schemacrawler.com/how-to.html
# schemacrawler - database schema discovery and comprehension tool

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '--server=[database system identifier]:server' \
  '--host=[database server host]:host:_hosts' \
  '--port=[database server port]:port' \
  '--database=[database name]:database' \
  '--user=[database user name]:user' \
  '--password=[database password]:password' \
  '--url=[JDBC connection URL]:url' \
  '--connection-properties=[JDBC connection properties]:properties' \
  '--command=[schemacrawler command]:command:(schema brief detailed list count dump quickdump script template)' \
  '--info-level=[crawl detail level]:level:(minimum standard detailed maximum)' \
  '--output-format=[output format]:format:(text html htmlx json csv tsv dot png svg pdf)' \
  '--output-file=[output file path]:output:_files' \
  '--schemas=[regex to select schemas]:schemas' \
  '--tables=[regex to select tables]:tables' \
  '--table-types=[filter table types]:types' \
  '--routines=[regex to select routines]:routines' \
  '--routine-types=[filter routine types]:types' \
  '--grep-columns=[regex to grep columns]:columns' \
  '--no-remarks[exclude table and column comments]' \
  '--no-empty-tables[exclude tables with no data]' \
  '--load-row-counts[include table row counts]' \
  '--portable=[hide system-generated object names]:mode:(names broad)' \
  '--log-level=[set logging level]:level:(OFF SEVERE WARNING INFO CONFIG FINE FINER FINEST ALL)' && ret=0

return ret
