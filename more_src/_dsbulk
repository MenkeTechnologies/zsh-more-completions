#compdef dsbulk

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'load:import data from a source file/URL into a table'
  'unload:export data from a table to a destination file/URL'
  'count:count rows in a table'
  'help:display help for dsbulk or a subcommand'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-h --driver.host)'{-h,--driver.host=}'[contact points]:host:_hosts' \
  '(-port --driver.port)'{-port=,--driver.port=}'[native transport port]:port:' \
  '(-u --driver.auth.username)'{-u,--driver.auth.username=}'[database username]:user:_users' \
  '(-p --driver.auth.password)'{-p,--driver.auth.password=}'[database password]:password:' \
  '(-b --driver.secure-connect-bundle)'{-b,--driver.secure-connect-bundle=}'[Astra Secure Connect Bundle]:file:_files' \
  '(-k --schema.keyspace)'{-k,--schema.keyspace=}'[target keyspace]:keyspace:' \
  '(-t --schema.table)'{-t,--schema.table=}'[target table]:table:' \
  '(-query --schema.query)'{-query=,--schema.query=}'[custom CQL query]:cql:' \
  '(-g --schema.graph)'{-g,--schema.graph=}'[graph name]:graph:' \
  '(-v --schema.vertex)'{-v,--schema.vertex=}'[vertex label]:label:' \
  '(-e --schema.edge)'{-e,--schema.edge=}'[edge label]:label:' \
  '(-m --schema.mapping)'{-m,--schema.mapping=}'[map input fields to columns]:mapping:' \
  '(-url --connector.csv.url)'{-url=,--connector.csv.url=}'[source/destination URL]:url:' \
  '(-urlfile --connector.csv.urlfile)'{-urlfile=,--connector.csv.urlfile=}'[file listing URLs]:file:_files' \
  '(-header --connector.csv.header)'{-header=,--connector.csv.header=}'[first row contains column names]:flag:(true false)' \
  '(-delim --connector.csv.delimiter)'{-delim=,--connector.csv.delimiter=}'[CSV delimiter]:char:' \
  '(-escape --connector.csv.escape)'{-escape=,--connector.csv.escape=}'[CSV escape character]:char:' \
  '--connector.csv.compression=[CSV compression]:type:(gzip deflate bzip2 lz4 snappy xz zstd none)' \
  '--connector.json.compression=[JSON compression]:type:(gzip deflate bzip2 lz4 snappy xz zstd none)' \
  '(-c --connector.name)'{-c,--connector.name=}'[connector name]:name:(csv json)' \
  '(-f --config)'{-f,--config=}'[path to config file]:file:_files' \
  '--dryRun[test without writing to database]' \
  '--schema.allowMissingFields[permit missing fields in input]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'dsbulk subcommand' subcommands && ret=0
    ;;
esac

return ret
