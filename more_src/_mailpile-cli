#compdef mailpile-cli mailpile
# Documentation: https://man.archlinux.org/search?q=mailpile-cli
# Reference accessed: 2026-05-16

# Mailpile: open-source web mail client with CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'add:add mailbox'
  'compose:compose a new message'
  'search:search messages'
  'tag:tag messages'
  'untag:untag messages'
  'index:reindex mail store'
  'rescan:rescan mailboxes'
  'crypto:crypto operations'
  'profiles:profile management'
  'help:show help for command'
  'www:start web UI'
  'serve:start mail server'
  'shutdown:stop a running Mailpile'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-w[force web UI]' \
  '--www[force web UI]' \
  '--quit[exit after running command]' \
  '--interact[stay interactive]' \
  '--profile=[mail profile to use]:profile:' \
  '--debug[debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mailpile command' commands && ret=0 ;;
esac
return ret
