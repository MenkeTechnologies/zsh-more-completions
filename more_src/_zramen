#compdef zramen
# _zramen — zramen CLI Linux zram compressed RAM swap configuration helper wrapping /sys/block/zram* sysfs creating destroying configuring lz4 lzo zstd lz4hc compression streams percent-of-RAM allocation swap priority systemd integration via OpenRC udev (gentoo zramen team, shell); getopt
# upstream: https://github.com/jirutka/zramen

_zramen() {
    local -a sub=(
        'start:start zram swap'
        'stop:stop zram swap'
        'config:show effective config'
        'status:show status'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-a+[compression algorithm]:a:(lzo lz4 lz4hc zstd 842 deflate)' \
        '--algorithm=+[algo]:a:(lzo lz4 lz4hc zstd 842 deflate)' \
        '-s+[size]:str:' \
        '--size=+[size]:str:' \
        '-p+[priority]:n:' \
        '--priority=+[priority]:n:' \
        '-P+[percent of RAM]:n:' \
        '--percent=+[percent]:n:' \
        '-n+[device id]:n:' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zramen subcommand' sub ;;
    esac
}

_zramen "$@"
