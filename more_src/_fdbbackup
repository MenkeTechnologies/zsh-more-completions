#compdef fdbbackup

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start a backup'
  'modify:modify backup parameters'
  'abort:abort an in-progress backup'
  'discontinue:discontinue an active backup'
  'wait:wait for a backup to finish'
  'status:show backup status'
  'delete:delete a backup'
  'expire:expire backup data older than threshold'
  'describe:describe a backup'
  'list:list backups in a base URL'
  'tags:list backup tags'
  'cleanup:clean up backup state'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-C=[cluster file]:file:_files' \
  '-d=[backup URL]:url:' \
  '-t=[backup tag]:tag:' \
  '--blob-credentials=[blob credentials file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'fdbbackup subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '-z[do not perform restore-side preparations]' \
          '(-s --snapshot-interval)'{-s,--snapshot-interval=}'[snapshot interval]:duration:' \
          '--initial-snapshot-interval=[initial snapshot interval]:duration:' \
          '--partitioned-log-experimental[use partitioned log]' \
          '-w[wait for backup to finish]' \
          '-k=[key range BEGIN [END]]:keys:' && ret=0
        ;;
      (modify)
        _arguments \
          '--active-snapshot-interval=[snapshot interval]:duration:' \
          '--verify-uid=[verify backup UID]:uid:' && ret=0
        ;;
      (discontinue)
        _arguments \
          '-w[wait for completion]' && ret=0
        ;;
      (expire)
        _arguments \
          '--expire-before-timestamp=[expire before datetime]:datetime:' \
          '--expire-before-version=[expire before version]:version:' \
          '--restorable-after-timestamp=[restorable after datetime]:datetime:' \
          '--restorable-after-version=[restorable after version]:version:' \
          '(-f --force)'{-f,--force}'[force expiration]' && ret=0
        ;;
      (describe)
        _arguments \
          '--version-timestamps[print version timestamps]' && ret=0
        ;;
      (list)
        _arguments \
          '(-b --base-url)'{-b,--base-url=}'[base URL]:url:' && ret=0
        ;;
      (cleanup)
        _arguments \
          '--delete-data[delete data]' \
          '--min-cleanup-seconds=[min cleanup seconds]:secs:' && ret=0
        ;;
    esac
    ;;
esac

return ret
