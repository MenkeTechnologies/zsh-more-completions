#compdef create-rwsdk
# Documentation: https://docs.rwsdk.com/reference/create-rwsdk/
# Scaffold a RedwoodSDK project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-V --version)'{-V,--version}'[display version number]' \
  '(-f --force)'{-f,--force}'[force overwrite if directory exists]' \
  '--release=[use a specific release version]:version:' \
  '--pre[use the latest pre-release (alpha, beta, rc)]' \
  '*:project directory:_files -/' && ret=0

return ret
