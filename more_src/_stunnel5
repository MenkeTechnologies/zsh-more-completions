#compdef stunnel5
# Documentation: https://man.archlinux.org/search?q=stunnel5
# Reference accessed: 2026-05-16

# stunnel5: legacy 5.x branch of the stunnel SSL/TLS tunnel
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version and config]' \
  '-sockets[show socket options and exit]' \
  '-options[show available OpenSSL options]' \
  '-fd[read config from file descriptor]:fd:' \
  '-reload[reload running stunnel config]' \
  '-reopen[reopen log files]' \
  '-exit[stop running stunnel]' \
  '-stop[stop running stunnel]' \
  '-install[install Windows service]' \
  '-uninstall[uninstall Windows service]' \
  '-start[start Windows service]' \
  '-quiet[quiet mode]' \
  '*:config file:_files -g "*.conf"' && ret=0
return ret
