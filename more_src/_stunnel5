#compdef stunnel5
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/stunnel.8.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# stunnel5: legacy 5.x branch of the stunnel SSL/TLS tunnel
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[print stunnel help menu]' \
  '(- *)-version[print stunnel version and compile time defaults]' \
  '-sockets[print default socket options]' \
  '-options[print supported TLS options]' \
  '-fd+[read the config file from specified file descriptor]:fd:' \
  '-install[install NT Service (Windows)]' \
  '-uninstall[uninstall NT Service (Windows)]' \
  '-start[start NT Service (Windows)]' \
  '-stop[stop NT Service (Windows)]' \
  '-reload[reload config of running NT Service (Windows)]' \
  '-reopen[reopen log file of running NT Service (Windows)]' \
  '-exit[exit already started stunnel (Windows)]' \
  '-quiet[do not display message boxes (Windows)]' \
  '*:config file:_files -g "*.conf"' && ret=0
return ret
