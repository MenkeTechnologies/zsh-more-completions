#compdef stunnel5

# stunnel 5.x: SSL/TLS encryption wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-options[print supported SSL options]' \
  '-fd[read config from file descriptor]:n:' \
  '-reload[reload configuration]' \
  '-reopen[reopen log file]' \
  '-stop[shut down running stunnel]' \
  '-status[print stunnel status]' \
  '*:stunnel config file:_files -g "*.conf"' && ret=0
return ret
