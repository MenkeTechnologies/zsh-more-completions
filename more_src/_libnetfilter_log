#compdef nfulnl_test nflog_test
# _libnetfilter_log — libnetfilter_log test/example helper (nfulnl_test / nflog_test from the libnetfilter_log examples; subscribes to an NFLOG group and prints decoded packets to stdout; -g group, -p pcap output, -d daemonize, -v verbose, -V version, -h help)
# upstream: https://git.netfilter.org/libnetfilter_log
# Flags from netfilter/libnetfilter_log examples/nfulnl_test.c on tip.

_libnetfilter_log() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-g+[NFLOG group]:n:' \
        '-p+[pcap output]:file:_files -g "*.(pcap|pcapng)"' \
        '-d[daemonize]' \
        '-v[verbose]'
}

_libnetfilter_log "$@"
