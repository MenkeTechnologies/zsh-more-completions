#compdef RNAsnoop
# Documentation: https://www.tbi.univie.ac.at/RNA/RNAsnoop.1.html
# RNAsnoop — find targets of a query H/ACA snoRNA (ViennaRNA)

local ret=1

_arguments -s -S \
  '--help[print help]' \
  '--detailed-help[print help with all details and hidden options]' \
  '--full-help[print help including hidden options]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--verbose[be verbose]' \
  '(-s --query)'{-s,--query}'=[query H/ACA snoRNA sequence]:string' \
  '(-t --target)'{-t,--target}'=[target sequence]:string' \
  '(-S --suffix)'{-S,--suffix}'=[suffix for output files]:string' \
  '(-P --from-RNAplfold)'{-P,--from-RNAplfold}'=[directory with RNAplfold accessibility data]:dir:_files -/' \
  '(-U --from-RNAup)'{-U,--from-RNAup}'=[directory with RNAup accessibility data]:dir:_files -/' \
  '(-O --output_directory)'{-O,--output_directory}'=[output directory]:dir:_files -/' \
  '--log-level=[set log level threshold]:level' \
  '--log-file=[print log messages to file]::file:_files' \
  '--log-time[include timestamp in log messages]' \
  '--log-call[include file and line of logging function]' \
  '(-A --alignment-mode)'{-A,--alignment-mode}'[use alignment mode]' \
  '(-f --fast-folding)'{-f,--fast-folding}'=[fast folding mode]:int:(0 1)' \
  '(-c --extension-cost)'{-c,--extension-cost}'=[extension cost]:int' \
  '(-e --energy-threshold)'{-e,--energy-threshold}'=[energy threshold]:double' \
  '(-o --minimal-right-duplex)'{-o,--minimal-right-duplex}'=[minimal right duplex energy]:int' \
  '(-l --minimal-loop-energy)'{-l,--minimal-loop-energy}'=[minimal loop energy]:int' \
  '(-p --minimal-left-duplex)'{-p,--minimal-left-duplex}'=[minimal left duplex energy]:int' \
  '(-q --minimal-duplex)'{-q,--minimal-duplex}'=[minimal duplex energy]:int' \
  '(-d --duplex-distance)'{-d,--duplex-distance}'=[duplex distance]:int' \
  '(-h --minimal-stem-length)'{-h,--minimal-stem-length}'=[minimal stem length]:int' \
  '(-i --maximal-stem-length)'{-i,--maximal-stem-length}'=[maximal stem length]:int' \
  '(-j --minimal-duplex-box-length)'{-j,--minimal-duplex-box-length}'=[minimal duplex box length]:int' \
  '(-k --maximal-duplex-box-length)'{-k,--maximal-duplex-box-length}'=[maximal duplex box length]:int' \
  '(-m --minimal-snoRNA-stem-loop-length)'{-m,--minimal-snoRNA-stem-loop-length}'=[minimal snoRNA stem-loop length]:int' \
  '(-n --maximal-snoRNA-stem-loop-length)'{-n,--maximal-snoRNA-stem-loop-length}'=[maximal snoRNA stem-loop length]:int' \
  '(-v --minimal-snoRNA-duplex-length)'{-v,--minimal-snoRNA-duplex-length}'=[minimal snoRNA duplex length]:int' \
  '(-w --maximal-snoRNA-duplex-length)'{-w,--maximal-snoRNA-duplex-length}'=[maximal snoRNA duplex length]:int' \
  '(-x --minimal-duplex-stem-energy)'{-x,--minimal-duplex-stem-energy}'=[minimal duplex stem energy]:int' \
  '(-y --minimal-total-energy)'{-y,--minimal-total-energy}'=[minimal total energy]:int' \
  '(-a --maximal-stem-asymmetry)'{-a,--maximal-stem-asymmetry}'=[maximal stem asymmetry]:int' \
  '(-b --minimal-lower-stem-energy)'{-b,--minimal-lower-stem-energy}'=[minimal lower stem energy]:int' \
  '(-L --alignmentLength)'{-L,--alignmentLength}'=[alignment length]:int' \
  '(-C --constraint)'{-C,--constraint}'[apply structure constraints]' \
  '(-I --produce-ps)'{-I,--produce-ps}'[produce PostScript output]' \
  '(-N --direct-redraw)'{-N,--direct-redraw}'[direct redraw]' && ret=0

return ret
