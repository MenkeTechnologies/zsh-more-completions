#compdef sigloss
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/registration/fugue.html
# FSL: estimate signal loss from a B0 fieldmap (in rad/s)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[input B0 fieldmap (rad/s)]:input:_files' \
  '-m[input mask volume]:mask:_files' \
  '-s[output signal loss estimate]:sigloss:_files' \
  '--te=[echo time (sec)]:te:' \
  '-v[verbose output]' \
  '*:image:_files' && ret=0

return ret
