#compdef jsubfinder
# Documentation: https://github.com/ThreatUnknown/jsubfinder
# searches webpages for javascript and analyzes them for hidden subdomains and secrets

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-K --nossl)'{-K,--nossl}'[skip SSL cert verification]' \
  '(-o --outputFile)'{-o,--outputFile}'[name/location to store the file]:output file:_files' \
  '(-s --secrets)'{-s,--secrets}'[check results for secrets e.g. api keys]' \
  '--sig[location of signatures for finding secrets]:sig file:_files' \
  '(-S --silent)'{-S,--silent}'[disable printing to the console]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'search:analyze URLs for hidden subdomains and secrets'
      'proxy:upstream HTTP proxy with TLS MITM for real-time analysis'
    )
    _describe -t commands 'jsubfinder command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      search)
        _arguments \
          '(-c --crawl)'{-c,--crawl}'[enable crawling]' \
          '(-g --greedy)'{-g,--greedy}'[check all files for URLs, not just Javascript]' \
          '(-f --inputFile)'{-f,--inputFile}'[file containing domains]:input file:_files' \
          '(-t --threads)'{-t,--threads}'[number of threads to use]:threads' \
          '(-u --url)'{-u,--url}'[URL to check]:url' && ret=0
        ;;
      proxy)
        _arguments \
          '(-p --port)'{-p,--port}'[proxy listening port]:port' \
          '--scope[in-scope URLs (comma-separated)]:scope' \
          '(-u --upstream-proxy)'{-u,--upstream-proxy}'[upstream proxy address]:upstream' && ret=0
        ;;
    esac
    ;;
esac

return ret
