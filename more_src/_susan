#compdef susan
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/registration/susan.html
# susan - nonlinear noise reduction / smoothing (positional args)

local ret=1

_arguments -s -S \
  '1:input image:_files' \
  '2:brightness threshold (bt):' \
  '3:spatial size sigma in mm (dt):' \
  '4:dimensionality:(2 3)' \
  '5:use median filter:(0 1)' \
  '6:n_usans:(0 1 2)' \
  '7:usan1 or output:_files' \
  '8:bt1:' \
  '9:usan2 or output:_files' \
  '10:bt2:' \
  '11:output:_files' && ret=0

return ret
