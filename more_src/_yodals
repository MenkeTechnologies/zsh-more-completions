#compdef yodals
# Documentation: https://yoda.hepforge.org/
# yodals - list the analysis objects in a YODA file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[print extra histogram details]' \
  '(-q --quiet)'{-q,--quiet}'[just print histogram details, no cosmetic filenames or blank lines]' \
  '(-m --match)'{-m,--match}'[only write histograms whose path matches this regex]:regex:' \
  '(-M --unmatch)'{-M,--unmatch}'[exclude histograms whose path matches this regex]:regex:' \
  '*:file:_files' && ret=0

return ret
