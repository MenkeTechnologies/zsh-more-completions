#compdef azuredisk-csi-driver azurediskplugin
# _azuredisk-csi-driver — Azure Disk CSI driver
# upstream: https://github.com/kubernetes-sigs/azuredisk-csi-driver
# Flags from pkg/azurediskplugin/main.go + pkg/azuredisk/azuredisk_option.go on tip.

_azuredisk-csi-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print the version and exit]' \
        '--metrics-address=[Prometheus metrics bind address]:addr:' \
        '--pre-stop-hook[run the pre-stop lifecycle hook and exit]' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--nodeid=[node id]:id:' \
        '--drivername=[name of the driver]:name:' \
        '--volume-attach-limit=[maximum number of attachable volumes per node]:n:' \
        '--reserved-data-disk-slot-num=[reserved data disk slots per node]:n:' \
        '--enable-perf-optimization[enable disk perf optimization]' \
        '--cloud-config-secret-name=[secret name of cloud config]:name:' \
        '--cloud-config-secret-namespace=[secret namespace of cloud config]:ns:' \
        '--custom-user-agent=[custom userAgent]:ua:' \
        '--user-agent-suffix=[userAgent suffix]:s:' \
        '--use-csiproxy-ga-interface=[enable csi-proxy GA interface on Windows]:bool:(true false)' \
        '--enable-otel-tracing[enable OpenTelemetry tracing]' \
        '--enable-minimum-retry-after=[enable minimum retry after policy]:bool:(true false)' \
        '--enable-disk-online-resize=[enable disk online resize]:bool:(true false)' \
        '--allow-empty-cloud-config=[allow running driver without cloud config]:bool:(true false)' \
        '--enable-list-volumes[enable ListVolumes on controller]' \
        '--enable-list-snapshots[enable ListSnapshots on controller]' \
        '--support-zone=[get zone info in NodeGetInfo]:bool:(true false)' \
        '--get-node-info-from-labels[get zone info from node labels in NodeGetInfo]' \
        '--enable-disk-capacity-check[enable volume capacity check in CreateVolume]' \
        '--enable-traffic-manager[enable traffic manager]' \
        '--traffic-manager-port=[default traffic manager port]:port:' \
        '--attach-detach-initial-delay-ms=[initial delay (ms) for batch attach/detach]:ms:' \
        '--vmss-cache-ttl-seconds=[VMSS cache TTL]:s:' \
        '--vm-type=[agent node type]:type:(vmss standard)' \
        '--enable-windows-host-process[run on Windows HostProcess container]' \
        '--use-win-cim-api=[use CIM API on Windows nodes]:bool:(true false)' \
        '--get-nodeid-from-imds[get NodeID from IMDS]' \
        '--wait-for-snapshot-ready[wait for snapshot ready when creating same-region snapshot]' \
        '--check-disk-lun-collision=[check disk LUN collision before attach]:bool:(true false)' \
        '--check-disk-count-for-batching=[check disk count before creating attach batch]:bool:(true false)' \
        '--force-detach-backoff=[force detach in backoff]:bool:(true false)' \
        '--wait-for-detach=[wait for detach before attaching disk on same node]:bool:(true false)' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_azuredisk-csi-driver "$@"
