#compdef 3dTORTOISEtoHere
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTORTOISEtoHere.html
# AFNI: convert a TORTOISE diffusion tensor into AFNI tensor format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-dt_tort[TORTOISE diffusion tensor file]:dtfile:_files' \
  '-scale_fac[scale factor for tensor values]:x:' \
  '-flip_x[flip x gradient component]' \
  '-flip_y[flip y gradient component]' \
  '-flip_z[flip z gradient component]' \
  '-prefix[output dataset prefix]:prefix:_files' \
  '*:dataset:_files' && ret=0

return ret
