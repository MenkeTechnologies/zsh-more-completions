#compdef smee
# _smee — Tinkerbell DHCP/iPXE/TFTP/HTTP/Syslog network boot server (tinkerbell/boots)
# upstream: https://github.com/tinkerbell/boots
# Flags from cmd/smee/flag.go on tip.

_smee() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--syslog-enabled=[enable syslog receiver]:bool:(true false)' \
        '--syslog-addr=[syslog bind IP]:ip:' \
        '--syslog-port=[syslog bind port]:port:' \
        '--tftp-enabled=[enable iPXE TFTP binary server]:bool:(true false)' \
        '--tftp-addr=[TFTP bind IP]:ip:' \
        '--tftp-port=[TFTP bind port]:port:' \
        '--tftp-timeout=[TFTP request timeout]:dur:' \
        '--tftp-block-size=[TFTP block size]:n:' \
        '--ipxe-script-patch=[iPXE script patch fragment]:patch:' \
        '--http-ipxe-binary-enabled=[enable iPXE HTTP binary server]:bool:(true false)' \
        '--http-ipxe-script-enabled=[enable iPXE HTTP script server]:bool:(true false)' \
        '--http-addr=[HTTP bind IP]:ip:' \
        '--http-port=[HTTP bind port]:port:' \
        '--extra-kernel-args=[extra kernel cmdline args]:args:' \
        '--trusted-proxies=[comma-sep trusted proxy CIDRs]:cidrs:' \
        '--osie-url=[HookOS OSIE images URL]:url:_urls' \
        '--tink-server=[Tink server host\:port]:host\:port:' \
        '--tink-server-tls=[use TLS for Tink server]:bool:(true false)' \
        '--tink-server-insecure-tls=[use insecure TLS for Tink server]:bool:(true false)' \
        '--ipxe-script-retries=[fetch retries in iPXE script]:n:' \
        '--ipxe-script-retry-delay=[delay between retries (s)]:n:' \
        '--dhcp-enabled=[enable DHCP server]:bool:(true false)' \
        '--dhcp-mode=[DHCP mode]:mode:(reservation proxy auto-proxy)' \
        '--dhcp-addr=[DHCP bind host\:port]:host\:port:' \
        '--dhcp-iface=[DHCP bind interface]:iface:_net_interfaces' \
        '--dhcp-ip-for-packet=[DHCP packet siaddr/opt54 IP]:ip:' \
        '--dhcp-syslog-ip=[Syslog server IP in DHCP opt 7]:ip:' \
        '--dhcp-tftp-ip=[TFTP server IP in DHCP opt 66]:ip:' \
        '--dhcp-tftp-port=[TFTP server port for DHCP opt]:port:'
}

_smee "$@"
