#compdef scaffoldly
# Documentation: https://scaffoldly.dev/docs/cli
# scaffoldly - deploy anything to AWS Lambda from a Dockerfile

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version number]' \
  '1:command:(show dev deploy)' \
  '*::arg:_files' && ret=0

return ret
