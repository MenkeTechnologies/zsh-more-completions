#compdef plumed-info
# Documentation: https://www.plumed.org/doc-v2.9/user-doc/html/info.html
# PLUMED info: print version and configuration information

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--configuration[print the configuration file]' \
  '--root[print the location of the root source directory]' \
  '--user-doc[print the location of the user manual (html)]' \
  '--developer-doc[print the location of the developer manual (html)]' \
  '--version[print the version number]' \
  '--long-version[print the version number (long version)]' \
  '--git-version[print the version number (git version, if available)]' \
  '--include-dir[print the location of the include dir]' \
  '--soext[print the extension of shared libraries (so or dylib)]' && ret=0

return ret
