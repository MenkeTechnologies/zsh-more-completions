#compdef kubectl-operator
# kubectl-operator (krew plugin): manage Kubernetes operators from OperatorHub
# https://github.com/operator-framework/kubectl-operator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'install:install an operator'
      'uninstall:uninstall an operator'
      'upgrade:upgrade an operator'
      'list:list installed operators'
      'list-available:list available operators from catalogs'
      'describe:describe an operator'
      'catalog:manage operator catalogs'
    )
    _describe -t commands 'kubectl-operator command' commands && ret=0
    ;;
  args)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
      '--context=[kubernetes context]:context' \
      '--kubeconfig=[path to kubeconfig]:file:_files' \
      '--channel=[subscription channel]:channel' \
      '--approval=[approval strategy]:approval:(Automatic Manual)' \
      '--version=[operator version]:version' \
      '--csv=[ClusterServiceVersion name]:csv' \
      '-X[cleanup all operator resources on uninstall]' \
      '--delete-all[delete all resources on uninstall]' \
      '--delete-crds[delete CRDs on uninstall]' \
      '--delete-operator-groups[delete operator groups on uninstall]' \
      '*:operator name' && ret=0
    ;;
esac

return ret
