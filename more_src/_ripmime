#compdef ripmime ripMIME

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '-V[show version]' \
  '-i+[input MIME file (- for stdin)]:file:_files' \
  '-d+[output directory]:dir:_files -/' \
  '-p+[prefix for nameless files]:prefix:' \
  '-e+[headers dump filename]:name:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '-q[quiet mode]' \
  '--verbose-contenttype[verbose content type]' \
  '--verbose-defects[summary of defects]' \
  '--verbose-mime[verbose mime parsing]' \
  '--debug[debug output]' \
  '--stdout[reporting to stdout]' \
  '--stderr[reporting to stderr]' \
  '--syslog[reporting to syslog]' \
  '--no-tnef[disable TNEF decoding]' \
  '--no-quotedprintable[disable QP decoding]' \
  '--no-uudecode[disable uudecoding]' \
  '--no-ole[disable OLE decoding]' \
  '--no-doublecr[disable double CR]' \
  '--no-mht[disable MHT decoding]' \
  '--no-paranoid[disable paranoid filename]' \
  '--paranoid[strict filename mode]' \
  '--name-by-type[name files by content type]' \
  '--no-nameless[skip nameless attachments]' \
  '--overwrite[overwrite existing]' \
  '--unique-names[generate unique names]' \
  '--prefix=[filename prefix]:prefix:' \
  '--mailbox[input is mailbox]' \
  '--recursion-max=[max recursion]:n:' \
  '--formdata[interpret as form data]' \
  '--exit-on-status[exit if any decoding fails]' \
  '--decode-headers[decode headers]' \
  '*:input file:_files' && ret=0

return ret
