#compdef jaspscan
# EMBOSS: scan DNA sequences for transcription factors

local ret=1

_arguments -s -S \
  '-sequence=[nucleotide sequence(s) USA]:sequence:_files' \
  '-menu=[JASPAR matrix set]:set:(C F P N O S B L H)' \
  '-matrices=[matrix files to read (or all)]:matrices' \
  '-threshold=[minimum match percentage to report a hit]:num' \
  '-outfile=[output report file name]:outfile:_files' \
  '-exclude=[names of matrices to exclude]:exclude' \
  '-both[search both forward and reverse strands]' \
  '-auto[turn off prompts]' \
  '-stdout[write first file to standard output]' \
  '-filter[read from stdin, write to stdout]' \
  '-options[prompt for standard and additional values]' \
  '-debug[write debug output]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-die[report dying program messages]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '-version[report version number and exit]' && ret=0

return ret
