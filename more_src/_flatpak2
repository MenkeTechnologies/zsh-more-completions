#compdef flatpak2
# _flatpak2 — Red Hat freedesktop Flatpak flatpak2 CLI command-line frontend wrapping the Flatpak open-source linux-only universal package distribution framework system for building distributing and running sandboxed desktop applications on Linux originally Alexander Larsson Red Hat now freedesktop.org technology for building packaging and distributing desktop apps sandbox-based Flathub install uninstall remove update upgrade list info search run kill ps override make-current enter info repair create-usb config repo build build-init build-finish build-export build-bundle build-import-bundle build-sign build-update-repo build-commit-from build-update-repo info config history mask permission-list permission-show permission-reset permission-set permissions remote-add remote-modify remote-delete remote-ls remote-info remote-info-show-help (Red Hat freedesktop Alexander Larsson team Bartłomiej Piotrowski, C); custom argparse
# upstream: https://flatpak.org/

_flatpak2() {
    local -a sub=(
        'install:install application'
        'remove:remove application'
        'uninstall:remove application'
        'update:update application'
        'upgrade:upgrade application'
        'list:list installed apps'
        'info:show app info'
        'search:search apps'
        'run:run an app'
        'kill:kill an app'
        'ps:show running apps'
        'enter:enter sandbox of running app'
        'override:set per-app overrides'
        'make-current:set current version'
        'repair:repair installation'
        'config:show config'
        'history:show history'
        'documents:list document portal'
        'document-export:export document'
        'document-unexport:unexport document'
        'document-info:show document info'
        'mask:mask packages'
        'pin:pin package'
        'permission-list:list permissions'
        'permission-show:show permissions'
        'permission-reset:reset permissions'
        'permission-set:set permissions'
        'permission-remove:remove permissions'
        'permissions:list permissions (alias)'
        'remote-add:add a remote'
        'remote-modify:modify a remote'
        'remote-delete:delete a remote'
        'remote-list:list remotes'
        'remote-ls:list refs in remote'
        'remote-info:show remote info'
        'remotes:list remotes (alias)'
        'create-usb:copy to USB'
        'build:build a sandbox'
        'build-init:initialize a build dir'
        'build-finish:finalize build'
        'build-export:export build to OSTree'
        'build-bundle:create bundle file'
        'build-import-bundle:import bundle file'
        'build-sign:sign build'
        'build-update-repo:update repo'
        'build-commit-from:commit ref from one repo to another'
        'help:show help'
        'version:show version'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--ostree-verbose[ostree verbose]' \
        '--gl-driver[GL driver]' \
        '--default-arch[default arch]' \
        '--supported-arches[supported arches]' \
        '--print-system-only[print system only]' \
        '--print-updated-env[print updated env]' \
        '--print-system-default-locale[print locale]' \
        '--user[user installation]' \
        '-u[user installation]' \
        '--system[system installation]' \
        '--installation=+[name]:str:' \
        '*--installation=+[name]:str:' \
        '--arch=+[a]:str:' \
        '--no-deps[no deps]' \
        '--no-related[no related]' \
        '--no-pull[no pull]' \
        '--no-deploy[no deploy]' \
        '--no-static-deltas[no static deltas]' \
        '--no-system-helper[no system helper]' \
        '--no-auto-pin[no auto pin]' \
        '--no-summary-index[no summary index]' \
        '--noninteractive[non interactive]' \
        '--app[app only]' \
        '--runtime[runtime only]' \
        '--all[all]' \
        '-a[all]' \
        '--bundle[install from bundle]' \
        '--from[install from ref]' \
        '--reinstall[reinstall]' \
        '--or-update[or update]' \
        '--include-debug[include debug]' \
        '--include-sdk[include SDK]' \
        '--branch=+[name]:str:' \
        '--commit=+[hash]:str:' \
        '--subpath=+[path]:str:' \
        '--unused[remove unused]' \
        '--force-remove[force remove]' \
        '--keep-ref[keep ref]' \
        '--delete-data[delete data]' \
        '--columns=+[cols]:str:' \
        '--show-details[show details]' \
        '-d[show details]' \
        '--show-disabled[show disabled]' \
        '--show-ref[show ref]' \
        '--show-commit[show commit]' \
        '--show-origin[show origin]' \
        '--show-size[show size]' \
        '--show-metadata[show metadata]' \
        '--show-permissions[show permissions]' \
        '--show-runtime[show runtime]' \
        '--show-sdk[show SDK]' \
        '--show-extensions[show extensions]' \
        '--show-location[show location]' \
        '-c+[command]:str:' \
        '--command=+[cmd]:str:' \
        '--cwd=+[dir]:str:' \
        '--env=+[k=v]:str:' \
        '*--env=+[k=v]:str:' \
        '--device=+[name]:str:' \
        '*--device=+[name]:str:' \
        '--filesystem=+[path]:str:' \
        '*--filesystem=+[path]:str:' \
        '--allow=+[feature]:str:' \
        '*--allow=+[feature]:str:' \
        '--disallow=+[feature]:str:' \
        '*--disallow=+[feature]:str:' \
        '--talk-name=+[name]:str:' \
        '*--talk-name=+[name]:str:' \
        '--system-talk-name=+[name]:str:' \
        '*--system-talk-name=+[name]:str:' \
        '--persist=+[path]:str:' \
        '*--persist=+[path]:str:' \
        '--share=+[feature]:str:' \
        '*--share=+[feature]:str:' \
        '--nofilesystem=+[path]:str:' \
        '*--nofilesystem=+[path]:str:' \
        '--unset-env=+[name]:str:' \
        '*--unset-env=+[name]:str:' \
        '--socket=+[socket]:str:' \
        '*--socket=+[socket]:str:' \
        '--nosocket=+[socket]:str:' \
        '*--nosocket=+[socket]:str:' \
        '--port=+[port]:n:' \
        '--remote=+[name]:str:' \
        '--app-path=+[dir]:dir:_files -/' \
        '--usr-path=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'flatpak subcommand' sub ;;
        args)
            case $words[1] in
                install|update|remove|uninstall|run|info|kill|enter|override|search|list|permissions|history) _arguments '*:application:' ;;
                remote-add|remote-modify|remote-delete|remote-info|remote-ls) _arguments '*:remote:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_flatpak2 "$@"
