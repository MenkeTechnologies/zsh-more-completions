#compdef git-secrets

# Zsh completion for git-secrets

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--scan[scan files for secrets]:*:files:_files' \
  '--scan-history[scan git history for secrets]' \
  '--install[install git hooks]:directory:_directories' \
  '--register-aws[register common AWS patterns]' \
  '--add[add a custom secret pattern]:pattern' \
  '--add-allowed[add an allowed pattern]:pattern' \
  '--add-provider[add a secret provider command]:provider command' \
  '--list[list registered patterns]' \
  '--aws-provider[run the default AWS provider]' \
  '-r[scan recursively]' \
  '--recursive[scan recursively]' \
  '-f[force overwrite of hooks]' \
  '--force[force overwrite of hooks]' \
  '--no-index[do not check staged files]' \
  '--cached[check staged files]' \
  '--untracked[check untracked files]' \
  '--allowed[list allowed patterns]' \
  '--global[use global git config]' && ret=0

return ret
