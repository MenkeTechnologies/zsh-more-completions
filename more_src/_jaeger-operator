#compdef jaeger-operator
# Documentation: https://man.archlinux.org/search?q=jaeger-operator
# Reference accessed: 2026-05-16

# jaeger-operator: Kubernetes operator for Jaeger
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'start:run operator'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--metrics-bind-address=[metrics bind addr]:addr:' \
  '--health-probe-bind-address=[health probe bind addr]:addr:' \
  '--leader-elect[enable leader election]' \
  '--zap-devel[zap dev mode]' \
  '--zap-encoder=[zap encoder]:enc:(console json)' \
  '--zap-log-level=[zap log level]:level:(debug info error)' \
  '--zap-stacktrace-level=[zap stacktrace level]:level:(info error panic)' \
  '--zap-time-encoding=[zap time encoding]:enc:(epoch iso8601 millis nanos rfc3339 rfc3339nano)' \
  '--zap-message-key=[zap message key]:key:' \
  '--openshift-create-dashboard[create OpenShift dashboard]' \
  '--watch-namespace=[watch namespace]:ns:' \
  '--platform=[platform]:platform:(kubernetes openshift)' \
  '--es-provision=[ES provisioning]:val:(true false auto)' \
  '--kafka-provision=[Kafka provisioning]:val:(true false auto)' \
  '--cassandra-provision=[Cassandra provisioning]:val:(true false auto)' \
  '--tracing-enabled[enable operator tracing]' \
  '--profiler-port=[profiler port]:port:' \
  '--feature-gates=[feature gates]:gates:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'jaeger-operator command' commands && ret=0 ;;
esac
return ret
