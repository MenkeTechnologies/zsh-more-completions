#compdef jaeger-operator
# Documentation: https://github.com/jaegertracing/jaeger-operator/blob/main/pkg/cmd/start/main.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jaeger-operator: Kubernetes operator for Jaeger. Subcommands are
# generate, start, version (added generate). Flags below are the real
# `start` flags from upstream source; removed fabricated --zap-* /
# --metrics-bind-address / --cassandra-provision / --profiler-port /
# --feature-gates / --watch-namespace / --openshift-create-dashboard.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'generate:generate a Kubernetes manifest from a Jaeger CR'
  'start:start the operator'
  'version:print the operator version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--log-level=[operator log level]:level:(trace debug info warning error fatal panic)' \
  '--platform=[target platform]:platform:(kubernetes openshift auto-detect)' \
  '--es-provision=[auto-provision Elasticsearch]:val:(yes no auto)' \
  '--kafka-provision=[auto-provision Kafka]:val:(yes no auto)' \
  '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
  '--webhook-bind-port=[webhook server port]:port:' \
  '--leader-elect[enable leader election for the controller manager]' \
  '--tracing-enabled[report the operator own spans to a Jaeger instance]' \
  '--metrics-host=[host to bind the metrics port]:host:' \
  '--metrics-port=[metrics port]:port:' \
  '--jaeger-agent-hostport=[location of the Jaeger Agent]:addr:' \
  '--documentation-url=[URL for the Documentation menu item]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'jaeger-operator command' commands && ret=0 ;;
esac
return ret
