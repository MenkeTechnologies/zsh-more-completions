#compdef tcpstates tcpstates-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/tcpstates.py argparse)
# Reference accessed: 2026-05-29
# tcpstates — trace TCP session state transitions and durations (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-T --time)'{-T,--time}'[include time column on output (HH\:MM\:SS)]' \
  '(-t --timestamp)'{-t,--timestamp}'[include timestamp on output (seconds)]' \
  '(-w --wide)'{-w,--wide}'[wide column output (fits IPv6 addresses)]' \
  '(-s --csv)'{-s,--csv}'[comma separated values output]' \
  '(-L --localport)'{-L,--localport=}'[comma-separated list of local ports to trace]:ports:' \
  '(-D --remoteport)'{-D,--remoteport=}'[comma-separated list of remote ports to trace]:ports:' \
  '(-Y --journal)'{-Y,--journal}'[log session state changes to the systemd journal]' \
  '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[trace IPv4 family only]' \
  '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[trace IPv6 family only]' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
