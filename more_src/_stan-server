#compdef stan-server nats-streaming-server
# Documentation: https://github.com/nats-io/nats-streaming-server/blob/main/nats-streaming-server.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# nats-streaming-server: NATS Streaming server (deprecated; superseded by JetStream)

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help_tls[show TLS help]' \
  {-cid,--cluster_id=}'[cluster ID (default test-cluster)]:id:' \
  {-st,--store=}'[store type]:type:(MEMORY FILE SQL)' \
  '--dir=[FILE store root directory]:dir:_files -/' \
  {-mc,--max_channels=}'[max channels (0 unlimited)]:n:' \
  {-msu,--max_subs=}'[max subscriptions per channel]:n:' \
  {-mm,--max_msgs=}'[max messages per channel]:n:' \
  {-mb,--max_bytes=}'[max bytes per channel]:size:' \
  {-ma,--max_age=}'[max message age]:duration:' \
  {-mi,--max_inactivity=}'[channel garbage-collect inactivity]:duration:' \
  {-ns,--nats_server=}'[external NATS Server URL]:url:' \
  {-sc,--stan_config=}'[streaming server config file]:file:_files' \
  {-hbi,--hb_interval=}'[heartbeat interval]:duration:' \
  {-hbt,--hb_timeout=}'[heartbeat response timeout]:duration:' \
  {-hbf,--hb_fail_count=}'[failed heartbeats before close]:n:' \
  '--ft_group=[FT group name]:name:' \
  {-sl,--signal=}'[signal embedded NATS Server]:sig:(stop quit reopen reload)' \
  '--encrypt=[encryption at rest]:bool:(true false)' \
  '--encryption_cipher=[encryption cipher]:cipher:(AES CHAHA)' \
  '--encryption_key=[encryption key (prefer env var)]:key:' \
  '--replace_durable=[replace existing durable subscription]:bool:(true false)' \
  '--clustered=[run clustered]:bool:(true false)' \
  '--cluster_node_id=[node id in cluster]:id:' \
  '--cluster_bootstrap=[bootstrap cluster]:bool:(true false)' \
  '--cluster_peers=[comma list of peer node IDs]:peers:' \
  '--cluster_log_path=[log replication data dir]:dir:_files -/' \
  '--cluster_log_cache_size=[in-memory log entry cache]:n:' \
  '--cluster_log_snapshots=[log snapshots to retain]:n:' \
  '--cluster_trailing_logs=[log entries after snapshot]:n:' \
  '--cluster_sync=[fsync after every replication write]:bool:(true false)' \
  '--cluster_raft_logging=[enable Raft logging]:bool:(true false)' \
  '--cluster_allow_add_remove_node=[allow add/remove cluster nodes via NATS]:bool:(true false)' \
  '--file_compact_enabled=[enable file compaction]:bool:(true false)' \
  '--file_compact_frag=[fragmentation threshold]:n:' \
  '--file_compact_interval=[min seconds between compactions]:n:' \
  '--file_compact_min_size=[min file size for compaction]:size:' \
  '--file_buffer_size=[file buffer size bytes]:size:' \
  '--file_crc=[enable CRC-32]:bool:(true false)' \
  '--file_crc_poly=[CRC-32 polynomial]:n:' \
  '--file_sync=[fsync on flush]:bool:(true false)' \
  '--file_slice_max_msgs=[max messages per file slice]:n:' \
  '--file_slice_max_bytes=[max file slice size]:size:' \
  '--file_slice_max_age=[max file slice duration]:duration:' \
  '--file_slice_archive_script=[archive script path]:file:_files' \
  '--file_fds_limit=[max file descriptors]:n:' \
  '--file_parallel_recovery=[parallel channel recovery on startup]:n:' \
  '--file_truncate_bad_eof=[truncate files with unexpected EOF]:bool:(true false)' \
  '--file_read_buffer_size=[read-ahead buffer]:size:' \
  '--file_auto_sync=[auto flush+sync interval]:duration:' \
  '--sql_driver=[SQL driver name]:driver:(mysql postgres)' \
  '--sql_source=[SQL datasource]:dsn:' \
  '--sql_no_caching=[disable caching]:bool:(true false)' \
  '--sql_max_open_conns=[max open SQL conns]:n:' \
  '--sql_bulk_insert_limit=[max msgs per bulk INSERT]:n:' \
  '-secure=[use TLS without verification]:bool:(true false)' \
  '-tls_client_key=[client key]:file:_files' \
  '-tls_client_cert=[client cert]:file:_files' \
  '-tls_client_cacert=[client cert CA]:file:_files' \
  {-SD,--stan_debug=}'[STAN debug output]:bool:(true false)' \
  {-SV,--stan_trace=}'[trace raw STAN protocol]:bool:(true false)' \
  '-SDV[STAN debug and trace]' \
  '--syslog_name=[Windows event source name]:name:' \
  {-a,--addr=}'[bind host address]:addr:' \
  {-p,--port=}'[client port (default 4222)]:port:' \
  {-P,--pid=}'[PID file]:file:_files' \
  {-m,--http_port=}'[HTTP monitoring port]:port:' \
  {-ms,--https_port=}'[HTTPS monitoring port]:port:' \
  {-c,--config=}'[NATS configuration file]:file:_files' \
  {-l,--log=}'[log output file]:file:_files' \
  {-T,--logtime=}'[timestamp log entries]:bool:(true false)' \
  {-s,--syslog=}'[enable syslog]:bool:(true false)' \
  {-r,--remote_syslog=}'[remote syslog addr]:addr:' \
  {-D,--debug=}'[enable debugging output]:bool:(true false)' \
  {-V,--trace=}'[trace raw protocol]:bool:(true false)' \
  '-DV[debug and trace]' \
  '--user=[user for connections]:user:' \
  '--pass=[password for connections]:pass:' \
  '--auth=[authorization token]:token:' \
  '--tls=[enable TLS]:bool:(true false)' \
  '--tlscert=[server certificate file]:file:_files' \
  '--tlskey=[server certificate key]:file:_files' \
  '--tlsverify=[TLS verify client certs]:bool:(true false)' \
  '--tlscacert=[client cert CA]:file:_files' \
  '--routes=[routes to solicit]:routes:' \
  '--cluster=[cluster URL for solicited routes]:url:' && ret=0
return ret
