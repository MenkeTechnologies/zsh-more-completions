#compdef pulsar-shell

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-c+,--config-file=}'[shell config file]:file:_files' \
  {-e+,--execute-command=}'[execute command and exit]:command:' \
  {-f+,--filename=}'[execute commands from file]:file:_files' \
  '--fail-on-error[exit on first error in batch mode]' \
  '--no-progress[disable progress display]' \
  '*:command:' && ret=0

return ret
