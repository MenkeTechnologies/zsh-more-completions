#compdef pulsar-shell
# Documentation: https://pulsar.apache.org/docs/next/administration-pulsar-shell/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-e+[execute one or more inline commands]:command:' \
  '-f+[execute commands from file]:file:_files' \
  '--fail-on-error[exit on first command failure]' \
  '*:command:' && ret=0

return ret
