#compdef cget
# Documentation: https://cget.readthedocs.io/en/latest/src/commands.html
# CMake package retrieval and installation tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --prefix)'{-p,--prefix=}'[set prefix where packages are installed]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[activate verbose logging output]' \
  '(-B --build-path)'{-B,--build-path=}'[build directory location for compilation]:dir:_files -/' \
  '*'{-D,--define=}'[pass an additional configuration variable to CMake]:var=value:' \
  '(-y --yes)'{-y,--yes}'[affirm all questions automatically]' \
  '(-G --generator)'{-G,--generator=}'[designate the CMake generator to use]:generator:' \
  '1:command:((
    init\:"initialize the cmake toolchain"
    install\:"configure, build and install a package"
    build\:"build a package without installing it"
    ignore\:"mark a package as already installed"
    remove\:"uninstall a package and its dependents"
    list\:"display all installed packages"
    clean\:"clear the directory used by cget"
    pkg-config\:"run pkg-config searching the cget directory"
  ))' \
  '*::arg:->args' && ret=0

return ret
