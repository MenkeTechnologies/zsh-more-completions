#compdef git-of-theseus-analyze git-of-theseus-line-plot git-of-theseus-stack-plot git-of-theseus-survival-plot
# Documentation: source-direct extraction from upstream
# erikbern/git-of-theseus git_of_theseus/{analyze,line_plot,
# stack_plot,survival_plot}.py argparse `parser.add_argument(...)`
# calls + setup.py `entry_points` console_scripts mapping
# (`git-of-theseus-analyze` -> `git_of_theseus.analyze:analyze_cmdline`,
# and 3 plot variants from `git_of_theseus:{line,stack,survival}_plot_cmdline`).
# Reference accessed: 2026-05-30 via gh api.
# Erik Bernhardsson git-of-theseus R136a — 4-stem multi-binary
# harvest of the git-of-theseus repo code-survival analysis suite.
# The toolset measures how much of a repo's code has survived from
# each cohort (year/quarter/etc.) of contributors, popularized by
# Bernhardsson's "The half-life of code" blog post. Pipeline is
# analyze -> JSON files -> plot.

# 2-flag pair shared by all 3 plotter binaries.
local -a _theseus_plot_common
_theseus_plot_common=(
  '--display[show plot interactively instead of writing to file]'
  '--outfile=[output image file (default <name>_plot.png)]:file:_files'
)

case $service in

  git-of-theseus-analyze)
    # Analyze a git repo's blame history into cohort JSON files.
    # The 11-flag analyzer is the most opinionated stage of the
    # pipeline; the plotters operate on its JSON output.
    _arguments -s -S \
      '--cohortfm=[Python datetime format string for cohort labels (default %Y)]:fmt:' \
      '--interval=[min seconds between commits to sample (default 604800=1week)]:sec:' \
      '*--ignore=[file glob to exclude (repeatable; each subtracts independently)]:glob:' \
      '*--only=[file glob to include (repeatable; if any provided, every file must match at least one)]:glob:' \
      '--outdir=[output directory for JSON results (default .)]:dir:_directories' \
      '--branch=[branch to track (default master)]:branch:' \
      '--ignore-whitespace[ignore whitespace changes when running git blame]' \
      '--all-filetypes[include all files (default: only common code filetypes)]' \
      '--quiet[disable all console output]' \
      '--procs=[number of parallel processes (default 2)]:n:' \
      '--opt[generate git commit-graph for performance (~80KB/kCommit disk overhead)]' \
      '1:repo directory:_directories'
    ;;

  git-of-theseus-line-plot)
    _arguments -s -S \
      "${_theseus_plot_common[@]}" \
      '--max-n=[max number of dataseries in legend (default 20)]:n:' \
      '--normalize[plot share of each as percentages summing to 100%]' \
      '1:input JSON file:_files -g "*.json"'
    ;;

  git-of-theseus-stack-plot)
    _arguments -s -S \
      "${_theseus_plot_common[@]}" \
      '--max-n=[max number of dataseries (default 20; remainder bucketed as "other")]:n:' \
      '--normalize[normalize the plot to 100%]' \
      '1:input JSON file:_files -g "*.json"'
    ;;

  git-of-theseus-survival-plot)
    _arguments -s -S \
      "${_theseus_plot_common[@]}" \
      '--exp-fit[overlay an exponential-decay best-fit curve]' \
      '--years=[number of years on x axis (default 5)]:years:' \
      '*:input JSON file(s):_files -g "*.json"'
    ;;

esac
