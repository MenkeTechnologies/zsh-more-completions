# -----------------------------------------------------------------------------
#
# WHY serde_yaml IS THE 75TH RUST CLI LIBRARY
#
# serde_yaml is the dominant Rust YAML library — even after
# David Tolnay archived it in March 2024.  The installed base
# is so large that successor libraries (serde-yml, serde-yaml-
# bw, saphyr) have not yet displaced it.  Distinct from every
# other Rust library in this taxonomy by being a YAML
# serializer + deserializer with serde framework integration.
#
# Five distinguishing characteristics:
#
#   1. SERDE INTEGRATION — serde_yaml is a #[derive(Serialize,
#      Deserialize)]-friendly YAML implementation.  The same
#      Rust structs used for JSON / TOML / MessagePack work
#      with YAML without changes:
#         use serde::{Serialize, Deserialize};
#         #[derive(Serialize, Deserialize, Debug)]
#         struct Pod {
#             api_version: String,
#             kind: String,
#             metadata: Metadata,
#         }
#         let pod: Pod = serde_yaml::from_str(yaml)?;
#      This is the central differentiator from yaml-rust
#      (which provides raw YAML access without serde) and
#      hands-rolled YAML parsers.
#
#   2. YAML 1.2 + 1.1 SUPPORT — serde_yaml handles the YAML
#      1.2 spec (current standard) plus most YAML 1.1
#      documents.  Distinct from libraries targeting only 1.1
#      (some older C / C++ implementations).
#
#   3. DOCUMENT-STREAM SUPPORT — multiple YAML documents in
#      one file (separated by `---`) parse as a stream;
#      essential for Kubernetes manifest files containing
#      multiple resources.
#
#   4. ANCHOR + ALIAS PRESERVATION — YAML's &anchor / *alias
#      mechanism preserves shared subtrees in parsed values;
#      serde_yaml round-trips these correctly.
#
#   5. DAVID-TOLNAY / dtolnay ECOSYSTEM PROVENANCE — distinct
#      from Sean McArthur (Hyperium), Sindre Sorhus (Node
#      utils), Mathew Roy (go-resty), Armin Ronacher
#      (console-rs).  David Tolnay's serde family is the
#      foundational Rust serialization ecosystem.
#
# -----------------------------------------------------------------------------
#
# THE cherrybomb CLI — clap derive + serde_yaml + tokio + reqwest
#
# cherrybomb's CLI is in src/options.rs.  Uses clap v4 derive
# with #[derive(Parser)] Options + #[derive(Subcommand)] Commands.
#
# Flags:
#   -v, --verbosity LEVEL   level of verbosity (enum)
#   -f, --file PATH         input OpenAPI/Swagger file (required
#                           unless --config specified)
#   -o, --output PATH       output file (default stdout)
#       --format FORMAT     output format: Json | Table (default Table)
#   -q, --quiet             disable console output
#   -c, --config PATH       config file (.json or .yaml; required
#                           unless --file specified)
#   -p, --profile PROFILE   audit profile to use (enum)
#       --server URL        override OAS servers with this URL
#   -i, --ignore-tls-errors BOOL
#                           ignore TLS errors
#       --no-telemetry      disable anonymous usage stats
#       --no-color          disable color output
#   -h, --help              show help
#   -V, --version           show version
#
# Subcommands:
#   auth                    define authentication for testing
#                           authenticated endpoints
#
# serde_yaml is used in src/main.rs's open_config_file to parse
# YAML-format config files (alongside serde_json for JSON
# configs).  cherrybomb-engine internally uses serde_yaml for
# OAS document parsing when the document is YAML-format.
#
# Five-axis distinctness from all previously-documented Rust
# libraries:
#
#   1. YAML I/O ABSTRACTION — serde_yaml parses YAML; distinct
#      from JSON (serde_json), TOML (toml), or other formats.
#
#   2. SERDE INTEGRATION — same #[derive(Serialize,
#      Deserialize)] structs work for YAML, JSON, TOML, etc.
#
#   3. DOCUMENT-STREAM SUPPORT — multi-document YAML files.
#
#   4. ANCHOR + ALIAS PRESERVATION — YAML's shared-subtree
#      mechanism preserved.
#
#   5. DAVID-TOLNAY / dtolnay / serde ECOSYSTEM PROVENANCE —
#      foundational Rust serialization maintainer.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/blst-security/cherrybomb/blob/main/src/options.rs
# clap v4 derive #[arg] attributes.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _cherrybomb_cmds _cherrybomb_formats _cherrybomb_verbosity _cherrybomb_profile
_cherrybomb_cmds=(
    'auth:Authentication definition for testing authenticated endpoints'
    'help:show help for a subcommand'
)
_cherrybomb_formats=(
    'Json:JSON output'
    'Table:terminal-formatted table (default)'
)
_cherrybomb_verbosity=(
    'silent:no console output'
    'normal:default output'
    'verbose:detailed output'
    'debug:debug-level output'
)
_cherrybomb_profile=(
    'info:informational checks only'
    'normal:standard audit profile'
    'strict:strict security profile'
)

_arguments -C \
    '(-v --verbosity)'{-v+,--verbosity=}'[level of verbosity]:level:->verbosity' \
    '(-f --file)'{-f+,--file=}'[input OpenAPI/Swagger file]:file:_files -g "*.(yaml|yml|json)"' \
    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
    '--format=[output format]:format:->format' \
    '(-q --quiet)'{-q,--quiet}'[disable console output]' \
    '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.(yaml|yml|json)"' \
    '(-p --profile)'{-p+,--profile=}'[audit profile to use]:profile:->profile' \
    '--server=[override OAS servers with this URL]:url:_default' \
    '(-i --ignore-tls-errors)'{-i+,--ignore-tls-errors=}'[ignore TLS errors]:enabled:(true false)' \
    '--no-telemetry[disable anonymous usage stats]' \
    '--no-color[disable color output]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    verbosity) _describe -t levels 'verbosity level' _cherrybomb_verbosity && ret=0 ;;
    format)    _describe -t formats 'output format' _cherrybomb_formats && ret=0 ;;
    profile)   _describe -t profiles 'audit profile' _cherrybomb_profile && ret=0 ;;
    cmd)
        _describe -t commands 'cherrybomb subcommand' _cherrybomb_cmds && ret=0
        ;;
esac

return ret
