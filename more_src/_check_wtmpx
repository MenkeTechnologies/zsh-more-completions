#compdef check_wtmpx
# Documentation: check_wtmpx (chkrootkit helper)
# Source: scan wtmpx for deleted-entry signs (Solaris-style wtmpx file).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:wtmpx file:_files' \
    && ret=0

return ret
