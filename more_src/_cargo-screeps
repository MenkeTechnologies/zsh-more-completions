#compdef cargo-screeps
# Documentation: https://github.com/rustyscreeps/cargo-screeps
# Build tool for deploying Rust WASM code to Screeps game servers

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --mode)'{-m,--mode}'=[deployment mode]:mode' \
  '*::command:->cmd' && ret=0

case $state in
  cmd)
    _values 'cargo-screeps subcommand' \
      'build[compile Rust source with wasm-pack]' \
      'deploy[run the deployment mode]' \
      'upload[shortcut for deploy -m upload]' \
      'copy[shortcut for deploy -m copy]' && ret=0
    ;;
esac

return ret
