#compdef db_printlog
# Documentation: db_printlog usage (Berkeley DB 18.1.40)
# Source: print Berkeley DB log file contents in human-readable form.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-N[silent: do not acquire DB env lock]' \
    '-r[reverse log order]' \
    '-b+[start log file/offset]:file/offset:' \
    '-D+[max data length]:bytes:' \
    '-e+[end log file/offset]:file/offset:' \
    '-h+[environment home]:dir:_files -/' \
    '-P+[password]:password:' \
    && ret=0

return ret
