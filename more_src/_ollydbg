#compdef ollydbg
# _ollydbg — OllyDbg 32-bit Windows assembler-level debugger (Oleh Yuschuk); classic ring-3 Windows debugger
# upstream: https://www.ollydbg.de

_ollydbg() {
    _arguments \
        '-P+[attach PID]:pid:_pids' \
        '-C+[command]:cmd:' \
        '-D[debug]' \
        '-Y[no UI prompts]' \
        '*:executable:_files'
}

_ollydbg "$@"
