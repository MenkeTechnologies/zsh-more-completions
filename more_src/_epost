#compdef epost
# Documentation: https://www.ncbi.nlm.nih.gov/books/NBK179288/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# NCBI EDirect epost: post a set of accessions/UIDs to Entrez history server
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-db=[database name]:db:(pubmed protein nucleotide gene structure pmc taxonomy snp dbvar)' \
  '-id=[comma-separated UID/accession list]:list:' \
  '-input=[file containing UIDs (one per line)]:file:_files' \
  '-format=[input format]:format:(acc id pmid)' \
  '-label=[label for this query for #N reference]:label:' \
  '-WebEnv=[reuse existing WebEnv]:env:' \
  '*::ids:' && ret=0
return ret
