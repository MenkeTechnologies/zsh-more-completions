#compdef spin

local -a _spin_commands
_spin_commands=(
  'add:add a component to an application'
  'build:build the Spin application'
  'cloud:commands for Fermyon Cloud'
  'deploy:deploy a Spin application'
  'doctor:detect problems with application'
  'help:print help information'
  'login:log in to a server'
  'new:scaffold a new application'
  'plugins:manage plugins'
  'registry:commands for OCI registries'
  'templates:manage templates'
  'up:start the Spin application'
  'watch:build and run on file changes'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'spin commands' _spin_commands
    ;;
  args)
    case "$words[1]" in
      new)
        _arguments \
          '--accept-defaults[accept default values]' \
          '(-o --output)'{-o,--output}'[output directory]:dir:_directories' \
          '(-t --template)'{-t,--template}'[template name]:template' \
          '--tag[template tag]:tag' \
          '--value[template value key=val]:value' \
          '*:name'
        ;;
      up)
        _arguments \
          '(-f --from)'{-f,--from}'[application manifest]:file:_files' \
          '--listen[listen address]:address' \
          '(-e --env)'{-e,--env}'[environment variable key=val]:env' \
          '--runtime-config-file[runtime config file]:file:_files' \
          '--state-dir[state directory]:dir:_directories' \
          '--direct-mounts[use direct mounts]' \
          '--temp[use temp directory for mounts]' \
          '--follow[follow logs]' \
          '--quiet[suppress output]' \
          '-L[log directory]:dir:_directories' \
          '--sqlite[SQLite database]:db' \
          '--key-value[key-value store]:store'
        ;;
      build)
        _arguments \
          '(-f --from)'{-f,--from}'[application manifest]:file:_files' \
          '(-u --up)'{-u,--up}'[run after build]' \
          '--component-id[build only this component]:component'
        ;;
      deploy)
        _arguments \
          '(-f --from)'{-f,--from}'[application manifest]:file:_files' \
          '--buildinfo[build metadata]:metadata' \
          '(-e --env)'{-e,--env}'[environment variable key=val]:env' \
          '--key-value[key-value pair]:pair' \
          '--variable[variable key=val]:var' \
          '--readiness-timeout[readiness timeout]:seconds' \
          '--no-buildinfo[skip build metadata]' \
          '--staging[deploy to staging]'
        ;;
      add)
        _arguments \
          '(-f --from)'{-f,--from}'[application manifest]:file:_files' \
          '(-t --template)'{-t,--template}'[template name]:template' \
          '--accept-defaults[accept default values]' \
          '--value[template value key=val]:value' \
          '--tag[template tag]:tag' \
          '*:name'
        ;;
      cloud)
        _arguments '1:subcommand:(apps deploy login logout sqlite variables link unlink)' '*:args'
        ;;
      plugins)
        _arguments '1:subcommand:(install list search uninstall update upgrade)' '*:args'
        ;;
      templates)
        _arguments '1:subcommand:(install list uninstall upgrade)' '*:args'
        ;;
      registry)
        _arguments '1:subcommand:(login pull push)' '*:args'
        ;;
      watch)
        _arguments \
          '(-f --from)'{-f,--from}'[application manifest]:file:_files' \
          '--listen[listen address]:address' \
          '(-e --env)'{-e,--env}'[environment variable key=val]:env' \
          '--skip-build[skip build step]' \
          '-c[clear terminal on rebuild]'
        ;;
      login)
        _arguments \
          '--url[server URL]:url' \
          '--token[auth token]:token' \
          '--username[username]:user' \
          '--password[password]:password' \
          '--status[show login status]' \
          '--list[list saved logins]'
        ;;
    esac
    ;;
esac
