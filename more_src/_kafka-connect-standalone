#compdef kafka-connect-standalone kafka-connect-standalone.sh connect-standalone
# _kafka-connect-standalone — Apache Kafka kafka-connect-standalone Kafka Connect standalone worker CLI for running source and sink connectors in single-JVM mode storing offsets to local file with one or more connector properties (apache team, Java); JCommander
# upstream: https://kafka.apache.org/

_kafka-connect-standalone() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-daemon[run as daemon]' \
        '--daemon[run as daemon]' \
        '-loggc[enable GC log]' \
        '--loggc[enable GC log]' \
        '--name=+[name]:str:' \
        '--logging-options=+[opt]:str:' \
        '*:worker and connector properties:_files -g "*.properties connect-standalone.properties"'
}

_kafka-connect-standalone "$@"
