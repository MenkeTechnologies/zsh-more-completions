#compdef quint
# Documentation: https://man.archlinux.org/search?q=quint
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--out=[Emit outputs to directory]:directory:_directories' \
  '--invariant=[Name invariant to check in repl]:name:' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'repl:Start the Quint proof assistant REPL'
      'run:Evaluate a Quint specification'
      'test:Execute Quint tests'
      'compile:Translate Quint to other targets'
      'typecheck:Typecheck without executing'
      'docs:Render built-in documentation'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
