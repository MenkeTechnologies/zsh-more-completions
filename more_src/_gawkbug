#compdef gawkbug
# Documentation: https://man.archlinux.org/search?q=gawkbug
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1::bug-report email address:_email_addresses' && ret=0

return ret
