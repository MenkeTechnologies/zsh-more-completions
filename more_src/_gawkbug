#compdef gawkbug
# Documentation: https://manpages.ubuntu.com/manpages/resolute/man1/gawkbug.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1::bug-report email address:_email_addresses' && ret=0

return ret
