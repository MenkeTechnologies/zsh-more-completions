(( $+functions[_dek_commands] )) ||
_dek_commands() {
    local commands; commands=(
'apply:Apply configuration (all or specific configs)' \
'check:Check what would change (dry-run)' \
'plan:List items from config (no state check)' \
'run:Run a command from config (no name = list commands)' \
'test:Spin up container, apply config, drop into shell' \
'exec:Run a command in the test container' \
'bake:Bake config into standalone binary' \
'state:Query system state probes' \
'completions:Generate shell completions (raw output)' \
'setup:Install dek completions for your shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'dek commands' commands "$@"
}
