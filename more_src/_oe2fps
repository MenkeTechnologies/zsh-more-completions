#compdef oe2fps
# Documentation: https://chemfp.readthedocs.io/en/latest/tools.html
# chemfp fingerprint generator using the OpenEye toolkit

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--id-tag=[identifier SD field]:tag:' \
  '-o+[output filename]:file:_files' \
  '--maccs166[create MACCS 166-bit fingerprints]' \
  '--rdmaccs[generate RDMACCS fingerprints]' \
  '--using=[reference fingerprint type from file]:file:_files' \
  '--no-progress[disable progress display]' \
  '*:structure file:_files' && ret=0

return ret
