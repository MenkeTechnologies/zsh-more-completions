#compdef 3dDiff
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dDiff.html
# Report differences between two datasets

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-tol[floating-point tolerance for comparing values]:tol:' \
  '-mask[mask to limit which regions are compared]:dataset:_files' \
  '-a[first input dataset]:dataset:_files' \
  '-b[second input dataset]:dataset:_files' \
  '-q[quiet mode: 0 no differences, 1 differences]' \
  '-tabular[display results as a table of differences]' \
  '-brutalist[display one-liner with four numeric values]' \
  '-long_report[generate comprehensive detailed report]' \
  '*:dataset:_files' && ret=0

return ret
