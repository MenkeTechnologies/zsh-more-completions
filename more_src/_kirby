#compdef kirby
# _kirby — Kirby CMS command-line interface (getkirby/cli)
# upstream: https://github.com/getkirby/cli
# Subcommands from commands/*.php.

_kirby() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_kirby_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                clean)
                    _arguments '1:target:(content)'
                    ;;
                install)
                    _arguments '1:install target:(kit repo)'
                    ;;
                make)
                    _arguments '1:make target:(blueprint collection command config controller language model plugin snippet template user)'
                    ;;
                plugin)
                    _arguments '1:plugin action:(install remove upgrade)'
                    ;;
                uuid)
                    _arguments '1:uuid action:(generate populate remove)'
                    ;;
                migrate)
                    _arguments '1:migrate target:(content)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kirby_commands] )) ||
_kirby_commands() {
    local -a commands
    commands=(
        'backup:create a backup of application files'
        'clean:clean content / cache (clean content)'
        'clear:clear caches'
        'download:download a Kirby kit'
        'help:show help for a command'
        'install:install kirby kit or repo'
        'license:license commands (register / unregister)'
        'make:scaffold blueprints / templates / snippets / plugins / etc.'
        'migrate:run a content migration'
        'plugin:install / remove / upgrade Kirby plugins'
        'register:register a Kirby license'
        'remove:remove a Kirby resource'
        'roots:show resolved Kirby root paths'
        'security:run a security check'
        'unzip:unzip a Kirby download'
        'upgrade:upgrade the current Kirby install'
        'uuid:generate / populate / remove content UUIDs'
        'version:show the installed Kirby version'
    )
    _describe -t commands 'kirby command' commands
}

_kirby "$@"
