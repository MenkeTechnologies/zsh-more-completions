#compdef luac-5.5
# Documentation: https://man.archlinux.org/search?q=luac-5.5
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-l[list bytecode (use -l -l for full listing)]' \
  '-o+[output to file (default luac.out)]:file:_files' \
  '-p[parse only]' \
  '-s[strip debug information]' \
  '-v[show version information]' \
  '*:source file:_files -g "*.lua"' && ret=0

return ret
