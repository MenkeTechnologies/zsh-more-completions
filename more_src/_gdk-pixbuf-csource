#compdef gdk-pixbuf-csource
# Documentation: gdk-pixbuf-csource --help (GdkPixbuf)
# Source: emit C source / GdkPixdata for an image (gdk-pixbuf-2.0).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(--struct --macros)--stream[generate pixbuf data stream]' \
    '(--stream --macros)--struct[generate GdkPixdata structure]' \
    '(--stream --struct)--macros[generate image size/pixel macros]' \
    '(--raw)--rle[use one byte run-length-encoding]' \
    '(--rle)--raw[provide raw image data copy]' \
    '--extern[generate extern symbols]' \
    '--static[generate static symbols]' \
    '--decoder[provide rle decoder]' \
    '--name=[C macro/variable name]:identifier:' \
    '--build-list[parse (name, image) pairs]' \
    '--g-fatal-warnings[make warnings fatal]' \
    '*:image:_files' \
    && ret=0

return ret
