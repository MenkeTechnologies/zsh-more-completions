#compdef cachix

# Zsh completion for cachix (Nix binary cache hosting)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'authtoken:set auth token'
      'config:manage configuration'
      'daemon:run as a daemon'
      'deploy:deploy a Cachix agent'
      'generate-keypair:generate a signing key pair'
      'import:import narinfo from S3'
      'pin:pin a store path'
      'push:push store paths to a cache'
      'remove:remove a store path from cache'
      'use:configure Nix to use a cache'
      'watch-exec:push paths produced by a command'
      'watch-store:push all new store paths'
    )
    _describe -t commands 'cachix command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (authtoken)
        _arguments '1:token' && ret=0
        ;;
      (push)
        _arguments \
          '(-j --jobs)'{-j,--jobs}'[number of parallel uploads]:jobs' \
          '--compression-level[compression level]:level:(1 2 3 4 5 6 7 8 9)' \
          '--compression-method[compression method]:method:(xz zstd)' \
          '--omit-deriver[omit deriver info]' \
          '1:cache name' \
          '*:store path:_files' && ret=0
        ;;
      (use)
        _arguments \
          '(-m --mode)'{-m,--mode}'[integration mode]:mode:(nixos user-nixconf)' \
          '-O[output directory]:dir:_files -/' \
          '1:cache name' && ret=0
        ;;
      (watch-exec)
        _arguments \
          '(-j --jobs)'{-j,--jobs}'[number of parallel uploads]:jobs' \
          '--compression-level[compression level]:level' \
          '--compression-method[compression method]:method:(xz zstd)' \
          '1:cache name' \
          '--:' \
          '*:command' && ret=0
        ;;
      (watch-store)
        _arguments \
          '(-j --jobs)'{-j,--jobs}'[number of parallel uploads]:jobs' \
          '--compression-level[compression level]:level' \
          '--compression-method[compression method]:method:(xz zstd)' \
          '1:cache name' && ret=0
        ;;
      (generate-keypair)
        _arguments '1:cache name' && ret=0
        ;;
      (pin)
        _arguments \
          '1:cache name' \
          '2:pin name' \
          '3:store path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
