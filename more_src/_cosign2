#compdef cosign2
# _cosign2 — Sigstore cosign2 CLI command-line frontend wrapping the Cosign container signing verification and storage tool open-source written in Go aiming to make signatures invisible infrastructure for software artifacts SLSA-supply-chain-security-levels-for-software-artifacts signs container images artifacts attestations SBOMs verifies signatures supports KMS-backed-keys keyless-OIDC-signing-Fulcio Rekor-transparency-log-OCI-spec-1.1 standard cosign-sign cosign-verify cosign-attest cosign-blob cosign-pkcs11 cosign-key-pair cosign-tree cosign-load cosign-save (Sigstore CNCF team Dan Lorenc, Go); cobra
# upstream: https://github.com/sigstore/cosign

_cosign2() {
    local -a sub=(
        'attach:attach signatures to image'
        'attest:attest a container image'
        'attest-blob:attest a blob'
        'clean:clean signatures'
        'completion:generate shell completion'
        'copy:copy signatures'
        'debug:debug Rekor entry'
        'discover:discover signature'
        'download:download an artifact'
        'env:show env vars'
        'generate:generate signing payload'
        'generate-key-pair:generate key pair'
        'import-key-pair:import key pair'
        'initialize:initialize TUF root'
        'load:load signed image'
        'login:login to registry'
        'manifest:manifest tools'
        'pkcs11-tool:PKCS11 token tools'
        'policy:policy operations'
        'public-key:show public key'
        'save:save signed image'
        'sign:sign an image'
        'sign-blob:sign a blob'
        'tree:show signature tree'
        'triangulate:show signature ref'
        'trusted-root:trusted root tools'
        'verify:verify signatures'
        'verify-attestation:verify attestations'
        'verify-blob:verify blob signature'
        'verify-blob-attestation:verify blob attestation'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--allow-http-registry[allow HTTP registry]' \
        '--allow-insecure-registry[allow insecure registry]' \
        '--key=+[key path]:_files' \
        '--cert=+[cert file]:file:_files -g "*.pem *.crt"' \
        '--cert-chain=+[cert chain]:file:_files' \
        '--certificate=+[file]:file:_files -g "*.pem *.crt"' \
        '--certificate-chain=+[file]:file:_files' \
        '--certificate-identity=+[id]:str:' \
        '--certificate-identity-regexp=+[regex]:str:' \
        '--certificate-oidc-issuer=+[url]:str:' \
        '--certificate-oidc-issuer-regexp=+[regex]:str:' \
        '--rekor-url=+[url]:str:' \
        '--fulcio-url=+[url]:str:' \
        '--oidc-issuer=+[url]:str:' \
        '--oidc-client-id=+[id]:str:' \
        '--oidc-client-secret-file=+[file]:file:_files' \
        '--oidc-redirect-url=+[url]:str:' \
        '--oidc-provider=+[name]:str:' \
        '--oidc-disable-ambient-providers[no ambient]' \
        '--identity-token=+[token]:str:' \
        '--registry-username=+[user]:_users' \
        '--registry-password=+[password]:str:' \
        '--registry-token=+[token]:str:' \
        '--allow-bypass-rekor[allow bypass Rekor]' \
        '-y[yes/skip prompts]' \
        '--yes[yes]' \
        '--output-signature=+[file]:file:_files' \
        '--output-certificate=+[file]:file:_files' \
        '--output-payload=+[file]:file:_files' \
        '--output-file=+[file]:file:_files' \
        '--bundle=+[file]:file:_files' \
        '--rfc3161-timestamp=+[file]:file:_files' \
        '--tsa-server-url=+[url]:str:' \
        '--predicate=+[file]:file:_files' \
        '--type=+[t]:t:(custom slsaprovenance link spdx spdxjson cyclonedx vuln openvex)' \
        '--annotations=+[k=v]:str:' \
        '*-a+[k=v]:str:' \
        '--attachment=+[t]:t:(sbom signature attestation)' \
        '--upload=+[v]:v:(true false)' \
        '--force[force overwrite]' \
        '--insecure-skip-verify[skip verify]' \
        '--registry-allow-insecure[allow insecure registry]' \
        '--platform=+[os/arch]:str:' \
        '--offline[offline]' \
        '--rekor-public-key=+[file]:file:_files' \
        '--ct-log-public-key=+[file]:file:_files' \
        '--sk-pin-policy=+[p]:p:(default never always)' \
        '--sk-touch-policy=+[p]:p:(default never always cached)' \
        '--key-name=+[name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cosign subcommand' sub ;;
        args)
            case $words[1] in
                sign|verify|attest|attest-blob|verify-attestation|sign-blob|verify-blob|verify-blob-attestation|attach|clean|copy|download|tree|triangulate|debug|public-key) _arguments '*:image:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                policy) _arguments '1:op:(init sign)' '*:arg:' ;;
            esac
            ;;
    esac
}

_cosign2 "$@"
