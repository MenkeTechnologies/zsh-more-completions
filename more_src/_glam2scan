#compdef glam2scan
# Documentation: https://meme-suite.org/meme/doc/glam2scan.html
# MEME Suite: search sequences for matches to a GLAM2 gapped motif

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output directory (default glam2scan_out), fail if exists]:dir:_files -/' \
  '-O[output directory, overwrite if exists]:dir:_files -/' \
  '-t[output text only to stdout]' \
  '-n[report this many matches]:n:' \
  '-2[examine both strands of nucleotide sequences]' \
  '-D[deletion pseudocount]:pseudocount:' \
  '-E[no-deletion pseudocount]:pseudocount:' \
  '-I[insertion pseudocount]:pseudocount:' \
  '-J[no-insertion pseudocount]:pseudocount:' \
  '-d[Dirichlet mixture file]:file:_files' \
  '*:alphabet/motif/sequence file:_files' && ret=0

return ret
