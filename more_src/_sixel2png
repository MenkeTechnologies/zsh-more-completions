#compdef sixel2png
# Documentation: https://manpages.debian.org/unstable/libsixel-bin/sixel2png.1.en.html
# convert DEC SIXEL images into PNG format images

local ret=1

_arguments -s -S \
  '(-H --help)'{-H,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version and license]' \
  '(-i --input)'{-i+,--input=}'[input SIXEL file (- for stdin)]:input:_files' \
  '(-o --output)'{-o+,--output=}'[output PNG file (- for stdout)]:output:_files' \
  '*:sixel file:_files' && ret=0

return ret
