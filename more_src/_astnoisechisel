#compdef astnoisechisel
# astnoisechisel — detect signal in noisy datasets

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress extra information]' \
  '--log[store program activity in a log file]' \
  '(-N --numthreads)'{-N,--numthreads}'[number of CPU threads]:number' \
  '--minmapsize[minimum bytes to use memory-mapped files]:size' \
  '--quietmmap[do not report memory-mapped file creation]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[output data type]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--tableformat[output table format]:format:(txt fits-ascii fits-binary)' \
  '(-h --hdu)'{-h,--hdu}'[extension name or number of input]:HDU' \
  '(-I --ignorecase)'{-I,--ignorecase}'[ignore case in matching column names]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and exit]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for current directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for current user]' \
  '--cite[show BibTeX citation for this program]' \
  '--config[configuration file to use]:file:_files' \
  '--checkconfig[print all config files and variables]' \
  '--onlyversion[only run if program version matches]:version' \
  '--searchin[search column metadata]:where:(name unit comment)' \
  '(-Z --tilesize)'{-Z,--tilesize}'[regular tile size on each dimension]:sizes' \
  '(-M --numchannels)'{-M,--numchannels}'[number of channels in each dimension]:channels' \
  '(-F --remainderfrac)'{-F,--remainderfrac}'[fraction of remainder to merge with tiles]:fraction' \
  '--interpnumngb[number of neighbors for interpolation]:number' \
  '--interpmetric[metric for nearest neighbor interpolation]:metric:(radial manhattan)' \
  '--interponlyblank[only interpolate over blank tiles]' \
  '--workoverch[work over channels instead of all input]' \
  '--checktiles[save tessellation in a file]' \
  '--oneelempertile[one element per tile in interpolation]' \
  '(-k --kernel)'{-k,--kernel}'[kernel file for convolution]:file:_files' \
  '--khdu[HDU of kernel image]:HDU' \
  '--convolved[convolved image file to skip convolution]:file:_files' \
  '--chdu[HDU of convolved image]:HDU' \
  '(-w --widekernel)'{-w,--widekernel}'[wider kernel file for better qthresh]:file:_files' \
  '--whdu[HDU of wide kernel image]:HDU' \
  '(-L --largetilesize)'{-L,--largetilesize}'[size of larger tiles]:sizes' \
  '--rawoutput[output only detection labels and 1-elem/tile grid]' \
  '(-l --label)'{-l,--label}'[label/count detected connected pixels]' \
  '--ignoreblankintiles[do not write blanks in tiled output]' \
  '(-Q --meanmedqdiff)'{-Q,--meanmedqdiff}'[max mean and median quantile diff per tile]:value' \
  '(-t --qthresh)'{-t,--qthresh}'[quantile threshold on convolved image]:quantile' \
  '(-a --outliernumngb)'{-a,--outliernumngb}'[neighboring tiles for outlier detection]:number' \
  '--outliersclip[sigma-clip params for outlier detection]:multiple,tolerance' \
  '--outliersigma[multiple of sigma to define outliers]:multiple' \
  '--smoothwidth[flat kernel width to smooth interpolated]:width' \
  '--checkqthresh[save quantile threshold estimation in file]' \
  '--blankasforeground[treat blanks as foreground in erosion/opening]' \
  '(-e --erode)'{-e,--erode}'[number of erosions after thresholding]:count' \
  '--erodengb[connectivity in erosion]:neighbors:(4 8)' \
  '--noerodequant[quantile for no erosion]:quantile' \
  '(-p --opening)'{-p,--opening}'[depth of opening after erosion]:depth' \
  '--openingngb[connectivity in opening]:neighbors:(4 8)' \
  '--skyfracnoblank[no blanks in undetected fraction calculation]' \
  '(-B --minskyfrac)'{-B,--minskyfrac}'[minimum fraction of undetected area in tile]:fraction' \
  '--checkdetsky[save sky value estimation for pseudo-detections]' \
  '(-s --sigmaclip)'{-s,--sigmaclip}'[sigma multiple and tolerance or number]:multiple,tolerance' \
  '(-R --dthresh)'{-R,--dthresh}'[sigma threshold for pseudo-detections]:threshold' \
  '--dopening[depth of opening after threshold]:depth' \
  '--dopeningngb[connectivity for threshold opening]:neighbors:(4 8)' \
  '--holengb[connectivity for filling holes]:neighbors:(4 8)' \
  '--pseudoconcomp[connectivity for labeling pseudo-detections]:neighbors:(4 8)' \
  '(-m --snminarea)'{-m,--snminarea}'[minimum pseudo-detection area for S/N]:area' \
  '--checksn[save pseudo-detection S/N values to file]' \
  '--minnumfalse[minimum number for S/N estimation]:number' \
  '(-c --snquant)'{-c,--snquant}'[quantile to define true detections]:quantile' \
  '--snthresh[manual pseudo-detection S/N threshold]:threshold' \
  '(-d --detgrowquant)'{-d,--detgrowquant}'[minimum quantile to expand detections]:quantile' \
  '--detgrowmaxholesize[max hole area after growth to fill]:area' \
  '--cleangrowndet[remove small S/N grown detections]' \
  '--checkdetection[save all detection steps to file]' \
  '--checksky[save final sky and STD steps]' \
  '(-C --continueaftercheck)'{-C,--continueaftercheck}'[continue processing after checks]' \
  '*:input FITS image:_files -g "*.fits(|.gz|.fz)(N)"'
