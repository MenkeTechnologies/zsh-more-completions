#compdef rumdl
# Documentation: https://man.archlinux.org/search?q=rumdl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

local -a output_formats=(
  text full concise grouped json json-lines github gitlab pylint azure sarif junit
)
local -a flavors=(
  standard mkdocs mdx pandoc quarto obsidian kramdown azure_devops
)
local -a rule_output_formats=(text json json-lines)
local -a fail_on_modes=(any warning error never)
local -a color_modes=(auto always never)
local -a schema_actions=(generate check print)
local -a import_formats=(toml json)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--color=[colored output]:mode:('"${(j: :)color_modes}"')' \
  '*'{-c,--config}'[config file path or inline TOML override]:config:' \
  '--no-config[ignore config files; use defaults]' \
  '--isolated[alias for --no-config]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:lint Markdown files'
      'fmt:format Markdown files'
      'init:create a configuration file'
      'rule:list or describe rules'
      'explain:show detailed rule documentation'
      'config:show or query configuration'
      'server:run the language server'
      'schema:generate or verify JSON schema'
      'import:convert markdownlint config'
      'vscode:manage the VS Code extension'
      'completions:emit shell completion script'
      'clean:clear the cache'
      'version:show version information'
    )
    _describe -t commands 'rumdl command' commands && ret=0
    ;;
  args)
    case $line[1] in
      check)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          {-f,--fix}'[apply automatic fixes]' \
          '--diff[show diff of fixes instead of writing files]' \
          '--dry-run[alias for --diff]' \
          {-l,--list-rules}'[list all enabled rules]' \
          {-v,--verbose}'[verbose output]' \
          '--profile[show profiling information]' \
          '--statistics[show rule violation counts]' \
          '--output-format=[diagnostic format]:format:('"${(j: :)output_formats}"')' \
          '--flavor=[Markdown flavor]:flavor:('"${(j: :)flavors}"')' \
          '--stdin[read Markdown from stdin]' \
          {-s,--silent}'[suppress diagnostics and summaries]' \
          {-w,--watch}'[re-run when files change]' \
          '--force-exclude[apply exclude patterns to explicit paths too]' \
          '--fail-on=[exit code policy]:mode:('"${(j: :)fail_on_modes}"')' \
          {-d,--disable}'[disable rules (comma-separated)]:rules:' \
          {-e,--enable}'[enable only these rules (comma-separated)]:rules:' \
          '--rules=[alias for --enable]:rules:' \
          '--extend-enable=[add enabled rules]:rules:' \
          '--extend-disable=[add disabled rules]:rules:' \
          '--fixable=[only these rules may be fixed]:rules:' \
          '--unfixable=[these rules may not be fixed]:rules:' \
          '--exclude=[exclude globs (comma-separated)]:globs:' \
          '--no-exclude[disable exclude patterns]' \
          '--include=[include only these globs]:globs:' \
          '--respect-gitignore[honor .gitignore when scanning]' \
          {-q,--quiet}'[suppress summary lines]' \
          '--show-full-path[show absolute paths in output]' \
          '--stdin-filename=[label for stdin diagnostics]:filename:' \
          '--stderr[write diagnostics to stderr]' \
          '--no-cache[disable result cache]' \
          '--cache-dir=[cache directory]:directory:_files -/' \
          '*:path:_files' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--diff[show diff instead of rewriting files]' \
          '--dry-run[alias for --diff]' \
          '--check[exit non-zero if formatting would change files]' \
          {-v,--verbose}'[verbose formatter output]' \
          '--output-format=[diagnostic format]:format:('"${(j: :)output_formats}"')' \
          '--flavor=[Markdown flavor]:flavor:('"${(j: :)flavors}"')' \
          '--stdin[read Markdown from stdin]' \
          {-s,--silent}'[suppress diagnostics; stdout is formatted content in stdin mode]' \
          {-w,--watch}'[re-run when files change]' \
          {-d,--disable}'[disable rules (comma-separated)]:rules:' \
          {-e,--enable}'[enable only these rules (comma-separated)]:rules:' \
          '--rules=[alias for --enable]:rules:' \
          '--extend-enable=[add enabled rules]:rules:' \
          '--extend-disable=[add disabled rules]:rules:' \
          '--fixable=[only these rules may be fixed]:rules:' \
          '--unfixable=[these rules may not be fixed]:rules:' \
          '--exclude=[exclude globs (comma-separated)]:globs:' \
          '--no-exclude[disable exclude patterns]' \
          '--include=[include only these globs]:globs:' \
          '--respect-gitignore[honor .gitignore when scanning]' \
          {-q,--quiet}'[suppress summary lines]' \
          '--show-full-path[show absolute paths in output]' \
          '--stdin-filename=[label for stdin diagnostics]:filename:' \
          '--stderr[write diagnostics to stderr]' \
          '--no-cache[disable result cache]' \
          '--cache-dir=[cache directory]:directory:_files -/' \
          '*:path:_files' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--pyproject[write to pyproject.toml section]' \
          '--preset=[config preset]:preset:(default google relaxed)' \
          {-o,--output}'=[output file path]:file:_files' && ret=0
        ;;
      rule)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '::rule id or name:' \
          {-o,--output}'=[rule listing format]:format:('"${(j: :)rule_output_formats}"')' \
          {-f,--fixable}'[only fixable rules]' \
          '--category=[filter by category]:category:' \
          '--explain[include full docs in JSON output]' \
          '--list-categories[list rule categories]' && ret=0
        ;;
      explain)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:rule id or name:' && ret=0
        ;;
      config)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--defaults[show only default values]' \
          '--no-defaults[show only non-default values]' \
          '--output=[output format]:format:' \
          '*:argument:' && ret=0
        ;;
      server)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--port=[TCP port for debug listener]:port:' \
          '--stdio[compatibility flag; stdio is default without --port]' \
          {-v,--verbose}'[verbose logging]' && ret=0
        ;;
      schema)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:action:('"${(j: :)schema_actions}"')' && ret=0
        ;;
      import)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:markdownlint config file:_files' \
          {-o,--output}'=[output path]:file:_files' \
          '--format=[output format]:format:('"${(j: :)import_formats}"')' \
          '--dry-run[print converted config without writing]' && ret=0
        ;;
      vscode)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--force[reinstall extension]' \
          '--update[update to latest extension]' \
          '--status[show install status only]' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-l --list)'{-l,--list}'[list supported shells]' \
          '::shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      clean|version)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
