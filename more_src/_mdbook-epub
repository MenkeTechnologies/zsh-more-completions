#compdef mdbook-epub
# _mdbook-epub — EPUB renderer for mdBook (Michael-F-Bryan/mdbook-epub)
# upstream: https://github.com/Michael-F-Bryan/mdbook-epub
# Flags from src/bin/mdbook-epub.rs (clap derive).

_mdbook-epub() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-s --standalone)'{-s,--standalone}'[run standalone, not as mdbook plugin]' \
        '*:root book folder:_files -/'
}

_mdbook-epub "$@"
