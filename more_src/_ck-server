#compdef ck-server
# _ck-server — Cloak server (traffic-obfuscation pluggable transport) (cbeuw/Cloak)
# upstream: https://github.com/cbeuw/Cloak
# Flags from cmd/ck-server/ck-server.go (flag).

_ck-server() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-v[print version]' \
        '-c+[config file path or JSON content]:file:_files -g "*.json"' \
        '-u[generate a UID to stdout]' \
        '-k[generate a public/private key pair to stdout]' \
        '-uid[generate and print a UID with label]' \
        '-key[generate and print a key pair with labels]' \
        '-d+[pprof bind address (ip:port)]:addr:' \
        '-verbosity=[log verbosity]:level:(debug info warn error fatal)'
}

_ck-server "$@"
