#compdef xata-cli
# Documentation: https://www.npmjs.com/package/xata-cli
# Reference accessed: 2026-05-23
# Verified: npx xata-cli --help.

# Zsh completion for xata-cli - Xata database CLI (legacy npm package)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*::args:' && ret=0

return ret
