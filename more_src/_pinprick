autoload -U is-at-least

_pinprick() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--color=[When to use colors\: auto, always, never]:COLOR:(always auto never)' \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_pinprick_commands" \
"*::: :->pinprick" \
&& ret=0
    case $state in
    (pinprick)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pinprick-command-$line[1]:"
        case $line[1] in
            (audit)
_arguments "${_arguments_options[@]}" : \
'--color=[When to use colors\: auto, always, never]:COLOR:(always auto never)' \
'-v[Show every matched outbound-call pattern, including ones that passed the version check (useful for CI audit logs)]' \
'--verbose[Show every matched outbound-call pattern, including ones that passed the version check (useful for CI audit logs)]' \
'(--json)--sarif[Output findings as SARIF 2.1.0 (for github/codeql-action/upload-sarif)]' \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::path -- Repository root:_files' \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
'--color=[When to use colors\: auto, always, never]:COLOR:(always auto never)' \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--color=[When to use colors\: auto, always, never]:COLOR:(always auto never)' \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(pin)
_arguments "${_arguments_options[@]}" : \
'--color=[When to use colors\: auto, always, never]:COLOR:(always auto never)' \
'--write[Write changes to files (default is dry-run)]' \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::path -- Repository root:_files' \
&& ret=0
;;
(score)
_arguments "${_arguments_options[@]}" : \
'--color=[When to use colors\: auto, always, never]:COLOR:(always auto never)' \
'--html[Emit a self-contained HTML report to stdout]' \
'--json[Output as JSON]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::path -- Repository root:_files' \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
'--only=[Only check actions whose owner/repo contains this substring (e.g., \`actions/checkout\`, \`actions/\` for the whole org)]:PATTERN:_default' \
'--color=[When to use colors\: auto, always, never]:COLOR:(always auto never)' \
'--write[Write changes to files (default is dry-run)]' \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::path -- Repository root:_files' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_pinprick__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pinprick-help-command-$line[1]:"
        case $line[1] in
            (audit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(pin)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(score)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_pinprick_commands] )) ||
_pinprick_commands() {
    local commands; commands=(
'audit:Audit actions for runtime fetch risks' \
'clean:Remove locally cached audit results' \
'completions:Generate shell completions' \
'pin:Pin action references to full SHAs' \
'score:Score a repository'\''s Actions supply chain posture' \
'update:Check for updates to pinned actions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'pinprick commands' commands "$@"
}
