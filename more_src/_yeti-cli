#compdef yeti-cli yeti
# _yeti-cli — Yeti yeti-cli CLI command-line frontend wrapping the YETI Your Everyday Threat Intelligence open-source threat intelligence platform formerly created by Thomas Chopitea providing forensic-intel TTPs malware-family threat-actor exploit-kit indicator observable export feed import feed-source query tag entity analytics user role permission webhook analytics task tag inline-analytics campaign intrusion-set observable-relationships dfiq-DigitalForensicsInvestigationQuestions (Yeti team Thomas Chopitea, Python); custom argparse
# upstream: https://yeti-platform.io/

_yeti-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'observable:observable operations'
        'indicator:indicator operations'
        'entity:entity operations'
        'threat-actor:threat actor operations'
        'campaign:campaign operations'
        'intrusion-set:intrusion set operations'
        'malware:malware operations'
        'exploit-kit:exploit kit operations'
        'ttp:TTP operations'
        'tool:tool operations'
        'vulnerability:vulnerability operations'
        'feed:feed operations'
        'feed-source:feed source operations'
        'analytics:analytics operations'
        'tag:tag operations'
        'export:export operations'
        'import:import operations'
        'task:task operations'
        'webhook:webhook operations'
        'user:user operations'
        'role:role operations'
        'dfiq:DFIQ operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.cfg *.ini"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.cfg *.ini"' \
        '-o+[format]:f:(json yaml table stix csv)' \
        '--output=+[format]:f:(json yaml table stix csv)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yeti subcommand' sub ;;
        args)
            case $words[1] in
                observable|indicator|entity|threat-actor|campaign|intrusion-set|malware|exploit-kit|ttp|tool|vulnerability|feed|feed-source|analytics|tag|task|webhook|user|role|dfiq) _arguments '1:op:(list get create update delete enable disable run)' '*:id:' ;;
            esac
            ;;
    esac
}

_yeti-cli "$@"
