#compdef cuda-install-samples cuda-install-samples-11.0 cuda-install-samples-12.0
# Documentation: https://man.archlinux.org/search?q=cuda-install-samples
# Reference accessed: 2026-05-16

# cuda-install-samples: install CUDA Samples to a writable directory
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:directory:_files -/' && ret=0
return ret
