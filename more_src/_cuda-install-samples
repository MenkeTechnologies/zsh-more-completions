#compdef cuda-install-samples cuda-install-samples-11.0 cuda-install-samples-12.0
# Documentation: https://docs.nvidia.com/cuda/cuda-installation-guide-linux/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cuda-install-samples: install CUDA Samples to a writable directory
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:directory:_files -/' && ret=0
return ret
