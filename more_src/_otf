#compdef otf
# Documentation: https://docs.otf.ninja/cli/
# otf - CLI client for OTF, an open source alternative to Terraform Enterprise

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--token=[API authentication token]:token' \
  '--url=[URL of OTF server]:url' \
  '1:command:(agents organizations runs state team-membership teams users workspaces completion help)' \
  '*::arg:_files' && ret=0

return ret
