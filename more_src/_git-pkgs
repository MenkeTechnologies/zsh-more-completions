#compdef git-pkgs
# Documentation: https://github.com/git-pkgs/git-pkgs
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Track package dependencies across git history (git-pkgs/git-pkgs)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'init:Initialize the dependency index'
      'list:List dependencies'
      'stats:Show dependency stats'
      'blame:Show who changed a dependency'
      'history:Show dependency history'
      'why:Explain a dependency'
      'diff:Diff dependencies between revisions'
      'vulns:Vulnerability commands (scan, blame)'
      'outdated:Show outdated dependencies'
      'update:Update the dependency index'
    )
    _describe -t commands 'git-pkgs command' commands && ret=0
    ;;
esac

return ret
