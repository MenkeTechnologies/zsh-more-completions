#compdef kubectl-rolesum
# Documentation: https://github.com/Ladicle/kubectl-rolesum
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace scope]:ns:' \
  '(-k --subject-kind)'{-k+,--subject-kind=}'[subject kind to summarize]:kind:(ServiceAccount User Group)' \
  '(-c --cluster-only)'{-c,--cluster-only}'[ignore namespaced roles, show only ClusterRoles]' \
  '(-o --options)'{-o,--options}'[list all options]' \
  '*:subject name:' && ret=0

return ret
