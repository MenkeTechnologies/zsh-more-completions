#compdef kubectl-rolesum
# Documentation: https://man.archlinux.org/search?q=kubectl-rolesum
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
  '(-k --subject-kind)'{-k+,--subject-kind=}'[subject kind]:kind:(ServiceAccount User Group)' \
  '(-c --cluster-only)'{-c,--cluster-only}'[only ClusterRoles]' \
  '(-o --options)'{-o,--options}'[list all options]' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--context=[context]:ctx:' \
  '--cluster=[cluster]:cluster:' \
  '--user=[user]:user:' \
  '--token=[bearer token]:tok:' \
  '*:subject name:' && ret=0

return ret
