#compdef ajv

# Zsh completion for ajv - AJV JSON Schema validator CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_ajv_global_flags=(
  '--spec=[JSON Schema specification]:spec:(draft7 draft2019 draft2020 jtd)'
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -s -S -C \
  "${_ajv_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'validate:Validate data against a schema'
      'compile:Compile a schema'
      'migrate:Migrate a schema to a different draft'
      'test:Test data validation result'
      'help:Show help'
    )
    _describe -t commands 'ajv commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      validate)
        _arguments -s -S \
          "${_ajv_global_flags[@]}" \
          '(-s --schema)'{-s,--schema}'=[schema file]:schema file:_files -g "*.json"' \
          '(-d --data)'{-d,--data}'=[data file]:data file:_files -g "*.json"' \
          '*'{-r,--ref}'=[referenced schema]:ref file:_files -g "*.json"' \
          '(-m --meta)'{-m,--meta}'=[meta schema file]:meta file:_files -g "*.json"' \
          '(-c --custom)'{-c,--custom}'=[custom keywords module]:module:' \
          '--errors=[error output format]:format:(js json line no)' \
          '--changes=[changes output format]:format:(js json line no)' \
          '(-o --out)'{-o,--out}'=[output file]:output file:_files' \
          '--strict[enable strict mode]' \
          '--all-errors[collect all errors]' \
          '--verbose[include data in errors]' \
          '--comment[log schema $comment]' \
          '--inline-refs[inline referenced schemas]' \
          '--remove-additional=[remove additional properties]:mode:(all true failing)' \
          '--use-defaults=[replace missing properties with defaults]:mode:(true empty)' \
          '--coerce-types=[coerce data types]:mode:(true array)' \
          '--multiple-of-precision=[precision for multipleOf]:precision:' \
          '--messages=[include error messages]:enabled:(true false)' \
          '--loop-required=[max required for loop]:count:' \
          '--loop-enum=[max enum for loop]:count:' \
          '--own-properties[only validate own properties]' && ret=0
        ;;
      compile)
        _arguments -s -S \
          "${_ajv_global_flags[@]}" \
          '(-s --schema)'{-s,--schema}'=[schema file]:schema file:_files -g "*.json"' \
          '*'{-r,--ref}'=[referenced schema]:ref file:_files -g "*.json"' \
          '(-m --meta)'{-m,--meta}'=[meta schema file]:meta file:_files -g "*.json"' \
          '(-c --custom)'{-c,--custom}'=[custom keywords module]:module:' \
          '(-o --out)'{-o,--out}'=[output file]:output file:_files' \
          '--strict[enable strict mode]' \
          '--all-errors[collect all errors]' \
          '--verbose[include data in errors]' \
          '--comment[log schema $comment]' \
          '--inline-refs[inline referenced schemas]' && ret=0
        ;;
      test)
        _arguments -s -S \
          "${_ajv_global_flags[@]}" \
          '(-s --schema)'{-s,--schema}'=[schema file]:schema file:_files -g "*.json"' \
          '(-d --data)'{-d,--data}'=[data file]:data file:_files -g "*.json"' \
          '*'{-r,--ref}'=[referenced schema]:ref file:_files -g "*.json"' \
          '--valid[data should be valid]' \
          '--invalid[data should be invalid]' && ret=0
        ;;
      migrate)
        _arguments -s -S \
          "${_ajv_global_flags[@]}" \
          '(-s --schema)'{-s,--schema}'=[schema file]:schema file:_files -g "*.json"' \
          '(-o --out)'{-o,--out}'=[output file]:output file:_files' && ret=0
        ;;
      help)
        ;;
    esac
    ;;
esac

return ret
