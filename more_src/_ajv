#compdef ajv
# ajv (ajv-cli) - JSON Schema validator CLI (canonical Node binding to Ajv)
#
# Upstream: https://github.com/ajv-validator/ajv-cli  (313+ stars, MIT)
# Library:  ajv-validator/ajv (~14k stars, MIT) -- the canonical Node JSON
#           Schema validator (drafts 4 / 6 / 7 / 2019-09 / 2020-12 + JTD).
# Authors:  Evgeny Poberezkin (Ajv core), Jesse Collis (ajv-cli)
#
# Source-direct extraction from upstream commands:
#   src/commands/validate.ts   -- validate cmd schema
#   src/commands/compile.ts    -- compile cmd schema
#   src/commands/test.ts       -- test cmd schema
#   src/commands/migrate.ts    -- migrate cmd schema
#   src/commands/options.ts    -- shared ajvOptions block
#   https://github.com/ajv-validator/ajv-cli/tree/master/src/commands
#
# Closes Axis 296 (JSON Schema validation, drafts 4/6/7/2019-09/2020-12 + JTD):
#   Rust : Stranger6667/jsonschema -> jsonschema-cli
#   Go   : santhosh-tekuri/jsonschema -> jv
#   Node : ajv-validator/ajv -> ajv-cli (this file)

local curcontext=$curcontext state line ret=1
typeset -A opt_args

_ajv_specs() {
    local -a s
    s=(
        'draft7:JSON Schema Draft 7 (most-deployed)'
        'draft2019:JSON Schema 2019-09'
        'draft2020:JSON Schema 2020-12'
        'jtd:JSON Type Definition (RFC 8927)'
    )
    _describe -t specs 'schema specification' s
}

_ajv_specs_no_jtd() {
    local -a s
    s=(
        'draft7:JSON Schema Draft 7'
        'draft2019:JSON Schema 2019-09'
        'draft2020:JSON Schema 2020-12'
    )
    _describe -t specs 'target draft for migration' s
}

_ajv_error_formats() {
    local -a f
    f=(
        'json:JSON-formatted error report'
        'line:single-line JSON per error'
        'text:plain text (default)'
        'js:JavaScript-style inspect output'
        'no:suppress error output'
    )
    _describe -t formats 'error format' f
}

_ajv_change_formats() {
    local -a f
    f=(
        'json:JSON-formatted patch report'
        'line:single-line JSON per patch op'
        'js:JavaScript-style inspect output'
    )
    _describe -t formats 'changes format' f
}

# Shared ajvOptions block; --foo and --foo-bar dash-case forms are accepted
# (options.ts: withDashCase + ajvOptions object). camelCase variants also
# accepted by minimist but dash-case is idiomatic on the CLI.
_ajv_options=(
    '--strict=[strict mode (true|false|log)]:mode:(true false log)'
    '--strict-schema=[strict schema validation]:mode:(true false log)'
    '--strict-numbers=[strict number validation]:mode:(true false log)'
    '--strict-types=[strict type validation]:mode:(true false log)'
    '--strict-tuples=[strict tuple validation]:mode:(true false log)'
    '--strict-required=[strict required validation]:mode:(true false log)'
    '--allow-matching-properties[allow overlapping properties/patternProperties]'
    '--allow-union-types[allow union types in keywords]'
    '--validate-formats[run format validation]'
    '--data[enable $data references]'
    '--all-errors[collect every validation error, not just the first]'
    '--verbose[include data in errors]'
    '--comment[log schema $comment keyword]'
    '--inline-refs=[inline referenced schemas (true|false|max-depth int)]:value:'
    '--loop-required=[max number of required props in loops]:count:'
    '--loop-enum=[max enum count for loops]:count:'
    '--own-properties[only validate own object properties (no proto)]'
    '--multiple-of-precision=[precision for multipleOf]:precision:'
    '--messages=[include error messages]:enabled:(true false)'
    '--remove-additional=[remove additional properties]:mode:(true false all failing)'
    '--use-defaults=[fill missing props with defaults]:mode:(true false empty)'
    '--coerce-types=[coerce data types]:mode:(true false array)'
    '--code-es5[generate ES5-compatible code]'
    '--code-lines[generate multi-line code]'
    '--code-optimize=[code optimisation passes (bool or int)]:value:'
    '--code-formats=[require()-able formats module to use for code gen]:module:'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->command' \
    '*::arg:->args' \
    && ret=0

case $state in
    command)
        local -a commands
        commands=(
            'validate:validate data against a schema (-s schema -d data...)'
            'compile:compile a schema; optionally emit standalone code (-o)'
            'test:assert data should be valid (--valid) or invalid (--invalid)'
            'migrate:migrate a schema to a newer draft (draft7/draft2019/draft2020)'
            'help:show command-specific help'
        )
        _describe -t commands 'ajv sub-command' commands && ret=0
        ;;
    args)
        case $line[1] in
            validate)
                _arguments -s -S \
                    '-s+[schema file (required; single file, no glob)]:schema:_files -g "*.(json|json5|yaml|yml)"' \
                    '*-d+[data file(s) to validate (required)]:data:_files -g "*.(json|json5|yaml|yml)"' \
                    '*-r+[referenced schema file(s)]:ref:_files -g "*.(json|json5|yaml|yml)"' \
                    '*-m+[meta-schema file(s)]:meta:_files -g "*.(json|json5|yaml|yml)"' \
                    '*-c+[custom-keyword module(s)]:module:' \
                    '--errors=[error output format]:format:_ajv_error_formats' \
                    '--changes=[print changes after data modification]:format:_ajv_change_formats' \
                    '--spec=[JSON Schema specification draft]:spec:_ajv_specs' \
                    "${_ajv_options[@]}" \
                    && ret=0
                ;;
            compile)
                _arguments -s -S \
                    '*-s+[schema file(s) (required)]:schema:_files -g "*.(json|json5|yaml|yml)"' \
                    '*-r+[referenced schema file(s)]:ref:_files -g "*.(json|json5|yaml|yml)"' \
                    '*-m+[meta-schema file(s)]:meta:_files -g "*.(json|json5|yaml|yml)"' \
                    '*-c+[custom-keyword module(s)]:module:' \
                    '-o+[emit standalone validation code to FILE]:output:_files' \
                    '--spec=[JSON Schema specification draft]:spec:_ajv_specs' \
                    "${_ajv_options[@]}" \
                    && ret=0
                ;;
            test)
                _arguments -s -S \
                    '-s+[schema file (required; single file, no glob)]:schema:_files -g "*.(json|json5|yaml|yml)"' \
                    '*-d+[data file(s) to test (required)]:data:_files -g "*.(json|json5|yaml|yml)"' \
                    '*-r+[referenced schema file(s)]:ref:_files -g "*.(json|json5|yaml|yml)"' \
                    '*-m+[meta-schema file(s)]:meta:_files -g "*.(json|json5|yaml|yml)"' \
                    '*-c+[custom-keyword module(s)]:module:' \
                    '(--invalid)--valid[assert that data should be valid]' \
                    '(--valid)--invalid[assert that data should be invalid]' \
                    '--errors=[error output format]:format:_ajv_error_formats' \
                    '--spec=[JSON Schema specification draft]:spec:_ajv_specs' \
                    "${_ajv_options[@]}" \
                    && ret=0
                ;;
            migrate)
                _arguments -s -S \
                    '*-s+[schema file(s) to migrate (required)]:schema:_files -g "*.(json|json5|yaml|yml)"' \
                    '-o+[output file (only valid with single -s)]:output:_files' \
                    '--indent=[JSON indent width (integer >= 1)]:indent:' \
                    '--validate-schema=[validate migrated schema (default true)]:enabled:(true false)' \
                    '--spec=[target draft for migration (no JTD)]:spec:_ajv_specs_no_jtd' \
                    && ret=0
                ;;
            help)
                _arguments \
                    '1:command:(validate compile test migrate help)' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
