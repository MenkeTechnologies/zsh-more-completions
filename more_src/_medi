(( $+functions[_medi_commands] )) ||
_medi_commands() {
    local commands; commands=(
'new:Create a new note with the specified key' \
'edit:Edit an existing note with the specified key' \
'get:Get the content of a note with the specified key' \
'list:List all notes' \
'backlinks:Find all notes that link to the given note key' \
'delete:Delete a note with the specified key' \
'search:Search for notes by content, title, or tags' \
'reindex:Reindex the search index' \
'find:Interactively find and edit a note' \
'import:Import notes from a directory or a single file' \
'export:Export notes to a file' \
'task:Manage tasks linked to notes' \
'status:Show a summary of the database' \
'lint:Run a lint check on all notes' \
'preview:Render a note in a live preview' \
'generate-completion:Generates shell completion scripts' \
'update:Update the medi application. Checks for a new version of medi and updates it if available' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'medi commands' commands "$@"
}
