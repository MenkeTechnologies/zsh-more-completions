_medi() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_medi_commands" \
"*::: :->medi" \
&& ret=0
    case $state in
    (medi)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:medi-command-$line[1]:"
        case $line[1] in
            (new)
_arguments "${_arguments_options[@]}" : \
'-m+[Provide the note content directly as an argument]:MESSAGE:_default' \
'--message=[Provide the note content directly as an argument]:MESSAGE:_default' \
'*-T+[Add one or more tags to the note]:TAG:_default' \
'*--tag=[Add one or more tags to the note]:TAG:_default' \
'-t+[Specify a title for the note]:TITLE:_default' \
'--title=[Specify a title for the note]:TITLE:_default' \
'--template=[Create a note from a template]:TEMPLATE:_default' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':key -- The key (or title) for the new note:_default' \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
'*-a+[Add one or more tags to the note]:ADD_TAG:_default' \
'*--add-tag=[Add one or more tags to the note]:ADD_TAG:_default' \
'*-r+[Remove one or more tags from the note]:RM_TAG:_default' \
'*--rm-tag=[Remove one or more tags from the note]:RM_TAG:_default' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':key -- The key of the note to edit:_default' \
&& ret=0
;;
(get)
_arguments "${_arguments_options[@]}" : \
'()*-t+[Retrieve all notes with a specific tag]:TAG:_default' \
'()*--tag=[Retrieve all notes with a specific tag]:TAG:_default' \
'--json[Output the full note data as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'*::keys -- The key(s) of the note(s) to retrieve:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-s+[The field to sort the notes by]:SORT_BY:(key created modified)' \
'--sort-by=[The field to sort the notes by]:SORT_BY:(key created modified)' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(backlinks)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':key -- The key of the note to find links for:_default' \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
'-f[Skip the confirmation prompt]' \
'--force[Skip the confirmation prompt]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':key -- The key of the note to delete:_default' \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':query -- The search query string:_default' \
&& ret=0
;;
(reindex)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(find)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(import)
_arguments "${_arguments_options[@]}" : \
'--dir=[The path to the directory containing .md files]:DIR:_default' \
'--file=[The path to a single .md file to import. (Requires --key)]:FILE:_default' \
'--key=[The key to use for the single file import]:KEY:_default' \
'--overwrite[Overwrite an existing note with the same key]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
'--format=[The output format]:FORMAT:(markdown json)' \
'*-t+[Export only notes with a specific tag]:TAG:_default' \
'*--tag=[Export only notes with a specific tag]:TAG:_default' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':path -- The path for the export directory or file:_default' \
&& ret=0
;;
(task)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_medi__task_commands" \
"*::: :->task" \
&& ret=0

    case $state in
    (task)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:medi-task-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':note_key -- The key of the note this task is for:_default' \
':description -- The description of the task:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(done)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':task_id -- The ID of the task to complete:_default' \
&& ret=0
;;
(prio)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':task_id -- The ID of the task to prioritize:_default' \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':task_id -- The ID of the task to delete:_default' \
&& ret=0
;;
(reset)
_arguments "${_arguments_options[@]}" : \
'-f[Skip the confirmation prompt]' \
'--force[Skip the confirmation prompt]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_medi__task__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:medi-task-help-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(done)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(prio)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(reset)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(status)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
