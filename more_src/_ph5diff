#compdef ph5diff
# Documentation: https://support.hdfgroup.org/documentation/hdf5/latest/_h5_t_o_o_l__d_f__u_g.html
# Parallel HDF5 file/object difference tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage message and exit]' \
  '(-V --version)'{-V,--version}'[print library version number and exit]' \
  '(-r --report)'{-r,--report}'[report mode, print differences]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print differences and object list]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, do not produce output]' \
  '(-c --compare)'{-c,--compare}'[list objects that are not comparable]' \
  '(-d --delta)'{-d+,--delta=}'[print differences exceeding absolute value D]:delta' \
  '(-p --relative)'{-p+,--relative=}'[print differences exceeding relative value R]:relative' \
  '--use-system-epsilon[treat values equal if difference < system epsilon]' \
  '(-N --nan)'{-N,--nan}'[avoid NaNs detection]' \
  '(-n --count)'{-n+,--count=}'[print differences up to count C]:count' \
  '--follow-symlinks[follow symbolic links and compare their target objects]' \
  '--no-dangling-links[error if any symbolic link does not resolve]' \
  '*--exclude-path=[exclude specified object path from comparison]:path' \
  '*--exclude-attribute=[exclude attributes on specified object path]:path' \
  '--enable-error-stack[print messages from the HDF5 error stack]' \
  '1:file1:_files' \
  '2:file2:_files' \
  '3:object1:' \
  '4:object2:' && ret=0

return ret
