#compdef condor_updates_stats
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_updates_stats.html
# display ClassAd update statistics parsed from condor_status output

local ret=1

_arguments -s -S \
  '(-help -h)'{-help,-h}'[display usage information and exit]' \
  '-version[display HTCondor version information and exit]' \
  '(-long -l)'{-long,-l}'[display all update statistics]' \
  '-history=[set the range of update numbers to print]:min-max' \
  '-interval=[the assumed update interval in seconds]:seconds' \
  '-notime[do not display assumed times for the updates]' \
  '-time[display assumed times for the updates]' \
  '(-summary -s)'{-summary,-s}'[display only summary information]' && ret=0

return ret
