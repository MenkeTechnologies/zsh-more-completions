#compdef wu-ftpd
# Documentation: https://man.archlinux.org/search?q=wu-ftpd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-a[use access file]' \
  '-A[do not use access file]' \
  '-d[debug]' \
  '-l[log all sessions]' \
  '-L[log all commands]' \
  '-i[log inbound transfers]' \
  '-o[log outbound transfers]' \
  '-v[verbose]' \
  '-q[do not use PID files]' \
  '-Q[no PID logging]' \
  '-r+[chroot dir]:dir:_files -/' \
  '-s[standalone]' \
  '-S[standalone with daemonize]' \
  '-T+[max idle minutes]:n:' \
  '-t+[default idle minutes]:n:' \
  '-u+[default umask]:mode:' \
  '-W[no wtmp logging]' \
  '-w[use wtmp]' \
  '-X[log to stderr]' && ret=0

return ret
