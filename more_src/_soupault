#compdef soupault
# Static website generator and HTML processor

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--version-number[print version number only]' \
  '--init[initialize a basic project]' \
  '--build[build the site]' \
  '--force[force rebuild all pages]' \
  '--site-dir[specify site directory]:dir:_files -/' \
  '--build-dir[specify build directory]:dir:_files -/' \
  '--config[specify config file]:file:_files' \
  '--verbose[enable verbose output]' \
  '--debug[enable debug output]' \
  '--strict[stop on errors]' \
  '--profile[build profile to use]:profile:' \
  && return 0
