#compdef gradualizer
# Documentation: https://github.com/josefs/Gradualizer/blob/master/README.md
# A Gradual type system / type checker for Erlang

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help and exit]' \
  '--infer[infer type information from literals and constructs]' \
  '--no_infer[only use type information from function specs]' \
  '--verbose[show what Gradualizer is doing]' \
  '*'{-pa,--path_add}'+[prepend directory to the code path]:dir:_files -/' \
  '*-I+[include path for Erlang source files]:dir:_files -/' \
  '--stop_on_first_error[stop type checking at the first error]' \
  '--no_stop_on_first_error[do not stop at first error (default)]' \
  '--no_prelude[do not override OTP specs]' \
  '--specs_override_dir=[add specs overrides from *.specs.erl files in dir]:dir:_files -/' \
  '--fmt_location=[how to format location when printing errors]:fmt' \
  '--color=[use colors when printing fancy messages]:when:(auto always never)' \
  '--no_color[alias for --color never]' \
  '--fancy[use fancy error messages (default)]' \
  '--no_fancy[do not use fancy error messages]' \
  '--union_size_limit=[unions larger than this are replaced by any()]:n' \
  '--solve_constraints[type check polymorphic calls]' \
  '*:path:_files' && ret=0

return ret
