#compdef animate
# Documentation: animate --help on ImageMagick 7.1.2
# Source: ImageMagick — `animate` CLI (alias of `magick animate`); X-window image sequence player.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-alpha[alpha option]:option:(on activate off deactivate set opaque copy transparent extract background shape)' \
    '-authenticate[decipher image password]:password:' \
    '-backdrop[display image centered on a backdrop]' \
    '-colormap[Shared or Private]:type:(Shared Private)' \
    '-colorspace[alternate image colorspace]:type:(RGB sRGB CMYK CMY HSL HSV HCL HWB Lab Luv YIQ YPbPr YCbCr Gray)' \
    '-decipher[convert cipher pixels to plain]:filename:_files' \
    '*-define[define format option]:format\:option:' \
    '-delay[display next image after pausing]:value:' \
    '-density[horizontal+vertical density (dpi)]:geometry:' \
    '-depth[image depth]:value:' \
    '-display[X server display]:server:' \
    '-dispose[layer disposal method]:method:(None Background Previous)' \
    '-dither[error diffusion method]:method:(None FloydSteinberg Riemersma)' \
    '-filter[resize filter]:type:(Point Box Triangle Hermite Hanning Hamming Blackman Gaussian Quadratic Cubic Catrom Mitchell Lanczos Bessel Sinc)' \
    '-format[output formatted image characteristics]:string:' \
    '-gamma[gamma correction]:value:' \
    '-geometry[preferred Image window size+location]:geometry:' \
    '-gravity[backdrop placement]:type:(NorthWest North NorthEast West Center East SouthWest South SouthEast)' \
    '-identify[identify image format+characteristics]' \
    '-immutable[displayed image cannot be modified]' \
    '-interlace[image interlacing scheme]:type:(None Line Plane Partition JPEG GIF PNG)' \
    '-interpolate[pixel-color interpolation method]:method:(Average Bilinear Integer Mesh Nearest Spline)' \
    '*-limit[pixel-cache resource limit]:type value:' \
    '-loop[loop images then exit]:iterations:' \
    '-matte[store matte channel if image has one]' \
    '-map[display image using Standard Colormap]:type:' \
    '-monitor[monitor progress]' \
    '-pause[seconds to pause before reanimating]:seconds:' \
    '-page[image canvas size+location]:geometry:' \
    '-quantize[reduce colors in colorspace]:colorspace:' \
    '-quiet[suppress all warning messages]' \
    '-regard-warnings[treat warnings as errors]' \
    '-remote[execute command in remote display process]:command:' \
    '-repage[image canvas size+location (operator)]:geometry:' \
    '-respect-parentheses[settings stay in effect until paren boundary]' \
    '-sampling-factor[horiz/vert sampling factor]:geometry:' \
    '-scenes[image scene range]:range:' \
    '-seed[seed pseudo-random number sequence]:value:' \
    '*-set[set image attribute]:attribute value:' \
    '-size[width and height of image]:geometry:' \
    '-support[resize support factor (>1 blurry, <1 sharp)]:factor:' \
    '-transparent-color[transparent color]:color:' \
    '-treedepth[color tree depth]:value:' \
    '-verbose[print detailed image information]' \
    '-visual[display image using this visual type]:type:' \
    '-virtual-pixel[virtual-pixel access method]:method:(Background Black CheckerTile Dither Edge Gray HorizontalTile HorizontalTileEdge Mirror Random Tile Transparent VerticalTile VerticalTileEdge White)' \
    '-window[display to background of this window]:id:' \
    '-channel[image channel mask]:mask:' \
    '-colors[preferred number of colors]:value:' \
    '-crop[crop image]:geometry:' \
    '-extent[set image size]:geometry:' \
    '-extract[extract area from image]:geometry:' \
    '-monochrome[transform image to black-and-white]' \
    '-resample[change resolution]:geometry:' \
    '-resize[resize the image]:geometry:' \
    '-rotate[apply Paeth rotation]:degrees:' \
    '-strip[strip image of profiles+comments]' \
