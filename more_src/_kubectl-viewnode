#compdef kubectl-viewnode
# Documentation: https://github.com/NTTDATA-DACH/viewnode
# Display Kubernetes cluster nodes with their pods and containers

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[use all namespaces and group scheduled pods by namespace]' \
  '(-b --container-tree-view)'{-b,--container-tree-view}'[format containers in tree view, otherwise inline]' \
  '--kubeconfig=[kubectl configuration file]:file:_files' \
  '(-n --namespace)'{-n,--namespace}'=[namespace to use; accepts comma-separated values]:namespace' \
  '(-f --node-filter)'{-f,--node-filter}'=[show only nodes according to filter]:filter' \
  '(-p --pod-filter)'{-p,--pod-filter}'=[show only pods according to filter]:filter' \
  '(-c --show-containers)'{-c,--show-containers}'[show containers in pod]' \
  '(-m --show-metrics)'{-m,--show-metrics}'[show memory footprint of nodes, pods and containers]' \
  '(-t --show-pod-start-times)'{-t,--show-pod-start-times}'[show start times of pods]' \
  '(-r --show-requests-and-limits)'{-r,--show-requests-and-limits}'[show requests and limits for cpu and memory]' \
  '--show-running-only[show running pods only]' \
  '(-v --verbosity)'{-v,--verbosity}'=[defines log level]:level:(debug info warn error fatal panic)' \
  '(-w --watch)'{-w,--watch}'[execute the command every second to observe changes]' && ret=0

return ret
