#compdef sfpick
# Documentation: https://github.com/ahay/src/blob/master/user/fomels/Mpick.c
# Madagascar: automatic picking from semblance-like panels

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'vel0=[surface velocity]:velocity' \
  '*rect=[smoothing radius on the n-th axis]:radius' \
  'niter=[number of iterations]:count' \
  'an=[axes anisotropy]:value' \
  'gate=[picking gate]:value' \
  'smooth=[if apply smoothing]:flag:(y n)' \
  'norm=[if apply normalization (0.~1.)]:flag:(y n)' \
  'back=[if run backward]:flag:(y n)' \
  'time=[optional output file for time array]:file:_files' \
  '*:RSF file:_files' && ret=0

return ret
