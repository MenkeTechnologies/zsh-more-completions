#compdef pwndbg
# Documentation: https://pwndbg.re/stable/setup/
# pwndbg — GDB plus exploit-dev/reverse-engineering context; used the same way as gdb

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(--args)--args[program plus its arguments follow]:program:_files' \
  '(--pid -p)'{--pid=,-p+}'[attach to running process by pid]:pid:' \
  '(--core -c)'{--core=,-c+}'[analyze the specified core file]:core:_files' \
  '(--exec -e)'{--exec=,-e+}'[use file as the executable]:exec:_files' \
  '(--symbols -s)'{--symbols=,-s+}'[read symbols from file]:symbols:_files' \
  '(--command -x)'{--command=,-x+}'[execute GDB commands from file]:file:_files' \
  '*'{--eval-command=,-ex+}'[execute a single GDB command]:command:' \
  '(--directory -d)'{--directory=,-d+}'[add directory to source search path]:dir:_files -/' \
  '--batch[run in batch mode and exit]' \
  '--batch-silent[run in batch mode silently]' \
  '(--nx -n)'{--nx,-n}'[do not read any .gdbinit files]' \
  '--nh[do not read ~/.gdbinit]' \
  '(--quiet -q)'{--quiet,-q}'[do not print version/copyright on startup]' \
  '--tui[use the terminal user interface]' \
  '*:executable:_files' && ret=0

return ret
