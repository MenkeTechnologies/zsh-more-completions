#compdef esmvaltool
# Documentation: https://docs.esmvaltool.org/projects/ESMValCore/en/latest/quickstart/run.html
# esmvaltool - Earth System Model Evaluation Tool

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:(run recipes config version)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s \
      '--config_dir=[path to configuration directory]:dir:_files -/' \
      '--check_level=[CMOR checker strictness]:level:(ignore relaxed default strict)' \
      '--resume_from=[reuse pre-processed files from previous runs]:dir:_files -/' \
      '--remove_preproc_dir=[remove preprocessing output directories]:bool:(True False)' \
      '--run_diagnostic=[run diagnostic scripts]:bool:(True False)' \
      '--max_datasets=[limit number of datasets per variable]:n:' \
      '--max_years=[limit total amount of years loaded]:n:' \
      '--skip_nonexistent=[run recipe even if some datasets are unavailable]:bool:(True False)' \
      '--diagnostics=[select specific diagnostics to run]:diag:' \
      '*:recipe:_files -g "*.yml"' && ret=0
    ;;
esac

return ret
