#compdef shelxe
# Documentation: https://wiki.uni-konstanz.de/ccp4/index.php/SHELX_C/D/E
# SHELXE density modification and poly-Ala chain tracing (macromolecular phasing).

local ret=1

_arguments -s -S \
  '-a+[number of global autotracing cycles]:n:' \
  '-b+[B-value weighting for anomalous map]:b:' \
  '-B+[beta sheet configuration]:n:(1 2 3)' \
  '-c+[fraction of pixels in crossover region]:c:' \
  '-d+[truncate reflection data to Angstroms]:d:' \
  '-D[fuse disulfides before NCS search]' \
  '-e+[add free lunch data up to Angstroms]:e:' \
  '-f[read F rather than intensity from native hkl]' \
  '-F+[fractional weight for phases from previous cycle]:F:' \
  '-g+[solvent gamma flipping factor]:g:' \
  '-G+[threshold for accepting new peptide]:G:' \
  '-h+[number of heavy atoms in native structure]:h:' \
  '-i[invert space group and input structure or phases]' \
  '-I+[initial DM cycles in cycle 1 only]:I:' \
  '-j+[print pseudo-free CC before every Nth cycle]:N:' \
  '-k+[min height/sigma for heavy atom sites]:k:' \
  '-K+[keep starting fragment unchanged]:n:' \
  '-l+[reserve space for reflection counts]:l:' \
  '-L+[minimum chain length retention]:L:' \
  '-m+[density modification iterations per cycle]:m:' \
  '-n+[apply N-fold NCS to traces]:n:' \
  '-o+[prune residues to optimise CC]:o:' \
  '-O[trace side chains]' \
  '-p+[search for DNA/RNA phosphates]:p:' \
  '-q+[search for alpha-helices]:len:' \
  '-Q[search for 12-helix extended by sliding]' \
  '-r+[FFT grid multiplier for maximum indices]:r:' \
  '-s+[solvent fraction]:s:' \
  '-S+[radius of sphere of influence]:S:' \
  '-t+[time for initial searches]:t:' \
  '-u+[allocable memory in MB]:MB:' \
  '-U+[abort threshold percentage]:U:' \
  '-v+[density sharpening]:v:' \
  '-w+[add experimental phases with weight per iteration]:w:' \
  '-x[diagnostics (requires PDB reference)]' \
  '-y+[highest resolution for calculated phases]:y:' \
  '-z+[substructure optimisation for max atoms]:z:' \
  '*:name:_files' && ret=0

return ret
