#compdef pocket-id
# Documentation: https://man.archlinux.org/search?q=pocket-id
# Reference accessed: 2026-05-16

# Zsh completion for pocket-id identity provider

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '*::args:{ _message "pocket-id server flags — see upstream" }' && ret=0

return ret
