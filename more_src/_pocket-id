#compdef pocket-id
# Documentation: https://github.com/pocket-id/pocket-id
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (backend/internal/cmds/).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'encryption-key-rotate:rotate the data encryption key'
      'export:export Pocket ID data to a zip archive'
      'healthcheck:check server health'
      'import:import Pocket ID data from a zip archive'
      'key-rotate:rotate the signing key'
      'one-time-access-token:create a one-time access token'
      'version:print version information'
    )
    _describe -t commands 'pocket-id command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      encryption-key-rotate)
        _arguments \
          '--new-key=[new encryption key for re-encrypting data]:key' \
          {-y,--yes}'[skip confirmation prompt]' && ret=0
        ;;
      export)
        _arguments \
          {-p+,--path=}'[destination for the zip file or - for stdout]:path:_files' && ret=0
        ;;
      import)
        _arguments \
          {-p+,--path=}'[path to zip file or - for stdin]:path:_files' \
          {-y,--yes}'[skip confirmation prompts]' \
          '--forcefully-acquire-lock[forcefully acquire the application lock]' && ret=0
        ;;
      healthcheck)
        _arguments \
          {-e+,--endpoint=}'[endpoint for Pocket ID]:url' \
          {-v,--verbose}'[verbose output]' && ret=0
        ;;
      key-rotate)
        _arguments \
          {-a+,--alg=}'[key algorithm]:alg:(RS256 RS384 RS512 ES256 ES384 ES512 EdDSA)' \
          {-c+,--crv=}'[curve name for EdDSA keys]:crv:(Ed25519)' \
          {-y,--yes}'[skip confirmation prompts]' && ret=0
        ;;
      one-time-access-token)
        _arguments '1:username or email:' && ret=0
        ;;
    esac
    ;;
esac

return ret
