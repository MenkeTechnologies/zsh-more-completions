#compdef keydb-check-aof
# Documentation: https://redis.io/docs/latest/operate/oss_and_stack/management/persistence/
# Reference accessed: 2026-05-19
# Verified: upstream Redis persistence docs at the URL above (keydb-check-aof
# is a redis-check-aof fork; --fix and --truncate-to-timestamp documented).

# keydb-check-aof: AOF inspector / fixer
local curcontext="$curcontext" ret=1
_arguments -C \
  '--fix[fix the AOF file, truncating at the first error]' \
  '--truncate-to-timestamp[truncate the AOF up to the given timestamp]:timestamp:' \
  '*:AOF file:_files -g "*.aof"' && ret=0
return ret
