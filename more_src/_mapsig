#compdef mapsig
# Documentation: https://www.ccp4.ac.uk/html/mapsig.html
# CCP4: print signal/noise statistics for a translation-function map

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'MAPIN[first input map file]:map:_files -g "*.(map|ccp4)"' \
  'MAPIN2[second input map file]:map:_files -g "*.(map|ccp4)"' \
  'MAPOUT[output combined map file]:map:_files' \
  'PEAK_LIST[output list of peaks found]:peaks:_files' \
  '*:keyword:(POINTS PEAKS SCALES TYPE MAPOUT END)' && ret=0

return ret
