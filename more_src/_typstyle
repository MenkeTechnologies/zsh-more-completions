#compdef typstyle
# Documentation: https://man.archlinux.org/search?q=typstyle
# Reference accessed: 2026-05-16

# Zsh completion for typstyle Typst formatter (typstyle-rs/typstyle). Args from crates/typstyle/src/cli.rs.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(--check --diff)'{-i,--inplace}'[format files in place]' \
  '(-i --inplace --diff)--check[verify formatting only]' \
  '(-i --inplace --check)--diff[show formatting diff]' \
  '(-l --line-width -c --column)'{-l,-c,--line-width,--column=}'[max line width]:width:' \
  '(-t --indent-width --tab-width)'{-t,--indent-width,--tab-width=}'[spaces per indent level]:width:' \
  '--no-reorder-import-items[keep import order as written]' \
  '--wrap-text[wrap markup text to line width]' \
  '(-a --ast)'{-a,--ast}'[print AST]' \
  '(-p --pretty-doc)'{-p,--pretty-doc}'[print pretty document]' \
  '--timing[print formatter timing]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-q --quiet)'{-q,--quiet}'[quiet logging]' \
  '*::path:_files'
