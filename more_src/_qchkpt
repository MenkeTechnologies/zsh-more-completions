#compdef qchkpt
# Documentation: https://docs.adaptivecomputing.com/torque/4-0-2/Content/topics/commands/qchkpt.htm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# qchkpt: checkpoint a PBS job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-W[wait]:delay:' \
  '*:jobid:' && ret=0
return ret
