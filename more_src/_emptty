#compdef emptty
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/emptty.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu noble emptty(1) manpage OPTIONS section.
# Removed from prior file: -h/--help (not documented in manpage).

# emptty: minimalist TTY display manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[start as daemon (no agetty)]' \
  '(-c --config)'{-c,--config=}'[load configuration from path]:file:_files' \
  '(-i --ignore-config)'{-i,--ignore-config}'[skip config file loading]' \
  '(-t --tty)'{-t,--tty=}'[override TTY]:tty:' \
  '(-u --default-user)'{-u,--default-user=}'[override default user]:user:_users' \
  '(-a --autologin)'{-a,--autologin=-}'[enable autologin]:session:' && ret=0
return ret
