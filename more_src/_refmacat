#compdef refmacat
# Documentation: https://www.ccp4.ac.uk/html/refmac5/usage/examples.html
# CCP4 refmacat: macromolecular refinement; logical-file keywords on command line

local ret=1

_arguments -s -S \
  '*:keyword or file:->kw' && ret=0

if [[ $state == kw ]]; then
  _alternative \
    'keywords:logical file:(XYZIN XYZOUT HKLIN HKLOUT LIBIN LIBOUT TLSIN TLSOUT)' \
    'files:file:_files' && ret=0
fi

return ret
