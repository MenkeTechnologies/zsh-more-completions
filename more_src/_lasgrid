#compdef lasgrid
# Documentation: https://github.com/LAStools/LAStools
# LAStools: grid LAS/LAZ points into a raster of elevation/intensity/density

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[display version number]' \
  '-gui[launch with GUI]' \
  '-v[verbose output]' \
  '-step+[grid cell size (n x n area)]:size' \
  '-elevation[raster elevation values]' \
  '-intensity[raster intensity values]' \
  '-rgb[use RGB color values]' \
  '-lowest[keep minimum value per cell]' \
  '-highest[keep maximum value per cell]' \
  '-average[compute mean value per cell]' \
  '-stddev[compute standard deviation per cell]' \
  '-range[use value range per cell]' \
  '-density[check point density per cell]' \
  '-counter[count points per grid cell]' \
  '-counter_8bit[point count with 8-bit storage]' \
  '-counter_16bit[point count with 16-bit storage]' \
  '-counter_32bit[point count with 32-bit storage]' \
  '-false[false-color visualization]' \
  '-gray[grayscale visualization]' \
  '-fill+[fill voids with search radius]:radius' \
  '-mem+[memory usage 500-2000 MB]:mb' \
  '-temp_files+[temporary file location]:path:_files -/' \
  '*-i+[input file]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-lof+[list of files input]:file:_files' \
  '-merged[merge multiple input files]' \
  '-o+[output file]:output:_files' \
  '-obil[output as BIL]' \
  '-oasc[output as ASCII]' \
  '-otif[output as GeoTIFF]' \
  '-opng[output as PNG]' \
  '-ojpg[output as JPG]' \
  '-oxyz[output as XYZ text]' \
  '-ocsv[output as CSV]' \
  '-odtm[output as DTM]' \
  '-olaz[output as LAZ]' \
  '-cores+[parallel processing cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
