#compdef mokvar
# Documentation: https://man.archlinux.org/search?q=mokvar
# Reference accessed: 2026-05-16

# mokvar: read MOK (Machine Owner Key) UEFI variables from EFI runtime
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-l[list mok vars]' \
  '*:variable:' && ret=0
return ret
