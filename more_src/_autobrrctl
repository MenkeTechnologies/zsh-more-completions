#compdef autobrrctl

# Zsh completion for autobrrctl administrative actions

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--config[path to configuration directory]:dir:_directories' \
  '1:action:->act' \
  '*::args:->args' && ret=0

case $state in
  act)
    local -a actions=(
      'create-user:create a web UI user'
      'change-password:rotate user password'
      'export-filters:dump filters as JSON files in cwd'
      'db:seed:sqlite seed from SQL file'
      'db:reset:recreate sqlite from seed'
      'db:convert:migrate sqlite database to postgres'
      version
      help
    )
    _describe -t actions 'autobrrctl action' actions && ret=0
    ;;
  args)
    case $words[1] in
      db:seed|db:reset)
        _arguments '--db-path[sqlite database]:file:_files' '--seed-db[seed SQL]:file:_files' && ret=0
        ;;
      db:convert)
        _arguments '--sqlite-db[sqlite path]:file:_files' '--postgres-url[DSN]:url' && ret=0
        ;;
      create-user|change-password)
        _message 'username' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
