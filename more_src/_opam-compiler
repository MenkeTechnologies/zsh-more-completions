#compdef opam-compiler
# Documentation: https://github.com/ocaml-opam/opam-compiler
# opam plugin to create switches from compiler sources (PRs, branches, dirs)

local ret=1
local -a subcmds

subcmds=(
  'create:create a switch using a custom OCaml compiler source'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--switch=[name of the switch to create]:switch' \
  '--configure-command=[command used to configure the compiler]:command' \
  '*--with=[pass a configure option (e.g. flambda)]:option' \
  '--dry-run[print external commands instead of running them]' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'opam-compiler command' subcmds && ret=0
    ;;
  args)
    _message 'compiler source (PR number, branch, url or directory)' && ret=0
    ;;
esac

return ret
