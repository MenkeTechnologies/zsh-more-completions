#compdef impacket-rdp_check

# Impacket rdp_check.py: check RDP credentials against a host
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos auth]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-target-ip[target host IP]:ip:' \
  '*:user[:password]@host:' && ret=0
return ret
