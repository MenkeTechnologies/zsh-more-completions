#compdef cargo-supply-chain

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'crates:list all dependency crates'
      'publishers:list all publishers of dependency crates'
      'update:compare local crates with upstream'
      'json:output dependency information as JSON'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (crates)
        _arguments \
          '--features=[comma-separated features to activate]:features:' \
          '--all-features[activate all features]' \
          '--no-default-features[do not activate default features]' \
          '--diffable[output in diffable format]' && ret=0
        ;;
      (publishers)
        _arguments \
          '--features=[comma-separated features to activate]:features:' \
          '--all-features[activate all features]' \
          '--no-default-features[do not activate default features]' \
          '--diffable[output in diffable format]' && ret=0
        ;;
      (update)
        _arguments \
          '--features=[comma-separated features to activate]:features:' \
          '--all-features[activate all features]' \
          '--no-default-features[do not activate default features]' && ret=0
        ;;
      (json)
        _arguments \
          '--features=[comma-separated features to activate]:features:' \
          '--all-features[activate all features]' \
          '--no-default-features[do not activate default features]' && ret=0
        ;;
    esac
    ;;
esac

return ret
