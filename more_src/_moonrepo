#compdef moon

_moon_commands() {
  local -a commands=(
    'action:Display information about an action'
    'bin:Return the binary path of a tool'
    'check:Run check tasks for affected projects'
    'ci:Run CI tasks'
    'clean:Clean stale cache'
    'completions:Generate shell completions'
    'dep-graph:Display the dependency graph'
    'docker:Manage Docker integration'
    'ext:Manage extensions'
    'generate:Generate code from a template'
    'graph:Display a visual graph'
    'init:Initialize a new moon workspace'
    'migrate:Migrate to latest configuration'
    'project:Display information about a project'
    'project-graph:Display the project graph'
    'query:Query information about the workspace'
    'run:Run one or many tasks'
    'setup:Setup the workspace toolchain'
    'sync:Sync the workspace and projects'
    'task:Display information about a task'
    'teardown:Tear down the workspace toolchain'
    'templates:List available templates'
    'upgrade:Upgrade moon to the latest version'
    'help:Print help'
  )
  _describe -t commands 'moon command' commands
}

_moon() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Print help]' \
    '(-V --version)'{-V,--version}'[Print version]' \
    '--color[Force colored output]' \
    '--concurrency[Maximum concurrency]:count:' \
    '--cache[Cache mode]:mode:(read write off)' \
    '--log[Log level]:level:(off error warn info debug trace)' \
    '--logFile[Log to file]:file:_files' \
    '1:command:_moon_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        run)
          _arguments \
            '--affected[Only run on affected projects]' \
            '--dependents[Also run on dependents]' \
            '--force[Force run (ignore cache)]' \
            '--profile[Record CPU profile]:file:_files' \
            '--remote[Run remotely]' \
            '--status[Filter by status]:status:(passed failed)' \
            '--summary[Print summary]' \
            '-u[Run on upstream dependencies]' \
            '--upstream[Run on upstream dependencies]' \
            '--query[Filter projects using query]:query:' \
            '*:target (project\:task):'
          ;;
        check)
          _arguments \
            '--all[Check all projects]' \
            '--affected[Only check affected projects]' \
            '--remote[Run remotely]' \
            '--summary[Print summary]' \
            '--update-cache[Update the cache]' \
            '*:project:'
          ;;
        ci)
          _arguments \
            '--base[Base branch or rev]:ref:' \
            '--head[Head branch or rev]:ref:' \
            '--job[Job index]:index:' \
            '--jobTotal[Total jobs]:count:' \
            '--remote[Run remotely]'
          ;;
        init)
          _arguments \
            '--to[Destination directory]:dir:_directories' \
            '--yes[Skip confirmations]' \
            '--minimal[Minimal config]' \
            '1:destination:_directories'
          ;;
        generate)
          _arguments \
            '--dest[Destination directory]:dir:_directories' \
            '--defaults[Use defaults]' \
            '--dryRun[Dry run]' \
            '--force[Overwrite existing]' \
            '--template[Template name]:template:' \
            '1:template name:'
          ;;
        project)
          _arguments \
            '--json[Output JSON]' \
            '1:project ID:'
          ;;
        query)
          local -a subcommands=(
            'projects:Query projects'
            'tasks:Query tasks'
            'touched-files:Query touched files'
            'hash:Query hash'
          )
          _describe -t subcommands 'query subcommand' subcommands
          ;;
        docker)
          local -a subcommands=(
            'file:Generate a multi-stage Dockerfile'
            'prune:Prune the workspace for Docker'
            'scaffold:Scaffold project skeleton for Docker'
            'setup:Setup a Dockerfile'
          )
          _describe -t subcommands 'docker subcommand' subcommands
          ;;
        clean)
          _arguments \
            '--lifetime[Cache lifetime]:duration:' \
            '--yes[Skip confirmations]'
          ;;
        completions)
          _arguments '1:shell:(bash zsh fish elvish powershell)'
          ;;
      esac
      ;;
  esac
}

_moon "$@"
