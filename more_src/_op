#compdef op

# Zsh completion for op - 1Password CLI

local curcontext="$curcontext" state line ret=1

_op_formats='--format[output format]:format:(json csv table human-readable)'

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--account[account to use]:account' \
  '--cache[enable caching]' \
  '--no-cache[disable caching]' \
  '--config[config directory]:directory:_files -/' \
  '--encoding[character encoding]:encoding:(utf-8)' \
  '--format[output format]:format:(json csv table human-readable)' \
  '--iso-timestamps[use ISO timestamps]' \
  '--no-color[disable color output]' \
  '--session[session token]:token' \
  '--debug[enable debug output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'account:manage accounts'
      'item:manage items'
      'vault:manage vaults'
      'document:manage documents'
      'user:manage users'
      'group:manage groups'
      'connect:manage Connect servers'
      'events-api:manage Events API'
      'inject:inject secrets into templates'
      'read:read a secret reference'
      'run:run a command with secrets'
      'signin:sign in to an account'
      'signout:sign out of an account'
      'update:update op'
      'whoami:show current user'
      'service-account:manage service accounts'
      'completion:generate shell completion script'
    )
    _describe -t commands 'op command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      account)
        local -a account_cmds=(
          'list:list accounts'
          'add:add an account'
          'get:get account details'
          'forget:forget an account'
        )
        _describe -t commands 'account command' account_cmds && ret=0
        ;;
      item)
        if (( CURRENT == 2 )); then
          local -a item_cmds=(
            'list:list items'
            'get:get an item'
            'create:create an item'
            'edit:edit an item'
            'delete:delete an item'
            'move:move an item'
            'share:share an item'
          )
          _describe -t commands 'item command' item_cmds && ret=0
        else
          case ${line[2]} in
            list)
              _arguments -s \
                '--vault[filter by vault]:vault' \
                '--categories[filter by category]:category' \
                '--tags[filter by tag]:tag' \
                '--favorite[show favorites only]' \
                '--include-archive[include archived items]' \
                '--format[output format]:format:(json csv table human-readable)' && ret=0
              ;;
            get)
              _arguments -s \
                '--vault[vault]:vault' \
                '--fields[fields to retrieve]:field' \
                '--format[output format]:format:(json table human-readable)' \
                '--include-archive[include archived items]' \
                '--otp[get one-time password]' \
                '--reveal[reveal secrets]' \
                ':item' && ret=0
              ;;
            create)
              _arguments -s \
                '--category[item category]:category:(Login Password "Secure Note" Identity "Credit Card" "Bank Account" "API Credential" "SSH Key" Document Database Server "Wireless Router" "Driver License" "Outdoor License" Passport "Email Account" "Reward Program" Membership)' \
                '--vault[vault]:vault' \
                '--title[item title]:title' \
                '--url[item URL]:url' \
                '--generate-password[generate a password]' \
                '--tags[item tags]:tags' && ret=0
              ;;
            edit|delete|move|share)
              _arguments ':item' && ret=0
              ;;
          esac
        fi
        ;;
      vault)
        local -a vault_cmds=(
          'list:list vaults'
          'get:get vault details'
          'create:create a vault'
          'edit:edit a vault'
          'delete:delete a vault'
        )
        if (( CURRENT == 2 )); then
          _describe -t commands 'vault command' vault_cmds && ret=0
        else
          _arguments -s \
            '--format[output format]:format:(json csv table human-readable)' \
            ':vault' && ret=0
        fi
        ;;
      document)
        local -a doc_cmds=(
          'list:list documents'
          'get:get a document'
          'create:create a document'
          'edit:edit a document'
          'delete:delete a document'
        )
        _describe -t commands 'document command' doc_cmds && ret=0
        ;;
      user)
        local -a user_cmds=(
          'list:list users'
          'get:get user details'
          'edit:edit a user'
          'confirm:confirm a user'
          'delete:delete a user'
          'suspend:suspend a user'
          'reactivate:reactivate a suspended user'
          'provision:provision a user'
          'group:manage user group membership'
        )
        _describe -t commands 'user command' user_cmds && ret=0
        ;;
      group)
        local -a group_cmds=(
          'list:list groups'
          'get:get group details'
          'create:create a group'
          'edit:edit a group'
          'delete:delete a group'
        )
        _describe -t commands 'group command' group_cmds && ret=0
        ;;
      connect)
        local -a connect_cmds=(
          'server:manage Connect servers'
          'token:manage Connect tokens'
          'group:manage Connect groups'
          'vault:manage Connect vaults'
        )
        _describe -t commands 'connect command' connect_cmds && ret=0
        ;;
      events-api)
        local -a events_cmds=(
          'create:create an Events API integration'
          'update:update an Events API integration'
          'get:get Events API integration details'
          'delete:delete an Events API integration'
          'list:list Events API integrations'
        )
        _describe -t commands 'events-api command' events_cmds && ret=0
        ;;
      inject)
        _arguments -s \
          '(-i --in-file)'{-i,--in-file}'[input file]:file:_files' \
          '(-o --out-file)'{-o,--out-file}'[output file]:file:_files' \
          '(-f --force)'{-f,--force}'[overwrite output file]' \
          '--account[account to use]:account' && ret=0
        ;;
      read)
        _arguments ':secret reference (op\://vault/item/field)' && ret=0
        ;;
      run)
        _arguments -s \
          '--env-file[environment file]:file:_files' \
          '--no-masking[disable secret masking]' \
          '--account[account to use]:account' \
          '*:command:_command_names' && ret=0
        ;;
      signin)
        _arguments -s \
          '--account[account to use]:account' \
          '--raw[output raw session token]' \
          '--force[force sign in]' && ret=0
        ;;
      signout)
        _arguments -s \
          '--account[account to use]:account' \
          '--forget[forget account after sign out]' && ret=0
        ;;
      completion)
        _arguments -s \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
