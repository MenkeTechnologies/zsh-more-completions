_arguments -s -S \
  '(- *)-?[show help]' \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-conf=[config file]:file:_files' \
  '-datadir=[data directory]:dir:_files -/' \
  '-getinfo[print aggregated info]' \
  '-named[use named args]' \
  '-stdin[read extra args from stdin]' \
  '-stdinrpcpass[read RPC password from stdin]' \
  '-stdinwalletpassphrase[read wallet passphrase from stdin]' \
  '-rpcconnect=[RPC server address]:host:_hosts' \
  '-rpcport=[RPC port]:port:' \
  '-rpcuser=[RPC username]:user:_users' \
  '-rpcpassword=[RPC password]:password:' \
  '-rpccookiefile=[auth cookie file]:file:_files' \
  '-rpcwait[wait for RPC server]' \
  '-rpcwallet=[wallet name]:wallet:' \
  '-rpcclienttimeout=[client timeout seconds]:secs:' \
  '-color=[color output]:when:(auto always never)' \
  '-addrinfo[print address-type counts]' \
  '-generate[wrapper to generate blocks]' \
  '-netinfo[print peer connectivity]' \
  '-chain=[chain]:chain:(main test signet regtest)' \
  '-regtest[use regtest network]' \
  '-testnet[use testnet network]' \
  '-signet[use signet network]' \
  '1: :->method' \
  '*:: :->args' && return

case $state in
  (method)
    _describe -t methods 'RPC method' methods
    ;;
esac
