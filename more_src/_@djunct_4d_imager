#compdef @djunct_4d_imager
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@djunct_4d_imager.html
# View the same slice across the time dimension of a 4D data set

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[access the help documentation]' \
  '-ver[display version number]' \
  '-inset[underlay dataset (required, typically 4D)]:dset:_files' \
  '-prefix[prefix for output files (required)]:prefix' \
  '-do_movie[create movie file]:mtype:(MPEG AGIF)' \
  '-blowup[magnification factor (1-8)]:bb' \
  '-set_dicom_xyz[set controller coordinates in RAI DICOM]:xx' \
  '-no_sepscl[skip separate-scale montage/movie creation]' \
  '-no_onescl[skip consistent-scale montage/movie creation]' \
  '-no_axi[omit axial slice views]' \
  '-no_cor[omit coronal slice views]' \
  '-no_sag[omit sagittal slice views]' \
  '-no_clean[retain temporary directory and intermediate files]' \
  '-echo[execute script with verbose output enabled]' && ret=0

return ret
