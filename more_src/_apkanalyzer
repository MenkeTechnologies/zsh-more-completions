#compdef apkanalyzer

local -a arguments

arguments=(
    '-h[Show help]'
    '--human-readable[Print sizes in human-readable format]'
    '1:category:(apk files manifest dex resources)'
    '*:: :->args'
)

_arguments -s -S $arguments && return

case "$state" in
    args)
        case ${words[1]} in
            apk)
                local -a apk_cmds=(
                    'summary:Print APK summary'
                    'file-size:Print APK file size'
                    'download-size:Print estimated download size'
                    'features:Print features used'
                    'compare:Compare two APKs'
                )
                if (( CURRENT == 2 )); then
                    _describe -t commands 'apk commands' apk_cmds
                else
                    _files -g "*.apk"
                fi
                ;;
            files)
                local -a files_cmds=(
                    'list:List files in APK'
                    'cat:Print file contents'
                )
                if (( CURRENT == 2 )); then
                    _describe -t commands 'files commands' files_cmds
                else
                    _files -g "*.apk"
                fi
                ;;
            manifest)
                local -a manifest_cmds=(
                    'print:Print manifest in XML'
                    'application-id:Print application ID'
                    'version-name:Print version name'
                    'version-code:Print version code'
                    'min-sdk:Print minimum SDK version'
                    'target-sdk:Print target SDK version'
                    'permissions:Print permissions'
                    'debuggable:Print debuggable flag'
                )
                if (( CURRENT == 2 )); then
                    _describe -t commands 'manifest commands' manifest_cmds
                else
                    _files -g "*.apk"
                fi
                ;;
            dex)
                local -a dex_cmds=(
                    'list:List dex files'
                    'references:Print method/field reference counts'
                    'packages:Print dex packages tree'
                    'code:Print bytecode'
                )
                if (( CURRENT == 2 )); then
                    _describe -t commands 'dex commands' dex_cmds
                else
                    _files -g "*.apk"
                fi
                ;;
            resources)
                local -a resources_cmds=(
                    'packages:Print resource packages'
                    'configs:Print resource configurations'
                    'value:Print resource value'
                    'names:Print resource names'
                    'xml:Print XML resource'
                )
                if (( CURRENT == 2 )); then
                    _describe -t commands 'resources commands' resources_cmds
                else
                    _files -g "*.apk"
                fi
                ;;
        esac
        ;;
esac
