#compdef eskip

# eskip: Skipper route file utility
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'check:validate routes'
  'print:format and print routes'
  'patch:patch route filters'
  'upsert:insert/replace routes in storage'
  'delete:delete routes'
  'reset:reset storage'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-f[routes file]:file:_files' \
  '--file=[routes file]:file:_files' \
  '-r[routes inline]:routes:' \
  '--routes=[routes inline]:routes:' \
  '-e[storage etcd URLs]:urls:' \
  '--etcd-urls=[storage etcd URLs]:urls:' \
  '-p[prepend filters]:filters:' \
  '--prepend-filters=[prepend filters]:filters:' \
  '-a[append filters]:filters:' \
  '--append-filters=[append filters]:filters:' \
  '-pretty[pretty print]' \
  '--pretty[pretty print]' \
  '--indent-str=[indent string]:str:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'eskip command' commands && ret=0 ;;
esac
return ret
