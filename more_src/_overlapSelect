#compdef overlapSelect
# UCSC kent: select records based on overlap of chromosome ranges

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-selectFmt=[format of select file]:fmt:(psl genePred bed coordCols)' \
  '-selectCoordCols=[select file coordinate columns spec]:spec:' \
  '-selectCds[use only CDS in select file]' \
  '-selectRange[expand select records to range of contained records]' \
  '-inFmt=[format of input file]:fmt:(psl genePred bed coordCols)' \
  '-inCoordCols=[input file coordinate columns spec]:spec:' \
  '-inCds[use only CDS in input file]' \
  '-inRange[expand input records to range]' \
  '-nonOverlapping[select non-overlapping instead of overlapping]' \
  '-strand[must be on same strand]' \
  '-oppositeStrand[must be on opposite strand]' \
  '-excludeSelf[exclude selecting a record with itself]' \
  '-idMatch[only overlap records with matching id]' \
  '-dropped=[output records that were not selected]:file:_files' \
  '-overlapThreshold=[minimum fraction overlap]:frac:' \
  '-overlapThresholdCeil=[maximum fraction overlap]:frac:' \
  '-overlapSimilarity=[minimum bidirectional overlap fraction]:frac:' \
  '-overlapSimilarityCeil=[maximum bidirectional overlap fraction]:frac:' \
  '-overlapBases=[minimum number of overlapping bases]:n:' \
  '-merge[merge overlapping records]' \
  '-mergeOutput[output input combined with selected record]' \
  '-statsOutput[output overlap statistics instead of records]' \
  '-statsOutputAll[output statistics for all records]' \
  '-statsOutputBoth[output statistics with record]' \
  '-idOutput[output pairs of overlapping ids]' \
  '-aggregate[overlap criteria aggregated over all records]' \
  '-tsv[output TSV header]' \
  '*:file:_files' && ret=0

return ret
