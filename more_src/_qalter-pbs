#compdef qalter
# _qalter-pbs — PBS qalter (modify attributes of one or more queued PBS jobs; same per-attribute flag surface as qsub: -A account, -a date, -c checkpoint, -e/-o stderr/stdout paths, -j join, -l resource_list, -m mail event mask, -M mail user, -N job name, -P project, -p priority, -q queue, -r rerunnable, -W extension list, -W depend=...)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qalter.c on tip.

_qalter-pbs() {
    _arguments \
        '-A+[account]:account:' \
        '-a+[date YYYYMMDDhhmm.ss]:date:' \
        '-c+[checkpoint spec]:spec:' \
        '-e+[stderr path]:path:_files' \
        '-o+[stdout path]:path:_files' \
        '-j+[join]:join:(oe eo n)' \
        '-l+[resource list]:resources:' \
        '-m+[mail mask]:events:(n a b e f s)' \
        '-M+[mail user]:user:_users' \
        '-N+[job name]:name:' \
        '-P+[project]:project:' \
        '-p+[priority]:priority:' \
        '-q+[queue]:queue:' \
        '-r+[rerunnable]:rerunnable:(y n)' \
        '-S+[shell]:shell:_files' \
        '-u+[user list]:user:_users' \
        '-W+[extension list]:list:' \
        '*:jobID:'
}

_qalter-pbs "$@"
