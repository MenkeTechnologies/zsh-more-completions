#compdef pulldown-cmark

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-T[enable tables extension]' \
  '-F[enable footnotes extension]' \
  '-S[enable strikethrough extension]' \
  '-L[enable task lists extension]' \
  '-P[enable smart punctuation]' \
  '-H[enable heading attributes]' \
  '-M[enable metadata blocks]' \
  '--heading-attributes[enable heading attributes]' \
  '-s[dump events instead of rendering]' \
  '*:file:_files -g "*.md"' && ret=0

return ret
