#compdef nightwatch

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[path to configuration file]:file:_files' \
  '--config=[path to configuration file]:file:_files' \
  '-e+[testing environment to use]:environment' \
  '--env=[testing environment to use]:environment' \
  '-t+[run a single test file]:file:_files' \
  '--test=[run a single test file]:file:_files' \
  '--testcase=[name of a single test case to run]:testcase' \
  '-g+[run tests from a specific group]:group' \
  '--group=[run tests from a specific group]:group' \
  '--skipgroup=[skip tests from a specific group]:group' \
  '-f+[filter test files by filename]:filter' \
  '--filter=[filter test files by filename]:filter' \
  '--tag=[filter tests by tag]:tag' \
  '--skiptags=[skip tests by tag]:tag' \
  '--retries=[number of retries for failed testcases]:count' \
  '--suiteRetries=[number of retries for failed test suites]:count' \
  '-r+[name of the test reporter]:reporter:(junit html json)' \
  '--reporter=[name of the test reporter]:reporter:(junit html json)' \
  '-o+[output folder for test reports]:directory:_directories' \
  '--output=[output folder for test reports]:directory:_directories' \
  '--headless[launch the browser in headless mode]' \
  '--devtools[open browser devtools automatically]' \
  '--debug[enable Node.js debugger]' \
  '--parallel[run tests in parallel]' \
  '-w+[number of workers for parallel mode]:count' \
  '--workers=[number of workers for parallel mode]:count' \
  '--timeout=[global timeout in milliseconds]:timeout' \
  '--verbose[output extended test information]' \
  '--serial[run groups of tests sequentially]' \
  '--list-files[list test files and exit]' \
  '--fail-fast[abort after first test failure]' \
  '--reuse-browser[use the same browser session for all tests]' \
  '*:test files:_files' && ret=0

return ret
