#compdef osqueryd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--flagfile=[read flags from file]:file:_files' \
  '--config_path=[config file]:file:_files -g "*.{json,conf}"' \
  '--config_plugin=[config plugin]:plugin:(filesystem tls)' \
  '--config_check[check config and exit]' \
  '--database_path=[database path]:directory:_directories' \
  '--pidfile=[PID file]:file:_files' \
  '--extensions_socket=[extensions socket]:socket:_files' \
  '--logger_plugin=[logger plugin]:plugin:(filesystem tls syslog)' \
  '--logger_path=[logger output path]:directory:_directories' \
  '--verbose[verbose output]' \
  '--debug[debug mode]' \
  '--daemonize[run as daemon]' \
  '-d[run as daemon]' \
  '-S[use syslog]' \
  '--disable_watchdog[disable watchdog]' \
  '--tls_hostname=[TLS hostname]:hostname' \
  '--tls_client_cert=[TLS client certificate]:file:_files' \
  '--tls_client_key=[TLS client key]:file:_files' \
  '--tls_server_certs=[TLS CA certificate]:file:_files' \
  '--enroll_secret_path=[enroll secret file]:file:_files' \
  '--host_identifier=[host identifier]:type:(hostname uuid instance ephemeral)' \
  '--force[force start]' && ret=0

return ret
