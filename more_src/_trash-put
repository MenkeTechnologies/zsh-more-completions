#compdef trash-put

# Zsh completion for trash-put (trash-cli)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-d --directory)'{-d,--directory}'[remove directories]' \
  '(-f --force)'{-f,--force}'[ignore nonexistent files]' \
  '(-i --interactive)'{-i,--interactive}'[prompt before every removal]' \
  '(-r -R --recursive)'{-r,-R,--recursive}'[remove directories and their contents recursively]' \
  '(-v --verbose)'{-v,--verbose}'[explain what is being done]' \
  '*:file:_files' && ret=0

return ret
