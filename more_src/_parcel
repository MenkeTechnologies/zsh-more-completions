#compdef parcel
# Documentation: https://parceljs.org/features/cli/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_parcel_log_levels=(none error warn info verbose)

_parcel() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a _parcel_cmds
  _parcel_cmds=(
    'serve:start a development server (default)'
    'watch:watch and rebuild on changes'
    'build:build for production'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:command:->cmds' \
    '*::arg:->args'

  case "$state" in
    cmds)
      _describe -t commands 'parcel command' _parcel_cmds
      ;;
    args)
      local -a common_args
      common_args=(
        '--target=[target to build (repeatable)]:target:'
        '--dist-dir=[output directory]:dir:_directories'
        '--public-url=[public URL prefix]:url:'
        '--no-source-maps[disable source maps]'
        '--config=[Parcel config file/package]:config:_files'
        '--reporter=[reporter plugin (repeatable)]:reporter:'
        '--log-level=[log level]:level:('"${_parcel_log_levels[*]}"')'
        '--cache-dir=[cache directory]:dir:_directories'
        '--no-cache[disable filesystem cache]'
        '--profile[run CPU sampling profile]'
        '--trace[run trace during build]'
        '*:entry files:_files'
      )

      case $line[1] in
        serve)
          _arguments \
            '(-p --port)'{-p+,--port=}'[dev server port]:port:' \
            '--host=[dev server host]:host:_hosts' \
            '--open=[open in browser]:browser:' \
            '--https[enable HTTPS]' \
            '--cert=[SSL certificate file]:file:_files' \
            '--key=[SSL key file]:file:_files' \
            '--no-hmr[disable hot module replacement]' \
            '--hmr-port=[HMR port]:port:' \
            '--hmr-host=[HMR hostname]:hostname:_hosts' \
            '--no-autoinstall[disable auto install]' \
            '--watch-dir=[root watch directory (monorepos)]:dir:_directories' \
            '--watch-for-stdin[stop when stdin closes]' \
            '--lazy[lazy build]' \
            $common_args
          ;;
        watch)
          _arguments \
            '--no-hmr[disable hot module replacement]' \
            '--hmr-port=[HMR port]:port:' \
            '--hmr-host=[HMR hostname]:hostname:_hosts' \
            '--no-autoinstall[disable auto install]' \
            '--watch-dir=[root watch directory (monorepos)]:dir:_directories' \
            '--watch-for-stdin[stop when stdin closes]' \
            $common_args
          ;;
        build)
          _arguments \
            '--no-optimize[disable optimization]' \
            '--no-scope-hoist[disable scope hoisting]' \
            '--no-content-hash[disable content hashing]' \
            '--detailed-report=[print detailed build report]:depth:' \
            $common_args
          ;;
      esac
      ;;
  esac
}

_parcel "$@"
