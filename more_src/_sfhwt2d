#compdef sfhwt2d
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mhwt2d.c
# Madagascar: 2-D Huygens wavefront tracing traveltimes

local ret=1

_arguments -s -S \
  'verb=[verbosity flag]:verb:(y n)' \
  'rays=[output rays instead of wavefronts]:rays:(y n)' \
  'xsou=[source x location]:xsou' \
  'zsou=[source z location]:zsou' \
  'nt=[number of time steps]:nt' \
  'ot=[time origin]:ot' \
  'dt=[time sampling]:dt' \
  'ng=[number of shooting angles]:ng' \
  'og=[shooting angle origin in degrees]:og' \
  'dg=[shooting angle sampling in degrees]:dg' \
  '*:RSF file:_files' && ret=0

return ret
