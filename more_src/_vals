#compdef vals

# Zsh completion for vals (secrets management)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'eval:evaluate a YAML document and replace secret references'
  'exec:execute a command with secrets in the environment'
  'env:output secrets as environment variables'
  'get:get a single secret value'
  'ksdecode:decode Kubernetes Secret'
  'flatten:flatten a YAML file'
  'version:print version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'vals command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (eval)
        _arguments \
          '(-f --file)'{-f,--file}'[YAML file to evaluate]:file:_files -g "*.yaml *.yml"' \
          '--exclude-secret[exclude secret by key]:key:' \
          '--output[output format]:format:(yaml json)' && ret=0
        ;;
      (exec)
        _arguments \
          '(-f --file)'{-f,--file}'[YAML file with env vars]:file:_files -g "*.yaml *.yml"' \
          '*:command:_command_names -e' && ret=0
        ;;
      (get)
        _arguments '1:secret URI:' && ret=0
        ;;
      (env)
        _arguments \
          '(-f --file)'{-f,--file}'[YAML file]:file:_files -g "*.yaml *.yml"' \
          '--format[output format]:format:(dotenv export json yaml)' && ret=0
        ;;
    esac
    ;;
esac

return ret
