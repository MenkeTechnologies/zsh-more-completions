#compdef git-delete-gone-branches
# Documentation: https://github.com/tj/git-extras/blob/main/man/git-delete-gone-branches.md
# git-extras: delete local branches whose upstream is gone

local ret=1

_arguments -s -S \
  '(-n --dry-run)'{-n,--dry-run}'[show branches that would be deleted without deleting]' \
  '(-f --force)'{-f,--force}'[skip confirmation prompt and delete immediately]' \
  '(-p --prune)'{-p,--prune}'[run git fetch --prune before checking for gone branches]' && ret=0

return ret
