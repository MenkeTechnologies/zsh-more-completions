#compdef orca_euler
# Documentation: https://www.faccts.de/docs/orca/6.0/manual/contents/detailed/utilities.html
# Analyze EPR/NMR tensors and compute Euler angles from an ORCA property file

local ret=1

_arguments -s -S \
  '-refg[use g tensor as reference]' \
  '-refD[use D tensor as reference]' \
  '-conv[Euler rotation convention]:convention:(zyz zxz)' \
  '-plotA[plot HFC tensors]' \
  '-plotQ[plot NQC tensors]' \
  '-detail[extended output]' \
  '*:property file:_files' && ret=0

return ret
