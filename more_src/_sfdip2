#compdef sfdip2
# Documentation: https://www.reproducibility.org/wiki/Guide_to_madagascar_programs
# Madagascar: 2-D dip estimation by plane wave destruction

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'niter=[number of iterations]:niter:' \
  'order=[accuracy order]:order:' \
  'nj=[antialiasing]:nj:' \
  'eps=[regularization]:eps:' \
  'lam=[regularization for lverb]:lam:' \
  'p0=[initial dip]:p0:' \
  'rect1=[dip smoothness on first axis]:rect1:' \
  'rect2=[dip smoothness on second axis]:rect2:' \
  'dip0=[initial dip file]:dip0:_files' \
  'mask=[mask file for missing data]:mask:_files' \
  'gauss=[Gaussian smoothing (y/n)]:gauss:(y n)' \
  'sign=[use signed dip (y/n)]:sign:(y n)' \
  'verb=[verbosity (y/n)]:verb:(y n)' \
  'lverb=[verbosity for linear solver (y/n)]:lverb:(y n)' \
  '*: :_files' && ret=0

return ret
