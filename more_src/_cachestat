#compdef cachestat cachestat-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/cachestat.py argparse)
# Reference accessed: 2026-05-29
# cachestat — VFS page-cache statistics (HITS/MISSES/DIRTIES) by interval (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:interval (seconds, default 1):' \
  '2:count (number of outputs, default unlimited):' \
  && ret=0

return ret
