#compdef kubescape
# Documentation: https://github.com/kubescape/kubescape
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_kubescape_commands() {
  local -a commands=(
    'scan:scan a Kubernetes cluster, manifest files, or images'
    'download:download artifacts for offline/air-gapped use'
    'list:list available frameworks and controls'
    'fix:auto-fix misconfigurations in manifest files'
    'patch:patch container images to fix vulnerabilities'
    'config:manage cached configurations'
    'operator:interact with the in-cluster Kubescape operator'
    'vap:manage Validating Admission Policies'
    'mcpserver:start the MCP server for AI assistant integration'
    'completion:generate shell completion scripts'
    'version:print version information'
    'help:help about any command'
  )
  _describe 'command' commands
}

_kubescape() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--cache-dir=[cache directory]:directory:_directories' \
    '--disable-color[disable color output]' \
    '--enable-color[force color output]' \
    '(-h --help)'{-h,--help}'[help for kubescape]' \
    '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
    '1:command:_kubescape_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        scan)
          _arguments \
            '--compliance-threshold=[compliance threshold (0-100)]:threshold' \
            '--controls-config=[path to controls config]:file:_files' \
            '--exceptions=[path to exceptions file]:file:_files' \
            '--exclude-namespaces=[namespaces to exclude]:namespaces' \
            '--format=[output format]:format:(json junit pdf pretty-printer html sarif)' \
            '--include-namespaces=[namespaces to include]:namespaces' \
            '--kube-context=[Kubernetes context]:context' \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '--severity-threshold=[severity threshold]:severity:(low medium high critical)' \
            '--submit[submit results to Kubescape cloud]' \
            '--use-from=[load a single framework from a local file]:file:_files' \
            '--use-artifacts-from=[load all artifacts from a local directory]:directory:_directories' \
            '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
            '(-h --help)'{-h,--help}'[help for scan]' \
            '*:target:_files'
          ;;
        download)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '(-h --help)'{-h,--help}'[help for download]' \
            '1:type:(framework control exceptions attack-tracks)' \
            '2:name'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[help for list]' \
            '1:type:(frameworks controls)'
          ;;
        fix)
          _arguments \
            '--no-confirm[skip confirmation prompt]' \
            '(-h --help)'{-h,--help}'[help for fix]' \
            '*:file:_files'
          ;;
        config)
          _arguments \
            '1:action:(set get delete view)' \
            '(-h --help)'{-h,--help}'[help for config]'
          ;;
        completion)
          _arguments \
            '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_kubescape "$@"
