#compdef astcrop
# astcrop — crop regions from FITS images

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress extra information]' \
  '--log[store program activity in a log file]' \
  '(-N --numthreads)'{-N,--numthreads}'[number of CPU threads]:number' \
  '--minmapsize[minimum bytes to use memory-mapped files]:size' \
  '--quietmmap[do not report memory-mapped file creation]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[output data type]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--tableformat[output table format]:format:(txt fits-ascii fits-binary)' \
  '(-h --hdu)'{-h,--hdu}'[extension name or number of input]:HDU' \
  '(-I --ignorecase)'{-I,--ignorecase}'[ignore case in matching column names]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and exit]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for current directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for current user]' \
  '--cite[show BibTeX citation for this program]' \
  '--config[configuration file to use]:file:_files' \
  '--checkconfig[print all config files and variables]' \
  '--onlyversion[only run if program version matches]:version' \
  '--searchin[search column metadata]:where:(name unit comment)' \
  '(-O --mode)'{-O,--mode}'[coordinate mode]:mode:(img wcs)' \
  '(-s --section)'{-s,--section}'[image section crop range]:section string' \
  '(-c --center)'{-c,--center}'[central coordinates of crop]:coordinates' \
  '(-w --width)'{-w,--width}'[width of crop box]:width' \
  '(-X --widthinpix)'{-X,--widthinpix}'[width is in pixels even in WCS mode]' \
  '(-l --polygon)'{-l,--polygon}'[polygon vertices or DS9 region file]:polygon' \
  '--polygonout[keep polygon outside, mask inside]' \
  '--polygonsort[sort polygon vertices counter-clockwise]' \
  '(-C --catalog)'{-C,--catalog}'[input catalog filename]:file:_files' \
  '--cathdu[HDU of catalog if FITS table]:HDU' \
  '(-n --namecol)'{-n,--namecol}'[column for crop filename]:column' \
  '(-x --coordcol)'{-x,--coordcol}'[column containing coordinates]:column' \
  '(-z --zeroisnotblank)'{-z,--zeroisnotblank}'[0.0 in float or double images are not blank]' \
  '(-b --noblank)'{-b,--noblank}'[remove parts of crop box outside input image]' \
  '--primaryimghdu[write crop in primary HDU of output]' \
  '--checkcenter[width in pixels of center box to check]:width' \
  '--hstartwcs[header keyword number to start reading WCS]:number' \
  '--hendwcs[header keyword number to stop reading WCS]:number' \
  '(-p --suffix)'{-p,--suffix}'[suffix of cropped images]:suffix' \
  '(-t --oneelemstdout)'{-t,--oneelemstdout}'[print one element value on stdout]' \
  '(-a --metaname)'{-a,--metaname}'[name of output HDU (EXTNAME keyword)]:name' \
  '(-A --append)'{-A,--append}'[append crop to existing output HDUs]' \
  '*:input FITS files:_files -g "*.fits(|.gz|.fz)(N)"'
