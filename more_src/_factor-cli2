#compdef factor-cli2 factor2
# _factor-cli2 — Slava Pestov Factor factor-cli2 CLI command-line frontend wrapping the Factor open-source stack-based concatenative programming language with high-level features including dynamic and static typing extensible syntax macros multimethods and a powerful object system inspired by Forth Joy open-source written in Factor and C originally Slava Pestov now Factor team Factor is a dynamic stack-based programming language Forth-inspired-concatenative natively compiled garbage collected REPL workspace listener UI X11 Cocoa Win32 image-based -run -e -i -no-user-init -roots -script -user-init-file -no-system-init-files -system-init-file -append-vmpath -prepend-vmpath -no-deploy -no-prelude (Slava Pestov Factor team Andrew Cholakian, Factor/C); custom argparse
# upstream: https://factorcode.org/

_factor-cli2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-i+[image]:file:_files -g "*.image"' \
        '-image=+[file]:file:_files -g "*.image"' \
        '-run=+[vocab]:str:' \
        '-e=+[expression]:str:' \
        '-script=+[file]:file:_files -g "*.factor"' \
        '-no-user-init[no user init]' \
        '-roots=+[dirs]:str:' \
        '-user-init-file=+[file]:file:_files -g "*.factor"' \
        '-no-system-init-files[no system init files]' \
        '-system-init-file=+[file]:file:_files' \
        '-append-vmpath=+[dir]:dir:_files -/' \
        '-prepend-vmpath=+[dir]:dir:_files -/' \
        '-no-deploy[no deploy]' \
        '-no-prelude[no prelude]' \
        '-callback-stack-size=+[N]:n:' \
        '-datastack-size=+[N]:n:' \
        '-retainstack-size=+[N]:n:' \
        '-callbacks-size=+[N]:n:' \
        '-fep[FEP]' \
        '-quiet[quiet]' \
        '-tenured-size=+[N]:n:' \
        '-young-size=+[N]:n:' \
        '-aging-size=+[N]:n:' \
        '-code-size=+[N]:n:' \
        '-pic=+[v]:v:(true false)' \
        '-call-counts[call counts]' \
        '-deploy-image[deploy image]' \
        '-deploy-config=+[file]:file:_files' \
        '-include=+[features]:str:' \
        '-exclude=+[features]:str:' \
        '-output-image=+[file]:file:_files' \
        '-deploy-vocab=+[name]:str:' \
        '*:factor file:_files -g "*.factor *.image *.fasl"'
}

_factor-cli2 "$@"
