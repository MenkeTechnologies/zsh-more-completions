#compdef dipy_align_syn
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_align_syn.html
# DIPY: symmetric diffeomorphic (SyN) image registration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--prealign_file=[text file with pre-alignment affine matrix]:file:_files' \
  '--inv_static[apply inverse mapping to static image]' \
  '--level_iters=[iterations at each Gaussian pyramid level]:iters' \
  '--metric=[metric type]:metric:(cc ssd em)' \
  '--mopt_sigma_diff=[CC: Gaussian smoothing kernel std dev]:sigma' \
  '--mopt_radius=[CC: neighborhood radius for correlation]:radius' \
  '--mopt_smooth=[SSD/EM: deformation field smoothness]:val' \
  '--mopt_inner_iter=[SSD/EM: iterations per multi-resolution level]:n' \
  '--mopt_q_levels=[EM: quantization levels]:n' \
  '--mopt_double_gradient[EM: add expected image gradients]' \
  '--mopt_step_type=[SSD/EM optimization schedule]:type:(gauss_newton demons)' \
  '--step_length=[maximum displacement vector length per iteration]:len' \
  '--ss_sigma_factor=[scale-space smoothing kernel parameter]:val' \
  '--opt_tol=[optimization stopping threshold]:tol' \
  '--inv_iter=[displacement field inversion iterations]:n' \
  '--inv_tol=[inversion error stopping threshold]:tol' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_warped=[warped moving image filename]:file:_files' \
  '--out_inv_static=[inverse-mapped static image filename]:file:_files' \
  '--out_field=[diffeomorphic map filename]:file:_files' \
  '*:image (static moving):_files' && ret=0

return ret
