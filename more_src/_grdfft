#compdef grdfft
# Documentation: https://docs.generic-mapping-tools.org/latest/grdfft.html
# Source: GenericMappingTools/gmt classic-mode grdfft — Fourier-domain grid operations (differentiate / integrate / continue / filter / spectrum).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[directional derivative azimuth (compass)]:azim:_default' \
    '-C+[upward/downward continue (m)]:level:_default' \
    '-D+[differentiate (scale or g for geoid→gravity)]:opts:_default' \
    '-E+[power spectrum radial/x/y]:dir:(r x y)' \
    '-F+[filter (cosine-taper / Gaussian / Butterworth)]:opts:_default' \
    '-G+[output grid / 1-D table]:file:_files' \
    '-I+[integrate (scale or g for gravity→geoid)]:opts:_default' \
    '-M+[gravity at 45° latitude (mGal)]:value:_default' \
    '-N+[FFT dims / detrend / extension / taper]:opts:_default' \
    '-Q[skip wavenumber ops (use with -N for intermediates)]' \
    '-S+[scale output (or d for deflection→μrad)]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-f+[I/O column data types]:types:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
