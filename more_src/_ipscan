#compdef ipscan angry-ip-scanner
# _ipscan — Angry IP Scanner ipscan (Java-based fast multi-threaded IP/port scanner; --feeder selects range source (Range / Random / Text), --start startIP, --end endIP, --random number of random IPs, --ports range, --threads max threads, --skip-empty hide unreachable, --quit-after-scan exit when done, --output csv|txt|xml output, --file output file)
# upstream: https://github.com/angryip/ipscan
# Flags from angryip/ipscan src/main/java/net/azib/ipscan on tip.

_ipscan() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--feeder+[feeder]:feeder:(Range Random Text)' \
        '--start+[start IP]:ip:' \
        '--end+[end IP]:ip:' \
        '--random+[random count]:n:' \
        '--ports+[ports list/range]:ports:' \
        '--threads+[max threads]:n:' \
        '--skip-empty[hide unreachable]' \
        '--quit-after-scan[exit after scan]' \
        '--output+[output]:format:(csv txt xml)' \
        '--file+[output file]:file:_files'
}

_ipscan "$@"
