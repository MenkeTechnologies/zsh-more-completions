#compdef kubectl-tail
# Documentation: https://github.com/boz/kail
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-tail = kail. Streams logs across pods matched by selectors.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-l+,--label=}'[match by label selector]:selector:' \
  '*'{-p+,--pod=}'[match pods by name]:pod:' \
  '*'{-n+,--ns=,--namespace=}'[match pods by namespace]:namespace:' \
  '*--svc=[match pods in a service]:svc:' \
  '*--rc=[match pods in a replication controller]:rc:' \
  '*--rs=[match pods in a replica set]:rs:' \
  '*'{-d+,--deploy=}'[match pods in a deployment]:deploy:' \
  '*--sts=[match pods in a statefulset]:sts:' \
  '*'{-j+,--job=}'[match pods in a job]:job:' \
  '*--node=[match pods on a node]:node:' \
  '*--ing=[match pods targeted by ingress]:ing:' \
  '*'{-c+,--containers=}'[restrict containers shown]:container:' \
  '*--ignore=[exclude matching pods]:pattern:' \
  '--current-ns[use current context namespace]' \
  '*--ignore-ns=[ignore specific namespaces]:ns:' \
  '--context=[kubernetes context]:context:' \
  '--dry-run[preview matching pods and exit]' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--log-file=[write output to file]:file:_files' \
  '--since=[show logs since duration]:duration:' \
  '(-o --output)'{-o+,--output=}'[output format]:fmt:(default raw json json-pretty zerolog)'
