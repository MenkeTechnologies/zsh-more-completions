#compdef kubectl-tail
# Documentation: https://man.archlinux.org/search?q=kubectl-tail
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'=[namespace]:namespace' \
  '(-f --follow)'{-f,--follow}'[follow logs]' \
  '--context=[kube context]:context' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--selector=[label selector]:selector' \
  '--timestamps[log timestamps]' \
  '*:pods or args: _default'
