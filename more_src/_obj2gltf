#compdef obj2gltf
# Documentation: https://github.com/CesiumGS/obj2gltf (bin/obj2gltf.js yargs CLI)
# Reference accessed: 2026-05-29
# Wavefront OBJ → glTF/GLB converter (CesiumGS).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --input)'{-i,--input=}'[input OBJ file]:file:_files -g "*.obj"' \
  '(-o --output)'{-o,--output=}'[output glTF or GLB file]:file:_files -g "*.(gltf|glb)"' \
  '(-b --binary)'{-b,--binary}'[save as binary glTF (.glb)]' \
  '(-s --separate)'{-s,--separate}'[write separate buffers and textures]' \
  '(-t --separateTextures)'{-t,--separateTextures}'[write separate textures only]' \
  '--checkTransparency[examine alpha channel of each pixel for transparency]' \
  '--secure[restrict file access to input OBJ directory]' \
  '--packOcclusion[pack occlusion into red channel of metallic-roughness]' \
  '(--metallicRoughness --specularGlossiness)--metallicRoughness[treat MTL values as metallic-roughness PBR]' \
  '(--metallicRoughness --specularGlossiness)--specularGlossiness[treat MTL values as specular-glossiness PBR]' \
  '--unlit[save with KHR_materials_unlit extension]' \
  '--metallicRoughnessOcclusionTexture=[override metallic-roughness-occlusion texture]:file:_files' \
  '--specularGlossinessTexture=[override specular-glossiness texture]:file:_files' \
  '--occlusionTexture=[override occlusion texture]:file:_files' \
  '--normalTexture=[override normal texture]:file:_files' \
  '--baseColorTexture=[override baseColor/diffuse texture]:file:_files' \
  '--emissiveTexture=[override emissive texture]:file:_files' \
  '--alphaTexture=[override alpha texture]:file:_files' \
  '--inputUpAxis=[OBJ up axis (default Y)]:axis:(X Y Z)' \
  '--outputUpAxis=[glTF up axis (default Y)]:axis:(X Y Z)' \
  '--triangleWindingOrderSanitization[apply triangle winding order sanitization]' \
  '--doubleSidedMaterial[enable double-sided material rendering]' \
  '*:file:_files -g "*.obj"' && ret=0

return ret
