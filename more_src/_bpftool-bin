#compdef bpftool
# _bpftool-bin — Linux kernel eBPF inspection tool (kernel tree, kernel-tools); load/list/dump/attach BPF programs and maps
# upstream: https://github.com/libbpf/bpftool

_bpftool-bin() {
    local -a sub=(
        'prog:BPF program operations'
        'map:BPF map operations'
        'link:BPF link operations'
        'cgroup:BPF cgroup attach/detach'
        'perf:perf_event_array operations'
        'net:network device BPF attachment'
        'feature:probe kernel BPF feature support'
        'btf:BTF type info'
        'gen:generate code from BPF skeleton'
        'struct_ops:BPF struct_ops operations'
        'iter:BPF iterator operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-j --json)'{-j,--json}'[JSON output]' \
        '(-p --pretty)'{-p,--pretty}'[pretty JSON output]' \
        '(-d --debug)'{-d,--debug}'[debug]' \
        '(-f --bpffs)'{-f,--bpffs}'[print bpffs paths]' \
        '(-m --mapcompat)'{-m,--mapcompat}'[map compat]' \
        '(-n --nomount)'{-n,--nomount}'[no implicit mount]' \
        '(-l --legacy)'{-l,--legacy}'[legacy map sizes]' \
        '(-B --base-btf)'{-B,--base-btf}'+[base BTF]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bpftool subcommand' sub ;;
        args)
            case $words[1] in
                prog) _arguments '1:prog cmd:(show list dump pin load loadall run profile attach detach tracelog)' '*:args:' ;;
                map) _arguments '1:map cmd:(show list create dump update lookup getnext delete pin event_pipe peek pop enqueue dequeue freeze)' '*:args:' ;;
                cgroup) _arguments '1:cgroup cmd:(show list tree attach detach)' '*:args:_files' ;;
                net) _arguments '1:net cmd:(show list attach detach)' '*:args:' ;;
                btf) _arguments '1:btf cmd:(show list dump)' '*:args:' ;;
                feature) _arguments '1:feature cmd:(probe list_builtins)' '*:args:' ;;
                gen) _arguments '1:gen cmd:(skeleton subskeleton object min_core_btf)' '*:args:_files' ;;
            esac
            ;;
    esac
}

_bpftool-bin "$@"
