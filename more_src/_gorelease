#compdef gorelease
# Documentation: https://man.archlinux.org/search?q=gorelease
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-base[base version or commit to compare against]:version or commit' \
  '-version[proposed release version]:version' && ret=0

return ret
