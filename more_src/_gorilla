#compdef gorilla
# Documentation: https://github.com/gorilla-llm/gorilla-cli
# LLM for CLI commands - generate commands from plain English

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --history)'{-p,--history}'[display command history]' \
  '*:prompt:' && ret=0

return ret
