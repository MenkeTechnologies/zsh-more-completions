#compdef pinot pinot-admin pinot-admin.sh
# Documentation: https://docs.pinot.apache.org/operators/cli
# Reference accessed: 2026-05-16
# Verified: upstream pinot-tools PinotAdministrator.java dispatcher.

# pinot-admin: Apache Pinot administration CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'AddSchema:add schema'
  'AddTable:add table'
  'AddTenant:add tenant'
  'ChangeNumReplicas:change replica count'
  'ChangeTableState:enable/disable table'
  'CheckOfflineSegmentIntervals:check segment intervals'
  'ConvertPinotSegment:convert segment format'
  'CreateSegment:create segment'
  'DeleteCluster:delete cluster'
  'LaunchDataIngestionJob:run data ingestion'
  'MoveReplicaGroup:move replica group'
  'OperateClusterConfig:cluster config ops'
  'PostQuery:post a query'
  'QuickStart:quickstart'
  'RebalanceTable:rebalance table'
  'SegmentProcessorFramework:segment processor'
  'ShowClusterInfo:show cluster info'
  'StartBroker:start broker'
  'StartController:start controller'
  'StartServer:start server'
  'StartServiceManager:start service manager'
  'StartZookeeper:start zookeeper'
  'StartKafka:start Kafka'
  'StopProcess:stop process'
  'UploadSegment:upload segment'
  'ValidateConfig:validate config'
  'ValidateSegment:validate segment'
  'VerifyClusterState:verify cluster state'
)
_arguments -C \
  '-help[show help]' \
  '-controllerHost=[controller host]:host:_hosts' \
  '-controllerPort=[controller port]:port:' \
  '-zkAddress=[ZooKeeper address]:addr:' \
  '-clusterName=[cluster name]:name:' \
  '-tableName=[table name]:name:' \
  '-schemaFile=[schema file]:file:_files -g "*.json"' \
  '-tableConfigFile=[table config file]:file:_files -g "*.json"' \
  '-configFileName=[config file]:file:_files' \
  '-dataDir=[data directory]:dir:_files -/' \
  '-segmentDir=[segment directory]:dir:_files -/' \
  '-format=[format]:format:' \
  '-outDir=[output directory]:dir:_files -/' \
  '-exec[execute (mutating ops)]' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'pinot-admin command' commands && ret=0 ;;
esac
return ret
