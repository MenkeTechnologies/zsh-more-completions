#compdef odyssey
# Documentation: https://github.com/yandex/odyssey
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--test[test configuration and exit]' \
  '--verbose[increase verbosity]' \
  '--daemonize[run as a daemon]' \
  '--pid-file[path to PID file]:pid file:_files' \
  '--log-file[path to log file]:log file:_files' \
  '1:configuration file:_files'
