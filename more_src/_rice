#compdef rice
# Documentation: https://man.archlinux.org/search?q=rice
# Reference accessed: 2026-05-16

# Zsh completion for rice (GeertJohan/go.rice, go-flags)

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(* -i --import-path)'{-i,--import-path}'[Go import path (repeatable)]:import' \
  '(-v --verbose)'{-v,--verbose}'[verbose debug]' \
  '--cpuprofile[write CPU profile]:file:_files' \
  '--memprofile[write memory profile]:file:_files' \
  '--tags+[build tags for embedded package]:tag' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'embed-go:emit embed Go (alias: embed)'
      'embed-syso:experimental embed-syso (currently broken upstream)'
      'append:append zip to an existing executable'
      'clean:remove generated rice files'
    )
    _describe -t commands 'rice command' commands && ret=0
    ;;
  args)
    case $words[1] in
      append)
        _arguments -s -S '--exec[executable to append to]:executable:_files' && ret=0
        ;;
      embed-go|embed-syso|clean) ;;
    esac
    ;;
esac

return ret
