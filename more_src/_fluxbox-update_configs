#compdef fluxbox-update_configs
# Documentation: https://github.com/fluxbox/fluxbox/blob/master/util/fluxbox-update_configs.cc
# Reference accessed: 2026-05-16
# Verified: upstream fluxbox source. X11-style single-dash long options.
# Removed from prior file: fabricated --help/--version flags and bogus
# man.archlinux.org search URL.

# fluxbox-update_configs: migrate Fluxbox configs between versions
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h -help)-h[show help]' \
  '(-h -help)-help[show help]' \
  '-rc[alternate resource configuration file]:file:_files' \
  '-pid[PID to signal fluxbox for reload]:pid:_pids' \
  '-check[compare config version with tool version]' && ret=0
return ret
