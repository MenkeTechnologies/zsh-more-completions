#compdef uvfmeas
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvfmeas.html
# MIRIAD uvfmeas - plot averaged spectrum and fit flux/spectral index

local ret=1

_arguments -s -S \
  'vis=[input uv dataset names (wildcards allowed)]:vis:_files' \
  'select=[standard uv selection commands]:select' \
  'line=[uv linetype (nchan,start,width,step)]:line' \
  'stokes=[polarization types to display]:stokes' \
  'hann=[Hanning smoothing width (odd integer)]:hann' \
  'offset=[RA and DEC positional shift in arcsec]:offset' \
  'order=[order of highest term in polynomial fit]:order' \
  'options=[nocal,nopass,nopol,log,plotvec,uvhist,plotfit,machine,mfflux,malpha,reshist,nolines]:options' \
  'yrange=[y-axis min and max range for plots]:yrange' \
  'device=[PGPLOT output device specification]:device' \
  'nxy=[number of plots in x and y directions]:nxy' \
  'log=[output file for averaged spectral data]:log:_files' \
  'fitp=[coefficients for user-specified fit overlay]:fitp' \
  'feval=[frequency in GHz for flux density evaluation]:feval' \
  '*:visibility data:_files' && ret=0

return ret
