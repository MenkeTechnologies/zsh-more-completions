#compdef mathomatic

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-b[batch mode (no prompt)]' \
  '-c[skip color highlight]' \
  '-d[do not display equation result]' \
  '-e+[evaluate expression]:expr:' \
  '-q[quiet mode]' \
  '-r[disable signals/readline]' \
  '-s+[set security level]:level:(0 1 2 3 4)' \
  '-t[test/script mode]' \
  '-u[unbuffered I/O]' \
  '-w[wide output]' \
  '-x[enable X11 graphing]' \
  '*:file:_files' && ret=0

return ret
