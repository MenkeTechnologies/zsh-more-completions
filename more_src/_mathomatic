#compdef mathomatic
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/mathomatic.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mathomatic uses only short single-letter options (no GNU long forms).
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help and exit]' \
  '(- *)-v[show version and exit]' \
  '-a[enable alternative colors]' \
  '-b[enable bold colors]' \
  '-c[toggle color mode]' \
  '-d[set demo mode]' \
  '-e[process expressions from command line then quit]' \
  '-m+[memory size multiplier]:multiplier:' \
  '-q[quiet mode]' \
  '-r[disable readline input processing]' \
  '-s+[enforced security level]:level:(0 1 2 3 4)' \
  '-t[test mode]' \
  '-u[unbuffered I/O]' \
  '-w[wide output mode]' \
  '-x[enable HTML/XHTML output mode]' \
  '*:file:_files' && ret=0

return ret
