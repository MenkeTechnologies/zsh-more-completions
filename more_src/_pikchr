#compdef pikchr

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--svg-only[output only the SVG without HTML wrapper]' \
  '--dark-mode[render for dark backgrounds]' \
  '--dont-stop[continue processing after errors]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:input file:_files -g "*.pikchr"' && ret=0

return ret
