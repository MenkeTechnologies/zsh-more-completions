#compdef agnos
# Documentation: https://github.com/krtab/agnos
# Source: krtab/agnos src/bin/agnos.rs — Let's Encrypt DNS-01 client with built-in DNS responder (Rust, clap).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--no-color[deactivate colors in output]' \
    '--debug[activate debug output]' \
    '--no-staging[use Lets Encrypt production server]' \
    '--acme-url=[use given URL as ACME server]:url:_default' \
    '--acme-serv-ca=[root cert (PEM) of ACME server HTTPS interface]:file:_files' \
    '--no-wait[do not wait between operations]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[print version]' \
    '1:config.toml:_files -g "*.toml"' \
    && ret=0

return ret
