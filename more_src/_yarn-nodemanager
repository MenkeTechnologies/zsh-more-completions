#compdef yarn-nodemanager
# _yarn-nodemanager — Apache Hadoop YARN NodeManager (per-host launcher; -recover replay local state on start, -format-state-store wipes state, -shutdown-on-out-of-disk; passes --loglevel/--config through to the yarn dispatcher; usually invoked via systemd or yarn-daemon.sh)
# upstream: https://github.com/apache/hadoop
# Flags from Apache Hadoop hadoop-yarn-project hadoop-yarn/hadoop-yarn-server-nodemanager NodeManager.java on tip.

_yarn-nodemanager() {
    _arguments \
        '--help[show help]' \
        '-recover[recover from local state]' \
        '-format-state-store[wipe local state]' \
        '-shutdown-on-out-of-disk[shutdown on disk fault]' \
        '--config+[config dir]:dir:_files -/' \
        '--loglevel+[log level]:level:(TRACE DEBUG INFO WARN ERROR FATAL)' \
        '--daemon=*[daemon mode]:mode:(start status stop)'
}

_yarn-nodemanager "$@"
