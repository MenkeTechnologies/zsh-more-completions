# ePSXe: closed-source PlayStation 1 emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*:PSX disc image:_files -g "*.(iso|cue|bin|img|mdf|pbp|chd|ecm)"' && ret=0
return ret
