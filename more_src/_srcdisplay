#compdef srcdisplay
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/srcdisplay/node5.html
# Display an image overlayed with the positions of detected sources

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--boxlistset=[dataset with source list output from eboxdetect]:file:_files' \
  '--withimageset=[provide a new image dataset]:bool:(yes no)' \
  '--imageset=[image dataset to display source positions on]:file:_files' \
  '--sourceradius=[radius of displayed circles per source, in degrees]:degrees' \
  '--useposerr=[use circle radius as positional error]:bool:(yes no)' \
  '--poserrcol=[column providing position error in arcseconds]:column' \
  '--syserr=[systematic error added in quadrature to position error]:value' \
  '--includesources=[region descriptor includes vs excludes circle area]:bool:(yes no)' \
  '--uselabel=[display row number alongside each source position]:bool:(yes no)' \
  '--withregionfile=[write DS9-format region file for source circles]:bool:(yes no)' \
  '--regionfile=[name of the output region file]:file:_files' \
  '--overlay=[preserve existing region markers]:bool:(yes no)' \
  '--srccolor=[color of source markers]:color:(black white red green blue cyan magenta yellow)' \
  '*:param=value:_default' && ret=0

return ret
