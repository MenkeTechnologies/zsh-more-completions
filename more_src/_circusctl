#compdef circusctl
# Documentation: https://circus.readthedocs.io/en/latest/man/circusctl/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# circusctl: control CLI for the Circus process manager
local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--endpoint=[ZMQ endpoint]:endpoint' \
  '--timeout=[connection timeout]:timeout' \
  '--ssh=[SSH server (user@host:port)]:host' \
  '--ssh_keyfile=[SSH key file]:key file:_files' \
  '--json[output as JSON]' \
  '--prettify[prettify output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'add:add a watcher'
      'decr:decrease number of processes in a watcher'
      'dstats:display process statistics'
      'get:get a watcher option value'
      'globaloptions:show global options'
      'incr:increase number of processes in a watcher'
      'ipython:open an iPython shell'
      'list:list watchers or processes in a watcher'
      'listen:listen to circusd events'
      'listsockets:list sockets'
      'numprocesses:show number of processes'
      'numwatchers:show number of watchers'
      'options:show watcher options'
      'quit:quit the arbiter'
      'reload:reload the arbiter'
      'reloadconfig:reload configuration from file'
      'restart:restart a watcher'
      'rm:remove a watcher'
      'set:set a watcher option'
      'signal:send a signal to a process or watcher'
      'start:start a watcher'
      'stats:show process statistics'
      'status:show watcher status'
      'stop:stop a watcher'
    )
    _describe -t commands 'circusctl command' commands && ret=0
    ;;
  args)
    case $line[1] in
      start|stop|restart|reload|status|stats|options|dstats|list|numprocesses)
        _arguments -s -S \
          '1:watcher name' && ret=0
        ;;
      signal)
        _arguments -s -S \
          '1:watcher name' \
          '2:signal:(HUP INT QUIT KILL TERM USR1 USR2)' && ret=0
        ;;
      set)
        _arguments -s -S \
          '1:watcher name' \
          '2:option:(numprocesses warmup_delay working_dir uid gid send_hup shell cmd priority copy_env copy_path hooks respawn)' \
          '3:value' && ret=0
        ;;
      get)
        _arguments -s -S \
          '1:watcher name' \
          '2:option:(numprocesses warmup_delay working_dir uid gid send_hup shell cmd priority copy_env copy_path hooks respawn)' && ret=0
        ;;
      add)
        _arguments -s -S \
          '1:watcher name' \
          '2:command' && ret=0
        ;;
      rm)
        _arguments -s -S \
          '1:watcher name' && ret=0
        ;;
      incr|decr)
        _arguments -s -S \
          '1:watcher name' \
          '2:number' && ret=0
        ;;
    esac
    ;;
esac

return ret
