#compdef tidy-imports collect-imports collect-exports reformat-imports list-bad-xrefs find-import py replace-star-imports transform-imports prune-broken-imports

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--quiet[quiet output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--debug[debug mode]' \
  '--print[print result to stdout]' \
  '(-i --inplace)'{-i,--inplace}'[edit files in place]' \
  '--diff[show diff only]' \
  '--diff-cmd=[diff command]:cmd:_command_names' \
  '--add-missing[add missing imports]' \
  '--remove-unused[remove unused imports]' \
  '--replace-star-imports[replace star imports]' \
  '--canonicalize[canonicalize import names]' \
  '--separate-from-imports[separate from-imports]' \
  '--align-imports=[alignment]:bool:(true false)' \
  '--from-spaces=[max from spaces]:n:' \
  '--align-future=[future alignment]:bool:(true false)' \
  '--hanging-indent=[hanging indent]:val:' \
  '--max-line-length=[max line length]:n:' \
  '--break-after-import=[break after import]:bool:(true false)' \
  '--align-future=[align future]:bool:(true false)' \
  '--use-known-imports[use known imports DB]' \
  '--actions=[which actions to take csv]:list:' \
  '--always-include-all=[always include __all__]:bool:(true false)' \
  '*:file:_files -g "*.py *.ipynb"' && ret=0

return ret
