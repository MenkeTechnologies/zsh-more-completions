# Documentation: https://github.com/deshaw/pyflyby
# Reference accessed: 2026-05-20
# Verified: pyflyby _cmdline.py source.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--version[show version]' \
  '--debug[debug mode]' \
  '--verbose[verbose stderr]' \
  '--quiet[quiet]' \
  '--actions=[comma-separated actions list]:list:_values -s , actions PRINT REPLACE IFCHANGED QUERY DIFF EXIT1 CHANGEDEXIT1 NOTHING' \
  '(-p --print)'{-p,--print}'[print result to stdout]' \
  '(-d --diff)'{-d,--diff}'[show diff only]' \
  '(-r --replace)'{-r,--replace}'[replace file in place if changed]' \
  '(-R --diff-replace)'{-R,--diff-replace}'[show diff and replace if changed]' \
  '(-i --interactive)'{-i,--interactive}'[interactive prompt]' \
  '--align-imports=[align imports column count]:N' \
  '--align=[align imports column count]:N' \
  '--from-spaces=[spaces after from]:N' \
  '--separate-from-imports[separate from-imports]' \
  '--no-separate-from-imports[do not separate from-imports]' \
  '--align-future[align future imports]' \
  '--no-align-future[do not align future imports]' \
  '--width=[max line width]:N' \
  '--black[format with black-compatible style]' \
  '--hanging-indent=[hanging indent mode]:mode:(never auto always)' \
  '(-u --uniform)'{-u,--uniform}'[uniform formatting]' \
  '(-n --unaligned)'{-n,--unaligned}'[unaligned formatting]' \
  '--symlinks[follow symlinks]' \
  '*:file:_files -g "*.(py|ipynb)"' && ret=0

return ret
