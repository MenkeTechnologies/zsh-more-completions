#compdef sicstus
# Documentation: https://sicstus.sics.se/sicstus/docs/latest4/html/sicstus/Start.html
# sicstus - SICStus Prolog development system

local ret=1

_arguments -s \
  '--help[display a help message and exit]' \
  '-f[fast start: do not read the initialization file on startup]' \
  '-i[forced interactive: prompt for input even if stdin is not a terminal]' \
  '*-l+[ensure file is loaded on startup before any initialization file]:file:_files' \
  '-r+[restore a saved-state on startup]:saved-state:_files' \
  '--goal=-[read a term and pass it to call/1 after all files are loaded]:goal' \
  '--noinfo[start with the informational Prolog flag set off (suppress info messages)]' \
  '--nologo[suppress the identification message and license information]' \
  '-a[pass remaining arguments to Prolog (retrievable via prolog_flag(argv,Args))]:*:argument' \
  '*:file:_files' && ret=0

return ret
