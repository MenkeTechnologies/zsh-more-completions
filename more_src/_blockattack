# blockattack: Tetris Attack / Panel de Pon style puzzle game
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--fullscreen[run in fullscreen mode]' \
  '--window[run in window mode]' \
  '--no-sound[disable sound]' \
  '--no-mouse[disable mouse pointer]' \
  '--vsync[enable vsync]' \
  '--no-vsync[disable vsync]' \
  '--update-check[run online update check]' \
  '--no-update-check[skip online update check]' \
  '--load-replay[load replay file]:file:_files' \
  '--config-dir[config directory]:dir:_files -/' && ret=0
return ret
