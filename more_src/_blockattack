#compdef blockattack
# Documentation: https://man.archlinux.org/search?q=blockattack
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-f[fullscreen]' \
  '-w[windowed]' \
  '--data-dir=+[data dir]:dir:_files -/' && ret=0

return ret
