#compdef berkshelf-cli berks-cli berks
# _berkshelf-cli — Chef Berkshelf cookbook dependency manager for Chef CLI alias (berkshelf team, Ruby); thor
# upstream: https://github.com/berkshelf/berkshelf

_berkshelf-cli() {
    local -a sub=(
        'apply:apply locked versions'
        'contingent:list dependencies'
        'cookbook:create cookbook skeleton'
        'config:manage berkshelf config'
        'config edit:edit config'
        'config show:show config'
        'config generate:generate config'
        'help:show help'
        'info:cookbook info'
        'init:init cookbook'
        'install:install dependencies'
        'list:list cookbooks'
        'outdated:show outdated cookbooks'
        'package:package cookbooks'
        'search:search for cookbooks'
        'shelf:cookbook storage'
        'shelf list:list shelf'
        'shelf show:show shelf entry'
        'shelf uninstall:remove from shelf'
        'show:show cookbook'
        'update:update cookbooks'
        'upload:upload cookbooks'
        'vendor:vendor cookbooks'
        'verify:verify cookbook'
        'version:show version'
        'viz:visualize dependency graph'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-b+[berksfile]:file:_files -g "Berksfile"' \
        '--berksfile=+[berksfile]:file:_files -g "Berksfile"' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--format=+[format]:f:(human json)' \
        '-F+[format]:f:(human json)' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'berks subcommand' sub ;;
        args)
            case $words[1] in
                install|update) _arguments \
                    '*:cookbook:' \
                    '--except=+[group]:str:' \
                    '--only=+[group]:str:' ;;
                upload) _arguments \
                    '*:cookbook:' \
                    '--no-freeze[no freeze]' \
                    '--force[force]' \
                    '--except=+[group]:str:' \
                    '--only=+[group]:str:' \
                    '--halt-on-frozen[halt on frozen]' \
                    '-H+[server]:host:_hosts' \
                    '--server-url=+[server]:host:_hosts' \
                    '--no-ssl-verify[no ssl verify]' \
                    '--ssl-verify-mode=+[mode]:m:(verify_none verify_peer)' \
                    '--client-key=+[file]:file:_files' \
                    '--client-name=+[name]:str:' \
                    '-V[skip dependencies]' \
                    '--skip-dependencies[skip dependencies]' \
                    '--skip-syntax-check[skip syntax check]' \
                    '-r[skip syntax check]' \
                    '--no-rake-tasks[no rake tasks]' \
                    '--validate[validate]' ;;
                vendor) _arguments '1:path:_files -/' ;;
                cookbook) _arguments \
                    '1:name:' \
                    '--license=+[license]:l:(none reserved apachev2 mit gplv2 gplv3)' \
                    '--maintainer=+[name]:str:' \
                    '--maintainer-email=+[email]:str:' \
                    '--skip-vagrant[skip vagrant]' \
                    '--skip-test-kitchen[skip test-kitchen]' \
                    '--skip-git[skip git]' \
                    '--no-git[no git]' \
                    '--foodcritic[include foodcritic]' \
                    '--no-foodcritic[exclude foodcritic]' ;;
                init) _arguments '1:path:_files -/' ;;
                package) _arguments '1:tarball file:_files' '*:cookbook:' ;;
            esac
            ;;
    esac
}

_berkshelf-cli "$@"
