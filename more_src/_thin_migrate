#compdef thin_migrate

# thin_migrate: migrate device-mapper thin volumes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-i --input)'{-i,--input=}'[source thin device]:file:_files' \
  '(-o --output)'{-o,--output=}'[destination device]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[no progress]' \
  '*::thin_migrate args:_files' && ret=0
return ret
