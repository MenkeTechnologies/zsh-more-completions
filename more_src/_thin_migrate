#compdef thin_migrate
# Documentation: https://man.archlinux.org/search?q=thin_migrate
# Reference accessed: 2026-05-16

# thin_migrate: stream a thin volume's data to another device
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '--source-dev=[source device]:dev:_files' \
  '--dest-dev=[destination device]:dev:_files' \
  '--source-meta=[source metadata file]:file:_files' \
  '--source-thinpool=[source thin-pool LV]:pool:' \
  '--source-thin-id=[source thin device id]:id:' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '--zero-dest[zero unallocated regions of dest]' \
  '--buffer-size-meg=[transfer buffer size MiB]:n:' \
  '*::thin_migrate args:_files' && ret=0
return ret
