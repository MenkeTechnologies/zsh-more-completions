#compdef isubset
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Produce a subset of an image

local ret=1

_arguments -s -S \
  'IMAGE=[image to take a subset from]:image:_files' \
  'YSTART=[first Y pixel of subset]:ystart:' \
  'YEND=[last Y pixel of subset]:yend:' \
  'XSTART=[first X pixel of subset]:xstart:' \
  'XEND=[last X pixel of subset]:xend:' \
  'OUTPUT=[resulting subset image]:output:_files' \
  '*:NDF data file:_files' && ret=0

return ret
