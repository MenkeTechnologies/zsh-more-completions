#compdef influx

# Zsh completion for InfluxDB CLI (influx v2)

local curcontext="$curcontext" state line ret=1

local -a influx_commands
influx_commands=(
  'apply:apply a template to manage resources'
  'auth:authorization management commands'
  'backup:backup database'
  'bucket:bucket management commands'
  'bucket-schema:bucket schema management'
  'completion:output shell completion code'
  'config:config management commands'
  'dashboards:list dashboards'
  'delete:delete points from InfluxDB'
  'export:export resources as a template'
  'org:organization management commands'
  'ping:check the InfluxDB /health endpoint'
  'query:execute a Flux query'
  'remote:remote connection management'
  'replication:replication stream management'
  'restore:restore backup data and metadata'
  'scripts:scripts management commands'
  'secret:secret management commands'
  'setup:setup InfluxDB instance'
  'stacks:manage stacks'
  'task:task management commands'
  'telegrafs:Telegraf management commands'
  'template:summarize and validate a template'
  'user:user management commands'
  'v1:InfluxDB v1 commands'
  'version:print the influx CLI version'
  'write:write points to InfluxDB'
)

local -a influx_global_flags
influx_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--host=[InfluxDB HTTP address]:host url:'
  '--skip-verify[skip TLS certificate verification]'
  '-t=[API token]:token:'
  '--token=[API token]:token:'
  '--configs-path=[path to config files]:path:_files'
  '-c=[config name to use]:config name:'
  '--active-config=[config name to use]:config name:'
  '--http-debug[inspect communication with InfluxDB]'
)

_arguments -s -S \
  $influx_global_flags \
  '--version[print version]' \
  '1:command:_describe -t commands command influx_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      setup)
        _arguments -s -S \
          $influx_global_flags \
          '-u=[primary username]:username:' \
          '--username=[primary username]:username:' \
          '-p=[primary password]:password:' \
          '--password=[primary password]:password:' \
          '-o=[primary organization name]:org:' \
          '--org=[primary organization name]:org:' \
          '-b=[primary bucket name]:bucket:' \
          '--bucket=[primary bucket name]:bucket:' \
          '-r=[retention period]:retention:' \
          '--retention=[retention period]:retention:' \
          '-n=[config name to set]:name:' \
          '--name=[config name to set]:name:' \
          '-f[skip confirmation prompt]' \
          '--force[skip confirmation prompt]' && ret=0
        ;;
      write)
        _arguments -s -S \
          $influx_global_flags \
          '-b=[bucket name]:bucket:' \
          '--bucket=[bucket name]:bucket:' \
          '--bucket-id=[bucket ID]:bucket id:' \
          '--compression=[input compression]:compression:(none gzip)' \
          '--encoding=[character encoding of input]:encoding:' \
          '--errors-file=[path to write rejected lines]:file:_files' \
          '-f=[file to import]:file:_files' \
          '--file=[file to import]:file:_files' \
          '--format=[input format]:format:(lp csv)' \
          '--header=[prepend header line to CSV input]:header:' \
          '--max-line-length=[max line length]:bytes:' \
          '-o=[organization name]:org:' \
          '--org=[organization name]:org:' \
          '--org-id=[organization ID]:org id:' \
          '-p=[line protocol precision]:precision:(ns us ms s)' \
          '--precision=[line protocol precision]:precision:(ns us ms s)' \
          '--rate-limit=[rate limit]:rate:' \
          '--skipHeader=[skip header rows]:count:' \
          '--skipRowOnError[skip rows with errors]' \
          '-u=[file URL to import]:url:' \
          '--url=[file URL to import]:url:' && ret=0
        ;;
      query)
        _arguments -s -S \
          $influx_global_flags \
          '-f=[path to Flux query file]:file:_files' \
          '--file=[path to Flux query file]:file:_files' \
          '-o=[organization name]:org:' \
          '--org=[organization name]:org:' \
          '--org-id=[organization ID]:org id:' \
          '-r[format results as raw annotated CSV]' \
          '--raw[format results as raw annotated CSV]' \
          '--profilers=[Flux profilers to enable]:profilers:' \
          '1:Flux query:' && ret=0
        ;;
      delete)
        _arguments -s -S \
          $influx_global_flags \
          '-b=[bucket name]:bucket:' \
          '--bucket=[bucket name]:bucket:' \
          '--bucket-id=[bucket ID]:bucket id:' \
          '-o=[organization name]:org:' \
          '--org=[organization name]:org:' \
          '--org-id=[organization ID]:org id:' \
          '-p=[delete predicate]:predicate:' \
          '--predicate=[delete predicate]:predicate:' \
          '--start=[start time]:time:' \
          '--stop=[stop time]:time:' && ret=0
        ;;
      bucket)
        local -a bucket_commands
        bucket_commands=(
          'create:create a bucket'
          'delete:delete a bucket'
          'list:list buckets'
          'update:update a bucket'
        )
        _arguments -s -S \
          $influx_global_flags \
          '1:bucket command:_describe -t commands command bucket_commands' \
          '*::bucket args:->bucket_args' && ret=0
        case "$state" in
          bucket_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  $influx_global_flags \
                  '-d=[bucket description]:description:' \
                  '--description=[bucket description]:description:' \
                  '-n=[bucket name]:name:' \
                  '--name=[bucket name]:name:' \
                  '-o=[organization name]:org:' \
                  '--org=[organization name]:org:' \
                  '--org-id=[organization ID]:org id:' \
                  '-r=[retention period]:retention:' \
                  '--retention=[retention period]:retention:' \
                  '--shard-group-duration=[shard group duration]:duration:' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  $influx_global_flags \
                  '-i=[bucket ID]:bucket id:' \
                  '--id=[bucket ID]:bucket id:' \
                  '-n=[bucket name]:name:' \
                  '--name=[bucket name]:name:' \
                  '-o=[organization name]:org:' \
                  '--org=[organization name]:org:' \
                  '--org-id=[organization ID]:org id:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $influx_global_flags \
                  '-i=[bucket ID]:bucket id:' \
                  '--id=[bucket ID]:bucket id:' \
                  '--json[output in JSON format]' \
                  '--limit=[number of buckets]:limit:' \
                  '-n=[bucket name]:name:' \
                  '--name=[bucket name]:name:' \
                  '--offset=[pagination offset]:offset:' \
                  '-o=[organization name]:org:' \
                  '--org=[organization name]:org:' \
                  '--org-id=[organization ID]:org id:' && ret=0
                ;;
              update)
                _arguments -s -S \
                  $influx_global_flags \
                  '-d=[bucket description]:description:' \
                  '--description=[bucket description]:description:' \
                  '-i=[bucket ID]:bucket id:' \
                  '--id=[bucket ID]:bucket id:' \
                  '-n=[bucket name]:name:' \
                  '--name=[bucket name]:name:' \
                  '-r=[retention period]:retention:' \
                  '--retention=[retention period]:retention:' \
                  '--shard-group-duration=[shard group duration]:duration:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      org)
        local -a org_commands
        org_commands=(
          'create:create an organization'
          'delete:delete an organization'
          'list:list organizations'
          'members:organization members management'
          'update:update an organization'
        )
        _arguments -s -S \
          $influx_global_flags \
          '1:org command:_describe -t commands command org_commands' \
          '*::org args:' && ret=0
        ;;
      user)
        local -a user_commands
        user_commands=(
          'create:create a user'
          'delete:delete a user'
          'list:list users'
          'password:update a user password'
          'update:update a user'
        )
        _arguments -s -S \
          $influx_global_flags \
          '1:user command:_describe -t commands command user_commands' \
          '*::user args:' && ret=0
        ;;
      auth)
        local -a auth_commands
        auth_commands=(
          'create:create an authorization'
          'delete:delete an authorization'
          'inactive:inactivate an authorization'
          'list:list authorizations'
          'active:activate an authorization'
        )
        _arguments -s -S \
          $influx_global_flags \
          '1:auth command:_describe -t commands command auth_commands' \
          '*::auth args:' && ret=0
        ;;
      task)
        local -a task_commands
        task_commands=(
          'create:create a task'
          'delete:delete a task'
          'list:list tasks'
          'log:log related commands'
          'retry-failed:retry failed runs'
          'run:run related commands'
          'update:update a task'
        )
        _arguments -s -S \
          $influx_global_flags \
          '1:task command:_describe -t commands command task_commands' \
          '*::task args:' && ret=0
        ;;
      backup)
        _arguments -s -S \
          $influx_global_flags \
          '-b=[bucket name]:bucket:' \
          '--bucket=[bucket name]:bucket:' \
          '--bucket-id=[bucket ID]:bucket id:' \
          '--compression=[compression type]:compression:(none gzip)' \
          '-o=[organization name]:org:' \
          '--org=[organization name]:org:' \
          '--org-id=[organization ID]:org id:' \
          '1:output path:_directories' && ret=0
        ;;
      restore)
        _arguments -s -S \
          $influx_global_flags \
          '-b=[bucket name]:bucket:' \
          '--bucket=[bucket name]:bucket:' \
          '--bucket-id=[bucket ID]:bucket id:' \
          '--full[perform a full restore]' \
          '--new-bucket=[new bucket name]:name:' \
          '--new-org=[new organization name]:name:' \
          '-o=[organization name]:org:' \
          '--org=[organization name]:org:' \
          '--org-id=[organization ID]:org id:' \
          '1:input path:_directories' && ret=0
        ;;
      config)
        local -a config_commands
        config_commands=(
          'create:create a config'
          'delete:delete a config'
          'list:list configs'
          'set:update a config'
        )
        _arguments -s -S \
          $influx_global_flags \
          '1:config command:_describe -t commands command config_commands' \
          '*::config args:' && ret=0
        ;;
      secret)
        local -a secret_commands
        secret_commands=(
          'delete:delete a secret'
          'list:list secrets'
          'update:update a secret'
        )
        _arguments -s -S \
          $influx_global_flags \
          '1:secret command:_describe -t commands command secret_commands' \
          '*::secret args:' && ret=0
        ;;
      completion)
        _arguments -s -S \
          $influx_global_flags \
          '1:shell:(bash zsh)' && ret=0
        ;;
      *)
        _arguments -s -S $influx_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
