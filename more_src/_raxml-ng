#compdef raxml-ng
# Documentation: https://github.com/amkozlov/raxml-ng/wiki/Tutorial
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# RAxML-NG: next-generation Randomized Axelerated ML inference
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--all[combined ML + bootstrap analysis]' \
  '--search[ML tree search only]' \
  '--evaluate[evaluate tree given alignment+model]' \
  '--bootstrap[bootstrap analysis only]' \
  '--check[validate alignment, no analysis]' \
  '--parse[parse alignment, write binary, no analysis]' \
  '--start[start tree generation only]' \
  '--rfdist[compute Robinson-Foulds distances]' \
  '--ancestral[ancestral state reconstruction]' \
  '--terrace[terrace exploration]' \
  '--consense[compute consensus tree]:type:(MR MRE STRICT)' \
  '--support[map support values onto tree]' \
  '--bsconverge[bootstrap convergence test]' \
  '--bsmsa[bootstrap MSA test]' \
  '--mrcabranch[plot MRCA branch annotations]' \
  '--workers[number of worker threads]:n:' \
  '--threads[total threads]:n:' \
  '--seed[random seed]:n:' \
  '--prefix[output prefix]:prefix:' \
  '--msa[MSA file]:file:_files' \
  '--msa-format[MSA format]:fmt:(FASTA PHYLIP CATG VCF)' \
  '--data-type[data type]:type:(DNA AA AUTO)' \
  '--model[evolutionary model spec or model file]:model:' \
  '--brlen[branch length type]:type:(scaled linked unlinked)' \
  '--opt-model[optimize model parameters]:opt:(on off)' \
  '--opt-branches[optimize branch lengths]:opt:(on off)' \
  '--lh-epsilon[likelihood epsilon for convergence]:val:' \
  '--spr-radius[SPR radius for search]:n:' \
  '--spr-cutoff[SPR cutoff value]:val:' \
  '--tree[starting tree file or method]:val:' \
  '--bs-trees[bootstrap trees specification]:val:' \
  '--bs-cutoff[bootstrap convergence cutoff]:val:' \
  '--bs-metric[bootstrap metric]:metric:(fbp tbe)' \
  '--site-weights[site weights file]:file:_files' \
  '--simd[force SIMD instructions]:simd:(auto none sse3 avx avx2)' \
  '--rate-scalers[enable per-rate scalers]:opt:(on off)' \
  '--force[force run even on suspicious input]:check:(perf_threads model_lh_impr fixed_brlen_outgroup)' \
  '--redo[overwrite previous output files]' \
  '*:alignment file:_files' && ret=0
return ret
