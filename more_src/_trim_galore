#compdef trim_galore
# Documentation: https://github.com/FelixKrueger/TrimGalore
# Reference accessed: 2026-05-27
# Verified: upstream FelixKrueger/TrimGalore src/cli.rs (clap CLI definition for the Rust v2.x rewrite).

# Zsh completion for trim_galore (quality/adapter trimmer).

_arguments -s \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '*--input=[input FASTQ file(s)]:file:_files' \
  '(-o --output_dir)'{-o+,--output_dir=}'[output directory]:dir:_files -/' \
  '--basename=[custom output basename]:name:' \
  '--dont_gzip[do not gzip output files]' \
  '(-q --quality)'{-q+,--quality=}'[Phred quality cutoff (default 20)]:int:' \
  '*'{-a+,--adapter=}'[adapter sequence(s)]:seq:' \
  '*--adapter2=[read-2 adapter (paired-end)]:seq:' \
  '(-e --error_rate)'{-e+,--error_rate=}'[max error rate]:float:' \
  '--stringency=[min adapter overlap]:int:' \
  '(-n --times)'{-n+,--times=}'[adapter trimming rounds]:int:' \
  '--discard_untrimmed[discard reads without adapters]' \
  '--illumina[Illumina universal adapter]' \
  '--nextera[Nextera transposase adapter]' \
  '--small_rna[small RNA adapter]' \
  '--stranded_illumina[stranded mRNA adapter]' \
  '--bgiseq[BGI/DNBSEQ adapter]' \
  '--length=[min read length after trimming]:int:' \
  '--max_length=[max read length]:int:' \
  '--max_n=[max N bases allowed]:float:' \
  '--trim_n[trim N bases from both ends]' \
  '--clip_R1=[bases to remove from R1 5 prime]:int:' \
  '--clip_R2=[bases to remove from R2 5 prime]:int:' \
  '--three_prime_clip_R1=[bases to remove from R1 3 prime]:int:' \
  '--three_prime_clip_R2=[bases to remove from R2 3 prime]:int:' \
  '--poly_a[trim poly-A/poly-T tails]' \
  '--poly_g[force poly-G trimming]' \
  '--no_poly_g[disable poly-G detection]' \
  '--phred33[Phred+33 quality encoding (default)]' \
  '--phred64[Phred+64 quality encoding]' \
  '--nextseq=[NextSeq 2-color trim cutoff]:int:' \
  '--paired[paired-end mode]' \
  '--retain_unpaired[keep unpaired survivors]' \
  '(-r --length_1)'{-r+,--length_1=}'[min length for unpaired R1]:int:' \
  '--length_2=[min length for unpaired R2]:int:' \
  '--hardtrim5=[keep only first N bases]:int:' \
  '--hardtrim3=[keep only last N bases]:int:' \
  '--clock[epigenetic clock UMI extraction]' \
  '--implicon=[IMPLICON UMI preprocessing]:int:' \
  '--demux=[demultiplex by inline barcodes]:file:_files' \
  '--rrbs[RRBS mode (MspI digestion)]' \
  '--non_directional[non-directional RRBS]' \
  '(-j --cores)'{-j+,--cores=}'[worker threads (default 1)]:int:' \
  '--clumpify[reorder reads for gzip compression]' \
  '--compression=[gzip level 1-9]:int:' \
  '--memory=[memory budget (e.g. 1G)]:size:' \
  '--fastqc[run FastQC on output]' \
  '--fastqc_args=[args to pass to FastQC]:args:' \
  '--no_report_file[skip writing trimming report]' \
  '--rename[append clipped sequences to read IDs]' \
  '--consider_already_trimmed=[skip if adapters at or below threshold]:int:' \
  '*:files:_files'
