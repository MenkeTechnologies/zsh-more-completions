#compdef flyteadmin

# Flyte Admin control plane
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'serve:run flyteadmin server'
  'migrate:run database migration'
  'secrets:secrets subcommands'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'flyteadmin command' commands && ret=0 ;;
esac
return ret
