#compdef flyteadmin
# Documentation: https://github.com/flyteorg/flyte/tree/v1.13.3/flyteadmin/cmd/entrypoints
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Flyte Admin control plane

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'serve:run flyteadmin server'
  'migrate:run database migration'
  'clusterresource:manage cluster resource template provisioning'
  'k8s_secret:k8s secret subcommands'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[config file (default ./flyteadmin_config.yaml)]:file:_files' \
  '--master=[Kubernetes API server address]:url:' \
  '--logtostderr[log to stderr]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'flyteadmin command' commands && ret=0 ;;
esac

return ret
