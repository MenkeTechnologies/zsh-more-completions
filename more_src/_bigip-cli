#compdef bigip-cli bigipctl f5-cli f5ctl
# _bigip-cli — F5 Networks bigip-cli CLI command-line frontend to the F5 BIG-IP iControl REST API managing virtual servers pools nodes monitors profiles iRules SSL TLS-cert routes datagroups partitions LTM GTM AS3 declarative-onboarding application-services-3 telemetry-streaming for F5 load balancer (F5 Networks team, Python); click
# upstream: https://www.f5.com/

_bigip-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'virtual:virtual server management'
        'pool:pool management'
        'node:node management'
        'monitor:monitor management'
        'profile:profile management'
        'irule:iRule management'
        'ssl:SSL TLS cert management'
        'cert:certificate management'
        'route:route management'
        'datagroup:data group management'
        'partition:partition management'
        'snat:SNAT management'
        'as3:AS3 declarative app services'
        'do:Declarative Onboarding'
        'ts:Telemetry Streaming'
        'cm:cluster management'
        'sys:system configuration'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--host=+[host]:_hosts' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '--partition=+[name]:str:' \
        '--insecure[skip TLS verify]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml table)' \
        '--format=+[format]:f:(json yaml table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bigip-cli subcommand' sub ;;
        args)
            case $words[1] in
                virtual|pool|node|monitor|profile|irule|ssl|cert|route|datagroup|partition|snat) _arguments '1:op:(list get create update delete enable disable)' '*:name:' ;;
                as3|do|ts) _arguments '1:op:(post get delete)' '*:file:_files -g "*.json"' ;;
            esac
            ;;
    esac
}

_bigip-cli "$@"
