#compdef lvmsadc
# Documentation: https://man.archlinux.org/search?q=lvmsadc
# Reference accessed: 2026-05-16

# lvmsadc: read-only LVM statistics collector (deprecated)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-d[debug level]:level:' \
  '*:VG name:' && ret=0
return ret
