#compdef wtype

# Zsh completion for wtype - Wayland xdotool replacement

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --delay)'{-d,--delay}'[delay between keystrokes in milliseconds]:ms' \
  '(-s --sleep)'{-s,--sleep}'[sleep before start in milliseconds]:ms' \
  '(-k --key)'{-k,--key}'[press a key]:key name' \
  '(-M --modifier)'{-M,--modifier}'[hold modifier]:modifier:(shift ctrl alt logo)' \
  '(-m --modifier-up)'{-m,--modifier-up}'[release modifier]:modifier:(shift ctrl alt logo)' \
  '(-P --key-down)'{-P,--key-down}'[press key down]:key name' \
  '(-p --key-up)'{-p,--key-up}'[release key]:key name' \
  '*:text to type'
