#compdef kubectl-ai
# Documentation: https://github.com/sozercan/kubectl-ai
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-n --namespace)'{-n,--namespace}'=[Kubernetes namespace]:namespace:' \
  '(-k --kubeconfig)'{-k,--kubeconfig}'=[Kubeconfig path]:file:_files' \
  '(-m --model)'{-m,--model}'=[LLM model]:model:' \
  '(-yes)'--yes'[Auto-approve actions]' \
  '*::prompt or args: _default'
