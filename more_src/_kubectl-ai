#compdef kubectl-ai
# Documentation: https://github.com/sozercan/kubectl-ai/blob/main/cmd/cli/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '-openai-deployment-name=[deployment name used for the model]:name:' \
  '-openai-api-key=[API key for the OpenAI service]:key:' \
  '-openai-endpoint=[endpoint for the OpenAI service]:url:' \
  '*-azure-openai-map=[mapping from OpenAI model to Azure deployment]:map:' \
  '-require-confirmation=[require confirmation before executing]:bool:(true false)' \
  '-temperature=[temperature to use for the model (0-1)]:temp:' \
  '-raw[print the raw YAML output immediately]' \
  '-use-k8s-api[use the Kubernetes API to create resources]' \
  '-k8s-openapi-url=[URL to a Kubernetes OpenAPI spec]:url:' \
  '-debug[print debug logs]' \
  '*::prompt or args: _default'
