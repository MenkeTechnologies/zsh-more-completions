#compdef wayfire
# Documentation: https://man.archlinux.org/search?q=wayfire
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'+[config file path]:config:_files -g "*.ini(-.)"' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-D --damage-debug)'{-D,--damage-debug}'[enable damage debug mode]' \
  '--damage-rerender[rerender every frame]' && ret=0

return ret
