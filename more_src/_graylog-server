#compdef graylog-server
# Documentation: https://archivedocs.graylog.org/en/latest/pages/installation/manual_setup.html
# Graylog server process startup parameters

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-f --configfile)'{-f,--configfile}'=[use configuration file]:config file:_files' \
  '(-d --debug)'{-d,--debug}'[run in debug mode]' \
  '(-l --local)'{-l,--local}'[run in local mode]' \
  '(-p --pidfile)'{-p,--pidfile}'=[set PID file path]:pid file:_files' \
  '(-np --no-pid-file)'{-np,--no-pid-file}'[do not write PID file]' \
  '--version[show version and exit]' \
  '*::arg:_files' && ret=0

return ret
