#compdef oct-propagation_spectrum
# Documentation: https://www.octopus-code.org/documentation/main/manual/utilities/oct-propagation_spectrum/
# Octopus: process multipoles files to obtain the propagation spectrum

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help and exit]' \
  '(-v --version)'{-v,--version}'[print octopus version]' \
  '(-r --reference)'{-r,--reference}'[name of the reference multipoles file]:reference file:_files' && ret=0

return ret
