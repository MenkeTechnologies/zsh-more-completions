#compdef wekan-cli wekan
# _wekan-cli — Wekan open-source Trello-like kanban CLI alias (wekan team, JavaScript); custom argparse over REST API
# upstream: https://github.com/wekan/wekan

_wekan-cli() {
    local -a sub=(
        'login:save credentials'
        'logout:clear credentials'
        'me:show current user'
        'user:list:list users'
        'user:create:create user'
        'user:delete:delete user'
        'user:update:update user'
        'board:list:list boards'
        'board:create:create board'
        'board:get:get board'
        'board:update:update board'
        'board:delete:delete board'
        'board:archive:archive board'
        'board:unarchive:unarchive board'
        'board:export:export board'
        'board:import:import board'
        'list:list:list lists on board'
        'list:create:create list'
        'list:delete:delete list'
        'list:archive:archive list'
        'list:unarchive:unarchive list'
        'swimlane:list:list swimlanes'
        'swimlane:create:create swimlane'
        'swimlane:delete:delete swimlane'
        'card:list:list cards'
        'card:create:create card'
        'card:get:get card'
        'card:update:update card'
        'card:delete:delete card'
        'card:move:move card'
        'card:copy:copy card'
        'card:archive:archive card'
        'card:assign:assign card'
        'card:checklist:list:list checklists'
        'card:checklist:add:add checklist'
        'card:checklist:item:add:add item'
        'card:checklist:item:complete:complete item'
        'card:comment:list:list comments'
        'card:comment:add:add comment'
        'card:label:add:add label'
        'card:label:remove:remove label'
        'label:list:list labels'
        'label:create:create label'
        'label:delete:delete label'
        'attachment:list:list attachments'
        'attachment:add:add attachment'
        'attachment:remove:remove attachment'
        'attachment:download:download attachment'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--url=+[wekan url]:url:_urls' \
        '--user=+[username]:user:_users' \
        '--password=+[password]:str:' \
        '--token=+[api token]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wekan subcommand' sub ;;
        args)
            case $words[1] in
                board:create) _arguments \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--owner=+[owner id]:str:' \
                    '--permission=+[permission]:p:(public private)' \
                    '--color=+[color]:str:' ;;
                card:create) _arguments \
                    '--board-id=+[board id]:str:' \
                    '--list-id=+[list id]:str:' \
                    '--swimlane-id=+[swimlane id]:str:' \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--description=+[description]:str:' \
                    '--author-id=+[author id]:str:' \
                    '--members=+[members csv]:str:' \
                    '--assignees=+[assignees csv]:str:' \
                    '--label-ids=+[label ids csv]:str:' \
                    '--due-at=+[due iso8601]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_wekan-cli "$@"
