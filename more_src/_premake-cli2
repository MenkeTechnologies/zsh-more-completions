#compdef premake-cli2 premake5_2
# _premake-cli2 — Jason Perkins premake-cli2 CLI command-line frontend wrapping the Premake powerful cross-platform build system written in C and Lua open-source originally Jason Perkins reads premake5.lua workspace project script and generates Visual Studio Xcode GMake Codelite Codeblocks Codeexpress make Codeblocks-LZ-PMD CodeWeavers project files makefiles and IDE solutions for the major build systems gmake gmake2 vs2005 vs2008 vs2010 vs2012 vs2013 vs2015 vs2017 vs2019 vs2022 xcode codelite codeblocks codeexpress export-compile-commands clean test scripts (Jason Perkins team, C/Lua); custom argparse
# upstream: https://premake.github.io/

_premake-cli2() {
    local -a actions
    actions=(
        'codeblocks:Generate Code::Blocks project files'
        'codelite:Generate CodeLite project files'
        'gmake:Generate GNU makefiles for Posix Cygwin MSYS'
        'gmake2:Generate GNU makefiles for v2 implementation'
        'vs2005:Generate Visual Studio 2005 project files'
        'vs2008:Generate Visual Studio 2008 project files'
        'vs2010:Generate Visual Studio 2010 project files'
        'vs2012:Generate Visual Studio 2012 project files'
        'vs2013:Generate Visual Studio 2013 project files'
        'vs2015:Generate Visual Studio 2015 project files'
        'vs2017:Generate Visual Studio 2017 project files'
        'vs2019:Generate Visual Studio 2019 project files'
        'vs2022:Generate Visual Studio 2022 project files'
        'xcode4:Generate Xcode 4+ project files'
        'export-compile-commands:Export compile_commands.json'
        'clean:Remove all generated files'
        'embed:Embed lua files in premake'
        'package:Package premake'
        'test:Run premake unit tests'
        'self-test:Run premake self tests'
        'scripts:Print directory of premake scripts'
        'systeminfo:Print system info'
    )
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--cc=+[cc]:c:(clang gcc msc mingw)' \
        '--dotnet=+[m]:m:(mono msnet pnet)' \
        '--debug-profiler[debug profiler]' \
        '--debugger[debugger]' \
        '--file=+[file]:file:_files -g "premake5.lua *.lua"' \
        '--fatal[stop on warning]' \
        '--insecure[insecure HTTPS]' \
        '--interactive[interactive shell]' \
        '--os=+[os]:o:(aix bsd haiku hurd linux macosx solaris windows wii xbox360 ios tvos android emscripten ios-simulator)' \
        '--scripts=+[dir]:dir:_files -/' \
        '--systemscript=+[file]:file:_files' \
        '--debug-extensions[debug extensions]' \
        '--no-test-self[no test self]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--test=+[name]:str:' \
        '--test-only=+[name]:str:' \
        '--module-only=+[name]:str:' \
        '--debug-mode[debug mode]' \
        '--profile-mode[profile mode]' \
        '--with-dummy-module-config[dummy config]' \
        '--allow-package-references[allow package references]' \
        '--ignore-warnings[ignore warnings]' \
        '--D+[k=v]:str:' \
        '*-D+[k=v]:str:' \
        '--define=+[k=v]:str:' \
        '1:action:->a' \
        '*:args:'

    case $state in
        a) _describe -t actions 'premake action' actions ;;
    esac
}

_premake-cli2 "$@"
