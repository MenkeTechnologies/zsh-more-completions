#compdef ntpdig

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-\!,--more-help}'[show more help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-4 --ipv4)'{-4,--ipv4}'[force IPv4]' \
  '(-6 --ipv6)'{-6,--ipv6}'[force IPv6]' \
  '(-a --authentication)'{-a,--authentication}'+[authentication key ID]:keyid:' \
  '(-b --bctimeout)'{-b,--bctimeout}'+[broadcast timeout sec]:sec:' \
  '(-B --bcaddress)'{-B,--bcaddress}'+[broadcast address]:addr:' \
  '(-c --concurrent)'{-c,--concurrent}'[concurrent name resolution]' \
  '(-d --debug-level)'{-d,--debug-level}'[debug level]' \
  '(-D --set-debug-level)'{-D,--set-debug-level}'+[set debug level]:level:' \
  '(-g --gap)'{-g,--gap}'+[time gap between requests ms]:ms:' \
  '(-K --kod)'{-K,--kod}'+[KoD history file]:file:_files' \
  '(-k --keyfile)'{-k,--keyfile}'+[key file]:file:_files' \
  '(-l --logfile)'{-l,--logfile}'+[log file]:file:_files' \
  '(-M --steplimit)'{-M,--steplimit}'+[step limit ms]:ms:' \
  '(-o --ntpversion)'{-o,--ntpversion}'+[NTP version 1-4]:ver:(1 2 3 4)' \
  '(-p --usereservedport)'{-p,--usereservedport}'[use NTP reserved port (123)]' \
  '(-S --step)'{-S,--step}'[step clock immediately]' \
  '(-s --slew)'{-s,--slew}'[slew time correction]' \
  '(-r --normalverbose)'{-r,--normalverbose}'[verbose]' \
  '(-t --timeout)'{-t,--timeout}'+[timeout sec]:sec:' \
  '(-u --uctimeout)'{-u,--uctimeout}'+[unicast timeout sec]:sec:' \
  '(-W --wait)'{-W,--wait}'[wait for response]' \
  '*:server:_hosts' && ret=0

return ret
