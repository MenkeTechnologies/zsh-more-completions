#compdef puppet-ssl
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/ssl.md
# puppet ssl - manage SSL keys and certificates for puppet agents

local ret=1

_arguments -s -S \
  '--help[print this help message]' \
  '--verbose[print additional information]' \
  '--debug[enable full debugging]' \
  '--localca[also clean the local CA certificate and CRL]' \
  '--target=[operate on the specified device certificate]:certname:' \
  '1:action:(bootstrap submit_request generate_request download_cert verify clean show)' \
  '*::arg:' && ret=0

return ret
