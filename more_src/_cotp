#compdef cotp

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-p+[database path]:path:_files' \
  '--path=[database path]:path:_files' \
  '1:command:->commands' && ret=0

case $state in
  commands)
    local -a commands=(
      'add:add a new OTP code'
      'edit:edit an existing OTP code'
      'remove:remove an OTP code'
      'import:import codes from file'
      'export:export codes to file'
      'extract:extract OTP from screenshot'
      'dashboard:show interactive dashboard'
    )
    _describe -t commands 'cotp command' commands && ret=0
    ;;
esac

return ret
