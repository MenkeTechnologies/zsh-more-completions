#compdef cotp
# Documentation: https://github.com/replydev/cotp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cotp - trustworthy, encrypted, command-line TOTP/HOTP authenticator.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--password-stdin[read password from stdin]' \
  '--database-path=[custom database path]:path:_files' \
  '1:command:->commands' && ret=0

case $state in
  commands)
    local -a commands=(
      'add:add a new TOTP/HOTP code from a BASE32 secret'
      'edit:edit an existing code'
      'remove:remove a code'
      'import:import codes from another app'
      'export:export the cotp database'
      'extract:extract first matching OTP code'
      'list:list codes (use --json for JSON)'
      'help:show help'
    )
    _describe -t commands 'cotp command' commands && ret=0
    ;;
esac

return ret
