#compdef kibitz
# Documentation: https://linux.die.net/man/1/kibitz
# Allow two people to interact with one shell/program

local ret=1

_arguments -s \
  '-noproc[run with no process underneath]' \
  '-noescape[disable the escape character]' \
  '-escape[set the escape character (default ^])]:char:' \
  '-silent[suppress informational connection messages]' \
  '-tty[tty to which the invitation should be sent]:ttyname:' \
  '-proxy[use username for the remote rlogin]:username:' \
  '1:user:_users' \
  '*::program:_command_names -e' && ret=0

return ret
