#compdef runhaskell-9.14.1
# Documentation: https://downloads.haskell.org/~ghc/latest/docs/users_guide/runghc.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. runhaskell is an alias for runghc;
# runghc only recognizes 4 of its own flags; unrecognized flags pass through to GHC.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-f+[path to GHC]:ghc:_command_names -e' \
  '*--ghc-arg=[pass option to GHC]:arg:' \
  '*:Haskell source:_files -g "*.(hs|lhs)"' && ret=0

return ret
