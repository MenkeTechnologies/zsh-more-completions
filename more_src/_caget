#compdef caget
# Documentation: https://docs.epics-controls.org/en/latest/
# Source: epics-base/epics-base modules/ca/src/tools/caget.c — EPICS Channel Access get tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-V[show EPICS/CA versions]' \
    '-w+[CA timeout (seconds)]:sec:_default' \
    '-c[asynchronous get with ca_get_callback]' \
    '-p+[CA priority (0=lowest)]:prio:_default' \
    '-t[terse mode (value only, no name)]' \
    '-a[wide mode: name timestamp value stat sevr]' \
    '-d+[request specific dbr type]:type:_default' \
    '-n[print DBF_ENUM as number]' \
    '-#+[print first N elements of array]:count:_default' \
    '-S[print char array as string (long string)]' \
    '-e+[%e format precision]:digits:_default' \
    '-f+[%f format precision]:digits:_default' \
    '-g+[%g format precision]:digits:_default' \
    '-s[get value as string]' \
    '-lx[round to long, print hex]' \
    '-lo[round to long, print octal]' \
    '-lb[round to long, print binary]' \
    '-0x[print integer as hex]' \
    '-0o[print integer as octal]' \
    '-0b[print integer as binary]' \
    '-F+[alternate output field separator]:sep:_default' \
    '*:PV name:_default' \
    && ret=0

return ret
