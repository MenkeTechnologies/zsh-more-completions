#compdef arm-none-eabi-addr2line
# _arm-none-eabi-addr2line — Arm Limited arm-none-eabi-addr2line CLI for the bare-metal ARM cross-addr2line translating program addresses to source-file line numbers using DWARF debug info inline-function expansion demangle (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-addr2line() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-a[show addresses]' \
        '--addresses[show addresses]' \
        '-b+[target]:str:' \
        '--target=+[target]:str:' \
        '-C[demangle]' \
        '--demangle[demangle]' \
        '--demangle=+[style]:s:(auto gnu lucid arm hp edg gnu-v3 java gnat dlang rust)' \
        '-e+[executable file]:file:_files' \
        '--exe=+[executable file]:file:_files' \
        '-f[show function names]' \
        '--functions[show function names]' \
        '-i[show inlines]' \
        '--inlines[show inlines]' \
        '-j+[section]:str:' \
        '--section=+[section]:str:' \
        '-p[pretty print]' \
        '--pretty-print[pretty print]' \
        '-r[recurse functions]' \
        '--recurse-functions[recurse functions]' \
        '-s[show base names]' \
        '--basenames[show base names]' \
        '*:addresses:'
}

_arm-none-eabi-addr2line "$@"
