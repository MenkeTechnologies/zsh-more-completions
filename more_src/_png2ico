#compdef png2ico
# Documentation: https://linux.die.net/man/1/png2ico
# convert PNG files into a Windows ICO icon file

local ret=1

_arguments -s \
  '--colors=[number of colors for following images (2, 16 or 256)]:colors:(2 16 256)' \
  '1:output ico:_files -g "*.ico"' \
  '*:png file:_files -g "*.png"' && ret=0

return ret
