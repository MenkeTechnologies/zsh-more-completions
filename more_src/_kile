#compdef kile

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--line=[go to line N]:n:' \
  '--column=[go to column N]:n:' \
  '--restore[restore previous session]' \
  '--graphicsfile=[insert image]:file:_files' \
  '*:tex_file:_files -g "*.{tex,bib,sty,cls}"' && ret=0

return ret
