#compdef haxe
# _haxe-bin — Haxe multi-target language CLI (Haxe Foundation, OCaml); compile Haxe to many target languages
# upstream: https://github.com/HaxeFoundation/haxe

_haxe-bin() {
    _arguments \
        '-cp+[classpath]:dir:_files -/' \
        '--class-path+[classpath]:dir:_files -/' \
        '-m+[main class]:class:' \
        '--main+[main class]:class:' \
        '-D+[define]:def:' \
        '--define+[define]:def:' \
        '-L+[Haxelib library]:lib:' \
        '--library+[Haxelib library]:lib:' \
        '-r+[remap package]:src:dst:' \
        '--remap+[remap package]:src:dst:' \
        '-c+[connect to compilation server]:host:port:' \
        '--connect+[connect to compilation server]:host:port:' \
        '-w+[warnings]:warnings:' \
        '--cmd+[run command after compile]:cmd:' \
        '--macro+[run macro]:str:' \
        '--js+[JS output]:file:_files' \
        '--lua+[Lua output]:file:_files' \
        '--swf+[SWF output]:file:_files' \
        '--neko+[Neko output]:file:_files' \
        '--php+[PHP output]:dir:_files -/' \
        '--python+[Python output]:file:_files' \
        '--hl+[HashLink output]:file:_files' \
        '--cpp+[C++ output]:dir:_files -/' \
        '--cppia+[Cppia output]:file:_files' \
        '--cs+[C# output]:dir:_files -/' \
        '--java+[Java output]:dir:_files -/' \
        '--swf-version+[SWF version]:ver:' \
        '--swf-header+[SWF header]:str:' \
        '--debug[debug]' \
        '-debug[debug]' \
        '-D=accessor_check_inline=+[accessor check inline]:bool:(true false)' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--times[print compile timings]' \
        '--server-listen+[server listen]:host:port:' \
        '--server-connect+[server connect]:host:port:' \
        '--display+[display request]:str:' \
        '--xml+[output XML]:file:_files' \
        '--no-output[no output]' \
        '--no-opt[no opt]' \
        '--no-inline[no inline]' \
        '--no-traces[strip traces]' \
        '-version[show version]' \
        '--version[show version]' \
        '--help[show help]' \
        '-h[show help]' \
        '--help-defines[print all defines]' \
        '--help-metas[print all metadata]' \
        '*:hxml file:_files -g "*.hxml"'
}

_haxe-bin "$@"
