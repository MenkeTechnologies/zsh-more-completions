#compdef semibin SemiBin
# SemiBin — semi-supervised metagenomic binning using deep siamese neural networks

local curcontext="$curcontext" state line ret=1

_semibin_common() {
  _arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(-i --input-fasta)'{-i,--input-fasta}'[input FASTA file]:fasta file:_files' \
    '(-b --input-bam)'{-b,--input-bam}'[input BAM file(s)]:*:BAM files:_files' \
    '(-o --output)'{-o,--output}'[output directory]:output dir:_files -/' \
    '(-p --threads)'{-p,--threads}'[number of threads]:threads' \
    "$@"
}

_semibin_single_easy_bin() {
  _semibin_common \
    '--environment[built-in model environment]:environment:(human_gut dog_gut ocean soil cat_gut human_oral mouse_gut pig_gut built_environment wastewater global)' \
    '--sequencing-type[sequencing type]:type:(short_read long_read)' \
    '--self-supervised[use self-supervised learning]' \
    '--semi-supervised[use semi-supervised learning]' \
    '--epochs[number of training epochs]:epochs' \
    '--batch-size[training batch size]:size' \
    '--min-len[minimum contig length]:length' \
    '--ratio[ratio of must-link to cannot-link]:ratio' \
    '--orf-finder[ORF finder to use]:finder:(prodigal fraggenescan)' \
    '--min-kmer-freq[minimum k-mer frequency]:freq' \
    '--random-seed[random seed for reproducibility]:seed' \
    '--tmpdir[temporary directory]:temp dir:_files -/' \
    '--compression[compression type for output]:type:(none gz xz)' \
    '--write-pre-reclustering-bins[output bins before reclustering]' \
    '--tag-output[tag output with sample name]:tag' \
    && return 0
}

_semibin_multi_easy_bin() {
  _semibin_common \
    '--environment[built-in model environment]:environment:(human_gut dog_gut ocean soil cat_gut human_oral mouse_gut pig_gut built_environment wastewater global)' \
    '--sequencing-type[sequencing type]:type:(short_read long_read)' \
    '--self-supervised[use self-supervised learning]' \
    '--semi-supervised[use semi-supervised learning]' \
    '--epochs[number of training epochs]:epochs' \
    '--batch-size[training batch size]:size' \
    '--min-len[minimum contig length]:length' \
    '--ratio[ratio of must-link to cannot-link]:ratio' \
    '--orf-finder[ORF finder to use]:finder:(prodigal fraggenescan)' \
    '-s[separator between sample and contig name]:separator' \
    '--separator[separator between sample and contig name]:separator' \
    '--min-kmer-freq[minimum k-mer frequency]:freq' \
    '--random-seed[random seed for reproducibility]:seed' \
    '--tmpdir[temporary directory]:temp dir:_files -/' \
    && return 0
}

_semibin_generate_sequence_features() {
  _semibin_common \
    '--min-len[minimum contig length]:length' \
    '--orf-finder[ORF finder to use]:finder:(prodigal fraggenescan)' \
    '--min-kmer-freq[minimum k-mer frequency]:freq' \
    && return 0
}

_semibin_train() {
  _semibin_common \
    '--data[training data file]:data file:_files' \
    '--data-split[training data split file]:split file:_files' \
    '--epochs[number of training epochs]:epochs' \
    '--batch-size[training batch size]:size' \
    '--mode[training mode]:mode:(self semi)' \
    '--random-seed[random seed]:seed' \
    && return 0
}

_semibin_bin() {
  _semibin_common \
    '--model[trained model path]:model file:_files' \
    '--data[data file]:data file:_files' \
    '--min-len[minimum contig length]:length' \
    '--random-seed[random seed]:seed' \
    '--compression[compression type for output]:type:(none gz xz)' \
    && return 0
}

_semibin_concatenate_fasta() {
  _arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(-i --input-fasta)'{-i,--input-fasta}'[input FASTA files]:*:fasta files:_files' \
    '(-o --output)'{-o,--output}'[output concatenated FASTA]:output file:_files' \
    '--min-len[minimum contig length]:length' \
    '-s[separator between sample and contig name]:separator' \
    '--separator[separator between sample and contig name]:separator' \
    && return 0
}

local -a subcmds
subcmds=(
  'single_easy_bin:single sample binning (all-in-one)'
  'multi_easy_bin:multi-sample binning (all-in-one)'
  'generate_sequence_features_single:generate features for single sample'
  'generate_sequence_features_multi:generate features for multi samples'
  'train_semi:train semi-supervised model'
  'train_self:train self-supervised model'
  'bin:run binning with trained model'
  'concatenate_fasta:concatenate FASTA files for multi-sample'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'semibin command' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      single_easy_bin) _semibin_single_easy_bin ;;
      multi_easy_bin) _semibin_multi_easy_bin ;;
      generate_sequence_features_single|generate_sequence_features_multi)
        _semibin_generate_sequence_features ;;
      train_semi|train_self) _semibin_train ;;
      bin) _semibin_bin ;;
      concatenate_fasta) _semibin_concatenate_fasta ;;
      *) _default ;;
    esac
    ;;
esac

return ret
