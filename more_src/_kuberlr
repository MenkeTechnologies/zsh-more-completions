#compdef kuberlr
# Documentation: https://man.archlinux.org/search?q=kuberlr
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'bins:list available kubectl binaries'
  'get-kubectl:download a specific kubectl version'
  'kubectl:invoke kubectl (with version detection)'
  'default-config:print the default kuberlr config'
  'completion:generate shell completion'
  'help:show help'
  'version:show kuberlr version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-k --kubectl-version)'{-k+,--kubectl-version=}'[force kubectl version]:version:' \
  '--config=[kuberlr config file]:file:_files -g "*.{conf,toml}"' \
  '--debug[enable debug logging]' \
  '--allow-download[allow downloading missing kubectl]' \
  '--strict-version-match[require exact version match]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kuberlr command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (get-kubectl)
        _arguments \
          '*::version:' && ret=0 ;;
      (kubectl)
        _arguments \
          '--allow-download[allow downloading]' \
          '*::kubectl_args:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
