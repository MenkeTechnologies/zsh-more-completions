#compdef estimateReadFiltering
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/estimateReadFiltering.html
# deepTools: estimate the number of reads that would be filtered from BAM files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bamfiles)'{-b,--bamfiles}'[indexed BAM files]:bam:_files -g "*.bam"' \
  '(-o --outFile)'{-o,--outFile}'[output results file]:file:_files' \
  '--sampleLabels[custom sample labels]:labels:' \
  '--smartLabels[auto-generate labels from filenames]' \
  '(-bs --binSize)'{-bs,--binSize}'[genomic window size in bases]:size:' \
  '(-n --distanceBetweenBins)'{-n,--distanceBetweenBins}'[spacing between sampled bins]:n:' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[show version]' \
  '--filterRNAstrand[select reads by strand]:strand:(forward reverse)' \
  '--ignoreDuplicates[consider identical reads once]' \
  '--minMappingQuality[minimum mapping quality threshold]:qual:' \
  '--samFlagInclude[include reads matching SAM flag]:flag:' \
  '--samFlagExclude[exclude reads matching SAM flag]:flag:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[BED/GTF file of regions to exclude]:file:_files' && ret=0

return ret
