#compdef pypresso
# Documentation: https://espressomd.github.io/doc/running.html
# Run a Python simulation script with the ESPResSo interpreter

local ret=1

_arguments -s -S \
  '--gdb[attach the GNU debugger: gdb --args python script]' \
  '--lldb[attach the LLVM debugger: lldb -- python script]' \
  '--valgrind[run under valgrind --leak-check=full]' \
  '--cuda-gdb[debug CUDA code: cuda-gdb --args python script]' \
  '--cuda-sanitizer[GPU memory/error detection via compute-sanitizer]' \
  '--kernprof[line-by-line Python profiler]' \
  '*:python script:_files -g "*.py"' && ret=0

return ret
