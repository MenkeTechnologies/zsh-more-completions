#compdef kea-shell
# Documentation: https://man.archlinux.org/search?q=kea-shell
# Reference accessed: 2026-05-16

# kea-shell: Kea control agent JSON shell
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '--host=[Kea ctrl-agent host]:host:_hosts' \
  '--port=[Kea ctrl-agent port]:port:' \
  '--path=[URL path]:path:' \
  '--auth-user=[basic auth user]:user:_users' \
  '--auth-password=[basic auth password]:pass:' \
  '--auth-passwordfile=[basic auth password file]:file:_files' \
  '--auth=[auth realm]:realm:' \
  '--ca=[CA cert file]:file:_files' \
  '--cert=[client cert]:file:_files' \
  '--key=[client key]:file:_files' \
  '--timeout=[timeout (s)]:s:' \
  '--service=[service to send command to]:service:(dhcp4 dhcp6 d2 ca)' \
  '*:command:_files' && ret=0
return ret
