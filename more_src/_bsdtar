#compdef bsdtar
# Documentation: https://manpages.debian.org/bookworm/libarchive-tools/bsdtar.1.en.html
# Reference accessed: 2026-05-30
# bsdtar — libarchive's tar implementation. Default tar on macOS and FreeBSD.
# Reads/writes 12+ archive formats including ustar/pax/cpio/zip/iso9660/ar
# plus all the lzip/lz4/zstd/lzop/lrzip compression variants.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show usage]' \
  '(- *)--version[show tar + libarchive version]' \
  '(-c --create -x --extract -t --list -r --append -u --update)'{-c,--create}'[create new archive]' \
  '(-c --create -x --extract -t --list -r --append -u --update)'{-x,--extract}'[extract files]' \
  '(-c --create -x --extract -t --list -r --append -u --update)'{-t,--list}'[list archive contents]' \
  '(-c --create -x --extract -t --list -r --append -u --update)'{-r,--append}'[append entries to uncompressed archive]' \
  '(-c --create -x --extract -t --list -r --append -u --update)'{-u,--update}'[append newer-only files]' \
  '(-z --gzip --gunzip -j --bzip2 --bzip --bunzip2 -J --xz -Z --compress --uncompress --lzma --lzop --lrzip --lz4 --zstd -a --auto-compress)'{-z,--gzip,--gunzip}'[gzip]' \
  '(-z --gzip --gunzip -j --bzip2 --bzip --bunzip2 -J --xz -Z --compress --uncompress --lzma --lzop --lrzip --lz4 --zstd -a --auto-compress)'{-j,--bzip2,--bzip,--bunzip2}'[bzip2]' \
  '(-z --gzip --gunzip -j --bzip2 --bzip --bunzip2 -J --xz -Z --compress --uncompress --lzma --lzop --lrzip --lz4 --zstd -a --auto-compress)'{-J,--xz}'[xz]' \
  '(-z --gzip --gunzip -j --bzip2 --bzip --bunzip2 -J --xz -Z --compress --uncompress --lzma --lzop --lrzip --lz4 --zstd -a --auto-compress)'{-Z,--compress,--uncompress}'[Lempel-Ziv-Welch compress(1)]' \
  '--lzma[original LZMA algorithm]' \
  '--lzop[lzop]' \
  '--lrzip[lrzip]' \
  '--lz4[lz4]' \
  '--zstd[zstandard]' \
  '(-z --gzip --gunzip -j --bzip2 --bzip --bunzip2 -J --xz -Z --compress --uncompress --lzma --lzop --lrzip --lz4 --zstd -a --auto-compress)'{-a,--auto-compress}'[infer compression from suffix]' \
  '(-f --file)'{-f,--file=}'[archive file (- for stdin/stdout)]:file:_files' \
  '(-b --block-size)'{-b,--block-size=}'[block size in 512-byte records]:N:' \
  '(-C --cd --directory)'{-C,--cd=,--directory=}'[chdir before processing]:dir:_files -/' \
  '(-T --files-from)'{-T,--files-from=}'[file containing file list (- for stdin)]:file:_files' \
  '(-X --exclude-from)'{-X,--exclude-from=}'[file containing exclusion patterns]:file:_files' \
  '*--exclude=[skip files matching glob]:pattern:' \
  '*--include=[only files matching glob]:pattern:' \
  '--exclude-vcs[skip VCS directories]' \
  '(-n --no-recursion --norecurse)'{-n,--no-recursion,--norecurse}'[do not recurse]' \
  '--strip-components=[strip N leading path elements]:N:' \
  '(-k --keep-old-files)'{-k,--keep-old-files}'[do not overwrite existing files]' \
  '--keep-newer-files[do not overwrite newer existing files]' \
  '(-m --modification-time)'{-m,--modification-time}'[do not restore mtime]' \
  '(-O --to-stdout)'{-O,--to-stdout}'[extract files to stdout]' \
  '(-U --unlink --unlink-first)'{-U,--unlink,--unlink-first}'[unlink before creating]' \
  '(-p --preserve-permissions)'{-p,--preserve-permissions}'[restore full perms/modes]' \
  '--safe-writes[atomic extract via temp files]' \
  '-S[extract sparse files as sparse]' \
  '(-P --absolute-paths)'{-P,--absolute-paths}'[preserve absolute paths]' \
  '(-L --dereference)'{-L,--dereference}'[follow symlinks; archive target]' \
  '-H[follow symlinks on command line only]' \
  '-h[synonym for -L]' \
  '(-l --check-links)'{-l,--check-links}'[warn if not all links archived]' \
  '--one-file-system[stay on one filesystem]' \
  '(--same-owner --no-same-owner)--same-owner[restore owner/group on extract]' \
  '(--same-owner --no-same-owner)--no-same-owner[do not restore owner/group]' \
  '-o[c/r/u: format=ustar; x: use running uid/gid]' \
  '--uid=[override uid]:uid:' \
  '--uname=[override user name]:name:' \
  '--gid=[override gid]:gid:' \
  '--gname=[override group name]:name:' \
  '--numeric-owner[use numeric ids, ignore names]' \
  '--format=[archive format]:fmt:(ustar pax v7 cpio shar ar mtree iso9660 zip 7zip xar raw)' \
  '--posix[--format=pax]' \
  '(--acls --no-acls)--acls[include POSIX.1e/NFSv4 ACLs]' \
  '(--acls --no-acls)--no-acls[exclude ACLs]' \
  '(--xattrs --no-xattrs)--xattrs[include extended attributes]' \
  '(--xattrs --no-xattrs)--no-xattrs[exclude extended attributes]' \
  '(--fflags --no-fflags)--fflags[include file flags (BSD chflags)]' \
  '(--fflags --no-fflags)--no-fflags[exclude file flags]' \
  '--newer=[only files newer than date]:date:' \
  '--newer-mtime=[only files with newer mtime]:date:' \
  '--newer-than=[only files newer than FILE]:file:_files' \
  '--newer-mtime-than=[only files with mtime newer than FILE]:file:_files' \
  '--older=[only files older than date]:date:' \
  '--older-mtime=[only files with older mtime]:date:' \
  '--older-than=[only files older than FILE]:file:_files' \
  '--older-mtime-than=[only files with mtime older than FILE]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-w --confirmation --interactive)'{-w,--confirmation,--interactive}'[confirm every action]' \
  '(-q --fast-read)'{-q,--fast-read}'[extract/list only first matching entry]' \
  '--totals[print summary stats]' \
  '-s+[regex pattern transform]:pattern:' \
  '*--options=[module-specific options]:opts:' \
  '--use-compress-program=[pipe through custom compressor]:program:_command_names -e' \
  '--null[separate filenames/patterns with null bytes]' \
  '--passphrase=[passphrase for encrypted archives]:passphrase:' \
  '(-B --read-full-blocks)'{-B,--read-full-blocks}'[ignored (GNU compat)]' \
  '*:file:_files' \
  && ret=0

return ret
