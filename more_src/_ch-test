#compdef ch-test
# Documentation: https://charliecloud.io/latest/ch-test.html
# Charliecloud: run the Charliecloud test suite.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage and exit]' \
  '(-s --scope)'{-s,--scope}'[test scope]:scope:(quick standard full)' \
  '--pack-fmt[packed image format]:format:(squash-mount tar-unpack squash-unpack)' \
  '(-b --builder)'{-b,--builder}'[builder to use]:builder:(ch-image docker podman buildah)' \
  '(-f --file)'{-f,--file}'[run tests in given .bats file only]:file:_files -g "*.bats"' \
  '--dry-run[print test summary and exit]' \
  '--img-dir[unpacked images directory]:dir:_files -/' \
  '--lustre[directory for Lustre tests]:dir:_files -/' \
  '--pack-dir[packed images directory]:dir:_files -/' \
  '--pedantic[fail or skip unmet requirements]:mode:(yes no)' \
  '--perm-dir[add filesystem permission fixture directory]:dir:_files -/' \
  '--sudo[enable sudo-requiring tests]' \
  '*:phase:(build run rootemu examples all mk-perm-dirs build-images clean rm-perm-dirs)' && ret=0

return ret
