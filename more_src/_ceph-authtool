#compdef ceph-authtool
# Documentation: https://docs.ceph.com/en/reef/man/8/ceph-authtool/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ceph-authtool: ceph keyring manipulation tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-l[list keys]' \
  '--list[list keys]' \
  '-p[print keys]' \
  '--print-key[print keys]' \
  '-C[create keyring]' \
  '--create-keyring[create keyring]' \
  '-g[generate key]' \
  '--gen-key[generate key]' \
  '--gen-print-key[generate key and print it]' \
  '--import-keyring=[import keyring]:file:_files' \
  '-n[name]:name:' \
  '--name=[name]:name:' \
  '-u[user]:user:_users' \
  '--cap=[set capability]:cap value:' \
  '--caps=[caps file]:file:_files' \
  '-a[add key]:key:' \
  '--add-key=[add key]:key:' \
  '*:keyring file:_files' && ret=0
return ret
