#compdef fresh
# Documentation: https://github.com/freshshell/fresh
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# fresh: dotfile manager (Bundler for shell configurations)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'install:build shell configuration and relevant symlinks'
  'update:fetch changes from GitHub repos and run install'
  'clean:remove dead symlinks and unused source repos'
  'edit:open your ~/.freshrc in your default editor'
  'show:output each freshrc line with matching source files'
  'search:query the fresh directory for shared dotfiles'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:subcommand:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd) _describe -t subcommands 'fresh subcommand' subcommands && ret=0 ;;
esac

return ret
