#compdef obexd
# Documentation: https://man.archlinux.org/search?q=obexd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --nodaemon)'{-n,--nodaemon}'[do not run as daemon]' \
  '(-d --debug)'{-d,--debug}'+[debug mask]:mask:' \
  '(-p --plugin)'{-p,--plugin}'+[load only these plugins]:names:' \
  '(-P --noplugin)'{-P,--noplugin}'+[skip these plugins]:names:' \
  '(-C --capability)'{-C,--capability}'+[capability file]:file:_files' \
  '(-r --root)'{-r,--root}'+[OBEX root directory]:dir:_files -/' \
  '(-l --symlinks)'{-l,--symlinks}'[follow symlinks]' \
  '(-a --auto-accept)'{-a,--auto-accept}'[auto-accept incoming transfers]' \
  '(-u --user-bus)'{-u,--user-bus}'[connect to user D-Bus]' \
  '(-s --system-bus)'{-s,--system-bus}'[connect to system D-Bus]' \
  '(-D --noplugin)'{-D,--noplugin}'+[disable plugins]:plugins:' && ret=0

return ret
