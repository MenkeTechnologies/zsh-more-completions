#compdef evil-winrm
# Documentation: https://github.com/Hackplayers/evil-winrm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-i+[target IP or hostname]:host:_hosts' \
  '-u+[username]:username:' \
  '-p+[password]:password:' \
  '-H+[NTLM hash]:hash:' \
  '-s+[PowerShell scripts path]:scripts path:_directories' \
  '-e+[executables path]:executables path:_directories' \
  '-P+[port number]:port:' \
  '-S[enable SSL]' \
  '-c+[client certificate]:cert file:_files' \
  '-k+[client private key]:key file:_files' \
  '-r+[Kerberos realm]:realm:' \
  '-K+[Kerberos ccache or kirbi ticket file]:file:_files' \
  '--ccache=[Kerberos ccache or kirbi ticket file]:file:_files' \
  '-l[enable session logging]' \
  '--log[enable session logging]' \
  '-n[disable colors]' \
  '--no-colors[disable colors]' \
  '-N[disable remote path completion]' \
  '--no-rpath-completion[disable remote path completion]' \
  '-a+[custom user-agent string]:ua:' \
  '--user-agent=[custom user-agent string]:ua:' \
  '-U+[custom URI endpoint (default /wsman)]:url:' \
  '--url=[custom URI endpoint (default /wsman)]:url:' \
  '--spn=[custom SPN prefix (default HTTP)]:SPN:' \
  '-V[show version]' && ret=0

return ret
