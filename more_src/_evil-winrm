#compdef evil-winrm

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-i+[target IP or hostname]:host:_hosts' \
  '-u+[username]:username:' \
  '-p+[password]:password:' \
  '-H+[NTLM hash]:hash:' \
  '-s+[PowerShell scripts path]:scripts path:_directories' \
  '-e+[executables path]:executables path:_directories' \
  '-P+[port number]:port:' \
  '-S[enable SSL]' \
  '-c+[client certificate]:cert file:_files' \
  '-k+[client private key]:key file:_files' \
  '-r+[Kerberos realm]:realm:' \
  '-l+[log file]:log file:_files' \
  '-n[disable colors]' \
  '--no-colors[disable colors]' \
  '--path=[custom URI path]:path:' \
  '--spn=[custom SPN]:SPN:' \
  '-V[show version]' && ret=0

return ret
