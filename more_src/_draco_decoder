#compdef draco_decoder
# Documentation: https://github.com/google/draco/blob/main/src/draco/tools/draco_decoder.cc
# Reference accessed: 2026-05-27
# Verified: upstream strcmp argument parsing in main() in src/draco/tools/draco_decoder.cc
#           (upstream draco_decoder only implements -h/-?, -i, -o; -version,
#           -skip_attribute_transform, -output_attribute_skipping are not in source)

# draco_decoder: Google Draco 3D geometry compression decoder.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-\?[show help]' \
  '-i+[input Draco file]:input:_files -g "*.drc"' \
  '-o+[output decoded geometry (defaults to input with .ply extension)]:output:_files' && ret=0

return ret
