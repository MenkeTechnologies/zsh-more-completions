#compdef subnetcalc
# Documentation: https://manpages.debian.org/bookworm/subnetcalc/subnetcalc.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '-n[skip reverse DNS lookup]' \
  '-uniquelocal[replace first 48 bits with IPv6 Unique Local prefix (RFC 4193)]' \
  '-uniquelocalhq[unique local prefix using high-quality random]' \
  '-nocolour[turn colourised output off]' \
  '-nocolor[turn colourised output off]' \
  '*:address-or-prefix: '
