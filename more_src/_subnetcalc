#compdef subnetcalc
# Documentation: https://man.archlinux.org/search?q=subnetcalc
# Reference accessed: 2026-05-16

_arguments -s \
  '-n[skip reverse DNS]' \
  '-uniquelocal[generate IPv6 unique local prefix]' \
  '-uniquelocalhq[unique local prefix high quality]' \
  '-nocolour[disable color]' \
  '-nocolor[disable color]' \
  '*:address-or-prefix: '
