#compdef qqem
# Documentation: https://man.archlinux.org/search?q=qqem
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--exportpath=[path for exporting effect]:path:_files -/' \
  '--create[create a new project]' \
  '*:project file:_files -g "*.qep"' && ret=0

return ret
