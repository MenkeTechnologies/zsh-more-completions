#compdef lasground
# LAStools: extract bare-earth by classifying ground points

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help]' \
  '-version[report tool version]' \
  '-gui[start with files loaded into GUI]' \
  '-v[verbose output]' \
  '-vv[very verbose output]' \
  '-silent[suppress non-error output]' \
  '-step+[grid resolution in meters (default 5)]:meters' \
  '-ground_class+[classification value for ground points]:code' \
  '-non_ground_class+[classification value for non-ground points]:code' \
  '-non_ground_unchanged[leave non-ground classifications intact]' \
  '*-ignore_class+[exclude classifications from processing]:code' \
  '-town[step 10m for towns with small buildings]' \
  '-city[step 25m for large buildings]' \
  '-metro[step 50m for very large urban areas]' \
  '-wilderness[step 3m for natural terrain]' \
  '-nature[step 5m (default)]' \
  '-archaeology[step 1m for detailed analysis]' \
  '-fine[enhanced search for steep terrain]' \
  '-extra_fine[intensive processing for very steep hills]' \
  '-ultra_fine[maximum precision for steep terrain]' \
  '-hyper_fine[extreme precision for very steep hills]' \
  '-coarse[simplified processing for flat terrain]' \
  '-extra_coarse[minimal processing for very flat areas]' \
  '-sub+[custom number of substeps]:n' \
  '-bulge+[TIN bulge allowance in meters]:meters' \
  '-spike+[spike removal threshold in meters]:meters' \
  '-stddev+[max stddev for planar patches (cm)]:cm' \
  '-offset+[max height above ground estimate (default 0.05)]:meters' \
  '-no_bulge[disable bulge refinement]' \
  '-no_stddev[disable standard deviation filtering]' \
  '-iterate+[number of iteration loops (default 2)]:n' \
  '-all_returns[process all returns not just last]' \
  '-by_flightline[classify separately by flightline]' \
  '-compute_height[compute height above ground per point]' \
  '-replace_z[replace elevation with computed height]' \
  '-not_airborne[mode for terrestrial or mobile LiDAR]' \
  '-feet[interpret horizontal units as feet]' \
  '-elevation_feet[interpret vertical units as feet]' \
  '*-i+[input LAS/LAZ file or wildcard]:input:_files -g "*.(las|laz|txt|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-odir+[output directory]:dir:_files -/' \
  '-odix+[output filename suffix]:suffix' \
  '-olas[output uncompressed LAS]' \
  '-olaz[output compressed LAZ]' \
  '-cores+[process files in parallel on N cores]:n' \
  '*:file:_files -g "*.(las|laz|txt|LAS|LAZ)"' && ret=0

return ret
