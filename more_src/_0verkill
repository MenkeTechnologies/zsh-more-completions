#compdef 0verkill
# Documentation: https://github.com/hackndev/0verkill
# Reference accessed: 2026-05-16

# 0verkill: ASCII-art deathmatch shooter
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-c[client mode]:host:_hosts' \
  '-s[server mode]' \
  '-p[port]:port:' \
  '-n[player name]:name:' \
  '--colour=[colour mode]:val:(none ansi 256)' \
  '*::0verkill args:_files' && ret=0
return ret
