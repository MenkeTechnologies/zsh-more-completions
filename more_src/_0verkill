#compdef 0verkill
# Documentation: https://github.com/hackndev/0verkill/blob/master/client.c
# Reference accessed: 2026-05-16
# Verified: client.c getopt strings "3hl:f:d:s:n:i:p:c:" / "hf:d:s:n:i:p:c:" (lines 2058-2071)

# 0verkill: ASCII-art network deathmatch shooter (client)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[print help and quit]' \
  '-3[enable 3D mode (red/green stereoscopic; requires TRI_D build)]' \
  '-s[screen dimensions]:WxH:' \
  '-d[X display name (X11 build only)]:display:' \
  '-f[X font name (X11 build only)]:font:' \
  '-i[server host]:host:_hosts' \
  '-n[player name]:name:' \
  '-p[server port]:port:' \
  '-c[player color (numeric code)]:colorcode:' \
  '*::extra args:_files' && ret=0
return ret
