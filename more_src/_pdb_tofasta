#compdef pdb_tofasta
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Extracts the residue sequence in a PDB file to FASTA format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-multi[write one FASTA per chain instead of a single record]' \
  '*:PDB file:_files' && ret=0

return ret
