#compdef phc_ctl
# _phc_ctl — linuxptp phc_ctl CLI lower-level PTP Hardware Clock control utility issuing get set adjust freq cmp wait commands on a /dev/ptp* character device for one-shot PHC operations debugging time stamping (linuxptp team, C); getopt
# upstream: https://linuxptp.sourceforge.net/

_phc_ctl() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-l+[print level]:l:(0 1 2 3 4 5 6 7)' \
        '-m[print to stdout]' \
        '-q[no syslog]' \
        '-f+[config file]:file:_files -g "*.conf *.cfg"' \
        '1:device:_files -g "/dev/ptp* /dev/pps*"' \
        '*:cmd:(set get adjust freq cmp wait caps max_adj)'
}

_phc_ctl "$@"
