#compdef ldns-update
# Documentation: https://man.archlinux.org/search?q=ldns-update
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-y+[tsig key:secret]:key:' \
  '1:zone:' \
  '2:server:_hosts' \
  '3:name:' \
  '4:ttl:' \
  '5:type:(A AAAA MX NS CNAME TXT PTR)' \
  '6:address:' && ret=0

return ret
