#compdef ldns-update
# Documentation: https://manpages.debian.org/bookworm/ldnsutils/ldns-update.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm ldns-update(1) manpage. Positional args
# only: name [zone] [ip|none] [tsig_name tsig_alg tsig_hmac].
# No -h/-y flags documented upstream.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -h/-y flags and incorrect positional order (zone/server/
# name/ttl/type/address — wrong; real positions are name/zone/ip/tsig*).

# ldns-update: NLnetLabs ldns Dynamic DNS Update utility (positional)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:name:' \
  '2:zone:' \
  '3:ip (or "none" to delete):' \
  '4:tsig_name:' \
  '5:tsig_alg:' \
  '6:tsig_hmac:' && ret=0
return ret
