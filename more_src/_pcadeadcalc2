#compdef pcadeadcalc2
# Calculate deadtime for a PCA Standard2 file (or background)

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[name of the Standard2 or background file]:input file:_files' \
  'outfile=[output file with dead-time quantities appended]:output file:_files' \
  'hkfiles=[list of PCA housekeeping files]:hk files:_files' \
  'std2file=[output from a previous pcadeadcalc2 run]:std2 file:_files' \
  'breakfile=[PCU breakdown GTI file, CALDB or NONE]:break file:_files' \
  'zero_bad=[set Xenon counts to zero for bad PCUs]:flag:(yes no)' \
  'transition_bad=[flag PCU high voltage transitions as bad]:flag:(yes no)' \
  'propane_bad=[flag PCUs with missing propane layers as bad]:flag:(yes no)' \
  'cleanup=[clean up scratch files]:flag:(yes no)' \
  'chatter=[verbosity level]:level:' \
  'clobber=[overwrite output file]:flag:(yes no)' \
  'history=[write HEADAS parameter history into output]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
