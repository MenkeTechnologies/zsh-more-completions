#compdef cuts
# Documentation: source-direct extraction from upstream
# arielf/cuts Perl script `sub usage` heredoc + Getopt::Std `our
# $opt_* / use vars qw(...)` declarations. The binary is a single
# Perl script (NOT a compiled binary) - shebang verified verbatim
# `#!/usr/bin/perl -w` at the top of the source file.
# Reference accessed: 2026-05-30 via gh api.
# arielf cuts R157a — "Unix 'cut' (and 'paste') on steroids" per
# upstream README. Sister to the standard `cut`/`paste` and the
# heavily-covered Rust replacements `choose`/`hck`/`csview`/
# `csvlens` in the corpus.

_arguments -s -S \
  '-v[verbose (mostly for debugging)]' \
  '-0[use 1-based column indexing (default is 0-based; mnemonic: -0 disables 0-based)]' \
  '-c[do NOT load personal config-file ~/.cuts.pl even if exists]' \
  '-d+[input column delimiter (Perl regex)]:regex:' \
  '(-d)-t+[input column delimiter (alias for -d)]:regex:' \
  '(-d -t)-s+[input column delimiter (alias for -d)]:regex:' \
  '-D+[output column delimiter (literal string)]:string:' \
  '(-D)-T+[output column delimiter (alias for -D)]:string:' \
  '(-D -T)-S+[output column delimiter (alias for -D)]:string:' \
  '*:column specs and files (formats: filename\:colno | filename | colno | -):_files'
