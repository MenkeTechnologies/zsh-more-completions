#compdef age-inspect
# Documentation: upstream README at github.com/FiloSottile/age
# Reference accessed: 2026-05-30
# age-inspect — examine encrypted .age files without decrypting them.
# Sister-binary to `age` (covered) + `age-keygen` (covered); displays
# metadata: recipient types, post-quantum-encryption status, size
# breakdown (header, encryption overhead, payload, total).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--json[machine-readable JSON output]' \
  '*:age file:_files -g "*.age"' \
  && ret=0

return ret
