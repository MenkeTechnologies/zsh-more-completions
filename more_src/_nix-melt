#compdef nix-melt
# Documentation: https://github.com/nix-community/nix-melt
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nix-melt - TUI flake.lock viewer

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-t --time-format)'{-t,--time-format}'[timestamp format string]:format:' \
  '::flake.lock or directory:_files -/'
