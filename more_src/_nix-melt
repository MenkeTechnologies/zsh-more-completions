#compdef nix-melt
# Documentation: https://man.archlinux.org/search?q=nix-melt
# Reference accessed: 2026-05-16

# Zsh completion for nix-melt (nix-community/nix-melt). Args from src/cli.rs (clap Parser).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-t --time-format)'{-t,--time-format=}'[timestamp format string]:format:' \
  '::flake.lock or directory:_files -/'
