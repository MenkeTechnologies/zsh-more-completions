#compdef dq
# Documentation: https://github.com/jschauma/dq
# DNS query tool

_arguments -s -S \
  '-s[DNS server to query]:server:_hosts' \
  '-t[query type]:type:(A AAAA CNAME MX NS PTR SOA SRV TXT CAA DNSKEY DS NAPTR TLSA ANY)' \
  '-p[port number]:port:' \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  '-T[use TCP]' \
  '-h[show help]' \
  '-v[verbose output]' \
  '1:domain name:' \
  && return 0
