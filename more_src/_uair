#compdef uair
# Documentation: https://man.archlinux.org/search?q=uair
# Reference accessed: 2026-05-16

# https://github.com/metent/uair — src/bin/uair/main.rs (argh)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  {-c+,--config=}'[config file]:file:_files' \
  {-s+,--socket=}'[unix socket path]:socket:_files' \
  {-l+,--log=}'[log file (default -)]:log:_files' \
  {-q,--quiet}'[no stdout]' \
  {-v,--version}'[print version and exit]' && ret=0

return ret
