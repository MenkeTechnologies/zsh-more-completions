#compdef kfactory
# Documentation: https://github.com/gdsfactory/kfactory
# kfactory KLayout-based layout CLI: build a cell/module to GDS/OAS, show in klive

local ret=1

_arguments -s -C \
  '(-V --version)'{-V,--version}'[show version of the CLI]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(build show)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s \
      '--show[show the file through klive in KLayout]' \
      '--library=[library used by the main layout file]:lib:' \
      '(--out-dir -o)'{--out-dir,-o}'=[output directory for written layouts]:dir:_files -/' \
      '--suffix=[layout file format]:fmt:(gds gdsgz oas)' \
      '--write-full[write the gds with full library support]' \
      '--write-static[write a layout with all cells converted to static]' \
      '--write-nocontext[write the layout without any meta info (for fabs)]' \
      '--max-vertex-count=[maximum vertices per polygon]:n:' \
      '--max-cellname-length=[maximum characters in a cell name]:n:' \
      '*:file:_files' && ret=0
    ;;
esac

return ret
