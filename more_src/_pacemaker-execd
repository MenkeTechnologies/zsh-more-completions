#compdef pacemaker-execd

# Pacemaker local resource execution subdaemon (lrmd)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-$,--version}'[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '*::pacemaker-execd args:_files' && ret=0
return ret
