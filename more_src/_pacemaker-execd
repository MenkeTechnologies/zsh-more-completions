#compdef pacemaker-execd

# Pacemaker execd daemon - typically started by pacemakerd, accepts
# standard logging options when invoked manually for debugging.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-V --verbose)'{-V,--verbose}'[increase log verbosity (repeatable)]' \
  '(--features)--features[print pacemaker features]' \
  '(--debug)--debug[run with debug logging]' \
  '($ --options)$[print command-line options]' \
  '*::pacemaker-execd args:_files' && ret=0
return ret
