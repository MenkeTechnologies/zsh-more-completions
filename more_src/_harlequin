#compdef harlequin

# Zsh completion for harlequin (terminal SQL IDE)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-a --adapter)'{-a,--adapter}'[database adapter to use]:adapter:(duckdb sqlite postgres mysql bigquery trino cassandra)' \
  '(-t --theme)'{-t,--theme}'[color theme]:theme' \
  '(-l --limit)'{-l,--limit}'[row limit for result sets]:limit' \
  '--read-only[open database in read-only mode]' \
  '--no-download[do not download remote files]' \
  '(-e --extension)'{-e,--extension}'[DuckDB extension to load]:extension' \
  '--init-path[path to init script]:init script:_files' \
  '(-f --file)'{-f,--file}'[SQL file to open in editor]:SQL file:_files -g "*.sql"' \
  '--no-autocomplete[disable autocomplete]' \
  '--host[database host]:host' \
  '(-p --port)'{-p,--port}'[database port]:port' \
  '(-U --user)'{-U,--user}'[database user]:user' \
  '--password[database password]:password' \
  '(-d --database)'{-d,--database}'[database name]:database' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:database path or connection string:_files' && ret=0

return ret
