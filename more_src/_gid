#compdef gid
# Documentation: man gid(1)
# Source: GNU idutils gid (man) — query ID database (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-f --file)'{-f+,--file=}'[ID database file]:file:_files' \
    '(-i --ignore-case)'{-i,--ignore-case}'[case-insensitive match]' \
    '(-l --literal -r --regexp -w --word -s --substring)'{-l,--literal}'[literal string match]' \
    '(-l --literal -r --regexp -w --word -s --substring)'{-r,--regexp}'[regexp match]' \
    '(-l --literal -r --regexp -w --word -s --substring)'{-w,--word}'[word match]' \
    '(-l --literal -r --regexp -w --word -s --substring)'{-s,--substring}'[substring match]' \
    '(-k --key)'{-k+,--key=}'[key output style]:style:(token pattern none)' \
    '(-R --result)'{-R+,--result=}'[result output style]:style:(filenames grep edit none)' \
    '(-S --separator)'{-S+,--separator=}'[separator style]:style:(braces space newline)' \
    '(-F --frequency)'{-F+,--frequency=}'[frequency range N..M]:N..M:_default' \
    '(-a --ambiguous)'{-a+,--ambiguous=}'[find ambiguous-LEN-char names]:LEN:_default' \
    '(-x --hex)'{-x,--hex}'[only hex numbers]' \
    '(-d --decimal)'{-d,--decimal}'[only decimal numbers]' \
    '(-o --octal)'{-o,--octal}'[only octal numbers]' \
    '--help[show help]' \
    '--version[show version]' \
    '*:pattern:_default' \
    && ret=0

return ret
