#compdef heimdall-frontend
# Documentation: https://man.archlinux.org/search?q=heimdall-frontend
# Reference accessed: 2026-05-16

# heimdall-frontend: Qt GUI for Heimdall (Samsung Odin replacement)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '*::heimdall-frontend args:_files' && ret=0
return ret
