#compdef otbcli_ConnectedComponentSegmentation
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ConnectedComponentSegmentation.html
# Orfeo ToolBox: connected component segmentation using a criterion expression

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[the image to segment]:image:_files' \
  '-out[the segmentation shape output]:output:_files' \
  '-mask[mask mathematical expression]:expr:' \
  '-expr[formula used for connected component segmentation]:expr:' \
  '-minsize[min object size in pixels]:value:' \
  '-obia[OBIA mathematical expression]:expr:' \
  '-elev.dem[directory containing DEM files]:dir:_files -/' \
  '-elev.geoid[geoid grid file]:file:_files' \
  '-elev.default[default height above ellipsoid]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
