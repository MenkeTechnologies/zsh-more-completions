#compdef cyclonus
# Documentation: https://github.com/mattfenwick/cyclonus
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Kubernetes NetworkPolicy analyzer/conformance test runner.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'analyze:analyze NetworkPolicies'
  'generate:run NetworkPolicy conformance suite'
  'probe:run a single NetworkPolicy test'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v+,--verbosity=}'[log level]:level:(debug info warn error)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cyclonus command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (analyze)
        _arguments \
          '*--mode=[analysis mode]:mode:(parse explain lint query-traffic query-target probe)' \
          '--context=[kube context]:context:' \
          '(-A --all-namespaces)'{-A,--all-namespaces}'[read all namespaces]' \
          '*'{-n+,--namespace=}'[namespace(s) to read]:namespace:' \
          '--policy-path=[policy file/dir]:path:_files' \
          '--traffic-path=[JSON traffic file]:file:_files' \
          '--target-pod-path=[JSON target pod file]:file:_files' \
          '--probe-path=[JSON probe model file]:file:_files' \
          '--use-example-policies[read example policies]' \
          '--simplify-policies[simplify policies (default true)]' && ret=0 ;;
      (generate|probe)
        _arguments \
          '--context=[kube context]:context:' \
          '*'{-n+,--namespace=}'[namespace]:namespace:' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
