#compdef is
# Documentation: https://github.com/microsoft/inshellisense
# inshellisense: IDE-style command line autocomplete session

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[output the current version]' \
  '(-l --login)'{-l,--login}'[start shell as a login shell]' \
  '(-s --shell)'{-s,--shell}'=[shell to use for command execution]:shell:(bash zsh fish pwsh powershell xonsh nu)' \
  '(-c --check)'{-c,--check}'[check if shell is in an inshellisense session]' \
  '(-T --test)'{-T,--test}'[make e2e tests reproducible across machines]' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose logging]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'inshellisense command' \
      'init[generate shell configuration and print source command]' \
      'reinit[update/reinitialize after upgrading]' \
      'doctor[verify installation was successful]' \
      'complete[generate a completion for the provided input]' \
      'uninstall[remove all bindings and configuration]' && ret=0
    ;;
  args)
    case $line[1] in
      init|reinit)
        _arguments '1:shell:(bash zsh fish pwsh powershell xonsh nu)' && ret=0
        ;;
      complete)
        _arguments '1:input:' && ret=0
        ;;
    esac
    ;;
esac

return ret
