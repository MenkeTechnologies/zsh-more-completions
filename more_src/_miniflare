#compdef miniflare

# Zsh completion for Miniflare - Cloudflare Workers local simulator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-H+[host to listen on]:host' \
  '--host=[host to listen on]:host' \
  '-p+[port to listen on]:port' \
  '--port=[port to listen on]:port' \
  '-d[enable debug logging]' \
  '--debug[enable debug logging]' \
  '-V[enable verbose logging]' \
  '--verbose[enable verbose logging]' \
  '-c+[path to wrangler.toml]:config:_files -g "*.toml"' \
  '--wrangler-config=[path to wrangler.toml]:config:_files -g "*.toml"' \
  '--wrangler-env=[wrangler environment to use]:env' \
  '--package=[path to package.json]:package:_files -g "package.json"' \
  '-m[enable modules mode]' \
  '--modules[enable modules mode]' \
  '--modules-rule=[module resolve rule]:rule' \
  '--compat-date=[compatibility date]:date' \
  '--compat-flag=[compatibility flag]:flag' \
  '--global=[global variable binding]:binding' \
  '-w[watch for changes]' \
  '--watch[watch for changes]' \
  '-u[auto-reload on file change]' \
  '--update-check[check for updates]' \
  '--root=[root directory]:directory:_directories' \
  '--mount=[mount worker]:mount' \
  '--upstream=[URL of upstream origin]:url' \
  '--site=[enable Workers Sites]:directory:_directories' \
  '--site-include=[site include patterns]:patterns' \
  '--site-exclude=[site exclude patterns]:patterns' \
  '--kv=[KV namespace binding]:binding' \
  '--kv-persist=[persist KV data]:path:_directories' \
  '--r2=[R2 bucket binding]:binding' \
  '--r2-persist=[persist R2 data]:path:_directories' \
  '--d1=[D1 database binding]:binding' \
  '--d1-persist=[persist D1 data]:path:_directories' \
  '--do=[Durable Object binding]:binding' \
  '--do-persist=[persist DO data]:path:_directories' \
  '--cache[enable cache]' \
  '--no-cache[disable cache]' \
  '--cache-persist=[persist cache data]:path:_directories' \
  '--env=[path to .env file]:env file:_files' \
  '--binding=[arbitrary binding]:binding' \
  '--live-reload[enable live reload]' \
  '*:script:_files -g "*.{js,mjs,ts}"' && ret=0

return ret
