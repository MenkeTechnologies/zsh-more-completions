#compdef lvmdevices
# _lvmdevices — LVM2 lvmdevices CLI managing the /etc/lvm/devices/system.devices allowlist file restricting which block devices LVM scans for PVs adding deleting checking updating entries enforcing PV-by-UUID device-IDs against accidental disk replacement (LVM team, C); getopt
# upstream: https://gitlab.com/lvmteam/lvm2

_lvmdevices() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-y[answer yes]' \
        '--yes[answer yes]' \
        '--check[check entries]' \
        '--update[update entries]' \
        '--adddev=+[device]:file:_files -g "/dev/sd* /dev/nvme* /dev/mapper/* /dev/mmcblk*"' \
        '--deldev=+[device]:file:_files -g "/dev/sd* /dev/nvme* /dev/mapper/*"' \
        '--addpvid=+[uuid]:str:' \
        '--delpvid=+[uuid]:str:' \
        '--deviceidtype=+[t]:t:(sys_wwid sys_serial mpath_uuid md_uuid loop_file devname wwid_naa wwid_eui wwid_t10)' \
        '--deviceid=+[id]:str:' \
        '--devicesfile=+[file]:file:_files' \
        '--config=+[config]:str:' \
        '--commandprofile=+[profile]:str:' \
        '--profile=+[profile]:str:' \
        '--debug[debug]' \
        '*:device:_files -g "/dev/sd* /dev/nvme* /dev/mapper/*"'
}

_lvmdevices "$@"
