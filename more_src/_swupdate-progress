#compdef swupdate-progress
# Documentation: source-direct extraction from upstream
# sbabic/swupdate tools/swupdate-progress.c lines 64-92
# (the `static struct option long_options[]` array and the
# usage() printf block).  Short-option string at line 251:
# `getopt_long(argc, argv, "cwprhs:e:q", long_options, NULL)`.
# Reference accessed: 2026-05-30 via gh api.
# Sister tool to R210's swupdate.  swupdate-progress connects
# to a running SWUpdate daemon's progress socket and drives
# user-feedback during an update: prints a progress bar (or
# JSON if --quiet+--exec), optionally forwards step/% updates
# to psplash, optionally executes a callback script when the
# update finishes, and optionally reboots on success.  Used as
# the LCD-display / LED-blink driver during industrial firmware
# updates.

# Flags decoded source-direct from long_options[]:
#   -h --help        (no_argument)
#   -p --psplash     (no_argument; forward step/% to psplash)
#   -r --reboot      (optional_argument; script path OR raw
#                     reboot() syscall if omitted)
#   -w --wait        (no_argument; block until SWUpdate connects)
#   -c --color       (no_argument; ANSI-color the progress bar)
#   -s --socket      (required_argument; progress IPC socket path)
#   -e --exec        (required_argument; script to call on result)
#   -q --quiet       (no_argument; suppress progress bar; pairs
#                     with --exec for headless integration)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '(-p --psplash)'{-p,--psplash}'[send step+percent info to the psplash process]' \
  '(-r --reboot)'{-r-,--reboot=-}'[reboot on success; optional script path overrides reboot() syscall]::script:_files' \
  '(-w --wait)'{-w,--wait}'[wait for a connection with SWUpdate]' \
  '(-c --color)'{-c,--color}'[use ANSI colors to show results]' \
  '(-s --socket)'{-s+,--socket=}'[path to progress IPC socket]:socket:_files' \
  '(-e --exec)'{-e+,--exec=}'[script to call with the result of the update]:script:_files' \
  '(-q --quiet)'{-q,--quiet}'[do not print progress bar (pair with --exec)]'
