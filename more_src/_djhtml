#compdef djhtml

# Zsh completion for djhtml (Django/Jinja HTML template indenter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-t --tabwidth)'{-t,--tabwidth}'[tab width]:width' \
  '(-c --check)'{-c,--check}'[check files without modifying]' \
  '(-d --diff)'{-d,--diff}'[show diff of changes]' \
  '(-i --in-place)'{-i,--in-place}'[modify files in place]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-o --output-file)'{-o,--output-file}'[output file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:template file:_files -g "*.{html,htm,jinja,jinja2,j2,djhtml}"' && ret=0

return ret
