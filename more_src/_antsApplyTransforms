#compdef antsApplyTransforms
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsApplyTransforms.cxx — apply ANTs transforms to an image (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --dimensionality)'{-d+,--dimensionality=}'[image dimensionality]:n:(2 3 4)' \
    '(-e --input-image-type)'{-e+,--input-image-type=}'[input image type]:type:(0 1 2 3 4 5)' \
    '--time-index=[time index for 4D input]:n:_default' \
    '(-i --input)'{-i+,--input=}'[input image]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '(-r --reference-image)'{-r+,--reference-image=}'[reference image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-o --output)'{-o+,--output=}'[output image / composite transform]:file:_files' \
    '(-n --interpolation)'{-n+,--interpolation=}'[interpolation method]:method:(Linear NearestNeighbor MultiLabel Gaussian BSpline CosineWindowedSinc WelchWindowedSinc HammingWindowedSinc LanczosWindowedSinc GenericLabel)' \
    '(-u --output-data-type)'{-u+,--output-data-type=}'[output data type]:type:(char uchar short ushort int uint float double default)' \
    '*'{-t+,--transform=}'[transform (repeatable, last on command line applied first)]:transform:_default' \
    '(-f --default-value)'{-f+,--default-value=}'[default value for out-of-bounds]:n:_default' \
    '-z+[invert next transform]:n:_default' \
    '--static-cast-for-R=[static-cast for R compatibility]:n:(0 1)' \
    '--float=[use float precision]:n:(0 1)' \
    '(- *)'{-v,--verbose}'[verbose]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
