#compdef nix-your-shell
# Documentation: https://man.archlinux.org/search?q=nix-your-shell
# Reference accessed: 2026-05-16

# Zsh completion for nix-your-shell (MercuryTechnologies/nix-your-shell, src/main.rs). Default subcommand is env when only the shell operand is given.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--log=[tracing filter; try debug or trace]:filter:' \
  '--absolute[emit absolute path to this binary in snippets]' \
  '--nom[run via nix-output-monitor instead of nix]' \
  '*--shell-arg=[extra argument forwarded to the shell]:arg:' \
  '1:shell executable or path:_command_names -e' \
  '2::subcommand:((env nix-shell nix))' \
  '*::args:_default'
