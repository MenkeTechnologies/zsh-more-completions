#compdef t1testpage
# Documentation: t1testpage --help (lcdf-typetools)
# Source: lcdf-typetools t1testpage — render a Type 1 font proof PostScript.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*(-g --glyph)'{-g,--glyph=}'[limit output to this glyph]:glyph:' \
    '(-s --smoke)'{-s,--smoke}'[smoke proofs (one char per page)]' \
    '(-o --output)'{-o,--output=}'[output file]:file:_files' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:Type 1 font (PFA / PFB):_files -g "*.{pfa,pfb}"' \
    && ret=0

return ret
