#compdef changelogen

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'gh:GitHub release operations'
)

_arguments -C \
  '--dir=[git repo path]:dir:_files -/' \
  '--token=[GitHub token]:token:' \
  '--from=[start commit]:ref:' \
  '--to=[end commit]:ref:' \
  '--output=[output file]:file:_files' \
  '--no-output[stdout only]' \
  '--bump[compute semver bump]' \
  '--release[bump version, commit and tag]' \
  '--publish[publish to npm]' \
  '--canary[canary release]' \
  '-r[release as specific version]:version:' \
  '--major[major bump]' \
  '--minor[minor bump]' \
  '--patch[patch bump]' \
  '--premajor[pre-major bump]' \
  '--preminor[pre-minor bump]' \
  '--prepatch[pre-patch bump]' \
  '--prerelease[prerelease bump]' \
  '--clean[exit if dirty]' \
  '--noAuthors[skip contributors section]' \
  '--hideAuthorEmail[hide author email]' \
  '--publishTag=[npm dist-tag]:tag:' \
  '--nameSuffix=[name suffix]:suffix:' \
  '--versionSuffix=[version suffix]:suffix:' \
  '--no-commit[skip commit]' \
  '--no-tag[skip tag]' \
  '--push[push tag and commit]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'changelogen subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (gh)
        _values 'gh action' 'release' && ret=0
        ;;
    esac
    ;;
esac

return ret
