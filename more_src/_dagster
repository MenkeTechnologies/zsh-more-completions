#compdef dagster

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'api:internal API commands'
      'asset:manage assets'
      'code-location:manage code locations'
      'definitions:manage definitions'
      'dev:start development server'
      'instance:manage instances'
      'job:manage jobs'
      'run:manage runs'
      'schedule:manage schedules'
      'sensor:manage sensors'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      dev)
        _arguments -s -S \
          '(-f --python-file)'{-f,--python-file}'[Python file]:file:_files -g "*.py"' \
          '(-m --module-name)'{-m,--module-name}'[Python module name]:module' \
          '(-d --working-directory)'{-d,--working-directory}'[working directory]:directory:_directories' \
          '(-p --port)'{-p,--port}'[port]:port' \
          '--host=[host]:host' \
          '--log-level=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
          '--log-format=[log format]:format:(colored json rich)' \
          '--live-data-poll-rate=[poll rate in seconds]:seconds' \
          '--code-server-log-level=[code server log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      job)
        _arguments -s -S \
          '1:action:(execute launch list print scaffold backfill)' && ret=0
        ;;
      asset)
        _arguments -s -S \
          '1:action:(list materialize wipe check)' && ret=0
        ;;
      schedule)
        _arguments -s -S \
          '1:action:(list start stop restart logs preview wipe debug)' && ret=0
        ;;
      sensor)
        _arguments -s -S \
          '1:action:(list start stop cursor preview)' && ret=0
        ;;
      instance)
        _arguments -s -S \
          '1:action:(info migrate reindex)' && ret=0
        ;;
    esac
    ;;
esac

return ret
