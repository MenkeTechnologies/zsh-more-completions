#compdef yad

# Zsh completion for yad (Yet Another Dialog)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--title[set dialog title]:title' \
  '--window-icon[set window icon]:icon:_files' \
  '--width[set dialog width]:width' \
  '--height[set dialog height]:height' \
  '--posx[set X position]:x' \
  '--posy[set Y position]:y' \
  '--geometry[set dialog geometry]:geometry' \
  '--timeout[set dialog timeout]:seconds' \
  '--timeout-indicator[show timeout indicator]:position:(top bottom left right)' \
  '--text[set dialog text]:text' \
  '--text-align[text alignment]:alignment:(left center right fill)' \
  '--image[set dialog image]:image:_files -g "*.{png,jpg,svg,xpm}"' \
  '--image-on-top[place image above text]' \
  '--icon-theme[set icon theme]:theme' \
  '--button[add a button]:button spec' \
  '--no-buttons[do not show buttons]' \
  '--buttons-layout[button layout]:layout:(start end center)' \
  '--no-markup[do not use Pango markup]' \
  '--no-escape[do not close on Escape]' \
  '--borders[set dialog border width]:width' \
  '--always-print-result[always print result]' \
  '--selectable-labels[make labels selectable]' \
  '--sticky[make window sticky]' \
  '--fixed[make window non-resizable]' \
  '--on-top[keep window on top]' \
  '--center[center dialog on screen]' \
  '--maximized[start maximized]' \
  '--fullscreen[start fullscreen]' \
  '--undecorated[remove window decorations]' \
  '--skip-taskbar[do not show in taskbar]' \
  '--splash[set splash window type]' \
  '--plug[embed dialog into socket]:socket ID' \
  '--tabnum[set tab number]:tab number' \
  '--parent-win[set parent window]:window ID' \
  '--kill-parent[send signal to parent]:signal' \
  '--print-xid[print X window ID]' \
  '--close-on-unfocus[close on focus loss]' \
  '--calendar[display calendar dialog]' \
  '--color[display color selection dialog]' \
  '--dnd[display drag-and-drop dialog]' \
  '--entry[display entry dialog]' \
  '--file[display file selection dialog]' \
  '--font[display font selection dialog]' \
  '--form[display form dialog]' \
  '--icons[display icons dialog]' \
  '--list[display list dialog]' \
  '--multi-progress[display multi-progress dialog]' \
  '--notebook[display notebook dialog]' \
  '--notification[display notification icon]' \
  '--paned[display paned dialog]' \
  '--picture[display picture dialog]' \
  '--print[display print dialog]' \
  '--progress[display progress dialog]' \
  '--scale[display scale dialog]' \
  '--text-info[display text information dialog]' \
  '--separator[set output separator]:separator' \
  '--item-separator[set input item separator]:separator' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--about[show about dialog]' \
  '--rest[read extra arguments from file]:file:_files' \
  '--gdk-debug[GDK debug flags]:flags' \
  '--gdk-no-debug[GDK no-debug flags]:flags' \
  '--gtk-module[load GTK module]:module' \
  '--display[specify X display]:display' && ret=0

return ret
