#compdef write-good

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--parse[show parse tree]' \
  '--text=[check a string of text]:text' \
  '--no-passive[disable passive voice check]' \
  '--no-illusion[disable lexical illusion check]' \
  '--no-so[disable "so" at sentence start check]' \
  '--no-thereIs[disable "there is/there are" check]' \
  '--no-weasel[disable weasel words check]' \
  '--no-adverb[disable adverb check]' \
  '--no-tooWordy[disable too wordy check]' \
  '--no-cliches[disable cliches check]' \
  '--no-eprime[disable E-Prime check]' \
  '--yes-passive[enable only passive voice check]' \
  '--yes-illusion[enable only lexical illusion check]' \
  '--yes-so[enable only "so" check]' \
  '--yes-thereIs[enable only "there is/there are" check]' \
  '--yes-weasel[enable only weasel words check]' \
  '--yes-adverb[enable only adverb check]' \
  '--yes-tooWordy[enable only too wordy check]' \
  '--yes-cliches[enable only cliches check]' \
  '--yes-eprime[enable only E-Prime check]' \
  '*:file:_files' && ret=0

return ret
