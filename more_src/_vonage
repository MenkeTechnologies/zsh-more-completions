#compdef vonage

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'apps:manage Vonage applications'
  'auth:manage authentication credentials'
  'balance:show account balance'
  'conversations:manage conversations'
  'jwt:manage JWT tokens'
  'members:manage application members'
  'numbers:manage Vonage numbers'
  'users:manage users'
  'mock:launch a Vonage mock server (via Prism)'
  'verify:verify API commands'
  'video:Video API commands'
  'messages:Messages API commands'
  'voice:Voice API commands'
  'rtc:RTC API commands'
  'network:Network APIs commands'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
  'autocomplete:setup tab autocomplete'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--api-key=[Vonage API key]:key:' \
  '--api-secret=[Vonage API secret]:secret:' \
  '--app-id=[Vonage application id]:id:' \
  '--private-key=[private key file path]:file:_files' \
  '--output=[output format]:format:(json yaml table)' \
  '--force[force the operation]' \
  '--color=[color output]:mode:(auto always never)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vonage command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (apps)
        local -a app_subs=(
          'list:list applications'
          'create:create an application'
          'delete:delete an application'
          'update:update an application'
          'show:show application details'
          'numbers:manage application numbers'
        )
        _describe -t acmds 'apps subcommand' app_subs && ret=0 ;;
      (auth)
        _arguments '*::sub:(set check show clear)' && ret=0 ;;
      (numbers)
        local -a num_subs=(
          'list:list owned numbers'
          'search:search available numbers'
          'buy:buy a number'
          'cancel:cancel a number'
          'update:update number routing'
          'show:show number details'
        )
        _describe -t ncmds 'numbers subcommand' num_subs && ret=0 ;;
      (users)
        _arguments '*::sub:(list create delete update show)' && ret=0 ;;
      (jwt)
        _arguments '*::sub:(generate decode validate)' && ret=0 ;;
      (conversations)
        _arguments '*::sub:(list create delete update show events members)' && ret=0 ;;
      (members)
        _arguments '*::sub:(list create delete update show)' && ret=0 ;;
      (mock)
        _arguments '*::api:(sms voice messages verify number-insight applications conversation)' && ret=0 ;;
      (verify)
        _arguments '*::sub:(start check cancel template)' && ret=0 ;;
      (video)
        _arguments '*::sub:(session token archive broadcast)' && ret=0 ;;
      (messages)
        _arguments '*::sub:(send sms whatsapp viber facebook)' && ret=0 ;;
      (voice)
        _arguments '*::sub:(call transfer mute unmute hangup)' && ret=0 ;;
      (network)
        _arguments '*::sub:(verify location authentication)' && ret=0 ;;
      (rtc)
        _arguments '*::sub:(token capability)' && ret=0 ;;
      (completion|autocomplete)
        _arguments '*::shell:(bash zsh fish)' && ret=0 ;;
    esac ;;
esac

return ret
