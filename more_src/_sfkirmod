#compdef sfkirmod
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mkirmod.c
# Madagascar: Kirchhoff 2-D/2.5-D modeling with analytical Green's functions

local ret=1

_arguments -s -S \
  'lin=[if linear operator]:lin:(y n)' \
  'adj=[adjoint flag]:adj:(y n)' \
  'absoff=[y - h0 is not in shot coordinate system]:absoff:(y n)' \
  'nt=[time samples]:nt' \
  'dt=[time sampling]:dt' \
  't0=[time origin]:t0' \
  'ns=[number of shots (midpoints if cmp=y)]:ns' \
  's0=[first shot (midpoint if cmp=y)]:s0' \
  'ds=[shot/midpoint increment]:ds' \
  'nh=[number of offsets]:nh' \
  'h0=[first offset]:h0' \
  'dh=[offset increment]:dh' \
  'verb=[verbosity flag]:verb:(y n)' \
  'refl=[reflectivity (A)]:refl:_files' \
  'r0=[normal reflectivity (if constant)]:r0' \
  'rgrad=[AVO gradient file (B/A)]:rgrad:_files' \
  'dip=[reflector dip file]:dip:_files' \
  'picks=[output traveltime picks]:picks:_files' \
  'slopes=[output receiver slopes]:slopes:_files' \
  'vel=[velocity]:vel' \
  'gradx=[horizontal velocity gradient]:gradx' \
  'gradz=[vertical velocity gradient]:gradz' \
  'velz=[vertical velocity for VTI anisotropy]:velz' \
  'eta=[parameter for VTI anisotropy]:eta' \
  'type=[velocity type: c constant, s linear sloth, v linear velocity, a VTI]:type:(c s v a)' \
  'twod=[2-D or 2.5-D]:twod:(y n)' \
  'refx=[reference x-coordinate for velocity]:refx' \
  'refz=[reference z-coordinate for velocity]:refz' \
  'vel2=[converted velocity]:vel2' \
  'gradx2=[converted velocity horizontal gradient]:gradx2' \
  'gradz2=[converted velocity vertical gradient]:gradz2' \
  'type2=[velocity type for converted (receiver) branch]:type2:(c s v a)' \
  'refx2=[reference x-coordinate for converted velocity]:refx2' \
  'refz2=[reference z-coordinate for converted velocity]:refz2' \
  'cmp=[compute CMP instead of shot gathers]:cmp:(y n)' \
  'freq=[peak frequency for Ricker wavelet]:freq' \
  '*:RSF file:_files' && ret=0

return ret
