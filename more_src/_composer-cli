#compdef composer-cli
# Documentation: https://github.com/osbuild/weldr-client
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'blueprints:manage blueprints'
  'modules:list available modules'
  'projects:list available projects'
  'sources:manage source repositories'
  'compose:start compose builds'
  'status:show service status'
  'help:show help'
  'distros:list available distros'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--socket=[connect to socket path]:file:_files' \
  '--api=[API version]:n:' \
  '--test=[testing mode]:n:' \
  '--json[JSON output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'composer-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (blueprints) _values 'subcommand' 'list' 'show' 'changes' 'diff' 'save' 'depsolve' 'push' 'delete' 'workspace' 'tag' 'undo' 'freeze' && ret=0 ;;
      (compose) _values 'subcommand' 'list' 'status' 'types' 'start' 'start-ostree' 'log' 'cancel' 'delete' 'info' 'metadata' 'logs' 'results' 'image' && ret=0 ;;
      (sources) _values 'subcommand' 'list' 'info' 'add' 'change' 'delete' && ret=0 ;;
      (modules) _values 'subcommand' 'list' 'info' && ret=0 ;;
      (projects) _values 'subcommand' 'list' 'info' && ret=0 ;;
      (status) _values 'subcommand' 'show' && ret=0 ;;
      (distros) _values 'subcommand' 'list' && ret=0 ;;
    esac ;;
esac

return ret
