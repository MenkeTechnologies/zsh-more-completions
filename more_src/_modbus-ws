_modbus-ws() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-s --serial)'{-s,--serial}'=[use serial port (e.g. /dev/ttyUSB0)]:port:_files -g "/dev/tty*"' \
        '(-b --baudrate)'{-b,--baudrate}'=[serial port baud rate (default 9600)]:baud:(1200 2400 4800 9600 19200 38400 57600 115200)' \
        '(-i --ip)'{-i,--ip}'=[use TCP/IP — set slave URL or IP address]:ip:' \
        '(-P --tcpport)'{-P,--tcpport}'=[bridge WebSocket/HTTP server port (default 3000)]:port:' \
        '(-c --nocache)'{-c,--nocache}'[do not use caching for Modbus communication]' \
        '(-w --nohttp)'{-w,--nohttp}'[run only WebSocket server (skip bundled HTTP server)]' \
        '(-m --maxlength)'{-m,--maxlength}'=[max registers/coils per Modbus request (default 10)]:n:'
}

_modbus-ws "$@"
