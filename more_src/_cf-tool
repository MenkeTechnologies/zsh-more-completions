#compdef cf-tool
# Documentation: https://github.com/xalanq/cf-tool
# Reference accessed: 2026-05-17
# Verified: upstream README at the URL above.

# cf-tool: Codeforces CLI (xalanq/cf-tool)
local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'config:configure handle, password and templates'
  'submit:submit code to Codeforces'
  'list:list problem statistics for a contest'
  'parse:fetch problem samples locally'
  'gen:generate code from templates'
  'test:compile and test code against samples'
  'watch:monitor submission status'
  'open:open problem page in browser'
  'stand:show contest standings'
  'sid:open specific submission page'
  'race:start competing with countdown'
  'pull:pull codes from solved problems'
  'clone:clone all codes of a user'
  'upgrade:update to the latest version'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'cf-tool command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
