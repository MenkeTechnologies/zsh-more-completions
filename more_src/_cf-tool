#compdef cf-tool

# xalanq/cf-tool — Codeforces CLI; subcommands include submit, parse, race, etc. (see upstream `cf-tool --help`).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'submit:submit solution'
  'list:list contests/problems'
  'parse:download samples'
  'gen:generate gen template'
  'race:watch standings'
  'watch:watch submissions'
  'open:open problem URL'
  'stand:show standings'
  'sid:print last submission id'
  'pull:pull all templates'
  'upgrade:self-upgrade'
  'config:configure credentials'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'cf-tool command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
