#compdef znapzendztatz
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=znapzendztatz&sektion=1
# znapzendztatz: show statistics of snapshots and storage used by znapzend

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help and exit]' \
  '--man[display man page and exit]' \
  '--debug[print debugging details from some library routines]' \
  '-H[suppress headers and separate fields by a single tab]' \
  '(-r --recursive)'{-r,--recursive}'[show statistics for dataset and sub datasets]' \
  '--inherited[allow specifying a dataset that inherits a backup plan]' \
  '--only-enabled[only show statistics for enabled datasets]' \
  '--setup[show the configuration key and the filesystem defining it]' \
  '--rootExec=[exec zfs via this command to obtain root (sudo or pfexec)]:cmd:(sudo pfexec)' \
  '--timeWarp=[act as if shifted by x seconds into the future]:seconds' \
  '*:src dataset:' && ret=0

return ret
