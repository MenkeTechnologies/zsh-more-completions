#compdef fwknopd
# Documentation: https://man.archlinux.org/search?q=fwknopd
# Reference accessed: 2026-05-16

_arguments -s \
  '(-i --interface)'{-i,--interface=}'[network interface]:iface:_net_interfaces' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '--fw-list[list fwknopd firewall rules]' \
  '--fw-list-all[list all firewall rules]' \
  '--fw-flush[remove fwknopd firewall rules]' \
  '(-a --access-file)'{-a,--access-file=}'[access.conf path]:file:_files' \
  '--access-folder=[access.conf folder]:dir:_files -/' \
  '(-c --config)'{-c,--config=}'[fwknopd.conf path]:file:_files' \
  '(-C --packet-limit)'{-C,--packet-limit=}'[SPA packet limit]:n:' \
  '(-d --digest-file)'{-d,--digest-file=}'[digest.cache path]:file:_files' \
  '(-D --dump-config)'{-D,--dump-config}'[dump derived config]' \
  '--dump-serv-err-codes[list error codes]' \
  '--fault-injection-tag=[libfiu tag]:tag:' \
  '(-A --afl-fuzzing)'{-A,--afl-fuzzing}'[AFL fuzzing mode]' \
  '(-K --kill)'{-K,--kill}'[terminate fwknopd]' \
  '--exit-parse-config[parse config and exit]' \
  '--exit-parse-digest-cache[validate digest and exit]' \
  '(-l --locale)'{-l,--locale=}'[locale override]:locale:' \
  '--no-ipt-check-support[disable iptables -C]' \
  '(-O --override-config)'{-O,--override-config=}'[override config files]:files:' \
  '--key-gen[generate keys to stdout]' \
  '--key-gen-file=[write keys to file]:file:_files' \
  '--key-len=[Rijndael key bytes]:n:' \
  '--hmac-key-len=[HMAC key bytes]:n:' \
  '(-p --pid-file)'{-p,--pid-file=}'[fwknopd.pid path]:file:_files' \
  '(-P --pcap-filter)'{-P,--pcap-filter=}'[BPF filter]:filter:' \
  '--pcap-file=[pcap file]:file:_files -g "*.pcap"' \
  '--pcap-any-direction[sniff both directions]' \
  '(-R --restart)'{-R,--restart}'[restart preserving options]' \
  '--rotate-digest-cache[rotate digest cache]' \
  '(-r --run-dir)'{-r,--run-dir=}'[runtime state dir]:dir:_files -/' \
  '(-S --status)'{-S,--status}'[show status]' \
  '--syslog-enable[send to syslog in foreground]' \
  '(-t --test)'{-t,--test}'[test SPA without firewall]' \
  '(-U --udp-server)'{-U,--udp-server}'[UDP socket mode]' \
  '*'{-v,--verbose}'[verbose]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--Version}'[show version]'
