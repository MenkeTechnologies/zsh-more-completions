#compdef cabal-cli
# _cabal-cli — Haskell cabal build tool CLI alias (haskell team, Haskell); custom argparse
# upstream: https://github.com/haskell/cabal

_cabal-cli() {
    local -a sub=(
        'install:install packages'
        'update:update package index'
        'list:list packages matching search'
        'info:show detailed info about a package'
        'fetch:fetch packages for later use'
        'build:compile target'
        'configure:configure how the project is built'
        'haddock:build haddocks'
        'haddock-project:build multi-package haddocks'
        'clean:clean build artifacts'
        'run:run target executable'
        'repl:start ghci with project context'
        'test:run tests'
        'bench:run benchmarks'
        'check:check package for common mistakes'
        'sdist:create source dist'
        'upload:upload to hackage'
        'report:upload test report'
        'init:scaffold new package'
        'unpack:unpack source from package'
        'get:unpack source from package'
        'help:show help'
        'gen-bounds:suggest version bounds'
        'outdated:show outdated dependencies'
        'freeze:create cabal.project.freeze'
        'list-bin:list executable paths'
        'man:generate manpage'
        'user-config:user config commands'
        'v1-install:legacy install'
        'v1-build:legacy build'
        'v1-configure:legacy configure'
        'v1-haddock:legacy haddock'
        'v1-clean:legacy clean'
        'v1-run:legacy run'
        'v1-repl:legacy repl'
        'v1-test:legacy test'
        'v1-bench:legacy bench'
        'v1-sandbox:legacy sandbox'
        'v2-install:explicit v2-install'
        'v2-build:explicit v2-build'
        'v2-configure:explicit v2-configure'
        'v2-haddock:explicit v2-haddock'
        'v2-clean:explicit v2-clean'
        'v2-run:explicit v2-run'
        'v2-repl:explicit v2-repl'
        'v2-test:explicit v2-test'
        'v2-bench:explicit v2-bench'
        'path:show cabal paths'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--numeric-version[show numeric version]' \
        '--config-file=+[config file]:file:_files' \
        '--default-user-config=+[default user config]:file:_files' \
        '-v+[verbosity]:l:(0 1 2 3)' \
        '--verbose=+[verbosity]:l:(0 1 2 3)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cabal subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '--lib[install lib only]' \
                    '--package-env=+[env file]:file:_files' \
                    '-z+[env file]:file:_files' \
                    '--installdir=+[install dir]:dir:_files -/' \
                    '--install-method=+[method]:m:(copy symlink)' \
                    '--overwrite-policy=+[policy]:p:(always never prompt)' \
                    '--install-libdir=+[install libdir]:dir:_files -/' \
                    '*:package:' ;;
                build|run|repl|test|bench|haddock) _arguments \
                    '--enable-tests[enable tests]' \
                    '--disable-tests[disable tests]' \
                    '--enable-benchmarks[enable benchmarks]' \
                    '--disable-benchmarks[disable benchmarks]' \
                    '--enable-documentation[enable docs]' \
                    '--disable-documentation[disable docs]' \
                    '--enable-coverage[enable coverage]' \
                    '--disable-coverage[disable coverage]' \
                    '-j+[jobs]:n:' \
                    '--jobs=+[jobs]:n:' \
                    '*:target:' ;;
                init) _arguments \
                    '--non-interactive[non-interactive]' \
                    '-n[non-interactive]' \
                    '--minimal[minimal scaffold]' \
                    '-m[minimal scaffold]' \
                    '--simple[simple cabal file]' \
                    '--package-name=+[name]:str:' \
                    '-p+[name]:str:' \
                    '--package-type=+[type]:t:(library executable both)' \
                    '--executable[executable]' \
                    '--lib[library]' \
                    '--license=+[license]:l:(BSD2 BSD3 MIT Apache-2.0 GPL-2.0-only GPL-3.0-only LGPL-2.1-only LGPL-3.0-only MPL-2.0 AGPL-3.0-only PublicDomain)' \
                    '-l+[license]:l:(BSD2 BSD3 MIT Apache-2.0 GPL-2.0-only GPL-3.0-only LGPL-2.1-only LGPL-3.0-only MPL-2.0 AGPL-3.0-only PublicDomain)' \
                    '--version=+[version]:str:' \
                    '--cabal-version=+[cabal-version]:str:' ;;
                update) _arguments '*:repository:' ;;
                list) _arguments '*:package:' '--simple-output[simple output]' ;;
                info) _arguments '*:package:' ;;
                unpack|get) _arguments '*:package:' '-d+[dest dir]:dir:_files -/' '--destdir=+[dest dir]:dir:_files -/' ;;
                sdist) _arguments \
                    '--list-only[list files only]' \
                    '-l[list files only]' \
                    '--output-directory=+[dir]:dir:_files -/' \
                    '-o+[file]:file:_files' \
                    '--targz[create .tar.gz]' \
                    '--zip[create zip]' ;;
                check) ;;
                gen-bounds) ;;
                outdated) _arguments \
                    '--exit-code[exit non-zero on outdated]' \
                    '--freeze-file[only freeze file]' \
                    '--new-freeze-file[only new-freeze file]' \
                    '--minor[ignore major version updates]' ;;
            esac
            ;;
    esac
}

_cabal-cli "$@"
