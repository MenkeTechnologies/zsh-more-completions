#compdef cog

# Zsh completion for cocogitto/cog (conventional commits tooling)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Create an empty conventional commits repository'
      'commit:Create a conventional commit'
      'check:Verify all commits follow conventional commits spec'
      'edit:Interactively edit commit history'
      'log:Display commits as conventional commits'
      'verify:Verify a single commit message'
      'changelog:Generate a changelog'
      'bump:Bump version based on conventional commits'
      'install-hook:Install cog git hooks'
      'generate-completions:Generate shell completions'
    )
    _describe -t commands 'cog command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      commit)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-B[Make a breaking change commit]' \
          '--breaking-change[Make a breaking change commit]' \
          '-e[Open editor for commit body]' \
          '--edit[Open editor for commit body]' \
          '-s+[Commit scope]:scope' \
          '--scope=[Commit scope]:scope' \
          '1:type:(feat fix docs style refactor perf test build ci chore revert)' \
          '2:message' && ret=0
        ;;
      check)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--from-latest-tag[Check from latest tag]' \
          '-l[Ignore merge commits]' \
          '--ignore-merge-commits[Ignore merge commits]' && ret=0
        ;;
      log)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-t+[Filter by type]:type:(feat fix docs style refactor perf test build ci chore revert)' \
          '--type=[Filter by type]:type:(feat fix docs style refactor perf test build ci chore revert)' \
          '-a+[Filter by author]:author' \
          '--author=[Filter by author]:author' \
          '-s+[Filter by scope]:scope' \
          '--scope=[Filter by scope]:scope' \
          '-B[Show only breaking changes]' \
          '--breaking-change[Show only breaking changes]' \
          '-e[Do not show errors]' \
          '--no-error[Do not show errors]' && ret=0
        ;;
      changelog)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-a+[Generate from tag]:tag' \
          '--at=[Generate from tag]:tag' \
          '-t+[Template path]:file:_files' \
          '--template=[Template path]:file:_files' \
          '-r+[Remote repository URL]:url' \
          '--remote=[Remote repository URL]:url' \
          '-o+[Repository owner]:owner' \
          '--owner=[Repository owner]:owner' \
          '--repository=[Repository name]:name' && ret=0
        ;;
      bump)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--auto[Automatically determine bump type]' \
          '--major[Bump major version]' \
          '--minor[Bump minor version]' \
          '--patch[Bump patch version]' \
          '--pre=[Set pre-release version]:pre' \
          '--build=[Set build metadata]:build' \
          '--dry-run[Show what would happen without making changes]' \
          '--skip-ci[Add skip-ci to commit message]' \
          '--skip-ci-override=[Custom skip-ci string]:string' \
          '--skip-untracked[Skip untracked files check]' \
          '--hook-profile=[Hook profile to use]:profile' && ret=0
        ;;
      verify)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:message' && ret=0
        ;;
      generate-completions)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:shell:(bash zsh fish elvish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
