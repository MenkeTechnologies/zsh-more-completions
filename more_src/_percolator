#compdef percolator
# Documentation: https://crux.ms/commands/percolator.html
# Crux percolator: semi-supervised re-ranking of PSMs.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--train-fdr=[FDR defining positive training examples]:fdr' \
  '--test-fdr=[FDR for hyperparameter selection]:fdr' \
  '--maxiter=[maximum training iterations]:n' \
  '--c-pos=[penalty weight for positive mistakes]:c' \
  '--c-neg=[penalty weight for negative mistakes]:c' \
  '--percolator-seed=[random number generator seed]:seed' \
  '--quick-validation[faster internal cross-validation]' \
  '--subset-max-train=[limit PSMs used for training]:n' \
  '--static[use provided initial weights as static model]' \
  '--test-each-iteration[measure performance per iteration]' \
  '--tdc=[use target-decoy competition for q-values]:bool:(T F)' \
  '--search-input=[target-decoy search type]:type' \
  '--only-psms[report results only at PSM level]' \
  '--no-terminate[do not stop on questionable SVM inputs]' \
  '--train-best-positive[at most one PSM per spectrum in positive set]' \
  '--max-charge-feature=[maximum charge state feature]:n' \
  '--protein-name-separator=[character separating protein IDs]:char' \
  '--spectral-counting-fdr=[report unique/total PSM counts]:fdr' \
  '--protein[enable Fido protein probability inference]' \
  '--picked-protein=[picked protein FDR with FASTA]:file:_files' \
  '--protein-enzyme=[enzyme type for digestion]:enzyme' \
  '--protein-report-duplicates[report duplicate proteins]' \
  '--protein-report-fragments[report protein fragments]' \
  '--fido-alpha=[probability of peptide emission]:p' \
  '--fido-beta=[probability of peptide from noise]:p' \
  '--fido-gamma=[prior probability protein present]:p' \
  '--fido-empirical-protein-q[estimate empirical p-/q-values]' \
  '--fido-fast-gridsearch=[threshold for faster grid search]:t' \
  '--fido-gridsearch-depth=[grid search depth]:n' \
  '--fido-gridsearch-mse-threshold=[q-value threshold for MSE]:t' \
  '--fido-no-split-large-components[skip graph component splitting]' \
  '--fido-protein-truncation-threshold=[probability assignment threshold]:t' \
  '--default-direction=[initial ranking feature by name]:name' \
  '--init-weights=[read initial weights from file]:file:_files' \
  '--output-weights=[output final weights to file]:file:_files' \
  '--klammer[enable retention time features]' \
  '--override[override weight error checking]' \
  '--unitnorm[use unit normalization]' \
  '--decoy-prefix=[prefix identifying decoy proteins]:prefix' \
  '--decoy-xml-output[include decoys in XML output]' \
  '--feature-file-out=[output computed features in PIN]:file:_files' \
  '--pout-output[output Percolator pout.xml]' \
  '--mzid-output[output mzIdentML results]' \
  '--txt-output[output tab-delimited results]' \
  '--top-match=[matches per spectrum]:n' \
  '--fileroot=[prefix for output filenames]:prefix' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--overwrite[replace existing files]' \
  '--parameter-file=[parameter configuration file]:file:_files' \
  '--verbosity=[verbosity level 0-60]:level' \
  '*:pin input:_files' && ret=0

return ret
