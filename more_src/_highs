#compdef highs
# Documentation: https://github.com/ERGO-Code/HiGHS
# HiGHS linear/mixed-integer/quadratic optimization solver

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '--model_file=[file of model to solve]:file:_files' \
  '--options_file=[file containing HiGHS options]:file:_files' \
  '--read_solution_file=[file of solution to read]:file:_files' \
  '--read_basis_file=[file of initial basis to read]:file:_files' \
  '--write_model_file=[file for writing out model]:file:_files' \
  '--solution_file=[file for writing out solution]:file:_files' \
  '--write_basis_file=[file for writing out final basis]:file:_files' \
  '--presolve=[presolve option]:option:(choose on off)' \
  '--solver=[solver option]:option:(choose simplex ipm)' \
  '--parallel=[parallel option]:option:(choose on off)' \
  '--run_crossover=[crossover option]:option:(choose on off)' \
  '--time_limit=[run time limit in seconds]:seconds' \
  '--random_seed=[seed for random number generation]:seed' \
  '--ranging=[compute cost/bound/RHS/solution ranging]:option:(on off)' \
  '*:file:_files' && ret=0

return ret
