#compdef sk skim
# Documentation: https://github.com/lotabout/skim/blob/master/man/man1/sk.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-b --bind)*'{-b+,--bind=}'[key bindings csv]:list:' \
  '(-m --multi)'{-m,--multi}'[multi-select]' \
  '(--no-multi)--no-multi[disable multi-select]' \
  '(-p --prompt)'{-p+,--prompt=}'[prompt]:s:' \
  '(--cmd-prompt)--cmd-prompt=[command prompt]:s:' \
  '(-e --exact)'{-e,--exact}'[exact match]' \
  '(--regex)--regex[regex match]' \
  '(--algo)--algo=[fuzzy algo]:a:(skim_v1 skim_v2)' \
  '(--case)--case=[case sensitivity]:c:(respect ignore smart)' \
  '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
  '(-c --cmd)'{-c+,--cmd=}'[command]:c:' \
  '(-q --query)'{-q+,--query=}'[initial query]:q:' \
  '(--cmd-query)--cmd-query=[command query]:q:' \
  '(--print-query)--print-query[print query]' \
  '(--print-cmd)--print-cmd[print command]' \
  '(-1 --select-1)'{-1,--select-1}'[auto-select if one]' \
  '(-0 --exit-0)'{-0,--exit-0}'[exit if no match]' \
  '(--sync)--sync[synchronous]' \
  '(--ansi)--ansi[ANSI color]' \
  '(--no-mouse)--no-mouse[disable mouse]' \
  '(--no-clear)--no-clear[no clear screen]' \
  '(--no-clear-start)--no-clear-start[no clear at start]' \
  '(--no-bold)--no-bold[no bold]' \
  '(--no-hscroll)--no-hscroll[no horizontal scroll]' \
  '(--no-sort)--no-sort[no sort]' \
  '(--reverse)--reverse[reverse layout]' \
  '(--layout)--layout=[layout]:l:(default reverse reverse-list)' \
  '(--height)--height=[height]:h:' \
  '(--min-height)--min-height=[min height]:h:' \
  '(--no-height)--no-height[no height]' \
  '(--margin)--margin=[margin]:m:' \
  '(--padding)--padding=[padding]:p:' \
  '(--inline-info)--inline-info[inline info]' \
  '(--header)--header=[header text]:h:' \
  '(--header-lines)--header-lines=[header lines]:n:' \
  '(--history)--history=[history file]:file:_files' \
  '(--cmd-history)--cmd-history=[cmd history file]:file:_files' \
  '(--history-size)--history-size=[history size]:n:' \
  '(--preview)--preview=[preview command]:c:' \
  '(--preview-window)--preview-window=[preview window]:w:' \
  '(-d --delimiter)'{-d+,--delimiter=}'[field delimiter]:s:' \
  '(-n --nth)*'{-n+,--nth=}'[fields to match]:n:' \
  '(--with-nth)--with-nth=[fields to display]:n:' \
  '(-t --tiebreak)'{-t+,--tiebreak=}'[tiebreak]:t:(score begin end length)' \
  '(--filter -f)'{-f+,--filter=}'[non-interactive filter]:q:' \
  '(--engine-factory)--engine-factory=[engine]:e:' \
  '(--tabstop)--tabstop=[tab stop]:n:' \
  '(--color)--color=[color scheme]:c:(16 dark light bw)' \
  '(--keep-right)--keep-right[keep right]' \
  '(--skip-to-pattern)--skip-to-pattern=[pattern]:p:' \
  '(--no-clear-if-empty)--no-clear-if-empty[no clear if empty]' \
  '(--show-cmd-error)--show-cmd-error[show cmd error]' \
  '(--read0)--read0[null delimited input]' \
  '(--print0)--print0[null delimited output]' \
  '(--tac)--tac[reverse input order]' \
  '(--no-bold)--no-bold[no bold]' \
  '(--reverse)--reverse[reverse]' \
  '*: :_files' && ret=0

return ret
