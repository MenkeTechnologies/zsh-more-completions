#compdef SplitIntervals
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/SplitIntervals.java
# GATK4: split intervals into sub-interval files for scatter-gather

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-L --intervals)'{-L,--intervals}'[genomic intervals to operate on]:intervals:_files' \
  '(-O --output)'{-O,--output}'[directory into which to write the scattered interval sub-directories]:dir:_files -/' \
  '(-scatter --scatter-count)'{-scatter,--scatter-count}'=[number of output interval files to split into]:count:' \
  '(-mode --subdivision-mode)'{-mode,--subdivision-mode}'=[how to divide intervals]:mode:' \
  '--min-contig-size=[minimum contig size to keep if getting intervals from the reference]:size:' \
  '--interval-file-prefix=[prefix to use when writing interval files]:prefix:' \
  '--interval-file-num-digits=[number of digits to use when writing interval files]:digits:' \
  '--extension=[extension to use when writing interval files]:ext:' \
  '--dont-mix-contigs[do not put intervals from multiple contigs in one scattered file]' \
  '*:options:_files' && ret=0

return ret
