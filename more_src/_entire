#compdef entire
# Documentation: https://docs.entire.io/cli/commands
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_entire() {
    local line state
    local -a commands
    commands=(
        'enable:Initialize Entire in a Git repository'
        'status:Show details of the currently active agent session'
        'rewind:Restore repository to a previous checkpoint'
        'explain:Generate AI-powered summary of a session'
        'resume:Pick up an agent session where it left off'
        'login:Authenticate with entire.io'
        'activity:Display summary of agent activity'
        'dispatch:Generate a summary report of recent agent work'
        'labs:Experimental workflows and features'
    )

    _arguments -C \
        '--version[Show version]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'entire command' commands
            ;;
    esac
}

_entire "$@"
