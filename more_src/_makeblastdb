#compdef makeblastdb
# Documentation: https://man.archlinux.org/search?q=makeblastdb
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-help[show help]' \
  '-version[show version]' \
  '-in=[input file]:file:_files' \
  '-input_type=[input type]:type:(asn1_bin asn1_txt blastdb fasta)' \
  '-dbtype=[database type]:type:(nucl prot)' \
  '-title=[database title]:title:' \
  '-parse_seqids[parse sequence IDs]' \
  '-hash_index[create hash index]' \
  '-mask_data=[masking data files]:files:_files' \
  '-mask_id=[masking algorithm IDs]:ids:' \
  '-mask_desc=[masking algorithm descriptions]:descriptions:' \
  '-gi_mask[create GI indexed masking data]' \
  '-gi_mask_name=[GI mask name]:name:' \
  '-out=[output database name]:name:' \
  '-max_file_sz=[max file size]:size:' \
  '-logfile=[log file]:file:_files' \
  '-taxid=[taxonomy ID]:id:' \
  '-taxid_map=[taxonomy ID map file]:file:_files' \
  '-blastdb_version=[BLAST database version]:version:(4 5)' \
  '-metadata_output_prefix=[metadata output prefix]:prefix:' \
  '*:file:_files' && ret=0

return ret
