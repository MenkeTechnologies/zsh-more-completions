#compdef ftstat
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftstat.html
# Compute numerical statistics for FITS images and table columns

local ret=1

_arguments -s -S \
  'infile=[input FITS file with optional HDU extension]:infile:_files' \
  'outfile=[output text report file, default STDOUT]:outfile:_files' \
  'centroid=[enable image centroid calculation]:centroid:(yes no)' \
  'clip=[apply iterative sigma-clipping]:clip:(yes no)' \
  'nsigma=[sigma rejection threshold]:nsigma:' \
  'maxiter=[max clipping iterations]:maxiter:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  '*:file:_files' && ret=0

return ret
