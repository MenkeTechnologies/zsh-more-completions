#compdef kubent

_kubent() {
  _arguments \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --version)'{-v,--version}'[Print version]' \
    '(-o --output)'{-o,--output}'[Output format]:format:(text json csv)' \
    '(-f --filename)'{-f,--filename}'[Scan specific files]:file:_files' \
    '(-l --target-version)'{-l,--target-version}'[Target Kubernetes version]:version:' \
    '(-c --cluster)'{-c,--cluster}'[Scan live cluster]' \
    '(-A --additional-kind)'{-A,--additional-kind}'[Additional resource kind]:kind:' \
    '(-e --exit-error)'{-e,--exit-error}'[Exit with error on deprecations found]' \
    '--context[Kubernetes context]:context:' \
    '--kubeconfig[Kubeconfig file]:file:_files' \
    '--helm2[Scan Helm 2 releases]' \
    '--helm3[Scan Helm 3 releases]' \
    '--no-headers[Do not print headers]' \
    '--log-level[Log level]:level:(trace debug info warn error fatal panic)' \
    '-d[Directory to scan]:directory:_directories'
}

_kubent "$@"
