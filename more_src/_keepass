#compdef keepass keepass2
# Documentation: https://manpages.debian.org/bookworm/keepass2/keepass2.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm keepass2(1) manpage. KeePass and KeePass2 share
# the same documented options.

# KeePass: cross-platform password manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '--auto-type[invoke global auto-type]' \
  '--lock-all[lock databases of all KeePass instances]' \
  '--unlock-all[unlock databases of all KeePass instances]' \
  '--exit-all[exit all KeePass instances]' \
  '*:database:_files -g "*.kdbx"' && ret=0
return ret
