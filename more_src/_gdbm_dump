#compdef gdbm_dump
# Documentation: gdbm_dump --help (GNU GDBM)
# Source: dump a GDBM database to a file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--usage[short usage]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-H --format)'{-H+,--format=}'[dump format]:format:(binary ascii 0 1)' \
    '1:gdbm file:_files' \
    '2:dump file:_files' \
    && ret=0

return ret
