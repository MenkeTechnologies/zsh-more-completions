#compdef hugin_stitch_project

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--batch[run as batch job]' \
  '--delete[delete project file when done]' \
  '--output=[output filename]:file:_files' \
  '--user-defined-output=[user defined script]:script:_files' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
