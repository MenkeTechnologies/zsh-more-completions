#compdef bitwarden-cli2 bw2
# _bitwarden-cli2 — Bitwarden Inc bitwarden-cli2 CLI command-line frontend wrapping the Bitwarden open-source password manager CLI bw written in TypeScript Node interface to a Bitwarden vault from a terminal can do everything from the Bitwarden web vault and more login logout unlock lock sync status list get create edit delete restore share send confirm import export generate encode receive update completion config serve completion folder-collection organization-collection collection-org item attachments folder organization send template (Bitwarden Inc team Kyle Spearrin, TypeScript); commander
# upstream: https://bitwarden.com/

_bitwarden-cli2() {
    local -a sub=(
        'login:log into a Bitwarden account'
        'logout:log out of a Bitwarden account'
        'lock:lock vault'
        'unlock:unlock vault'
        'sync:sync vault'
        'generate:generate password/passphrase'
        'encode:base64 encode'
        'config:configure server'
        'update:check CLI updates'
        'completion:generate shell completion'
        'status:show status'
        'list:list objects'
        'get:get an object'
        'create:create an object'
        'edit:edit an object'
        'delete:delete an object'
        'restore:restore an object'
        'share:share an object'
        'move:move an object'
        'confirm:confirm a member'
        'import:import a vault'
        'export:export the vault'
        'send:send operations'
        'receive:receive a send'
        'template:get an object template'
        'serve:run as REST server'
        'pending:pending operations'
        'history:command history'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--pretty[pretty output]' \
        '--raw[raw output]' \
        '--response[full response]' \
        '--cleanexit[clean exit]' \
        '--quiet[quiet]' \
        '--nointeraction[no interaction]' \
        '--session=+[token]:str:' \
        '-f+[format]:f:(json csv)' \
        '--format=+[fmt]:f:(json csv)' \
        '--method=+[m]:m:(0 1 3 6)' \
        '--code=+[code]:str:' \
        '--apikey[API key auth]' \
        '--sso[SSO]' \
        '--check[check installation]' \
        '--passwordfile=+[file]:file:_files' \
        '--passwordenv=+[name]:str:' \
        '--organizationid=+[id]:str:' \
        '--collectionid=+[id]:str:' \
        '--folderid=+[id]:str:' \
        '--itemid=+[id]:str:' \
        '--server=+[url]:str:' \
        '--web-vault=+[url]:str:' \
        '--api=+[url]:str:' \
        '--identity=+[url]:str:' \
        '--icons=+[url]:str:' \
        '--notifications=+[url]:str:' \
        '--events=+[url]:str:' \
        '--key-connector=+[url]:str:' \
        '-l+[length]:n:' \
        '--length=+[N]:n:' \
        '-u[uppercase]' \
        '--uppercase[uppercase]' \
        '-c[capitalize]' \
        '--capitalize[capitalize]' \
        '-l[lowercase]' \
        '--lowercase[lowercase]' \
        '-n[numbers]' \
        '--number[include numbers]' \
        '--special[include special chars]' \
        '-s[special chars]' \
        '-p[passphrase]' \
        '--passphrase[passphrase]' \
        '--words=+[N]:n:' \
        '--separator=+[c]:str:' \
        '--includeNumber[include number]' \
        '--minNumber=+[N]:n:' \
        '--minSpecial=+[N]:n:' \
        '--input=+[file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--port=+[port]:n:' \
        '--hostname=+[host]:_hosts' \
        '--password=+[password]:str:' \
        '--ambiguous[no ambiguous chars]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bw subcommand' sub ;;
        args)
            case $words[1] in
                list) _arguments '1:type:(items folders collections org-collections org-members organizations sends)' '*:arg:' ;;
                get) _arguments '1:type:(item username password uri totp notes exposed attachment folder collection org-collection organization template fingerprint send)' '*:id:' ;;
                create|edit|delete|restore) _arguments '1:type:(item attachment folder org-collection)' '*:id:' ;;
                send) _arguments '1:op:(create get edit delete list remove-password receive)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_bitwarden-cli2 "$@"
