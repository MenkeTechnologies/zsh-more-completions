#compdef csview

# Zsh completion for csview - CSV viewer

_arguments -s -S \
  '(-d --delimiter)'{-d,--delimiter}'[Specify the field delimiter]:delimiter:' \
  '(-H --no-headers)'{-H,--no-headers}'[Specify that the input has no header row]' \
  '(-c --columns)'{-c,--columns}'[Select columns to display]:columns:' \
  '(-s --style)'{-s,--style}'[Table style]:style:(ascii markdown rounded sharp modern grid none)' \
  '(-p --padding)'{-p,--padding}'[Cell padding]:padding:' \
  '(-S --sniff)'{-S,--sniff}'[Number of rows to sniff for delimiter]:rows:' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '*:file:_files'
