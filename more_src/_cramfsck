#compdef cramfsck fsck.cramfs
# Documentation: https://manpages.debian.org/bookworm/util-linux/fsck.cramfs.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# util-linux fsck.cramfs (aka cramfsck): check a CRAMFS image

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose messaging]' \
  '(-b --blocksize)'{-b+,--blocksize=}'[blocksize for --extract]:bytes:' \
  '--extract=-[test uncompress; optionally extract to dir]::dir:_files -/' \
  '-a[silently ignored]' \
  '-y[silently ignored]' \
  '*:CRAMFS image:_files' && ret=0

return ret
