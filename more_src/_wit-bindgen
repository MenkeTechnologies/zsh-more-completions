#compdef wit-bindgen

local curcontext="$curcontext" state line ret=1

_wit_bindgen_commands() {
  local -a commands=(
    'c:generate C bindings'
    'rust:generate Rust bindings'
    'go:generate Go bindings'
    'teavm-java:generate TeavmJava bindings'
    'markdown:generate Markdown documentation'
  )
  _describe -t commands 'wit-bindgen command' commands
}

_wit_bindgen_common_options() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-w --world)'{-w,--world}'[world to generate bindings for]:world' \
    '(-o --out-dir)'{-o,--out-dir}'[output directory]:dir:_files -/' \
    "$@"
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:_wit_bindgen_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      rust)
        _wit_bindgen_common_options \
          '--format[run rustfmt on generated code]' \
          '--std-feature[gate std usage behind a feature]' \
          '--raw-strings[use raw strings in generated code]' \
          '--ownership[ownership model]:model:(owning borrowing borrowing-duplicate-if-necessary)' \
          '--runtime-path[path to runtime crate]:path' \
          '--bitflags-path[path to bitflags crate]:path' \
          '*--skip[skip generating bindings for interface]:interface' \
          '*--with[override generated type with existing type]:mapping' \
          '--type-section-suffix[suffix for type section custom section]:suffix' \
          '--export-macro-name[name of the export macro]:name' \
          '*:wit file or directory:_files' && ret=0
        ;;
      c)
        _wit_bindgen_common_options \
          '*:wit file or directory:_files' && ret=0
        ;;
      go)
        _wit_bindgen_common_options \
          '*:wit file or directory:_files' && ret=0
        ;;
      teavm-java)
        _wit_bindgen_common_options \
          '*:wit file or directory:_files' && ret=0
        ;;
      markdown)
        _wit_bindgen_common_options \
          '*:wit file or directory:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
