#compdef pod5
# Documentation: https://pod5-file-format.readthedocs.io/en/latest/docs/tools.html
# POD5 file format tools (convert/inspect/merge/filter/subset/repack/view/recover/update)

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_pod5_cmds() {
  local -a cmds
  cmds=(
    'convert:Convert between POD5 and FAST5'
    'inspect:Inspect the contents of POD5 files'
    'merge:Merge POD5 files into one'
    'filter:Filter reads into a new POD5 by read ID'
    'subset:Subset reads into separate POD5 files'
    'repack:Repack POD5 files removing wasted space'
    'view:View read details as a table'
    'recover:Recover reads from a corrupted POD5 file'
    'update:Update POD5 files to the latest version'
  )
  _describe -t commands 'pod5 command' cmds
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :_pod5_cmds' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $line[1] in
      convert)
        local -a sub
        sub=('fast5:convert FAST5 to POD5' 'to_fast5:convert POD5 to FAST5')
        _arguments -C \
          '1: :{_describe -t target "convert target" sub}' \
          '*:: :->csub' && ret=0
        case $line[1] in
          fast5)
            _arguments -s \
              '--output=[output file or directory]:path:_files' \
              '--one-to-one=[one-to-one conversion base path]:dir:_files -/' \
              '--strict[enforce strict runtime assertions]' \
              '*:fast5:_files' && ret=0
            ;;
          to_fast5)
            _arguments -s \
              '--output=[output directory]:dir:_files -/' \
              '--file-read-count=[reads per output file]:n' \
              '*:pod5:_files' && ret=0
            ;;
        esac
        ;;
      view)
        _arguments -s \
          '(-L --list-fields)'{-L,--list-fields}'[list available fields]' \
          '--output=[output file path]:file:_files' \
          '--separator=[field separator]:sep' \
          '(-I --ids)'{-I,--ids}'[output only read IDs]' \
          '(-H --no-header)'{-H,--no-header}'[omit header row]' \
          '--include=[fields to include]:fields' \
          '--exclude=[fields to exclude]:fields' \
          '*:pod5:_files' && ret=0
        ;;
      inspect)
        local -a sub
        sub=('reads:print csv table of all reads' 'read:details for one read' 'summary:summary of file contents')
        _describe -t sub 'inspect target' sub
        _arguments -s '*:pod5:_files' && ret=0
        ;;
      merge)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[merged output file]:file:_files' \
          '(-D --duplicate-ok)'{-D,--duplicate-ok}'[permit duplicate read IDs]' \
          '*:pod5:_files' && ret=0
        ;;
      filter)
        _arguments -s \
          '--output=[filtered output file]:file:_files' \
          '--ids=[text file of read IDs]:file:_files' \
          '(-M --missing-ok)'{-M,--missing-ok}'[disable missing read ID warning]' \
          '*:pod5:_files' && ret=0
        ;;
      subset)
        _arguments -s \
          '--csv=[mapping CSV file]:file:_files' \
          '--table=[CSV/TSV table for dynamic mapping]:file:_files' \
          '--columns=[grouping columns]:cols' \
          '--output=[output directory]:dir:_files -/' \
          '--template=[f-string filename template]:template' \
          '--duplicate-ok[allow duplicate read IDs]' \
          '*:pod5:_files' && ret=0
        ;;
      update)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[update output directory]:dir:_files -/' \
          '*:pod5:_files' && ret=0
        ;;
      repack|recover)
        _arguments -s '*:pod5:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
