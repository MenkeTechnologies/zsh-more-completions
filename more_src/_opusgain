#compdef opusgain
# Documentation: https://github.com/FrancisRussell/zoog
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-r[ReplayGain target]' \
  '-a[album mode]' \
  '-s[show current gain only]' \
  '-n[do not write]' \
  '*:file:_files -g "*.opus"' && ret=0

return ret
