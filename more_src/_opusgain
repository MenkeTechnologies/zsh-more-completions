#compdef opusgain
# Documentation: https://man.archlinux.org/search?q=opusgain
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-r[ReplayGain target]' \
  '-a[album mode]' \
  '-s[show current gain only]' \
  '-n[do not write]' \
  '*:file:_files -g "*.opus"' && ret=0

return ret
