#compdef aarch64-linux-addr2line aarch64-linux-gnu-addr2line
# _aarch64-linux-addr2line — GNU binutils aarch64-linux-addr2line CLI cross-arch address-to-source-line resolver translating ARMv8 AArch64 program counter values into source filename function name line number records by reading DWARF debug info for crash backtrace symbolication kernel-oops decoding (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_aarch64-linux-addr2line() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a[show addresses]' \
        '--addresses[show addresses]' \
        '-b+[bfd target]:str:' \
        '--target=+[bfd target]:str:' \
        '-C[demangle]' \
        '--demangle[demangle]' \
        '-e+[executable]:file:_files' \
        '--exe=+[executable]:file:_files' \
        '-f[show function names]' \
        '--functions[show function names]' \
        '-i[show inline frames]' \
        '--inlines[show inline frames]' \
        '-p[show pretty output]' \
        '--pretty-print[pretty output]' \
        '-s[strip directory components]' \
        '--basenames[strip directory components]' \
        '-j+[section]:str:' \
        '--section=+[name]:str:' \
        '-r+[recurse limit]:n:' \
        '--recurse-limit=+[N]:n:' \
        '*:address:'
}

_aarch64-linux-addr2line "$@"
