#compdef orbctl orb
# _orbctl — OrbStack fast lightweight container and Linux VM CLI for macOS (orbstack team, Go); cobra
# upstream: https://orbstack.dev

_orbctl() {
    local -a sub=(
        'create:create a machine'
        'delete:delete a machine'
        'list:list machines'
        'ls:list machines'
        'start:start a machine'
        'stop:stop a machine'
        'restart:restart a machine'
        'rename:rename a machine'
        'info:show machine info'
        'config:configure machine settings'
        'logs:show machine logs'
        'shell:open shell in machine'
        'run:run command in machine'
        'push:copy file to machine'
        'pull:copy file from machine'
        'default:set default machine'
        'status:show daemon status'
        'start:start service'
        'stop:stop service'
        'restart:restart service'
        'update:update orbstack'
        'version:show version'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--machine=+[machine name]:str:' \
        '-m+[machine name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'orb subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--arch=+[architecture]:a:(amd64 arm64)' \
                    '-a+[architecture]:a:(amd64 arm64)' \
                    '--user=+[username]:user:_users' \
                    '-u+[username]:user:_users' \
                    '--password=+[password]:str:' \
                    '*:image:(ubuntu debian fedora arch alpine rocky almalinux opensuse centos kali nixos void)' ;;
                run|shell) _arguments \
                    '--user=+[user]:user:_users' \
                    '-u+[user]:user:_users' \
                    '--dir=+[working dir]:dir:_files -/' \
                    '*:command:_command_names' ;;
                push|pull) _arguments '*:file:_files' ;;
                config) _arguments '1:key:(cpu memory disk swap)' '2:value:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_orbctl "$@"
