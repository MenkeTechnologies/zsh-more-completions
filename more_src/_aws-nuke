#compdef aws-nuke

# Zsh completion for aws-nuke - remove all resources from an AWS account

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'nuke:nuke all resources in an AWS account'
  'resource-types:list available resource types'
  'account:show account information'
  'version:show version'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'aws-nuke command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (nuke)
        _arguments -s -S \
          '--config=[path to config file]:file:_files -g "*.{yml,yaml}"' \
          '--profile=[AWS profile]:profile' \
          '--access-key-id=[AWS access key ID]:key' \
          '--secret-access-key=[AWS secret access key]:secret' \
          '--session-token=[AWS session token]:token' \
          '--default-region=[default AWS region]:region' \
          '--force[skip confirmation prompt]' \
          '--force-sleep=[time to sleep between force confirmations]:seconds' \
          '--no-dry-run[actually delete resources]' \
          '--quiet[minimize output]' \
          '--log-level=[set log level]:level:(trace debug info warn error)' \
          '--no-prompt[skip all confirmation prompts]' && ret=0
        ;;
      (resource-types)
        _arguments -s -S \
          '--config=[path to config file]:file:_files -g "*.{yml,yaml}"' && ret=0
        ;;
    esac
    ;;
esac

return ret
