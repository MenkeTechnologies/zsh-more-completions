#compdef whichdb
# whichdb - Search all sequence databases for an entry and retrieve it

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-entry[ID or accession number to search for]:entry:' \
  '-outfile[output file name]:file:_files' \
  '-get[retrieve and output matching sequences to files]' \
  '-showall[display info about failed search attempts]' \
  '-odirectory[output directory]:dir:_files -/' \
  '-auto[turn off prompts]' \
  '-stdout[write to standard output]' \
  '-filter[read stdin, write stdout]' \
  '-options[prompt for values]' \
  '-debug[write debug output]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report program messages]' \
  '-version[display version number]' && ret=0

return ret
