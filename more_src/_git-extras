#compdef git-extras

# Zsh completion for git-extras - GIT utilities

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'alias:define, search and show aliases'
  'archive-file:export current HEAD as a zip archive'
  'authors:generate authors report'
  'browse:open repository in browser'
  'bug:create a bug branch'
  'bulk:run git commands across multiple repos'
  'changelog:generate changelog'
  'clear:risky clean and target cleanup'
  'clear-soft:soft cleanup'
  'coauthor:add co-authored-by'
  'commits-since:list commits since a date'
  'contrib:show contributions for author'
  'count:output commit count'
  'cp:copy a file keeping its history'
  'create-branch:create branches'
  'delete-branch:delete branches'
  'delete-merged-branches:delete merged branches'
  'delete-submodule:delete a submodule'
  'delete-tag:delete tags'
  'delta:list changed files'
  'effort:show effort statistics'
  'extras:manage git-extras commands'
  'feature:create feature branch'
  'force-clone:force-clone a repository'
  'fork:fork a repository on GitHub'
  'fresh-branch:create a fresh branch'
  'gh-pages:create gh-pages branch'
  'graft:merge and remove branch'
  'ignore:add entries to .gitignore'
  'ignore-io:get .gitignore templates'
  'info:show information about the repo'
  'local-commits:list unpushed commits'
  'lock:lock a file'
  'locked:list locked files'
  'magic:automate add, commit, push'
  'merge-into:merge current branch into another'
  'merge-repo:merge a repo as subdir'
  'missing:show commits not merged'
  'mr:merge request on GitLab'
  'obliterate:rewrite history to remove files'
  'pr:create pull request'
  'psykorebase:rebase with merges'
  'pull-request:create pull request'
  'reauthor:rewrite author info'
  'rebase-patch:rebases a patch'
  'release:create release commit and tag'
  'rename-branch:rename a branch'
  'rename-file:rename a file tracking history'
  'rename-tag:rename a tag'
  'rename-remote:rename a remote'
  'repl:REPL for running git commands'
  'reset-file:reset one file'
  'root:show root directory'
  'scp:copy files to SSH host'
  'sed:replace patterns in codebase'
  'setup:set up a git repository'
  'show-merged-branches:show merged branches'
  'show-unmerged-branches:show unmerged branches'
  'show-tree:show branch tree with decorations'
  'squash:squash N commits'
  'stamp:stamp the last commit message'
  'standup:recall work done'
  'summary:repository summary'
  'sync:sync local branch with remote'
  'touch:touch and add files'
  'undo:undo the last commit'
  'unlock:unlock a file'
  'utimes:change file modification times'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--update[self update]' \
  '1:command:->command' \
  '*:argument' && ret=0

case $state in
  command)
    _describe -t commands 'git-extras command' commands && ret=0
    ;;
esac

return ret
