#compdef AnnotateIntervals
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/AnnotateIntervals.java
# Annotates intervals with GC content, mappability, and segmental-duplication content

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'[Output file for annotated intervals.]:value:_files' \
  '--mappability-track=[Path to Umap single-read mappability track in .bed or .bed.gz format (see https\://bism...]:value:_files' \
  '--segmental-duplication-track=[Path to segmental-duplication track in .bed or .bed.gz format.]:value:_files' \
  '--feature-query-lookahead=[Number of bases to cache when querying feature tracks.]:value:' \
  '*:argument:_files' && ret=0

return ret
