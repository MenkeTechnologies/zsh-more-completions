#compdef ragg2
# Documentation: https://github.com/radareorg/radare2/blob/master/man/ragg2.1
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '-F[native output format]' \
  '-h[show help]' \
  '-L[list plugins]' \
  '-O[default output filename]' \
  '-r[raw bytes output]' \
  '-s[show assembler]' \
  '-v[show version]' \
  '-x[execute]' \
  '-z[C string output]' \
  '-a=[arch]:arch:(x86 mips arm)' \
  '-b=[bits]:bits:(32 64)' \
  '-B=[hexpairs append]:hex:' \
  '*-c=[k=v config]:setting:' \
  '-C=[append file]:file:_files' \
  '-d=[patch dword]:off\:dword:' \
  '-D=[patch qword]:off\:qword:' \
  '-e=[egg expression]:expr:' \
  '-E=[encoder]:encoder:' \
  '-f=[output format]:fmt:(raw c pe elf mach0 python javascript)' \
  '-H=[show variable]:var:' \
  '-i=[shellcode plugin]:plugin:' \
  '*-I=[include path]:dir:_files -/' \
  '-k=[kernel]:os:(linux bsd osx w32)' \
  '-n=[append 32-bit]:dword:' \
  '-N=[append 64-bit]:dword:' \
  '-o=[output file]:file:_files' \
  '-p=[padding]:spec:' \
  '-P=[debruijn size]:n:' \
  '-q=[debruijn offset]:fragment:' \
  '-S=[append string]:str:' \
  '-w=[patch hex]:off\:hex:' \
  '-X=[execute hex chain]:hex:' \
  '*:source file:_files -g "*.(r|c)"'
