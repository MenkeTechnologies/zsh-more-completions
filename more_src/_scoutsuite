#compdef scout

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '1:provider:->providers' \
  '*::arg:->args' && ret=0

case $state in
  (providers)
    local -a providers=(
      'aws:scan Amazon Web Services'
      'azure:scan Microsoft Azure'
      'gcp:scan Google Cloud Platform'
      'aliyun:scan Alibaba Cloud'
      'oci:scan Oracle Cloud Infrastructure'
    )
    _describe -t providers 'cloud provider' providers && ret=0
    ;;
  (args)
    local -a common_args=(
      '--force[force re-run even if results exist]'
      '--max-rate=[maximum API call rate per second]:rate:'
      '--max-workers=[maximum number of workers]:workers:'
      '--report-dir=[report output directory]:dir:_files -/'
      '--report-name=[custom report name]:name:'
      '--timestamp[add timestamp to report name]'
      '--no-browser[do not open browser after scan]'
      '--result-format=[result format]:format:(json sqlite)'
      '--database-name=[database file name]:file:'
      '--exceptions=[exceptions file]:file:_files'
      '--ruleset=[custom ruleset]:file:_files'
      '(-v --verbose)'{-v,--verbose}'[verbose output]'
      '--debug[enable debug output]'
      '--quiet[quiet mode]'
      '--logfile=[log file]:file:_files'
      '--services=[comma-separated services to scan]:services:'
      '--skip=[comma-separated services to skip]:services:'
    )
    case ${words[1]} in
      (aws)
        _arguments \
          $common_args \
          '--profile=[AWS profile]:profile:' \
          '--regions=[AWS regions to scan]:regions:' \
          '--ip-ranges=[IP ranges file]:file:_files' \
          '--ip-ranges-key-name=[key name for IP ranges]:key:' && ret=0
        ;;
      (azure)
        _arguments \
          $common_args \
          '--cli[use Azure CLI authentication]' \
          '--msi[use managed service identity]' \
          '--service-principal[use service principal]' \
          '--file-auth=[auth parameters file]:file:_files' \
          '--user-account[use user account]' \
          '--tenant=[Azure tenant ID]:tenant:' \
          '--subscription=[Azure subscription IDs]:subscriptions:' \
          '--all-subscriptions[scan all subscriptions]' && ret=0
        ;;
      (gcp)
        _arguments \
          $common_args \
          '--service-account=[service account key file]:file:_files' \
          '--user-account[use user account]' \
          '--project-id=[GCP project ID]:project:' \
          '--folder-id=[GCP folder ID]:folder:' \
          '--organization-id=[GCP organization ID]:org:' \
          '--all-projects[scan all projects]' && ret=0
        ;;
    esac
    ;;
esac

return ret
