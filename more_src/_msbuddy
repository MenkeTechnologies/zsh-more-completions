#compdef msbuddy
# Documentation: https://github.com/Philipbear/msbuddy
# msbuddy: bottom-up molecular formula annotation for MS data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-mgf+[path to the MGF file]:mgf file:_files -g "*.mgf"' \
  '-usi+[a single USI string]:usi' \
  '-csv+[CSV file with USI strings in first column]:csv file:_files -g "*.csv"' \
  '(-output -o)'{-output,-o}'+[output file path]:output:_files' \
  '(-details -d)'{-details,-d}'[write detailed results]' \
  '(-ms_instr -ms)'{-ms_instr,-ms}'+[MS instrument type]:instrument:(orbitrap qtof fticr)' \
  '-use_Da[use Dalton for mass tolerance]' \
  '-ms1_tol+[MS1 tolerance]:tolerance' \
  '-ms2_tol+[MS2 tolerance]:tolerance' \
  '(-halogen -hal)'{-halogen,-hal}'[consider halogen atoms F Cl Br I]' \
  '(-parallel -p)'{-parallel,-p}'[use parallel computing]' \
  '-n_cpu+[number of CPUs to use]:cpus' \
  '(-timeout_secs -t)'{-timeout_secs,-t}'+[timeout in seconds]:seconds' \
  '(-batch_size -bs)'{-batch_size,-bs}'+[batch size]:size' \
  '-isotope_bin_mztol+[m/z tolerance for isotope binning in Dalton]:tolerance' \
  '-max_isotope_cnt+[maximum isotope count]:count' \
  '-rel_int_denoise_cutoff+[relative intensity cutoff for MS2 denoise]:cutoff' \
  '-top_n_per_50_da+[top n peaks per 50 Da for MS2 denoise]:n' && ret=0

return ret
