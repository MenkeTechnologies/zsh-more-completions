#compdef mlx_whisper
# Documentation: https://github.com/ml-explore/mlx-examples/blob/main/whisper/README.md
# MLX Whisper: transcribe or translate audio with Whisper on Apple Silicon

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model=[Whisper model name or path]:model:' \
  '--output-dir=[directory for output files]:dir:_files -/' \
  '--output-format=[output format]:format:(txt vtt srt tsv json all)' \
  '--task=[transcribe or translate]:task:(transcribe translate)' \
  '--language=[language hint]:language:' \
  '--verbose=[print progress and debug info]:verbose:(True False)' \
  '*:audio file:_files' && ret=0

return ret
