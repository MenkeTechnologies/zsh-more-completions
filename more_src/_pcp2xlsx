#compdef pcp2xlsx
# Documentation: https://man.archlinux.org/man/pcp2xlsx.1.en
# Performance Co-Pilot metrics exporter to XLSX spreadsheet

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[display version and exit]' \
  '(-F --output-file)'{-F+,--output-file=}'[output file]:outfile:_files' \
  '(-0 --precision-force)'{-0+,--precision-force=}'[force precision overriding specs]:precision' \
  '(-4 --names-change)'{-4+,--names-change=}'[action on metric name change]:action:(update ignore abort)' \
  '(-5 --ignore-unknown)'{-5,--ignore-unknown}'[silently ignore unresolvable metric names]' \
  '(-a --archive)'{-a+,--archive=}'[PCP archive source]:archive:_files' \
  '(-b --space-scale)'{-b+,--space-scale=}'[unit/scale for byte metrics]:scale' \
  '(-c --config)'{-c+,--config=}'[configuration file or directory]:config:_files' \
  '(-C --check)'{-C,--check}'[exit before reporting any values]' \
  '(-s --samples)'{-s+,--samples=}'[number of samples to report]:samples' \
  '(-t --interval)'{-t+,--interval=}'[reporting interval]:interval' \
  '*:metric:_default' && ret=0

return ret
