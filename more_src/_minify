#compdef minify

# Zsh completion for minify - tdewolff/minify CLI for minifying web assets

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-o,--output}'+[output file or directory]:file:_files' \
  '--type+[force MIME type]:type:(css html js json svg xml)' \
  '--mime+[force MIME type]:mime type' \
  {-r,--recursive}'[recurse into directories]' \
  '--match+[filename pattern to include]:pattern' \
  {-l,--list}'[list all accepted filetypes]' \
  '--watch[watch for changes]' \
  '--sync[sync copied files]' \
  {-b,--bundle}'[bundle files]' \
  {-p,--preserve}'+[preserve attributes]:attribute:(mode ownership timestamps links all)' \
  '--css-precision+[CSS decimal precision]:int' \
  '--html-keep-comments[keep HTML comments]' \
  '--html-keep-conditional-comments[keep conditional comments]' \
  '--html-keep-default-attrvals[keep default attribute values]' \
  '--html-keep-document-tags[keep document tags]' \
  '--html-keep-end-tags[keep end tags]' \
  '--html-keep-quotes[keep attribute quotes]' \
  '--html-keep-whitespace[keep whitespace]' \
  '--js-precision+[JS decimal precision]:int' \
  '--js-keep-var-names[keep variable names]' \
  '--js-version+[JS version]:version' \
  '--json-precision+[JSON decimal precision]:int' \
  '--json-keep-numbers[keep original number formatting]' \
  '--svg-precision+[SVG decimal precision]:int' \
  '--svg-keep-comments[keep SVG comments]' \
  '--xml-keep-whitespace[keep XML whitespace]' \
  {-q,--quiet}'[suppress output]' \
  {-v,--verbose}'[verbose output]' \
  '*:files:_files'
