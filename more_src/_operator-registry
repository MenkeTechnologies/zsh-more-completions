#compdef operator-registry

# operator-registry: serve operator catalog over gRPC
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'serve:serve a catalog'
  'registry:registry helper commands'
  'opm:opm commands'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-d[database file]:file:_files' \
  '--database=[database file]:file:_files' \
  '-p[gRPC port]:port:' \
  '--port=[gRPC port]:port:' \
  '-t[termination log file]:file:_files' \
  '--termination-log=[termination log file]:file:_files' \
  '--skip-migrate[skip migration]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'operator-registry command' commands && ret=0 ;;
esac
return ret
