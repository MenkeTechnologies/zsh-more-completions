#compdef tftpd
# _tftpd — OpenBSD tftpd (TFTP server serving the given directory; -w allows writes, -c allows creating new files, -i pure inetd mode, -r tracks lease state via control socket)
# upstream: https://github.com/openbsd/src (usr.sbin/tftpd)
# Flags from usr.sbin/tftpd/tftpd.8 on tip.

_tftpd() {
    _arguments \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-c[allow file creation on write]' \
        '-d[debug (foreground + stderr)]' \
        '-i[inetd mode]' \
        '-v[verbose]' \
        '-w[allow writes]' \
        '-l+[bind address]:address:' \
        '-p+[port]:port:' \
        '-r+[control socket]:file:_files' \
        '1:directory:_files -/'
}

_tftpd "$@"
