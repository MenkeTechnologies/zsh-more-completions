#compdef xbps-digest
# _xbps-digest — compute SHA-256 digest of files (XBPS-style) (void-linux/xbps)
# upstream: https://github.com/void-linux/xbps
# Flags from bin/xbps-digest/main.c.

_xbps-digest() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show XBPS version]'
        '(-m --mode)'{-m+,--mode=}'[digest mode]:mode:(sha256)'
        '*:file:_files'
    )
    _arguments -s -S $args
}

_xbps-digest "$@"
