#compdef barman
# Documentation: https://docs.pgbarman.org/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'archive-wal:archive a WAL'
  'backup:perform a backup'
  'check:check server configuration'
  'check-backup:check backup'
  'cron:run cron tasks'
  'delete:delete a backup'
  'diagnose:show diagnostic info'
  'get-wal:get a WAL'
  'help:show help'
  'list-backups:list backups'
  'list-files:list files'
  'list-server:list configured servers'
  'list-servers:list configured servers'
  'put-wal:put a WAL'
  'rebuild-xlogdb:rebuild WAL DB'
  'receive-wal:receive WAL stream'
  'recover:recover a backup'
  'replication-status:show replication status'
  'show-backup:show backup info'
  'show-server:show server config'
  'show-servers:show servers'
  'status:show server status'
  'switch-wal:force a WAL switch'
  'switch-xlog:force a WAL switch (alias)'
  'sync-backup:sync backup to passive'
  'sync-info:sync info'
  'sync-wals:sync WALs'
  'verify:verify backup'
  'verify-backup:verify backup'
  'config-update:update config'
  'config-switch:switch config'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-f --format)'{-f+,--format=}'[output format]:f:(console json)' \
  '(--color)--color=[color mode]:m:(never always auto)' \
  '(--no-color)--no-color[no color]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'barman command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (backup)
        _arguments \
          '--immediate-checkpoint[immediate checkpoint]' \
          '--no-immediate-checkpoint[no immediate]' \
          '--reuse-backup=[reuse mode]:m:(off copy link)' \
          '--retry-times=[retry n]:n:' \
          '--retry-sleep=[retry sleep]:s:' \
          '--jobs=[jobs]:n:' \
          '--bwlimit=[bandwidth limit]:n:' \
          '--manifest=[manifest mode]:m:' \
          '--no-manifest[no manifest]' \
          '--wait[wait]' \
          '--wait-timeout=[wait timeout]:s:' \
          '--keepalive-interval=[keepalive]:s:' \
          '--name=[backup name]:n:' \
          '*: :' && ret=0 ;;
      (recover)
        _arguments \
          '--target-time=[target time]:t:' \
          '--target-xid=[target xid]:x:' \
          '--target-tli=[target tli]:t:' \
          '--target-name=[target name]:n:' \
          '--target-immediate[immediate]' \
          '--exclusive[exclusive]' \
          '--standby-mode[standby mode]' \
          '--remote-ssh-command=[ssh cmd]:cmd:' \
          '--retry-times=[retry n]:n:' \
          '--retry-sleep=[retry sleep]:s:' \
          '--jobs=[jobs]:n:' \
          '--bwlimit=[bandwidth limit]:n:' \
          '*: :_files -/' && ret=0 ;;
      (delete|show-backup|verify|verify-backup|check-backup|list-files)
        _arguments '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
