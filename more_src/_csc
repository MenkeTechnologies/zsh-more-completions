#compdef csc csc.exe
# Documentation: https://learn.microsoft.com/en-us/dotnet/csharp/language-reference/compiler-options/listed-alphabetically
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Roslyn / Mono C# command-line compiler. (Chicken csc is a separate binary.)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-help[show help]' \
  '-?[show help]' \
  '-out:-[output file name]:file:_files' \
  '-target\:exe[build console executable]' \
  '-target\:winexe[build Windows executable]' \
  '-target\:library[build library DLL]' \
  '-target\:module[build module]' \
  '-target\:appcontainerexe[build appcontainer executable]' \
  '-target\:winmdobj[build winmd intermediate]' \
  '*-reference:-[reference assembly]:file:_files -g "*.dll *.exe"' \
  '*-r:-[reference assembly]:file:_files -g "*.dll *.exe"' \
  '*-addmodule:-[link to module]:file:_files -g "*.netmodule"' \
  '*-lib:-[search lib path]:dir:_files -/' \
  '-recurse:-[recurse search files]:pattern:' \
  '-debug[generate debug info]' \
  '-debug:full[full debug info]' \
  '-debug:pdbonly[pdb only debug info]' \
  '-debug:portable[portable debug info]' \
  '-debug:embedded[embedded debug info]' \
  '-pdb:-[pdb file name]:file:_files' \
  '-optimize[enable optimisations]' \
  '-optimize+[enable optimisations]' \
  '-optimize-[disable optimisations]' \
  '-define:-[define preprocessor symbols csv]:list:' \
  '-d:-[define preprocessor symbols]:list:' \
  '-warn:-[warning level 0-4]:lvl:(0 1 2 3 4)' \
  '-warnaserror[treat warnings as errors]' \
  '-warnaserror+[treat warnings as errors]' \
  '-warnaserror-[reset warnings as errors]' \
  '-nowarn:-[disable warnings csv]:list:' \
  '-langversion:-[language version]:ver:(default latest preview 1 2 3 4 5 6 7 7.1 7.2 7.3 8 9 10 11 12 13)' \
  '-nostdlib[no implicit mscorlib reference]' \
  '-nostdlib+[no implicit mscorlib reference]' \
  '-nullable:-[nullable]:mode:(disable enable warnings annotations)' \
  '-checked[overflow checking on]' \
  '-checked-[overflow checking off]' \
  '-unsafe[allow unsafe code]' \
  '-unsafe+[allow unsafe code]' \
  '-doc:-[XML doc output]:file:_files' \
  '-keyfile:-[strong name keyfile]:file:_files' \
  '-keycontainer:-[strong name container]:name:' \
  '-delaysign[delay sign assembly]' \
  '-delaysign+[delay sign assembly]' \
  '-publicsign[public sign assembly]' \
  '-platform:-[platform target]:p:(anycpu anycpu32bitpreferred arm arm64 x86 x64 itanium)' \
  '-main:-[main type]:type:' \
  '-m:-[main type]:type:' \
  '-resource:-[embed resource]:file:_files' \
  '-res:-[embed resource]:file:_files' \
  '-linkresource:-[link resource]:file:_files' \
  '-linkres:-[link resource]:file:_files' \
  '-win32icon:-[Win32 icon]:file:_files -g "*.ico"' \
  '-win32manifest:-[Win32 manifest]:file:_files' \
  '-win32res:-[Win32 resource]:file:_files' \
  '-codepage:-[source codepage]:n:' \
  '-utf8output[output messages in UTF-8]' \
  '-noconfig[do not auto-include csc.rsp]' \
  '-nologo[no compiler banner]' \
  '-version[show version]' \
  '-bugreport:-[create bug report file]:file:_files' \
  '-errorlog:-[error log file (SARIF)]:file:_files' \
  '-features:-[advanced compiler features csv]:list:' \
  '-fullpaths[print fully qualified paths]' \
  '-pathmap:-[path replacements csv]:list:' \
  '-filealign:-[file alignment]:n:' \
  '-baseaddress:-[DLL base address]:addr:' \
  '-highentropyva[high entropy ASLR]' \
  '-highentropyva+[high entropy ASLR]' \
  '-subsystemversion:-[OS version]:ver:' \
  '-deterministic[deterministic build]' \
  '-deterministic+[deterministic build]' \
  '-publicsign[public sign]' \
  '-langversion:-[language version]:ver:' \
  '-refonly[reference assembly only]' \
  '-refout:-[reference assembly output]:file:_files' \
  '-instrument:-[instrument]:k:(TestCoverage)' \
  '-modulename:-[module name]:name:' \
  '*:source:_files -g "*.cs *.rsp"' && ret=0

return ret
