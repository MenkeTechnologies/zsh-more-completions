#compdef zeppelin-cli zeppelin
# _zeppelin-cli — Apache Zeppelin zeppelin-cli CLI command-line frontend wrapping the Apache Zeppelin Web-based notebook for data analytics interactive visualization providing daemon start stop status restart upgrade reload interpreter notebook export-notebook import-notebook user-credentials-management security policy plugin (Apache Zeppelin team, Java); custom argparse
# upstream: https://zeppelin.apache.org/

_zeppelin-cli() {
    local -a sub=(
        'start:start Zeppelin daemon'
        'stop:stop Zeppelin daemon'
        'restart:restart Zeppelin daemon'
        'status:show daemon status'
        'reload:reload configuration'
        'upgrade:upgrade Zeppelin'
        'notebook:notebook management'
        'export-notebook:export a notebook'
        'import-notebook:import a notebook'
        'interpreter:interpreter management'
        'user:user management'
        'credentials:credentials management'
        'plugin:plugin management'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server-url=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--port=+[port]:n:' \
        '--ssl[use SSL]' \
        '-c+[config file]:file:_files -g "zeppelin-site.xml *.xml *.properties"' \
        '--config=+[file]:file:_files -g "*.xml *.properties"' \
        '--note-id=+[id]:str:' \
        '--paragraph-id=+[id]:str:' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zeppelin-cli subcommand' sub ;;
        args)
            case $words[1] in
                notebook|interpreter|user|credentials|plugin) _arguments '1:op:(list show create update delete enable disable restart run clone bind unbind)' '*:name:' ;;
                export-notebook|import-notebook) _arguments '*:file:_files -g "*.json"' ;;
            esac
            ;;
    esac
}

_zeppelin-cli "$@"
