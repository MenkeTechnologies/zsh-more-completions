#compdef tbtrans
# Documentation: https://docs.siesta-project.org/projects/siesta/en/stable/reference/tbtrans.html
# SIESTA TBtrans tight-binding transport Green function code

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print help and quit]' \
  '(-v -version)'{-v,-version}'[print TBtrans version and quit]' \
  '(-o -out)'{-o,-out}'[write all output here instead of STDOUT]:file:_files' \
  '-L[override SystemLabel parameter]:label:' \
  '-V[override TBT.Voltage e.g. 0.2:eV]:voltage:' \
  '-D[override TBT.Directory creating it if needed]:dir:_files -/' \
  '-HS[override the used Hamiltonian (TBT.HS)]:HS file:_files' \
  '-fdf[set any fdf flag e.g. -fdf TBT.Voltage:0.2:eV]:fdf flag:' \
  '*:fdf file:_files' && ret=0

return ret
