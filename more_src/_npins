#compdef npins
# Documentation: https://man.archlinux.org/search?q=npins
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--name=[Optional human-readable pin label]:name:' \
  '-d+[Changelog depth]:depth' \
  '--help[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'init:Bootstrap npins.json in this repo'
      'show:Show versions and hashes for pinned inputs'
      'fetch:Download pinned sources into the store'
      'update:Refresh pins according to branch or release rules'
      'remove:Delete a named pin'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
