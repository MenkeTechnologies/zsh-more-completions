#compdef chainSort
# sort chains (by default by score)

local ret=1

_arguments -s -S \
  '-target[sort on target start rather than score]' \
  '-query[sort on query start rather than score]' \
  '-index=[build simple two-column index file]:tab file:_files' \
  '1:in file:_files -g "*.chain"' \
  '2:out file:_files' && ret=0

return ret
