#compdef pg_easy_replicate
# Documentation: https://github.com/shayonj/pg_easy_replicate
# Logical replication based switchover/zero-downtime migration for PostgreSQL

local ret=1
local -a commands

commands=(
  'config_check:verify source and target have required configuration'
  'bootstrap:set up temporary infrastructure needed for replication'
  'start_sync:start logical replication between databases'
  'stop_sync:stop active replication'
  'switchover:transition source to read-only after full sync'
  'stats:display replication metrics in JSON'
  'cleanup:remove bootstrapped data for a group'
  'notify:send stats to a webhook endpoint'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds) _describe -t commands 'pg_easy_replicate command' commands && ret=0 ;;
  args)
    case $line[1] in
      bootstrap)
        _arguments \
          '(-g --group-name)'{-g,--group-name}'=[group name]:group' \
          '--copy-schema[copy schema to target]' \
          '--special-user-role=[special user role for managed providers]:role' && ret=0 ;;
      start_sync)
        _arguments \
          '(-g --group-name)'{-g,--group-name}'=[group name]:group' \
          '--schema-name=[schema name to replicate]:schema' \
          '--tables=[comma separated tables to include]:tables' \
          '--exclude_tables=[comma separated tables to exclude]:tables' \
          '(-d --track-ddl)'{-d,--track-ddl}'[enable DDL tracking]' \
          '--no-recreate-indices-post-copy[do not recreate indices after copy]' && ret=0 ;;
      cleanup)
        _arguments \
          '(-g --group-name)'{-g,--group-name}'=[group name]:group' \
          '(-e --everything)'{-e,--everything}'[remove schema changes and user data]' && ret=0 ;;
      notify)
        _arguments \
          '(-g --group-name)'{-g,--group-name}'=[group name]:group' \
          '(-u --url)'{-u,--url}'=[url to notify]:url' \
          '--frequency=[notification frequency]:seconds' \
          '--timeout=[request timeout]:seconds' && ret=0 ;;
      stop_sync|switchover|stats|config_check)
        _arguments \
          '(-g --group-name)'{-g,--group-name}'=[group name]:group' \
          '--special-user-role=[special user role for managed providers]:role' && ret=0 ;;
    esac ;;
esac

return ret
