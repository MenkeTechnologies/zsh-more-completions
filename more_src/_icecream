# icecc: Icecream distributed compiler stub. Wraps a compiler invocation and routes to network.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--build-native[build native compiler environment archive]' \
  '*::compiler command:_command_names -e' && return 0
