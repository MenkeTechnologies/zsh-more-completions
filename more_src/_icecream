#compdef icecc
# Documentation: https://man.archlinux.org/search?q=icecc
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--build-native[build native environment]' \
  '-b+[build for specified platform]:platform' \
  '*::compiler command:_command_names -e' && return 0
