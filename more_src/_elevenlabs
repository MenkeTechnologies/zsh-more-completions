#compdef elevenlabs elevenlabs-cli

_elevenlabs() {
    local line state
    local -a commands
    commands=(
        'auth:Authentication commands'
        'agents:Manage voice agents'
        'tts:Generate speech from text'
        'stt:Transcribe audio to text'
        'voice:Manage voices'
    )

    _arguments -C \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'elevenlabs command' commands
            ;;
        args)
            case $line[1] in
                auth)
                    _arguments '1:subcommand:(login logout)'
                    ;;
                agents)
                    _arguments '1:subcommand:(init add push pull list)' '2: :->agent_args'
                    ;;
                tts)
                    _arguments '--output[Output file]:file:_files' '*:text:'
                    ;;
                stt)
                    _arguments '*:audio-file:_files'
                    ;;
                voice)
                    _arguments '1:subcommand:(list clone create delete)' '2: :->voice_args'
                    ;;
            esac
            ;;
    esac
}

_elevenlabs "$@"
