#compdef vim-athena

# vim-athena: Vim build variant
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-v[vi mode (compatible)]' \
  '-e[ex mode]' \
  '-E[improved ex mode]' \
  '-s[silent (batch) mode]' \
  '-R[read-only]' \
  '-d[diff mode]' \
  '-y[easy mode]' \
  '-Z[restricted mode]' \
  '-m[no modification]' \
  '-M[no modification, no commands]' \
  '-N[no compat (default for vim)]' \
  '-V[verbose level]:level:' \
  '-D[debug mode]' \
  '-r[recover edit session]' \
  '-L[same as -r]' \
  '-T[terminal type]:term:' \
  '-u[use this vimrc]:file:_files' \
  '--noplugin[skip plugins]' \
  '-p[open files in tabs]' \
  '-o[open files in horizontal splits]' \
  '-O[open files in vertical splits]' \
  '-S[execute file after vimrc]:file:_files -g "*.vim"' \
  '-W[record keystrokes]:file:_files' \
  '-w[append keystrokes]:file:_files' \
  '-c[execute Ex command]:cmd:' \
  '--cmd[execute Ex command before vimrc]:cmd:' \
  '-C[compatible vi mode]' \
  '-X[no X11 connection]' \
  '*:files:_files' && ret=0
return ret
