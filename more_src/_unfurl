#compdef unfurl
# Documentation: https://github.com/tomnomnom/unfurl
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_unfurl_cmds() {
    local -a commands=(
        'keys:extract query string keys'
        'values:extract query string values'
        'keypairs:extract query string key=value pairs'
        'domains:extract hostnames'
        'paths:extract request paths'
        'apexes:extract apex domains'
        'json:output URL components as JSON'
        'format:format URLs with a template'
    )
    _describe -t commands 'unfurl mode' commands
}

_unfurl() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-u --unique)'{-u,--unique}'[only output unique values]' \
        '(-v --verbose)'{-v,--verbose}'[verbose mode (output URL parse errors)]' \
        '1:mode:_unfurl_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                format)
                    _arguments \
                        '1:format-string'
                    ;;
            esac
            ;;
    esac
}

_unfurl "$@"
