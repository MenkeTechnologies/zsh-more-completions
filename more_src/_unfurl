#compdef unfurl

_unfurl_cmds() {
    local -a commands=(
        'domains:extract domains from URLs'
        'paths:extract paths from URLs'
        'keys:extract query string keys'
        'values:extract query string values'
        'keypairs:extract query string key-value pairs'
        'format:format URLs with a template'
        'apexes:extract apex domains'
        'json:output URL components as JSON'
        'unique:remove duplicate URLs'
        'help:print help information'
    )
    _describe -t commands 'unfurl command' commands
}

_unfurl() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-u --unique)'{-u,--unique}'[only output unique values]' \
        '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
        '1:command:_unfurl_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                format)
                    _arguments \
                        '1:format-string'
                    ;;
            esac
            ;;
    esac
}

_unfurl "$@"
