#compdef anesthetic
# Documentation: https://anesthetic.readthedocs.io/en/latest/
# anesthetic: GUI to visualize nested sampling runs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-p,--params}'=[parameters to display]:param' \
  '1:file root:_files' && ret=0

return ret
