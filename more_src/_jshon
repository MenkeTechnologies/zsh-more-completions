#compdef jshon
# Documentation: https://manpages.debian.org/testing/jshon/jshon.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jshon - a JSON parser for the shell.
# Actions and options may be repeated and chained; use -s -S where order
# does not matter for the meta options.

local ret=1

_arguments \
  '(- *)-h[show jshon usage]' \
  '*-F+[read JSON from file instead of stdin]:file:_files' \
  '*-I[edit file in place (requires -F)]' \
  '*-P[strip JSONP callback before parsing]' \
  '*-S[sort output by key]' \
  '*-Q[suppress error messages on stderr]' \
  '*-C[continue on recoverable errors, inserting null]' \
  '*-V[pass-by-value edit history (safer, slower)]' \
  '*-0[use null delimiters for -u and -k output]' \
  '*-t[print the type of the top of stack]' \
  '*-l[print the length of the top of stack]' \
  '*-k[print the keys of the top of stack]' \
  '*-e+[extract value at the given index]:index:' \
  '*-E+[extract by nametag:namevalue:valuetag]:selector:' \
  '*-a[map remaining actions across array/object elements]' \
  '*-s+[create a JSON string from the value]:value:' \
  '*-n+[create a JSON element (true/false/null/[]/{}/number)]:value:' \
  '*-u[unstring: print decoded plain text]' \
  '*-j[print top of stack as encoded JSON]' \
  '*-p[pop: rewind the last manipulation]' \
  '*-d+[delete the item at the given index]:index:' \
  '*-i+[insert stack contents into parent at index]:index:' \
  '*-w+[wrap top of stack in the given key]:key:' \
  '*-r[rotate: swap the top two stack items]' && ret=0

return ret
