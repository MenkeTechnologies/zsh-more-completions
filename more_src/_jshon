#compdef jshon
# Documentation: https://man.archlinux.org/search?q=jshon
# Reference accessed: 2026-05-16

# Zsh completion for jshon JSON manipulator (typical -e -a -k switches; see jshon -h).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show jshon usage]' \
  '*:jshon arguments:_message "see jshon(1)"' && ret=0

return ret
