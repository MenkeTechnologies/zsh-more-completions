#compdef hermesc hermes
# _hermesc — Hermes JavaScript engine compiler (Meta/Facebook); ahead-of-time compiles JS to bytecode for React Native
# upstream: https://github.com/facebook/hermes

_hermesc() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-version[show version]' \
        '-emit-binary[emit binary]' \
        '-O[optimize]' \
        '-O0[no optimize]' \
        '-out+[output file]:file:_files' \
        '-target=+[target arch]:arch:(HBC c)' \
        '-help[show help]' \
        '-dump-ast[dump AST]' \
        '-dump-ir[dump IR]' \
        '-dump-bytecode[dump bytecode]' \
        '-disable-direct-eval[disable direct eval]' \
        '-no-source-locations[strip source locations]' \
        '-strict[strict mode]' \
        '-static-builtins[use static builtins]' \
        '-w[no warnings]' \
        '-Werror[warnings as errors]' \
        '-fno-color[disable color]' \
        '-fcolor[force color]' \
        '-fno-debug-info[strip debug info]' \
        '-Xes6-proxy[enable ES6 Proxy]' \
        '-Xenable-tdz[enable TDZ checks]' \
        '*:script:_files -g "*.js"'
}

_hermesc "$@"
