#compdef depth
# Documentation: https://github.com/KyleBanks/depth
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# KyleBanks/depth — Go dependency tree visualization
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-internal[visualize all internal dependencies]' \
  '-max=[limit dependency tree to max depth]:n' \
  '-test[include test dependencies]' \
  '-explain=[print import chains containing target package]:package' \
  '-json[output as JSON]' \
  '1:package import path:' \
  '*::more packages: _default'
