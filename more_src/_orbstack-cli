#compdef orbstack-cli orb
# _orbstack-cli — OrbStack fast Linux/Docker for macOS CLI alias (OrbStack team, Rust/Swift); custom argparse
# upstream: https://orbstack.dev

_orbstack-cli() {
    local -a sub=(
        'start:start the OrbStack engine'
        'stop:stop the engine'
        'restart:restart the engine'
        'status:show engine status'
        'create:create new machine'
        'delete:delete machine'
        'list:list machines'
        'info:show machine info'
        'logs:show machine logs'
        'rename:rename machine'
        'reset-password:reset login password'
        'config:show or set config'
        'use:set default machine'
        'pull:pull docker image'
        'push:push docker image'
        'exec:execute command in machine'
        'shell:open shell in machine'
        'ssh:ssh to machine'
        'cp:copy files'
        'ip:print machine IP'
        'env:print env vars to source'
        'install-docker:install docker support'
        'install-kubectl:install kubectl'
        'install:install OrbStack itself'
        'uninstall:uninstall OrbStack'
        'update:update OrbStack'
        'completion:generate completion'
        'mount:mount machine fs'
        'unmount:unmount machine fs'
        'docker:run docker command via OrbStack'
        'kube:start:start kubernetes'
        'kube:stop:stop kubernetes'
        'kube:status:show kubernetes status'
        'kube:reset:reset kubernetes'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--json[json output]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'orb subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '1:image:(ubuntu debian alpine arch fedora centos rocky almalinux opensuse nixos kali openwrt void slackware gentoo)' \
                    '2:name:' \
                    '--user=+[user]:_users' \
                    '--arch=+[arch]:a:(amd64 arm64)' \
                    '--set-default[set default]' \
                    '--no-start[do not start]' ;;
                delete|info|logs|rename|use|exec|shell|ssh|cp|ip|mount|unmount|reset-password) _arguments \
                    '*:machine:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_orbstack-cli "$@"
