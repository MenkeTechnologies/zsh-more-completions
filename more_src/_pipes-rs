#compdef pipes-rs
# Documentation: https://github.com/lhvy/pipes-rs
# an over-engineered rewrite of pipes.sh in Rust

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-b[toggle bold text]:bold:(true false)' \
  '-c[set the color mode]:mode:(ansi rgb none)' \
  '-d[set the delay in ms]:ms' \
  '-i[toggle if pipes inherit style when hitting the edge]:inherit:(true false)' \
  '-k[set the kinds of pipes, comma separated]:kinds' \
  '-p[set the number of pipes on screen]:count' \
  '-r[percentage of screen filled before resetting]:ratio' \
  '-t[chance of a pipe turning each frame]:chance' \
  '--palette=[set the color palette, RGB mode only]:palette:(default darker pastel matrix)' \
  '--rainbow=[degrees per frame to shift the hue of each pipe]:degrees' && ret=0

return ret
