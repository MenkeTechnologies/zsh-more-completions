#compdef nebula
# Documentation: https://man.archlinux.org/search?q=nebula
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)-version[print version]'
  '-config[path to config file]:file:_files'
  '-test[test the config and exit]'
  '-print-cert[print the certificate and exit]:file:_files'
)

_arguments -s -S $arguments
