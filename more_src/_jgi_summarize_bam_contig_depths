#compdef jgi_summarize_bam_contig_depths
# Documentation: https://bitbucket.org/berkeleylab/metabat/src/master/README.md
# MetaBAT - summarize per-contig depth from BAM files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--outputDepth=[output file for depth matrix (default STDOUT)]:file:_files' \
  '--percentIdentity=[minimum alignment identity (default 97)]:percent' \
  '--pairedContigs=[output file for paired contig matrix]:file:_files' \
  '--unmappedFastq=[prefix for unmapped read files]:prefix' \
  '--noIntraDepthVariance[exclude variance along contig length]' \
  '--showDepth[generate per-base depth file per BAM]' \
  '--includeEdgeBases[include read-length edges in calculations]' \
  '--maxEdgeBases=[maximum edge length when excluding (default 75)]:bases' \
  '--referenceFasta=[reference assembly fasta]:file:_files' \
  '--shredLength=[maximum shred fragment length]:length' \
  '--shredDepth=[overlapping shred generation depth]:depth' \
  '--minContigLength=[minimum contig length for processing]:length' \
  '--minContigDepth=[minimum depth threshold for contig breaking]:depth' \
  '*:bam files:_files' && ret=0

return ret
