#compdef jubaconv
# Documentation: https://man.archlinux.org/search?q=jubaconv
# Reference accessed: 2026-05-16
# Source: https://github.com/hhatto/zsh_completions/blob/b1627488644e58825560d52b1f4c0c0a8feb6d39/_jubaconv
# Repository: hhatto/zsh_completions (_jubaconv)

typeset -A opt_args
local context state line

_arguments -s -S \
    "(-\? --help)"{-\?,--help}"[print this message]:" \
    "(-i --input-format)"{-i,--input-format}"[input format (json/datum) (string \[=json\])]:format:(json datum)" \
    "(-o --output-format)"{-o,--output-format}"[output format (json/datum/fv) (string \[=fv\])]:format:(json datum fv)" \
    "(-c --conf)"{-c,--conf}"[converter config file (string \[=\])]:file:_files" \
    "*::args:_gnu_generic"

