#compdef bb
# Documentation: https://book.babashka.org/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bb (babashka): native Clojure scripting runtime

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help,-\?}'[show help]' \
  '(- *)--version[show version]' \
  '(- *)--describe[describe the babashka process as EDN]' \
  '(-e --eval)'{-e,--eval}'[evaluate expression]:expression' \
  '(-f --file)'{-f,--file}'[evaluate file]:file:_files -g "*.{clj,bb,edn}"' \
  '(-m --main)'{-m,--main}'[call -main of namespace]:namespace' \
  '(-x --exec)'{-x,--exec}'[call fully qualified var with CLI parsing]:var' \
  '--init[load file before evaluation]:file:_files' \
  '--config[replace bb.edn with given config]:file:_files -g "*.edn"' \
  '--deps-root[treat directory as root for relative paths]:dir:_files -/' \
  '-i[bind *input* to lazy seq of text lines]' \
  '-I[bind *input* to lazy seq of EDN values]' \
  '-o[write output as text lines]' \
  '-O[write output as EDN values]' \
  '--stream[process each value individually]' \
  '(-cp --classpath)'{-cp,--classpath}'[classpath]:classpath' \
  '-Sdeps[deps.edn map]:deps map' \
  '-Sforce[force classpath recalculation]' \
  '--prn[print result with prn]' \
  '--debug[print debug info and internal stacktraces]' \
  '--force-exit[force exit even with non-daemon threads]' \
  '--uberscript[write uberscript to file]:file:_files' \
  '--uberjar[write uberjar to file]:file:_files -g "*.jar"' \
  '--jar[run from JAR file]:jar file:_files -g "*.jar"' \
  '1:subcommand:(clojure doc print-deps tasks run prepare repl socket-repl nrepl-server version describe help)' \
  '*:files:_files' && ret=0

return ret
