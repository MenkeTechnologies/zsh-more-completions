#compdef ip-tcp_metrics
# Documentation: https://man.archlinux.org/man/ip-tcp_metrics.8.en
# ip tcp_metrics - manage cached TCP metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip tcp_metrics command' \
      'show[display cached TCP metrics entries]' \
      'flush[remove entries by selection criteria]' \
      'delete[remove a single entry]' \
      'address[IPv4/IPv6 prefix or address]' && ret=0
    ;;
esac

return ret
