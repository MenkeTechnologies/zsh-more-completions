#compdef tofi-run
# _tofi-run — tofi tofi-run CLI executable launcher around the tofi dmenu-style fuzzy menu daemon for Wayland scanning PATH-resolved executables presenting them with configurable font color border anchor positioning fuzzy matching prefix multi-char keyboard filter (Philip Jones team, C); getopt
# upstream: https://github.com/philj56/tofi

_tofi-run() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.ini *.conf"' \
        '--config=+[config file]:file:_files -g "*.ini *.conf"' \
        '--output=+[output name]:str:' \
        '--prompt-text=+[prompt]:str:' \
        '--hide-input[hide input]' \
        '--hidden-character=+[char]:str:' \
        '--anchor=+[a]:a:(top-left top top-right left center right bottom-left bottom bottom-right)' \
        '--margin-top=+[N]:n:' \
        '--margin-bottom=+[N]:n:' \
        '--margin-left=+[N]:n:' \
        '--margin-right=+[N]:n:' \
        '--width=+[N]:n:' \
        '--height=+[N]:n:' \
        '--font=+[font]:str:' \
        '--font-size=+[N]:n:' \
        '--num-results=+[N]:n:' \
        '--background-color=+[color]:str:' \
        '--foreground-color=+[color]:str:' \
        '--selection-color=+[color]:str:' \
        '--placeholder-text=+[text]:str:' \
        '--matching-algorithm=+[a]:a:(normal fuzzy prefix contains)' \
        '--horizontal[horizontal layout]' \
        '--result-spacing=+[N]:n:' \
        '--require-match=+[s]:s:(true false)' \
        '--auto-accept-single=+[s]:s:(true false)' \
        '--history=+[s]:s:(true false)' \
        '--history-file=+[file]:file:_files' \
        '--drun-launch=+[s]:s:(true false)' \
        '--drun-print-exec=+[s]:s:(true false)' \
        '*::'
}

_tofi-run "$@"
