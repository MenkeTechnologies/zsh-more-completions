#compdef phlare grafana-pyroscope-server
# _phlare — Grafana Labs phlare CLI Grafana Phlare continuous profiling database server now Grafana Pyroscope ingesting CPU memory profiles in pprof folded jfr formats from Go Java Python Ruby Node.js Rust applications providing PromQL-style profile querying flame-graph UI multi-tenancy similar to Loki Tempo (Grafana Labs team, Go); pflag
# upstream: https://grafana.com/oss/pyroscope/

_phlare() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-config.file=+[file]:file:_files -g "*.yaml *.yml"' \
        '-config.expand-env=+[bool]:s:(true false)' \
        '-target=+[t]:t:(all distributor ingester querier query-frontend query-scheduler store-gateway compactor server-admin-api)' \
        '-server.http-listen-address=+[host]:_hosts' \
        '-server.http-listen-port=+[port]:n:' \
        '-server.grpc-listen-address=+[host]:_hosts' \
        '-server.grpc-listen-port=+[port]:n:' \
        '-server.path-prefix=+[path]:str:' \
        '-server.tls-enabled[server TLS]' \
        '-server.tls-cert-path=+[file]:file:_files' \
        '-server.tls-key-path=+[file]:file:_files' \
        '-log.level=+[l]:l:(debug info warn error)' \
        '-log.format=+[f]:f:(logfmt json)' \
        '-storage.backend=+[b]:b:(s3 gcs azure swift filesystem)' \
        '-storage.s3.endpoint=+[host:port]:str:' \
        '-storage.s3.region=+[region]:str:' \
        '-storage.s3.bucket-name=+[name]:str:' \
        '-storage.gcs.bucket-name=+[name]:str:' \
        '-storage.azure.account-name=+[name]:str:' \
        '-storage.azure.container-name=+[name]:str:' \
        '-storage.filesystem.dir=+[dir]:dir:_files -/' \
        '-runtime-config.file=+[file]:file:_files' \
        '-runtime-config.reload-period=+[duration]:str:' \
        '-memberlist.bind-port=+[port]:n:' \
        '-memberlist.join=+[addr]:str:' \
        '-multitenancy-enabled[enable multi-tenancy]' \
        '-distributor.ingestion-rate-limit-mb=+[N]:n:' \
        '*::'
}

_phlare "$@"
