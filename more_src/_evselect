#compdef evselect
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/evselect/node16.html
# XMM-Newton SAS: event selection and creation of products

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--table=[event list table specifier]:table:' \
  '--filteredset=[output filtered event list]:file:_files' \
  '--keepfilteroutput=[retain filtering results]:flag:(yes no)' \
  '--flagcolumn=[selection status flag column]:column:' \
  '--flagbit=[bit position in flag column]:bit:' \
  '--expression=[filter expression (selectlib syntax)]:expr:' \
  '--writedss=[write data subspace info]:flag:(yes no)' \
  '--cleandss=[remove unused data subspace components]:flag:(yes no)' \
  '--updateexposure=[recalculate exposure keywords]:flag:(yes no)' \
  '--filterexposure=[filter EPIC exposure extensions]:flag:(yes no)' \
  '--blockstocopy=[extensions to copy to output]:blocks:' \
  '--energycolumn=[energy column name]:column:' \
  '--imageset=[output image filename]:file:_files' \
  '--xcolumn=[X-coordinate column]:column:' \
  '--ycolumn=[Y-coordinate column]:column:' \
  '--squarepixels=[enforce equal x/y bin sizes]:flag:(yes no)' \
  '--ximagesize=[X-axis pixel count]:size:' \
  '--yimagesize=[Y-axis pixel count]:size:' \
  '--ximagebinsize=[X-axis binning factor]:size:' \
  '--yimagebinsize=[Y-axis binning factor]:size:' \
  '--imagedatatype=[output data type]:type:' \
  '--spectrumset=[output spectrum filename]:file:_files' \
  '--spectralbinsize=[spectrum binning factor]:size:' \
  '--specchannelmin=[minimum channel number]:chan:' \
  '--specchannelmax=[maximum channel number]:chan:' \
  '--rateset=[output time series filename]:file:_files' \
  '--timecolumn=[time coordinate column]:column:' \
  '--timebinsize=[time bin size]:size:' \
  '--timemin=[earliest time for series]:time:' \
  '--timemax=[latest time for series]:time:' \
  '--maketimecolumn=[include explicit time column]:flag:(yes no)' \
  '--makeratecolumn=[output rates instead of counts]:flag:(yes no)' \
  '--histogramset=[output histogram filename]:file:_files' \
  '--histogramcolumn=[source column for histogram]:column:' \
  '--histogrambinsize=[histogram binning factor]:size:' \
  '*:event file:_files' && ret=0

return ret
