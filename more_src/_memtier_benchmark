#compdef memtier_benchmark
# Documentation: https://man.archlinux.org/search?q=memtier_benchmark
# Reference accessed: 2026-05-16

# memtier_benchmark — Redis/Memcache load generator (Redis Labs). Flags mirror `memtier_benchmark --help`.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-s,--server}"=[server hostname]:host" \
  {-p,--port}"=[TCP port]:port" \
  {-P,--protocol}"=[protocol]:proto:(redis memcache_text memcache_binary)" \
  {-n,--requests}"=[total requests per client]:int" \
  {-c,--clients}"=[parallel clients]:int" \
  {-t,--threads}"=[worker threads]:int" \
  {-d,--data-size}"=[payload size]:int" \
  {-R,--pipeline}"=[pipeline depth]:int" \
  '--key-prefix=[key prefix string]:prefix' \
  '--ratio=[SET:GET ratio]:ratio' \
  '--authenticate=[Redis AUTH secret]:secret' \
  '--tls[TLS for Redis]' \
  '--cluster[Redis cluster mode]' && ret=0

return ret
