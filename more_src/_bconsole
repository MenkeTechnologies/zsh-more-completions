#compdef bconsole
# Documentation: https://manpages.ubuntu.com/manpages/focal/man8/bconsole.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bconsole: Bacula management console

_arguments -s \
  '-D+[select a director]:director:' \
  '-l[list defined directors]' \
  '-c+[config file]:file:_files' \
  '-d+[set debug level]:n:' \
  '-dt[print timestamp in debug output]' \
  '-n[no conio (for scripting)]' \
  '-s[no signals (for debugging)]' \
  '-u+[command execution timeout (seconds)]:secs:' \
  '-t[test the configuration file and report]' \
  '(- *)-\?[show version and usage]'
