#compdef bconsole
# Documentation: https://man.archlinux.org/search?q=bconsole
# Reference accessed: 2026-05-16

_arguments -s \
  '-D+[director name]:director:' \
  '-l[list defined directors]' \
  '-c+[config file]:file:_files' \
  '-d+[debug level]:n:' \
  '-dt[print debug timestamps]' \
  '-n[no conio (scripting)]' \
  '-s[no signals (debugging)]' \
  '-u+[command timeout secs]:secs:' \
  '-t[test config and report]' \
  '(- *)-?[show version and usage]'
