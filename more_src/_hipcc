#compdef hipcc hipconfig
# Documentation: https://man.archlinux.org/search?q=hipcc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-V)--version[show version]' \
  '-v[verbose output]' \
  '(-c)-c[compile only]' \
  '-S[assemble only]' \
  '-E[preprocess only]' \
  '-x+[input language]:lang:(c c++ hip cuda)' \
  '-O0[no optimization]' \
  '-O1[level 1]' \
  '-O2[level 2]' \
  '-O3[level 3]' \
  '-Os[size optimization]' \
  '-g[debug info]' \
  '-o+[output file]:file:_files' \
  '*-I+[include directory]:dir:_files -/' \
  '*-L+[library directory]:dir:_files -/' \
  '*-l+[link library]:lib:' \
  '*-D+[define macro]:macro:' \
  '*-U+[undef macro]:macro:' \
  '*-W+[warning option]:warn:' \
  '*-f+[flag]:flag:' \
  '--offload-arch=[GPU architecture]:arch:(gfx900 gfx906 gfx908 gfx90a gfx940 gfx941 gfx942 gfx1030 gfx1100 gfx1101 gfx1102 sm_70 sm_75 sm_80 sm_86 sm_89 sm_90)' \
  '*--offload-arch=[GPU architecture]:arch:' \
  '--amdgpu-target=[AMD GPU target deprecated]:arch:' \
  '*--amdgpu-target=[AMD GPU target]:arch:' \
  '--rocm-path=[ROCm root]:dir:_files -/' \
  '--rocm-device-lib-path=[device libs path]:dir:_files -/' \
  '--gpu-bundle-output[bundle output]' \
  '--no-gpu-bundle-output[no bundle output]' \
  '--cuda-path=[CUDA path]:dir:_files -/' \
  '--cuda-device-only[only compile for device]' \
  '--cuda-host-only[only compile for host]' \
  '--cuda-gpu-arch=[CUDA gpu arch]:arch:' \
  '*--gpu-arch=[gpu arch]:arch:' \
  '--gpu-max-threads-per-block=[max threads per block]:n:' \
  '--genco[generate code object]' \
  '-mllvm[pass to LLVM]:opt:' \
  '*: :_files -g "*.cpp *.cu *.hip *.c *.cc *.cxx *.h *.hpp"' && ret=0

return ret
