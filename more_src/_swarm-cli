#compdef swarm-cli
# _swarm-cli — CLI to manage Bee nodes / interact with the Swarm network (ethersphere/swarm-cli)
# upstream: https://github.com/ethersphere/swarm-cli
# Subcommands from src/config.ts + src/command/.

_swarm-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--bee-api-url=[Bee-client API URL]:url:' \
        '--config-folder=[config folder path]:dir:_files -/' \
        '--config-file=[config file name]:file:' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-q --quiet)'{-q,--quiet}'[only print results]' \
        '--curl[print equivalent curl commands]' \
        '*'{-H+,--header=}'[extra HTTP header (repeatable)]:header:' \
        '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
        '--dev[Bee node is in dev mode]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'addresses:show node addresses'
                'cheque:cashout cheques'
                'download:download data from Swarm'
                'feed:manage Swarm feeds'
                'grantee:manage grantee lists'
                'hash:compute a Swarm hash'
                'history:upload history management'
                'identity:manage identities'
                'manifest:work with Swarm manifests'
                'pinning:pin/unpin content'
                'pss:postal service over Swarm'
                'quickstart:quickly bootstrap a Bee node'
                'stake:manage stake'
                'stamp:manage postage stamps'
                'status:show node status'
                'upload:upload data to Swarm'
                'utility:utility commands'
                'wallet:manage the on-chain wallet'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_swarm-cli "$@"
