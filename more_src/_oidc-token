#compdef oidc-token
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/oidc-token.1.html
# oidc-token - get an OIDC access token on the command line

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[display help information]' \
  '--usage[display brief usage summary]' \
  '(-V --version)'{-V,--version}'[display program version]' \
  '(-a --all)'{-a,--all}'[return all available information (token, issuer, expiration)]' \
  '(-c --env)'{-c,--env}'[export token data as shell environment variables]' \
  '(-e --expires-at)'{-e,--expires-at=}'[return the expiration time for the access token]:env var' \
  '(-f --force-new)'{-f,--force-new}'[force that a new access token is issued]' \
  '(-i --issuer)'{-i,--issuer=}'[return the issuer associated with the access token]:env var' \
  '(-o --token)'{-o,--token=}'[return the requested access token]:env var' \
  '(-t --time)'{-t,--time=}'[minimum seconds the access token should be valid]:seconds' \
  '--aud=[audience for the requested access token]:audience' \
  '--id-token[return an ID-token rather than an access token]' \
  '--name=[name of this application]:name' \
  '--seccomp[enable seccomp system call filtering]' \
  '(-s --scope)'{-s,--scope=}'[scope to be requested for the access token]:scope' \
  '*:account shortname:' && ret=0

return ret
