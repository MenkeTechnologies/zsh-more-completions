#compdef vital
# Documentation: https://forum.vital.audio/t/vital-command-line-options-on-the-mac-version-of-vital/6287
# Vital spectral warping wavetable synthesizer

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help options]' \
  '(-v --version)'{-v,--version}'[show version information and exit]' \
  '--headless[run without graphical interface]' \
  '--tabletowav[convert a vitaltable to a wav file]' \
  '--tableimages[render an image for the table]' \
  '--render[render to an audio file]' \
  '(-m --midi)'{-m,--midi}'[note to play with --render]:note' \
  '(-l --length)'{-l,--length}'[note length to play with --render]:length' \
  '(-b --bpm)'{-b,--bpm}'[BPM to play with --render]:bpm' \
  '--images[render oscilloscope images with --render]' \
  '*:file:_files' && ret=0

return ret
