#compdef grpcui

# Zsh completion for grpcui (gRPC web UI)

_arguments -s -S \
  '-help[Show help]' \
  '-version[Print version]' \
  '-plaintext[Use plaintext (no TLS)]' \
  '-insecure[Skip server certificate and domain verification]' \
  '-cacert=[CA certificate file for TLS]:ca cert:_files -g "*.{pem,crt,cer}"' \
  '-cert=[Client certificate file for TLS]:client cert:_files -g "*.{pem,crt,cer}"' \
  '-key=[Client private key file for TLS]:client key:_files -g "*.{pem,key}"' \
  '-authority=[Value of :authority pseudo-header]:authority:' \
  '-proto=[Proto source file to use]:proto file:_files -g "*.proto"' \
  '-protoset=[Proto descriptor set file]:protoset file:_files -g "*.protoset"' \
  '*-import-path=[Path for proto imports]:import path:_directories' \
  '*-reflect-header=[Reflection header (key: value)]:header:' \
  '*-rpc-header=[Extra header for RPCs (key: value)]:header:' \
  '-connect-timeout=[Connection timeout]:timeout:' \
  '-keepalive-time=[Keepalive time]:time:' \
  '-max-msg-sz=[Maximum message size in bytes]:size:' \
  '-max-time=[Maximum time for operation]:time:' \
  '-port=[Port to listen on for web UI]:port:' \
  '-bind=[Address to bind the web UI]:address:' \
  '-open-browser[Open browser automatically]' \
  '-base-path=[Base path for web UI]:path:' \
  '-servername=[Override server name for TLS]:server name:' \
  '-vv[Enable very verbose output]' \
  '1:server host\:port:' && return 0
