#compdef fdbdr

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start disaster recovery'
  'switch:switch DR direction'
  'abort:abort DR'
  'status:show DR status'
)

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-d=[destination cluster file]:file:_files' \
  '-s=[source cluster file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'fdbdr subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '-k=[key range BEGIN [END]]:keys:' && ret=0
        ;;
      (status)
        _arguments \
          '-e=[entries limit]:n:' && ret=0
        ;;
    esac
    ;;
esac

return ret
