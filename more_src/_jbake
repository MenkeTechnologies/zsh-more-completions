#compdef jbake
# Documentation: https://jbake.org/docs/2.6.7/
# JBake Java static site/blog generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bake)'{-b,--bake}'[perform a bake]' \
  '(-i --init)'{-i,--init}'[initialise a project structure]' \
  '(-s --server)'{-s,--server}'[start serving the baked site]' \
  '(-t --template)'{-t,--template}'=[template engine]:engine:(freemarker groovy groovy-mte thymeleaf jade)' \
  '(-p --port)'{-p,--port}'=[server port]:port:' \
  '1:source:_files -/' \
  '2:destination:_files -/' && ret=0

return ret
