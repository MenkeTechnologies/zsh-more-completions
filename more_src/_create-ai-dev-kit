#compdef create-ai-dev-kit
# Documentation: https://www.npmjs.com/package/create-ai-dev-kit
# Reference accessed: 2026-05-24
# Verified: npm view create-ai-dev-kit bin; npm readme CLI Options section.

# Zsh completion for create-ai-dev-kit - AGENTS/CLAUDE/Copilot instructions scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--project=[project name for generated templates]:name:' \
  '--codex[generate AGENTS.md]' \
  '--claude[generate CLAUDE.md]' \
  '--copilot[generate .github/copilot-instructions.md]' \
  '--force[overwrite existing files instead of skipping]' \
  '--dry-run[show planned files without writing them]' && ret=0

return ret
