#compdef cgdisk-cli
# _cgdisk-cli — Rod Smith gdisk cgdisk curses-based GPT partition tool CLI alias (gdisk team, C++); custom argparse
# upstream: https://sourceforge.net/projects/gptfdisk/

_cgdisk-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-v[show version]' \
        '-V[show version]' \
        '-a+[arch alignment]:n:' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper}*"'
}

_cgdisk-cli "$@"
