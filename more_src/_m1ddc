#compdef m1ddc
# Documentation: https://man.archlinux.org/search?q=m1ddc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands properties

commands=(
  'display:select display by ID/UUID'
  'get:read property'
  'set:write property'
  'chg:change property by delta'
  'max:read maximum value of property'
  'display:list displays'
)

properties=(
  'luminance:brightness'
  'contrast:contrast'
  'volume:audio volume'
  'mute:mute (1=mute 2=unmute)'
  'red:red gain'
  'green:green gain'
  'blue:blue gain'
  'preset:preset mode'
  'pbp:picture-by-picture'
  'pip:picture-in-picture'
  'input:input source'
  'input-alt:alternate input'
  'standby:standby'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'm1ddc command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (get|max) _describe -t props 'property' properties && ret=0 ;;
      (set|chg) _describe -t props 'property' properties && ret=0 ;;
      (display) _values 'display selector' 'list' 'detailed' && ret=0 ;;
    esac ;;
esac

return ret
