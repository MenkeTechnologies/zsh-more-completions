#compdef m1ddc
# Documentation: https://github.com/waydabber/m1ddc/blob/main/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands properties

commands=(
  'set:write property value'
  'get:read property value'
  'max:read maximum value of property'
  'chg:change property by delta'
  'display:select display by ID/UUID or list'
)

properties=(
  'luminance:brightness'
  'contrast:contrast'
  'red:red gain'
  'green:green gain'
  'blue:blue gain'
  'volume:audio volume'
  'input:input source'
  'input-alt:alternate input addressing'
  'mute:mute (on/off or 1/2)'
  'pbp:picture-by-picture (Dell)'
  'pbp-input:second PIP/PBP input (Dell)'
  'kvm:KVM order (Dell)'
  'kvm-switch:move KVM to next device (Dell)'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'm1ddc command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (get|max|set|chg) _describe -t props 'property' properties && ret=0 ;;
      (display) _values 'display selector' 'list' 'detailed' && ret=0 ;;
    esac ;;
esac

return ret
