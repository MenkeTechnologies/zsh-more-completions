#compdef shopify-hydrogen
# _shopify-hydrogen — Shopify Hydrogen storefront subcommands (Shopify/hydrogen)
# upstream: https://github.com/Shopify/hydrogen
# Subcommands from packages/cli/src/index.ts (oclif).

_shopify-hydrogen() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'init:scaffold a new Hydrogen storefront'
                'dev:run the Hydrogen dev server'
                'build:build the storefront for production'
                'check:lint storefront for known issues'
                'codegen:generate Storefront-API GraphQL types'
                'deploy:deploy storefront to Oxygen'
                'preview:preview a production build'
                'setup:run interactive Hydrogen setup'
                'g:shortcut for generate route'
                'generate:generate route or routes'
                'link:link a Hydrogen storefront to local code'
                'unlink:unlink a Hydrogen storefront'
                'list:list available storefronts'
                'login:log in to Shopify'
                'logout:log out of Shopify'
                'env:manage storefront environment variables'
                'customer-account:manage customer-account config'
                'debug:debugging helpers (cpu profile, etc)'
                'shortcut:create a shell alias for `shopify hydrogen`'
                'upgrade:upgrade @shopify/hydrogen packages'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                env) _arguments '1:sub:(list pull push)' ;;
                generate) _arguments '1:sub:(route routes)' ;;
                setup) _arguments '1:sub:(css markets vite)' ;;
                debug) _arguments '1:sub:(cpu)' ;;
                customer-account) _arguments '1:sub:(push)' ;;
            esac
            ;;
    esac
}

_shopify-hydrogen "$@"
