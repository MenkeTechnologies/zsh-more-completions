#compdef openmc
# openmc — Monte Carlo particle transport simulation

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-s,--threads}'=[number of OpenMP threads]:threads:' \
  {-c,--cross_sections}'=[path to cross sections XML]:cross sections file:_files -g "*.xml(-.)"' \
  {-p,--path}'=[path to input files]:input dir:_directories' \
  '--event[use event-based parallelism]' \
  '--geometry-debug[enable geometry debugging mode]' \
  '--tallies[only calculate tallies]' \
  '--volume[run stochastic volume calculation]' \
  '--plot[generate geometry plots]' \
  '--track[write particle tracks]' \
  '--restart=[restart from state point file]:statepoint file:_files' \
  '--sourcepoint=[path to source file]:source file:_files' \
  ':input directory:_directories' && ret=0

return ret
