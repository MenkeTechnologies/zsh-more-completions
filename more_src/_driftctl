#compdef driftctl

# Zsh completion for driftctl (infrastructure drift detection)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '--no-version-check[Disable version check]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'scan:Scan for infrastructure drift'
      'gen-driftignore:Generate a .driftignore file'
      'completion:Generate shell completion scripts'
    )
    _describe -t commands 'driftctl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      scan)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--from=[IaC source]:source' \
          '--to=[Cloud provider]:provider:(aws+tf azure+tf gcp+tf github+tf)' \
          '--output=[Output format]:format:(console html json plan://)' \
          '-o+[Output format]:format:(console html json plan://)' \
          '--filter=[Resource type filter]:filter' \
          '--strict[Only show managed resources drift]' \
          '--deep[Enable deep mode for detailed scanning]' \
          '--tf-provider-version=[Terraform provider version]:version' \
          '--driftignore=[Path to .driftignore]:file:_files' \
          '--config-dir=[Directory for driftctl config]:dir:_directories' \
          '--headers=[Extra HTTP headers]:headers' \
          '--tfc-token=[Terraform Cloud token]:token' \
          '--tfc-endpoint=[Terraform Cloud API endpoint]:url' \
          '--tf-lockfile=[Path to .terraform.lock.hcl]:file:_files' \
          '--quiet[Suppress progress output]' && ret=0
        ;;
      gen-driftignore)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--input=[Input file path]:file:_files' \
          '-i+[Input file path]:file:_files' \
          '--exclude-unmanaged[Exclude unmanaged resources]' \
          '--exclude-missing[Exclude missing resources]' \
          '--exclude-changed[Exclude changed resources]' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
