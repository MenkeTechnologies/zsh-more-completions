#compdef falkon-cli falkon-launcher

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--profile=[profile name]:profile:' \
  '--private-browsing[start in private mode]' \
  '--portable[portable mode]' \
  '--new-tab=[open URL in new tab]:url:' \
  '--current-tab=[open URL in current tab]:url:' \
  '--no-extensions[disable extensions]' \
  '--no-remote[disable remote connections]' \
  '*:url:' && ret=0

return ret
