#compdef trivy-plugin
# _trivy-plugin — Aqua Trivy plugin manager subcommand alias (Aqua Security, Go); spf13/cobra
# upstream: https://github.com/aquasecurity/trivy

_trivy-plugin() {
    local -a sub=(
        'install:install a plugin'
        'uninstall:uninstall a plugin'
        'list:list installed plugins'
        'info:show plugin info'
        'run:run a plugin'
        'update:update an installed plugin'
        'upgrade:upgrade installed plugins'
        'search:search plugins on plugin index'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--debug[debug]' \
        '-d[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'trivy-plugin subcommand' sub ;;
        args)
            case $words[1] in
                install|uninstall|info|update) _arguments \
                    '*:plugin:' ;;
                list) _arguments '*:arg:' ;;
                run) _arguments \
                    '1:plugin:' \
                    '*:plugin-arg:' ;;
                upgrade) _arguments '*:plugin:' ;;
                search) _arguments '1:keyword:' ;;
            esac
            ;;
    esac
}

_trivy-plugin "$@"
