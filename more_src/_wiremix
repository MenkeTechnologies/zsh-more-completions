#compdef wiremix
# Documentation: https://www.mankier.com/1/wiremix
# wiremix - simple TUI audio mixer for PipeWire

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[override default config file path]:file:_files' \
  '(-r --remote)'{-r,--remote}'[name of the remote to connect to]:name' \
  '(-f --fps)'{-f,--fps}'[target frames per second (0 for unlimited)]:fps' \
  '(-s --char-set)'{-s,--char-set}'[character set to use]:set:(default compat extracompat)' \
  '(-t --theme)'{-t,--theme}'[theme to use]:theme:(default nocolor plain)' \
  '(-p --peaks)'{-p,--peaks}'[audio peak meters]:peaks:(off mono auto)' \
  '--no-mouse[disable mouse support]' \
  '--mouse[enable mouse support]' \
  '(-v --tab)'{-v,--tab}'[initial tab view]:tab:(playback recording output input configuration)' \
  '*'{-T,--tabs}'[which tabs are present and their order]:tabs:(playback recording output input configuration)' \
  '(-m --max-volume-percent)'{-m,--max-volume-percent}'[maximum volume for volume sliders]:percent' \
  '--no-enforce-max-volume[allow increasing volume past max-volume-percent]' \
  '--enforce-max-volume[prevent increasing volume past max-volume-percent]' \
  '--no-lazy-capture[monitor peak levels of all nodes]' \
  '--lazy-capture[monitor only on-screen nodes to reduce CPU usage]' && ret=0

return ret
