#compdef alimask
# HMMER: calculate and add a column mask to a multiple sequence alignment

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o+[direct summary output to file]:file:_files' \
  '--modelrange=[supply range(s) in model coordinates]:range' \
  '--alirange=[supply range(s) in alignment coordinates]:range' \
  '--appendmask[add to existing mask in alignment]' \
  '--model2ali=[print model range and corresponding alignment range]:range' \
  '--ali2model=[print alignment range and corresponding model range]:range' \
  '--amino[assert sequences are protein]' \
  '--dna[assert sequences are DNA]' \
  '--rna[assert sequences are RNA]' \
  '--fast[define consensus columns by symfrac fraction]' \
  '--hand[define consensus columns from reference annotation]' \
  '--symfrac=[residue fraction threshold]:x' \
  '--fragthresh=[sequence length threshold for fragments]:x' \
  '--wpb[Henikoff position-based sequence weighting]' \
  '--wgsc[Gerstein/Sonnhammer/Chothia weighting]' \
  '--wblosum[BLOSUM clustering weighting]' \
  '--wnone[no relative weights]' \
  '--wid=[identity threshold for --wblosum]:x' \
  '--informat=[assert input alignment format]:format' \
  '--outformat=[output alignment format]:format' \
  '--seed=[seed random number generator]:n' \
  '*:alignment file:_files' && ret=0

return ret
