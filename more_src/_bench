#compdef bench
# Documentation: https://man.archlinux.org/search?q=bench
# Reference accessed: 2026-05-16

# https://github.com/Gabriella439/bench — src/Main.hs (optparse-applicative + Criterion)
_arguments -s -S \
  '--before[command before each run]:cmd:' \
  '--after[command after each run]:cmd:' \
  '--version[show version]' \
  '*:benchmark command:_command_names -e'
