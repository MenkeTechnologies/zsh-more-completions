#compdef bench
# Documentation: https://github.com/Gabriella439/bench
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# https://github.com/Gabriella439/bench — Haskell criterion-style benchmark wrapper
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-o --output)'{-o,--output}'=[write report to file]:file:_files' \
  '--csv=[write CSV summary to file]:file:_files' \
  '--junit=[write JUnit summary to file]:file:_files' \
  '(-t --template)'{-t,--template}'=[custom template for report]:file:_files' \
  '--raw=[write raw data to file]:file:_files' \
  '(-I --ci)'{-I,--ci}'=[confidence interval]:ci:' \
  '(-G --no-gc)'{-G,--no-gc}'[disable GC between iterations]' \
  '(-L --time-limit)'{-L,--time-limit}'=[time limit in seconds]:secs:' \
  '--resamples=[bootstrap resamples count]:count:' \
  '--regress=[perform regression]:resp:pred:' \
  '(-n --iters)'{-n,--iters}'=[run without analysis]:iters:' \
  '(-m --match)'{-m,--match}'=[match benchmark names]:match:(prefix glob pattern)' \
  '(-v --verbosity)'{-v,--verbosity}'=[verbosity level]:level:' \
  '(-l --list)'{-l,--list}'[list available benchmarks]' \
  '*:benchmark command:_command_names -e'
