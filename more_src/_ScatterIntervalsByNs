#compdef ScatterIntervalsByNs
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/util/ScatterIntervalsByNs.java
# Picard: writes an interval list based on splitting a reference at Ns

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-R --REFERENCE)'{-R,--REFERENCE}'=[reference sequence with index and dictionary]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output interval list file]:file:_files' \
  '(-OT --OUTPUT_TYPE)'{-OT,--OUTPUT_TYPE}'=[type of intervals to output]:t:(N ACGT BOTH)' \
  '(-N --MAX_TO_MERGE)'{-N,--MAX_TO_MERGE}'=[max contiguous N bases to tolerate]:n:' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
