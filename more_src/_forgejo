#compdef forgejo

# Zsh completion for forgejo - Forgejo git hosting server CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-c --config)'{-c,--config}'[config file path]:config file:_files' \
  '(-w --work-path)'{-w,--work-path}'[working directory]:directory:_directories' \
  '(-C --custom-path)'{-C,--custom-path}'[custom directory path]:directory:_directories' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'web:Start the web server'
      'admin:Admin operations'
      'cert:Generate self-signed certificate'
      'hook:Git hook delegates'
      'dump:Dump all data'
      'generate:Generate resources'
      'doctor:Diagnose and fix problems'
      'manager:Manage running server'
      'embedded:Manage embedded resources'
      'migrate:Run database migrations'
      'dump-repo:Dump a repository'
      'restore-repo:Restore a repository'
      'actions:Manage Forgejo Actions'
      'convert:Convert database'
      'docs:Generate documentation'
    )
    _describe -t commands 'forgejo command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      web)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[port number]:port' \
          '--install-port=[port for install page]:port' \
          '(-P --pid)'{-P,--pid}'[PID file path]:pid file:_files' && ret=0
        ;;
      admin)
        local -a subcmds=(
          'user:Manage users'
          'auth:Manage authentication sources'
          'repo:Manage repositories'
        )
        _describe -t subcmds 'admin subcommand' subcmds && ret=0
        ;;
      hook)
        local -a subcmds=(
          'pre-receive:Run pre-receive hook'
          'update:Run update hook'
          'post-receive:Run post-receive hook'
        )
        _describe -t subcmds 'hook subcommand' subcmds && ret=0
        ;;
      generate)
        local -a subcmds=(
          'secret:Generate a secret'
        )
        _describe -t subcmds 'generate subcommand' subcmds && ret=0
        ;;
      doctor)
        local -a subcmds=(
          'check:Run diagnostic checks'
          'convert:Convert database'
          'recreate-table:Recreate database tables'
        )
        _describe -t subcmds 'doctor subcommand' subcmds && ret=0
        ;;
      manager)
        local -a subcmds=(
          'shutdown:Graceful shutdown'
          'restart:Graceful restart'
          'flush-queues:Flush queues'
          'logging:Manage logging'
          'processes:List running processes'
        )
        _describe -t subcmds 'manager subcommand' subcmds && ret=0
        ;;
      embedded)
        local -a subcmds=(
          'list:List embedded resources'
          'view:View an embedded resource'
          'extract:Extract embedded resources'
        )
        _describe -t subcmds 'embedded subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
