#compdef entangled
# Documentation: https://github.com/entangled/entangled.py
# entangled - bi-directional tangle for literate programming in Markdown

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    watch\:"run the daemon and keep sources in sync"
    tangle\:"extract code blocks into source files"
    stitch\:"apply source changes back to markdown"
    brei\:"run build tasks defined in the config"
  ))' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $words[1] in
      tangle)
        _arguments -s \
          '--force[overwrite local changes]' \
          '-r[regenerate without writing files]' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
