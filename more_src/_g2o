#compdef g2o
# Documentation: https://github.com/RainerKuemmerle/g2o/blob/master/g2o/apps/g2o_cli/g2o.cpp
# General graph optimization solver

local ret=1

_arguments -s -S \
  '-i[perform n iterations, if negative consider the gain]:n' \
  '-gain[the gain used to stop optimization]:g' \
  '-ig[maximum number of iterations with gain enabled]:n' \
  '-v[verbose output of the optimization process]' \
  '-guess[initial guess based on spanning tree]' \
  '-guessOdometry[initial guess based on odometry]' \
  '-inc[run incrementally]' \
  '-update[updates after x odometry nodes]:n' \
  '-guiout[gui output while running incrementally]' \
  '-marginalize[marginalize on or off]:state:(on off)' \
  '-printSolverProperties[print the properties of the solver]' \
  '-solverProperties[set the internal properties of a solver]:props' \
  '-gnudump[dump to gnuplot data file]:file:_files' \
  '-robustKernel[use this robust error function]:kernel' \
  '-robustKernelWidth[width for the robust kernel]:w' \
  '-computeMarginals[compute the marginal covariances]' \
  '-gaugeId[force the gauge]:id' \
  '-o[output final version of the graph]:file:_files' \
  '-solver[specify which solver to use]:solver' \
  '-solverlib[specify a solver library to load]:lib:_files' \
  '-typeslib[specify a types library to load]:lib:_files' \
  '-stats[specify a file for the statistics]:file:_files' \
  '-listTypes[list the registered types]' \
  '-listRobustKernels[list the registered robust kernels]' \
  '-listSolvers[list the available solvers]' \
  '-renameTypes[create a lookup for loading types into other types]:map' \
  '-gaugeList[set the list of gauges separated by commas]:list' \
  '-summary[append a summary of this optimization run]:file:_files' \
  '-nonSequential[apply robust kernel only on loop closures]' \
  '*:graph:_files -g "*.g2o"' && ret=0

return ret
