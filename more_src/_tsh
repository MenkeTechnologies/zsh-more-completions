#compdef tsh

# Zsh completion for tsh - Teleport SSH client

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_tsh_global_flags=(
  '(-p --proxy)'{-p,--proxy}'[Teleport proxy address]:proxy address:'
  '(-u --user)'{-u,--user}'[Teleport user name]:user:'
  '--auth[Specify the type of authentication connector]:connector:'
  '(-c --cluster)'{-c,--cluster}'[Specify the Teleport cluster]:cluster:'
  '--ttl[Minutes to live for a session]:minutes:'
  '(-i --identity)'{-i,--identity}'[Identity file]:file:_files'
  '--out[Identity output file]:file:_files'
  '--format[Identity format]:format:(file openssh tls kubernetes)'
  '--insecure[Do not verify server certificate]'
  '--debug[Verbose logging to stdout]'
  '(- *)--help[Show help]'
)

_arguments -s -S -C \
  "${_tsh_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'ssh:Run shell or execute a command on a remote SSH node'
      'ls:List remote SSH nodes'
      'clusters:List available Teleport clusters'
      'login:Log in to a cluster'
      'logout:Log out of all sessions'
      'status:Display the list of proxy servers and retrieved certificates'
      'env:Print commands to set Teleport session environment variables'
      'proxy:Run local TLS proxy'
      'apps:View and control proxied applications'
      'db:View and control proxied databases'
      'kube:Manage Kubernetes access'
      'mfa:Manage multi-factor authentication devices'
      'request:Manage access requests'
      'version:Print the tsh client version'
      'help:Show help'
    )
    _describe -t commands 'tsh commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      ssh)
        _arguments -s -S \
          "${_tsh_global_flags[@]}" \
          '(-L --forward)'{-L,--forward}'[Forward localhost connections to remote server]:host\:port:'
          '(-D --dynamic-forward)'{-D,--dynamic-forward}'[Forward localhost connections to remote server using SOCKS5]:port:'
          '--local[Execute command on localhost after connecting to SSH node]' \
          '-t[Allocate a pseudo-terminal]' \
          '-N[Do not execute remote command]' \
          '(-A --forward-agent)'{-A,--forward-agent}'[Forward agent to target node]' \
          '1:host:' \
          '*:command:' && ret=0
        ;;
      login)
        _arguments -s -S \
          "${_tsh_global_flags[@]}" \
          '--browser[Set to none to suppress browser opening]:browser:(none)' \
          '--kube-cluster[Name of the Kubernetes cluster]:cluster:' \
          '--request-reason[Reason for access request]:reason:' \
          '1:cluster:' && ret=0
        ;;
      ls)
        _arguments -s -S \
          "${_tsh_global_flags[@]}" \
          '--search[Resource search keywords]:keywords:' \
          '--query[Resource query]:query:' \
          '--format[Output format]:format:(text json yaml)' \
          '--all[List nodes from all clusters]' && ret=0
        ;;
      db)
        _arguments -s -S \
          "${_tsh_global_flags[@]}" \
          '1:subcommand:(ls login logout env config connect)' && ret=0
        ;;
      kube)
        _arguments -s -S \
          "${_tsh_global_flags[@]}" \
          '1:subcommand:(ls login sessions credentials)' && ret=0
        ;;
      apps)
        _arguments -s -S \
          "${_tsh_global_flags[@]}" \
          '1:subcommand:(ls login logout config)' && ret=0
        ;;
      mfa)
        _arguments -s -S \
          "${_tsh_global_flags[@]}" \
          '1:subcommand:(ls add rm)' && ret=0
        ;;
      request)
        _arguments -s -S \
          "${_tsh_global_flags[@]}" \
          '1:subcommand:(ls show create approve deny drop)' && ret=0
        ;;
      status|clusters|env|version|logout|help)
        _arguments -s -S \
          "${_tsh_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
