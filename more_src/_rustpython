#compdef rustpython rp
# _rustpython — RustPython: Python 3 interpreter written in Rust
# upstream: https://github.com/RustPython/RustPython
# Flags from src/settings.rs (CPython-compatible plus RustPython extras).

_rustpython() {
    local -a args
    args=(
        '*-b[issue warning on bytes/str coercion (-bb = error)]'
        '-B[do not write .pyc files on import]'
        '-c+[program passed in as string (terminates option list)]:command:'
        '*-d[turn on parser debugging output (debug builds only)]'
        '-E[ignore PYTHON\* environment variables]'
        '-i[inspect interactively after running script]'
        '-I[isolate from user environment (implies -E and -s)]'
        '-m+[run library module as a script]:module:'
        '*-O[optimize: remove asserts and __debug__ branches (-OO drops docstrings)]'
        '-P[do not prepend potentially unsafe path to sys.path]'
        '-q[do not print version/copyright on interactive startup]'
        '-s[do not add user site directory to sys.path]'
        '-S[do not auto-import site on initialization]'
        '-u[force unbuffered stdout/stderr]'
        '*-v[verbose: trace import statements (-vv for more)]'
        '(- *)-V[print version (-VV for more info)]'
        '-W+[warning control (action\:message\:category\:module\:lineno)]:warning:'
        '-x[skip first line of source (non-Unix shebang)]'
        '-X+[implementation-specific option]:option:'
        '--check-hash-based-pycs=[control hash-based .pyc invalidation]:mode:(always default never)'
        '--install-pip=[install pip via the chosen mechanism]:mode:(ensurepip get-pip)'
        '--help-env[print help about Python environment variables]'
        '--help-xoptions[print help about -X options]'
        '--help-all[print complete help information]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '*:Python script or argv:_files -g "*.py"'
    )
    _arguments -s -S $args
}

_rustpython "$@"
