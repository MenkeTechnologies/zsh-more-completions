#compdef aprates
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/aprates.html
# Compute net counts, rate, and/or flux plus credible intervals for a point source

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'n=[number of counts in source aperture]:n:' \
  'A_s=[geometric area of source aperture]:A_s:' \
  'alpha=[PSF Fraction in source aperture]:alpha:' \
  'T_s=[exposure time in source aperture]:T_s:' \
  'E_s=[average exposure in source aperture]:E_s:' \
  'eng_s=[average energy of events in source aperture]:eng_s:' \
  'flux_s=[average flux from events in source aperture]:flux_s:' \
  'm=[number of counts in background aperture]:m:' \
  'A_b=[geometric area of background aperture]:A_b:' \
  'beta=[PSF Fraction in background aperture]:beta:' \
  'T_b=[exposure time in background aperture]:T_b:' \
  'E_b=[average exposure in background aperture]:E_b:' \
  'eng_b=[average energy of events in background aperture]:eng_b:' \
  'flux_b=[average flux from events in background aperture]:flux_b:' \
  'conf=[desired credible interval]:conf:' \
  'outfile=[output file name]:file:_files' \
  'resolution=[resolution of PDF function]:resolution:' \
  'pdf=[which statistics to use in evaluating the PDF]:pdf:' \
  'max_counts=[max total counts before switching to Gaussian stats]:max_counts:' \
  'itermax=[maximum number of iterations for PDF grid]:itermax:' \
  'nsigma=[number of sigma from the mode for initial grid size]:nsigma:' \
  'pmin=[threshold of the ratio min(PDF)/PDF[mode]]:pmin:' \
  'verbose=[tool chatter and debugging output]:verbose:(0 1 2 3 4 5)' && ret=0

return ret
