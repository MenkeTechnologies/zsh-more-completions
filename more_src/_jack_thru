#compdef jack_thru
# Documentation: https://github.com/jackaudio/jack-example-tools/blob/main/example-clients/thru_client.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jack_thru: pipe JACK input to JACK output.
# Source main() takes NO option flags; positional args are
# [client-name [server-name]]. Removed fabricated
# -n/-s/--name/--server/-h/--help flags (not in source).
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:JACK client name:' \
  '2:JACK server name:' && ret=0
return ret
