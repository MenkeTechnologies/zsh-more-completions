#compdef jack_thru
# Documentation: https://github.com/jackaudio/jack-example-tools/blob/main/example-clients/thru_client.c
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# jack_thru: pipe JACK input to JACK output
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-n[JACK client name]:name:' \
  '--name=[JACK client name]:name:' \
  '-s[JACK server name]:name:' \
  '--server=[JACK server name]:name:' \
  '*::jack_thru args:_files' && ret=0
return ret
