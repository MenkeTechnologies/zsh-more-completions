#compdef capture-website
# Documentation: https://github.com/sindresorhus/capture-website-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--output=[image file path]:file:_files' \
  '--auto-output[auto-generate filename from URL/input]' \
  '--type=[image type]:type:(png jpeg webp)' \
  '--quality=[image quality 0-1]:n:' \
  '--overwrite[overwrite destination file]' \
  '--width=[page width]:px:' \
  '--height=[page height]:px:' \
  '--scale-factor=[scale webpage n times]:n:' \
  '--clip=[clipping region x,y,width,height]:rect:' \
  '--inset=[inset relative to viewport/element]:inset:' \
  '--list-devices[list supported devices]' \
  '--emulate-device=[emulate specific device]:device:' \
  '--dark-mode[emulate dark color scheme]' \
  '--timeout=[seconds before timeout]:sec:' \
  '--delay=[wait seconds after page loads]:sec:' \
  '--wait-for-element=[wait for CSS selector visibility]:selector:' \
  '--wait-for-network-idle[wait for network idle]' \
  '--preload-lazy-content[scroll to trigger lazy-loaded content]' \
  '--element=[capture specific DOM element]:selector:' \
  '*--hide-elements=[hide matching elements]:selector:' \
  '*--remove-elements=[remove matching elements]:selector:' \
  '*--click-element=[click specified element]:selector:' \
  '--scroll-to-element=[scroll to element]:selector:' \
  '*--module=[inject JavaScript module]:src:' \
  '*--script=[inject classic script]:src:' \
  '*--style=[inject CSS styles]:css:' \
  '--disable-animations[disable CSS animations/transitions]' \
  '--no-javascript[disable JavaScript execution]' \
  '*--header=[set custom HTTP header]:header:' \
  '--user-agent=[set user agent]:agent:' \
  '*--cookie=[set cookie]:cookie:' \
  '--authentication=[HTTP auth credentials]:user:pass:' \
  '--referrer=[custom referrer header]:url:' \
  '*--local-storage=[set localStorage item]:item:' \
  '--throw-on-http-error[error on non-2xx status codes]' \
  '--insecure[accept self-signed certificates]' \
  '--allow-cors[allow cross-origin requests]' \
  '--no-block-ads[disable ad blocking]' \
  '--debug[show browser window]' \
  '--log-console[redirect console output to terminal]' \
  '--launch-options=[Puppeteer launch options JSON]:json:' \
  '--no-default-background[transparent background]' \
  '--pdf-format=[paper format]:fmt:(letter legal tabloid ledger a0 a1 a2 a3 a4 a5 a6)' \
  '--pdf-landscape[use landscape orientation]' \
  '--pdf-margin=[page margins]:margin:' \
  '--pdf-background[include background graphics]' \
  '*:URL or HTML file:_files' && ret=0

return ret
