#compdef gpgsplit
# Documentation: gpgsplit --help on gpgsplit (GnuPG) 2.5.20
# Source: GnuPG gpgsplit — split an OpenPGP message into packets.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-p --prefix)'{-p,--prefix=}'[prepend filenames with STRING]:string:' \
    '--uncompress[uncompress a packet]' \
    '--secret-to-public[convert secret keys to public keys]' \
    '--no-split[write to stdout (no splitting)]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:OpenPGP file:_files -g "*.{gpg,pgp,asc}"' \
    && ret=0

return ret
