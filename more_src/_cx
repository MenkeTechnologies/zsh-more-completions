#compdef cx
# Documentation: https://man.archlinux.org/search?q=cx
# Reference accessed: 2026-05-16
# Source: https://github.com/guidomodarelli/system-config/blob/2caa0c60942187c8c49d2ec355a1902aaab134e6/configs/zsh/.zsh/completions/_cx
# Repository: guidomodarelli/system-config (configs/zsh/.zsh/completions/_cx)

# Completion for cx
# Supports:
#   upgrade (as first positional)
#   -m <model>
#   -re <reasoning>
#   -c, --commit
#   --no-mcps
# Remaining args treated as query tokens.

: "${CX_FZF_HEIGHT:=20%}"   # Altura de fzf (override: export CX_FZF_HEIGHT=40%)

_cx_models() {
  echo "gpt-5.5
gpt-5.4
gpt-5.3-codex"
}

_cx_reasoning() {
  echo "low
medium
high
xhigh"
}

_cx_model_select() {
  local -a items
  items=($(_cx_models))
  if (( $+commands[fzf] )); then
    local sel
    sel=$(printf '%s\n' "${items[@]}" | fzf --no-multi --height "${CX_FZF_HEIGHT}" --layout=reverse --border --prompt="Modelo> " --exit-0 --select-1 --query="${PREFIX}")
    if [[ -n $sel ]]; then
      compadd -- "$sel"
      return 0
    fi
  fi
  compadd -a items
}

_cx_reasoning_select() {
  local -a items
  items=($(_cx_reasoning))
  if (( $+commands[fzf] )); then
    local sel
    sel=$(printf '%s\n' "${items[@]}" | fzf --no-multi --height "${CX_FZF_HEIGHT}" --layout=reverse --border --prompt="Reasoning> " --exit-0 --select-1 --query="${PREFIX}")
    if [[ -n $sel ]]; then
      compadd -- "$sel"
      return 0
    fi
  fi
  compadd -a items
}

_cx() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  # Si ya se eligió 'upgrade' como primer argumento, no sugerir nada más.
  if [[ ${words[2]} == upgrade ]]; then
    return 0
  fi

  # Primera posición: siempre tratada como estado 'first' (para sugerir 'upgrade')
  _arguments -C \
    '1:first arg:->first' \
    '-m[Model to use]:model:_cx_model_select' \
    '-re[Reasoning effort]:effort:_cx_reasoning_select' \
    '(-c --commit)'{-c,--commit}'[Run built-in commit prompt in yolo mode (overrides query)]' \
    '--no-mcps[Disable MCP servers for this run]' \
    '*:query token:' && return 0

  case $state in
    first)
      # Sugerir 'upgrade'; si el usuario ya escribió algo, se filtra automáticamente.
      compadd upgrade
      return 0
      ;;
  esac
}

_cx "$@"
