#compdef dls

# dls: Sleuth Kit data unit (block) lister
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-A[list all allocated blocks]' \
  '-e[list every block]' \
  '-l[list block details]' \
  '-s[print slack space only]' \
  '-S[print slack and unused]' \
  '-a[list only allocated data]' \
  '-z[zero-only blocks]' \
  '-f[filesystem type]:fstype:(ntfs fat fat12 fat16 fat32 ext ext2 ext3 ext4 ufs ufs1 ufs2 iso9660 hfs swap raw)' \
  '-i[image type]:imgtype:(raw split aff afd afm afflib ewf)' \
  '-o[volume offset (sectors)]:n:' \
  '-b[block size]:bytes:' \
  '*:image file:_files' && ret=0
return ret
