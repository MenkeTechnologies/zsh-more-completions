#compdef dependency-cruise
# Documentation: https://github.com/sverweij/dependency-cruiser/blob/main/doc/cli.md
# dependency-cruise - validate and visualize dependencies (dependency-cruiser CLI)

local ret=1

_arguments -s -S \
  '--help[display help text]' \
  '(-T --output-type)'{-T,--output-type}'[output format]:type:(err err-long dot ddot archi flat mermaid d2 err-html markdown html csv teamcity azure-devops text json anon baseline metrics null)' \
  '(-f --output-to)'{-f,--output-to}'[write output to a file]:file:_files' \
  '--config=[use a configuration file with rules]:file:_files' \
  '--validate=[alias for --config]:file:_files' \
  '--no-config[skip the configuration file]' \
  '--init[run the interactive setup wizard]' \
  '--metrics[calculate stability metrics]' \
  '--no-metrics[disable metrics calculation]' \
  '--info[show supported alt-js languages]' \
  '--ignore-known=[ignore violations listed in a baseline file]:file:_files' \
  '--no-ignore-known[do not ignore known violations]' \
  '(-X --do-not-follow)'{-X,--do-not-follow}'[stop following modules matching the pattern]:regex:' \
  '(-I --include-only)'{-I,--include-only}'[only include modules matching the pattern]:regex:' \
  '(-F --focus)'{-F,--focus}'[show module with its direct neighbors]:regex:' \
  '--focus-depth=[number of neighbor layers to show]:depth:' \
  '--reaches=[show modules that transitively depend on the pattern]:regex:' \
  '--affected=[show modules changed since a git revision]:revision:' \
  '--highlight=[highlight modules matching the pattern]:regex:' \
  '(-S --collapse)'{-S,--collapse}'[summarize to a folder depth or pattern]:value:' \
  '(-x --exclude)'{-x,--exclude}'[exclude dependencies matching the pattern]:regex:' \
  '--max-depth=[limit the cruise depth]:depth:' \
  '--progress=[show progress feedback]:type:(cli-feedback performance-log ndjson none)' \
  '--no-progress[hide progress feedback]' \
  '--prefix=[prefix for links in the output]:prefix:' \
  '--module-systems=[module systems to detect]:systems:' \
  '--ts-pre-compilation-deps[include pre-compilation TypeScript dependencies]' \
  '--ts-config=[path to TypeScript config file]:file:_files' \
  '--webpack-config=[path to webpack config file]:file:_files' \
  '--preserve-symlinks[do not resolve symlinks]' \
  '--cache=[enable caching at a location]:dir:_files -/' \
  '--cache-strategy=[cache change detection strategy]:strategy:(metadata content)' \
  '--no-cache[disable caching]' \
  '*:path:_files' && ret=0

return ret
