#compdef _chromium-browser
# Documentation: https://man.archlinux.org/search?q=_chromium-browser
# Reference accessed: 2026-05-16
# Source: https://github.com/HeLiBloks/zsh-completion-Collectable-Completions/blob/b4d9a414dc5af4c9208ef9668c4ab70ea6a211e9/_chromium-browser
# Repository: HeLiBloks/zsh-completion-Collectable-Completions (_chromium-browser)

_arguments -s '(1 - :)--ppapi-flash-version[]'\
  '(1 - :)'{-h,--help}'[Show help screen]'\
  '(1 - :)--version[Show version information]'\
  '--app[Runs URL in "app mode" with no browser toolbars]'\
  '--display[See GTK documentation for more]'\
  '--incognito[Open in incognito mode]'\
  '--no-proxy-server[Disables the proxy server. Overrides any environment variables or settings picked via the options dialog]'\
  '--no-touch-pinch[Disable pinch gestures.]'\
  '--password-store[Set the password store to use]:password store:'\
  '--ppapi-flash-path[/lib/adobe-flashplugin/libpepflashplayer.so]'\
  '--proxy-auto-detect[Autodetect proxy configuration. Overrides any environment variables or settings picked via the options dialog]'\
  '--proxy-pac-url[Specify proxy autoconfiguration URL. Overrides any environment variables or settings picked via the options dialog]:url:_hosts'\
  '--proxy-server[Specify the HTTP/SOCKS4/SOCKS5 proxy server to use for requests. This overrides any environment  variables  or  set‐]:url:_hosts'\
  '--temp-profile[Start with a new and temporary profile]'\
  '--user-data-dir[Specifies the directory that user data (your "profile") is kept  in]:files:_files /-'\
  '--verbose[Events logged to stderr.]'\
  {-g,--debug}'[Start within /usr/bin/gdb]'\
  '*:filename:_files'

