#compdef chromium-browser chromium
# Documentation: https://peter.sh/experiments/chromium-command-line-switches/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(1 - :)'{-h,--help}'[show help screen]' \
  '(1 - :)--version[show version information]' \
  '--app=[launch URL in application mode]:url:' \
  '--incognito[open in incognito mode]' \
  '--no-proxy-server[disable the proxy server]' \
  '--password-store=[set the password store to use]:password store:(basic gnome kwallet)' \
  '--proxy-auto-detect[autodetect proxy configuration]' \
  '--proxy-pac-url=[specify proxy autoconfig URL]:url:_hosts' \
  '--proxy-server=[HTTP/SOCKS4/SOCKS5 proxy server]:url:_hosts' \
  '--user-data-dir=[directory where user profile data is kept]:dir:_files -/' \
  '--temp-profile[start with a new temporary profile]' \
  '--no-sandbox[disable the sandbox]' \
  '--disable-gpu[disable hardware GPU acceleration]' \
  '--headless[run without a UI]' \
  '--enable-features=[enable runtime features]:features:' \
  '--disable-features=[disable runtime features]:features:' \
  '*:filename:_files'

