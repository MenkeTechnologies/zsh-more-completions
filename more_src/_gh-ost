#compdef gh-ost

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--host=[MySQL hostname]:hostname:_hosts' \
  '--port=[MySQL port]:port:' \
  '--user=[MySQL user]:username:' \
  '--password=[MySQL password]:password:' \
  '--ask-pass[prompt for MySQL password]' \
  '--database=[database name]:database:' \
  '--table=[table name]:table:' \
  '--alter=[ALTER statement]:alter statement:' \
  '--execute[actually execute the migration]' \
  '--test-on-replica[test on replica before executing on master]' \
  '--migrate-on-replica[migrate on replica, do not promote]' \
  '--initially-drop-old-table[drop _old table at start]' \
  '--initially-drop-ghost-table[drop _ghost table at start]' \
  '--initially-drop-socket-file[drop socket file at start]' \
  '--ok-to-drop-table[drop _old table after migration]' \
  '--chunk-size=[number of rows per chunk]:rows:(100 500 1000 2500 5000)' \
  '--max-load=[max load before throttling]:load spec:' \
  '--critical-load=[max load before aborting]:load spec:' \
  '--max-lag-millis=[max replication lag]:milliseconds:' \
  '--throttle-control-replicas=[replicas to check for lag]:hosts:' \
  '--nice-ratio=[sleep ratio between chunks]:ratio:' \
  '--concurrent-rowcount[estimate rows concurrently]' \
  '--exact-rowcount[use exact row count]' \
  '--allow-on-master[allow running on master]' \
  '--allow-master-master[allow running on master-master setup]' \
  '--allow-nullable-unique-key[allow nullable unique key]' \
  '--approve-renamed-columns[approve renamed columns]' \
  '--skip-renamed-columns[skip renamed columns]' \
  '--tungsten[support Tungsten replication]' \
  '--assume-rbr[assume row-based replication]' \
  '--assume-master-host=[set explicit master]:hostname:_hosts' \
  '--cut-over=[cut-over strategy]:strategy:(atomic two-step)' \
  '--force-table-names=[override table names]:names:' \
  '--serve-socket-file=[Unix socket for interactive commands]:socket file:_files' \
  '--panic-flag-file=[flag file to panic and abort]:file:_files' \
  '--postpone-cut-over-flag-file=[flag file to postpone cut-over]:file:_files' \
  '--throttle-flag-file=[flag file to throttle]:file:_files' \
  '--throttle-additional-flag-file=[additional throttle flag file]:file:_files' \
  '--timestamp-old-table[add timestamp to old table name]' \
  '--verbose[verbose output]' \
  '--debug[debug mode]' \
  '--stack[add stack trace to error output]' && ret=0

return ret
