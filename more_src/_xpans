#compdef xpans
# Documentation: https://github.com/ericmandel/xpa/blob/master/doc/pod/xpans.pod
# XPA name server coordinating connections between clients and servers

local ret=1

_arguments -s -S \
  '-h[print help message]' \
  '-e[exit when there are no more XPA connections]' \
  '-k+[send keepalive messages every n seconds]:sec' \
  '-p+[listen for connections on specified port]:port' \
  '-l+[log database entries to file]:log:_files' \
  '-s+[log security info to file]:security log:_files' \
  '-P+[accept proxy requests]:n:(1 2)' \
  '--version[show version information]' && ret=0

return ret
