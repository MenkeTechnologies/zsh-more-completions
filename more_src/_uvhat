#compdef uvhat
# Documentation: https://lweb.cfa.harvard.edu/sma/miriad/manuals/SMAuguide/smauserhtml/uvhat.html
# Convert Hat Creek uv format into MIRIAD uv format

local ret=1

_arguments -s \
  'in=[input RALINT UV format data file]:file:_files' \
  'out=[output MIRIAD dataset name]:dataset:_files -/' \
  'logrange=[begin,end Hat Creek log numbers to include]:range' \
  'CHN=[number of ranges then channel pairs marking GOOD channels]:channels' \
  'BAD=[number of ranges then channel pairs marking BAD channels]:channels' \
  'ANT=[antenna selection (e.g. 123)]:antennas' \
  'SCA=[scale factors for baselines 12,23,31]:scales' \
  'DPH=[phase corrections in radians for baselines 12,23,31]:phases' \
  'WEI=[weights (unused in uvhat)]:weights' \
  '*:dataset:_files' && ret=0

return ret
