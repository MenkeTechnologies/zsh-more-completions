#compdef gokart

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'scan:scan Go source for security vulnerabilities'
  'help:show help'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'gokart command' commands && ret=0
    ;;
  args)
    case $line[1] in
      scan)
        _arguments -s -S \
          '(-i --input)'{-i,--input}'[input directory]:directory:_directories' \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '(-g --globalsTainted)'{-g,--globalsTainted}'[mark global variables as tainted]' \
          '(-x --sarif)'{-x,--sarif}'[output in SARIF format]' \
          '(-s --scan-vendor)'{-s,--scan-vendor}'[scan vendor directory]' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '--analyzers[analyzers to run]:analyzers:' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
