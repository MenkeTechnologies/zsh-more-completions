#compdef dinit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-d,--services-dir}'=[services directory]:directory:_directories' \
  {-s,--system}'[run as system service manager]' \
  {-u,--user}'[run as user service manager]' \
  {-p,--socket-path}'=[control socket path]:socket path:_files' \
  {-l,--log-file}'=[log file path]:log file:_files' \
  {-o,--container}'[run in container mode]' \
  {-q,--quiet}'[suppress output]' \
  '--env-file=[environment file]:env file:_files' \
  '--ready-fd=[file descriptor to notify readiness]:fd' \
  '*:service name' && ret=0

return ret
