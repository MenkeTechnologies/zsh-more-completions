#compdef condor_token_request_approve
# _condor_token_request_approve — HTCondor condor_token_request_approve (server-side: an administrator approves a pending IDTOKEN request raised by condor_token_request; --reqid pending request ID, --clientid CIPHERTEXT pairing, -name target daemon, -pool collector address)
# upstream: https://github.com/htcondor/htcondor
# Flags from HTCondor src/condor_tools/token_request_approve on tip.

_condor_token_request_approve() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-version[show version]' \
        '--reqid+[request id]:reqid:' \
        '--clientid+[client id pairing]:clientid:' \
        '-name+[daemon name]:name:' \
        '-pool+[collector]:host:_hosts'
}

_condor_token_request_approve "$@"
