#compdef womtool
# Documentation: https://cromwell.readthedocs.io/en/stable/WOMtool/
# WOMtool: command-line utility for validating and inspecting WDL workflows (Cromwell)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'validate:perform full syntax and semantic validation of a WDL file'
  'inputs:print a JSON skeleton of the inputs needed for this workflow'
  'outputs:print a JSON skeleton of the outputs for this workflow'
  'parse:write out an abstract syntax tree for a valid WDL file'
  'highlight:reformat and colorize/tag a WDL file (html or console)'
  'graph:print a .dot of the workflow DAG'
  'womgraph:convert a WDL file to WOM and print a graph of the result'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[print version]' \
  '--list-dependencies[(validate) list files referenced in import statements]' \
  '--all[(graph) include all WDL graph nodes in the DAG]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'womtool command' commands && ret=0 ;;
  (args) _files -g '*.wdl' && ret=0 ;;
esac

return ret
