#compdef unifi-os
# Documentation: https://man.archlinux.org/search?q=unifi-os
# Reference accessed: 2026-05-16

# UniFi Dream Machine style router OS: `unifi-os shell` enters the application container.
# Other verbs vary by firmware; after `shell`, pass through.

local curcontext="$curcontext" state line ret=1
local -a sub

sub=(
  'shell:attach an interactive shell in the UniFi OS workload'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '1: :->t1' \
  '*:: :->rest' && ret=0

case $state in
  t1)
    _describe -t commands 'unifi-os' sub && ret=0
    ;;
  rest)
    case $line[1] in
      shell)
        _arguments -s -S '*: :_normal' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
