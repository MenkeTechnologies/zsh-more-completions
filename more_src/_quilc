#compdef quilc
# Documentation: https://pyquil-docs.rigetti.com/en/v2.2.1/quilc-man.html
# The optimizing Quil compiler

local ret=1

_arguments -s -S \
  '(-h -? --help)'{-h,-\?,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-S --server)'{-S,--server}'[run compiler in server mode as HTTP server]' \
  '--port=[run server on specified port]:port' \
  '--time-limit=[limit request time in milliseconds]:ms' \
  '--isa=[compile for qubit architecture (8Q,20Q,16QMUX,file)]:isa' \
  '(-p --protoquil)'{-p,--protoquil}'[input/output must be ProtoQuil]' \
  '(-d --compute-gate-depth)'{-d,--compute-gate-depth}'[print calculated gate depth]' \
  '(-2 --compute-2Q-gate-depth)'{-2,--compute-2Q-gate-depth}'[print multiqubit gate depth]' \
  '--compute-gate-volume[print calculated gate volume]' \
  '(-r --compute-runtime)'{-r,--compute-runtime}'[print estimated runtime]' \
  '(-f --compute-fidelity)'{-f,--compute-fidelity}'[print estimated fidelity]' \
  '(-u --compute-unused-qubits)'{-u,--compute-unused-qubits}'[print unused qubits list]' \
  '(-t --show-topological-overhead)'{-t,--show-topological-overhead}'[print SWAP gates count]' \
  '--gate-blacklist=[ignore specified gates in statistics]:gates' \
  '--gate-whitelist=[consider only specified gates]:gates' \
  '--without-pretty-printing[disable numerical formatting]' \
  '--prefer-gate-ladders[use ladders instead of SWAP gates]' \
  '(-j --json-serialize)'{-j,--json-serialize}'[output as JSON]' \
  '(-s --print-logical-schedule)'{-s,--print-logical-schedule}'[include parallelized schedule in JSON]' \
  '(-m --compute-matrix-reps)'{-m,--compute-matrix-reps}'[print matrix representation]' \
  '--verbose[print compiler activity]' \
  '--enable-state-prep-reductions[optimize assuming zero initial state]' && ret=0

return ret
