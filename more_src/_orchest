#compdef orchest
# _orchest — Orchest build deploy run version-control multi-step data pipelines from Jupyter notebooks (orchest team, Python); click
# upstream: https://github.com/orchest/orchest

_orchest() {
    local -a sub=(
        'install:install Orchest'
        'uninstall:uninstall Orchest'
        'start:start Orchest'
        'stop:stop Orchest'
        'restart:restart Orchest'
        'status:show Orchest status'
        'update:update Orchest'
        'version:show version'
        'patch:patch Orchest config'
        'debug:run diagnostics'
        'adduser:add a user'
        'logs:show logs'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbosity=+[level]:l:(0 1 2 3)' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--silent[silent]' \
        '--cluster=+[k8s cluster]:str:' \
        '--namespace=+[k8s namespace]:str:' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'orchest subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '--socket-path=+[docker socket]:file:_files' \
                    '--port=+[port]:port:_ports' \
                    '--cluster-type=+[type]:t:(minikube k3s eks gke aks generic)' \
                    '--registry-storage=+[GiB]:n:' \
                    '--fqdn=+[fqdn]:host:_hosts' \
                    '--no-tls[no tls]' \
                    '--single-node[single node]' ;;
                start|stop|restart) _arguments \
                    '--container-runtime=+[runtime]:r:(docker containerd)' \
                    '--no-wait[no wait]' ;;
                update) _arguments \
                    '--registry=+[registry url]:url:_urls' \
                    '--dev[install dev version]' ;;
                adduser) _arguments \
                    '--admin[grant admin]' \
                    '--password=+[password]:str:' \
                    '*:username:_users' ;;
                logs) _arguments \
                    '--follow[follow]' \
                    '-f[follow]' \
                    '--tail=+[N]:n:' \
                    '--service=+[service]:str:' ;;
            esac
            ;;
    esac
}

_orchest "$@"
