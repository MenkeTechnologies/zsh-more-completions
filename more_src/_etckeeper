#compdef etckeeper

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-d+[specify etc directory]:directory:_directories' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'init:initialize repository'
      'commit:commit changes'
      'pre-commit:run pre-commit checks'
      'post-install:run post-install hook'
      'pre-install:run pre-install hook'
      'unclean:check for uncommitted changes'
      'update-ignore:update ignore patterns'
      'vcs:run VCS command in /etc'
      'uninit:remove repository'
    )
    _describe 'command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      commit)
        _arguments \
          '-m+[commit message]:message' \
          '*:file:_files' && ret=0
        ;;
      vcs)
        _arguments '*:vcs arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
