#compdef pdb_delelem
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Deletes all atoms matching the given element(s), e.g. -H or -H,N

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[element(s) to delete, e.g. -H or -H,N]:element' \
  '*:PDB file:_files' && ret=0

return ret
