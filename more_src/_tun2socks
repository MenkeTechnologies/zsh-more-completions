#compdef tun2socks

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-device+[TUN device name or URL]:device' \
  '-proxy+[SOCKS5 proxy address]:proxy URL' \
  '-loglevel=[log level]:level:(debug info warn error silent)' \
  '-interface=[bind to specific interface]:interface' \
  '-tcp-sndbuf=[TCP send buffer size]:size' \
  '-tcp-rcvbuf=[TCP receive buffer size]:size' \
  '-tcp-auto-tuning[enable TCP auto-tuning]' \
  '-udp-timeout=[UDP session timeout]:duration' \
  '-mtu=[set TUN device MTU]:mtu' \
  '-restapi=[enable REST API]:address' && ret=0

return ret
