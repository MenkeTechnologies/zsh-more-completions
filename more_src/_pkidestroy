#compdef pkidestroy
# Documentation: https://github.com/dogtagpki/pki/blob/master/docs/manuals/man8/pkidestroy.8.md
# Reference accessed: 2026-05-16
# Verified: upstream docs/manuals/man8/pkidestroy.8.md.

# pkidestroy: remove a Dogtag PKI subsystem
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-s[subsystem to eliminate]:subsystem:(CA KRA OCSP TKS TPS)' \
  '-i[instance name (default pki-tomcat)]:instance:' \
  '-u[security domain username]:user:_users' \
  '-W[security domain password file]:file:_files' \
  '*-v[verbose output (repeatable)]' && ret=0
return ret
