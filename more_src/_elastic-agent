#compdef elastic-agent

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'diagnostics:gather diagnostic information'
  'enroll:enroll the agent in Fleet'
  'help:show help'
  'inspect:inspect agent state'
  'install:install the agent'
  'logs:tail agent logs'
  'otel:run the OpenTelemetry collector mode'
  'privileged:set agent to privileged mode'
  'restart:restart the agent'
  'run:run the agent in foreground'
  'status:show agent status'
  'uninstall:uninstall the agent'
  'unprivileged:set agent to unprivileged mode'
  'upgrade:upgrade the agent'
  'version:show agent version'
  'windows:Windows-specific operations'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'elastic-agent subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (diagnostics)
        _arguments \
          '--file=[output file]:file:_files' \
          '--cpu-profile[capture CPU profile]' \
          '--exclude-events[exclude events]' && ret=0
        ;;
      (enroll|install)
        _arguments \
          '--url=[Fleet URL]:url:' \
          '--enrollment-token=[enrollment token]:token:' \
          '--ca-sha256=[CA SHA256 fingerprint]:hash:' \
          '--certificate-authorities=[CAs file]:file:_files' \
          '--daemon-timeout=[daemon timeout]:duration:' \
          '--delay-enroll[delay enrollment]' \
          '--elastic-agent-cert=[agent cert]:file:_files' \
          '--elastic-agent-cert-key=[agent cert key]:file:_files' \
          '--elastic-agent-cert-key-passphrase=[passphrase file]:file:_files' \
          '--fleet-server-cert=[fleet server cert]:file:_files' \
          '--fleet-server-cert-key=[fleet server cert key]:file:_files' \
          '--fleet-server-cert-key-passphrase=[fleet server passphrase file]:file:_files' \
          '--fleet-server-client-auth=[client auth mode]:mode:(none optional required)' \
          '--fleet-server-es=[Elasticsearch URL]:url:' \
          '--fleet-server-es-ca=[ES CA file]:file:_files' \
          '--fleet-server-es-ca-trusted-fingerprint=[ES CA fingerprint]:hash:' \
          '--fleet-server-es-cert=[ES cert]:file:_files' \
          '--fleet-server-es-cert-key=[ES cert key]:file:_files' \
          '--fleet-server-es-insecure[skip ES TLS verification]' \
          '--fleet-server-host=[fleet server host]:host:_hosts' \
          '--fleet-server-policy=[fleet server policy]:policy:' \
          '--fleet-server-port=[fleet server port]:port:' \
          '--fleet-server-service-token=[service token]:token:' \
          '--fleet-server-service-token-path=[service token path]:file:_files' \
          '--fleet-server-timeout=[fleet server timeout]:duration:' \
          '--force[force enrollment]' \
          '*--header=[extra HTTP header]:header:' \
          '--id=[agent id]:id:' \
          '--insecure[skip TLS verification]' \
          '--proxy-disabled[disable proxy]' \
          '*--proxy-header=[proxy header]:header:' \
          '--proxy-url=[proxy URL]:url:' \
          '--replace-token[replace token]' \
          '--staging=[staging URL]:url:' \
          '--tag=[agent tags]:tags:' \
          '--base-path=[install base path]:path:_files -/' \
          '--non-interactive[non-interactive install]' \
          '--privileged[install as privileged]' \
          '--unprivileged[install as unprivileged]' && ret=0
        ;;
      (inspect)
        _arguments \
          '--variables[show variables]' \
          '--monitoring[show monitoring]' \
          '--variables-wait=[wait for variables]:duration:' \
          '--show-config[show config]' \
          '--show-spec[show spec]' \
          ':target:(components)' && ret=0
        ;;
      (otel)
        _arguments \
          '*--config=[config file]:spec:' \
          '*--feature-gates=[feature gate]:gate:' \
          '*--set=[set property]:setting:' \
          ':action:(validate)' && ret=0
        ;;
      (run)
        _arguments \
          '-c=[config file]:file:_files' \
          '--e[log to stderr]' \
          '--environment=[environment]:env:' \
          '--path.config=[config path]:dir:_files -/' \
          '--path.home=[home path]:dir:_files -/' \
          '--path.logs=[logs path]:dir:_files -/' \
          '--v[verbose]' && ret=0
        ;;
      (status)
        _arguments \
          '--output=[output format]:format:(human json yaml)' && ret=0
        ;;
      (uninstall)
        _arguments \
          '--force[force uninstall]' \
          '--skip-fleet-audit[skip Fleet audit]' && ret=0
        ;;
      (upgrade)
        _arguments \
          '--source-uri=[source URI]:uri:' \
          '--skip-verify[skip verification]' \
          '--pgp-path=[PGP path]:file:_files' \
          '--pgp-uri=[PGP URI]:uri:' \
          ':version:' && ret=0
        ;;
      (logs)
        _arguments \
          '(-f --follow)'{-f,--follow}'[follow logs]' \
          '(-n --number)'{-n,--number=}'[number of lines]:n:' \
          '(-C --component)'{-C,--component=}'[component]:component:' \
          '--no-color[disable color]' && ret=0
        ;;
      (windows)
        _values 'windows action' 'registry update' 'registry remove' && ret=0
        ;;
    esac
    ;;
esac

return ret
