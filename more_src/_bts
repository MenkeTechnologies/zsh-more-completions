#compdef bts
# Documentation: https://manpages.debian.org/bts
# Source: debian/devscripts scripts/bts.pl — manipulate Debian Bug Tracking System (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    {-h,--help}'[show help]' \
    '--version[show version]' \
    '(--online)-o[offline mode]' \
    '(--online)--offline[offline mode]' \
    '--online[online mode]' \
    '(--no-cache)--cache[use cache]' \
    '--no-cache[do not use cache]' \
    '--cache-mode=-[cache mode]:mode:(min mbox full)' \
    '--cachemode=-[cache mode]:mode:(min mbox full)' \
    '--cache-delay=-[cache delay (seconds)]:seconds:_default' \
    {-m,--mbox,--mail}'[open mbox/mail viewer]' \
    {-w,--web}'[open web viewer]' \
    '--mailreader=-[mailreader command]:cmd:_default' \
    '--mail-reader=-[mailreader command]:cmd:_default' \
    '*--cc-addr=-[Cc address]:addr:_default' \
    '--sendmail=-[sendmail-like binary]:cmd:_command_names' \
    '--smtp-host=-[SMTP host[:port]]:host:_hosts' \
    '--smtphost=-[SMTP host[:port]]:host:_hosts' \
    '--smtp-reportbug[use reportbug SMTP host]' \
    '--smtp-user=-[SMTP user]:user:_users' \
    '--smtp-username=-[SMTP user]:user:_users' \
    '--smtp-pass=-[SMTP password]:pass:_default' \
    '--smtp-password=-[SMTP password]:pass:_default' \
    '--smtp-helo=-[SMTP HELO]:helo:_default' \
    '-f[force refresh of bts cache]' \
    '(--no-force-refresh)--force-refresh[force refresh]' \
    '--no-force-refresh[do not force refresh]' \
    '(--no-only-new)--only-new[only fetch new bugs]' \
    '--no-only-new[also fetch known bugs]' \
    {-n,--no-action}'[do not actually send commands]' \
    '*'{-q,--quiet}'[quiet mode (stackable)]' \
    '(--noconf --no-conf)'{--noconf,--no-conf}'[ignore conf files]' \
    '(--no-include-resolved)--include-resolved[include resolved bugs]' \
    '--no-include-resolved[exclude resolved bugs]' \
    '(--no-ack)--ack[request ack]' \
    '--no-ack[no ack requested]' \
    '(--no-interactive)'{-i,--interactive}'[ask before sending]' \
    '--no-interactive[do not ask before sending]' \
    '1:command:(affects archive assign blocked bugs cache claim cleancache clone close context disown done fixed forcemerge forwarded found help limit listcachedbugs merge mirror noowner notfixed notforwarded notfound owner package reassign reopen reply reportspam retitle select severity show spamreport status submitter subscribe summary tags unarchive unblock unclaim unmerge unsubscribe user usertags version)' \
    '*::command args:_default' \
    && ret=0

return ret
