#compdef syz-trace2syz
# _syz-trace2syz — convert strace logs to syzkaller programs (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-trace2syz/trace2syz.go (flag).

_syz-trace2syz() {
    _arguments \
        '-file=[strace log file to parse]:file:_files' \
        '-dir=[directory of strace logs to parse]:dir:_files -/' \
        '-deserialize=[directory to store deserialized programs]:dir:_files -/'
}

_syz-trace2syz "$@"
