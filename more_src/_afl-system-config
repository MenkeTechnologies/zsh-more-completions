#compdef afl-system-config
# _afl-system-config — reconfigure system for higher AFL++ fuzzing performance (AFLplusplus/AFLplusplus)
# upstream: https://github.com/AFLplusplus/AFLplusplus
# Flags from afl-system-config (sh).

_afl-system-config() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-hh[show extended help]' \
        '(- *)--help[show help]'
}

_afl-system-config "$@"
