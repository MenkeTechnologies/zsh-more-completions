#compdef anchor

# Zsh completion for anchor - Solana Anchor framework CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a new workspace'
  'new:create a new program in the workspace'
  'build:build the workspace'
  'verify:verify a deployed program'
  'test:run integration tests against a localnet'
  'deploy:deploy each program in the workspace'
  'upgrade:upgrade a single program'
  'migrate:run the deploy migration script'
  'idl:commands for interacting with IDL'
  'cluster:cluster utilities'
  'keys:program keypair commands'
  'expand:expand macros'
  'run:run an anchor script'
  'shell:start an Anchor shell'
  'localnet:start a local Solana validator'
  'account:fetch and decode an account'
  'publish:publish a program to the Anchor Program Registry'
  'login:save an Anchor Registry API token'
  'logout:remove API token'
  'airdrop:request an airdrop'
  'completions:generate shell completions'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'anchor command' commands && ret=0
    ;;
  args)
    case $words[1] in
      init)
        _arguments \
          '--javascript[use JavaScript instead of TypeScript]' \
          '--solidity[use Solidity instead of Rust]' \
          '--no-git[do not initialize a git repository]' \
          '--no-install[do not run install]' \
          '--package-manager[package manager to use]:pm:(npm yarn pnpm)' \
          '--template[template to use]:template:(multiple single)' \
          '--test-template[test template]:template:(mocha jest ava)' \
          '1:project name:' && ret=0
        ;;
      build)
        _arguments \
          '(-v --verifiable)'{-v,--verifiable}'[build using a docker image for reproducibility]' \
          '(-p --program-name)'{-p,--program-name}'[name of the program]:name:' \
          '--solana-version[solana version to use]:version:' \
          '--docker-image[docker image to use]:image:' \
          '--bootstrap[bootstrap from package]:option:' \
          '--idl[generate IDL]:dir:_directories' \
          '--idl-ts[generate TypeScript IDL]:dir:_directories' \
          '--no-idl[do not generate IDL]' \
          '--skip-lint[skip linting]' \
          '--arch[target architecture]:arch:(bpf sbf)' \
          '--no-docs[do not generate docs]' && ret=0
        ;;
      deploy)
        _arguments \
          '(-p --program-name)'{-p,--program-name}'[name of the program to deploy]:name:' \
          '--program-keypair[path to program keypair]:keypair:_files' \
          '--provider.cluster[cluster to deploy to]:cluster:(devnet testnet mainnet localnet)' \
          '--provider.wallet[wallet keypair to use]:wallet:_files' \
          '--verifiable[deploy a verifiable build]' && ret=0
        ;;
      test)
        _arguments \
          '--skip-deploy[skip deploying programs]' \
          '--skip-build[skip building programs]' \
          '--skip-local-validator[do not start a local validator]' \
          '--skip-lint[skip linting]' \
          '--detach[detach validator from foreground]' \
          '--run[only run tests matching the given name]:test name:' \
          '--provider.cluster[cluster to use]:cluster:(devnet testnet mainnet localnet)' \
          '--provider.wallet[wallet keypair to use]:wallet:_files' && ret=0
        ;;
      idl)
        local -a idl_commands=(
          'init:initialize an IDL account'
          'fetch:fetch an IDL from a program'
          'parse:parse an IDL from program source'
          'upgrade:upgrade an IDL'
          'set-buffer:set a new IDL buffer'
          'write-buffer:write an IDL into a buffer account'
          'set-authority:set the authority of an IDL'
          'erase-authority:erase the authority of an IDL'
          'authority:get the authority of an IDL'
          'close:close an IDL account'
        )
        _describe -t idl-commands 'idl command' idl_commands && ret=0
        ;;
      cluster)
        local -a cluster_commands=(
          'list:list available clusters'
        )
        _describe -t cluster-commands 'cluster command' cluster_commands && ret=0
        ;;
      keys)
        local -a keys_commands=(
          'list:list program keys'
          'sync:sync program keys with declare_id macros'
        )
        _describe -t keys-commands 'keys command' keys_commands && ret=0
        ;;
      airdrop)
        _arguments \
          '--provider.cluster[cluster]:cluster:(devnet testnet)' \
          '1:amount:' && ret=0
        ;;
    esac
    ;;
esac

return ret
