#compdef lua-format
# Documentation: https://github.com/Koihik/LuaFormatter
# reformat Lua source code

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help menu]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose mode]' \
  '-i[reformat files in-place]' \
  '--dump-config[output default style to stdout]' \
  '-c+[specify style configuration file]:file:_files' \
  '--config=[specify style configuration file]:file:_files' \
  '--column-limit=[maximum line length]:limit' \
  '--indent-width=[spaces per indentation level]:width' \
  '--tab-width=[spaces per tab character]:width' \
  '--continuation-indent-width=[indentation for continuation lines]:width' \
  '--spaces-before-call=[spaces before function calls]:count' \
  '--column-table-limit=[line length for table elements]:limit' \
  '--table-sep=[table field separator character]:char' \
  '--use-tab[indent with tabs]' \
  '--no-use-tab[indent with spaces]' \
  '--align-table-field[align table fields]' \
  '--no-align-table-field[do not align table fields]' \
  '--align-args[align function call arguments]' \
  '--no-align-args[do not align function call arguments]' \
  '--align-parameter[align function definition parameters]' \
  '--no-align-parameter[do not align function definition parameters]' \
  '--chop-down-table[break table fields onto separate lines]' \
  '--no-chop-down-table[do not break table fields]' \
  '--chop-down-kv-table[break key-value table fields onto separate lines]' \
  '--no-chop-down-kv-table[do not break key-value table fields]' \
  '--chop-down-parameter[break parameters onto separate lines]' \
  '--no-chop-down-parameter[do not break parameters]' \
  '--keep-simple-control-block-one-line[keep simple control blocks on one line]' \
  '--no-keep-simple-control-block-one-line[do not keep simple control blocks on one line]' \
  '--keep-simple-function-one-line[keep simple functions on one line]' \
  '--no-keep-simple-function-one-line[do not keep simple functions on one line]' \
  '--break-after-operator[break after operator]' \
  '--no-break-after-operator[break before operator]' \
  '--double-quote-to-single-quote[convert double quotes to single quotes]' \
  '--single-quote-to-double-quote[convert single quotes to double quotes]' \
  '--spaces-inside-table-braces[add spaces inside table braces]' \
  '--no-spaces-inside-table-braces[no spaces inside table braces]' \
  '--spaces-around-equals-in-field[spaces around equals in table fields]' \
  '--no-spaces-around-equals-in-field[no spaces around equals in table fields]' \
  '--line-separator=[line ending style]:type:(input os lf crlf cr)' \
  '*:lua file:_files -g "*.lua"' && ret=0

return ret
