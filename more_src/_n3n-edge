#compdef n3n-edge
# Documentation: https://github.com/n42n/n3n/blob/main/n3n-edge.8
# Reference accessed: 2026-05-16
# Verified: upstream n42n/n3n n3n-edge.8 manpage source.
# Removed from prior file: bogus man.archlinux.org search URL;
# missing 'stop' subcommand and 'help options'/'help config' forms.

# n3n-edge: n3n peer-to-peer VPN edge node (n2n fork)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'start:start the edge'
  'stop:stop the edge'
  'help:show help (or "help options" / "help config")'
)

_arguments -C \
  '*-O[set config option section.option=value]:setting:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '-c[community name (<=16 bytes)]:community:' \
  '--community=[community name]:community:' \
  '-l[supernode host:port]:host\:port:' \
  '--supernode-list=[supernode]:host\:port:' \
  '-k[ASCII encryption key]:key:' \
  '-a[TUNTAP interface IP \[mode\]<ip>\[/n\]]:addr:' \
  '-r[enable packet routing]' \
  '(-d --daemon)'{-d,--daemon}'[fork to background]' \
  '*-v[verbose (repeatable)]' \
  '*--verbose[verbose (repeatable)]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'n3n-edge command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (help) _values 'help topic' 'options' 'config' && ret=0 ;;
    esac
    ;;
esac
return ret
