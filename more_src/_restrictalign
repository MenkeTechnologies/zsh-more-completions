#compdef restrictalign
# Documentation: https://bio3d.colorado.edu/imod/doc/man/restrictalign.html
# Restrict tilt alignment parameters for low number of fiducials

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-align -a -AlignCommandFile)'{-align,-a,-AlignCommandFile}'[Command file for running Tiltalign. If this option is not]:file:_files' \
  '(-fiducials -f -NumberOfFiducials)'{-fiducials,-f,-NumberOfFiducials}'[Numbers of fiducial markers (beads) in the alignment model.]:value' \
  '(-views -vi -NumberOfViews)'{-views,-vi,-NumberOfViews}'[Number of views in the tilt series. If this option is not]:value' \
  '(-target -ta -TargetMeasurementRatio)'{-target,-ta,-TargetMeasurementRatio}'[Target ratio of measurements to unknown values. If two...]:value' \
  '-minimum[option, the restriction that gives a ratio closest to]' \
  '(-minimum -m -MinMeasurementRatio)'{-minimum,-m,-MinMeasurementRatio}'[Minimum ratio of measurements to unknown values....]:value' \
  '(-order -or -OrderOfRestrictions)'{-order,-or,-OrderOfRestrictions}'[Multiple integers]' \
  '(-cross -cr -UseCrossValidation)'{-cross,-cr,-UseCrossValidation}'[With this option, the program will test for the value of]:value' \
  '(-local -l -LocalAlignValidation)'{-local,-l,-LocalAlignValidation}'[Do cross-validation on local alignment parameters; enter 1...]:value' \
  '(-benefit -b -MinRobustBenefit)'{-benefit,-b,-MinRobustBenefit}'[Minimum percentage benefit (reduction in leave-out error)...]:value' \
  '(-cvorder -cv -CrossValTestOrder)'{-cvorder,-cv,-CrossValTestOrder}'[Multiple integers]' \
  '(-onestep -on -OneStepPerVariableTest)'{-onestep,-on,-OneStepPerVariableTest}'[Make only one change for a variable before testing other...]:value' \
  '(-permute -p -TestPermutations)'{-permute,-p,-TestPermutations}'[Multiple integers]' \
  '(-skipbeam -s -SkipBeamTiltWithOneRot)'{-skipbeam,-s,-SkipBeamTiltWithOneRot}'[By default, the program will add a solution for beam tilt...]' \
  '(-trial -tr -TrialMode)'{-trial,-tr,-TrialMode}'[Output modifications to a different command file instead of]' \
  '(-verbose -ve -VerboseOutput)'{-verbose,-ve,-VerboseOutput}'[Output the errors at each step when doing cross-validation]' \
  '-PID[Print process ID]' \
  '-StandardInput[read parameters from standard input]' \
  '-usage[print usage]' \
  '*:file:_files' && ret=0

return ret
