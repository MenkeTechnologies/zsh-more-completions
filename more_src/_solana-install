#compdef solana-install agave-install
# Documentation: https://docs.anza.xyz/cli/install
# solana-install / agave-install - Solana (Agave) cluster software installer

local curcontext="$curcontext" state line ret=1
local -a sub

sub=(
  'init:initialize the installation with config'
  'info:display installation information'
  'update:check for and apply updates'
  'run:run a program from the active release'
  'gc:garbage-collect old cached releases'
  'list:list installed/available releases'
  'deploy:deploy a new update manifest'
  'help:show help'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'=[configuration file path]:file:_files' \
  '(-d --data-dir)'{-d,--data-dir}'=[directory for installation data]:dir:_files -/' \
  '--no-modify-path[do not modify the PATH environment variable]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd) _describe -t commands 'solana-install command' sub && ret=0 ;;
  args)
    case $words[1] in
      info) _arguments '--local[only show local installation info]' '--eval[output environment vars in evaluable format]' && ret=0 ;;
      update) _arguments '--check[only check for an update, do not apply]' && ret=0 ;;
    esac
    ;;
esac

return ret
