# WHAT IT IS
#   `narr` is a **single-binary self-hosted web reader** that
#   ingests both:
#
#     • Classical RSS / Atom / JSONFeed feeds (the syndication
#       families predating Nostr — every blog and podcast on
#       the open web), and
#
#     • Nostr long-form text notes (kind:30023 NIP-23 articles
#       posted by tracked authors to relays of interest), Nostr
#       text notes from saved follow lists, and any other Nostr
#       event-kind that fits the "stream of dated entries from a
#       known author" mental model.
#
#   It runs as a standalone HTTP server (default
#   `127.0.0.1:7049`) backed by a single SQLite file (default
#   `<user-config-dir>/narr/storage.db`) and supports HTTP basic
#   auth (`--auth user:pass` or a `--auth-file`) plus HTTPS via
#   a `--cert-file` / `--key-file` pair.  All flags can also be
#   supplied via the `NARR_*` environment variables
#   (`NARR_ADDR`, `NARR_BASE`, `NARR_AUTHFILE`, `NARR_AUTH`,
#   `NARR_CERTFILE`, `NARR_KEYFILE`, `NARR_DB`, `NARR_LOGFILE`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/narr/main.go
#                       `flag.StringVar` / `flag.BoolVar` calls;
#                       extracted via raw.githubusercontent.com
#                       fetch of cmd/narr/main.go)
#
#   narr [OPTIONS]
#
#   Options:
#     -addr <HOST:PORT>              Address to run server on
#                                    [default: 127.0.0.1:7049]
#                                    [env: NARR_ADDR]
#     -base <PATH>                   Base path of the service URL
#                                    (for reverse-proxy mounting)
#                                    [env: NARR_BASE]
#     -auth-file <PATH>              Path to a file containing
#                                    `username:password`.  Takes
#                                    precedence over `-auth`.
#                                    [env: NARR_AUTHFILE]
#     -auth <USER:PASS>              Username and password literal
#                                    in `user:pass` format
#                                    [env: NARR_AUTH]
#     -cert-file <PATH>              Path to TLS cert file for HTTPS
#                                    [env: NARR_CERTFILE]
#     -key-file <PATH>               Path to TLS key file for HTTPS
#                                    [env: NARR_KEYFILE]
#     -db <PATH>                     Storage file path (SQLite)
#                                    [default: <user-config-dir>/
#                                     narr/storage.db]
#                                    [env: NARR_DB]
#     -log-file <PATH>               Path to log file instead of
#                                    stdout
#                                    [env: NARR_LOGFILE]
#     -version                       Print application version
#                                    and exit
#     -open                          Open the server in default
#                                    browser after startup
#     -h, -help                      Show usage (auto-generated by
#                                    Go's stdlib `flag` package)
#
# AXIS / CORPUS POSITION
#   `fiatjaf/narr` declares a **direct** dependency on
#   `github.com/nbd-wtf/go-nostr v0.48.4` in its `go.mod` (verified
#   via `gh api repos/fiatjaf/narr/contents/go.mod`).
#   `nbd-wtf/go-nostr` is THE canonical Go Nostr SDK — the Go
#   counterpart to rust-nostr/nostr-sdk (Rust) and nbd-wtf/
#   nostr-tools (TS/JS — same author `nbd-wtf` umbrella).  Every
#   serious Go Nostr application depends on it: relay
#   implementations (fiatjaf/khatru — fiatjaf's own canonical
#   relay framework, scsibug/nostr-rs-relay's Go competitors,
#   github-tijlxyz/khatru-pyramid, sandwichfarm/notemine,
#   verse-pbc/groups_relay's Go bridge); client tooling
#   (mattn/algia — the popular Mattn Nostr CLI client,
#   8go/nostr-commander-rs's predecessor, fiatjaf/nak —
#   fiatjaf's own canonical Swiss-army knife CLI tool); paid-
#   relay + zapping infrastructure (zapstore/zsp, getAlby/
#   nostr-wallet-connect, plantimals/knob); Bitcoin L2 wallet
#   daemons (ArkLabsHQ/fulmine, arkade-os/arkd's Nostr
#   notification subsystem); blogs / static-site generators
#   (dtonon/oracolo — minimalist Nostr blog as a single
#   HTML file, fiatjaf/narr the very project we are completing
#   here); social-graph + reputation tools (pippellia-btc/rely,
#   plantimals/knob); P2P + remote-control tools (ClarkQAQ/nrat
#   — Nostr-based anonymous remote access tool, mmalmi/nostr-vpn,
#   ryogrid/nostrp2p); and Lightning + zap infrastructure
#   (LNVPS/api, getAlby/nostr-wallet-connect, benthecarman/zap-
#   tunnel's Go components).
#
#   `nbd-wtf/go-nostr` exposes the typed `Event` struct (with
#   `Event.ID`, `Event.PubKey`, `Event.CreatedAt` (`nostr.Timestamp`
#   typed wrapper over int64), `Event.Kind` (`nostr.Kind` typed
#   wrapper), `Event.Tags` (`nostr.Tags` typed wrapper over
#   `[][]string`), `Event.Content`, `Event.Sig`, plus
#   `event.Sign(privkey)` / `event.CheckSignature()` /
#   `event.GetID()` / `event.Serialize()` methods); the typed
#   `Filter` struct + `Filter.Matches(event)` /
#   `Filter.MatchesIgnoringTimestampConstraints(event)` matching;
#   typed event-kind constants (`KindProfileMetadata` = 0,
#   `KindTextNote` = 1, `KindRecommendServer` = 2,
#   `KindFollowList` = 3, `KindEncryptedDirectMessage` = 4,
#   `KindDeletion` = 5, `KindRepost` = 6, `KindReaction` = 7,
#   `KindBadgeAward` = 8, `KindSeal` = 13, `KindPrivateDirectMessage`
#   = 14, `KindGenericRepost` = 16, `KindChannelCreation` = 40,
#   `KindGiftWrap` = 1059, `KindAuthentication` = 22242,
#   `KindNutzap` = 9321, `KindZapRequest` = 9734,
#   `KindZapReceipt` = 9735, `KindMuteList` = 10000,
#   `KindRelayList` = 10002, `KindBookmarkList` = 10003,
#   `KindArticle` = 30023, `KindHTTPAuth` = 27235, `KindBunkerRequest`
#   = 24133, `KindBunkerResponse` = 24134, and dozens more
#   typed `Kind` constants); the typed `nostr.GeneratePrivateKey()`
#   / `nostr.GetPublicKey(sk)` / `nostr.NormalizeURL(url)` /
#   `nostr.IsValidPublicKey(pk)` / `nostr.IsValid32ByteHex(s)`
#   key + URL helpers; the typed `Relay` struct + `relay.Connect(ctx)`
#   / `relay.Publish(ctx, event)` / `relay.Subscribe(ctx,
#   filters, opts)` / `relay.QuerySync(ctx, filter)` /
#   `relay.Close()` methods; the typed `SimplePool` struct +
#   `pool.SubscribeMany(ctx, urls, filters)` /
#   `pool.SubscribeManyEose(ctx, urls, filters)` /
#   `pool.QuerySingle(ctx, urls, filter)` /
#   `pool.PublishMany(ctx, urls, event)` multi-relay
#   convenience layer; and the full set of typed NIP packages
#   under `github.com/nbd-wtf/go-nostr/`:  `nip01` (basic
#   protocol), `nip04` (encrypted DMs), `nip05` (DNS verification
#   `name@host` resolver), `nip06` (BIP-39 derivation), `nip09`
#   (event deletion), `nip10` (event threads), `nip11` (relay
#   information document), `nip13` (proof-of-work), `nip17`
#   (private direct messages with gift wrapping), `nip19`
#   (bech32-encoded entities: `npub1…` / `nsec1…` / `note1…` /
#   `nprofile1…` / `nevent1…` / `nrelay1…` / `naddr1…`), `nip21`
#   (URI scheme), `nip26` (delegations), `nip28` (public chat
#   channels), `nip29` (relay-based groups), `nip39` (external
#   identities), `nip42` (relay authentication), `nip44`
#   (XChaCha20-Poly1305 payload encryption), `nip45` (relay-
#   COUNT mechanism), `nip46` (Nostr Connect / bunker URLs),
#   `nip47` (Nostr Wallet Connect — Lightning over Nostr),
#   `nip49` (encrypted secret-key export), `nip51` (lists),
#   `nip57` (Lightning zaps), `nip59` (gift wrap), `nip60`
#   (Cashu wallet), `nip61` (nutzaps), `nip65` (relay list
#   metadata), `nip77` (negentropy reconciliation), `nip78`
#   (application-specific data), `nip94` (file metadata),
#   `nip96` (HTTP file storage), and `nip98` (HTTP auth) —
#   each exposed as a typed package with verifier + builder
#   helpers.
#
#   Verified via:
#     gh api repos/fiatjaf/narr/contents/go.mod
#       → module github.com/fiatjaf/narr
#       → require github.com/nbd-wtf/go-nostr v0.48.4
#         (DIRECT — inside first `require (` block before any
#         closing `)`)
#     raw.githubusercontent.com fiatjaf/narr master cmd/narr/main.go
#       → flag.StringVar(&addr,    "addr",      opt("NARR_ADDR",
#         "127.0.0.1:7049"), "...")
#       → flag.StringVar(&basepath,"base",      opt("NARR_BASE", ""), …)
#       → flag.StringVar(&authfile,"auth-file", opt("NARR_AUTHFILE", ""), …)
#       → flag.StringVar(&auth,    "auth",      opt("NARR_AUTH", ""), …)
#       → flag.StringVar(&certfile,"cert-file", opt("NARR_CERTFILE", ""), …)
#       → flag.StringVar(&keyfile, "key-file",  opt("NARR_KEYFILE", ""), …)
#       → flag.StringVar(&db,      "db",        opt("NARR_DB", ""), …)
#       → flag.StringVar(&logfile, "log-file",  opt("NARR_LOGFILE", ""), …)
#       → flag.BoolVar(&ver,       "version",   false, "...")
#       → flag.BoolVar(&open,      "open",      false, "...")
#       → import "github.com/fiatjaf/narr/src/platform"
#       → import "github.com/fiatjaf/narr/src/server"
#       → import "github.com/fiatjaf/narr/src/storage"
#       → import "github.com/fiatjaf/narr/src/worker"
#       → worker.InitializeNostr(sqlitedb)  (the call that wires
#         the Nostr ingestion goroutine into the storage layer)
#
#   This entry is the Go=166 leader bump that continues Axis 111
#   (Nostr protocol) at 2/0/0 following R1031 _fipsctl (Rust=166
#   OPENED the axis via jmcorgan/fips on nostr-sdk).  TS-Node=166
#   closing pair on deck for R1033 via the canonical
#   `nbd-wtf/nostr-tools` (the canonical JS/TS Nostr SDK by the
#   same author, the JS reference implementation of every NIP).
#
#   No completion for `narr` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_narr() {
    _arguments -s \
        '(- *)-version[print application version and exit]' \
        '(- *)'{-h,-help}'[show usage]' \
        '-addr=[address to run server on (default 127.0.0.1:7049)]:host\:port:' \
        '-base=[base path of the service URL]:path:' \
        '-auth-file=[path to file containing user\:password]:path:_files' \
        '-auth=[user\:password literal]:credentials:' \
        '-cert-file=[path to TLS cert file for HTTPS]:path:_files -g "*.crt *.pem *.cert"' \
        '-key-file=[path to TLS key file for HTTPS]:path:_files -g "*.key *.pem"' \
        '-db=[storage file path (SQLite)]:path:_files -g "*.db *.sqlite *.sqlite3"' \
        '-log-file=[path to log file instead of stdout]:path:_files -g "*.log"' \
        '-open[open the server in default browser after startup]'
}

_narr "$@"
