#compdef uvgains
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvgains.html
# MIRIAD uvgains - convert raw on-off total-power data into a gains table

local ret=1

_arguments -s -S \
  'vis=[input uv-data file]:vis:_files' \
  'select=[standard uv selection commands]:select' \
  'line=[uv linetype (line,nchan,start,width,step)]:line' \
  'ref=[reference linetype for gains]:ref' \
  'stokes=[polarizations to convert input data to]:stokes' \
  'interval=[time averaging interval in minutes]:interval' \
  'out=[output uv dataset]:out:_files' \
  'options=[nocal,nopol,dopass,polyfit,window,dsb,scalar,unwrap,noamp]:options' \
  'device=[PGPLOT device for polynomial fit plot]:device' \
  'nxy=[plot window layout x and y counts]:nxy' \
  'npoly=[Lagrange polynomial order for fitting]:npoly' \
  'badchan=[channel ranges to exclude from polyfit]:badchan' \
  'endchan=[number of edge channels to drop in polyfit]:endchan' \
  '*:visibility data:_files' && ret=0

return ret
