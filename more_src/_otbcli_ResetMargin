#compdef otbcli_ResetMargin
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ResetMargin.html
# Orfeo ToolBox: reset the margins of an image with a fill value

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[scalar input image]:image:_files' \
  '-out[scalar output image]:output:_files' \
  '-threshold.y.start[top line index threshold]:value:' \
  '-threshold.y.end[bottom line index threshold]:value:' \
  '-threshold.x[column index threshold]:value:' \
  '-roi.startx[X position of ROI start]:value:' \
  '-roi.starty[Y position of ROI start]:value:' \
  '-roi.sizex[X size of ROI]:value:' \
  '-roi.sizey[Y size of ROI]:value:' \
  '-margin.top[top margin for ROI]:value:' \
  '-margin.bottom[bottom margin for ROI]:value:' \
  '-margin.left[left margin for ROI]:value:' \
  '-margin.right[right margin for ROI]:value:' \
  '-mode[region specification method]:mode:(roi margin threshold)' \
  '-fillval[value to insert in margins]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
