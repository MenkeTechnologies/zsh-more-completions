#compdef kubestr
# Documentation: https://kubestr.io/
# discover, validate and benchmark Kubernetes storage options

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'+[namespace to use]:namespace' \
  '(-o --output)'{-o,--output}'+[output format]:format:(json yaml)' \
  '(-e --outfile)'{-e,--outfile}'+[write output to file]:file:_files' \
  '*:command:(fio csicheck browse)' && ret=0

return ret
