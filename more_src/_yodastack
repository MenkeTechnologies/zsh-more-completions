#compdef yodastack
# Documentation: https://yoda.hepforge.org/
# yodastack - stack/add together histograms from several YODA files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'[write output to specified path]:file:_files' \
  '(-m --match)'{-m,--match}'[only write histograms whose path matches this regex]:regex:' \
  '(-M --unmatch)'{-M,--unmatch}'[exclude histograms whose path matches this regex]:regex:' \
  '(-v --verbose)'{-v,--verbose}'[print extra merging details]' \
  '(-q --quiet)'{-q,--quiet}'[only print fatal errors]' \
  '*:datafile:_files' && ret=0

return ret
