#compdef natron Natron NatronRenderer
# Documentation: https://man.archlinux.org/search?q=natron
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --background)'{-b,--background}'[background render]' \
  '(-w --writer)'{-w,--writer}'+[writer name and range]:writer:' \
  '(-i --reader)'{-i,--reader}'+[override reader]:reader:' \
  '(-l --onload)'{-l,--onload}'+[python script on load]:file:_files -g "*.py"' \
  '(-c --cmd)'{-c,--cmd}'+[python command]:cmd:' \
  '(-t --interactive)'{-t,--interactive}'[interactive mode after load]' \
  '(-o --output)'{-o,--output}'+[render specific writer]:opts:' \
  '(--no-settings)--no-settings[skip user settings]' \
  '(--clear-cache)--clear-cache[clear cache]' \
  '*:project:_files -g "*.ntp"' && ret=0

return ret
