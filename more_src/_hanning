#compdef hanning
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/hanning.html
# MIRIAD: smooth a cube along the spectral axis

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image]:in:_files' \
  'out=[output image]:out:_files' \
  'region=[region of interest]:region:' \
  'object=[smoothing method]:object:(hanning boxcar)' \
  'width=[number of channels, odd]:width:' \
  '*:image:_files' && ret=0

return ret
