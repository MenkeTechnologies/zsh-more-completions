#compdef csearch
# Zsh completion for csearch - search indexed code (Google Codesearch)
# https://github.com/google/codesearch

_arguments -s -S \
  '(- *)'-h'[display help]' \
  '-c[print only a count of matching lines]' \
  '-f=[filter by file name matching regexp]:file regexp:' \
  '-i[case-insensitive search]' \
  '-l[list matching files only]' \
  '-n[print line numbers]' \
  '-0[use null-terminated output]' \
  '-verbose[enable verbose output]' \
  '-brute[brute-force search without using index]' \
  '-indexpath=[set path to index file]:index path:_files' \
  ':regexp pattern:'
