#compdef wl-mirror

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-b[backend]:backend:(auto egl)' \
  '-s[scaling mode]:mode:(fit cover exact linear nearest)' \
  '-t[transform]:transform:(normal 90 180 270 flipped flipped-90 flipped-180 flipped-270)' \
  '-r[region]:region:' \
  '-S[stream socket]:socket:_files' \
  '--no-fullscreen[do not start fullscreen]' \
  '--fullscreen[start fullscreen]' \
  '--fullscreen-output[fullscreen on output]:output:' \
  '--no-fullscreen-output[disable fullscreen output preference]' \
  '1:output:' && ret=0

return ret
