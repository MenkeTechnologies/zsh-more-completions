#compdef wl-mirror
# Documentation: https://github.com/Ferdi265/wl-mirror
# Reference accessed: 2026-05-21
# Verified: argument parser in upstream src/options.c (strcmp() switch on
# argv[0] enumerates the flag set; scaling/backend/transform values come
# from the same file).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--no-verbose[disable verbose logging]' \
  '(-c --show-cursor)'{-c,--show-cursor}'[show cursor on mirrored screen]' \
  '--no-show-cursor[hide cursor on mirrored screen]' \
  '(-i --invert-colors)'{-i,--invert-colors}'[invert colors]' \
  '--no-invert-colors[do not invert colors]' \
  '(-f --freeze)'{-f,--freeze}'[freeze current image]' \
  '--unfreeze[resume screen capture]' \
  '--toggle-freeze[toggle freeze state]' \
  '(-F --fullscreen)'{-F,--fullscreen}'[start fullscreen]' \
  '--no-fullscreen[do not start fullscreen]' \
  '--fullscreen-output[fullscreen target output]:output:' \
  '--no-fullscreen-output[unset fullscreen target output]' \
  '(-s --scaling)'{-s,--scaling}'[scaling mode]:mode:(fit cover exact linear nearest)' \
  '(-b --backend)'{-b,--backend}'[capture backend]:backend:(auto export-dmabuf screencopy screencopy-dmabuf screencopy-shm extcopy extcopy-dmabuf extcopy-shm)' \
  '(-t --transform)'{-t,--transform}'[output transform]:transform:(normal flipX flipY flipped 0 0cw 0ccw 90 90cw 90ccw 180 180cw 180ccw 270 270cw 270ccw)' \
  '(-r --region)'{-r,--region}'[capture region (slurp format)]:region:' \
  '--no-region[capture entire output]' \
  '(-S --stream)'{-S,--stream}'[read options from stdin]' \
  '--title[custom window title]:title:' \
  '1:output:' && ret=0

return ret
