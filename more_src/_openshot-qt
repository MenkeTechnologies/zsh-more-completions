#compdef openshot-qt
# Documentation: https://man.archlinux.org/search?q=openshot-qt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--debug[enable debug logging]' \
  '--list-versions[list versions of dependencies]' \
  '--lang=[set UI language]:lang:' \
  '--reset[reset settings to defaults]' \
  '*:project file:_files -g "*.osp"' && ret=0

return ret
