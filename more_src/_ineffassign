#compdef ineffassign
# Documentation: https://github.com/gordonklaus/ineffassign
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-n[exit code 1 on findings]' \
  '*: :_files' && ret=0

return ret
