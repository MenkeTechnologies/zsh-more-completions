#compdef bwfmetaedit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--verbose[verbose output]' \
  '--simulate[simulate without modifying]' \
  '--specialchars[allow special characters in fields]' \
  '--reject-overwrite[reject files that would be overwritten]' \
  '--accept-nopadding[accept files without padding byte]' \
  '--continue-errors[continue on errors]' \
  '--append[append to existing bext chunk]' \
  '--in-core[process in memory]' \
  '--out-core[write to temp file first]' \
  '--Description[set Description]:description:' \
  '--Originator[set Originator]:originator:' \
  '--OriginatorReference[set OriginatorReference]:reference:' \
  '--OriginationDate[set OriginationDate]:date:' \
  '--OriginationTime[set OriginationTime]:time:' \
  '--TimeReference[set TimeReference]:reference:' \
  '--BextVersion[set BextVersion]:version:' \
  '--UMID[set UMID]:umid:' \
  '--LoudnessValue[set LoudnessValue]:value:' \
  '--LoudnessRange[set LoudnessRange]:range:' \
  '--MaxTruePeakLevel[set MaxTruePeakLevel]:level:' \
  '--MaxMomentaryLoudness[set MaxMomentaryLoudness]:loudness:' \
  '--MaxShortTermLoudness[set MaxShortTermLoudness]:loudness:' \
  '--CodingHistory[set CodingHistory]:history:' \
  '--IARL[set archival location]:location:' \
  '--IART[set artist]:artist:' \
  '--ICMT[set comment]:comment:' \
  '--ICRD[set creation date]:date:' \
  '--IENG[set engineer]:engineer:' \
  '--IGNR[set genre]:genre:' \
  '--INAM[set name]:name:' \
  '--IPRD[set product]:product:' \
  '--ISFT[set software]:software:' \
  '--ISRC[set source]:source:' \
  '--ITCH[set technician]:technician:' \
  '--MD5-Generate[generate MD5]' \
  '--MD5-Verify[verify MD5]' \
  '--MD5-Embed[embed MD5 in file]' \
  '--out-xml[XML output]' \
  '--in-xml[read from XML]:file:_files -g "*.xml"' \
  '--out-csv[CSV output]' \
  '--in-csv[read from CSV]:file:_files -g "*.csv"' \
  '*:files:_files -g "*.wav(|.bwf|.rf64)"' \
  && ret=0

return ret
