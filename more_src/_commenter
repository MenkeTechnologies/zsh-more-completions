#compdef commenter
# _commenter — bulk comment on matching GitHub issues/PRs (kubernetes/test-infra)
# upstream: https://github.com/kubernetes/test-infra
# Flags from robots/commenter/main.go (flag).

_commenter() {
    _arguments \
        '-query=[GitHub search query]:query:' \
        '-updated=[filter to issues unmodified for at least]:duration:' \
        '-include-archived[match archived issues]' \
        '-include-closed[match closed issues]' \
        '-include-locked[match locked issues]' \
        '-confirm[mutate GitHub]' \
        '-comment=[comment to append]:text:' \
        '-template[treat --comment as Go text template]' \
        '-ceiling=[max number of issues to modify (0=infinite)]:n:' \
        '-endpoint=[GitHub API endpoint]:url:_urls' \
        '-graphql-endpoint=[GitHub GraphQL endpoint]:url:_urls' \
        '-token=[GitHub token file]:file:_files' \
        '-random[choose random matching issues]'
}

_commenter "$@"
