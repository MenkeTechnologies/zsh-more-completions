#compdef supermercado
# Documentation: https://github.com/mapbox/supermercado
# Supercharge mercantile with extra tile-stream operations

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(- *)--help[show help and exit]' \
  '1:command:((
    burn\:"stream intersecting [x, y, z] tiles from GeoJSON at a zoom level"
    edges\:"output the edge tiles of an input [x, y, z] stream"
    union\:"output unioned GeoJSON from an input [x, y, z] stream"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      burn)
        _arguments -s -S \
          '--help[show help]' \
          '1:zoom level:' && ret=0
        ;;
      *)
        _arguments '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
