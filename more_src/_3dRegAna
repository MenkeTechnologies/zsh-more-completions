#compdef 3dRegAna
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dRegAna.html
# AFNI: multiple linear regression analysis for 3D datasets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-rows[number of input datasets]:n:' \
  '-cols[number of X variables]:m:' \
  '*-xydata[X variable values and input filename]:values filename:_files' \
  '-model[regression model specification]:model:' \
  '-diskspace[print required disk space]' \
  '-workmem[megabytes of RAM to use]:mega:' \
  '-rmsmin[minimum rms error to reject constant]:r:' \
  '-fdisp[display results with F >= fval]:fval:' \
  '-flof[F threshold for lack of fit]:alpha:' \
  '*-fcoef[F-stat for kth coefficient]:k prefixname:_files' \
  '*-rcoef[partial R^2 for kth coefficient]:k prefixname:_files' \
  '*-tcoef[t-stat for kth coefficient]:k prefixname:_files' \
  '-bucket[output bucket dataset]:n prefixname:_files' \
  '*-brick[define sub-brick of bucket]:m type k label:' \
  '-datum[output data type]:DATUM:(short float)' \
  '*:dataset:_files' && ret=0

return ret
