#compdef 3dvolreg
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dvolreg.html
# AFNI 3D rigid-body volume registration (motion correction)

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-verbose[print progress reports]' \
  '-Fourier[Fourier interpolation (most accurate)]' \
  '-heptic[7th-order polynomial interpolation (default)]' \
  '-quintic[5th-order polynomial interpolation]' \
  '-cubic[cubic polynomial interpolation]' \
  '-linear[linear interpolation]' \
  '-clipit[clip output to input value range]' \
  '-noclip[disable value clipping]' \
  '-zpad[zeropad edges by n voxels during rotation]:voxels' \
  '-prefix[output dataset prefix]:prefix' \
  '-float[output in floating-point format]' \
  '-base[set base brick to nth sub-brick]:n' \
  '-dfile[save motion parameters to file]:file:_files' \
  '-1Dfile[save motion params as 6-column ASCII]:file:_files' \
  '-1Dmatrix_save[save transform matrix to file]:file:_files' \
  '-rotcom[output 3drotate commands]' \
  '-maxdisp[print max displacement in mm]' \
  '-nomaxdisp[disable max displacement calc]' \
  '-maxdisp1D[write per-brick displacement to file]:file:_files' \
  '-savedisp[save x,y,z displacement datasets]:prefix' \
  '-tshift[time-shift before registration]:count' \
  '-rotparent[apply rotation from reference dataset]:dataset:_files' \
  '-gridparent[align output grid to dataset]:dataset:_files' \
  '-maxite[limit convergence iterations]:m' \
  '-x_thresh[movement convergence threshold]:x' \
  '-rot_thresh[rotation convergence threshold]:r' \
  '-delta[finite-difference distance in voxels]:d' \
  '-final[final output interpolation mode]:mode:(NN linear cubic quintic heptic Fourier wsinc5)' \
  '-weight[weight by specified brick]:dataset:_files' \
  '-edging[edge region where weight is zero]:ee' \
  '-twopass[two-pass registration]' \
  '-twoblur[first-pass blur factor]:bb' \
  '-twodup[reset output origins to base]' \
  '-sinit[disable zeroth-pass scale estimation]' \
  '-coarse[coarse shifts del num]:del' \
  '-coarserot[include coarse angle search]' \
  '-nocoarserot[skip coarse angle search]' \
  '-wtinp[use input sub-brick 0 as weight]' \
  '*:dataset:_files' && ret=0

return ret
