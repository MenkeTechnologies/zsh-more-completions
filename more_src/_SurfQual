#compdef SurfQual
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/SurfQual.html
# AFNI/SUMA check the quality of surfaces

local ret=1

_arguments -s -S \
  '-spec[spec file containing input surfaces (mandatory)]:spec:_files' \
  '-surf_A[input surface A (mandatory)]:surface:' \
  '-sphere[surfaces are spherical; radius/normal checks]' \
  '-self_intersect[check if surface self-intersects]' \
  '-summary[results summary to standard output]' \
  '-prefix[prefix for output files]:outpref:' \
  '*:surface:_files' && ret=0

return ret
