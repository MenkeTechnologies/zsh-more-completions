#compdef tclkitsh
# Documentation: https://wiki.tcl-lang.org/page/Tclkit
# Single-file command-line Tcl interpreter (tclsh-equivalent Tclkit)

local ret=1

_arguments -s \
  '-encoding[specify encoding of the script file]:encoding:' \
  '1:script or starkit:_files' \
  '*::args:_default' && ret=0

return ret
