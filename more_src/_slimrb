#compdef slimrb
# Documentation: https://man.archlinux.org/search?q=slimrb
# Reference accessed: 2026-05-16

_arguments -s \
  '(-s --stdin)'{-s,--stdin}'[read stdin]' \
  '--trace[full traceback]' \
  '(-c --compile)'{-c,--compile}'[compile only]' \
  '(-e --erb)'{-e,--erb}'[convert to ERB]' \
  '--rails[Rails-compatible]' \
  '*'{-r,--require}'=[library]:lib:' \
  '(-p --pretty)'{-p,--pretty}'[pretty HTML]' \
  '*'{-o,--option}'=[NAME=CODE]:option:' \
  '(-l --locals)'{-l,--locals}'=[locals]:locals:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:file:_files -g "*.slim"'
