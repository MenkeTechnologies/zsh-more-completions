#compdef genePredCheck
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: validate genePred files or tables

local ret=1

_arguments -s -S \
  '-db=[database used to get chromosome sizes and perhaps the table to check]:db' \
  '*:genePred file or table:_files' && ret=0

return ret
