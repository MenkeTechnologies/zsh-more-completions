#compdef foldmason
# Documentation: https://github.com/steineggerlab/foldmason
# FoldMason - multiple structure alignment of proteins

local ret=1

local -a cmds
cmds=(
  'easy-msa:multiple alignment workflow from structure files'
  'structuremsa:multiple alignment from structure database'
  'createdb:pre-process structure databases for repeated alignment tasks'
  'msa2lddt:calculate structure-based scoring metrics for alignments'
  'msa2lddtreport:generate interactive HTML visualization of results'
  'msa2lddtjson:produce JSON output compatible with the webserver'
  'refinemsa:iterative refinement to enhance alignment quality'
)

_arguments -s -S \
  '--threads[number of threads]:n' \
  '--gap-open[gap opening penalty]:penalty' \
  '--gap-extend[gap extension penalty]:penalty' \
  '--refine-iters[number of refinement iterations]:n' \
  '--output-mode[amino acid or 3Di alphabet output]:mode' \
  '--pair-threshold[max proportion of gaps in column for LDDT]:threshold' \
  '--report-mode[HTML/JSON visualization generation mode]:mode' \
  '--precluster[enable pre-clustering for large datasets]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'foldmason command' cmds && ret=0 ;;
  args) _files && ret=0 ;;
esac

return ret
