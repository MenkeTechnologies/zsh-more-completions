#compdef raine
# Documentation: https://github.com/zelurker/raine/blob/master/source/config.c
# Reference accessed: 2026-05-16
# Verified: source/config.c CLI_Help (lines 65-150) + CLI_Options table
# (lines 1777-1810).

# Raine: arcade emulator (CPS1/CPS2/Neo Geo/etc.)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-?[show help]' \
  '(-game -g)'{-game,-g}'[select a game to load]:gamename:' \
  '-rp[path for 1st ROM path]:path:_files -/' \
  '(-gamelist -gl)'{-gamelist,-gl}'[list all games]' \
  '-gl-avail[list only available games]' \
  '-rol[rotate game list left]' \
  '-ror[rotate game list right]' \
  '-test[test a game (60 frames then exit)]:gamename:' \
  '(-gameinfo -listinfo -li)'{-gameinfo,-listinfo,-li}'[list info for a game or all games]:gamename:' \
  '(-romcheck -rc)'{-romcheck,-rc}'[check roms are valid]:gamename:' \
  '(-romcheck-full -rcf)'{-romcheck-full,-rcf}'[full romcheck (slow)]:gamename:' \
  '(-joystick -j)'{-joystick,-j}'[joystick type]:type:' \
  '(-limitspeed -l)'{-limitspeed,-l}'[limit emulation speed to 60fps]' \
  '(-nogui -n)'{-nogui,-n}'[disable GUI]' \
  '-cont[enable continuous playing]' \
  '-nocont[disable continuous playing]' \
  '-autoload[enable auto savegame loading]' \
  '-noautoload[disable auto savegame loading]' \
  '(-screenx -sx)'{-screenx,-sx}'[screen width]:width:' \
  '(-screeny -sy)'{-screeny,-sy}'[screen height]:height:' \
  '-geometry[window placement WxH+x+y]:WxH+x+y:' \
  '(-fullscreen -fs)'{-fullscreen,-fs}'[fullscreen on/off]:bool:(0 1)' \
  '-nb[no border]' \
  '-wb[with border]' \
  '(-bpp -depth)'{-bpp,-depth}'[screen colour depth]:n:(8 16 24 32)' \
  '(-rotate -r)'{-rotate,-r}'[rotate display]:angle:' \
  '(-norotate -nor)'{-norotate,-nor}'[no rotation]' \
  '(-flip -f)'{-flip,-f}'[flip mode]:mode:(0 1 2 3)' \
  '(-flipx -fx)'{-flipx,-fx}'[flip X]' \
  '(-flipy -fy)'{-flipy,-fy}'[flip Y]' \
  '(-noflip -nof)'{-noflip,-nof}'[no flip]' \
  '-nc[no curl (disable ROM downloads)]' \
  '-listdsw[list dipswitches for a game]:gamename:' \
  '-region[set region (use -1 for list)]:n:' \
  '(-source_file -lsf)'{-source_file,-lsf}'[list source file]:gamename:' \
  '-verbose[show extra info for romcheck]' \
  '(-video -vm)'{-video,-vm}'[video mode]:mode:(0 1 2)' \
  '-render[renderer (0=DrawPixels 1=Texture)]:n:(0 1)' \
  '-dbuf[double buffer]:n:(0 1 2)' \
  '-shader[shader file]:file:_files' \
  '-filter[opengl filter]:n:(0 1)' \
  '*:game image:_files -g "*.(zip|7z|cue|iso)"' && ret=0
return ret
