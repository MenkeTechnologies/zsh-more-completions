#compdef img2dcm
# Documentation: https://support.dcmtk.org/docs-snapshot/img2dcm.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmdata/apps/img2dcm.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmdata/apps/img2dcm.cc OFCommandLine setup + docs/man/img2dcm.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(-i --input-format)'{-i+,--input-format=}'[input file format (JPEG default, BMP)]:format:(JPEG BMP)' \
  '(-df --dataset-from)'{-df+,--dataset-from=}'[use dataset from DICOM file]:file:_files' \
  '(-dx --dataset-from-xml)'{-dx+,--dataset-from-xml=}'[use dataset from XML file]:file:_files' \
  '(-stf --study-from)'{-stf+,--study-from=}'[read patient/study from DICOM file]:file:_files' \
  '(-sef --series-from)'{-sef+,--series-from=}'[read patient/study/series from DICOM file]:file:_files' \
  '(-ii --instance-inc)'{-ii,--instance-inc}'[increase instance number read from DICOM file]' \
  '(-dp --disable-progr)'{-dp,--disable-progr}'[disable support for progressive JPEG]' \
  '(-de --disable-ext)'{-de,--disable-ext}'[disable support for extended sequential JPEG]' \
  '(-jf --insist-on-jfif)'{-jf,--insist-on-jfif}'[insist on JFIF header]' \
  '(-ka --keep-appn)'{-ka,--keep-appn}'[keep APPn sections (except JFIF)]' \
  '(-rc --remove-com)'{-rc,--remove-com}'[remove COM segment]' \
  '(+Vd --validate-document)'{+Vd,--validate-document}'[validate XML document against DTD]' \
  '(+Vn --check-namespace)'{+Vn,--check-namespace}'[check XML namespace in document root]' \
  '--do-checks[enable attribute validity checking (default)]' \
  '--no-checks[disable attribute validity checking]' \
  '(+i2 --insert-type2)'{+i2,--insert-type2}'[insert missing type 2 attributes (default)]' \
  '(-i2 --no-type2-insert)'{-i2,--no-type2-insert}'[do not insert missing type 2 attributes]' \
  '(+i1 --invent-type1)'{+i1,--invent-type1}'[invent missing type 1 attributes (default)]' \
  '(-i1 --no-type1-invent)'{-i1,--no-type1-invent}'[do not invent missing type 1 attributes]' \
  '(-Ct --transliterate)'{-Ct,--transliterate}'[try to approximate unrepresentable characters]' \
  '(-Cd --discard-illegal)'{-Cd,--discard-illegal}'[discard characters that cannot be represented]' \
  '*'{-k+,--key=}'[add key/attribute (gggg,eeee="str" or path or dict name="str")]:key:' \
  '(-sc --sec-capture)'{-sc,--sec-capture}'[write Secondary Capture SOP class (default)]' \
  '(-nsc --new-sc)'{-nsc,--new-sc}'[write new Secondary Capture SOP classes]' \
  '(-vlp --vl-photo)'{-vlp,--vl-photo}'[write Visible Light Photographic SOP class]' \
  '(-oph --oph-photo)'{-oph,--oph-photo}'[write Ophthalmic Photography SOP classes]' \
  '(+F --write-file)'{+F,--write-file}'[write file format (default)]' \
  '(-F --write-dataset)'{-F,--write-dataset}'[write data set without file meta information]' \
  '(+g= --group-length-recalc)'{+g=,--group-length-recalc}'[recalculate group lengths if present (default)]' \
  '(+g --group-length-create)'{+g,--group-length-create}'[always write with group length elements]' \
  '(-g --group-length-remove)'{-g,--group-length-remove}'[always write without group length elements]' \
  '(+e --length-explicit)'{+e,--length-explicit}'[write with explicit lengths (default)]' \
  '(-e --length-undefined)'{-e,--length-undefined}'[write with undefined lengths]' \
  '(-p --padding-off)'{-p,--padding-off}'[no padding (implicit if --write-dataset)]' \
  '(+p --padding-create)'{+p+,--padding-create=}'[align file/items on byte multiples]:file-pad item-pad:' \
  '*:imgfile-in:_files'
