#compdef goimapnotify
# Documentation: source-direct extraction from upstream
# shackra/goimapnotify main.go `flag.String/.Bool/.Int(...)`
# declarations (Go stdlib flag package, NOT cobra/urfave/viper).
# Reference accessed: 2026-05-30 via gh api.
# shackra goimapnotify R140a — Go reimplementation of the original
# Perl imapnotify by Brandon Long. Subscribes to IMAP IDLE on one
# or more mailbox folders defined in a JSON config and runs a
# user-defined command on new-mail / message-deleted / message-
# moved events. Sister to fdm / msmtp / isync / offlineimap mail
# pipeline tools already covered in the corpus.

_arguments -s -S \
  '-conf=[JSON config file path (default \$XDG_CONFIG_HOME/goimapnotify/goimapnotify.conf)]:file:_files -g "*.(conf|json)"' \
  '-list[list all mailboxes from the configured IMAP host and exit]' \
  '-log-level=[log verbosity level]:level:(error warning warn info information debug)' \
  '-wait=[seconds between IDLE event and execution of scripts (default 1)]:sec:'
