#compdef tcshow
# Documentation: https://man.archlinux.org/search?q=tcshow
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--tc-command[show tc commands]' \
  '--tc-script[generate tc script]' \
  '--debug[debug output]' \
  '--quiet[quiet]' \
  '--debug-query[debug DB query]' \
  '--stacktrace[show stacktrace]' \
  '--color[colorize output]' \
  '--export=[export to path]:file:_files' \
  '--exclude-filter-id[exclude filter id]' \
  '--dump-db=[SQLite dump path]:file:_files' \
  '--ipv6[IPv6 mode]' \
  '--docker[Docker mode]' \
  '*:device:_net_interfaces'
