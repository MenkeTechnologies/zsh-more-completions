#compdef tcshow
# Documentation: https://tcconfig.readthedocs.io/en/latest/pages/usage/tcshow/index.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--tc-command[display tc commands and exit]' \
  '--tc-script[generate shell script file]' \
  '--debug[enable debug output]' \
  '--quiet[suppress execution log]' \
  '--debug-query[debug query printing]' \
  '--stacktrace[print stack trace]' \
  '--color[colorize output]' \
  '--export=[export to path]:file:_files' \
  '--exclude-filter-id[do not display filter_id]' \
  '--dump-db=[dump parsed results to SQLite database]:file:_files' \
  '--ipv6[display IPv6 shaping rules]' \
  '--docker[apply to Docker container]' \
  '*:device:_net_interfaces'
