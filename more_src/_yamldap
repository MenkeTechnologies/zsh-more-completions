#compdef yamldap
# ============================================================================
# _yamldap — zsh completion for yamldap, YAML-backed lightweight LDAP server
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/rvben/yamldap
#   Author     : Ruben J. Jongejan
#   License    : MIT OR Apache-2.0
#   Stars      : 15
#   Language   : Rust
#   Crate      : yamldap v0.1.3   (published on crates.io)
#   Binary     : yamldap          (Cargo.toml [package] name, default bin)
#   Last push  : 2026-05-12
#
# WHAT IT IS
#   yamldap is "a lightweight LDAP server that serves directory data from
#   YAML files".  It implements the LDAP v3 wire protocol on top of the
#   kanidm `ldap3_proto` ASN.1 codec and exposes a directory tree that is
#   loaded from a single YAML file at startup, optionally re-loaded
#   automatically when the file changes on disk (--hot-reload + the `notify`
#   crate's filesystem watcher).  The intended use cases are testing LDAP
#   clients without spinning up OpenLDAP / 389-DS / Active Directory, and
#   small read-mostly internal directories where the schema fits comfortably
#   in a hand-edited YAML file.  Password hashing covers bcrypt / SHA-1 /
#   SHA-256 / SHA-512 (via `bcrypt` and the `sha1` / `sha2` crates), and an
#   `--ad-compat` flag turns on Active Directory compatibility quirks
#   (sAMAccountName attribute aliasing, AD-style search filters).
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/config.rs clap-derive CliArgs)
#   yamldap -f <FILE> [OPTIONS]
#
#   Options:
#     -f, --file <FILE>          Path to YAML directory file  (REQUIRED)
#     -p, --port <PORT>          Port to listen on            [default: 389]
#         --bind-address <ADDR>  Address to bind to           [default: 0.0.0.0]
#         --base-dn <DN>         Override base DN from YAML file
#         --allow-anonymous      Allow anonymous LDAP bind operations
#         --hot-reload           Enable hot-reloading of YAML file changes
#                                via inotify/kqueue/FSEvents (`notify` crate)
#     -v, --verbose              Enable verbose logging (DEBUG level)
#         --log-level <LEVEL>    debug | info | warn | error   [default: info]
#         --ad-compat            Enable Active Directory compatibility mode
#     -h, --help                 Print help
#     -V, --version              Print version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `ldap3_proto = "0.4"` declared in Cargo.toml — the
#   LDAP protocol definitions crate from the kanidm/ldap3 workspace (the
#   canonical Rust LDAP3 implementation maintained by the Kanidm Identity-
#   and-Access-Management project, https://github.com/kanidm/ldap3, 78
#   stars, MPL-2.0).  Paired with the `rasn = "0.18"` ASN.1 codec and
#   `rasn-ldap = "0.18"` LDAP ASN.1 definitions, yamldap implements a full
#   server-side LDAP v3 stack on top of kanidm's protocol crate.
#   Verified via:
#     gh api repos/rvben/yamldap/contents/Cargo.toml
#       → ldap3_proto = "0.4"
#   This entry is the Rust=114 leader bump that OPENS Axis 59
#   (LDAP Directory Service Library), pairing with future Go=go-ldap/ldap
#   and TS-Node=ldapjs poles to close the axis at 1/1/1.
#
#   No completion for `yamldap` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.  Stock zsh
#   ships a generic `_ldap` (for `ldap*` / `ldapsearch` style OpenLDAP
#   client tools) but no `_yamldap`.
# ============================================================================

_yamldap() {
    _arguments -s \
        '(-f --file)'{-f+,--file=}'[path to YAML directory file (REQUIRED)]:yaml file:_files -g "*.(yaml|yml)"' \
        '(-p --port)'{-p+,--port=}'[port to listen on (default 389)]:port:' \
        '--bind-address=[address to bind to (default 0.0.0.0)]:bind addr:_hosts' \
        '--base-dn=[override base DN from YAML file]:base DN:' \
        '--allow-anonymous[allow anonymous LDAP bind operations]' \
        '--hot-reload[enable hot-reloading of YAML file changes]' \
        '(-v --verbose)'{-v,--verbose}'[enable verbose logging (DEBUG)]' \
        '--log-level=[log level (default info)]:level:(debug info warn error)' \
        '--ad-compat[enable Active Directory compatibility mode]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_yamldap "$@"
