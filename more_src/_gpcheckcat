#compdef gpcheckcat
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gpcheckcat.html
# Verify the integrity of the Greenplum Database system catalog tables

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[display help information]' \
  '-A[run on all databases in the installation]' \
  '-B[number of concurrent processes to execute]:parallel_processes' \
  '-C[run cross consistency, foreign key, and ACL tests for a catalog table]:catalog_table' \
  '-g[generate SQL scripts to fix catalog inconsistencies]:dir:_files -/' \
  '-l[list the gpcheckcat tests]' \
  '-O[run only tests that can run in online mode]' \
  '-p[connection port]:port' \
  '-P[database user password]:password' \
  '-R[tests to run (comma-delimited)]:tests' \
  '-s[tests to skip (comma-delimited)]:tests' \
  '-S[shared catalog table testing]:mode:(none only)' \
  '-U[connecting database user]:user' \
  '-v[verbose output with detailed test information]' \
  '*-x[set a server configuration parameter at session level]:param=value' \
  '--skip-leaked-temp-schema[skip cleanup of orphaned temporary schemas]' \
  '*:database:' && ret=0

return ret
