#compdef kpt

# Zsh completion for kpt (Kubernetes package tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'pkg:manage packages'
      'fn:manage functions'
      'live:manage live cluster resources'
      'alpha:alpha commands'
      'version:show version'
      'help:show help for a subcommand'
    )
    _describe -t commands 'kpt subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      pkg)
        local -a pkg_subcmds=(
          'get:fetch a package from a repo'
          'init:initialize a package'
          'update:update a local package'
          'diff:diff a local package against upstream'
          'tree:display package resource structure'
          'cat:print package resources'
        )
        _describe -t commands 'pkg subcommand' pkg_subcmds && ret=0
        ;;
      fn)
        local -a fn_subcmds=(
          'render:render a package'
          'eval:evaluate a function on resources'
          'source:read resources from stdin'
          'sink:write resources to stdout'
        )
        _describe -t commands 'fn subcommand' fn_subcmds && ret=0
        ;;
      live)
        local -a live_subcmds=(
          'init:initialize inventory for live management'
          'apply:apply package resources to cluster'
          'destroy:remove package resources from cluster'
          'status:show status of package resources'
          'migrate:migrate from ConfigMap to ResourceGroup inventory'
        )
        _describe -t commands 'live subcommand' live_subcmds && ret=0
        ;;
      help)
        local -a subcmds=(pkg fn live alpha version)
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
