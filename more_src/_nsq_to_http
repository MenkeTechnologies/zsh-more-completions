#compdef nsq_to_http
# Documentation: https://nsq.io/components/utilities.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-version[print version]' \
  '-topic=[NSQ topic]:topic:' \
  '-channel=[NSQ channel]:channel:' \
  '*-nsqd-tcp-address=[nsqd TCP address (repeatable)]:address:' \
  '*-lookupd-http-address=[lookupd HTTP address (repeatable)]:address:' \
  '-mode=[connection mode]:mode:(round-robin multicast hostpool epsilon-greedy)' \
  '-sample=[percent of messages to send]:percent:' \
  '-status-every=[duration between status updates]:duration:' \
  '-content-type=[Content-Type for HTTP requests]:type:' \
  '*-post=[HTTP endpoint POST URL (repeatable)]:url:' \
  '*-get=[HTTP endpoint GET URL (repeatable)]:url:' \
  '*-header=[HTTP request header (repeatable)]:header:' \
  '-http-client-connect-timeout=[HTTP connect timeout]:duration:' \
  '-http-client-request-timeout=[HTTP request timeout]:duration:' \
  '-max-in-flight=[max in-flight messages]:n:' \
  '-n=[number of concurrent publishers]:n:' \
  '*-consumer-opt=[consumer config option key=value (repeatable)]:opt:' && ret=0

return ret
