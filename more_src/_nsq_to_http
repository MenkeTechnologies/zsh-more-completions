#compdef nsq_to_http
# Documentation: https://man.archlinux.org/search?q=nsq_to_http
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-version[show version]' \
  '*-topic=[NSQ topic (repeatable)]:topic:' \
  '-channel=[NSQ channel]:channel:' \
  '*-nsqd-tcp-address=[nsqd TCP address (repeatable)]:address:' \
  '*-lookupd-http-address=[lookupd HTTP address (repeatable)]:address:' \
  '-mode=[connection mode]:mode:(round-robin multicast hostpool epsilon-greedy)' \
  '-sample=[percent of messages to send]:percent:' \
  '-status-every=[duration to log status]:duration:' \
  '-content-type=[Content-Type for HTTP requests]:type:' \
  '*-post=[HTTP endpoint POST URL (repeatable)]:url:' \
  '*-get=[HTTP endpoint GET URL (repeatable)]:url:' \
  '-http-timeout=[HTTP timeout]:duration:' \
  '-http-timeout-ms=[HTTP timeout (ms)]:n:' \
  '-http-connect-timeout=[HTTP connect timeout]:duration:' \
  '-max-in-flight=[max in-flight messages]:n:' \
  '-throttle-fraction=[throttle messages by fraction]:f:' \
  '-consumer-opt=[consumer config option]:opt:' \
  '-producer-opt=[producer config option]:opt:' \
  '-log-level=[log verbosity]:level:(debug info warn error fatal)' \
  '-log-prefix=[log message prefix]:prefix:' && ret=0

return ret
