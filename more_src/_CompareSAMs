#compdef CompareSAMs
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/CompareSAMs.java
# Picard: compare two SAM/BAM/CRAM files and report differences

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output comparison results file]:file:_files' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' \
  '*:SAM/BAM/CRAM file:_files' && ret=0

return ret
