#compdef koka

# Zsh completion for koka (effect-typed functional language)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-o --output)'{-o,--output}'[set output directory]:directory:_files -/' \
  '--outname[set output name]:name' \
  '(-i --include)'{-i,--include}'[add include directory]:directory:_files -/' \
  '--target[set compilation target]:target:(c js wasm)' \
  '--cc[set C compiler]:compiler:_command_names' \
  '--ccopts[set C compiler options]:options' \
  '--debug[compile in debug mode]' \
  '(-O --optimize)'{-O,--optimize}'[set optimization level]:level:(0 1 2 3)' \
  '--fstdalloc[use standard allocator]' \
  '--fno-trmc[disable tail-recursive modulo cons]' \
  '--fno-reuse[disable reuse analysis]' \
  '--showcore[show core output]' \
  '--showtypesigs[show inferred type signatures]' \
  '--showkindandflavour[show kinds and flavours]' \
  '--core[stop after core generation]' \
  '--library[compile as library]' \
  '--execute[execute after compilation]' \
  '--console[interactive console mode]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]:level:(0 1 2 3)' \
  '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
  '(-l --link)'{-l,--link}'[link with library]:library' \
  '--color[use colored output]:when:(auto always never)' \
  '(-? --help)'{'-?',--help}'[show help]' \
  '*:source file:_files -g "*.kk(N)"' && ret=0

return ret
