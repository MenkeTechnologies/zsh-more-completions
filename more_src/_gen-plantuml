#compdef gen-plantuml
# _gen-plantuml — generate a PlantUML class diagram from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/plantumlgen.py (click).

_gen-plantuml() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.(plantuml|puml|png|svg)"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(plantuml puml png svg)'
        '*'{-c+,--classes=}'[class(es) to emit (repeatable)]:class:'
        '--directory=[output directory (when emitting images)]:dir:_files -/'
        '--kroki-server=[Kroki server URL for rendering]:url:'
        '--dry-run[print PlantUML source without rendering an image]'
        '--preserve-names[keep class / slot names as written]'
        '--normalize-names[normalize names to PlantUML conventions]'
        '--include-enums[render enumerations in the diagram]'
        '--no-include-enums[omit enumerations from the diagram]'
        '--mark-mixins[render mixins distinctly]'
        '--no-mark-mixins[render mixins like regular classes]'
        '--all[render all classes (overrides --classes filtering)]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-plantuml "$@"
