#compdef nix-top
# Documentation: https://github.com/amarshall/nix-top
# show what Nix is currently building, top-style

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --delay)'{-d,--delay}'[delay in seconds between updates (default 0.5)]:seconds:' \
  '(-1 --once)'{-1,--once}'[run once and print a single screen]' && ret=0

return ret
