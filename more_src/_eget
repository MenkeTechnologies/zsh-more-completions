#compdef eget

# Zsh completion for eget (GitHub release binary downloader)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-t --tag)'{-t,--tag}'[tagged release to use instead of latest]:tag' \
  '--pre-release[include pre-releases]' \
  '(-s --system)'{-s,--system}'[target system in OS/arch format]:system' \
  '--to[destination directory or file]:path:_files' \
  '(-f --file)'{-f,--file}'[glob to select file from archive]:pattern' \
  '--asset[glob to select release asset]:pattern' \
  '--sha256[verify SHA-256 checksum]:checksum' \
  '--verify-sha256[verify SHA-256 using checksum file]:checksum file' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-d --download-only)'{-d,--download-only}'[download without extracting]' \
  '--upgrade-only[only download if newer version available]' \
  '(-D --download-all)'{-D,--download-all}'[download all files from release]' \
  '(-k --kill)'{-k,--kill}'[remove eget home directory]' \
  '(-r --remove)'{-r,--remove}'[remove installed target]:target' \
  '(-l --list)'{-l,--list}'[list installed targets]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:repository (user/repo or URL)' && ret=0

return ret
