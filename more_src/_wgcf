#compdef wgcf
# Documentation: https://github.com/ViRb3/wgcf
# Reference accessed: 2026-05-21
# Verified: upstream cmd/*.go (root.go, register, generate, update) at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'register:register new Cloudflare Warp account'
  'generate:generate WireGuard profile'
  'update:update current account (license key, devices)'
  'status:show current device status'
  'trace:print trace info'
  'help:show help'
  'completion:generate shell completion script'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[configuration file]:file:_files -g "*.toml"' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wgcf command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (register)
        _arguments \
          '(-n --name)'{-n+,--name=}'[device name shown in 1.1.1.1 app]:name:' \
          '(-m --model)'{-m+,--model=}'[device model]:model:' \
          '(-k --key)'{-k+,--key=}'[base64 private key]:key:' \
          '--accept-tos[accept Cloudflare Terms of Service non-interactively]' && ret=0 ;;
      (generate)
        _arguments \
          '(-p --profile)'{-p+,--profile=}'[output WireGuard profile file]:file:_files -g "*.conf"' && ret=0 ;;
      (update)
        _arguments \
          '(-n --name)'{-n+,--name=}'[update device name]:name:' \
          '(-l --license-key)'{-l+,--license-key=}'[update device license key]:key:' \
          '*--remove=[remove device by ID]:device id:' \
          '*--deactivate=[deactivate device by ID]:device id:' \
          '*--activate=[activate device by ID]:device id:' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
