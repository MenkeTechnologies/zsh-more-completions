#compdef jack_monitor_client
# Documentation: https://github.com/jackaudio/jack-example-tools/blob/main/tools/monitor_client.c
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above.
# Note: prior file invented -h/-n/-s/--name/--server; the real usage
# is "jack_monitor_client client" — a single positional, no options.

# jack_monitor_client: request port monitoring under JACK
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:client port:' && ret=0
return ret
