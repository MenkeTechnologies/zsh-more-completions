#compdef jack_monitor_client
# Documentation: https://man.archlinux.org/search?q=jack_monitor_client
# Reference accessed: 2026-05-16

# jack_monitor_client: prints connections under JACK
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-n[JACK client name]:name:' \
  '--name=[JACK client name]:name:' \
  '-s[JACK server name]:name:' \
  '--server=[JACK server name]:name:' \
  '*::jack_monitor_client args:_files' && ret=0
return ret
