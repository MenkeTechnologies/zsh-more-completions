#compdef cosutil
# Documentation: https://github.com/huanght1997/cosutil
# cosutil - unofficial command line tool to access Tencent Cloud COS

local ret=1

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-b --bucket)'{-b,--bucket=}'[bucket name]:bucket' \
  '(-r --region)'{-r,--region=}'[region]:region' \
  '(-c --config_path)'{-c,--config_path=}'[config file path]:config:_files' \
  '(-l --log_path)'{-l,--log_path=}'[log file path]:path:_files -/' \
  '--log_size=[max log file size]:size' \
  '--log_backup_count=[number of log backups to keep]:count' \
  '1:command:(config upload download copy move delete list info signurl restore createbucket deletebucket abort probe listparts getbucketacl putbucketacl getobjectacl putobjectacl getbucketversioning putbucketversioning)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $line[1] in
      upload)
        _arguments -s \
          '(-r --recursive)'{-r,--recursive}'[upload recursively when upload directory]' \
          '(-H --headers)'{-H,--headers=}'[specify HTTP headers]:headers' \
          '(-s --sync)'{-s,--sync}'[upload and skip the same file]' \
          '(-f --force)'{-f,--force}'[upload without history breakpoint]' \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' \
          '--include=[specify filter rules, separated by commas]:rules' \
          '--ignore=[specify ignored rules, separated by commas]:rules' \
          '--skipmd5[upload without x-cos-meta-md5]' \
          '--delete[delete objects which exist in COS but not local]' \
          '*:file:_files' && ret=0
        ;;
      download)
        _arguments -s \
          '(-f --force)'{-f,--force}'[force overwrite]' \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' \
          '(-r --recursive)'{-r,--recursive}'[download recursively]' \
          '(-s --sync)'{-s,--sync}'[download and skip the same file]' \
          '(-H --headers)'{-H,--headers=}'[specify HTTP headers]:headers' \
          '--versionId=[object version id]:versionid' \
          '--include=[specify filter rules]:rules' \
          '*:file:_files' && ret=0
        ;;
      copy|move)
        _arguments -s \
          '(-H --headers)'{-H,--headers=}'[specify HTTP headers]:headers' \
          '(-d --directive)'{-d,--directive=}'[metadata directive]:directive:(Copy Replaced)' \
          '(-r --recursive)'{-r,--recursive}'[operate recursively]' \
          '*:path:_files' && ret=0
        ;;
      delete)
        _arguments -s \
          '(-r --recursive)'{-r,--recursive}'[delete recursively]' \
          '--versions[delete all versions]' \
          '--versionId=[object version id]:versionid' \
          '(-f --force)'{-f,--force}'[force delete]' \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' \
          '*:object:_files' && ret=0
        ;;
      list)
        _arguments -s \
          '(-a --all)'{-a,--all}'[list all]' \
          '(-r --recursive)'{-r,--recursive}'[list recursively]' \
          '(-n --num)'{-n,--num=}'[number of entries]:num' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '--human[human readable sizes]' \
          '*:path:_files' && ret=0
        ;;
      info)
        _arguments -s \
          '--human[human readable sizes]' \
          '*:object:_files' && ret=0
        ;;
      signurl)
        _arguments -s \
          '(-t --timeout)'{-t,--timeout=}'[signed url timeout]:seconds' \
          '*:object:_files' && ret=0
        ;;
      restore)
        _arguments -s \
          '(-r --recursive)'{-r,--recursive}'[restore recursively]' \
          '(-d --day)'{-d,--day=}'[number of days kept]:days' \
          '(-t --tier)'{-t,--tier=}'[restore tier]:tier:(Expedited Standard Bulk)' \
          '*:object:_files' && ret=0
        ;;
      deletebucket)
        _arguments -s \
          '(-f --force)'{-f,--force}'[force delete bucket]' && ret=0
        ;;
      probe)
        _arguments -s \
          '(-n --num)'{-n,--num=}'[number of test objects]:num' \
          '(-s --size)'{-s,--size=}'[size of test objects]:size' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
