#compdef rust-objcopy
# Documentation: https://github.com/rust-embedded/cargo-binutils
# Reference accessed: 2026-05-16
# Verified: cargo-binutils wrapper invoking llvm-objcopy from Rust
# toolchain sysroot. Accepts the same flags as llvm-objcopy.
# Removed from prior file: bogus man.archlinux.org search URL.

# rust-objcopy: cargo-binutils wrapper for llvm-objcopy
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-O[output format]:format:' \
  '-I[input format]:format:' \
  '--strip-all[remove all symbols]' \
  '--strip-debug[remove debug info]' \
  '*:object file:_files' && ret=0
return ret
