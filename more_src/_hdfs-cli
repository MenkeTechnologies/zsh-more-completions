#compdef hdfs
# Documentation: https://man.archlinux.org/search?q=hdfs
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'classpath:print classpath'
  'dfs:run filesystem command'
  'envvars:print env vars'
  'fetchdt:fetch delegation token'
  'fsck:run filesystem check'
  'getconf:get config'
  'groups:get groups'
  'lsSnapshottableDir:list snapshottable dirs'
  'snapshotDiff:diff between snapshots'
  'jmxget:JMX get'
  'oev:offline edits viewer'
  'oiv:offline image viewer'
  'oiv_legacy:legacy oiv'
  'datanode:run a datanode'
  'dfsadmin:DFS admin'
  'haadmin:HA admin'
  'journalnode:run JournalNode'
  'mover:run mover'
  'namenode:run NameNode'
  'nfs3:run NFS3 gateway'
  'portmap:run portmap'
  'secondarynamenode:run secondary NN'
  'storagepolicies:storage policies'
  'zkfc:ZKFailoverController'
  'cacheadmin:cache admin'
  'crypto:crypto admin'
  'erasurecode:erasure coding'
  'debug:debug commands'
  'diskbalancer:disk balancer'
  'router:router commands'
  'sps:storage policy satisfier'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*--config=[config dir]:dir:_files -/' \
  '*--loglevel=[log level]:l:(FATAL ERROR WARN INFO DEBUG TRACE)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'hdfs command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (dfs)
        _arguments \
          '*: :_values "subcommand" -appendToFile -cat -checksum -chgrp -chmod -chown -copyFromLocal -copyToLocal -count -cp -createSnapshot -deleteSnapshot -df -du -dus -expunge -find -get -getfacl -getfattr -getmerge -head -help -ls -lsr -mkdir -moveFromLocal -moveToLocal -mv -put -renameSnapshot -rm -rmdir -rmr -setfacl -setfattr -setrep -stat -tail -test -text -touch -touchz -truncate -usage' && ret=0 ;;
      (fsck)
        _arguments \
          '-list-corruptfileblocks[list corrupt blocks]' \
          '-move[move corrupt to lost+found]' \
          '-delete[delete corrupt]' \
          '-files[list files]' \
          '-blocks[list blocks]' \
          '-locations[block locations]' \
          '-racks[block locations + racks]' \
          '-storagepolicies[storage policies]' \
          '-includeSnapshots[include snapshots]' \
          '-openforwrite[show open for write]' \
          '-showprogress[show progress]' \
          '-blockId+[block id]:id:' \
          '-replicaDetails[show replica details]' \
          '*: :' && ret=0 ;;
      (dfsadmin)
        _arguments \
          '*: :_values "subcommand" -saveNamespace -rollEdits -finalizeUpgrade -refreshNodes -setQuota -clrQuota -setSpaceQuota -clrSpaceQuota -setStoragePolicy -getStoragePolicy -unsetStoragePolicy -listOpenFiles -refreshUserToGroupsMappings -refreshSuperUserGroupsConfiguration -refreshCallQueue -refresh -reconfig -fetchImage -setBalancerBandwidth -getBalancerBandwidth -triggerBlockReport -listOpenFiles -allowSnapshot -disallowSnapshot -metasave -report -safemode -getDatanodeInfo -evictWriters -shutdownDatanode -refreshServiceAcl -setStoragePolicy' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
