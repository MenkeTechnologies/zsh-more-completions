#compdef taze
# Documentation: https://github.com/antfu-collective/taze
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# taze: a modern cli tool that keeps dependencies fresh.
# Mode is a positional argument (default | major | minor | patch | next | newest).

local curcontext="$curcontext" state line ret=1
local -a modes
modes=(
  'default:respect specified version ranges (recommended)'
  'major:check all updates including breaking changes'
  'minor:bump within same major'
  'patch:bump patch only'
  'next:next pre-release'
  'newest:newest published version'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-r --recursive)'{-r,--recursive}'[scan subdirectories for package.json]' \
  '(-l --include-locked)'{-l,--include-locked}'[include locked deps (no ^ or ~)]' \
  '--include=[filter packages by name/regex (comma-separated)]:pattern:' \
  '--exclude=[exclude packages by name/regex (comma-separated)]:pattern:' \
  '--peer[include peerDependencies]' \
  '--maturity-period=[only update to versions older than N days]:days:' \
  '--force[fetch latest info without caching]' \
  '--write[write updated versions to package.json]' \
  '--install[run package manager install after writing]' \
  '1: :->mode' \
  '*::file:_files -g "*.json"' && ret=0

case $state in
  (mode) _describe -t modes 'taze mode' modes && ret=0 ;;
esac

return ret
