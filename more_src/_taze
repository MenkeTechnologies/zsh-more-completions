#compdef taze

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-w[write updated versions to package.json]' \
  '--write[write updated versions to package.json]' \
  '-r[check for all packages recursively]' \
  '--recursive[check for all packages recursively]' \
  '-i[interactive mode to select updates]' \
  '--interactive[interactive mode to select updates]' \
  '-l[include locked dependencies]' \
  '--include-locked[include locked dependencies]' \
  '-f+[filter packages by name]:pattern' \
  '--filter=[filter packages by name]:pattern' \
  '-x+[exclude packages by name]:pattern' \
  '--exclude=[exclude packages by name]:pattern' \
  '-P+[filter by dependency type]:type:(dependencies devDependencies optionalDependencies peerDependencies)' \
  '--dep=[filter by dependency type]:type:(dependencies devDependencies optionalDependencies peerDependencies)' \
  '-m+[version range mode]:mode:(default major minor patch latest newest)' \
  '--mode=[version range mode]:mode:(default major minor patch latest newest)' \
  '--ignore-paths=[paths to ignore]:paths' \
  '--no-install[skip install after writing]' \
  '-g[check global packages]' \
  '--global[check global packages]' \
  '-C+[change directory]:directory:_directories' \
  '*:package.json:_files -g "*.json"' && ret=0

return ret
