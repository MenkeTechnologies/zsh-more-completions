#compdef bmputil bmputil-cli
# Documentation: https://github.com/blackmagic-debug/bmputil/blob/main/README.md
# Black Magic Probe management and firmware flashing utility

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --serial --serial-number)'{-s,--serial,--serial-number}'=[match probe by serial number]:serial' \
  '--index=[select probe by index]:index' \
  '(-p --port)'{-p,--port}'=[match probe by USB port]:port' \
  '1: :((probe\:"manage attached probes" target\:"target operations" server\:"GDB server" debug\:"debug commands" complete\:"shell completions"))' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      probe)
        _arguments -s \
          '1: :((info\:"show probe information" update\:"update firmware" switch\:"switch firmware variant" reboot\:"reboot the probe"))' \
          '--list-targets[list available targets]' \
          '--allow-dangerous-options[enable dangerous options]' \
          '--override-firmware-type=[override firmware type]:type' \
          '(-f --force)'{-f,--force}'[force update even if up to date]' \
          '--use-rc[allow release-candidate firmware]' \
          '--dfu[reboot into DFU bootloader]' \
          '--repeat[repeat the operation]' && ret=0
        ;;
      target)
        _arguments -s '1: :((power\:"control target power"))' && ret=0
        ;;
      complete)
        _arguments -s '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
