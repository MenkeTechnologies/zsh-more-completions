#compdef srec_cat

# srec_cat: SRecord concatenate/manipulate (S-record/IHX)
# Documentation: https://srecord.sourceforge.net/man/man1/srec_cat.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-v[verbose]' \
  '-o[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '-Output_Format=[output format]:fmt:(motorola intel binary ascii_hex bash brokered_motorola coe coff_array c_array dec_binary elf emon52 fairchild fast_load fastload fluke formatted_binary forth four_packed_code idt intel intel_hex intel16 lattice memory_initialization_file mif mips_flash mos_technology mos_technology_hex msbin needham_hex os65v os65v_hex prom prom_hex ppc_lh ppx ppb signetics spasm tektronix tektronix_extended ti_tagged ti_tagged_16 ti_txt vhdl vmem wilson)' \
  '-Output_Block_Size=[output block size]:n:' \
  '-Output_Block_Size_Maximum=[max block size]:n:' \
  '-Output_Constant=[fill constant]:hex:' \
  '-fill[fill empty regions]' \
  '-pad[pad with zero]' \
  '-crc16-bigendian[append CRC16 BE]' \
  '-crc16-littleendian[append CRC16 LE]' \
  '-crc32-bigendian[append CRC32 BE]' \
  '-crc32-littleendian[append CRC32 LE]' \
  '-Sequence[reorder records by address]' \
  '-Skip_Holes[skip holes]' \
  '-Stm32[stm32 specific]' \
  '*:input file:_files' && ret=0
return ret
