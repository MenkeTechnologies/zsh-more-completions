#compdef cargo-update
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-update.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for the built-in `cargo update` subcommand.

_arguments -s -S \
  '--recursive[force update dependencies of given spec]' \
  '--precise=[set dependency to exact version (or git rev)]:version:' \
  '(-w --workspace)'{-w,--workspace}'[only update workspace members]' \
  '--dry-run[do not write the lockfile]' \
  '--breaking[update to latest SemVer-breaking version (nightly, -Z unstable-options)]' \
  '--manifest-path=[Cargo.toml]:file:_files -g "*.toml"' \
  '--ignore-rust-version[ignore rust-version]' \
  '*'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress cargo log messages]' \
  '--color=[coloring]:when:(auto always never)' \
  '--config=[override Cargo config value]:key=value or path:' \
  '--frozen[require Cargo.lock and cache up to date]' \
  '--locked[require Cargo.lock up to date]' \
  '--offline[run without network]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:spec:'
