#compdef cargo-update

# Zsh completion for cargo update

_arguments -s -S \
  '(-p --package)'{-p+,--package=}'[package to update]:package:' \
  '--aggressive[force updating all dependencies of given package]' \
  '--precise=[update a single dependency to exactly the specified version]:version:' \
  '--workspace[only update workspace members]' \
  '--dry-run[do not actually write the lockfile]' \
  '--manifest-path=[path to Cargo.toml]:manifest path:_files -g "*.toml"' \
  '(-v --verbose)'{-v,--verbose}'[use verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[require Cargo.lock and cache are up to date]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without accessing the network]' \
  '(-h --help)'{-h,--help}'[show help]'
