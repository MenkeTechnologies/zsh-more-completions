#compdef avdmanager-cli
# _avdmanager-cli — Android avdmanager CLI alias for AVD lifecycle (Google AOSP, Java); custom argparse
# upstream: https://android.googlesource.com/platform/sdk/

_avdmanager-cli() {
    local -a sub=(
        'create:create AVD/device'
        'delete:delete AVD/device'
        'move:move AVD/device'
        'list:list AVDs/devices/targets'
        'rename:rename AVD'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--silent[silent]' \
        '-s[silent]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--clear-cache[clear cache]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'avdmanager subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '1:object:(avd device project test-project lib-project uitest-project)' \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--package=+[system image package]:str:' \
                    '-k+[system image package]:str:' \
                    '--device=+[device profile]:str:' \
                    '-d+[device profile]:str:' \
                    '--path=+[path]:dir:_files -/' \
                    '-p+[path]:dir:_files -/' \
                    '--sdcard=+[sdcard size or img]:str:' \
                    '-c+[sdcard size or img]:str:' \
                    '--force[force]' \
                    '-f[force]' \
                    '--abi=+[abi]:abi:(armeabi-v7a arm64-v8a x86 x86_64)' \
                    '-b+[abi]:abi:(armeabi-v7a arm64-v8a x86 x86_64)' \
                    '--skin=+[skin]:str:' \
                    '-s+[skin]:str:' \
                    '--tag=+[tag]:str:' \
                    '-g+[tag]:str:' ;;
                delete) _arguments \
                    '1:object:(avd device)' \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' ;;
                move) _arguments \
                    '1:object:(avd device)' \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--rename=+[new name]:str:' \
                    '-r+[new name]:str:' \
                    '--path=+[new path]:dir:_files -/' \
                    '-p+[new path]:dir:_files -/' ;;
                rename) _arguments \
                    '1:old-name:' \
                    '2:new-name:' ;;
                list) _arguments \
                    '1:object:(avd target device)' \
                    '--compact[compact output]' \
                    '-c[compact output]' \
                    '--null[null delimited]' \
                    '-0[null delimited]' ;;
            esac
            ;;
    esac
}

_avdmanager-cli "$@"
