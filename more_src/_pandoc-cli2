#compdef pandoc-cli2
# Documentation: https://man.archlinux.org/search?q=pandoc-cli2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --from -r --read)'{-f+,--from=,-r+,--read=}'[input format]:f:(beamer biblatex bibtex bits commonmark commonmark_x context creole csljson csv djot docbook docbook4 docbook5 docx dokuwiki endnotexml epub epub2 epub3 fb2 gfm haddock html html4 html5 ipynb jats jats_archiving jats_articleauthoring jats_publishing jira json latex man markdown markdown_github markdown_mmd markdown_phpextra markdown_strict mdoc mediawiki muse native odt opml org pod ris rst rtf t2t textile tikiwiki tsv twiki typst vimwiki)' \
  '(-t --to -w --write)'{-t+,--to=,-w+,--write=}'[output format]:t:(asciidoc asciidoc_legacy asciidoctor beamer biblatex bibtex chunkedhtml commonmark commonmark_x context csljson djot docbook docbook4 docbook5 docx dokuwiki dzslides epub epub2 epub3 fb2 gfm haddock html html4 html5 icml ipynb jats jats_archiving jats_articleauthoring jats_publishing jira json latex man markdown markdown_github markdown_mmd markdown_phpextra markdown_strict markua mediawiki ms muse native odt opendocument opml org pdf plain pod pptx revealjs rst rtf s5 slideous slidy tei texinfo textile typst xwiki zimwiki)' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-d --defaults)*'{-d+,--defaults=}'[defaults file]:file:_files -g "*.yaml *.yml"' \
  '(--data-dir)--data-dir=[user data dir]:dir:_files -/' \
  '--bash-completion[print bash completion]' \
  '--list-input-formats[list input formats]' \
  '--list-output-formats[list output formats]' \
  '--list-extensions=[list extensions for format]:f:' \
  '--list-highlight-languages[list highlight langs]' \
  '--list-highlight-styles[list highlight styles]' \
  '(-S --shift-heading-level-by)'{-S+,--shift-heading-level-by=}'[shift heading level]:n:' \
  '--base-header-level=[base header level]:n:' \
  '--strip-empty-paragraphs[strip empty paragraphs]' \
  '--indented-code-classes=[csv]:list:' \
  '--default-image-extension=[ext]:e:' \
  '--file-scope[per-file scope]' \
  '(-F --filter)*'{-F+,--filter=}'[filter program]:file:_files' \
  '(-L --lua-filter)*'{-L+,--lua-filter=}'[lua filter]:file:_files -g "*.lua"' \
  '*-M+[k=v meta]:v:' \
  '*--metadata=[k=v meta]:v:' \
  '*--metadata-file=[meta file]:file:_files' \
  '--preserve-tabs[preserve tabs]' \
  '--tab-stop=[tab stop]:n:' \
  '(-s --standalone)'{-s,--standalone}'[standalone]' \
  '--template=[template]:file:_files' \
  '(-V --variable)*'{-V+,--variable=}'[k=v var]:v:' \
  '(-D --print-default-template)'{-D+,--print-default-template=}'[print default template]:f:' \
  '--print-default-data-file=[print default data file]:file:_files' \
  '--print-highlight-style=[print style]:s:' \
  '--no-highlight[no highlight]' \
  '--highlight-style=[style]:s:' \
  '--syntax-definition=[syntax def]:file:_files -g "*.xml"' \
  '(-H --include-in-header)*'{-H+,--include-in-header=}'[in-header file]:file:_files' \
  '(-B --include-before-body)*'{-B+,--include-before-body=}'[before body]:file:_files' \
  '(-A --include-after-body)*'{-A+,--include-after-body=}'[after body]:file:_files' \
  '--resource-path=[resource paths csv]:list:_files -/' \
  '--request-header=[k=v header]:h:' \
  '--no-check-certificate[no cert verify]' \
  '--abbreviations=[file]:file:_files' \
  '--dpi=[dpi]:n:' \
  '--eol=[end-of-line]:e:(crlf lf native)' \
  '--wrap=[wrap]:m:(auto none preserve)' \
  '--columns=[width]:n:' \
  '--toc[table of contents]' \
  '--table-of-contents[TOC]' \
  '--toc-depth=[TOC depth]:n:' \
  '--no-strip-comments[no strip comments]' \
  '--strip-comments[strip comments]' \
  '--reference-links[reference-style links]' \
  '--reference-location=[ref location]:l:(block section document)' \
  '--top-level-division=[level]:l:(default section chapter part)' \
  '(-N --number-sections)'{-N,--number-sections}'[number sections]' \
  '--number-offset=[csv]:list:' \
  '--listings[use lstlistings]' \
  '(-i --incremental)'{-i,--incremental}'[incremental display]' \
  '--slide-level=[level]:n:' \
  '--section-divs[wrap sections in divs]' \
  '--email-obfuscation=[obfuscation]:m:(none javascript references)' \
  '--id-prefix=[prefix]:p:' \
  '(-T --title-prefix)'{-T+,--title-prefix=}'[title prefix]:p:' \
  '(-c --css)*'{-c+,--css=}'[css URL]:url:' \
  '--reference-doc=[reference doc]:file:_files' \
  '--epub-cover-image=[cover image]:file:_files' \
  '--epub-title-page=[title page]:b:(true false)' \
  '--epub-metadata=[metadata]:file:_files' \
  '--epub-embed-font=[font]:file:_files' \
  '--split-level=[split level]:n:' \
  '--epub-chapter-level=[chapter level]:n:' \
  '--epub-subdirectory=[subdir]:s:' \
  '--ipynb-output=[ipynb output]:m:(all best none)' \
  '--pdf-engine=[engine]:e:(pdflatex lualatex xelatex tectonic latexmk wkhtmltopdf weasyprint prince context pdfroff typst groff)' \
  '--pdf-engine-opt=[engine opt]:o:' \
  '(-C --citeproc)'{-C,--citeproc}'[run citeproc]' \
  '--bibliography=[bib file]:file:_files' \
  '--csl=[csl file]:file:_files -g "*.csl"' \
  '--citation-abbreviations=[file]:file:_files' \
  '--natbib[use natbib]' \
  '--biblatex[use biblatex]' \
  '(-m --latexmathml)*-m+[katex]:b:(true false)' \
  '--mathjax=[mathjax URL]:url:' \
  '--mathml[use mathml]' \
  '--katex=[katex URL]:url:' \
  '--gladtex[use gladtex]' \
  '--webtex=[webtex URL]:url:' \
  '--trace[trace]' \
  '--dump-args[dump args]' \
  '--ignore-args[ignore positional args]' \
  '--verbose[verbose]' \
  '--quiet[quiet]' \
  '--fail-if-warnings[fail on warnings]' \
  '--log=[log file]:file:_files' \
  '*: :_files' && ret=0

return ret
