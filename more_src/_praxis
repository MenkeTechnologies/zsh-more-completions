_praxis() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_praxis_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments '::project name:' && ret=0 ;;
                intent)
                    _arguments \
                        '1:intent subcommand:(create update validate list check)' \
                        '*::arg:->intent_args'
                    case $state in
                        intent_args)
                            case $words[1] in
                                create)
                                    _arguments '1:intent description:' && ret=0 ;;
                                validate)
                                    _arguments '1:intent ID:' && ret=0 ;;
                                update|list|check)
                                    _arguments '*: :' && ret=0 ;;
                            esac ;;
                    esac ;;
                spec)
                    _arguments \
                        '1:spec subcommand:(derive refine validate lock list check delete archive apply)' \
                        '*::arg:->spec_args'
                    case $state in
                        spec_args)
                            case $words[1] in
                                derive|check)
                                    _arguments \
                                        '--from-intent=[intent ID to derive from]:intent-id:' \
                                        '*: :' && ret=0 ;;
                                validate|delete|archive|apply)
                                    _arguments '1:spec ID:' && ret=0 ;;
                                refine|lock|list)
                                    _arguments '*: :' && ret=0 ;;
                            esac ;;
                    esac ;;
                agent)
                    _arguments \
                        '1:agent subcommand:(broker run ping ask)' \
                        '*::arg:->agent_args'
                    case $state in
                        agent_args)
                            case $words[1] in
                                broker)
                                    _arguments \
                                        '--port=[MQTT broker port]:port:' && ret=0 ;;
                                ask)
                                    _arguments '1:prompt:' && ret=0 ;;
                                run|ping)
                                    _arguments '*: :' && ret=0 ;;
                            esac ;;
                    esac ;;
                model)
                    _arguments '--intent-id=[target intent ID]:id:' && ret=0 ;;
                analyze)
                    _arguments \
                        '1:analyze subcommand:(impact intent drift)' \
                        '*: :' && ret=0 ;;
                integration)
                    _arguments \
                        '1:integration subcommand:(commands generate-slash-commands)' \
                        '*: :' && ret=0 ;;
                tool)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_praxis_commands] )) ||
_praxis_commands() {
    local -a commands
    commands=(
        'init:initialize a new project to be used with Praxis'
        'intent:manage intents (the WHY)'
        'model:generate or update the intent model'
        'spec:manage specs (the WHAT)'
        'agent:MQTT-backed agent surface (broker/run/ping/ask)'
        'analyze:analysis commands (impact/intent/drift)'
        'integration:editor / IDE integration (slash-commands)'
        'tool:tool surface'
    )
    _describe -t commands 'praxis command' commands
}

_praxis "$@"
