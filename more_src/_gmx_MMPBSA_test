#compdef gmx_MMPBSA_test
# Documentation: https://valdes-tresanco-ms.github.io/gmx_MMPBSA/dev/examples/gmx_MMPBSA_test/
# Download and run the gmx_MMPBSA validation test suite

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-t[test level(s) to run: 0 all, 1 minimal, 2 fast, or system numbers 3-18]:level' \
  '(-f --folder)'{-f,--folder}'[folder to store all data]:folder:_files -/' \
  '(-r --reuse)'{-r,--reuse}'[reuse existing test folder]' \
  '(-ng --nogui)'{-ng,--nogui}'[do not open gmx_MMPBSA_ana afterwards]' \
  '(-n --num_processors)'{-n,--num_processors}'[CPU cores per calculation via MPI]:n' && ret=0

return ret
