#compdef ambassador-cli ambassador edgectl
# _ambassador-cli — Datawire Ambassador Labs ambassador-cli CLI command-line frontend to the Ambassador Emissary-ingress API Gateway and Edge Stack Envoy-based Kubernetes-native API-gateway managing Mapping AuthService RateLimitService TLSContext Host Module-Resource configuration deploy edge-control auth-control diagnostics observability-plugin (Datawire team, Go); cobra
# upstream: https://www.getambassador.io/

_ambassador-cli() {
    local -a sub=(
        'install:install Ambassador'
        'uninstall:uninstall Ambassador'
        'login:authenticate to Ambassador Cloud'
        'logout:log out'
        'status:show installation status'
        'config:configuration'
        'connect:connect to Ambassador Cloud'
        'disconnect:disconnect from Ambassador Cloud'
        'edge:edge control'
        'service:service connect'
        'cluster:cluster management'
        'plugin:plugin operations'
        'mapping:mapping operations'
        'host:host operations'
        'tls:TLS context operations'
        'ratelimit:rate limit service'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '-o+[output]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ambassador subcommand' sub ;;
        args)
            case $words[1] in
                mapping|host|tls|ratelimit) _arguments '1:op:(list get create update delete)' '*:name:' ;;
            esac
            ;;
    esac
}

_ambassador-cli "$@"
