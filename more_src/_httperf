#compdef httperf

# Zsh completion for httperf - HTTP performance measurement tool

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--server[target server hostname]:hostname:_hosts' \
  '--port[target server port]:port' \
  '--uri[target URI]:URI' \
  '--ssl[use SSL/TLS]' \
  '--ssl-ciphers[SSL cipher list]:ciphers' \
  '--ssl-no-reuse[do not reuse SSL sessions]' \
  '--num-conns[total connections to create]:number' \
  '--num-calls[number of calls per connection]:number' \
  '--rate[connection creation rate]:rate' \
  '--timeout[inactivity timeout]:seconds' \
  '--think-timeout[think time for sessions]:seconds' \
  '--burst-length[burst length]:length' \
  '--hog[use as many TCP ports as needed]' \
  '--client[client ID/total]:id/N' \
  '--close-with-reset[close connections with RST]' \
  '--method[HTTP method]:method:(GET POST PUT DELETE HEAD OPTIONS TRACE PATCH)' \
  '--add-header[add header]:header' \
  '--print-reply[print server replies]:mode' \
  '--print-request[print requests]:mode' \
  '--max-connections[max concurrent connections]:number' \
  '--max-piped-calls[max pipelined calls]:number' \
  '--period[inter-arrival period]:period' \
  '--recv-buffer[receive buffer size]:bytes' \
  '--send-buffer[send buffer size]:bytes' \
  '--session-cookies[enable session cookies]' \
  '--verbose[be verbose]' \
  '--wlog[replay log file]:y/n,file:_files' \
  '--wsess[session specification]:num,num,think' \
  '--wsesslog[session log]:num,think,file:_files' \
  '--wset[working set]:num,think'
