#compdef audit2rbac
# Documentation: https://github.com/liggitt/audit2rbac
# Autogenerate RBAC policies based on Kubernetes audit logs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --filename)'{-f,--filename}'=[process audit log from file or URL]:audit log:_files' \
  '--user=[generate policies for the specified user]:user:' \
  '--serviceaccount=[generate policies for the specified service account (namespace:name)]:serviceaccount:' \
  '(-o --output)'{-o,--output}'=[write generated policies to file]:output:_files' \
  '--generate-name=[name to use for generated objects]:name:' \
  '--generate-labels=[labels to add to generated objects]:labels:' \
  '--generate-annotations=[annotations to add to generated objects]:annotations:' \
  '--context=[the name of the kubeconfig context to use]:context:' \
  '--version[print version information]' \
  '*::arg:_files' && ret=0

return ret
