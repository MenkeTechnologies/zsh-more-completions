#compdef obspy-print
# ObsPy: print information about waveform files

local ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --format)'{-f,--format}'+[waveform format (slightly faster if specified)]:format' \
  '(-n --no-merge)'{-n,--no-merge}'[switch off cleanup merge]' \
  '--no-sorting[switch off sorting of traces]' \
  '(-g --print-gaps)'{-g,--print-gaps}'[switch on printing of gap information]' \
  '*:files:_files' && ret=0

return ret
