#compdef alacritty
# _alacritty-bin — Alacritty GPU-accelerated cross-platform terminal (Joe Wilm, Rust); fast no-frills terminal
# upstream: https://github.com/alacritty/alacritty

_alacritty-bin() {
    local -a sub=(
        'msg:send a message to running instance'
        'migrate:migrate config to new format'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-T --title)'{-T,--title}'+[window title]:title:' \
        '--class+[wm class]:str:' \
        '--name+[wm name]:str:' \
        '--config-file+[config file]:file:_files -g "*.toml"' \
        '--working-directory+[cwd]:dir:_files -/' \
        '--print-events[print parsed events]' \
        '--ref-test[ref test mode]' \
        '--hold[hold after exit]' \
        '(-o --option)'{-o,--option}'+[KEY=value]:str:' \
        '(-e --command)'{-e,--command}'+[command]:cmd:_command_names -e' \
        '--socket+[control socket]:file:_files' \
        '--embed+[embed into window id]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'alacritty subcommand' sub ;;
        args)
            case $words[1] in
                msg) _arguments \
                    '(-s --socket)'{-s,--socket}'+[socket]:file:_files' \
                    '1:msg cmd:(create-window config)' \
                    '*:args:' ;;
            esac
            ;;
    esac
}

_alacritty-bin "$@"
