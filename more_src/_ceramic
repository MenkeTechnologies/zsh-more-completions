#compdef ceramic
# Decentralized data network CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'daemon:manage the Ceramic daemon'
      'config:manage configuration'
      'did:manage DIDs'
      'pin:manage pinned streams'
      'stream:interact with streams'
      'commits:show stream commits'
      'create:create a new document'
      'show:show a document'
      'state:show stream state'
      'update:update a document'
    )
    _describe -t commands 'ceramic command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
