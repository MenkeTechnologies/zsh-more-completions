#compdef watchman-cli watchman
# _watchman-cli — Meta Watchman file watching service CLI alias (facebook team, C++); custom argparse
# upstream: https://github.com/facebook/watchman

_watchman-cli() {
    local -a sub=(
        'clock:show clock for a root'
        'debug-ageout:debug ageout'
        'debug-contenthash:debug contenthash'
        'debug-drop-privs:drop privileges'
        'debug-poison:debug poison'
        'debug-recrawl:debug recrawl'
        'debug-set-subscriptions-paused:debug pause subscriptions'
        'debug-status:debug status'
        'debug-symlink-target-cache:debug symlink target cache'
        'debug-watcher-info:debug watcher info'
        'debug-watcher-info-clear:debug watcher info clear'
        'find:find files'
        'flush-subscriptions:flush subscriptions'
        'get-config:get config'
        'get-sockname:get socket name'
        'help:show help'
        'list-capabilities:list capabilities'
        'log:log message'
        'log-level:set log level'
        'pid:show pid'
        'query:run query'
        'shutdown-server:shutdown server'
        'since:show changes since'
        'state-enter:state enter'
        'state-leave:state leave'
        'subscribe:subscribe to events'
        'trigger:add trigger'
        'trigger-del:delete trigger'
        'trigger-list:list triggers'
        'unsubscribe:remove subscription'
        'version:show version'
        'watch:watch a root'
        'watch-del:remove watch'
        'watch-del-all:remove all watches'
        'watch-list:list watches'
        'watch-project:watch project'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--inetd[inetd mode]' \
        '--no-save-state[no save state]' \
        '--statefile=+[file]:file:_files' \
        '--no-spawn[no spawn]' \
        '--no-local[no local]' \
        '-U+[unix socket path]:file:_files' \
        '--unix-listener-path=+[unix socket]:file:_files' \
        '--tcp-listener-port=+[port]:port:' \
        '--tcp-listener-enable=+[bool]:b:(true false)' \
        '--logfile=+[file]:file:_files' \
        '-o+[file]:file:_files' \
        '--log-level=+[level]:n:' \
        '-c+[level]:n:' \
        '-f[run in foreground]' \
        '--foreground[run in foreground]' \
        '-p+[persistent]:str:' \
        '--persistent[persistent]' \
        '-s+[server-encoding]:s:(json bser bser-v2)' \
        '--server-encoding=+[encoding]:s:(json bser bser-v2)' \
        '-S+[sock-name]:str:' \
        '--sockname=+[sock-name]:str:' \
        '-n+[name-resolver]:str:' \
        '--no-pretty[no pretty]' \
        '--json-command[json command]' \
        '-j[json command]' \
        '--output-encoding=+[encoding]:e:(json bser bser-v2 pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'watchman subcommand' sub ;;
        args)
            case $words[1] in
                watch|watch-project|watch-del|since|find|query|subscribe|trigger|clock|state-enter|state-leave) _arguments '1:path:_files -/' '*:args:' ;;
            esac
            ;;
    esac
}

_watchman-cli "$@"
