#compdef influx_tsm
# Documentation: https://github.com/influxdata/influx_tsm
# Convert old b1 and bz1 InfluxDB time series data to TSM format

local ret=1

_arguments -s -S \
  '-dbs=[comma-delimited list of databases to convert (default: all)]:databases' \
  '-parallel[perform parallel conversion (up to GOMAXPROCS shards at once)]' \
  '-nobackup[disable database backups (not recommended)]' \
  '-backup=[location to back up the current databases]:backup dir:_files -/' \
  '-debug=[enable http debugging endpoints on the given address]:address' \
  '-interval=[how often status updates are printed]:duration' \
  '-y[do not ask, just convert]' \
  '-profile=[CPU profile location]:file:_files' \
  '*:data directory:_files -/' && ret=0

return ret
