#compdef codis-dashboard
# Documentation: https://github.com/CodisLabs/codis/blob/master/cmd/dashboard/main.go
# Codis dashboard — cluster coordinator for the Codis Redis solution

local ret=1

_arguments -s -S \
  '--ncpu=[set runtime.GOMAXPROCS to N]:n:' \
  '(-c --config)'{-c,--config=}'[run with the specific configuration]:file:_files -g "*.toml"' \
  '(-l --log)'{-l,--log=}'[path/name of daily rotated log file]:file:_files' \
  '--log-level=[set the log level]:level:(INFO WARN DEBUG ERROR)' \
  '--host-admin=[admin address to advertise]:addr:' \
  '--pidfile=[write pid to this file]:file:_files' \
  '--zookeeper=[ZooKeeper address for coordination]:addr:' \
  '--etcd=[etcd address for coordination]:addr:' \
  '--filesystem=[filesystem root for coordination]:root:_files -/' \
  '--product_name=[product name]:name:' \
  '--product_auth=[product auth]:auth:' \
  '--remove-lock[remove the coordinator lock and exit]' \
  '--default-config[print the default configuration and exit]' \
  '--version[show version and exit]' && ret=0

return ret
