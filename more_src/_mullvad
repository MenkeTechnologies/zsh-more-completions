#compdef mullvad

# Zsh completion for mullvad VPN CLI

_mullvad() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands=(
        'account:manage Mullvad account'
        'relay:manage relay and tunnel constraints'
        'connect:connect to a VPN tunnel'
        'disconnect:disconnect from the VPN tunnel'
        'reconnect:reconnect to the VPN tunnel'
        'tunnel:manage tunnel specific options'
        'dns:manage DNS options'
        'lan:manage local network sharing settings'
        'obfuscation:manage obfuscation settings'
        'bridge:manage bridge settings'
        'status:view tunnel state'
        'version:show the current version'
        'auto-connect:manage auto-connect setting'
        'lockdown-mode:manage lockdown mode (block when disconnected)'
        'custom-dns:configure custom DNS servers'
        'split-tunnel:manage split tunneling'
    )

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'mullvad command' commands
            ;;
        args)
            case $words[1] in
                account)
                    local -a account_commands=(
                        'get:get account information'
                        'login:log in to a Mullvad account'
                        'logout:log out of the current account'
                        'create:create a new Mullvad account'
                        'redeem:redeem a voucher'
                    )
                    _arguments -C \
                        '(- *)--help[show help]' \
                        '1:account command:->acctcmd'
                    case $state in
                        acctcmd)
                            _describe -t account_commands 'account command' account_commands
                            ;;
                    esac
                    ;;
                relay)
                    local -a relay_commands=(
                        'get:get current relay constraints'
                        'list:list available relay locations'
                        'set:set relay constraints'
                        'update:update the relay list'
                    )
                    _arguments -C \
                        '(- *)--help[show help]' \
                        '1:relay command:->relaycmd'
                    case $state in
                        relaycmd)
                            _describe -t relay_commands 'relay command' relay_commands
                            ;;
                    esac
                    ;;
                tunnel)
                    local -a tunnel_commands=(
                        'get:get current tunnel options'
                        'set:set tunnel options'
                    )
                    _arguments -C \
                        '(- *)--help[show help]' \
                        '1:tunnel command:->tunnelcmd'
                    case $state in
                        tunnelcmd)
                            _describe -t tunnel_commands 'tunnel command' tunnel_commands
                            ;;
                    esac
                    ;;
                dns)
                    local -a dns_commands=(
                        'get:get current DNS settings'
                        'set:set DNS options'
                    )
                    _arguments -C \
                        '(- *)--help[show help]' \
                        '1:dns command:->dnscmd'
                    case $state in
                        dnscmd)
                            _describe -t dns_commands 'dns command' dns_commands
                            ;;
                    esac
                    ;;
                lan)
                    local -a lan_commands=(
                        'get:get current LAN sharing setting'
                        'set:set LAN sharing'
                    )
                    _arguments -C \
                        '(- *)--help[show help]' \
                        '1:lan command:->lancmd'
                    case $state in
                        lancmd)
                            _describe -t lan_commands 'lan command' lan_commands
                            ;;
                    esac
                    ;;
                obfuscation)
                    local -a obf_commands=(
                        'get:get current obfuscation settings'
                        'set:set obfuscation mode'
                    )
                    _arguments -C \
                        '(- *)--help[show help]' \
                        '1:obfuscation command:->obfcmd'
                    case $state in
                        obfcmd)
                            _describe -t obf_commands 'obfuscation command' obf_commands
                            ;;
                    esac
                    ;;
                bridge)
                    local -a bridge_commands=(
                        'get:get current bridge settings'
                        'set:set bridge state and settings'
                        'list:list available bridge relays'
                    )
                    _arguments -C \
                        '(- *)--help[show help]' \
                        '1:bridge command:->bridgecmd'
                    case $state in
                        bridgecmd)
                            _describe -t bridge_commands 'bridge command' bridge_commands
                            ;;
                    esac
                    ;;
                auto-connect)
                    local -a ac_commands=(
                        'get:get current auto-connect setting'
                        'set:set auto-connect on or off'
                    )
                    _arguments -C \
                        '(- *)--help[show help]' \
                        '1:auto-connect command:->accmd'
                    case $state in
                        accmd)
                            _describe -t ac_commands 'auto-connect command' ac_commands
                            ;;
                    esac
                    ;;
                lockdown-mode)
                    local -a ld_commands=(
                        'get:get current lockdown mode setting'
                        'set:set lockdown mode on or off'
                    )
                    _arguments -C \
                        '(- *)--help[show help]' \
                        '1:lockdown-mode command:->ldcmd'
                    case $state in
                        ldcmd)
                            _describe -t ld_commands 'lockdown-mode command' ld_commands
                            ;;
                    esac
                    ;;
                split-tunnel)
                    local -a st_commands=(
                        'get:get current split tunnel settings'
                        'add:add an application to split tunnel'
                        'delete:remove an application from split tunnel'
                        'clear:clear all split tunnel applications'
                    )
                    _arguments -C \
                        '(- *)--help[show help]' \
                        '1:split-tunnel command:->stcmd'
                    case $state in
                        stcmd)
                            _describe -t st_commands 'split-tunnel command' st_commands
                            ;;
                    esac
                    ;;
                connect|disconnect|reconnect|status|version)
                    _arguments -s -S \
                        '(- *)--help[show help]'
                    ;;
                custom-dns)
                    local -a cdns_commands=(
                        'get:get current custom DNS settings'
                        'set:set custom DNS servers'
                    )
                    _arguments -C \
                        '(- *)--help[show help]' \
                        '1:custom-dns command:->cdnscmd'
                    case $state in
                        cdnscmd)
                            _describe -t cdns_commands 'custom-dns command' cdns_commands
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

_mullvad "$@"
