#compdef void
# Documentation: https://void.cloud/reference/cli
# Reference accessed: 2026-05-22
# Verified: void.cloud CLI reference command and flag tables.

# Zsh completion for void - Void cloud deployment and project CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'void command' \
      'init[setup wizard]' \
      'deploy[build and deploy]' \
      'prepare[generate .void artifacts]' \
      'gen[code generation]' \
      'db[database commands]' \
      'secret[production secrets]' \
      'env[env.ts schema]' \
      'auth[authentication]' \
      'project[project management]' \
      'domain[custom domains]' \
      'mcp[start Void MCP server]' \
      'help[show help]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--tsconfig[update tsconfig only]' \
          '--agents[agent instructions skills MCP]' \
          '--github[create GitHub Actions workflow]' && ret=0
        ;;
      deploy)
        _arguments \
          '--project[target project slug]:slug:' \
          '--dir[pre-built static directory]:directory:_directories' \
          '--spa[SPA mode for static deploy]' \
          '--skip-build[skip build step]' \
          '--debug[mirror deploy log to stderr]' && ret=0
        ;;
      gen)
        if (( $#line > 1 )); then
          case $line[2] in
            route)
              _arguments \
                '--methods[HTTP methods]:methods:(get post put patch delete)' \
                '1:route path:' && ret=0
              ;;
          esac
        else
          _values 'gen command' \
            'model[scaffold model migration and routes]' \
            'migration[empty migration file]' \
            'route[API route file]' \
            'middleware[numbered middleware file]' \
            'ssr[SSR entry scaffold]' \
            'cron[cron job file]' \
            'queue[queue consumer file]' && ret=0
        fi
        ;;
      db)
        if (( $#line > 1 )); then
          case $line[2] in
            migrate|status)
              _arguments '--remote[use remote database]' && ret=0
              ;;
            seed)
              _arguments '--file[seed file path]:file:_files' && ret=0
              ;;
            execute)
              _arguments '--file[SQL file path]:file:_files' '*:sql:' && ret=0
              ;;
            export)
              _arguments \
                '--output[write to file]:file:_files' \
                '--no-data[schema only]' \
                '--no-schema[data only]' \
                '--table[single table]:table:' && ret=0
              ;;
          esac
        else
          _values 'db command' \
            push generate status reset seed execute migrate studio \
            rename-migrations set-url export && ret=0
        fi
        ;;
      secret)
        _values 'secret command' list put sync delete && ret=0
        ;;
      env)
        if (( $#line > 1 )); then
          case $line[2] in
            check)
              _arguments '--remote[validate against remote secrets]' && ret=0
              ;;
            example)
              _arguments '--force[suppress appended block notice]' && ret=0
              ;;
          esac
        else
          _values 'env command' check types example && ret=0
        fi
        ;;
      auth)
        _values 'auth command' login logout whoami token && ret=0
        ;;
      project)
        if (( $#line > 1 )); then
          case $line[2] in
            logs)
              _arguments \
                '--level[log level]:level:(error warn info log debug all)' \
                '--filter[substring filter]:text:' \
                '--range[time range]:duration:' \
                '--deployment[deployment ID]:id:' && ret=0
              ;;
            purge-cache)
              _arguments '--project[project slug]:slug:' && ret=0
              ;;
          esac
        else
          _values 'project command' \
            status link list logs rollback cancel delete purge-cache && ret=0
        fi
        ;;
      domain)
        _values 'domain command' add delete list status && ret=0
        ;;
      secret|domain)
        _arguments '--project[project slug]:slug:' '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
