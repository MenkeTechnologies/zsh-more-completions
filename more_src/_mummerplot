#compdef mummerplot
# Documentation: https://github.com/mummer4/mummer/blob/master/scripts/mummerplot.pl
# MUMmer utility to generate plots of alignment data using gnuplot

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-b --breaklen)'{-b,--breaklen}'+[highlight alignments with distant breakpoints]:len' \
  '(-c --coverage)'{-c,--coverage}'[generate a reference coverage plot]' \
  '--color[color plot lines with a percent similarity gradient]' \
  '--nocolor[turn off all plot color]' \
  '--depend[print dependency information and exit]' \
  '(-f --filter)'{-f,--filter}'[only display best alignments at each spot]' \
  '--fat[layout sequences using fattest alignment only]' \
  '(-l --layout)'{-l,--layout}'[layout a delta multiplot intelligibly]' \
  '(-p --prefix)'{-p,--prefix}'+[output file prefix]:prefix' \
  '(-r --IdR)'{-r,--IdR}'+[plot a reference sequence ID on the X-axis]:id' \
  '(-q --IdQ)'{-q,--IdQ}'+[plot a query sequence ID on the Y-axis]:id' \
  '(-R --Rfile)'{-R,--Rfile}'+[plot ordered reference sequences from file]:file:_files' \
  '(-Q --Qfile)'{-Q,--Qfile}'+[plot ordered query sequences from file]:file:_files' \
  '(-s --size)'{-s,--size}'+[set output size]:size:(small medium large)' \
  '(-S --SNP)'{-S,--SNP}'[highlight SNP locations in each alignment]' \
  '(-t --terminal)'{-t,--terminal}'+[set the output terminal]:terminal' \
  '--title=[gnuplot plot title]:title' \
  '(-x --xrange)'{-x,--xrange}'+[set the xrange for the plot]:range' \
  '(-y --yrange)'{-y,--yrange}'+[set the yrange for the plot]:range' \
  ':match file:_files' && ret=0

return ret
