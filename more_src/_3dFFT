#compdef 3dFFT
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dFFT.html
# AFNI 3D FFT of input dataset in x,y,z directions

local ret=1

_arguments -s -S \
  '-abs[output magnitude of the FFT (default)]' \
  '-phase[output phase without unwrapping]' \
  '-complex[output complex-valued FFT result]' \
  '-inverse[perform inverse FFT]' \
  '-Lx[FFT length in x-direction]:xx:' \
  '-Ly[FFT length in y-direction]:yy:' \
  '-Lz[FFT length in z-direction]:zz:' \
  '-altIN[alternate signs of input before FFT]' \
  '-altOUT[alternate signs of output after FFT]' \
  '-input[input dataset]:dataset:_files' \
  '-prefix[output dataset prefix name]:prefix:' \
  '*:dataset:_files' && ret=0

return ret
