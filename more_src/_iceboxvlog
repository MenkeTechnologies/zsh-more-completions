#compdef iceboxvlog
# _iceboxvlog — Project IceStorm iceboxvlog CLI translating an icebox ASCII placement file back into a Verilog netlist by enumerating routed nets PLBs IOBs RAM tiles for round-trip simulation verification or analysis (Clifford Wolf team, Python); custom argparse
# upstream: https://github.com/YosysHQ/icestorm

_iceboxvlog() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-s[strip names]' \
        '-S[strip nets]' \
        '-l[list IO]' \
        '-L[list LCs]' \
        '-n[no buffers]' \
        '-p+[pcf file]:file:_files -g "*.pcf"' \
        '-c[combinational only]' \
        '-y[allow latches]' \
        '*:asc file:_files -g "*.asc"'
}

_iceboxvlog "$@"
