# Repository: ishan-parihar/operant (completion/operant.zsh)
#compdef operant
# Operant CLI zsh completion
# Install: copy to ~/.zsh/completion/_operant and add fpath

_operant() {
    local -a commands
    commands=(
        'onboard:Run setup wizard'
        'doctor:Run diagnostic checks'
        'status:Show system status'
        'help:Show help'
        'version:Show version'
    )

    _arguments -C \
        '1: :->command' \
        '2: :->subcommand' \
        '--config[Path to config file]:file:_files' \
        '--verbose[Enable verbose output]' \
        '--help[Show help]' \
        '--version[Show version]'

    case "$state" in
        command)
            _describe 'command' commands
            ;;
        subcommand)
            case "$words[2]" in
                onboard)
                    _arguments \
                        '--mode[Setup mode]:(quickstart advanced)' \
                        '--reset-scope[Reset scope]:(config config+creds full)' \
                        '--help[Show help]'
                    ;;
                doctor)
                    _arguments \
                        '--yes[Auto-accept fixes]' \
                        '--repair[Apply repairs]' \
                        '--help[Show help]'
                    ;;
                status)
                    _arguments \
                        '--deep[Include deep checks]' \
                        '--json[Output as JSON]' \
                        '--help[Show help]'
                    ;;
            esac
            ;;
    esac
}

_operant "$@"
