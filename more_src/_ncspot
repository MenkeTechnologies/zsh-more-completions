#compdef ncspot

# Zsh completion for ncspot (Spotify TUI client)

_arguments -s -S \
  '(-b --basepath)'{-b,--basepath}'[custom basepath]:path:_files -/' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && return 0
