#compdef kpack-rebase
# _kpack-rebase — kpack rebase build phase helper
# upstream: https://github.com/buildpacks-community/kpack
# Flags from cmd/rebase/main.go on tip.

_kpack-rebase() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--run-image=[new run image to rebase onto]:image:' \
        '--last-built-image=[previous image to rebase]:image:' \
        '--build-changes=[JSON string of build changes + reasons]:json:' \
        '--report=[path to write report.toml]:file:_files' \
        '*--basic-docker=[basic auth for docker registry: secret=domain]:spec:' \
        '*--dockercfg=[path to dockercfg credential]:path:_files' \
        '*--dockerconfig=[path to docker config.json credential]:path:_files' \
        '*--imagepull=[builder image pull credential path]:path:_files' \
        '*:tag:'
}

_kpack-rebase "$@"
