#compdef scoop

# Zsh completion for scoop - Windows package manager for command-line programs

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'alias:manage scoop aliases'
      'bucket:manage scoop buckets'
      'cache:manage download cache'
      'cat:show content of specified manifest'
      'checkup:check system for potential problems'
      'cleanup:clean up apps by removing old versions'
      'config:get or set configuration values'
      'create:create a custom app manifest'
      'depends:list dependencies for an app'
      'download:download apps without installing'
      'export:export installed apps, buckets and configs'
      'help:show help for a command'
      'hold:hold an app to prevent updates'
      'home:open the homepage for an app'
      'import:import apps, buckets and configs from a file'
      'info:display information about an app'
      'install:install apps'
      'list:list installed apps'
      'prefix:return the path for an installed app'
      'reset:reset an app to resolve conflicts'
      'search:search available apps'
      'shim:manage shims'
      'status:show status and check for updates'
      'unhold:unhold an app to allow updates'
      'uninstall:uninstall an app'
      'update:update apps or scoop itself'
      'virustotal:look up hash or app on VirusTotal'
      'which:locate a shim/executable'
    )
    _describe -t commands 'scoop command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-g,--global}'[install globally]' \
          {-i,--independent}'[do not install dependencies]' \
          {-k,--no-cache}'[do not use download cache]' \
          {-u,--no-update-scoop}'[do not update scoop before installing]' \
          {-s,--skip}'[skip hash validation]' \
          {-a,--arch}'+[architecture]:arch:(32bit 64bit arm64)' \
          '*:app' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-g,--global}'[uninstall globally installed app]' \
          {-p,--purge}'[remove all persistent data]' \
          '*:app' && ret=0
        ;;
      update)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-f,--force}'[force update]' \
          {-g,--global}'[update globally installed apps]' \
          {-i,--independent}'[do not install dependencies]' \
          {-k,--no-cache}'[do not use download cache]' \
          {-s,--skip}'[skip hash validation]' \
          {-q,--quiet}'[suppress output]' \
          {-a,--all}'[update all apps]' \
          '*:app' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-i,--installed}'[list installed apps]' \
          {-r,--reverse}'[reverse sort order]' \
          {-u,--updated}'[sort by update date]' \
          '*:query' && ret=0
        ;;
      search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-r,--remote}'[search remote buckets]' \
          '1:query' && ret=0
        ;;
      cleanup)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-g,--global}'[clean up globally installed apps]' \
          {-k,--cache}'[remove outdated download cache]' \
          {-a,--all}'[clean up all apps]' \
          '*:app' && ret=0
        ;;
      status)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-l,--local}'[check status against local copies]' && ret=0
        ;;
      bucket)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(add list known rm)' \
          '*:argument' && ret=0
        ;;
      cache)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(show rm)' \
          '*:argument' && ret=0
        ;;
      config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(get set unset show)' \
          '*:argument' && ret=0
        ;;
      export)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-c,--config}'[include config in export]' && ret=0
        ;;
      import)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:file:_files' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:argument' && ret=0
        ;;
    esac
    ;;
esac

return ret
