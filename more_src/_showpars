#compdef showpars
# Documentation: https://dragons.readthedocs.io/projects/recipe-system-users-manual/en/stable/supptools.html
# DRAGONS: show available parameters and defaults for a primitive

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show program version number]' \
  '(-d --doc)'{-d,--doc}'[show the full docstring]' \
  '--adpkg[specify instrument package]:pkg:' \
  '--drpkg[name of the DRAGONS instrument package]:pkg:' \
  '1:file:_files' \
  '2:primitive:' && ret=0

return ret
