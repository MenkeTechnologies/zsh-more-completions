#compdef wossname
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/wossname.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS wossname: find programs by keywords in short description
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' \
  '-auto[turn off all prompts]' \
  '-stdout[write standard output]' \
  '-filter[read stdin/write stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug log]' \
  '-verbose[verbose output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[report version]' \
  '-explode[expand group names into multiple combinations]' \
  '-allmatch[require all words to match]' \
  '-noallmatch[allow any word to match]' \
  '-showkeywords[display keywords with program documentation]' \
  '-outfile=[output file]:file:_files' \
  '-html[format output as HTML table]' \
  '-groups[output only group names]' \
  '-alphabetic[list programs alphabetically]' \
  '-emboss[search EMBOSS program documentation]' \
  '-noemboss[do not search EMBOSS program documentation]' \
  '-embassy[search EMBASSY program documentation]' \
  '-noembassy[do not search EMBASSY program documentation]' \
  '-showembassy=[search specific EMBASSY package]:package:' \
  '-colon[use colons to separate group hierarchy levels]' \
  '-gui[report only GUI-compatible programs]' \
  '*:search keyword:' && ret=0

return ret
