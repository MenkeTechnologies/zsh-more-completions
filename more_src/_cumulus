#compdef cumulus polkadot-parachain
# _cumulus — Parity Tech Cumulus polkadot-parachain collator node implementing Substrate parachain runtime template for Polkadot/Kusama parathread parachain consensus (paritytech team, Rust); clap
# upstream: https://github.com/paritytech/cumulus

_cumulus() {
    local -a sub=(
        'export-genesis-state:export genesis state'
        'export-genesis-wasm:export genesis wasm'
        'build-spec:build chain spec'
        'check-block:check block'
        'export-blocks:export blocks'
        'export-state:export state'
        'import-blocks:import blocks'
        'purge-chain:purge chain'
        'revert:revert chain'
        'key:key operations'
        'try-runtime:try runtime'
        'benchmark:benchmark'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--chain=+[chain]:c:(asset-hub-polkadot asset-hub-kusama collectives-polkadot bridge-hub-polkadot bridge-hub-kusama people-polkadot people-kusama coretime-polkadot coretime-kusama dev local-dev)' \
        '--dev[run in dev mode]' \
        '--validator[run as validator]' \
        '--collator[run as collator]' \
        '--no-prometheus[no prometheus]' \
        '--prometheus-external[expose prometheus]' \
        '--prometheus-port=+[port]:n:' \
        '--rpc-port=+[port]:n:' \
        '--rpc-external[expose RPC]' \
        '--rpc-cors=+[origins]:str:' \
        '--rpc-methods=+[mode]:m:(auto safe unsafe)' \
        '--rpc-max-connections=+[N]:n:' \
        '--port=+[port]:n:' \
        '--name=+[name]:str:' \
        '--telemetry-url=+[url verbosity]:str:' \
        '--no-telemetry[no telemetry]' \
        '--base-path=+[dir]:dir:_files -/' \
        '-d+[dir]:dir:_files -/' \
        '--keystore-path=+[dir]:dir:_files -/' \
        '--password-filename=+[file]:file:_files' \
        '--node-key=+[key]:str:' \
        '--node-key-file=+[file]:file:_files' \
        '--state-pruning=+[N]:str:' \
        '--blocks-pruning=+[N]:str:' \
        '--bootnodes=+[csv]:str:' \
        '--reserved-nodes=+[csv]:str:' \
        '--in-peers=+[N]:n:' \
        '--out-peers=+[N]:n:' \
        '--parachain-id=+[N]:n:' \
        '--relay-chain-rpc-url=+[url]:str:' \
        '--relay-chain-rpc-urls=+[csv]:str:' \
        '--collator-key=+[key]:str:' \
        '--force-authoring[force authoring]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cumulus subcommand' sub ;;
        args) ;;
    esac
}

_cumulus "$@"
