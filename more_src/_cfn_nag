#compdef cfn_nag
# Documentation: https://github.com/stelligent/cfn_nag
# Reference accessed: 2026-06-04

# Zsh completion for cfn_nag - CloudFormation linting tool

_arguments \
    '--input-path[path to CloudFormation template to lint (required)]:file:_files' \
    '--output-format[output format]:format:(txt json colortxt)' \
    '--debug[enable debug output]' \
    '--rule-directory[directory of custom rules to include]:directory:_directories' \
    '--profile-path[path to a profile file]:file:_files' \
    '--parameter-values-path[path to a JSON file of parameter values]:file:_files' \
    '--template-pattern[glob pattern for templates to scan]:pattern' \
    '--ignore-fatal[continue scanning even if a fatal violation is found]' \
    '--print-suppression[print details of rules that are suppressed]' \
    '--fail-on-warnings[treat warnings as failures]' \
    '--deny-list-path[path to a deny list file]:file:_files' \
    '(- *)--version[show version]' \
    '(- *)--help[show help message]'
