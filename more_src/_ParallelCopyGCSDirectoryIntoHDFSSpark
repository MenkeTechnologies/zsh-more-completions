#compdef ParallelCopyGCSDirectoryIntoHDFSSpark
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/spark/ParallelCopyGCSDirectoryIntoHDFSSpark.java
# GATK Spark: copy a GCS directory into HDFS in parallel

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--input-gcs-path=[input GCS file path (trailing slash for a directory)]:path:' \
  '--input-file-glob=[optional wildcard glob to subset input files to copy]:glob:' \
  '--output-hdfs-directory=[output HDFS directory to transfer the data into]:path:' \
  '*:argument:_files' && ret=0

return ret
