#compdef hermit

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--level=[log level]:level:(trace debug info warn error)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'exec:execute a binary managed by Hermit'
      'info:show info about a package'
      'init:initialize Hermit in a directory'
      'install:install packages'
      'list:list installed packages'
      'search:search for packages'
      'shell-hooks:manage shell hooks'
      'status:show Hermit status'
      'test:test packages'
      'uninstall:uninstall packages'
      'update:update package sources'
      'upgrade:upgrade installed packages'
      'validate:validate Hermit configuration'
      'env:manage Hermit environment'
      'manifest:manage package manifests'
      'gc:garbage collect old package versions'
      'nuke:remove all Hermit state'
    )
    _describe -t commands 'hermit command' commands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--sources=[package sources]:sources' \
          '1:directory:_directories' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:package' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:package' && ret=0
        ;;
      search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:query' && ret=0
        ;;
      info)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:package' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:package' && ret=0
        ;;
      env)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-r[raw output]' \
          '--raw[raw output]' && ret=0
        ;;
      shell-hooks)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--zsh[output zsh hooks]' \
          '--bash[output bash hooks]' && ret=0
        ;;
    esac
    ;;
esac

return ret
