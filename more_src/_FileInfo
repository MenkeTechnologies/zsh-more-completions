#compdef FileInfo
# OpenMS TOPP: show basic information about an MS data file

local ret=1

_arguments -s -S \
  '-in[input file]:input file:_files' \
  '-in_type[input file type]:type:(mzData mzXML mzML sqMass dta dta2d mgf featureXML consensusXML idXML pepXML mzTab fid mzid trafoXML fasta pqp)' \
  '-out[output file (txt)]:output file:_files' \
  '-out_tsv[tab-separated flat text output file]:output file:_files' \
  '-m[show meta information about the whole experiment]' \
  '-p[show data processing information]' \
  '-s[compute five-number statistics of intensities, qualities, and widths]' \
  '-d[show detailed listing of all spectra and chromatograms]' \
  '-c[check for corrupt data in the file]' \
  '-v[validate the file only]' \
  '-i[check whether an mzML file contains valid indices]' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
