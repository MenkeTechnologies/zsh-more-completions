#compdef tlsextract
# Documentation: https://www.ccp4.ac.uk/html/tlsextract.html
# CCP4 TLSEXTRACT - extract TLS group descriptions into REFMAC format

local ret=1

_arguments -s -S \
  'XYZIN[input PDB with TLS group REMARK records]:file:_files' \
  'TLSOUT[output TLS tensors in REFMAC format]:file:_files' \
  '*:file:_files' && ret=0

return ret
