#compdef lix

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:build a derivation or fetch a store path'
  'bundle:bundle an installable into a single file'
  'config:manage Lix configuration'
  'copy:copy paths between two stores'
  'daemon:run lix-daemon (privileged builder)'
  'derivation:operate on derivations'
  'develop:run a bash shell with build environment'
  'doctor:check installation for issues'
  'edit:open derivation .nix in editor'
  'eval:evaluate Nix expression'
  'flake:manage flakes'
  'fmt:reformat Nix files'
  'hash:compute and convert cryptographic hashes'
  'help:show help'
  'help-stores:show store types help'
  'key:generate signing keys'
  'log:show build log of derivation'
  'nar:operate on NAR files'
  'path-info:show information about store paths'
  'print-dev-env:print bash dev environment'
  'profile:manage Nix profiles'
  'realisation:manage content-addressed derivation outputs'
  'registry:manage flake registry'
  'repl:start interactive REPL'
  'run:run a Nix application'
  'search:search for packages'
  'shell:run a shell with packages'
  'show-config:show config (deprecated, use config show)'
  'show-derivation:show derivation (use derivation show)'
  'store:manipulate Nix store'
  'upgrade-nix:upgrade Lix/Nix install'
  'version:show version'
  'why-depends:explain why a path depends on another'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' \
  '--debug[enable debug output]' \
  '--log-format=[log format]:fmt:(raw internal-json bar bar-with-logs)' \
  '--print-build-logs[print full build logs]' \
  '--option[set Nix config option]:name:' \
  '--store=[Nix store URL]:url:' \
  '--extra-experimental-features=[enable feature]:feature:' \
  '--no-substitute[do not use substituters]' \
  '--max-jobs=[parallel jobs]:n:' \
  '--cores=[per-build cores]:n:' \
  '--keep-going[keep going on errors]' \
  '--keep-failed[keep failed build dirs]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'lix subcommand' subcommands && ret=0 ;;
esac

return ret
