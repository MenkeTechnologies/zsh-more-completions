#compdef asn1Coding asn1Decoding
# Documentation: asn1Coding/asn1Decoding --help (GNU Libtasn1)
# Source: encode/decode DER data using ASN.1 definitions + value assignments.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

if [[ $service == asn1Coding ]]; then
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-c --check)'{-c,--check}'[check syntax only]' \
        '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
        '1:asn1 definitions:_files -g "*.(asn|asn1)"' \
        '2:assignments file:_files' \
        && ret=0
else
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-b --benchmark)'{-b,--benchmark}'[benchmark decoding]' \
        '(-s --strict)'{-s,--strict}'[strict DER decoding]' \
        '(-t --no-time-strict)'{-t,--no-time-strict}'[strict DER but not in time fields]' \
        '1:asn1 definitions:_files -g "*.(asn|asn1)"' \
        '2:DER-encoded file:_files' \
        '3:ASN1 type name:' \
        && ret=0
fi

return ret
