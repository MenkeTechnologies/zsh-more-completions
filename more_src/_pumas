# Source: cargo binstall pumas@0.5.0
# Probed via: generate-completion zsh
# Repository: https://github.com/graelo/pumas
#compdef pumas

autoload -U is-at-least

_pumas() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_pumas_commands" \
"*::: :->pumas" \
&& ret=0
    case $state in
    (pumas)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pumas-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
'-i+[Update rate \[ms\], min=100]:SAMPLE_RATE_MS:_default' \
'--sample-rate=[Update rate \[ms\], min=100]:SAMPLE_RATE_MS:_default' \
'--history-size=[History buffer size]:HISTORY_SIZE:_default' \
'--accent-color=[ASCII code for labels, max\: 255, default\: green]:ACCENT_COLOR:_default' \
'--gauge-fg-color=[ASCII code, max=255, default\: green]:GAUGE_FG_COLOR:_default' \
'--gauge-bg-color=[ASCII code, max=255, default\: white]:GAUGE_BG_COLOR:_default' \
'--history-fg-color=[ASCII code, max=255, default\: blue]:HISTORY_FG_COLOR:_default' \
'--history-bg-color=[ASCII code, max=255, default\: white]:HISTORY_BG_COLOR:_default' \
'--json[Print metrics to stdout as JSON instead of running the UI]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(generate-completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':shell -- Shell for which you want completion:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_pumas__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pumas-help-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(generate-completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_pumas_commands] )) ||
_pumas_commands() {
    local commands; commands=(
'run:Run the power usage monitor' \
'generate-completion:Print a shell completion script to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'pumas commands' commands "$@"
}
(( $+functions[_pumas__generate-completion_commands] )) ||
_pumas__generate-completion_commands() {
    local commands; commands=()
    _describe -t commands 'pumas generate-completion commands' commands "$@"
}
(( $+functions[_pumas__help_commands] )) ||
_pumas__help_commands() {
    local commands; commands=(
'run:Run the power usage monitor' \
'generate-completion:Print a shell completion script to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'pumas help commands' commands "$@"
}
(( $+functions[_pumas__help__generate-completion_commands] )) ||
_pumas__help__generate-completion_commands() {
    local commands; commands=()
    _describe -t commands 'pumas help generate-completion commands' commands "$@"
}
(( $+functions[_pumas__help__help_commands] )) ||
_pumas__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'pumas help help commands' commands "$@"
}
(( $+functions[_pumas__help__run_commands] )) ||
_pumas__help__run_commands() {
    local commands; commands=()
    _describe -t commands 'pumas help run commands' commands "$@"
}
(( $+functions[_pumas__run_commands] )) ||
_pumas__run_commands() {
    local commands; commands=()
    _describe -t commands 'pumas run commands' commands "$@"
}

if [ "$funcstack[1]" = "_pumas" ]; then
    _pumas "$@"
else
    compdef _pumas pumas
fi
