#compdef steampipe
# Documentation: https://steampipe.io/docs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Source: github.com/turbot/steampipe cmd/ directory

# Zsh completion for steampipe (SQL for cloud APIs). Note: check/dashboard/mod/variable
# moved to the separate Powerpipe tool and are no longer steampipe subcommands.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'completion:generate shell completion scripts'
  'help:help about any command'
  'login:log in to Steampipe Cloud / Turbot Pipes'
  'plugin:steampipe plugin management'
  'query:execute SQL queries interactively or in batch'
  'service:steampipe database service management'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--install-dir[steampipe install directory]:dir:_files -/' \
  '--workspace[workspace profile]:workspace:' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'steampipe command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (query)
        _arguments \
          '--header[include column headers]:bool:(true false)' \
          '--output[output format]:format:(table csv json line)' \
          '--separator[separator for csv output]:separator:' \
          '--timing[show query timing]' \
          '--search-path[set search path]:path:' \
          '--search-path-prefix[set search path prefix]:prefix:' \
          '--watch[watch SQL files for changes]' \
          '*:query or file:_files -g "*.sql"' && ret=0
        ;;
      (plugin)
        local -a plugin_cmds=('install:install a plugin' 'list:list installed plugins' 'uninstall:uninstall a plugin' 'update:update plugins')
        _describe -t plugin_cmds 'plugin command' plugin_cmds && ret=0
        ;;
      (service)
        local -a svc_cmds=('start:start the service' 'status:show service status' 'stop:stop the service' 'restart:restart the service')
        _describe -t svc_cmds 'service command' svc_cmds && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
