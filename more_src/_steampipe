#compdef steampipe

# Zsh completion for steampipe (SQL for cloud APIs)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:execute one or more controls'
  'completion:generate shell completion scripts'
  'dashboard:start the dashboard UI'
  'help:help about any command'
  'login:log in to Steampipe Cloud'
  'mod:steampipe mod management'
  'plugin:steampipe plugin management'
  'query:execute SQL queries interactively or in batch'
  'service:steampipe database service management'
  'variable:steampipe variable management'
  'version:show version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--install-dir[steampipe install directory]:dir:_files -/' \
  '--workspace[workspace profile]:workspace:' \
  '--cloud-host[Steampipe Cloud host]:host:' \
  '--cloud-token[Steampipe Cloud token]:token:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'steampipe command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (query)
        _arguments \
          '--header[include column headers]:bool:(true false)' \
          '--output[output format]:format:(table csv json line)' \
          '--separator[separator for csv output]:separator:' \
          '--timing[show query timing]' \
          '--search-path[set search path]:path:' \
          '--search-path-prefix[set search path prefix]:prefix:' \
          '--watch[watch SQL files for changes]' \
          '*:query or file:_files -g "*.sql"' && ret=0
        ;;
      (check)
        _arguments \
          '--output[output format]:format:(brief csv html json md snapshot text none)' \
          '--export[export file]:file:_files' \
          '--progress[show progress]:bool:(true false)' \
          '--search-path[set search path]:path:' \
          '--search-path-prefix[set search path prefix]:prefix:' \
          '--tag[filter by tag]:tag:' \
          '--theme[output theme]:theme:(dark light plain)' \
          '--where[SQL where clause]:where:' \
          '--dry-run[show checks without running]' \
          '*:control or benchmark:' && ret=0
        ;;
      (plugin)
        local -a plugin_cmds=('install:install a plugin' 'list:list installed plugins' 'uninstall:uninstall a plugin' 'update:update plugins')
        _arguments '1:plugin command:((${(j: :)${plugin_cmds// /\\:}}))' '*:plugin:' && ret=0
        ;;
      (mod)
        local -a mod_cmds=('init:initialize a mod' 'install:install mod dependencies' 'list:list mod dependencies' 'uninstall:uninstall a mod' 'update:update mod dependencies')
        _arguments '1:mod command:((${(j: :)${mod_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (service)
        local -a svc_cmds=('start:start the service' 'status:show service status' 'stop:stop the service' 'restart:restart the service')
        _arguments '1:service command:((${(j: :)${svc_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (dashboard)
        _arguments \
          '--browser[open in browser]:bool:(true false)' \
          '--dashboard-listen[listen address]:address:(local network)' \
          '--dashboard-port[listen port]:port:' \
          '*:dashboard:' && ret=0
        ;;
    esac
    ;;
esac

return ret
