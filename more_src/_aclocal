#compdef aclocal aclocal-1.18
# Documentation: aclocal --help (GNU Automake)
# Source: assemble aclocal.m4 from m4 macro files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '--automake-acdir=[automake-provided m4 directory]:dir:_files -/' \
    '--aclocal-path=[colon-separated third-party local dirs]:path:' \
    '--system-acdir=[third-party system-wide m4 directory]:dir:_files -/' \
    '--diff=-[run COMMAND on changed m4 files]::command:' \
    '--dry-run[do not actually update any file]' \
    '--force[always update output]' \
    '*-I+[add directory to search list for .m4 files]:dir:_files -/' \
    '--install[copy third-party files to first -I directory]' \
    '--output=[output file]:file:_files' \
    '--print-ac-dir[print system-wide m4 dir and exit]' \
    '--verbose[do not be silent]' \
    '*'{-W+,--warnings=}'[report warnings in CATEGORY]:category:(cross gnu obsolete override portability portability-recursive extra-portability syntax unsupported all none error)' \
    && ret=0

return ret
