#compdef pijul

# Zsh completion for Pijul (patch-based version control system)

_pijul() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'init:create a new repository'
    'clone:clone a remote repository'
    'record:record changes in the working copy'
    'diff:show changes in the working copy'
    'log:show the history of changes'
    'push:push changes to a remote repository'
    'pull:pull changes from a remote repository'
    'change:show the contents of a change'
    'channel:manage channels'
    'apply:apply a change to the repository'
    'reset:reset the working copy'
    'fork:create a new channel'
    'unrecord:unrecord a change'
    'remote:manage remote repositories'
    'archive:create an archive of the repository'
    'credit:show authors of each line'
    'tag:manage tags'
    'identity:manage identities'
    'key:manage keys'
    'completion:generate shell completion scripts'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'pijul command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        init)
          _arguments -s -S \
            '--channel=[set the name of the initial channel]:channel name:' \
            '1:directory:_files -/' \
            && ret=0
          ;;
        clone)
          _arguments -s -S \
            '--channel=[clone a specific channel]:channel name:' \
            '--change=[clone up to a specific change]:change hash:' \
            '--lazy[only download changes as needed]' \
            '-k+[set path for SSH key]:key file:_files' \
            '1:remote URI:' \
            '2:local path:_files -/' \
            && ret=0
          ;;
        record)
          _arguments -s -S \
            '-a[record all changes]' \
            '--all[record all changes]' \
            '-m+[set the change message]:message:' \
            '--message=[set the change message]:message:' \
            '--author=[set the author]:author:' \
            '--channel=[record on a specific channel]:channel name:' \
            '--repository=[path to the repository]:repository:_files -/' \
            '--timestamp=[set the timestamp]:timestamp:' \
            '--working-copy[record the working copy]' \
            '*:files:_files' \
            && ret=0
          ;;
        diff)
          _arguments -s -S \
            '--repository=[path to the repository]:repository:_files -/' \
            '--channel=[use a specific channel]:channel name:' \
            '--json[output in JSON format]' \
            '--short[short summary]' \
            '--untracked[include untracked files]' \
            '*:files:_files' \
            && ret=0
          ;;
        log)
          _arguments -s -S \
            '--repository=[path to the repository]:repository:_files -/' \
            '--channel=[use a specific channel]:channel name:' \
            '--hash-only[show only hashes]' \
            '--state[show channel state]' \
            '--description[show change descriptions]' \
            '-n+[number of changes to show]:count:' \
            '--limit=[number of changes to show]:count:' \
            && ret=0
          ;;
        push)
          _arguments -s -S \
            '--repository=[path to the repository]:repository:_files -/' \
            '--from-channel=[push from a specific channel]:channel name:' \
            '--to-channel=[push to a specific channel]:channel name:' \
            '-a[push all changes]' \
            '--all[push all changes]' \
            '-k+[set path for SSH key]:key file:_files' \
            '1:remote URI:' \
            && ret=0
          ;;
        pull)
          _arguments -s -S \
            '--repository=[path to the repository]:repository:_files -/' \
            '--from-channel=[pull from a specific channel]:channel name:' \
            '--to-channel=[pull to a specific channel]:channel name:' \
            '-a[pull all changes]' \
            '--all[pull all changes]' \
            '-k+[set path for SSH key]:key file:_files' \
            '1:remote URI:' \
            && ret=0
          ;;
        channel)
          _arguments -s -S \
            '--repository=[path to the repository]:repository:_files -/' \
            '1:subcommand:(list new delete rename switch)' \
            '2:channel name:' \
            && ret=0
          ;;
        reset)
          _arguments -s -S \
            '--repository=[path to the repository]:repository:_files -/' \
            '--channel=[channel to reset]:channel name:' \
            '--change=[reset to a specific change]:change hash:' \
            '--force[force reset]' \
            '*:files:_files' \
            && ret=0
          ;;
        unrecord)
          _arguments -s -S \
            '--repository=[path to the repository]:repository:_files -/' \
            '--channel=[channel to unrecord from]:channel name:' \
            '--reset[also reset the working copy]' \
            '1:change hash:' \
            && ret=0
          ;;
        remote)
          _arguments -s -S \
            '--repository=[path to the repository]:repository:_files -/' \
            '1:subcommand:(list add delete)' \
            '2:name:' \
            '3:URI:' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--repository=[path to the repository]:repository:_files -/' \
            '*:files:_files' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_pijul "$@"
