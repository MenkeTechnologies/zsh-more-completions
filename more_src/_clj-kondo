#compdef clj-kondo

# Zsh completion for clj-kondo - Clojure linter

_arguments -s -S \
  '--lint[a file, directory or classpath ("-" for stdin)]:paths:_files' \
  '--lang[force lang]:lang:(clj cljs cljc)' \
  '--filename[in case stdin is used for linting, use this value as filename]:filename:_files' \
  '--cache[use a cache]:boolean:(true false)' \
  '--cache-dir[use custom directory for cache]:directory:_files -/' \
  '--parallel[lint sources in parallel]' \
  '--config[config file or map]:config:' \
  '--config-dir[path to a directory containing a config.edn file]:directory:_files -/' \
  '--dependencies[classpath ment for linting a dependency (classpath)]:classpath:' \
  '--copy-configs[copy configs from dependencies while linting]' \
  '--skip-lint[run custom hooks, but skip linting]' \
  '--fail-level[minimum severity to cause a non-zero exit code]:level:(error warning)' \
  '--no-warnings[exit with code 2 if there are no warnings nor errors]' \
  '--repro[disable reading from $HOME/.config/clj-kondo/config.edn]' \
  '--debug[print debug info]' \
  '--report-duration[show lint duration for each linted file]' \
  '--version[print version string]' \
  '--help[print help]'
