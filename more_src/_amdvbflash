#compdef amdvbflash

# AMDVBFlash: AMD/ATI video BIOS flash utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '/?[show help]' \
  '-help[show help]' \
  '-i[show adapter info]' \
  '-ai[show ASIC info]' \
  '-p[program (write) BIOS]:adapter file:_files' \
  '-s[save BIOS to file]:adapter file:_files' \
  '-v[verify BIOS]:adapter file:_files' \
  '-cf[bypass checks (force flash)]' \
  '-pa[program all adapters]:file:_files' \
  '-sa[save all adapters]' \
  '-ce[clear errors]' \
  '-fa[force flash type detection]' \
  '-fs[force SSID]' \
  '-fp[program PCI subsystem ID]' \
  '-id[show adapter ID]' \
  '-mc[no menu compatibility check]' \
  '-mi[no menu image check]' \
  '-rom[show ROM size]' \
  '-rsr[restore subsystem revision]' \
  '*::amdvbflash args:_files' && ret=0
return ret
