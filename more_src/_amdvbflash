#compdef amdvbflash
# Documentation: https://github.com/Strunzdesign/amdvbflash
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# amdvbflash: AMD video BIOS flash utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-i[list adapters]' \
  '-s[save current VBIOS]:adapter file:' \
  '-p[program VBIOS]:adapter file:' \
  '-cf[verify checksum]:file:_files' \
  '-cb[check BIOS]:file:_files' \
  '-pa[program all]:file:_files' \
  '-info[show info]:file:_files' \
  '-fp[force program (ignore checks)]:file:_files' \
  '-f[force]' \
  '-isi[show subsystem info]:adapter:' \
  '-pcimap[show PCI map]' \
  '*::amdvbflash args:_files' && ret=0
return ret
