#compdef atmos

_atmos_subcommands() {
  local -a subcmds=(
    'atlantis:Execute Atlantis commands'
    'aws:Execute AWS commands'
    'completion:Generate shell completion scripts'
    'describe:Describe configuration'
    'docs:Generate and manage documentation'
    'helmfile:Execute Helmfile commands'
    'terraform:Execute Terraform commands'
    'validate:Validate configurations'
    'vendor:Manage vendored components and stacks'
    'version:Print the version'
    'workflow:Execute a workflow'
  )
  _describe -t commands 'atmos subcommand' subcmds
}

_atmos() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '--logs-level[Set log level]:level:(Trace Debug Info Warning Off)' \
    '--logs-file[Set log file]:file:_files' \
    '--redirect-stderr[Redirect stderr to a file]:file:_files' \
    '1:subcommand:_atmos_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        terraform)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '-s[Stack name]:stack:' \
            '--stack[Stack name]:stack:' \
            '--dry-run[Dry run mode]' \
            '1:command:(plan apply destroy init output validate clean workspace)' \
            '2:component:'
          ;;
        helmfile)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '-s[Stack name]:stack:' \
            '--stack[Stack name]:stack:' \
            '--dry-run[Dry run mode]' \
            '1:command:(diff apply sync destroy)' \
            '2:component:'
          ;;
        describe)
          _arguments \
            '1:resource:(component stacks config dependents affected)' \
            '-s[Stack name]:stack:' \
            '--stack[Stack name]:stack:'
          ;;
        vendor)
          _arguments \
            '1:action:(pull)' \
            '-s[Stack name]:stack:' \
            '--stack[Stack name]:stack:' \
            '-c[Component name]:component:' \
            '--component[Component name]:component:' \
            '--type[Component type]:type:(terraform helmfile)' \
            '--dry-run[Dry run mode]'
          ;;
        workflow)
          _arguments \
            '-f[Workflow manifest file]:file:_files' \
            '--file[Workflow manifest file]:file:_files' \
            '--dry-run[Dry run mode]' \
            '1:workflow:'
          ;;
      esac
      ;;
  esac
}

_atmos "$@"
