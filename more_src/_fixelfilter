#compdef fixelfilter
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/fixelfilter.html
# Source: MRtrix3/mrtrix3 cmd/fixelfilter.cpp — fixel data smoothing / thresholding / connected-component filter (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-matrix+[fixel-fixel connectivity matrix (required for some filters)]:file:_files -/' \
    '-threshold_value+[threshold on input fixel data]:value:_default' \
    '-threshold_connectivity+[connectivity threshold for connected-component analysis]:value:_default' \
    '-fwhm+[FWHM of spatial smoothing component]:mm:_default' \
    '-minweight+[minimum smoothing weight threshold]:value:_default' \
    '-mask+[binary fixel mask to smooth within]:file:_files' \
    '1:input:_files' \
    '2:filter:(connect smooth threshold)' \
    '3:output:_files' \
    && ret=0

return ret
