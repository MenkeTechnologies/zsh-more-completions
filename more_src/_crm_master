#compdef crm_master

# Pacemaker crm_master: set or get master scores for promotable resources
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-r --resource)'{-r,--resource=}'[resource id]:resource:' \
  '(-N --node)'{-N,--node=}'[node name]:node:' \
  '(-l --lifetime)'{-l,--lifetime=}'[lifetime]:lifetime:(forever reboot)' \
  '(-D --delete)'{-D,--delete}'[delete master attribute]' \
  '(-G --query)'{-G,--query}'[query master attribute value]' \
  '(-v --value)'{-v,--value=}'[set master attribute value]:val:' \
  '*::crm_master args:_files' && ret=0
return ret
