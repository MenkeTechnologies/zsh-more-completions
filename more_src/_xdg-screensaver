#compdef xdg-screensaver
# _xdg-screensaver — XDG xdg-screensaver (control the screensaver/idle inhibitor for the current desktop session; suspend/resume blanking around a long-running task, reset the idle timer, lock/activate immediately, query status)
# upstream: https://gitlab.freedesktop.org/xdg/xdg-utils
# Subcommands from xdg-utils scripts/xdg-screensaver.in on tip.

_xdg-screensaver() {
    _arguments \
        '--help[show help]' \
        '--manual[show full manual]' \
        '--version[show version]' \
        '1:command:(suspend resume activate lock reset status)' \
        '*:window:'
}

_xdg-screensaver "$@"
