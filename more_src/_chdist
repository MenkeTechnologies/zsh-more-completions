#compdef chdist
# Documentation: https://manpages.debian.org/chdist
# Source: debian/devscripts scripts/chdist.pl — query different Debian/Ubuntu distros (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    {-h,--help}'[show help]' \
    '--version[show version]' \
    {-d+,--data-dir=}'[data directory]:dir:_files -/' \
    {-a+,--arch=}'[architecture]:arch:_default' \
    '1:command:(create apt apt-get apt-cache aptitude apt-rdepends src2bin bin2src compare-packages compare-bin-packages compare-versions compare-src-bin-packages compare-src-bin-versions grep-dctrl-packages grep-dctrl-sources list)' \
    '*::command args:_default' \
    && ret=0

return ret
