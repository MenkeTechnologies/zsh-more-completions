#compdef condor_release
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_release.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_release: release a held Condor job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-name[schedd]:name:' \
  '-pool[pool]:pool:' \
  '-addr[address]:sinful:' \
  '-all[release all jobs]' \
  '-constraint[constraint]:expr:' \
  '*:jobid:' && ret=0
return ret
