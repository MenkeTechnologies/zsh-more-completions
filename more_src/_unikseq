#compdef unikseq
# Documentation: https://github.com/bcgsc/unikseq
# identify unique/conserved regions via k-mer comparison of ingroup vs outgroup

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-r[reference FASTA sequence]:fasta:_files' \
  '-i[ingroup FASTA sequences or bloom filter]:fasta:_files' \
  '-o[outgroup FASTA sequences or bloom filter]:fasta:_files' \
  '-k[k-mer length]:length:' \
  '-l[leniency, min consecutive non-unique k-mers tolerated in outgroup]:leniency:' \
  '-m[max percentage of outgroup entries tolerated to have reference k-mer]:pct:' \
  '-t[print only first t bases in TSV output]:bases:' \
  '-c[output conserved FASTA regions]:flag:(0 1)' \
  '-s[minimum reference region size in bp to output]:size:' \
  '-p[minimum proportion of ingroup entries]:pct:' \
  '-u[minimum percentage of unique k-mers in regions]:pct:' \
  '-v[output TSV files]:flag:(0 1)' && ret=0

return ret
