#compdef doltgres
# Documentation: https://www.doltgres.com/docs/reference/server
# DoltgreSQL server - Git-for-data with PostgreSQL wire protocol

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--data-dir=[directory where databases are stored]:dir:_files -/' \
  '--config=[path to config.yaml configuration file]:config:_files' \
  '--host=[host address the server runs on]:host:_hosts' \
  '--port=[port the server runs on]:port' \
  '--timeout=[connection timeout in seconds]:seconds' \
  '--readonly[disable modification of the database]' \
  '--loglevel=[logging level]:level:(trace debug info warning error fatal)' \
  '--no-auto-commit[set @@autocommit = off for the server]' \
  '--max-connections=[number of connections handled by the server]:count' \
  '--socket=[path for the unix socket file]:socket:_files' && ret=0

return ret
