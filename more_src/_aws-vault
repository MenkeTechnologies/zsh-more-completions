#compdef aws-vault

# Zsh completion for aws-vault (AWS credential helper)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add credentials to the vault'
  'clear:clear temporary credentials from the session'
  'exec:execute a command with AWS credentials'
  'export:export credentials as environment variables'
  'list:list profiles (alias: ls)'
  'login:generate a login link for the AWS Console'
  'remove:remove credentials from the vault (alias: rm)'
  'rotate:rotate credentials'
)

_get_aws_profiles() {
  local -a profiles
  if [[ -f ~/.aws/config ]]; then
    profiles=(${(f)"$(grep '\[profile ' ~/.aws/config 2>/dev/null | sed 's/\[profile //' | sed 's/\]//')"})
  fi
  _describe -t profiles 'AWS profile' profiles
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debug[show debug output]' \
  '--backend[secret backend]:backend:(secret-service kwallet pass file keychain)' \
  '--prompt[prompt driver]:driver:(osascript kdialog zenity terminal)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'aws-vault command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (exec)
        _arguments \
          '(-d --duration)'{-d,--duration}'[duration of temporary credentials]:duration:' \
          '(-n --no-session)'{-n,--no-session}'[skip GetSessionToken]' \
          '--region[AWS region]:region:' \
          '(-t --mfa-token)'{-t,--mfa-token}'[MFA token]:token:' \
          '--json[output as JSON]' \
          '--server[run a credential server]' \
          '--lazy[get credentials lazily]' \
          '1:profile:_get_aws_profiles' \
          '*:command:_command_names -e' && ret=0
        ;;
      (login)
        _arguments \
          '(-d --duration)'{-d,--duration}'[duration of login session]:duration:' \
          '--region[AWS region]:region:' \
          '(-t --mfa-token)'{-t,--mfa-token}'[MFA token]:token:' \
          '(-n --no-session)'{-n,--no-session}'[skip GetSessionToken]' \
          '(-s --stdout)'{-s,--stdout}'[print URL to stdout]' \
          '1:profile:_get_aws_profiles' && ret=0
        ;;
      (add)
        _arguments \
          '--env[read credentials from environment]' \
          '1:profile:_get_aws_profiles' && ret=0
        ;;
      (remove|rm)
        _arguments \
          '(-f --force)'{-f,--force}'[force removal]' \
          '--sessions-only[only remove sessions]' \
          '1:profile:_get_aws_profiles' && ret=0
        ;;
      (rotate)
        _arguments \
          '(-n --no-session)'{-n,--no-session}'[skip GetSessionToken]' \
          '(-t --mfa-token)'{-t,--mfa-token}'[MFA token]:token:' \
          '1:profile:_get_aws_profiles' && ret=0
        ;;
      (export)
        _arguments \
          '(-d --duration)'{-d,--duration}'[duration]:duration:' \
          '--format[output format]:format:(export-env json ini)' \
          '(-n --no-session)'{-n,--no-session}'[skip GetSessionToken]' \
          '(-t --mfa-token)'{-t,--mfa-token}'[MFA token]:token:' \
          '1:profile:_get_aws_profiles' && ret=0
        ;;
      (list|ls)
        _arguments \
          '--profiles[show only profile names]' \
          '--sessions[show only session names]' \
          '--credentials[show only credentials]' && ret=0
        ;;
      (clear)
        _arguments '1:profile:_get_aws_profiles' && ret=0
        ;;
    esac
    ;;
esac

return ret
