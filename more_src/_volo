#compdef volo
# ---------------------------------------------------------------------------
# volo — high-performance RPC framework CLI by CloudWeGo / ByteDance (Rust, 2,597★)
#
# upstream: https://github.com/cloudwego/volo (volo-cli/)
# author : CloudWeGo team @ ByteDance
# license: Apache-2.0 OR MIT
#
# Source-direct completion: every subcommand and every flag below is verbatim
# from volo-cli/src/model.rs `RootCommand` clap-derive struct + the
# `define_commands!` macro expansions in init.rs, idl/mod.rs, repo/mod.rs,
# migrate.rs, http.rs on the volo tip.
#
# Direct deps from volo-cli/Cargo.toml:
#   tonic                  workspace dep   ← canonical Rust gRPC server +
#                                            client (this axis) — by the
#                                            tokio team (hyper foundation)
#   volo-build, pilota-thrift-parser       (volo's own scaffolding)
#   clap (derive, wrap_help)
#   colored, log, pretty_env_logger
#   update-informer                        (cargo crates.io version notifier)
#
# volo-cli scaffolds Thrift and gRPC service projects from IDL files (.thrift
# / .proto), either local or pulled from a git remote, and writes complete
# Cargo project layouts wired through volo-build's macros.
#
# === AXIS 162 OPENER — gRPC service framework ecosystem ===
# Axis position: Rust=217 OPENS Axis 162 at slot 1/0/0.  Canonical Rust gRPC
# framework is `tonic` by the tokio team — built on top of hyper + h2,
# providing async-stream-aware gRPC server and client with Tower middleware
# integration.  Used by Linkerd2 proxy, ButcherShop, lighthouse, foundationdb
# Rust client, OpenTelemetry exporters, BurntSushi-adjacent search backends,
# CloudWeGo volo, distributed-systems runtimes, blockchain RPC stacks.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=217   ← THIS FILE              (axis 162 OPENS, slot 1/0/0)
#   Go=217     ← next round              (axis 162 continues, slot 2/0/0)
#   TS-Node=217 ← round after            (axis 162 CLOSES at triple-217, slot 1/1/1)
# ---------------------------------------------------------------------------

_volo() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'init:init your thrift or grpc project'
        'repo:manage your IDL repositories (add/update)'
        'idl:manage your IDLs (add)'
        'migrate:migrate volo project metadata to a newer format'
        'http:HTTP RPC scaffolding (init)'
        'help:help for a subcommand'
    )

    _arguments -C \
        '*'{-v,--verbose}'[turn on verbose mode (repeatable)]' \
        '(-n --entry-name)'{-n,--entry-name=}'[entry name (default "default")]:entry name:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'volo command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                init)
                    _arguments \
                        '--repo=[git repo name for repo (e.g. cloudwego_volo)]:repo name:' \
                        '(-g --git)'{-g,--git=}'[git repo for idl (git@domain:path/repo.git)]:git url:' \
                        '(-r --ref)'{-r,--ref=}'[git repo ref/branch for idl (requires --git)]:ref:' \
                        '*'{-i,--includes=}'[include dirs for idl (repeatable)]:include dir:_files -/' \
                        '(-h --help)'{-h,--help}'[print help]' \
                        '1:project name:' \
                        '2:idl path (.thrift or .proto):_files -g "*.(thrift|proto)"' && ret=0
                    ;;
                idl)
                    local -a icmds
                    icmds=( 'add:add an IDL entry' )
                    _arguments -C \
                        '(-n --entry-name)'{-n,--entry-name=}'[entry name (default "default")]:entry name:' \
                        '(-h --help)'{-h,--help}'[print help]' \
                        '1: :->icmds' && ret=0
                    case $state in
                        icmds) _describe -t commands 'volo idl command' icmds && ret=0 ;;
                    esac
                    ;;
                repo)
                    local -a rcmds
                    rcmds=(
                        'add:add an IDL git repo'
                        'update:update an existing IDL git repo'
                    )
                    _arguments -C \
                        '(-n --entry-name)'{-n,--entry-name=}'[entry name (default "default")]:entry name:' \
                        '(-h --help)'{-h,--help}'[print help]' \
                        '1: :->rcmds' && ret=0
                    case $state in
                        rcmds) _describe -t commands 'volo repo command' rcmds && ret=0 ;;
                    esac
                    ;;
                migrate)
                    _arguments \
                        '(-h --help)'{-h,--help}'[print help]' && ret=0
                    ;;
                http)
                    local -a hcmds
                    hcmds=( 'init:init an HTTP RPC project' )
                    _arguments -C \
                        '(-h --help)'{-h,--help}'[print help]' \
                        '1: :->hcmds' && ret=0
                    case $state in
                        hcmds) _describe -t commands 'volo http command' hcmds && ret=0 ;;
                    esac
                    ;;
                help)
                    _describe -t commands 'volo command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_volo "$@"
