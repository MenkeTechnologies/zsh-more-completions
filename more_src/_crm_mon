#compdef crm_mon
# Documentation: https://www.mankier.com/8/crm_mon
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crm_mon: monitor Pacemaker cluster status
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-output[show output help]' \
  '(- *)--help-display[show display options]' \
  '(- *)--help-additional[show additional options]' \
  '(- *)--help-deprecated[show deprecated options]' \
  '(- *)'{-\$,--version}'[display software version]' \
  '*'{-V,--verbose}'[increase debug output]' \
  '(-Q --quiet)'{-Q,--quiet}'[be less descriptive in output]' \
  '--output-as=[output format]:fmt:(console html text xml none)' \
  '--output-to=[output file (- for stdout)]:file:_files' \
  '--html-cgi[add CGI headers (with --output-as=html)]' \
  '--html-stylesheet=[external stylesheet URI (with --output-as=html)]:uri:' \
  '--html-title=[page title (with --output-as=html)]:title:' \
  '(-I --include)'{-I+,--include=}'[include sections]:sections:' \
  '(-U --exclude)'{-U+,--exclude=}'[exclude sections]:sections:' \
  '--node=[filter to node or tag]:node:' \
  '--resource=[filter to resource or tag]:resource:' \
  '(-n --group-by-node)'{-n,--group-by-node}'[group resources by node]' \
  '(-r --inactive)'{-r,--inactive}'[display inactive resources]' \
  '(-f --failcounts)'{-f,--failcounts}'[display resource fail counts]' \
  '(-o --operations)'{-o,--operations}'[display resource operation history]' \
  '(-t --timing-details)'{-t,--timing-details}'[display operation history with timing]' \
  '(-c --tickets)'{-c,--tickets}'[display cluster tickets]' \
  '(-m --fence-history)'{-m+,--fence-history=}'[fence history level]:level:(0 1 2 3)' \
  '(-L --neg-locations)'{-L,--neg-locations}'[display negative location constraints]' \
  '(-A --show-node-attributes)'{-A,--show-node-attributes}'[display node attributes]' \
  '(-D --hide-headers)'{-D,--hide-headers}'[hide all headers]' \
  '(-R --show-detail)'{-R,--show-detail}'[show more details]' \
  '--show-description[show resource descriptions]' \
  '(-b --brief)'{-b,--brief}'[brief output]' \
  '(-i --interval)'{-i+,--interval=}'[update frequency]:timespec:' \
  '(-1 --one-shot)'{-1,--one-shot}'[display cluster status once and exit]' \
  '(-d --daemonize)'{-d,--daemonize}'[run in background as daemon]' \
  '(-p --pid-file)'{-p+,--pid-file=}'[pid file location]:file:_files' \
  '(-E --external-agent)'{-E+,--external-agent=}'[program to run during resource ops]:file:_files' \
  '(-e --external-recipient)'{-e+,--external-recipient=}'[recipient for external program]:rcpt:' \
  '(-W --watch-fencing)'{-W,--watch-fencing}'[listen for fencing events]' \
  '(-X --as-xml)'{-X,--as-xml}'[deprecated: write cluster status as XML]' && ret=0
return ret
