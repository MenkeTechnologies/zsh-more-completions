#compdef crm_mon
# Documentation: https://man.archlinux.org/search?q=crm_mon
# Reference accessed: 2026-05-16

# crm_mon: monitor cluster status
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '-Q[do not print headers]' \
  '--quiet[do not print headers]' \
  '-1[show one-shot output then exit]' \
  '--one-shot[show one-shot output then exit]' \
  '-d[run as daemon, write to file]' \
  '--daemonize[run as daemon, write to file]' \
  '-i[refresh interval in seconds]:seconds:' \
  '--interval=[refresh interval in seconds]:seconds:' \
  '-X[output in XML]' \
  '--xml-file=[XML state file]:file:_files' \
  '-h[HTML output file]:file:_files' \
  '--as-html=[HTML output file]:file:_files' \
  '-w[wrap text output for narrow terminals]' \
  '-A[group resources by node]' \
  '--group-by-node[group resources by node]' \
  '-r[show inactive resources]' \
  '--inactive[show inactive resources]' \
  '-R[show failure detail]' \
  '--show-detail[show failure detail]' \
  '-D[hide footer]' \
  '--disable-cib=[do not show CIB info]' \
  '-T[show tickets]' \
  '--tickets[show tickets]' \
  '-c[show cluster times]' \
  '--show-cluster-options[show cluster options]' \
  '-f[show fencing/stonith events]' \
  '--fence-history[show fencing history]' \
  '-n[group by node]' \
  '--node=[show only this node]:node:' \
  '-N[neat output]' \
  '--neat[neat output]' \
  '--output-as=[output format]:fmt:(console text html xml)' \
  '--output-to=[output file]:file:_files' \
  '*::crm_mon args:_files' && ret=0
return ret
