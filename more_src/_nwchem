#compdef nwchem
# Documentation: https://man.archlinux.org/search?q=nwchem
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '-np+[number of processes]:processes:' \
  '-nt+[number of threads]:threads:' \
  '1:input file:_files -g "*.nw"' \
  '*:file:_files' && ret=0

return ret
