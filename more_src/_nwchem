#compdef nwchem
# Documentation: https://nwchemgit.github.io/Getting-Started.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. nwchem takes a single input
# file (default extension .nw, default name nwchem.nw); no documented
# command-line option flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:input file:_files -g "*.nw"' \
  '*:file:_files' && ret=0

return ret
