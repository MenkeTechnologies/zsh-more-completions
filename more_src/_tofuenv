#compdef tofuenv

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:install OpenTofu version'
  'use:switch active version'
  'uninstall:remove an installed version'
  'list:list installed versions'
  'list-remote:list remotely available versions'
  'version-name:print active version'
  'pin:write current version to .opentofu-version'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tofuenv subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install|use|uninstall)
        _arguments ':version:(latest latest-allowed min-required)' && ret=0
        ;;
    esac
    ;;
esac

return ret
