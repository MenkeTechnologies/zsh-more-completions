#compdef showfeat
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/showfeat.html
# showfeat - Display features of a sequence in pretty format

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-sequence[input sequence(s)]:file:_files' \
  '-outfile[output file name]:file:_files' \
  '-sourcematch[filter features by source name]:source:' \
  '-typematch[filter features by type]:type:' \
  '-tagmatch[filter features by tag names]:tag:' \
  '-valuematch[filter features by tag values]:value:' \
  '-sort[sort features by Type/Start/Source/Nosort]:sort:(Type Start Source Nosort Join)' \
  '-joinfeatures[combine coding regions on a single line]' \
  '-annotation[regions to annotate with text labels]:annotation:' \
  '-html[generate HTML-formatted output]' \
  '-id[show sequence ID name]' \
  '-description[show sequence description]' \
  '-scale[show position scale line]' \
  '-width[display width in characters]:width:' \
  '-collapse[display overlapping features on single lines]' \
  '-forward[show forward strand features]' \
  '-reverse[show reverse strand features]' \
  '-unknown[show directionless features]' \
  '-strand[display strand orientation]' \
  '-sourceshow[display feature origin/source]' \
  '-position[display feature start/end coordinates]' \
  '-typeshow[show feature type]' \
  '-tagshow[display feature tags and values]' \
  '-valueshow[show tag values]' \
  '-stricttags[display only matching tag/value pairs]' \
  '-auto[turn off prompts]' \
  '-version[display version number]' \
  '*:sequence file:_files' && ret=0

return ret
