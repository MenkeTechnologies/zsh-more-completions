#compdef gotestdox
# Documentation: https://github.com/bitfield/gotestdox
# gotestdox: turn Go test names into readable sentences

local ret=1

# Any arguments are passed through to 'go test'; -run is the common filter.
_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '-run=[run only tests matching the regexp]:regexp' \
  '*:package:_files -/' && ret=0

return ret
