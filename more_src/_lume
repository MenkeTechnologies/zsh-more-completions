#compdef lume

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'build:build the site'
      'init:create a new lume project'
      'run:run a custom script'
      'serve:serve the site locally'
      'upgrade:upgrade lume to the latest version'
      'import-map:update import map file'
      'cms:start the CMS'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (build)
        _arguments \
          '--src=[source directory]:dir:_files -/' \
          '--dest=[destination directory]:dir:_files -/' \
          '--location=[URL location]:url:' \
          '--quiet[quiet output]' && ret=0
        ;;
      (serve)
        _arguments \
          '--src=[source directory]:dir:_files -/' \
          '--dest=[destination directory]:dir:_files -/' \
          '--port=[port number]:port:' \
          '--hostname=[hostname]:host:' \
          '--open[open in browser]' && ret=0
        ;;
      (init)
        _arguments \
          '--theme=[use a theme]:theme:' \
          '--plugins=[comma-separated plugins]:plugins:' \
          '1:directory:_files -/' && ret=0
        ;;
      (run)
        _arguments '1:script name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
