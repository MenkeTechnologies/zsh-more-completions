#compdef pageres

# Zsh completion for pageres-cli - capture website screenshots at various resolutions

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-d,--delay}'+[delay before capture in seconds]:seconds' \
  '--timeout+[timeout in seconds]:seconds' \
  {-c,--crop}'[crop to exact resolution]' \
  '--css+[inject custom CSS]:css' \
  '--selector+[capture specific element]:selector' \
  '--hide+[hide specific elements]:selector' \
  '--no-crop[do not crop]' \
  {-f,--filename}'+[output filename template]:template' \
  '--overwrite[overwrite existing files]' \
  '--format+[image format]:format:(png jpg)' \
  {-s,--scale}'+[scale factor]:factor' \
  '--cookie+[cookie string]:cookie' \
  '--header+[HTTP header]:header' \
  '--username+[authentication username]:username' \
  '--password+[authentication password]:password' \
  '--user-agent+[custom user agent string]:string' \
  '--transparent[transparent background]' \
  '--darkMode[enable dark mode]' \
  '*:url and resolution'
