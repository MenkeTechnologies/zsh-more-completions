#compdef oozie

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'job:manage individual job operations'
  'jobs:display status for multiple jobs'
  'admin:system administration tasks'
  'validate:validate workflow/coordinator/bundle XML'
  'sla:Service Level Agreement operations (deprecated)'
  'info:retrieve info about topics like timezones'
  'pig:submit pig jobs through HTTP'
  'hive:submit hive jobs through HTTP'
  'sqoop:submit sqoop jobs through HTTP'
  'mapreduce:submit MapReduce jobs'
  'mr:alias for mapreduce'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '-oozie+[Oozie server URL]:url:' \
  '-auth+[authentication type]:type:(SIMPLE BASIC KERBEROS)' \
  '-doas+[impersonate user]:user:_users' \
  '-timezone+[timezone]:tz:' \
  '-verbose[verbose output]' \
  '-debug[debug output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'oozie subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (job)
        _arguments \
          '-config+[job configuration file]:file:_files -g "*.xml"' \
          '-submit[submit a job]' \
          '-run[run a job]' \
          '-start+[start a submitted job]:jobId:' \
          '-suspend+[suspend a job]:jobId:' \
          '-resume+[resume a job]:jobId:' \
          '-kill+[kill a job]:jobId:' \
          '-change+[change a job]:jobId:' \
          '-rerun+[rerun a job]:jobId:' \
          '-info+[show job info]:jobId:' \
          '-log+[show job log]:jobId:' \
          '-errorlog+[show job error log]:jobId:' \
          '-auditlog+[show job audit log]:jobId:' \
          '-definition+[show job definition]:jobId:' \
          '-status+[show job status]:jobId:' \
          '-update+[update job]:jobId:' \
          '-poll+[poll job until status]:jobId:' \
          '-rerun_failed[rerun failed actions only]' \
          '-rerun_coord+[rerun coordinator]:jobId:' \
          '-rerun_action+[action numbers to rerun]:n:' \
          '-D+[set job parameter]:key=value:' \
          '*:job xml:_files -g "*.xml"' && ret=0
        ;;
      (jobs)
        _arguments \
          '-len+[number of jobs]:n:' \
          '-offset+[start offset]:n:' \
          '-filter+[filter (e.g. status=RUNNING)]:filter:' \
          '-jobtype+[job type]:type:(wf coordinator coord bundle)' \
          '-localtime[show in local time]' \
          '-kill[bulk kill]' \
          '-suspend[bulk suspend]' \
          '-resume[bulk resume]' && ret=0
        ;;
      (admin)
        _arguments \
          '-status[show server status]' \
          '-shutdown[shut down server]' \
          '-systemmode+[set system mode]:mode:(NORMAL NOWEBSERVICE SAFEMODE)' \
          '-version[show server version]' \
          '-queuedump[dump queue]' \
          '-list_sharelib[list share libs]' \
          '-update_sharelib[update share libs]' \
          '-purge[purge old jobs]' \
          '-instrumentation[show instrumentation data]' \
          '-metrics[show metrics]' \
          '-osenv[show OS env]' \
          '-systemproperties[show system properties]' \
          '-javasysprops[show Java system properties]' \
          '-configuration[show configuration]' && ret=0
        ;;
      (validate)
        _arguments \
          '*:XML file:_files -g "*.xml"' && ret=0
        ;;
      (info)
        _arguments \
          '-timezones[show available timezones]' && ret=0
        ;;
      (pig|hive|sqoop|mapreduce|mr)
        _arguments \
          '-config+[job config XML]:file:_files -g "*.xml"' \
          '-file+[script file]:file:_files' \
          '-Pkey=[set Pig param]:key=value:' \
          '-Dkey=[set property]:key=value:' && ret=0
        ;;
    esac
    ;;
esac

return ret
