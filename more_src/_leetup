#compdef leetup
# Documentation: https://github.com/dragfire/leetup/blob/master/src/cmd.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'user:authenticate'
  'pick:pick a problem'
  'list:list problems'
  'submit:submit a solution'
  'test:test a problem'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd) _describe -t commands 'leetup command' commands && ret=0 ;;
  args)
    case $words[1] in
      list)
        _arguments -s -S \
          '(-t --tag)'{-t+,--tag=}'[filter by tag]:tag:' \
          '(-q --query)'{-q+,--query=}'[query by conditions]:query:' \
          '(-s --stat)'{-s,--stat}'[show statistic counter]' \
          '(-o --order)'{-o+,--order=}'[order by]:order:(ProblemId Title Difficulty)' && ret=0
        ;;
      user)
        _arguments -s -S \
          '(-c --cookie)'{-c,--cookie}'[login using cookie]' \
          '(-l --logout)'{-l,--logout}'[logout]' && ret=0
        ;;
      pick)
        _arguments -s -S \
          '(-g --generate)'{-g,--generate}'[generate code]' \
          '(-d --def)'{-d,--def}'[include problem definition]' \
          '(-l --lang)'{-l+,--lang=}'[language]:lang:' \
          '*:problem id:' && ret=0
        ;;
      submit)
        _arguments -s -S \
          '*:file:_files' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(-t --test_data)'{-t+,--test_data=}'[custom test cases]:data:' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
