    local commands; commands=(
'setup:Generate a config file to be used with the other commands' \
'paths:Print paths to the config file and the data directory' \
'dev:Interact with the device' \
'update-mga:Make sure the MGA data is up to date' \
'completion:Generate shell completion' \
'help:Print this message or the help of the given subcommand(s)' \
