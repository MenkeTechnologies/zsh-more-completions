#compdef darker

# Zsh completion for darker - apply Black or isort only to changed lines

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version]' \
  '(-r --revision)'{-r,--revision}'[revision to compare against]:revision' \
  '--diff[print diff instead of writing changes]' \
  '--check[do not write changes, return non-zero if files would be reformatted]' \
  '(-i --isort)'{-i,--isort}'[run isort in addition to black]' \
  '(-L --lint)'{-L,--lint}'[run additional linter (e.g. flake8)]:lint command' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[reduce verbosity]' \
  '--color[force colored output]' \
  '(-W --workers)'{-W,--workers}'[number of parallel workers]:count' \
  '(-S --skip-string-normalization)'{-S,--skip-string-normalization}'[do not normalize string quotes]' \
  '--no-skip-string-normalization[normalize string quotes]' \
  '(-l --line-length)'{-l,--line-length}'[max line length]:length' \
  '(-t --target-version)'{-t,--target-version}'[python version]:version:(py33 py34 py35 py36 py37 py38 py39 py310 py311 py312)' \
  '--skip-magic-trailing-comma[skip magic trailing comma]' \
  '--stdin-filename[filename used for stdin]:filename:_files' \
  '*:file:_files' && ret=0

return ret
