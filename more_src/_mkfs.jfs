#compdef mkfs.jfs jfs_mkfs
# Documentation: https://man.archlinux.org/search?q=mkfs.jfs
# Reference accessed: 2026-05-16

_arguments -s \
  '-c[check device for bad blocks]' \
  '-j+[external journal device]:device:_files' \
  '-J+[journal options]:opts:' \
  '-L+[volume label]:label:' \
  '-O[case-insensitive (OS/2 compat)]' \
  '-q[quiet]' \
  '-s+[inline log size MB]:mb:' \
  '(- *)-V[show version]' \
  ':device:_files' \
  ':block-count:'
