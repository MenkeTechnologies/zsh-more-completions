# airtable-mcp-server — MCP over stdio; flags via `airtable-mcp-server --help`

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '--version[show version]' \
  '*:args:_default' && ret=0

return ret
