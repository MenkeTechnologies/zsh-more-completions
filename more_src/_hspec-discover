#compdef hspec-discover
# Documentation: https://hspec.github.io/hspec-discover.html
# Automatically discover and run Hspec tests

local ret=1

_arguments -s -S \
  '--nested[enable nested mode]' \
  '--formatter=[use the given formatter]:formatter' \
  '--module-name=[use a module name different from Main]:name' \
  '--no-main[do not generate a main function]' \
  '*:file:_files' && ret=0

return ret
