#compdef kismet_cap_linux_wifi kismet_cap_linux_bluetooth kismet_cap_rtl433 kismet_cap_rtl_433 kismet_cap_rtladsb kismet_cap_rtlamr kismet_cap_freaklabs_zigbee kismet_cap_nrf_mousejack kismet_cap_nxp_kw41z
# _kismet-cli — Kismet capture drivers (per-protocol capture binaries (Wi-Fi, Bluetooth, rtl_433, ADS-B, ZigBee, etc.) that the modern kismet(8) daemon launches over its capture-control protocol; --connect URI for remote drone, --source source spec, --user/--password authentication, --uuid override, --help, --version; intended to be invoked by kismet rather than directly)
# upstream: https://github.com/kismetwireless/kismet (capture_*)
# Common flags from kismet capture_*/main.c on tip.

_kismet-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--connect+[remote URI]:uri:' \
        '--source+[source spec]:spec:' \
        '--user+[user]:user:_users' \
        '--password+[password]:password:' \
        '--uuid+[uuid]:uuid:' \
        '--config+[config file]:file:_files'
}

_kismet-cli "$@"
