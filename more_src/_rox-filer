#compdef rox rox-filer
# Documentation: https://man.archlinux.org/search?q=rox
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --new)'{-n,--new}'[force new instance]' \
  '(-N --no-session)'{-N,--no-session}'[do not connect to session]' \
  '(-d --dir)'{-d,--dir}'[treat args as dirs]' \
  '(-D --close)'{-D,--close}'[close window for dir]:dir:_files -/' \
  '(-t --top)'{-t,--top}'+[open as pinboard top]:file:_files' \
  '(-b --bottom)'{-b,--bottom}'+[panel at bottom]:name:' \
  '(-l --left)'{-l,--left}'+[panel at left]:name:' \
  '(-r --right)'{-r,--right}'+[panel at right]:name:' \
  '(-p --pinboard)'{-p,--pinboard}'+[pinboard name]:name:' \
  '(-o --override)'{-o,--override}'[use override-redirect]' \
  '(-x --examine)'{-x,--examine}'+[re-examine file]:file:_files' \
  '(-s --show)'{-s,--show}'+[show file in parent]:file:_files' \
  '(-S --rpc)'{-S,--rpc}'[run as RPC server]' \
  '(-R --RPC)'{-R,--RPC}'[invoke RPC method from stdin]' \
  '(-U --user)'{-U,--user}'[include username in IPC name]' \
  '*:path:_files' && ret=0

return ret
