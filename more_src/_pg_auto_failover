#compdef pg_auto_failover pg_autoctl
# _pg_auto_failover — Citus Data pg_auto_failover pg_autoctl CLI command-line frontend wrapping the pg_auto_failover automated failover automation extension for PostgreSQL implementing two-node and three-node clusters with monitor node primary secondary replication promotion election-state-machine-restore-replica-creation-coordination (Citus Data team, C); custom argparse
# upstream: https://pg-auto-failover.readthedocs.io/

_pg_auto_failover() {
    local -a sub=(
        'create:create a node'
        'destroy:destroy a node'
        'drop:drop a node'
        'enable:enable a feature'
        'disable:disable a feature'
        'show:show state'
        'set:set configuration'
        'get:get configuration value'
        'config:configuration'
        'do:do a manual action'
        'run:run a node'
        'reload:reload configuration'
        'stop:stop a node'
        'restart:restart a node'
        'watch:watch state changes'
        'perform:perform manual action'
        'fsm:state-machine operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--pgdata=+[dir]:dir:_files -/' \
        '--monitor=+[uri]:str:' \
        '--hostname=+[host]:_hosts' \
        '--pgport=+[port]:n:' \
        '--listen=+[addr]:str:' \
        '--nodename=+[name]:str:' \
        '--name=+[name]:str:' \
        '--ssl-self-signed[ssl self-signed]' \
        '--ssl-ca-file=+[file]:file:_files' \
        '--ssl-crl-file=+[file]:file:_files' \
        '--no-ssl[no SSL]' \
        '--server-cert=+[file]:file:_files' \
        '--server-key=+[file]:file:_files' \
        '--candidate-priority=+[N]:n:' \
        '--replication-quorum=+[bool]:s:(true false)' \
        '--auth=+[method]:str:' \
        '--username=+[user]:str:' \
        '--dbname=+[name]:str:' \
        '--formation=+[name]:str:' \
        '--group=+[id]:str:' \
        '--node-id=+[id]:str:' \
        '--watch[watch mode]' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pg_auto_failover subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments '1:node-type:(monitor postgres formation)' ;;
                show) _arguments '1:resource:(state events nodes settings uri logs config)' ;;
                do) _arguments '1:action:(promote failover restart restore stop reload start drain enable disable maintenance)' ;;
            esac
            ;;
    esac
}

_pg_auto_failover "$@"
