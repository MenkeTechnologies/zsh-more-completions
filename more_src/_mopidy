#compdef mopidy

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--save-debug-log[save debug log]' \
  '*--config=[config file or dir]:path:_files' \
  '*'{-o,--option=}'[override config]:section/key=value:' \
  ':subcommand:(config deps local)'
