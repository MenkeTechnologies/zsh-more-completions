#compdef kubectl-pod-lens
# Documentation: https://github.com/sunny0826/kubectl-pod-lens
# kubectl-pod-lens - kubectl plugin to show pod-related resources

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[query all objects in all API groups]' \
  '(-l --selector)'{-l,--selector}'=[selector (label query) to filter on]:selector' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace' \
  '--context=[name of the kubeconfig context to use]:context' \
  '--kubeconfig=[path to the kubeconfig file to use]:file:_files' \
  '*:pod name:' && ret=0

return ret
