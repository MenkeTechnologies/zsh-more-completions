#compdef marktext mark-text

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '--debug[enable debug mode]' \
  '--safe[disable plugins and user config]' \
  '(-n --new-window)'{-n,--new-window}'[open new window]' \
  '--user-data-dir=[user data dir]:dir:_files -/' \
  '--disable-gpu[disable GPU acceleration]' \
  '*: :_files -g "*.md *.markdown *.mdown *.mkd *.txt"' && ret=0

return ret
