#compdef fish-indent

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--ansi[colorize output with ANSI escape sequences]' \
  '--html[output HTML]' \
  '(-i --no-indent)'{-i,--no-indent}'[do not indent output]' \
  '(-w --write)'{-w,--write}'[write to file in-place]' \
  '(-c --check)'{-c,--check}'[check if file is already indented]' \
  '--dump-parse-tree[dump the parse tree as JSON]' \
  '--dump-grouping[dump the grouping information]' \
  '*:file:_files' && ret=0

return ret
