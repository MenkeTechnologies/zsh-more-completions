#compdef eld eldarica
# _eldarica — Eldarica: Constrained Horn Clause (CHC) model checker
# upstream: https://github.com/uuverifiers/eldarica
# Flags from src/main/scala/lazabs/Main.scala (single-dash, GNU-style not supported).

_eldarica() {
    local -a args
    args=(
        '-horn[input is Horn clauses]'
        '-in[read input from stdin]'
        '-hin[input format: Prolog Horn syntax]'
        '-hsmt[input format: SMT-LIB Horn]'
        '-ints[input format: NTS]'
        '-cex[print a plain counterexample on failure]'
        '-dotCEX[render counterexample as a PNG (requires graphviz)]'
        '-eogCEX[open counterexample PNG with eog]'
        '-pngNo[do not render counterexample PNG]'
        '-sol[print Prolog-style solution]'
        '-ssol[print SMT-LIB solution]'
        '-solutionReconstruction:wp[reconstruct solution via weakest-precondition]'
        '-solutionReconstruction:cegar[reconstruct solution via CEGAR]'
        '-sym[run symbolic execution]'
        '-sym:[symex engine]:engine:(depthFirst breadthFirst random)'
        '-symDepth:[max symbolic-execution depth]:depth:'
        '-portfolio[run several configurations in parallel]'
        '-abstract[enable template-based abstraction]'
        '-abstractPO[abstract with parameterized objects]'
        '-abstract:manual[manual templates]'
        '-abstract:term[term-only templates]'
        '-abstract:oct[octagon templates]'
        '-abstract:relEqs[relational equalities]'
        '-abstract:relEqs2[relational equalities (variant 2)]'
        '-abstract:relIneqs[relational inequalities]'
        '-abstract:relIneqs2[relational inequalities (variant 2)]'
        '-abstract:off[disable template abstraction]'
        '-abstractTO:[abstraction timeout in ms]:ms:'
        '-hints:[load template hints from FILE]:file:_files'
        '-postHints:[load post-condition hints from FILE]:file:_files'
        '-pPredicates:[print discovered predicates to FILE]:file:_files'
        '-pHints[print template hints]'
        '-minePredicates[mine new predicates during refinement]'
        '-splitClauses:[clause-splitting mode]:mode:'
        '-glb[use global predicate abstraction]'
        '-disj[disjunctive interpolation]'
        '-lbe[large-block encoding]'
        '-arrayQuans:[array quantifier handling]:mode:(off on)'
        '-heapSolver:[heap solver]:solver:(native array)'
        '-cloneArrays[clone arrays in encoding]'
        '-noSlicing[disable slicing optimisation]'
        '-noIntervals[disable interval analysis]'
        '-fairNIASplitting[enable fair NIA splitting]'
        '-princess[use Princess as the SMT solver backend]'
        '-stac[static accelerate]'
        '-dynac[dynamic accelerate]'
        '-unap[under-approximate]'
        '-tem[enable template generation]'
        '-dinq[dump interpolation queries]'
        '-brew[enable babarew]'
        '-t:[overall timeout in seconds]:secs:'
        '-m:[entry function name (for non-Horn input)]:name:'
        '-s:[solution output file]:file:_files'
        '-log[enable info-level logging]'
        '-statistics[print statistics]'
        '-log:[log level]:level:(info warn error)'
        '-logSimplified[log the simplified Horn clauses]'
        '-logSimplifiedSMT[log the simplified Horn clauses as SMT-LIB]'
        '-logPreds:[log predicates for the given function]:fn:'
        '-pIntermediate[print intermediate clause sets]'
        '-sp[pretty-print SMT output]'
        '-p[pretty-print]'
        '-f[print abstraction-in file]'
        '-n[disable spuriousness checks]'
        '*:input file:_files -g "*.(smt2|smt|nts|pl|c)"'
    )
    _arguments -s -S $args
}

_eldarica "$@"
