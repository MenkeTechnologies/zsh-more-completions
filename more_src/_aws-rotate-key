#compdef aws-rotate-key
# Documentation: https://github.com/stefansundin/aws-rotate-key
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# https://github.com/stefansundin/aws-rotate-key — rotate AWS IAM access keys in ~/.aws/credentials

_arguments -s -S \
  '-auth-profile=[profile for AWS API calls]:profile:' \
  '-profile=[profile to rotate keys for]:profile:' \
  '-d[delete old key instead of deactivating]' \
  '-mfa[prompt for MFA]' \
  '-mfa-serial-number=[MFA device ARN]:arn:' \
  '-y[assume yes to prompts]' \
  '-version[print version]' && return 0
