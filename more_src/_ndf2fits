#compdef ndf2fits
# Documentation: https://starlink.eao.hawaii.edu/docs/sun55.htx/sun55ss14.html
# CONVERT NDF2FITS - convert NDFs into FITS files

local ret=1

_arguments -C \
  'IN=[NDFs to be converted into FITS]:NDF file:_files' \
  'OUT=[output FITS files]:FITS file:_files' \
  'ALLOWTAB=[write WCS using the TAB algorithm]:flag:(TRUE FALSE)' \
  'AXISORDER=[order of WCS axes in the FITS header]:order:' \
  'BITPIX=[FITS bits-per-pixel value]:bitpix:(8 16 32 -32 -64)' \
  'CHECKSUM=[add integrity-check keywords]:flag:(TRUE FALSE)' \
  'COMP=[array components to transfer]:component:(Data Variance Quality)' \
  'CONTAINER=[inputs are multi-NDF HDS containers]:flag:(TRUE FALSE)' \
  'DUPLEX=[airlock header propagation for multiple components]:flag:(TRUE FALSE)' \
  'ENCODING=[WCS encoding scheme]:encoding:' \
  'NATIVE=[write WCS using native AST encoding]:flag:(TRUE FALSE)' \
  'MERGE=[merge airlock headers from UKIRT containers]:flag:(TRUE FALSE)' \
  'ORIGIN=[value for the ORIGIN keyword]:origin:' \
  'PROEXTS=[propagate NDF extensions as binary-table sub-files]:flag:(TRUE FALSE)' \
  'PROFITS=[merge NDF FITS extension into headers]:flag:(TRUE FALSE)' \
  'PROHIS=[write NDF history as FITS HISTORY cards]:flag:(TRUE FALSE)' \
  'PROVENANCE=[export NDF provenance information]:flag:(TRUE FALSE)' \
  'USEAXIS=[export AXIS coordinates to alternate WCS]:flag:(TRUE FALSE)' \
  '*:NDF file:_files' && ret=0

return ret
