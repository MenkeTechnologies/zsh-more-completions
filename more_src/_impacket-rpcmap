#compdef impacket-rpcmap
# Documentation: https://github.com/fortra/impacket/blob/master/examples/rpcmap.py
# Lookups listening MSRPC interfaces

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-brute-uuids[bruteforce UUIDs even if MGMT interface is available]' \
  '-brute-opnums[bruteforce opnums for found UUIDs]' \
  '-brute-versions[bruteforce major versions of found UUIDs]' \
  '-opnum-max=[bruteforce opnums from 0 to N, default 64]:n' \
  '-version-max=[bruteforce versions from 0 to N, default 64]:n' \
  '-auth-level=[MS-RPCE auth level, from 1 to 6, default 6]:level' \
  '-uuid=[test only this UUID]:uuid' \
  '-debug[turn DEBUG output ON]' \
  '-ts[adds timestamp to every logging output]' \
  '-target-ip=[IP address of the target machine]:ip' \
  '-port=[destination port to connect to SMB server]:port:(139 445)' \
  '-auth-rpc=[\[domain/\]username\[:password\]]:creds' \
  '-auth-transport=[\[domain/\]username\[:password\]]:creds' \
  '-hashes-rpc=[NTLM hashes, format is LMHASH:NTHASH]:hashes' \
  '-hashes-transport=[NTLM hashes, format is LMHASH:NTHASH]:hashes' \
  '-no-pass[don'\''t ask for passwords]' \
  '1:stringbinding (e.g. ncacn_ip_tcp\:192.168.0.1\[135\]):' && ret=0

return ret
