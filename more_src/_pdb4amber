#compdef pdb4amber
# Documentation: https://ambermd.org/AmberTools.php
# clean and prepare PDB files for the Amber LEaP programs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --in)'{-i,--in}'+[PDB input file]:file:_files -g "*.pdb"' \
  '(-o --out)'{-o,--out}'+[PDB output file]:file:_files -g "*.pdb"' \
  '(-y --nohyd)'{-y,--nohyd}'[remove all hydrogen atoms]' \
  '(-d --dry)'{-d,--dry}'[remove all water molecules]' \
  '(-p --prot)'{-p,--prot}'[keep only Amber-compatible residues]' \
  '--noter[remove TER, MODEL, ENDMDL cards]' \
  '--constantph[rename GLU,ASP,HIS for constant pH simulation]' \
  '--most-populous[keep most populous alternate conformation]' \
  '--keep-altlocs[keep alternative conformations]' \
  '--reduce[run Reduce first to add hydrogens]' \
  '--pdbid[fetch structure with given pdbid]' \
  '--add-missing-atoms[use tleap to add missing atoms]' \
  '--model[model to use from a multi-model pdb file]:integer:' \
  '(-l --logfile)'{-l,--logfile}'+[log filename]:file:_files' \
  '*:PDB file:_files -g "*.pdb"' && ret=0

return ret
