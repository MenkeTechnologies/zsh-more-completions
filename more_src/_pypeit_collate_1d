#compdef pypeit_collate_1d
# Documentation: https://pypeit.readthedocs.io/en/release/scripts.html
# Flux/Coadd multiple 1d spectra from multiple nights

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '*--spec1d_files=[one or more spec1d files to flux/coadd/archive]:file:_files' \
  '--par_outfile=[output to save the parameters]:file:_files' \
  '--outdir=[path for coadded output and report files]:dir:_files -/' \
  '--spec1d_outdir=[path for modified spec1d files]:dir:_files -/' \
  '--tolerance=[tolerance when comparing object coordinates]:tolerance' \
  '--match_using=[how 1D spectra are matched]:match:(pixel ra/dec)' \
  '--dry_run[display matches without flux/coadd/archive]' \
  '--ignore_flux[only coadd non-fluxed spectra]' \
  '--flux[flux calibrate using archived sensfuncs before coadding]' \
  '--exclude_slit_trace_bm=[slit trace bitmask bits to exclude]:bits' \
  '--exclude_serendip[exclude SERENDIP objects from collating]' \
  '--wv_rms_thresh=[skip objects with wavelength RMS above this value]:thresh' \
  '--refframe=[reference frame correction prior to coadding]:frame:(observed heliocentric barycentric)' \
  '--chk_version[enforce strict PypeIt version checking]' \
  '*:input file:_files' && ret=0

return ret
