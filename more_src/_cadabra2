#compdef cadabra2
# Computer algebra system for field theory (tensor algebra)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--input[input file]:file:_files' \
  '--output[output file]:file:_files' \
  '--silent[suppress output]' \
  '--jupyter[run as Jupyter kernel]' \
  '*:notebook file:_files -g "*.(cnb|cdb)"' \
  && return 0
