#compdef gt5
# Documentation: https://gt5.sourceforge.net/
# gt5 - a diff-capable du-browser

local ret=1

_arguments -s -S \
  '--help[display brief help information]' \
  '--cut-at=[do not show files below percentage of parent]:percent' \
  '--diff-dir=[directory to store diffs between runs]:dir:_files -/' \
  '--discard[do not save current run for diff comparison]' \
  '--save-state[force saving current state]' \
  '--no-diffs[disable diff functionality]' \
  '--link-files[insert links to files for direct access]' \
  '--max-depth=[ignore directories deeper than level]:depth' \
  '--max-lines=[only consider the N biggest files]:lines' \
  '--with-mounts[include filesystem content below mountpoints]' \
  '--debug[generate HTML without launching browser]' \
  '--verbose[display informational messages]' \
  '--get-gawk[download and install gawk]' \
  '--get-links[download and install links browser]' \
  '--get-links2[download and install links2 browser]' \
  '--get-elinks[download and install elinks browser]' \
  '*:path:_files' && ret=0

return ret
