#compdef nix-cli2
# _nix-cli2 — Eelco Dolstra NixOS nix-cli2 CLI command-line frontend wrapping the Nix CLI new unified command-line interface for the Nix purely functional package manager open-source written in C++ originally Eelco Dolstra now NixOS Foundation Determinate Systems nix command nix flake nix profile nix run nix shell nix develop nix build nix log nix path-info nix copy nix store nix nixpkgs Nix-flakes-experimental Flake derivation nar registry hash bundle daemon eval doctor edit search show-config show-derivation upgrade-nix version why-depends repl key fmt sigs upload help (Eelco Dolstra NixOS Foundation team, C++); custom argparse
# upstream: https://nixos.org/

_nix-cli2() {
    local -a sub=(
        'build:build packages'
        'bundle:bundle into binary'
        'config:Nix configuration'
        'copy:copy paths'
        'daemon:run as daemon'
        'derivation:derivation operations'
        'develop:enter dev shell'
        'doctor:diagnose system'
        'edit:edit a package'
        'env:env operations'
        'eval:evaluate expr'
        'flake:flake operations'
        'fmt:format Nix files'
        'hash:hash operations'
        'help:show help'
        'help-stores:list stores'
        'key:signing key ops'
        'log:show build log'
        'nar:NAR operations'
        'path-info:show store path info'
        'print-dev-env:print dev env'
        'profile:profile operations'
        'realisation:CA realisation'
        'registry:flake registry ops'
        'repl:open Nix REPL'
        'run:run a package'
        'search:search packages'
        'shell:enter shell with packages'
        'show-config:show config'
        'show-derivation:show derivation'
        'sigs:signature ops'
        'store:store operations'
        'upgrade-nix:upgrade Nix'
        'upload:upload to store'
        'version:show version'
        'why-depends:why depends'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-vvv[more verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--log-format=+[f]:f:(raw internal-json bar bar-with-logs)' \
        '--print-build-logs[print build logs]' \
        '-L[print build logs]' \
        '--print-trace[print trace]' \
        '--show-trace[show trace]' \
        '--store=+[uri]:str:' \
        '--max-jobs=+[N]:n:' \
        '-j+[jobs]:n:' \
        '--cores=+[N]:n:' \
        '--system=+[arch]:str:' \
        '--extra-system-features=+[features]:str:' \
        '--substituters=+[uris]:str:' \
        '--option=+[k v]:str:' \
        '*--option=+[k v]:str:' \
        '--experimental-features=+[features]:str:' \
        '*--experimental-features=+[features]:str:' \
        '--extra-experimental-features=+[features]:str:' \
        '--include-trusted=+[v]:v:(true false)' \
        '--refresh[refresh cache]' \
        '--no-substitute[no substitute]' \
        '--substitute[substitute]' \
        '--no-link[no link]' \
        '--no-update-lock-file[no update lock]' \
        '--no-write-lock-file[no write lock]' \
        '--no-allow-dirty[no allow dirty]' \
        '--allow-dirty[allow dirty]' \
        '--keep-going[keep going]' \
        '-k[keep going]' \
        '--keep-failed[keep failed]' \
        '--no-build-output[no build output]' \
        '--repair[repair store paths]' \
        '--rebuild[rebuild]' \
        '--accept-flake-config[accept flake config]' \
        '--commit-lock-file[commit lock file]' \
        '--inputs-from=+[ref]:str:' \
        '--update-input=+[name]:str:' \
        '*--update-input=+[name]:str:' \
        '--override-input=+[name=flake]:str:' \
        '*--override-input=+[name=flake]:str:' \
        '--out-link=+[path]:_files' \
        '-o+[out link]:_files' \
        '--profile=+[name]:str:' \
        '--print-out-paths[print out paths]' \
        '--installable=+[ref]:str:' \
        '--file=+[file]:file:_files -g "*.nix"' \
        '-f+[file]:file:_files -g "*.nix"' \
        '-E+[expression]:str:' \
        '--expr=+[expr]:str:' \
        '--apply=+[fn]:str:' \
        '--arg=+[k=v]:str:' \
        '*--arg=+[k=v]:str:' \
        '--argstr=+[k=v]:str:' \
        '*--argstr=+[k=v]:str:' \
        '--include=+[path]:_files' \
        '*-I+[path]:_files' \
        '--json[JSON output]' \
        '--raw[raw]' \
        '--xml[XML]' \
        '--strict[strict]' \
        '--read-only[read only]' \
        '--no-stack-trace[no stack trace]' \
        '--all[all]' \
        '--available[show available]' \
        '--installed[show installed]' \
        '--out-paths[show out paths]' \
        '--exclude=+[regex]:str:' \
        '*--exclude=+[regex]:str:' \
        '--match=+[regex]:str:' \
        '--regex[use regex]' \
        '--no-eval-cache[no eval cache]' \
        '--eval-cache[eval cache]' \
        '--add-root=+[path]:_files' \
        '--gc[GC]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nix subcommand' sub ;;
        args)
            case $words[1] in
                flake) _arguments '1:op:(archive check clone info init lock metadata new prefetch show update)' '*:arg:' ;;
                profile) _arguments '1:op:(install remove upgrade list rollback wipe-history history diff-closures)' '*:arg:' ;;
                store) _arguments '1:op:(add add-file add-path cat copy-log delete diff-closures dump-path gc info ls make-content-addressable optimise path-from-hash-part prefetch-file ping repair sign verify)' '*:arg:' ;;
                registry) _arguments '1:op:(list add remove pin)' '*:arg:' ;;
                hash) _arguments '1:op:(file path to-base16 to-base32 to-base64 to-sri md5 sha1 sha256 sha512)' '*:arg:' ;;
                key) _arguments '1:op:(generate-secret convert-secret-to-public)' '*:arg:' ;;
                build|run|shell|develop|search|log|path-info|edit|why-depends|copy|nar|bundle|sigs|repl) _arguments '*:installable:' ;;
            esac
            ;;
    esac
}

_nix-cli2 "$@"
