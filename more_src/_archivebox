#compdef archivebox

local -a subcommands
subcommands=(
  'help:Show help'
  'version:Show version'
  'init:Initialize a new archive collection'
  'info:Show info about the archive collection'
  'config:Get or set configuration values'
  'setup:Install dependencies and setup the collection'
  'add:Add new URLs to the archive'
  'remove:Remove URLs from the archive'
  'update:Re-archive URLs that have been previously added'
  'list:List archived URLs'
  'shell:Open an interactive shell'
  'server:Run the archive web server'
  'manage:Run Django management commands'
  'schedule:Set up scheduled archiving'
  'status:Show the status of the archive'
  'oneshot:Archive a single URL without adding it to the collection'
)

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--quiet[suppress output]' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      add)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--quiet[suppress output]' \
          '--update-all[update all existing snapshots]' \
          '--index-only[only add to index without archiving]' \
          '--overwrite[overwrite existing snapshots]' \
          '--init[initialize collection if needed]' \
          '--extractors=[comma-separated list of extractors to use]:extractors' \
          '--depth=[recursion depth]:depth:(0 1)' \
          '--tag=[comma-separated list of tags]:tags' \
          '--parser=[parser to use for input]:parser:(auto pocket_html pinboard_rss wallabag_atom shaarli_rss medium_rss netscape_html generic_rss generic_json generic_html generic_txt url_list)' \
          '*:URLs or file:_files'
        ;;
      server)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--quiet[suppress output]' \
          '--reload[enable auto-reload on code changes]' \
          '--init[initialize collection if needed]' \
          '--port=[port to listen on]:port' \
          '--host=[address to bind to]:host' \
          '--createsuperuser[create an admin user on startup]' \
          '--quick-init[quick initialization]' \
          '--debug[enable debug mode]'
        ;;
      list)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--quiet[suppress output]' \
          '--csv[output as CSV]' \
          '--json[output as JSON]' \
          '--html[output as HTML]' \
          '--with-headers[include column headers]' \
          '--sort=[sort order]:sort field:(bookmarked_date downloaded_date title url)' \
          '--before=[only show entries before date]:date' \
          '--after=[only show entries after date]:date' \
          '--status=[filter by status]:status:(indexed archived unarchived)' \
          '--filter-type=[filter match type]:filter type:(exact substring regex domain tag search)' \
          '--filter=[filter text]:text'
        ;;
      remove)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--quiet[suppress output]' \
          '*:filter'
        ;;
      update)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--quiet[suppress output]' \
          '*:filter'
        ;;
      init)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--quiet[suppress output]'
        ;;
      config)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--quiet[suppress output]' \
          '*:key=value'
        ;;
      schedule)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--quiet[suppress output]'
        ;;
      info|status|setup|version|help|shell|manage|oneshot)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--quiet[suppress output]'
        ;;
    esac
    ;;
esac
