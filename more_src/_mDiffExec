#compdef mDiffExec
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mDiffExec.html
# Run mDiff on all overlap pairs listed in a difference table

local ret=1

_arguments -s -S \
  '-p+[directory containing reprojected input images]:projdir:_files -/' \
  '-d[enable debugging]' \
  '-n[no-area-images flag]' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '1:diffs table:_files -g "*.tbl"' \
  '2:header template:_files' \
  '3:diff directory:_files -/' && ret=0

return ret
