#compdef gforth
# Documentation: gforth --help (GNU Forth)
# Source: ANSI Forth implementation.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '--appl-image=[application image file]:file:_files' \
    '--clear-dictionary[initialise dictionary with 0 bytes]' \
    '(-d --data-stack-size)'{-d+,--data-stack-size=}'[data stack size]:size:' \
    '--debug[debug startup info]' \
    '--diag[diagnostic startup info]' \
    '--die-on-signal[exit instead of THROW]' \
    '(--dynamic --no-dynamic)--dynamic[dynamic native code]' \
    '(--dynamic --no-dynamic)--no-dynamic[statically compiled primitives only]' \
    '(-f --fp-stack-size)'{-f+,--fp-stack-size=}'[FP stack size]:size:' \
    '--ignore-async-signals[ignore async signals]' \
    '(-i --image-file)'{-i+,--image-file=}'[image file]:file:_files' \
    '(-l --locals-stack-size)'{-l+,--locals-stack-size=}'[locals stack size]:size:' \
    '(-m --dictionary-size)'{-m+,--dictionary-size=}'[dictionary size]:size:' \
    '--no-offset-im[load image at normal position]' \
    '--no-super[no superinstructions]' \
    '--offset-image[load image at different position]' \
    '(-p --path)'{-p+,--path=}'[search path]:path:' \
    '--print-metrics[print code-gen metrics on exit]' \
    '--print-sequences[print primitive sequences for optimisation]' \
    '(-r --return-stack-size)'{-r+,--return-stack-size=}'[return stack size]:size:' \
    '--ss-greedy[greedy superinst selection]' \
    '--ss-min-codesize[smallest native code]' \
    '--ss-min-ls[minimise loads/stores]' \
    '--ss-min-lsu[minimise loads/stores/updates]' \
    '--ss-min-nexts[minimise static superinsts]' \
    '--ss-number=[N static superinsts]:n:' \
    '--ss-states=[N stack-caching states]:n:' \
    '*:Forth source:_files -g "*.(fs|fth|4th)"' \
    && ret=0

return ret
