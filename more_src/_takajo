#compdef takajo
# Documentation: https://github.com/Yamato-Security/takajo
# Takajo - Hayabusa results analyzer (DFIR timeline analysis)

local ret=1
local -a commands

commands=(
  'automagic:execute as many commands as possible'
  'extract-scriptblocks:extract PowerShell script blocks'
  'html-report:create an HTML report'
  'html-server:serve an HTML report'
  'list-domains:list domains'
  'list-hashes:list hashes'
  'list-ip-addresses:list IP addresses'
  'list-undetected-evtx:list EVTX files with no detections'
  'list-unused-rules:list rules with no detections'
  'split-csv-timeline:split a CSV timeline by computer'
  'split-json-timeline:split a JSONL timeline by computer'
  'stack-cmdlines:stack command lines'
  'stack-computers:stack computers'
  'stack-dns:stack DNS queries'
  'stack-ip-addresses:stack IP addresses'
  'stack-logons:stack logons'
  'stack-processes:stack processes'
  'stack-services:stack services'
  'stack-tasks:stack scheduled tasks'
  'stack-users:stack users'
  'sysmon-process-tree:print a Sysmon process tree'
  'timeline-logon:create a logon timeline'
  'timeline-partition-diagnostic:create a partition diagnostic timeline'
  'timeline-suspicious-processes:create a suspicious processes timeline'
  'timeline-tasks:create a scheduled tasks timeline'
  'ttp-summary:summarize MITRE ATT&CK TTPs'
  'ttp-visualize:visualize TTPs'
  'ttp-visualize-sigma:visualize TTPs from sigma'
  'vt-domain-lookup:VirusTotal domain lookup'
  'vt-hash-lookup:VirusTotal hash lookup'
  'vt-ip-lookup:VirusTotal IP lookup'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --timeline)'{-t,--timeline}'=[Hayabusa JSONL timeline file or directory]:file:_files' \
  '(-o --output)'{-o,--output}'=[output file or directory]:path:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress the launch banner]' \
  '(-s --skipProgressBar)'{-s,--skipProgressBar}'[disable the progress bar]' \
  '(-l --level)'{-l,--level}'=[minimum alert level threshold]:level' \
  '(-r --rulepath)'{-r,--rulepath}'=[path to Hayabusa rules directory]:dir:_files -/' \
  '(-a --apiKey)'{-a,--apiKey}'=[VirusTotal API key]:key' \
  '(-p --port)'{-p,--port}'=[web server port]:port' \
  '(-d --displayTable)'{-d,--displayTable}'[display results in table format]' \
  '(-m --makeMultiline)'{-m,--makeMultiline}'[output fields across multiple lines]' \
  '(-C --clobber)'{-C,--clobber}'[overwrite existing output]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds) _describe -t commands 'takajo command' commands && ret=0 ;;
esac

return ret
