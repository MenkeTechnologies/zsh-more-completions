#compdef hmoment

# EMBOSS hmoment: hydrophobic moment plot of protein
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-seqall=[protein sequence(s)]:protein USA:_files' \
  '-window=[scanning window size]:size:' \
  '-aangle=[alpha-helix angle (degrees)]:angle:' \
  '-bangle=[beta-sheet angle (degrees)]:angle:' \
  '-baseline=[baseline value to display]:val:' \
  '-plot[produce graph output]' \
  '-graph=[graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-double[plot alpha and beta together]' \
  '-outfile=[output file]:file:_files' \
  '*:protein USA:_files' && ret=0
return ret
