#compdef guacingest
# _guacingest — GUAC ingestor (pubsub → graphql) (guacsec/guac)
# upstream: https://github.com/guacsec/guac
# Flags from cmd/guacingest/cmd/root.go + pkg/cli/store.go (cobra).

_guacingest() {
    local -a args
    args=(
        '--pubsub-addr=[gocloud pubsub connection string]:url:'
        '--blob-addr=[gocloud blob-store connection string]:url:'
        '--csub-addr=[collect-sub service address]:host\:port:'
        '--gql-addr=[GraphQL server endpoint URL]:url:'
        '--header-file=[RFC-822 file of HTTP headers for the GQL server]:file:_files'
        '--add-vuln-on-ingest[query/ingest OSV vulnerabilities during ingest]'
        '--add-license-on-ingest[query/ingest ClearlyDefined licenses during ingest]'
        '--add-eol-on-ingest[query/ingest endoflife.date EOL data during ingest]'
        '--enable-otel[enable OpenTelemetry metrics + tracing]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
    )
    _arguments -s $args
}

_guacingest "$@"
