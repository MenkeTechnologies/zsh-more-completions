#compdef refind-mkrlconf
# Documentation: https://man.archlinux.org/search?q=refind-mkrlconf
# Reference accessed: 2026-05-16

# refind-mkrlconf: scan /boot and emit refind_linux.conf
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--force[force overwrite]' \
  '--outfile=[output file]:file:_files' \
  '*::refind-mkrlconf args:_files' && ret=0
return ret
