#compdef dinitcheck

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --services-dir)'{-d,--services-dir}'=[specify services directory]:services dir:_files -/' \
  '--am-system-init[check as if running as system init]' \
  '--socket-path=[specify control socket path]:socket path:_files' \
  '(-n --online)'{-n,--online}'[check online (running) service definitions]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output, only return exit code]' \
  '*:service name:_files -W /etc/dinit.d' \
  && ret=0

return ret
