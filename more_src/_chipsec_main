#compdef chipsec_main chipsec_main.py
# Documentation: https://chipsec.github.io/usage/Running-Chipsec.html
# CHIPSEC platform security assessment framework main runner

local ret=1

_arguments -s -S \
  '(-m --module)'{-m,--module}'[specify module to run]:module:' \
  '(-mx --module_exclude)'{-mx,--module_exclude}'[modules NOT to run]:modules:' \
  '(-a --module_args)'{-a,--module_args}'[additional module arguments]:args:' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-vv --vverbose)'{-vv,--vverbose}'[very verbose logging]' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '(-l --log)'{-l,--log}'[output to log file]:log:_files' \
  '(-p --platform)'{-p,--platform}'[explicitly specify platform code]:platform:' \
  '--pch[explicitly specify PCH code]:pch:' \
  '(-n --no_driver)'{-n,--no_driver}'[do not load kernel module]' \
  '(-i --ignore_platform)'{-i,--ignore_platform}'[run despite unrecognized platform]' \
  '(-j --json)'{-j,--json}'[JSON output filename]:file:_files' \
  '(-x --xml)'{-x,--xml}'[XML output filename]:file:_files' \
  '(-k --markdown)'{-k,--markdown}'[markdown output filename]:file:_files' \
  '(-t --moduletype)'{-t,--moduletype}'[run specific test type]:type:' \
  '--hal[HAL logging]' \
  '(-nb --no_banner)'{-nb,--no_banner}'[do not display banner]' \
  '-nl[do not save logs automatically]' && ret=0

return ret
