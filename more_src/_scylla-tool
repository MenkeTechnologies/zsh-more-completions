#compdef scylla-tool

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'sstable:sstable utility commands'
  'commitlog:commit log dump'
  'system_schema:dump system schema'
  'compact:offline compaction'
  'sstabledump:dump sstable contents'
  'sstableinfo:print sstable info'
  'sstableupgrade:upgrade sstable format'
  'sstableloader:bulk load sstables'
  'sstablerepairedset:mark sstables as repaired'
  'sstablelevelreset:reset levels'
  'sstableofflinerelevel:offline releveling'
  'help:show help'
  'types:list available subcommands and aliases'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--logger-log-level=[log level]:level:' \
  '--default-log-level=[default log level]:level:(trace debug info warn error)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'scylla-tool subcommand' subcommands && ret=0
    ;;
  (args)
    _files && ret=0
    ;;
esac

return ret
