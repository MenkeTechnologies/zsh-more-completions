_logto() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'init:download and run the latest Logto release (alias: i, install)'
        'i:alias for init'
        'install:alias for init'
        'database:Logto database commands (alias: db)'
        'db:alias for database'
        'connector:Logto connector commands (alias: c, connectors)'
        'c:alias for connector'
        'connectors:alias for connector'
    )

    _arguments -C \
        '(-e --env --env-file)'{-e,--env,--env-file=}'[path to your .env file]:env file:_files -g "*.env*"' \
        '(--db --db-url --database-url)--db=[Postgres URL to Logto database]:url:' \
        '(--db --db-url --database-url)--db-url=[Postgres URL to Logto database]:url:' \
        '(--db --db-url --database-url)--database-url=[Postgres URL to Logto database]:url:' \
        '(- *)'{-v,--version}'[print Logto CLI version]' \
        '(- *)'{-h,--help}'[print help]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'logto command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                init|i|install)
                    _arguments \
                        '(-p --path)'{-p,--path=}'[path of Logto, must be a non-existing path]:path:_files -/' \
                        '(--ss --skip-seed)--ss[skip Logto database seeding]' \
                        '(--ss --skip-seed)--skip-seed[skip Logto database seeding]' \
                        '--cloud[init Logto for cloud (hidden)]' \
                        '(--du --download-url)--du=[custom download URL]:url:' \
                        '(--du --download-url)--download-url=[custom download URL]:url:' \
                        '(--dapc --disable-admin-pwned-password-check)--dapc[disable admin pwned-password check]' \
                        '(--dapc --disable-admin-pwned-password-check)--disable-admin-pwned-password-check[disable admin pwned-password check]' && ret=0
                    ;;
                database|db)
                    local -a dbcmds
                    dbcmds=(
                        'config:read/write Logto database config rows'
                        'seed:seed Logto database tables (--cloud --test --encrypt-base-role --disable-pwned-password-check)'
                        'alteration:run / list / revert database alterations'
                        'system:Logto system table operations'
                    )
                    _describe -t commands 'logto database command' dbcmds && ret=0
                    ;;
                connector|c|connectors)
                    _arguments \
                        '(-p --path)'{-p,--path=}'[path to your Logto instance directory]:path:_files -/' \
                        '1: :->ccmds' && ret=0

                    local -a ccmds
                    ccmds=(
                        'add:add a connector to the Logto instance'
                        'list:list installed connectors'
                        'remove:remove a connector'
                        'link:symlink a local connector directory for development'
                    )
                    case $state in
                        ccmds)
                            _describe -t commands 'logto connector command' ccmds && ret=0
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac

    return ret
}

_logto "$@"
