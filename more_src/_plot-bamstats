#compdef plot-bamstats
# Documentation: https://github.com/samtools/samtools/blob/develop/misc/plot-bamstats
# parse output of samtools stats and call gnuplot to create graphs

local ret=1

_arguments -s -S \
  '(-h -? --help)'{-h,-\?,--help}'[show help]' \
  '(-k --keep-files)'{-k,--keep-files}'[do not remove temporary files]' \
  '(-l --log-y)'{-l,--log-y}'[set the Y axis scale of the Insert Size plot to log 10]' \
  '(-m --merge)'{-m,--merge}'[merge multiple bamstats files and output to STDOUT]' \
  '(-p --prefix)'{-p,--prefix}'+[output files prefix]:prefix:_files' \
  '(-r --ref-stats)'{-r,--ref-stats}'+[reference stats file with expected GC content]:file:_files -g "*.gc"' \
  '(-s --do-ref-stats)'{-s,--do-ref-stats}'+[calculate reference sequence GC for later use with -r]:file:_files -g "*.(fa|fasta)"' \
  '(-t --targets)'{-t,--targets}'+[restrict -s to the listed regions]:file:_files' \
  '(-q --alt-qual-avg-method)'{-q,--alt-qual-avg-method}'[calculate average base quality using average base error probabilities]' \
  '*:bamstats file:_files' && ret=0

return ret
