_protoc-gen-connect-es() {
    _arguments -s -S \
        '(- *)--help[print plugin help text and exit]' \
        '(- *)-h[print plugin help text and exit]' \
        '(- *)--version[print plugin version and exit]'

    # When invoked by protoc / buf the plugin reads a CodeGeneratorRequest
    # from stdin; per-invocation options come in via
    # --connect-es_opt=KEY=VALUE (protoc) or `opt:` lines (buf.gen.yaml).
    # Available KEYs (verbatim from v1.7.0 README "Plugin options"):
    #
    #   target=js|ts|dts          default "js+dts"; combinable via "+"
    #                              e.g. target=ts → generates _connect.ts
    #                                   target=js+dts → _connect.js + .d.ts
    #
    #   import_extension=.js|none|.ts
    #                              default ".js"
    #                              "none" removes the .js extension
    #                              ".ts"  replaces .js with .ts (Deno)
    #
    #   js_import_style=module|legacy_commonjs
    #                              default "module" (ESM import/export)
    #                              "legacy_commonjs" emits require() calls
    #
    #   keep_empty_files=true|false
    #                              default false; set true for Bazel-style
    #                              build systems requiring declared outputs
    #
    #   ts_nocheck=true|false
    #                              default true (prepends `// @ts-nocheck`)
    #                              set false to enable type checking on
    #                              generated code (catches stale imports)
}

_protoc-gen-connect-es "$@"
