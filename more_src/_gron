#compdef gron

# Zsh completion for gron - make JSON greppable

_arguments -s -S \
  '(-u --ungron)'{-u,--ungron}'[ungron: turn stream of assignments back into JSON]' \
  '--no-sort[do not sort JSON keys]' \
  '-s[sort JSON output (default)]' \
  '--sort[sort JSON output (default)]' \
  '--stream[output JSON as a stream of values]' \
  '(-v --values)'{-v,--values}'[output only values, not paths]' \
  '--json[output as JSON]' \
  '-j[output as JSON]' \
  '--colorize[colorize output]' \
  '-c[colorize output]' \
  '--monochrome[no colorization]' \
  '-m[no colorization]' \
  '--indent[number of spaces for indentation]:N:' \
  '--addr[base variable name to assign to]:name:' \
  '-i[base variable name to assign to]:name:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:JSON file or URL:_files -g "*.json"'
