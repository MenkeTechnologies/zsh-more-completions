#compdef audtool
# Documentation: https://man.archlinux.org/man/audtool.1
# audtool - small tool to modify behavior of a running Audacious instance

local ret=1

_arguments -s -S \
  '--current-song[display formatted title]' \
  '--current-song-filename[show file path or URI]' \
  '--current-song-length[display duration in M:SS]' \
  '--current-song-length-seconds[duration in seconds]' \
  '--current-song-length-frames[duration in milliseconds]' \
  '--current-song-output-length[playback counter in M:SS]' \
  '--current-song-output-length-seconds[playback counter in seconds]' \
  '--current-song-bitrate[streaming rate in bits/second]' \
  '--current-song-bitrate-kbps[streaming rate in kilobits/second]' \
  '--current-song-frequency[sample rate in hertz]' \
  '--current-song-channels[number of audio channels]' \
  '--current-song-tuple-data[metadata value for field]:field' \
  '--current-song-info[bitrate, sample rate and channel count]' \
  '--playback-play[start or resume playback]' \
  '--playback-pause[toggle pause state]' \
  '--playback-playpause[play if stopped, pause if active]' \
  '--playback-stop[halt playback]' \
  '--playback-playing[return 0 if playing]' \
  '--playback-paused[return 0 if paused]' \
  '--playback-stopped[return 0 if stopped]' \
  '--playback-status[show status]' \
  '--playback-seek[jump to position in seconds]:time' \
  '--playback-seek-relative[skip relative to current position]:time' \
  '--playback-record[toggle output stream recording]' \
  '--playback-recording[return 0 if recording enabled]' \
  '--select-displayed[apply commands to visible playlist]' \
  '--select-playing[apply commands to active playlist]' \
  '--playlist-advance[skip to next song]' \
  '--playlist-reverse[go to previous song]' \
  '--playlist-addurl[add song to end]:path:_files' \
  '--playlist-insurl[insert at position]:path:_files' \
  '--playlist-delete[remove song at position]:position' \
  '--playlist-length[count songs]' \
  '--playlist-song[show formatted title at position]:position' \
  '--playlist-song-filename[show file path at position]:position' \
  '--playlist-display[list all titles]' \
  '--playlist-position[show current position]' \
  '--playlist-jump[skip to position]:position' \
  '--playlist-clear[empty playlist]' \
  '--playlist-auto-advance-toggle[toggle auto-advance]' \
  '--playlist-repeat-toggle[toggle repeat]' \
  '--playlist-shuffle-toggle[toggle shuffle]' \
  '--playlist-save[export playlist]:path:_files' \
  '--number-of-playlists[count open playlists]' \
  '--current-playlist[get current playlist number]' \
  '--set-current-playlist[switch to playlist]:playlist' \
  '--new-playlist[create and switch to new playlist]' \
  '--delete-current-playlist[remove playlist]' \
  '--playqueue-add[queue song at position]:position' \
  '--playqueue-remove[dequeue song at position]:position' \
  '--playqueue-length[count queued songs]' \
  '--playqueue-display[list queued titles]' \
  '--playqueue-clear[empty queue]' \
  '--get-volume[show volume percentage]' \
  '--set-volume[set volume percentage]:level' \
  '--equalizer-activate[toggle equalizer]:state:(on off)' \
  '--equalizer-get[display all settings]' \
  '--mainwin-show[toggle main window]:state:(on off)' \
  '--version[display version information]' \
  '--shutdown[close Audacious]' \
  '--help[show command summary]' \
  '*:arg:_files' && ret=0

return ret
