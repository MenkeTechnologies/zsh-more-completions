#compdef git-hound
# Documentation: https://man.archlinux.org/search?q=git-hound
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/git-hound — Ripgrep-powered secret scanner for git

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
