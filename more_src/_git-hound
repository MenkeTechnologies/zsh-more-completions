#compdef git-hound
# Documentation: https://github.com/tillson/git-hound
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# git-hound: a pattern-matching, batch-catching client and secret snatcher

_arguments -s -S \
  '--query[search query]:query:' \
  '--query-file[file with multiple queries]:file:_files' \
  '--pages[max pages per query]:pages:' \
  '--threads[number of digging threads]:threads:' \
  '--dig-commits[dig through commit history (CPU intensive)]' \
  '--dig-files[dig through repo files (CPU intensive)]' \
  '--no-gists[exclude Gist searches]' \
  '--no-repos[exclude repository searches]' \
  '--no-keywords[skip built-in keyword matching]' \
  '--no-api-keys[disable generic API key detection]' \
  '--no-files[skip file searching]' \
  '--json[output results in JSON]' \
  '--results-only[print only matched strings]' \
  '--all-results[include results without detected secrets]' \
  '--dashboard[stream results to web dashboard]' \
  '--rules[path to regex rules or GitLeaks folder]:path:_directories' \
  '--config-file[configuration file location]:file:_files' \
  '--many-results[search beyond 100 pages]' \
  '--fast[skip file grepping, return search previews only]' \
  '--no-scoring[disable false positive filtering]' \
  '--debug[enable verbose logging]' \
  '--api-debug[show GitHub API request details]' \
  '--profile[enable performance profiling]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::args:_default' && return 0
