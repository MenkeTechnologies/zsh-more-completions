#compdef imcopy
# _imcopy — copy/compress/uncompress a FITS image (HEASARC/cfitsio)
# upstream: https://github.com/HEASARC/cfitsio
# Usage from utilities/imcopy.c: imcopy inputImage outputImage[compress]

_imcopy() {
    _arguments \
        '1:input FITS image:_files -g "*.(fits|fit|fts)"' \
        '2:output FITS image (optionally [compress …]):_files -g "*.(fits|fit|fts)"'
}

_imcopy "$@"
