#compdef gamdl

# https://github.com/glomatico/gamdl — rich-click (`gamdl --help`)
_arguments -s -S \
  '--help[help]' \
  '--version[version]' \
  '(-c --cookie-file)'{-c,--cookie-file}'=-[cookies.txt]:file:_files' \
  '(-o --output-dir)'{-o,--output-dir}'=-[download dir]:dir:_directories' \
  '*:Apple Music / URL args:_default'
