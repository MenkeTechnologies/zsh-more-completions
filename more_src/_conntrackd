#compdef conntrackd

_arguments -s \
  '-d[run as daemon]' \
  '-C[config file]:file:_files' \
  '(- *)-v[show version]' \
  '(- *)-h[show help]' \
  '-i[dump internal cache]:type:(ct expect)' \
  '-e[dump external cache]:type:(ct expect)' \
  '-x[XML output]' \
  '-f[flush cache]:scope:(internal external)' \
  '-F[flush kernel table]:type:(ct expect)' \
  '-c[commit external cache]' \
  '-B[bulk send to replicas]' \
  '-n[request resync]' \
  '-k[kill daemon]' \
  '-s[dump statistics]:type:(network cache runtime link rsqueue process queue ct expect)' \
  '-R[force kernel resync]:type:(ct expect)' \
  '-t[reset kernel timers]'
