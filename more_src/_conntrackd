#compdef conntrackd
# Documentation: https://www.netfilter.org/projects/conntrack-tools/conntrackd-manpage.html
# Reference accessed: 2026-05-17
# Verified: upstream conntrackd(8) manpage at the URL above.

_arguments -s \
  '-d[run as daemon (fork to background)]' \
  '-C[config file]:file:_files' \
  '(- *)-v[show version]' \
  '(- *)-h[show help]' \
  '-i[dump internal cache]:type:(ct expect)' \
  '-e[dump external cache]:type:(ct expect)' \
  '-x[XML output (with -i/-e)]' \
  '-f[flush cache]:scope:(internal external)' \
  '-F[flush kernel conntrack table]:type:(ct expect)' \
  '-c[commit external cache to conntrack table]' \
  '-B[force bulk send to replica firewalls]' \
  '-n[request resync with other node]' \
  '-k[kill the daemon]' \
  '-s[dump statistics]:type:(network cache runtime link rsqueue process queue ct expect)' \
  '-R[force resync against kernel conntrack table]:type:(ct expect)' \
  '-t[reset in-kernel timers]'
