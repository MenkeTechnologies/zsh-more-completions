#compdef jaccard
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/jaccard.html
# Jaccard statistic of overlap between two sets (bedtools jaccard)

local ret=1

_arguments -s -S \
  '-a[BED/GFF/VCF file A]:file:_files' \
  '-b[BED/GFF/VCF file B]:file:_files' \
  '-f[minimum overlap as fraction of A]:fraction' \
  '-F[minimum overlap as fraction of B]:fraction' \
  '-r[require reciprocal overlap]' \
  '-e[satisfy minimum fraction for A OR B]' \
  '-s[force strandedness (same strand)]' \
  '-S[require opposite strandedness]' \
  '-split[treat split BAM/BED12 entries as distinct intervals]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
