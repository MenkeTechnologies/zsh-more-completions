#compdef rails

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'new:create a new Rails application'
  'plugin:create a new Rails plugin'
  'server:start the Rails server'
  's:start the Rails server'
  'console:start the Rails console'
  'c:start the Rails console'
  'generate:run a generator'
  'g:run a generator'
  'destroy:undo a generator'
  'd:undo a generator'
  'test:run the test suite'
  't:run the test suite'
  'routes:list application routes'
  'runner:run a Ruby snippet in the application context'
  'dbconsole:open a database console'
  'about:show framework version info'
  'initializers:list application initializers'
  'middleware:list Rack middleware'
  'stats:show application code stats'
  'notes:search annotation comments'
  'secret:generate a new secret'
  'credentials:manage encrypted credentials'
  'app:update:run new templates against an existing app'
  'action_mailbox:install:install Action Mailbox'
  'action_text:install:install Action Text'
  'db:create:create the database'
  'db:drop:drop the database'
  'db:migrate:run pending migrations'
  'db:rollback:roll back the last migration'
  'db:seed:load seed data'
  'db:setup:create + load schema + seed'
  'db:reset:drop and recreate the database'
  'db:prepare:prepare the database'
  'db:purge:purge the database'
  'db:version:show migration version'
  'db:fixtures:load:load fixtures'
  'db:schema:load:load db/schema.rb'
  'db:schema:dump:dump db/schema.rb'
  'db:schema:cache:dump:dump schema cache'
  'db:schema:cache:clear:clear schema cache'
  'db:structure:load:load db/structure.sql'
  'db:structure:dump:dump db/structure.sql'
  'db:migrate:status:show migration status'
  'db:migrate:up:run a single migration up'
  'db:migrate:down:run a single migration down'
  'db:migrate:redo:re-run last migration'
  'db:test:prepare:prepare the test database'
  'db:encryption:init:bootstrap Active Record encryption'
  'version:show Rails version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rails subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (new)
        _arguments \
          '(-d --database)'{-d,--database=}'[database]:db:(mysql trilogy postgresql sqlite3 mariadb-mysql mariadb-trilogy)' \
          '(-j --javascript --js)'{-j,--javascript=,--js=}'[JS bundler]:js:(importmap bun webpack esbuild rollup)' \
          '(-c --css)'{-c,--css=}'[CSS framework]:css:(tailwind bootstrap bulma postcss sass)' \
          '(-m --template)'{-m,--template=}'[application template]:path:_files' \
          '(-n --name)'{-n,--name=}'[application name]:name:' \
          '--api[generate API-only app]' \
          '--minimal[generate minimal app]' \
          '(-B --skip-bundle)'{-B,--skip-bundle}'[skip bundle install]' \
          '(-G --skip-git)'{-G,--skip-git}'[skip git init]' \
          '--skip-docker[skip Docker]' \
          '--skip-keeps[skip .keep files]' \
          '(-M --skip-action-mailer)'{-M,--skip-action-mailer}'[skip Action Mailer]' \
          '--skip-action-mailbox[skip Action Mailbox]' \
          '--skip-action-text[skip Action Text]' \
          '(-O --skip-active-record)'{-O,--skip-active-record}'[skip Active Record]' \
          '--skip-active-job[skip Active Job]' \
          '--skip-active-storage[skip Active Storage]' \
          '(-C --skip-action-cable)'{-C,--skip-action-cable}'[skip Action Cable]' \
          '(-A --skip-asset-pipeline)'{-A,--skip-asset-pipeline}'[skip asset pipeline]' \
          '(-J --skip-javascript --skip-js)'{-J,--skip-javascript,--skip-js}'[skip JS]' \
          '--skip-hotwire[skip Hotwire]' \
          '--skip-jbuilder[skip Jbuilder]' \
          '(-T --skip-test)'{-T,--skip-test}'[skip test framework]' \
          '--skip-system-test[skip system tests]' \
          '--skip-bootsnap[skip Bootsnap]' \
          '--skip-dev-gems[skip dev gems]' \
          '--skip-thruster[skip Thruster]' \
          '--skip-rubocop[skip RuboCop]' \
          '--skip-brakeman[skip Brakeman]' \
          '--skip-bundler-audit[skip bundler-audit]' \
          '--skip-ci[skip CI files]' \
          '--skip-kamal[skip Kamal]' \
          '--skip-solid[skip Solid Queue/Cable/Cache]' \
          '--dev[use Rails from local checkout]' \
          '--devcontainer[generate dev container]' \
          '--edge[use edge Rails]' \
          '(--main --master)'{--main,--master}'[use main branch]' \
          '--rc=[Railsrc file]:file:_files' \
          '--no-rc[skip Railsrc]' \
          ':path:_files -/' && ret=0
        ;;
      (server|s)
        _arguments \
          '(-p --port)'{-p,--port=}'[port]:port:' \
          '(-b --binding)'{-b,--binding=}'[binding address]:addr:' \
          '(-c --config)'{-c,--config=}'[config file]:file:_files' \
          '(-d --daemon)'{-d,--daemon}'[daemonize]' \
          '(-u --using)'{-u,--using=}'[server]:server:(puma falcon)' \
          '(-P --pid)'{-P,--pid=}'[PID file]:file:_files' \
          '(-C --dev-caching)'{-C,--dev-caching,--no-dev-caching}'[toggle dev caching]' \
          '(-e --environment)'{-e,--environment=}'[environment]:env:(development test production)' \
          '--early-hints[enable early hints]' \
          '--log-to-stdout[log to stdout]' && ret=0
        ;;
      (routes)
        _arguments \
          '(-c --controller)'{-c,--controller=}'[controller name]:name:' \
          '(-g --grep)'{-g,--grep=}'[grep pattern]:pattern:' \
          '(-E --expanded)'{-E,--expanded}'[expanded format]' \
          '(-u --unused)'{-u,--unused}'[show unused routes]' && ret=0
        ;;
      (plugin)
        _values 'plugin action' 'new' && ret=0
        ;;
      (generate|g|destroy|d)
        _values 'generator' \
          'controller' 'model' 'scaffold' 'migration' 'mailer' 'helper' \
          'job' 'channel' 'resource' 'integration_test' 'system_test' \
          'task' 'generator' 'jbuilder' 'application_record' 'mailbox' \
          'devise' 'devise:install' && ret=0
        ;;
    esac
    ;;
esac

return ret
