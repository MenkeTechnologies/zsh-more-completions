#compdef pyenv-virtualenv pyenv-virtualenvs pyenv-virtualenv-delete pyenv-virtualenv-init pyenv-virtualenv-prefix pyenv-activate pyenv-deactivate
# Documentation: https://man.archlinux.org/search?q=pyenv-virtualenv
# Reference accessed: 2026-05-16

case "$service" in
  pyenv-virtualenv)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '*--system-site-packages[system site packages]' \
      '*-p=[python]:python:' \
      '*--python=[python]:python:' \
      '1:python version:' \
      '2:name:' ;;
  pyenv-virtualenvs)
    _arguments '--bare[bare format]' '--skip-aliases[skip aliases]' ;;
  pyenv-virtualenv-delete)
    _arguments '(-f --force)'{-f,--force}'[force]' '*:env:' ;;
  pyenv-virtualenv-prefix)
    _arguments '*:env:' ;;
  pyenv-virtualenv-init)
    _arguments '1:shell:(bash zsh fish ksh)' ;;
  pyenv-activate)
    _arguments '*:env:' ;;
  pyenv-deactivate)
    _arguments '(- *)'{-h,--help}'[show help]' ;;
esac
