#compdef gammaray
# Documentation: https://man.archlinux.org/search?q=gammaray
# Reference accessed: 2026-05-16

# KDAB GammaRay — Qt introspection (`gammaray --help`). Typical: attach to PID or launch app.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--probe=[inject probe ABI]:abi:(qt5 qt6)' \
  '(-p --pid)'{-p,--pid}"=[attach to PID]:pid:_pids" \
  '1::program:_command_names' \
  '*::args:_normal' && ret=0

return ret
