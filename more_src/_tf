#compdef tf
# Documentation: https://github.com/battenworks/tf
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tf: opinionated wrapper around Terraform/OpenTofu CLI
local curcontext="$curcontext" state line ret=1
local -a _tf_cmds
_tf_cmds=(
  'clean:remove .terraform/ and .terraform.lock.hcl then init'
  'on:remove .off extensions from config files'
  'off:add .off extensions to config files'
  'replan:run upgrade init then plan'
  'test:run fmt recursive then upgrade init then test'
)

_arguments -C \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'tf command' _tf_cmds && ret=0 ;;
esac

return ret
