#compdef difft difftastic
# Documentation: https://github.com/Wilfred/difftastic
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--list-languages[list supported languages]' \
  '(- *)--list-themes[list themes]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--background=[background]:b:(dark light)' \
  '--byte-limit=[byte limit]:n:' \
  '--check-only[check only, exit 1 if different]' \
  '--color=[color]:c:(always auto never)' \
  '--context=[context lines]:n:' \
  '--display=[display mode]:m:(side-by-side side-by-side-show-both inline json)' \
  '--exit-code[exit non-zero on diff]' \
  '--graph-limit=[graph node limit]:n:' \
  '--ignore-comments[ignore whitespace-only changes in comments]' \
  '--language=[force language]:lang:' \
  '--missing-as-empty[treat missing files as empty]' \
  '--node-limit=[node limit]:n:' \
  '--num-context-lines=[context lines]:n:' \
  '--override=[glob:lang override]:o:' \
  '--parse-error-limit=[parse error limit]:n:' \
  '--skip-unchanged[skip unchanged files]' \
  '--sort-paths[sort paths]' \
  '--strip-cr=[strip CR]:b:(on off)' \
  '--syntax-highlight=[syntax highlight]:b:(on off)' \
  '--tab-width=[tab width]:n:' \
  '--theme=[theme]:t:(dark light dark-wcag-aa dark+ light+ classic-dark classic-light)' \
  '--width=[terminal width]:n:' \
  '--dump-syntax=[dump syntax tree for file]:file:_files' \
  '--dump-ts=[dump tree-sitter tree]:file:_files' \
  '*: :_files' && ret=0

return ret
