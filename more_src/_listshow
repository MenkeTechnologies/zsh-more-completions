#compdef listshow
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss85.html
# KAPPA: report the positions stored in a positions list

local ret=1

_arguments -s \
  'CATFRAME=[coordinate Frame for the output catalogue]:catframe' \
  'CATEPOCH=[epoch for output-catalogue sky positions]:catepoch' \
  'CLOSE=[close polygons when plotting]:close:(TRUE FALSE)' \
  'COMP=[NDF array component to display]:comp:(Data Variance Error Quality)' \
  'DESCRIBE=[describe the coordinate Frame]:describe:(TRUE FALSE)' \
  'DEVICE=[graphics device for output]:device' \
  'EPOCH=[epoch for the Sky Coordinate System]:epoch' \
  'FIRST=[first position to display]:first' \
  'FRAME=[coordinate Frame for reported positions]:frame' \
  'GEODESIC=[straight or geodesic connecting lines]:geodesic:(TRUE FALSE)' \
  'INCAT=[input positions-list catalogue]:catalogue:_files' \
  'JUST=[text justification]:just' \
  'LABEL=[label positions on the device]:label:(TRUE FALSE)' \
  'LABTYPE=[label content]:labtype' \
  'LAST=[last position to display]:last' \
  'LOGFILE=[text file for formatted coordinates]:file:_files' \
  'MARKER=[PGPLOT marker type]:marker' \
  'METHOD=[interpolation scheme]:method' \
  'NAME=[graphics-database picture name]:name' \
  'NDF=[input NDF for pixel values]:NDF:_files' \
  'OUTCAT=[output catalogue]:catalogue:_files' \
  'PARAMS=[interpolation-method parameters]:params' \
  'PLOT=[graphics type for marking positions]:plot' \
  'POSNS=[output unformatted coordinates]:posns' \
  'STEP=[increment between identifiers]:step' \
  'STCSCOL=[catalogue column with STC-S shapes]:stcscol' \
  'STRINGS=[text strings for Text plotting]:strings' \
  'STYLE=[plotting style attributes]:style' \
  '*:NDF:_files' && ret=0

return ret
