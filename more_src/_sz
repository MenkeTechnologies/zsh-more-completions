#compdef sz sb sx

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-a[ASCII transfer mode]' \
  '-b[binary transfer mode]' \
  '-B+[buffer size]:size' \
  '-c+[send command]:command' \
  '-C[use 32 bit CRC]' \
  '-d[convert dot to slash in pathnames]' \
  '-e[escape all control characters]' \
  '-f[send full pathname]' \
  '-i+[send command, return immediately]:command' \
  '-k[send 1024 byte packets (XMODEM)]' \
  '-L+[packet length]:length' \
  '-l+[frame length]:length' \
  '-N[newer or longer files]' \
  '-n[newer files]' \
  '-o[use old 16 bit checksum]' \
  '-O[disable timeouts]' \
  '-p[protect existing files]' \
  '-q[quiet mode]' \
  '-r[resume transfer]' \
  '-R[restricted mode]' \
  '-t+[change timeout]:seconds' \
  '-u[unlink file after transfer]' \
  '-v[verbose mode]' \
  '-w+[set window size]:size' \
  '-X[use XMODEM protocol]' \
  '-y[overwrite existing files]' \
  '-Y[overwrite existing files, skip if same]' \
  '-Z[use ZMODEM protocol]' \
  '*:file:_files' && return 0
