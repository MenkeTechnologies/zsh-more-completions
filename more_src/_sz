#compdef sz sb sx
# Documentation: https://manpages.debian.org/testing/lrzsz/sz.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)-h[show help]' \
  '-+[append to existing file at receiver (ZMODEM)]' \
  '-2[use two stop bits]' \
  '-8[try 8KB blocksize (non-standard zmodem extension)]' \
  '-a[ASCII transfer (convert newlines to CR/LF)]' \
  '-b[binary transfer mode]' \
  '-B+[set read buffer size in bytes]:size' \
  '-c+[send command to receiver]:command' \
  '-C+[retry sending command N times]:n' \
  '-d[convert dot to slash in transmitted pathname]' \
  '-e[escape all control characters]' \
  '-E[force renaming if destination exists]' \
  '-f[send full pathname]' \
  '-i+[send command, return immediately upon reception]:command' \
  '-k[send 1024 byte packets (XMODEM/YMODEM)]' \
  '-L+[ZMODEM sub-packet length (32-1024)]:length' \
  '-l+[acknowledge every N characters (32-1024)]:length' \
  '-m+[stop if speed drops below N bytes/sec]:bytes' \
  '-M+[duration threshold for minimum speed check]:seconds' \
  '-n[send only if newer or destination missing]' \
  '-N[send if newer/longer or destination missing]' \
  '-o[disable automatic 32-bit CRC selection]' \
  '-O[disable read timeout handling]' \
  '-p[protect: skip if destination exists]' \
  '-q[suppress verbose output]' \
  '-r[resume interrupted transfer]' \
  '-R[restricted mode]' \
  '-s+[stop transmission at HH:MM]:time' \
  '-S[enable timesync protocol support]' \
  '-t+[change timeout (tenths of seconds)]:tim' \
  '-T[turbo mode (do not escape certain characters)]' \
  '-u[unlink file after successful transmission]' \
  '-U[disable restricted mode]' \
  '*-v[increase verbosity]' \
  '-w+[set window size]:size' \
  '-X[use XMODEM protocol]' \
  '-y[overwrite existing files]' \
  '-Y[overwrite or skip if same]' \
  '-Z[use ZMODEM protocol]' \
  '*:file:_files' && return 0
