#compdef gevgen_atmo
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/Apps/gAtmoEvGen.cxx
# gevgen_atmo - GENIE atmospheric neutrino event generation application

local ret=1

_arguments -s -S \
  '(-h)-h[show syntax and exit]' \
  '-r[MC run number]:run:' \
  '-f[input flux files (simulation:/path/file[code])]:flux:' \
  '-g[geometry: ROOT file or target mix with weight fractions]:geom:_files' \
  '-R[input rotation matrix (Euler angles) for flux coordinate transform]:rotation:' \
  '-t[geometry top volume for event generation]:topvol:' \
  '-m[XML file with maximum path lengths for detector materials]:xml:_files' \
  '-L[geometry length units (default mm)]:units:' \
  '-D[geometry density units (default g_cm3)]:units:' \
  '-n[number of events to generate]:nevents:' \
  '-e[requested exposure in kiloton-years]:exposure:' \
  '-T[requested exposure in seconds]:seconds:' \
  '-E[neutrino energy range min,max in GeV (default 0.5,50)]:erange:' \
  '-o[output event file prefix (default gntp)]:prefix:' \
  '--flux-ray-generation-surface-distance[longitudinal radius for flux ray generation surface]:dist:' \
  '--flux-ray-generation-surface-radius[transverse radius for flux ray generation surface]:radius:' \
  '--seed[random number seed]:seed:' \
  '--cross-sections[XML file with pre-computed cross-section values]:xml:_files' \
  '--event-generator-list[event generator list name]:list:' \
  '--tune[GENIE neutrino interaction model tune]:tune:' \
  '--message-thresholds[XML file customizing message stream thresholds]:xml:_files' \
  '--unphysical-event-mask[16-bit mask for unphysical event handling]:mask:' \
  '--event-record-print-level[verbosity for event record output]:level:' \
  '--mc-job-status-refresh-rate[status file update frequency]:rate:' \
  '--cache-file[ROOT file for cross-section caching]:file:_files' \
  '*: :_files' && ret=0

return ret
