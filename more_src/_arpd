#compdef arpd
# Documentation: man arpd(8)
# Source: iproute2/iproute2 misc/arpd.c (main) — userspace ARP daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-l[dump and exit]' \
    '-k[disable kernel broadcasts]' \
    '-b+[database file]:db:_files' \
    '-B+[broadcast burst]:burst:_default' \
    '-f+[load mapping from file]:file:_files' \
    '-a+[active probe attempts]:n:_default' \
    '-n+[negative cache timeout (seconds)]:seconds:_default' \
    '-p+[poll interval (seconds)]:seconds:_default' \
    '-R+[broadcast rate (per second)]:rate:_default' \
    '*:interface:_net_interfaces' \
    && ret=0

return ret
