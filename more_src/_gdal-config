#compdef gdal-config
# Documentation: https://man.archlinux.org/search?q=gdal-config
# Reference accessed: 2026-05-16

_arguments -s \
  '--prefix=[install dir]:dir:_files -/' \
  '--libs[linker flags]' \
  '--dep-libs[dep linker flags]' \
  '--cflags[include paths]' \
  '--datadir[data dir]' \
  '--version[show version]' \
  '--ogr-enabled[OGR built in]' \
  '--gnm-enabled[GNM built in]' \
  '--formats[list formats]' \
  '--plugindir[plugin dir]'
