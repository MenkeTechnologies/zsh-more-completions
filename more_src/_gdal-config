#compdef gdal-config

_arguments -s \
  '--prefix=[install dir]:dir:_files -/' \
  '--libs[linker flags]' \
  '--dep-libs[dep linker flags]' \
  '--cflags[include paths]' \
  '--datadir[data dir]' \
  '--version[show version]' \
  '--ogr-enabled[OGR built in]' \
  '--gnm-enabled[GNM built in]' \
  '--formats[list formats]' \
  '--plugindir[plugin dir]'
