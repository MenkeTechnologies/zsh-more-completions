#compdef pconvert
# Documentation: https://step.esa.int/main/wp-content/help/versions/10.0.0/snap/org.esa.snap.snap.help/general/overview/PConvertUsage.html
# ESA SNAP product/image converter

local ret=1

_arguments -s -S \
  '(-? --help -h)'{-\?,--help,-h}'[show help]' \
  '(-f --format)'{-f,--format}'=[output format/file extension]:format:(dim h5 tifp png jpg tif bmp)' \
  '(-b --bands)'{-b,--bands}'=[bands to write as image]:bands:' \
  '(-p --rgb-profile)'{-p,--rgb-profile}'=[RGB profile file]:file:_files' \
  '(-s --histo-skip)'{-s,--histo-skip}'=[histogram skip percentages lo,hi]:skip:' \
  '(-m --histo-match)'{-m,--histo-match}'=[histogram matching method]:method:' \
  '(-c --color-palette)'{-c,--color-palette}'=[color palette file]:file:_files' \
  '(-n --no-data-color)'{-n,--no-data-color}'=[no-data color R,G,B,A]:color:' \
  '(-r --max-res)'{-r,--max-res}'=[max image resolution W,H]:res:' \
  '(-W --width)'{-W,--width}'=[image output width]:width:' \
  '(-H --height)'{-H,--height}'=[image output height]:height:' \
  '(-o --outdir)'{-o,--outdir}'=[output directory]:dir:_files -/' \
  '(-d --debug)'{-d,--debug}'[print debug information]' \
  '*:input file:_files' && ret=0

return ret
