#compdef jpegrescan
# Documentation: https://man.archlinux.org/search?q=jpegrescan
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-s[strip metadata]' \
  '-v[verbose]' \
  '-q[quiet]' \
  '-i[keep originals (do not overwrite)]' \
  '-a[try arithmetic coding]' \
  '-t+[tmp dir]:dir:_files -/' \
  '*:file:_files -g "*.{jpg,jpeg,JPG,JPEG}"' && ret=0

return ret
