#compdef sdig
# Documentation: https://doc.powerdns.com/authoritative/manpages/sdig.1.html
# Send a DNS query and display the answer, with DoH and DoT support

local ret=1

_arguments -s -S \
  '1:ip-address-or-doh-url:_hosts' \
  '2:port:_ports' \
  '3:qname:' \
  '4:qtype:(A AAAA MX NS TXT SOA CNAME SRV PTR ANY DNSKEY DS)' \
  '*:option:(class dnssec ednssubnet hidesoadetails hidettl proxy recurse showflags dumpluaraw tcp dot insecure fastOpen subjectName caStore tlsProvider opcode cookie traceid)' && ret=0

return ret
