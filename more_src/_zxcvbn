#compdef zxcvbn
# Documentation: https://github.com/dropbox/zxcvbn
# Reference accessed: 2026-05-17
# Verified: dropbox/zxcvbn library has no official CLI; this
# completion targets third-party wrappers (gamontal/zxcvbn-cli npm
# + zxcvbn-cli Rust crate). Flags vary by implementation: -h/--help,
# -V/--version, -l/--limit-results, -S/--sequence,
# -s/--crack-times-sec, -j/--json, -i/--stdin.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --user-input, --max-length (those are library options,
# not CLI flags).

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-l --limit-results)'{-l,--limit-results}'[show only score+warning+suggestions]' \
  '(-S --sequence)'{-S,--sequence}'[show match sequence]' \
  '(-s --crack-times-sec)'{-s,--crack-times-sec}'[show crack times in seconds]' \
  '(-j --json)'{-j,--json}'[JSON output]' \
  '(-i --stdin)'{-i,--stdin}'[read password from stdin]' \
  '1:password:' && ret=0
return ret
