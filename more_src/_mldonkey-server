#compdef mldonkey-server mlnet
# Documentation: https://sources.debian.org/data/main/m/mldonkey/3.1.6-1/debian/xml-man/mlnet.help
# Reference accessed: 2026-05-16
# Verified: mldonkey 3.1.6 help text from Debian source (last shipped in
# buster; dropped from bullseye/bookworm). All downloads.ini settings
# can be passed as -<name> <value> on the command line; only the most
# common are listed here.
# Removed from prior file: fabricated -h/--help/-V/--version generic
# flags and bogus man.archlinux.org search URL.

# mldonkey-server (mlnet): multi-network P2P client/server
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[print version and exit]' \
  '-exit[exit immediately]' \
  '-format[check file format]:file:_files' \
  '-test_ip[test IP]:ip:' \
  '-check_impl[display info on implementations]' \
  '-stdout[keep output to stdout after startup]' \
  '-stderr[keep output to stderr after startup]' \
  '-find_port[find another port when one is already used]' \
  '-pid[directory for PID file]:dir:_files -/' \
  '-useradd[create user/change password]:"user pass":' \
  '-client_name[client name]:name:' \
  '-allowed_ips[allowed client IPs]:list:' \
  '-gui_port[GUI port (default 4001)]:port:' \
  '-http_port[HTTP port (default 4080)]:port:' \
  '-telnet_port[telnet port (default 4000)]:port:' \
  '-max_hard_upload_rate[max upload kBps]:rate:' \
  '-max_hard_download_rate[max download kBps]:rate:' \
  '-enable_bittorrent[enable BitTorrent network]:bool:(true false)' \
  '-enable_donkey[enable eDonkey network]:bool:(true false)' \
  '*:option:' && ret=0
return ret
