autoload -U is-at-least

_git-statuses() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-d+[Recursively scan all subdirectories to the given depth. If set to 1, only the current directory is scanned. If set to -1, all subdirectories are scanned. (this may take a while)]:DEPTH:_default' \
'--depth=[Recursively scan all subdirectories to the given depth. If set to 1, only the current directory is scanned. If set to -1, all subdirectories are scanned. (this may take a while)]:DEPTH:_default' \
'--subdir=[Look in a specific subdir if it exists for each folder This can be useful, if you don'\''t checkout in a folder directly but in a subfolder like \`repo-name/checkout\`]:SUBDIR:_default' \
'--completions=[Generate shell completions]:SHELL:(bash elvish fish powershell zsh)' \
'-r[Show remote URL]' \
'--remote[Show remote URL]' \
'-c[Use a condensed layout]' \
'--condensed[Use a condensed layout]' \
'-s[Show a summary of the scan]' \
'--summary[Show a summary of the scan]' \
'-f[Run a fetch before scanning to update the repository state Note\: This may take a while for large repositories]' \
'--fetch[Run a fetch before scanning to update the repository state Note\: This may take a while for large repositories]' \
'-F[Run a fast-forward merge after fetching]' \
'--ff[Run a fast-forward merge after fetching]' \
'-l[Print a legend explaining the color codes and statuses used in the output]' \
'--legend[Print a legend explaining the color codes and statuses used in the output]' \
'-p[Show the path to the repository]' \
'--path[Show the path to the repository]' \
'-n[Only show non clean repositories]' \
'--non-clean[Only show non clean repositories]' \
'--json[Output in JSON format]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::dir -- Directory to scan:_files' \
&& ret=0
}

(( $+functions[_git-statuses_commands] )) ||
_git-statuses_commands() {
    local commands; commands=()
    _describe -t commands 'git-statuses commands' commands "$@"
}

if [ "$funcstack[1]" = "_git-statuses" ]; then
    _git-statuses "$@"
else
    compdef _git-statuses git-statuses
fi
