#compdef fastq_quality_trimmer
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fastq_quality_trimmer.1.en.html
# FASTX-Toolkit: trim low-quality bases from the end of FASTQ reads

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-t+[quality threshold; lower-quality end bases are trimmed]:quality' \
  '-l+[minimum length; shorter trimmed reads are discarded (default 0)]:length' \
  '-Q+[FASTQ ASCII offset (default 33)]:offset' \
  '-v[verbose: report number of sequences]' \
  '-z[compress output with GZIP]' \
  '-i+[FASTQ input file (default STDIN)]:input file:_files' \
  '-o+[FASTQ output file (default STDOUT)]:output file:_files' && ret=0

return ret
