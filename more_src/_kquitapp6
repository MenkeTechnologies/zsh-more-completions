#compdef kquitapp6 kquitapp5 kquitapp
# _kquitapp6 — KDE kquitapp (ask a running Qt/KDE app to quit via DBus; the positional argument is the application name as registered on the session bus, e.g. plasmashell, dolphin, ksysguard)
# upstream: https://invent.kde.org/frameworks/kservice (src/kquitapp/kquitapp.cpp)
# Argument shape from kservice src/kquitapp/kquitapp.cpp on tip.

_kquitapp6() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--service+[D-Bus service name]:service:' \
        '1:application name:(plasmashell dolphin kate konsole kwrite okular krunner ksystemstats kded6 kactivitymanagerd kdeconnectd)'
}

_kquitapp6 "$@"
