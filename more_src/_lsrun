#compdef lsrun
# Documentation: https://www.ibm.com/docs/en/spectrum-lsf/10.1.0?topic=reference-lsrun
# Submit a task to IBM Spectrum LSF for execution

local ret=1

_arguments -s -S \
  '-l[run the task locally if execution on another host fails]' \
  '-L[force lsrun to go through RES to execute a task]' \
  '-P[create a pseudo-terminal when starting the task on UNIX hosts]' \
  '-S[create a pseudo-terminal with shell mode support]' \
  '-v[display the name of the host running the task]' \
  '-m[execution host must be one of the specified hosts]:hosts:_hosts' \
  '-R[run the task on a host that meets the resource requirement]:res_req:' \
  '*::command:_command_names -e' && ret=0

return ret
