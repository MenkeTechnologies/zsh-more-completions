#compdef coleslaw
# Documentation: https://github.com/coleslaw-org/coleslaw
# Coleslaw Common Lisp static site generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(setup new generate stage preview watch watch-preview deploy)' \
  '*::arg:_files' && ret=0

return ret
