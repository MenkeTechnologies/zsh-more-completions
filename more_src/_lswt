#compdef lswt
# Documentation: https://man.archlinux.org/search?q=lswt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-j[JSON output]' \
  '-p[show PID]' && ret=0

return ret
