#compdef lswt
# Documentation: https://manpages.opensuse.org/Tumbleweed/lswt/lswt.1.en.html
# Reference accessed: 2026-05-19
# Verified: opensuse Tumbleweed lswt(1) manpage (Wayland toplevel lister).
# Removed from prior file: bogus man.archlinux.org search URL;
# missing -w/--watch, -c/--custom format, --force-protocol.

# lswt: list Wayland toplevels
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-w --watch)'{-w,--watch}'[run in watch mode]' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '(-c --custom)'{-c+,--custom=}'[custom CSV format string]:fmt:' \
  '--force-protocol=[force specific Wayland protocol]:proto:(ext-foreign-toplevel-list-v1 wlr-foreign-toplevel-management-unstable-v1)' && ret=0

return ret
