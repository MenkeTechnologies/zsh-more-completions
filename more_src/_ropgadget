#compdef ROPgadget ropgadget
# Documentation: https://man.archlinux.org/search?q=ROPgadget
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(--checksec)--checksec[check ELF security]' \
  '(--binary)--binary=[binary file]:file:_files' \
  '(--opcode)--opcode=[search opcodes]:opcode:' \
  '(--string)--string=[search string]:s:' \
  '(--memstr)--memstr=[search memory string]:s:' \
  '(--depth)--depth=[gadget depth]:n:' \
  '(--only)--only=[only with these instructions csv]:list:' \
  '(--filter)--filter=[filter instructions csv]:list:' \
  '(--range)--range=[range hex-hex]:r:' \
  '(--badbytes)--badbytes=[bad bytes hex]:hex:' \
  '(--rawArch)--rawArch=[raw arch]:arch:(arm arm64 mips ppc sparc x86)' \
  '(--rawMode)--rawMode=[raw mode]:m:(arm thumb 32 64 mips mips32 mips64 ppc ppc32 ppc64 sparc 16 32 64 little big)' \
  '(--rawEndian)--rawEndian=[endian]:e:(little big)' \
  '(--re)--re=[regex match]:re:' \
  '(--offset)--offset=[image base offset hex]:hex:' \
  '(--ropchain)--ropchain[ROP chain]' \
  '(--thumb)--thumb[ARM Thumb]' \
  '(--console)--console[console mode]' \
  '(--norop)--norop[no ROP]' \
  '(--nojop)--nojop[no JOP]' \
  '(--nosys)--nosys[no syscall]' \
  '(--multibr)--multibr[multibranch]' \
  '(--all)--all[show all]' \
  '(--callPreceded)--callPreceded[call-preceded gadgets]' \
  '(--noinstr)--noinstr=[exclude instructions csv]:list:' \
  '(--silent)--silent[silent]' \
  '(--align)--align=[gadget alignment]:n:' \
  '(--mipsrop)--mipsrop=[mips rop type]:t:(stackfinder system tail lia0 li__)' \
  '*: :_files' && ret=0

return ret
