#compdef cog

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[checksum generated code]' \
  '-d[delete generated code from input]' \
  '*-D[define a global string]:name=value:' \
  '-e[warn if a file has no cog code]' \
  '*-I[add a directory to the include path]:include path:_files -/' \
  '-n[specify encoding for input files]:encoding:' \
  '-o[write output to a file]:output file:_files' \
  '-r[replace the input file with output]' \
  '-s[suffix all generated lines with string]:suffix string:' \
  '-U[use Unix newlines (LF only)]' \
  '-w[use a command to write output files]:write command:' \
  '-x[excise all generated output]' \
  '-z[delete blank lines in generated output]' \
  '--check[check that generated code is up-to-date]' \
  '--markers[set the markers for cog code]:markers:' \
  '--verbosity[set verbosity level]:verbosity level:' \
  '*:file:_files' && ret=0

return ret
