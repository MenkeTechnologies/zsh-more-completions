#compdef khost
# Documentation: https://manpages.debian.org/testing/knot-host/khost.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  '-a[send ANY query in verbose mode]' \
  '-d[enable debug messages]' \
  '-r[disable recursion]' \
  '-T[use TCP protocol]' \
  '-v[verbose output]' \
  '-w[wait forever for the reply]' \
  '-c+[query class (default IN)]:class:(IN CH HS)' \
  '-t+[query type (e.g. NS A AAAA MX TXT TYPE65535)]:type:' \
  '-R+[UDP retries (default 1)]:n:' \
  '-W+[reply wait time in seconds]:seconds:' \
  '*::name_or_server:_hosts' && ret=0

return ret
