#compdef bamToPsl
# convert a bam file to a psl and optionally a fasta of the reads

local ret=1

_arguments -s -S \
  '-fasta=[output query sequences to specified file]:fa file:_files' \
  '-chromAlias=[two-column file for target name translation]:file:_files' \
  '-nohead[do not output the PSL header]' \
  '-dots=[output progress dot every N alignments]:n' \
  '1:in bam:_files -g "*.bam"' \
  '2:out psl:_files' && ret=0

return ret
