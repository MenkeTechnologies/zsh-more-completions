#compdef miniflux

# completions for Miniflux RSS reader CLI

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message]'
  '(- *)'{-v,--version}'[show version]'
  '(- *)--info[show build information]'
  '-c+[configuration file]:file:_files'
  '--config-file=[configuration file]:file:_files'
  '--create-admin[create an admin user]'
  '--debug[enable debug mode]'
  '--flush-sessions[flush all user sessions]'
  '--healthcheck[perform health check]:url'
  '--migrate[run database migrations]'
  '--refresh-feeds[refresh all feeds]'
  '--reset-feed-errors[reset all feed errors]'
  '--reset-password[reset user password]'
  '--run-cleanup-tasks[run cleanup tasks]'
  '--config-dump[dump parsed configuration as environment variables]'
  '--export-user-feeds=[export user feeds as OPML]:username'
  '*:file:_files'
)

_arguments -s -S $arguments
