#compdef miniflux
# Documentation: https://miniflux.app/docs/cli.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: miniflux uses Go flag package, so single-dash long flags
# (-config-file, -healthcheck) are canonical. Double-dash variants
# happen to work but are not the documented form.

# completions for Miniflux RSS reader CLI

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message]'
  '(- *)'{-v,--version}'[show version]'
  '(- *)'{-i,--info}'[show build information]'
  '(-c --config-file)'{-c,--config-file=}'[configuration file]:file:_files'
  '--create-admin[create an admin user]'
  '--debug[enable debug mode]'
  '--flush-sessions[flush all user sessions]'
  '--healthcheck=[perform health check on endpoint]:url'
  '--migrate[run database migrations]'
  '--refresh-feeds[refresh all feeds]'
  '--reset-feed-errors[reset all feed errors]'
  '--reset-feed-next-check-at[reset feed next-check timing]'
  '--reset-password[reset user password]'
  '--run-cleanup-tasks[run cleanup tasks]'
  '--config-dump[dump parsed configuration as environment variables]'
  '--export-user-feeds=[export feeds for user as OPML]:username'
  '*:file:_files'
)

_arguments -s -S $arguments
