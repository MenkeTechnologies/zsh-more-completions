#compdef Interferogram
# Documentation: https://github.com/senbox-org/s1tbx/blob/master/s1tbx-op-insar/src/main/java/org/esa/s1tbx/insar/gpf/InterferogramOp.java
# ESA SNAP gpt Interferogram operator - form interferogram and coherence from a stack

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show operator help]' \
  '-e[show detailed error messages with stack trace]' \
  '-t+[set target output file]:target:_files' \
  '-f+[set output file format]:format:(GeoTIFF GeoTIFF-BigTIFF HDF5 BEAM-DIMAP NetCDF4-CF)' \
  '-p+[read processing parameters from file]:param file:_files' \
  '-c+[set tile cache size in bytes]:size' \
  '-q+[set maximum parallelism]:threads' \
  '-x[clear internal tile cache after each tile row]' \
  '*-S-[define a source product location]:source=file:_files' \
  '*-D-[define a system property]:name=value' \
  '-PsubtractFlatEarthPhase=-[subtract flat-earth phase]:bool:(true false)' \
  '-PsrpPolynomialDegree=-[order of flat earth phase polynomial]:degree:(1 2 3 4 5 6 7 8)' \
  '-PsrpNumberPoints=-[number of points for flat earth phase estimation]:n:(301 401 501 601 701 801 901 1001)' \
  '-PorbitDegree=-[degree of orbit polynomial interpolator]:degree:(1 2 3 4 5)' \
  '-PincludeCoherence=-[include coherence estimation]:bool:(true false)' \
  '-PcohWinAz=-[coherence window size in azimuth]:size' \
  '-PcohWinRg=-[coherence window size in range]:size' \
  '-PsquarePixel=-[use ground square pixel]:bool:(true false)' \
  '-PsubtractTopographicPhase=-[subtract topographic phase]:bool:(true false)' \
  '-PdemName=-[the digital elevation model]:dem' \
  '-PexternalDEMFile=-[external DEM]:file:_files' \
  '-PexternalDEMNoDataValue=-[DEM no data value]:value' \
  '-PexternalDEMApplyEGM=-[external DEM apply EGM]:bool:(true false)' \
  '-PtileExtensionPercent=-[tile extension percent for DEM simulation]:percent' \
  '-PoutputElevation=-[output elevation]:bool:(true false)' \
  '-PoutputLatLon=-[output lat/lon]:bool:(true false)' \
  '*:source product:_files' && ret=0

return ret
