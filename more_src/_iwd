#compdef iwctl

# Zsh completion for iwd (iNet Wireless Daemon) iwctl command

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-p+[enable prompt functionality]:prompt' \
  '--passphrase=[station passphrase]:passphrase' \
  '--dont-ask[do not prompt for missing credentials]' \
  '--timeout=[timeout in seconds]:seconds' \
  '1:object:->objects' \
  '*::arg:->args' && ret=0

case $state in
  objects)
    local -a objects=(
      'adapter:manage wireless adapters'
      'ap:manage access point mode'
      'debug:debug commands'
      'device:manage wireless devices'
      'dpp:device provisioning protocol'
      'known-networks:manage known networks'
      'station:manage station mode'
      'wsc:Wi-Fi Simple Configuration'
    )
    _describe -t objects 'iwctl object' objects && ret=0
    ;;
  args)
    case $line[1] in
      station)
        if (( CURRENT == 2 )); then
          local -a devices
          devices=(${(f)"$(iwctl device list 2>/dev/null | awk 'NR>4 && NF{print $1}')"})
          _describe -t devices 'wireless device' devices && ret=0
        elif (( CURRENT == 3 )); then
          local -a station_cmds=(
            'connect:connect to a network'
            'connect-hidden:connect to a hidden network'
            'disconnect:disconnect from network'
            'scan:scan for networks'
            'get-networks:list available networks'
            'get-hidden-access-points:list hidden access points'
            'show:show station details'
          )
          _describe -t commands 'station command' station_cmds && ret=0
        fi
        ;;
      device)
        if (( CURRENT == 2 )); then
          local -a devices
          devices=(${(f)"$(iwctl device list 2>/dev/null | awk 'NR>4 && NF{print $1}')"})
          _describe -t devices 'wireless device' devices && ret=0
        elif (( CURRENT == 3 )); then
          local -a device_cmds=(
            'list:list devices'
            'show:show device details'
            'set-property:set device property'
          )
          _describe -t commands 'device command' device_cmds && ret=0
        fi
        ;;
      adapter)
        if (( CURRENT == 2 )); then
          local -a adapters
          adapters=(${(f)"$(iwctl adapter list 2>/dev/null | awk 'NR>4 && NF{print $1}')"})
          _describe -t adapters 'wireless adapter' adapters && ret=0
        elif (( CURRENT == 3 )); then
          local -a adapter_cmds=(
            'list:list adapters'
            'show:show adapter details'
            'set-property:set adapter property'
          )
          _describe -t commands 'adapter command' adapter_cmds && ret=0
        fi
        ;;
      known-networks)
        if (( CURRENT == 2 )); then
          local -a networks
          networks=(${(f)"$(iwctl known-networks list 2>/dev/null | awk 'NR>4 && NF{print $1}')"})
          _describe -t networks 'known network' networks && ret=0
        elif (( CURRENT == 3 )); then
          local -a kn_cmds=(
            'list:list known networks'
            'forget:forget a known network'
            'show:show network details'
            'set-property:set network property'
          )
          _describe -t commands 'known-networks command' kn_cmds && ret=0
        fi
        ;;
      ap)
        if (( CURRENT == 2 )); then
          local -a devices
          devices=(${(f)"$(iwctl device list 2>/dev/null | awk 'NR>4 && NF{print $1}')"})
          _describe -t devices 'wireless device' devices && ret=0
        elif (( CURRENT == 3 )); then
          local -a ap_cmds=(
            'start:start access point'
            'start-profile:start access point with profile'
            'stop:stop access point'
            'show:show access point info'
            'get-clients:list connected clients'
          )
          _describe -t commands 'ap command' ap_cmds && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
