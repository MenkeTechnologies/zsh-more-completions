#compdef brename

# Zsh completion for brename - batch rename via regular expression

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --pattern)'{-p,--pattern}'=[search pattern (regex)]:pattern:' \
  '(-r --replacement)'{-r,--replacement}'=[replacement string]:replacement:' \
  '(-s --path-separator)'{-s,--path-separator}'=[path separator]:separator:' \
  '(-d --include-dir)'{-d,--include-dir}'[include directories in renaming]' \
  '(-D --only-dir)'{-D,--only-dir}'[only rename directories]' \
  '(-e --include-ext)'{-e,--include-ext}'=[only include files with given extension]:extension:' \
  '(-w --overwrite-mode)'{-w,--overwrite-mode}'=[overwrite mode]:mode:' \
  '(-R --recursive)'{-R,--recursive}'[rename recursively]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[ignore case in pattern matching]' \
  '(-n --dry-run)'{-n,--dry-run}'[dry run, show what would be renamed]' \
  '(-f --force)'{-f,--force}'[force rename, overwrite existing files]' \
  '*'{-x,--exclude}'=[exclude files matching pattern]:pattern:' \
  '(-U --undo)'{-U,--undo}'[undo the last rename operation]' \
  '(-l --list)'{-l,--list}'[list files matching pattern]' \
  '--nr-width=[minimum width of number]:width:' \
  '--start-num=[start number for numbering]:number:' \
  '--only-flipped[only show flipped renames]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-k --keep-ext)'{-k,--keep-ext}'[keep file extension unchanged]' \
  '(-K --skip-err)'{-K,--skip-err}'[skip errors and continue]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:path:_files'
