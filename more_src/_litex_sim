#compdef litex_sim
# Documentation: https://github.com/enjoy-digital/litex/blob/master/litex/tools/litex_sim.py
# LiteX Verilator-based SoC simulator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--rom-init=[ROM init file (.bin or .json)]:file:_files' \
  '--ram-init=[RAM init file (.bin or .json)]:file:_files' \
  '--with-sdram[enable SDRAM support]' \
  '--with-sdram-bist[enable SDRAM BIST generator/checker]' \
  '--sdram-module=[select SDRAM chip]:module:' \
  '--sdram-data-width=[set SDRAM chip data width]:width:' \
  '--sdram-init=[SDRAM init file (.bin or .json)]:file:_files' \
  '--sdram-from-spd-dump=[generate SDRAM module from SPD EEPROM dump]:file:_files' \
  '--sdram-verbosity=[set SDRAM checker verbosity]:level:' \
  '--with-ethernet[enable Ethernet support]' \
  '--ethernet-phy-model=[Ethernet PHY to simulate]:model:' \
  '--with-etherbone[enable Etherbone support]' \
  '--local-ip=[local IP address of SoC]:ip:' \
  '--remote-ip=[remote IP address of TFTP server]:ip:' \
  '--with-sdcard[enable SDCard support]' \
  '--with-spi-flash[enable SPI Flash (MMAPed)]' \
  '--with-i2c[enable I2C support]' \
  '--with-jtagremote[enable jtagremote support]' \
  '--with-gpio[enable tristate GPIO (32 pins)]' \
  '--with-video-framebuffer[enable Video Framebuffer]' \
  '--with-video-terminal[enable Video Terminal]' \
  '--with-video-colorbars[enable Video test pattern]' \
  '--with-analyzer[enable Analyzer support]' \
  '--sim-debug[add simulation debugging modules]' \
  '--sim-speed[report effective simulated sys_clk speed]' \
  '--gtkwave-savefile[generate GTKWave savefile]' \
  '--non-interactive[run simulation without user input]' \
  '--trace[enable VCD tracing]' \
  '--trace-fst[enable FST tracing]' \
  '--trace-start=[time to start tracing]:time:' \
  '--trace-end=[time to end tracing]:time:' \
  '*:arg:_files' && ret=0

return ret
