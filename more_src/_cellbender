#compdef cellbender
# Documentation: https://cellbender.readthedocs.io/en/latest/reference/index.html
# cellbender - remove technical artifacts from single-cell data

local ret=1
local -a subcmds

subcmds=(
  'remove-background:remove ambient/background RNA from a count matrix'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'cellbender command' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      remove-background)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--input=[input unfiltered count matrix]:file:_files' \
          '--output=[output .h5 file]:file:_files' \
          '--cuda[enable GPU inference]' \
          '--checkpoint=[checkpoint tarball to resume]:file:_files' \
          '--force-use-checkpoint[bypass checkpoint validation]' \
          '--expected-cells=[approximate cell count]:n:' \
          '--total-droplets-included=[droplets for inference]:n:' \
          '--force-cell-umi-prior=[override UMI prior for cells]:n:' \
          '--force-empty-umi-prior=[override UMI prior for empty droplets]:n:' \
          '--low-count-threshold=[exclude droplets below this UMI count]:n:' \
          '--model=[model to use]:model:(naive simple ambient swapping full)' \
          '--epochs=[training epochs]:n:' \
          '--z-dim=[latent variable z dimension]:n:' \
          '--z-layers=[encoder hidden layer dimensions]:dims:' \
          '--training-fraction=[fraction of data for training]:frac:' \
          '--empty-drop-training-fraction=[fraction from empty droplets]:frac:' \
          '--learning-rate=[learning rate]:rate:' \
          '--constant-learning-rate[use ClippedAdam instead of OneCycleLR]' \
          '--num-training-tries=[retry attempts]:n:' \
          '--learning-rate-retry-mult=[learning rate multiplier per retry]:mult:' \
          '--checkpoint-mins=[checkpoint save interval in minutes]:mins:' \
          '--ignore-features=[feature indices to exclude]:indices:' \
          '--exclude-feature-types=[feature types to skip]:types:' \
          '--projected-ambient-count-threshold=[min ambient counts to include features]:thresh:' \
          '--fpr=[target false positive rate]:fpr:' \
          '--posterior-batch-size=[batch size for posterior]:n:' \
          '--posterior-regularization=[regularization method]:method:(PRq PRmu PRmu_gene)' \
          '--alpha=[tunable parameter for PRq]:alpha:' \
          '--q=[tunable parameter for CDF threshold]:q:' \
          '--estimator=[output estimation method]:method:(map mean cdf sample mckp)' \
          '--estimator-multiple-cpu[parallelize MCKP estimator]' \
          '--final-elbo-fail-fraction=[final ELBO failure threshold]:frac:' \
          '--epoch-elbo-fail-fraction=[per-epoch ELBO failure threshold]:frac:' \
          '--cpu-threads=[CPU thread count]:n:' \
          '--debug[enable debug logging]' \
          '*:file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
