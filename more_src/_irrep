#compdef irrep
# Documentation: https://pypi.org/project/irrep/
# Compute irreducible representations of electronic states from DFT wave functions

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-code=[name of the DFT code]:code:(vasp abinit espresso wannier90)' \
  '-spinor=[wave functions are spinors (T/F, VASP only)]:spinor:(T F)' \
  '-fWFK=[Abinit/QE WFK file with wave functions]:file:_files' \
  '-fWAV=[VASP WAVECAR file]:file:_files' \
  '-fPOS=[VASP POSCAR file]:file:_files' \
  '-Ecut=[plane-wave cutoff in eV]:ecut:' \
  '-kpoints=[indices of k-points to compute]:kpoints:' \
  '-kpnames=[labels for the k-points]:kpnames:' \
  '-EF=[Fermi energy]:ef:' \
  '-IBstart=[starting band index]:ibstart:' \
  '-IBend=[ending band index]:ibend:' \
  '-degenThresh=[degeneracy threshold]:thresh:' \
  '-refUC=[transformation to the conventional cell]:refuc:' \
  '-shiftUC=[shift of the unit cell origin]:shiftuc:' \
  '-searchcell[automatically find transformation to conventional cell]' \
  '-onlysym[only calculate symmetry operations]' \
  '-writebands[write band energies and characters]' \
  '-plotbands[generate a band-structure plot]' \
  '-v[verbosity level]:verbosity:' \
  '*:file:_files' && ret=0

return ret
