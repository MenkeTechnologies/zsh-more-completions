#compdef ods-signerd
# _ods-signerd — OpenDNSSEC ods-signerd (per-zone signer daemon that reads zone files and DNSSEC policy data prepared by ods-enforcerd, then writes signed copies; -c config file, -f foreground, -v verbose, -1 single shot then exit, --version; controlled at runtime by ods-signer(8) over the local control socket)
# upstream: https://github.com/opendnssec/opendnssec
# Flags from opendnssec/opendnssec signer/src on tip.

_ods-signerd() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '-f[foreground]' \
        '-v[verbose]' \
        '-1[single shot]'
}

_ods-signerd "$@"
