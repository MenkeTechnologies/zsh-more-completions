#compdef amdump
# Documentation: https://manpages.ubuntu.com/manpages/focal/man8/amdump.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '--no-taper[disable tape writing]' \
  '--no-dump[disable dump]' \
  '--no-flush[disable flush]' \
  '--no-vault[disable vault]' \
  '--exact-match[exact host/disk match]' \
  '*-o+[config override]:option:' \
  ':config:' \
  '*:host or disk:'
