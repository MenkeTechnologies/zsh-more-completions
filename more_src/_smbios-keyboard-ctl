#compdef smbios-keyboard-ctl
# Documentation: https://man.archlinux.org/search?q=smbios-keyboard-ctl
# Reference accessed: 2026-05-16

# smbios-keyboard-ctl: configure Dell keyboard backlight/lock
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  "--get-backlight[get keyboard backlight]" "--set-backlight=[set backlight (off dim bright)]:val:(off dim bright)" "--get-keyboard-state[get keyboard state]" "--enable-keyboard[enable keyboard]" "--disable-keyboard[disable keyboard]" \
  '*::smbios-keyboard-ctl args:_files' && ret=0
return ret
