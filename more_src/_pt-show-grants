#compdef pt-show-grants
# Documentation: https://docs.percona.com/percona-toolkit/pt-show-grants.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--ask-pass[prompt for password]' \
  '(--buffer-stdout --no-buffer-stdout)'{--buffer-stdout,--no-buffer-stdout}'[enable/disable STDOUT buffering]' \
  '--charset=[default character set]:charset:' \
  '--config=[comma-separated config files]:files:_files' \
  '--convert-MariaDB[convert MariaDB syntax to valid MySQL]' \
  '--database=[default database]:db:' \
  '--defaults-file=[defaults file]:file:_files' \
  '--drop[output DROP USER statements before each user]' \
  '--flush[add FLUSH PRIVILEGES after output]' \
  '(--header --no-header)'{--header,--no-header}'[include dump header]' \
  '--host=[host]:host:_hosts' \
  '--ignore=[ignore these users]:list:' \
  '(--include-unused-roles --no-include-unused-roles)'{--include-unused-roles,--no-include-unused-roles}'[include unused roles in MySQL 8+]' \
  '--mysql_ssl=[create SSL MySQL connection]:n:' \
  '--only=[only these users]:list:' \
  '--password=[password]:pw:' \
  '--pid=[PID file]:file:_files' \
  '--port=[port]:port:' \
  '--revoke[include REVOKE statements]' \
  '--separate[print one grant per line]' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--socket=[socket]:file:_files' \
  '(--timestamp --no-timestamp)'{--timestamp,--no-timestamp}'[include timestamp in header]' \
  '--user=[user]:user:' \
  '*:DSN:' && ret=0

return ret
