#compdef crewai
# Documentation: https://docs.crewai.com/concepts/cli
# Reference accessed: 2026-05-17
# Verified: upstream lib/cli/src/crewai_cli/cli.py at https://github.com/crewAIInc/crewAI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'create:create a new crew or flow'
      'run:run the crew'
      'train:train the crew'
      'test:test the crew'
      'replay:replay a task'
      'log-tasks-outputs:log latest task outputs'
      'reset-memories:reset crew memories'
      'memory:memory management (TUI)'
      'install:install crew dependencies'
      'update:update crewai'
      'version:show installed version'
      'flow:flow management'
      'deploy:manage CrewAI AMP deployments'
      'tool:tool management'
      'template:template management'
      'triggers:trigger management'
      'chat:interactive session with your crew'
      'login:authenticate via device code flow'
      'logout:end session'
      'org:organization management'
      'enterprise:enterprise configuration'
      'config:configuration settings'
      'env:environment commands'
      'traces:trace collection control'
      'checkpoint:checkpoint management'
      'uv:passthrough to uv'
    )
    _describe -t commands 'crewai command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      create)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--provider=[provider to use]:provider:' \
          '--skip_provider[skip provider validation]' \
          '1:type:(crew flow)' \
          '2:name:' && ret=0
        ;;
      train)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-n --n_iterations)'{-n,--n_iterations=}'[number of training iterations]:count:' \
          '(-f --filename)'{-f,--filename=}'[training data file]:file:_files' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-n --n_iterations)'{-n,--n_iterations=}'[number of test iterations]:count:' \
          '(-m --model)'{-m,--model=}'[model to use for testing]:model:' && ret=0
        ;;
      replay)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-t --task_id)'{-t,--task_id=}'[task ID to replay]:task id:' && ret=0
        ;;
      version)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--tools[also show installed tool versions]' && ret=0
        ;;
      reset-memories)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-m --memory)'{-m,--memory}'[reset memory]' \
          '(-l --long)'{-l,--long}'[reset long-term memory]' \
          '(-s --short)'{-s,--short}'[reset short-term memory]' \
          '(-e --entities)'{-e,--entities}'[reset entity memory]' \
          '(-kn --knowledge)'{-kn,--knowledge}'[reset knowledge storage]' \
          '(-a --all)'{-a,--all}'[reset all memories]' && ret=0
        ;;
      flow)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(kickoff plot add-crew)' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(create list status logs push remove validate)' && ret=0
        ;;
      org)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(list current switch)' && ret=0
        ;;
      config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(list set reset)' && ret=0
        ;;
      traces)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(enable disable status)' && ret=0
        ;;
      template)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(list add)' && ret=0
        ;;
      tool)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(create install publish)' && ret=0
        ;;
      triggers)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(list run)' && ret=0
        ;;
      checkpoint)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(list info resume diff prune)' && ret=0
        ;;
      env)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(view)' && ret=0
        ;;
      logout)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--reset[also reset cached state]' && ret=0
        ;;
      run|install|log-tasks-outputs|memory|update|chat|login|enterprise)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
