#compdef crewai
# Documentation: https://github.com/crewAIInc/crewAI
# Reference accessed: 2026-05-23
# Verified: crewai --help (crewai PyPI Typer CLI).

# Zsh completion for crewai - CrewAI multi-agent framework CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'crewai command' \
      'chat[start conversation with Crew]' \
      'checkpoint[browse and inspect checkpoints]' \
      'config[CLI configuration]' \
      'create[create new crew or flow]' \
      'deploy[deploy Crew CLI group]' \
      'enterprise[enterprise configuration]' \
      'env[environment variable commands]' \
      'flow[flow related commands]' \
      'install[install the Crew]' \
      'log-tasks-outputs[retrieve latest task outputs]' \
      'login[sign up or login to CrewAI AMP]' \
      'logout[logout from CrewAI AMP]' \
      'memory[open Memory TUI]' \
      'org[organization management]' \
      'replay[replay crew execution from task]' \
      'reset-memories[reset crew memories]' \
      'run[run the Crew]' \
      'template[browse and install templates]' \
      'test[test crew and evaluate results]' \
      'tool[tool repository commands]' \
      'traces[trace collection management]' \
      'train[train the crew]' \
      'triggers[trigger related commands]' \
      'update[update pyproject.toml for Crew]' \
      'uv[uv wrapper with custom tools]' \
      'version[show installed crewai version]' && ret=0
    ;;
esac

return ret
