#compdef hexchat hexchat-cli
# Documentation: https://man.archlinux.org/search?q=hexchat
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '(-a --no-auto)'{-a,--no-auto}'[do not auto-connect]' \
  '(-d --cfgdir)'{-d+,--cfgdir=}'[config directory]:dir:_files -/' \
  '(-n --no-plugins)'{-n,--no-plugins}'[do not load plugins]' \
  '(-p --plugindir)'{-p+,--plugindir=}'[plugin directory]:dir:_files -/' \
  '(-r --no-auto-connect)'{-r,--no-auto-connect}'[do not auto-connect to servers]' \
  '(-u --existing)'{-u,--existing}'[do not open new instance]' \
  '*--url=[connect to URL]:url:' \
  '*--command=[execute command on startup]:cmd:' \
  '--display=[X display]:display:' \
  '--gdk-debug=[GDK debug flags]:flags:' \
  '--no-xshm[disable X SHM]' \
  '*::passthrough:' && ret=0

return ret
