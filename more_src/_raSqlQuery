#compdef raSqlQuery
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: do a SQL-like query on a RA file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-queryFile=[file containing the query]:file:_files' \
  '-query=[SQL-like query string]:query:' \
  '-db=[act on trackDb files for the given database]:db:' \
  '-addFile[add file field to say where record is defined]' \
  '-addDb[add db field to say where record is defined]' \
  '-strict[only report tracks that exist in db]' \
  '-key=[use this as the key field for merges and parenting]:field:' \
  '-parent[merge together inheriting on parentField]' \
  '-parentField=[field that tells us who is the parent]:field:' \
  '-overrideNeeded[override field-by-field only if override follows track name]' \
  '-noInheritField=[don'\''t inherit from parent if this field present]:field:' \
  '-merge[merge records with same keyField across files]' \
  '-restrict=[restrict output to keys in this file]:file:_files' \
  '*:ra file:_files' && ret=0

return ret
