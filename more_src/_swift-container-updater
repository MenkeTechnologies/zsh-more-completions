#compdef swift-container-updater
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/swift-container-updater.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Swift container updater
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-o[run once and exit]' \
  '--once[run once and exit]' \
  '--devices=[comma-separated device list]:list:' \
  '--policy-name=[storage policy name]:name:' \
  '--partitions=[comma-separated partitions]:list:' \
  '*:swift config file:_files -g "*.conf"' && ret=0
return ret
