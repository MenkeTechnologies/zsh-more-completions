#compdef deploy deploy-rs
# _deploy-rs — multi-profile Nix flake deploy tool (serokell/deploy-rs)
# upstream: https://github.com/serokell/deploy-rs
# Flags from src/cli.rs (clap).

_deploy-rs() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--targets=[multiple deploy targets (flake#profile…)]:targets:' \
        '(-c --checksigs)'{-c,--checksigs}'[check signatures during deploy]' \
        '(-i --interactive)'{-i,--interactive}'[prompt before each activation]' \
        '(-d --debug-logs)'{-d,--debug-logs}'[enable debug logs]' \
        '--log-dir=[log directory]:dir:_files -/' \
        '(-k --keep-result)'{-k,--keep-result}'[keep nix-build result link]' \
        '(-r --result-path)'{-r+,--result-path=}'[result link path]:path:_files' \
        '(-s --skip-checks)'{-s,--skip-checks}'[skip flake checks]' \
        '--remote-build[build on the remote host]' \
        '--ssh-user=[ssh user]:user:_users' \
        '--profile-user=[Nix profile owner]:user:_users' \
        '--ssh-opts=[extra ssh options]:opts:' \
        '--fast-connection=[fast connection optimization]:bool:(true false)' \
        '--auto-rollback=[auto rollback on failure]:bool:(true false)' \
        '--hostname=[override target hostname]:host:_hosts' \
        '--magic-rollback=[enable magic-rollback]:bool:(true false)' \
        '--confirm-timeout=[seconds to wait for confirmation]:secs:' \
        '--activation-timeout=[seconds to wait for activation]:secs:' \
        '--temp-path=[remote temp directory]:path:_files -/' \
        '--dry-activate[dry-run activation]' \
        '--boot[activate on next boot only]' \
        '--rollback-succeeded=[rollback if deploy succeeded]:bool:(true false)' \
        '--sudo=[sudo program]:cmd:' \
        '--interactive-sudo=[interactive sudo prompt]:bool:(true false)' \
        '1:target (flake#profile):' \
        '*::extra build args:'
}

_deploy-rs "$@"
