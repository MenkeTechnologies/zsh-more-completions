#compdef clusteradm
# Documentation: https://open-cluster-management.io/docs/getting-started/installation/start-the-control-plane/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:bootstrap the cluster manager on the hub cluster'
  'join:register a managed cluster to the hub'
  'accept:approve a pending managed cluster CSR'
  'get:get info from the hub (token, hub-info, ...)'
  'clean:uninstall OCM components from the control plane'
  'install:install OCM addons or components'
  'upgrade:upgrade OCM components on the hub'
  'version:show clusteradm and bundle version'
  'addon:manage OCM addons'
  'create:create OCM resources'
  'delete:delete OCM resources'
  'unjoin:un-register a managed cluster from the hub'
  'proxy:proxy interactions with a managed cluster'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--context=[kubeconfig context]:context:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'clusteradm command' commands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--wait[wait until installation completes]' \
          '--context=[kubeconfig context]:context:' \
          '--bundle-version=[OCM bundle version]:version:' \
          '--resource-qos-class=[QoS class]:qos:(Default BestEffort ResourceRequirement)' \
          '--resource-limits=[container resource limits]:limits:' \
          '--resource-requests=[container resource requests]:requests:' \
          '--use-bootstrap-token[use bootstrap token instead of ServiceAccount]' && ret=0
        ;;
      join)
        _arguments \
          '--hub-token=[hub registration token]:token:' \
          '--hub-apiserver=[hub API server URL]:url:' \
          '--wait[wait until join completes]' \
          '--cluster-name=[managed cluster name]:name:' \
          '--force-internal-endpoint-lookup[force internal endpoint lookup]' && ret=0
        ;;
    esac
    ;;
esac

return ret
