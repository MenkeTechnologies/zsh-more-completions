#compdef langchain-cli

# Zsh completion for LangChain CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'app:manage LangServe applications'
      'template:manage LangChain templates'
      'serve:serve a LangServe application'
      'integration:manage integrations'
      'migrate:migrate code to newer versions'
    )
    _describe -t commands 'langchain-cli command' commands && ret=0
    ;;
  args)
    case $line[1] in
      app)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->app_cmds' \
          '*::arg:->app_args' && ret=0
        case $state in
          app_cmds)
            local -a app_commands=(
              'new:create a new LangServe app'
              'add:add a template to the app'
              'remove:remove a template from the app'
            )
            _describe -t commands 'app subcommand' app_commands && ret=0
            ;;
          app_args)
            case $line[1] in
              new)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--name=[application name]:name' \
                  '--package=[packages to include]:package' \
                  '--pip[use pip instead of poetry]' \
                  '1:directory:_directories' && ret=0
                ;;
              add)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--api-path=[API path for the template]:path' \
                  '--pip[use pip instead of poetry]' \
                  '*:template' && ret=0
                ;;
              remove)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '*:template' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      template)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->tpl_cmds' \
          '*::arg:->tpl_args' && ret=0
        case $state in
          tpl_cmds)
            local -a tpl_commands=(
              'new:create a new template'
              'list:list available templates'
            )
            _describe -t commands 'template subcommand' tpl_commands && ret=0
            ;;
          tpl_args)
            case $line[1] in
              new)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--name=[template name]:name' \
                  '1:directory:_directories' && ret=0
                ;;
              list)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--port=[port number]:port' \
          '--host=[host address]:host' && ret=0
        ;;
      integration)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->int_cmds' \
          '*::arg:->int_args' && ret=0
        case $state in
          int_cmds)
            local -a int_commands=(
              'new:create a new integration'
              'create-doc:create documentation for integration'
            )
            _describe -t commands 'integration subcommand' int_commands && ret=0
            ;;
          int_args)
            case $line[1] in
              new)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--name=[integration name]:name' && ret=0
                ;;
              create-doc)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--name=[integration name]:name' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      migrate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--diff[show diff only]' \
          '--include=[include patterns]:pattern' \
          '--exclude=[exclude patterns]:pattern' \
          '*:files:_files -g "*.py"' && ret=0
        ;;
    esac
    ;;
esac

return ret
