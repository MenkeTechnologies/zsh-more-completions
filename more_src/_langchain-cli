#compdef langchain langchain-cli
# Documentation: https://github.com/langchain-ai/langchain
# Reference accessed: 2026-05-23
# Verified: langchain-cli and langchain --help (langchain-cli PyPI).

# Zsh completion for langchain-cli - LangChain / LangServe project CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'langchain command' \
      'migrate[migrate langchain to latest version]' \
      'serve[start LangServe app]' \
      'template[develop installable templates]' \
      'app[manage LangChain apps]' \
      'integration[develop LangChain integration packages]' && ret=0
    ;;
  args)
    case $line[1] in
      app)
        if (( CURRENT == 2 )); then
          _values 'app command' \
            'new[create new LangServe application]' \
            'add[add template to LangServe app]' \
            'remove[remove package from LangServe app]' \
            'serve[start LangServe app]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
