#compdef cd2cue

# cd2cue: emit a CUE sheet from an audio CD
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-d[CD device]:device:_files' \
  '--device=[CD device]:device:_files' \
  '-o[output cue file]:file:_files -g "*.cue"' \
  '--output=[output cue file]:file:_files -g "*.cue"' \
  '*::cd2cue args:_files' && ret=0
return ret
