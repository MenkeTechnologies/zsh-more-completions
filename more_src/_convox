#compdef convox
# Documentation: https://github.com/convox/convox
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above; subcommands from
# docs.convox.com CLI reference.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'apps:list/create/delete apps'
  'build:create a build'
  'builds:list builds'
  'deploy:create and promote a build'
  'deploy-debug:diagnose deploy failures'
  'releases:manage app releases'
  'restart:restart an app'
  'ps:list app processes'
  'services:list services for an app'
  'scale:scale a service'
  'run:execute a command in a new process'
  'exec:execute a command in a running process'
  'cp:copy files to/from a running process'
  'env:manage environment variables'
  'certs:manage SSL certificates'
  'letsencrypt:manage Let'\''s Encrypt configurations'
  'rack:get/configure the rack'
  'racks:list available racks'
  'instances:list rack instances'
  'balancers:list app balancers'
  'resources:manage rack resources'
  'login:authenticate with a rack'
  'logs:get logs for an app'
  'api:query the Rack API'
  'proxy:proxy a connection inside the rack'
  'registries:manage private registries'
  'start:start app locally for development'
  'test:run tests'
  'update:update the CLI or a rack'
  'version:show CLI version'
  'workflows:list / run workflows'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'convox command' commands && ret=0 ;;
esac

return ret
