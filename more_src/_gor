#compdef gor
# Documentation: https://github.com/buger/goreplay
# GoReplay - HTTP traffic replay tool

_arguments -s -S \
  '--input-raw[capture HTTP traffic from given port]:port:' \
  '--input-raw-track-response[enable response tracking for raw input]' \
  '--input-raw-engine[capture engine]:engine:(raw_socket pcap af_packet)' \
  '--input-raw-bpf-filter[BPF filter for raw input]:filter:' \
  '--input-file[replay from file]:file:_files' \
  '--input-tcp[receive traffic from another GoReplay instance]:address:' \
  '--output-http[replay traffic to given endpoint]:URL:' \
  '--output-http-workers[number of parallel workers]:count:' \
  '--output-http-timeout[HTTP request timeout]:duration:' \
  '--output-http-redirects[max number of redirects to follow]:count:' \
  '--output-http-track-response[track HTTP responses]' \
  '--output-file[save traffic to file]:file:_files' \
  '--output-file-append[append to output file instead of overwriting]' \
  '--output-file-flush-interval[flush interval for output file]:duration:' \
  '--output-file-size-limit[size limit for output file]:size:' \
  '--output-file-queue-limit[queue limit for output file]:count:' \
  '--output-tcp[forward traffic to another GoReplay instance]:address:' \
  '--output-stdout[output to stdout]' \
  '--http-allow-url[filter requests by URL regexp]:regexp:' \
  '--http-disallow-url[filter out requests by URL regexp]:regexp:' \
  '--http-allow-header[filter requests by header]:header:' \
  '--http-disallow-header[filter out requests by header]:header:' \
  '--http-allow-method[filter requests by HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '--http-set-header[set request header]:header:' \
  '--http-rewrite-url[rewrite URL using regexp]:rule:' \
  '--http-set-param[set request URL param]:param:' \
  '--http-original-host[use original host header]' \
  '--http-pprof[enable profiling endpoint]:port:' \
  '--middleware[command to use as middleware]:command:' \
  '--prettify-http[prettify HTTP output]' \
  '--split-output[split output into multiple files]' \
  '--recognize-tcp-sessions[recognize TCP sessions]' \
  '--copy-buffer-size[size of copy buffer]:size:' \
  '--stats[enable stats output]' \
  '--exit-after[exit after specified duration]:duration:' \
  '--verbose+[set verbosity level]:level:(0 1 2 3)' \
  '--debug[turn on debug output]' \
  && return 0
