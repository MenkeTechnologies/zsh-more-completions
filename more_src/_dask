#compdef dask

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'scheduler:run a Dask scheduler'
  'worker:run a Dask worker'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'dask subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (scheduler)
        _arguments \
          '--host=[bind host]:host:_hosts' \
          '--port=[bind port]:port:' \
          '--interface=[network interface]:iface:' \
          '--protocol=[protocol]:protocol:(tcp tls inproc ucx)' \
          '--tls-ca-file=[TLS CA file]:file:_files' \
          '--tls-cert=[TLS cert file]:file:_files' \
          '--tls-key=[TLS key file]:file:_files' \
          '--dashboard-address=[dashboard address]:addr:' \
          '--dashboard[enable dashboard]' \
          '--no-dashboard[disable dashboard]' \
          '--dashboard-prefix=[dashboard prefix]:prefix:' \
          '--jupyter[enable jupyter]' \
          '--no-jupyter[disable jupyter]' \
          '--pid-file=[PID file]:file:_files' \
          '--scheduler-file=[scheduler file]:file:_files' \
          '--idle-timeout=[idle timeout]:duration:' \
          '*--preload=[preload module]:module:' && ret=0
        ;;
      (worker)
        _arguments \
          '--host=[bind host]:host:_hosts' \
          '--listen-address=[listen address]:addr:' \
          '--contact-address=[contact address]:addr:' \
          '--interface=[network interface]:iface:' \
          '--protocol=[protocol]:protocol:(tcp tls inproc ucx)' \
          '--nthreads=[threads per worker]:n:' \
          '--nworkers=[number of workers]:n:' \
          '--name=[worker name]:name:' \
          '--memory-limit=[memory limit]:size:' \
          '--nanny[run nanny]' \
          '--no-nanny[run without nanny]' \
          '--nanny-port=[nanny port]:port:' \
          '--worker-port=[worker port]:port:' \
          '--worker-class=[worker class]:class:' \
          '--death-timeout=[death timeout]:duration:' \
          '--lifetime=[worker lifetime]:duration:' \
          '--lifetime-stagger=[lifetime stagger]:duration:' \
          '--lifetime-restart[restart on lifetime end]' \
          '--no-lifetime-restart[do not restart on lifetime]' \
          '--local-directory=[local directory]:dir:_files -/' \
          '--resources=[resources JSON]:json:' \
          '*--preload=[preload module]:module:' \
          '*--preload-nanny=[nanny preload module]:module:' \
          '--scheduler-sni=[scheduler SNI]:name:' \
          '--dashboard[enable dashboard]' \
          '--no-dashboard[disable dashboard]' \
          '--dashboard-address=[dashboard address]:addr:' \
          '--pid-file=[PID file]:file:_files' \
          ':scheduler-address:' && ret=0
        ;;
    esac
    ;;
esac

return ret
