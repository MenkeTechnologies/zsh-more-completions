#compdef k0s
# Documentation: https://docs.k0sproject.io/stable/cli/k0s/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Corrected from prior file: removed obsolete top-level 'default-config'
# and 'validate' (now under 'k0s config'); added real top-level commands
# airgap, api, ctr, keepalived-config, sysinfo; added real controller
# flags --no-taints/--single/--enable-k0s-cloud-provider.

_k0s_commands() {
  local -a commands=(
    'airgap:manage airgap setup'
    'api:run the controller API'
    'backup:create a backup'
    'completion:generate shell completion'
    'config:configuration related sub-commands'
    'controller:run k0s controller'
    'ctr:containerd CLI'
    'docs:generate k0s command documentation'
    'etcd:manage etcd cluster'
    'install:install k0s as a system service'
    'keepalived-config:generate keepalived configuration'
    'kubeconfig:create a kubeconfig file for a specified user'
    'kubectl:run kubectl commands'
    'reset:uninstall k0s and clean up the node'
    'restore:restore k0s state from a backup archive'
    'start:start the k0s service configured on this host'
    'status:get k0s instance status information'
    'stop:stop the k0s service configured on this host'
    'sysinfo:display host information for diagnostics'
    'token:manage join tokens'
    'version:print the k0s version'
    'worker:run k0s worker'
  )
  _describe 'command' commands
}

_k0s() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '(-h --help)'{-h,--help}'[help for k0s]' \
    '(-d --debug)'{-d,--debug}'[debug logging (default: false)]' \
    '(-v --verbose)'{-v,--verbose}'[verbose logging (default: false)]' \
    '--data-dir=[data directory for k0s]:directory:_directories' \
    '1:command:_k0s_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        controller|worker)
          _arguments \
            '(-c --config)'{-c,--config}'=[config file]:file:_files' \
            '--data-dir=[data directory]:directory:_directories' \
            '--enable-worker[enable a worker on the controller node]' \
            '--no-taints[disable default taints for controller node]' \
            '--single[run a single-node cluster]' \
            '--enable-k0s-cloud-provider[enable the k0s cloud provider]' \
            '--token-file=[path to the join token file]:file:_files'
          ;;
        install)
          local -a subcmds=(
            'controller:install k0s controller as a service'
            'worker:install k0s worker as a service'
          )
          _describe 'subcommand' subcmds
          ;;
        config)
          local -a subcmds=(
            'create:output the default k0s configuration yaml to stdout'
            'edit:launch the editor to edit k0s configuration'
            'status:display dynamic configuration reconciliation status'
            'validate:validate k0s configuration'
          )
          _describe 'subcommand' subcmds
          ;;
        token)
          local -a subcmds=(
            'create:create a join token'
            'list:list join tokens'
            'invalidate:invalidate existing join tokens'
            'pre-shared:generate pre-shared join tokens and certs'
          )
          _describe 'subcommand' subcmds
          ;;
        kubeconfig)
          local -a subcmds=(
            'admin:display admin kubeconfig'
            'create:create a kubeconfig for a user'
          )
          _describe 'subcommand' subcmds
          ;;
        etcd)
          local -a subcmds=(
            'leave:leave the etcd cluster'
            'member-list:list etcd cluster members'
          )
          _describe 'subcommand' subcmds
          ;;
        backup)
          _arguments '--save-path=[path to save the backup archive]:directory:_directories'
          ;;
        restore)
          _arguments '1:backup file:_files'
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_k0s "$@"
