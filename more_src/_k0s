#compdef k0s

_k0s_commands() {
  local -a commands=(
    'backup:create a backup'
    'completion:generate shell completion'
    'config:manage k0s configuration'
    'controller:run k0s controller'
    'default-config:output default config'
    'docs:generate documentation'
    'etcd:manage etcd'
    'help:help about any command'
    'install:install k0s as a system service'
    'kubeconfig:manage kubeconfig'
    'kubectl:run kubectl commands'
    'reset:reset k0s node'
    'restore:restore from a backup'
    'start:start the k0s service'
    'status:show k0s status'
    'stop:stop the k0s service'
    'token:manage tokens'
    'validate:validate configuration'
    'version:print version'
    'worker:run k0s worker'
  )
  _describe 'command' commands
}

_k0s() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '-h[display help]' \
    '--help[display help]' \
    '-d[debug logging]' \
    '--debug[debug logging]' \
    '-v[verbose logging]' \
    '--verbose[verbose logging]' \
    '1:command:_k0s_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        controller|worker)
          _arguments \
            '-c[config file]:file:_files' \
            '--config[config file]:file:_files' \
            '--data-dir[data directory]:directory:_directories' \
            '--enable-worker[enable worker on controller]' \
            '--token-file[token file]:file:_files'
          ;;
        install)
          _arguments \
            '1:role:(controller worker)' \
            '-c[config file]:file:_files' \
            '--config[config file]:file:_files'
          ;;
        token)
          local -a subcmds=(
            'create:create a join token'
            'list:list tokens'
            'invalidate:invalidate a token'
          )
          _describe 'subcommand' subcmds
          ;;
        kubeconfig)
          local -a subcmds=(
            'admin:generate admin kubeconfig'
            'create:create kubeconfig for a user'
          )
          _describe 'subcommand' subcmds
          ;;
        backup)
          _arguments '--save-path[backup save path]:directory:_directories'
          ;;
        restore)
          _arguments '1:backup file:_files'
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_k0s "$@"
