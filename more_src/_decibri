#compdef decibri
# Source: cargo binstall decibri-cli@0.1.0
# Probed via: completions zsh
# Repository: https://github.com/decibri/decibri-cli

autoload -U is-at-least

_decibri() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--json[Emit machine-readable JSON output where supported]' \
'-q[Suppress non-essential human output]' \
'--quiet[Suppress non-essential human output]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_decibri_commands" \
"*::: :->decibri" \
&& ret=0
    case $state in
    (decibri)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:decibri-command-$line[1]:"
        case $line[1] in
            (version)
_arguments "${_arguments_options[@]}" : \
'--json[Emit machine-readable JSON output where supported]' \
'-q[Suppress non-essential human output]' \
'--quiet[Suppress non-essential human output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(devices)
_arguments "${_arguments_options[@]}" : \
'(--output)--input[List input devices only]' \
'--output[List output devices only]' \
'--json[Emit machine-readable JSON output where supported]' \
'-q[Suppress non-essential human output]' \
'--quiet[Suppress non-essential human output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(capture)
_arguments "${_arguments_options[@]}" : \
'-o+[Output WAV file path]:OUTPUT:_files' \
'--output=[Output WAV file path]:OUTPUT:_files' \
'-d+[Recording duration. Accepts bare seconds (10, 5.5) or humantime strings (10s, 1m30s). If omitted, records until Ctrl+C]:DURATION:_default' \
'--duration=[Recording duration. Accepts bare seconds (10, 5.5) or humantime strings (10s, 1m30s). If omitted, records until Ctrl+C]:DURATION:_default' \
'-r+[Sample rate in Hz. Default 16000 (voice). Music preset\: 44100]:RATE:_default' \
'--rate=[Sample rate in Hz. Default 16000 (voice). Music preset\: 44100]:RATE:_default' \
'-c+[Number of channels. 1 = mono (default), 2 = stereo]:CHANNELS:_default' \
'--channels=[Number of channels. 1 = mono (default), 2 = stereo]:CHANNELS:_default' \
'--device=[Device name substring (case-insensitive) or numeric index from \`decibri devices\`]:DEVICE:_default' \
'--json[Emit machine-readable JSON output where supported]' \
'-q[Suppress non-essential human output]' \
'--quiet[Suppress non-essential human output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(play)
_arguments "${_arguments_options[@]}" : \
'--device=[Device name substring (case-insensitive) or numeric index from \`decibri devices\`]:DEVICE:_default' \
'--json[Emit machine-readable JSON output where supported]' \
'-q[Suppress non-essential human output]' \
'--quiet[Suppress non-essential human output]' \
'-h[Print help]' \
'--help[Print help]' \
':file -- WAV file to play:_files' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--json[Emit machine-readable JSON output where supported]' \
'-q[Suppress non-essential human output]' \
'--quiet[Suppress non-essential human output]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Target shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_decibri__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:decibri-help-command-$line[1]:"
        case $line[1] in
            (version)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(devices)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(capture)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(play)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_decibri_commands] )) ||
_decibri_commands() {
    local commands; commands=(
'version:Show version and build information' \
'devices:List available audio input and output devices' \
'capture:Record audio from an input device to a WAV file' \
'play:Play a WAV file through an output device' \
'completions:Generate shell completion scripts (plumbing only in v0.1.0)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'decibri commands' commands "$@"
}
