#compdef kubectl-creyaml
# Documentation: https://github.com/sahil-lakhwani/kubectl-creyaml
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-creyaml: generate example CR YAML from a CRD. Invoked as
# `kubectl creyaml <CRD-name>`.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--required[output only required properties]' \
  '*:CRD name:_default'
