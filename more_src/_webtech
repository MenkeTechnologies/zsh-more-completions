#compdef webtech

local -a arguments

arguments=(
  '(-u --urls)'{-u,--urls}'=[target URL]:url:'
  '(-i --inputfile)'{-i,--inputfile}'=[file with URLs to scan]:file:_files'
  '(-o --output)'{-o,--output}'=[output to file]:file:_files'
  '(-of --output-format)'{-of,--output-format}'=[output format]:format:(json csv text)'
  '(-g --grep)'{-g,--grep}'[output in grep-friendly format]'
  '(-ua --user-agent)'{-ua,--user-agent}'=[custom user agent]:user-agent:'
  '--random-user-agent[use random user agent]'
  '(-rh --request-headers)'{-rh,--request-headers}'=[custom request headers as JSON]:headers:'
  '--timeout=[request timeout in seconds]:seconds:'
  '--max-redirects=[maximum number of redirects to follow]:redirects:'
  '--no-verify-ssl[disable SSL certificate verification]'
  '(-h --help)'{-h,--help}'[show help message]'
  '(-V --version)'{-V,--version}'[show version information]'
)

_arguments -s -S $arguments
