#compdef otbcli_PantexTextureExtraction
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_PantexTextureExtraction.html
# Orfeo ToolBox: compute the PanTex built-up texture index on an image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image to compute features on]:image:_files' \
  '-channel[selected channel index]:value:' \
  '-out[output image of texture features]:output:_files' \
  '-min[input image minimum]:value:' \
  '-max[input image maximum]:value:' \
  '-sradx[window radius along X]:value:' \
  '-srady[window radius along Y]:value:' \
  '-nbin[number of bins per axis for histogram]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
