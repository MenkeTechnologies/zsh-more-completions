#compdef create-mercato-app
# Documentation: https://github.com/open-mercato/open-mercato/tree/main/packages/create-app
# Reference accessed: 2026-05-24
# Verified: npm view create-mercato-app bin; create-app README at the URL above.

# Zsh completion for create-mercato-app - Open Mercato application scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--app=[bootstrap official ready app]:app name:' \
  '--app-url=[bootstrap ready app from GitHub URL]:url:' \
  '--skip-agentic-setup[skip interactive agentic setup wizard]' \
  '--init-git[initialize a local Git repository after scaffolding]' \
  '--no-init-git[do not initialize a local Git repository]' \
  '--registry=[custom npm registry URL]:url:' \
  '--verdaccio[use local Verdaccio registry at http://localhost:4873]' \
  ':app name:' && ret=0

return ret
