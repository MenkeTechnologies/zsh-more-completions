#compdef mieli
# _mieli — Rust CLI wrapper around Meilisearch (irevoire/mieli)
# upstream: https://github.com/irevoire/mieli
# Subcommands + flags from src/options.rs + src/meilisearch.rs (clap).

_mieli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global
    global=(
        '*'{-v,--verbose}'[increase log verbosity (repeatable)]'
        '(-a --addr)'{-a+,--addr=}'[Meilisearch server URL]:url:'
        '--async[exit immediately after enqueuing]'
        '(-i --index)'{-i+,--index=}'[Meilisearch index name]:name:'
        '(-k --key)'{-k+,--key=}'[Meilisearch master/API key]:key:'
        '--user-agent=[HTTP User-Agent for requests]:ua:'
        '--custom-header=[extra HTTP header (Name: value)]:header:'
        '--interval=[task status poll interval (ms)]:ms:'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
    )

    _arguments -C $global \
        '1: :_mieli_commands' \
        '*::arg:->args' && ret=0

    return ret
}

(( $+functions[_mieli_commands] )) ||
_mieli_commands() {
    local -a commands
    commands=(
        'self:modify the mieli installation'
        'index:manipulate indexes (alias: indexes, i)'
        'documents:manipulate documents (alias: document, doc, docs, d)'
        'da:shortcut to add documents'
        'dd:shortcut to delete documents'
        'dump:create a Meilisearch dump'
        'snapshot:create a Meilisearch snapshot'
        'tasks:get information on the task queue (alias: task, t)'
        'tl:shortcut to list the tasks'
        'batches:get information about batches (alias: batch, b)'
        'health:healthcheck the Meilisearch instance'
        'version:return the Meilisearch instance version (alias: ver, v)'
        'stats:return per-index stats (alias: stat)'
        'search:search the configured index (use --interactive for TUI)'
        'settings:get or update index settings (alias: set, setting)'
        'key:get or update API keys (alias: keys, k)'
        'log:get or update logs (alias: logs)'
        'experimental:manage experimental features (alias: exp)'
    )
    _describe -t commands 'mieli command' commands
}

_mieli "$@"
