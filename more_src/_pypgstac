#compdef pypgstac
# Documentation: https://stac-utils.github.io/pgstac/pypgstac/
# pyPgSTAC CLI for loading and migrating a pgstac PostgreSQL database

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--dsn=[pgstac database connection URL]:dsn' \
  '--install-completion[install shell completion]' \
  '--show-completion[show shell completion]' \
  '1:command:(initversion load migrate pgready version loadqueryables)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      load)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--dsn=[pgstac database connection URL]:dsn' \
          '--method=[load strategy]:method:(insert insert_ignore upsert delsert)' \
          '1:table:(collections items)' \
          '2:file:_files' && ret=0
        ;;
      loadqueryables)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--dsn=[pgstac database connection URL]:dsn' \
          '--collection_ids=[scope queryables to collections]:ids' \
          '--delete_missing[remove properties absent from source]' \
          '--index_fields=[create indexes only for named fields]:fields' \
          '*:file:_files' && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
