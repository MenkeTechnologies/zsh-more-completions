#compdef asar

# Zsh completion for asar - Electron archive tool

local curcontext="$curcontext" state line ret=1

local -a subcommands
subcommands=(
  'pack:Create an asar archive from a directory'
  'p:Create an asar archive from a directory'
  'extract:Extract an asar archive'
  'e:Extract an asar archive'
  'list:List files in an asar archive'
  'l:List files in an asar archive'
  'extract-file:Extract a single file from an asar archive'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'asar subcommand' subcommands
    ;;
  args)
    case $words[1] in
      pack|p)
        _arguments \
          '1:source directory:_directories' \
          '2:output asar file:_files -g "*.asar"'
        ;;
      extract|e)
        _arguments \
          '1:asar archive:_files -g "*.asar"' \
          '2:destination directory:_directories'
        ;;
      list|l)
        _arguments \
          '(-i --is-pack)'{-i,--is-pack}'[show whether file is packed]' \
          '1:asar archive:_files -g "*.asar"'
        ;;
      extract-file)
        _arguments \
          '1:asar archive:_files -g "*.asar"' \
          '2:file name'
        ;;
    esac
    ;;
esac

return ret
