#compdef minio

# Zsh completion for minio - MinIO object storage server

_minio() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands=(
        'server:start MinIO object storage server'
        'gateway:start MinIO gateway'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'minio command' commands
            ;;
        args)
            case $words[1] in
                server)
                    _arguments -s -S \
                        '(- *)'{-h,--help}'[show help]' \
                        '--address=[bind to a specific ADDRESS:PORT]:address:' \
                        '--console-address=[bind console to a specific ADDRESS:PORT]:address:' \
                        '(-S --certs-dir)'{-S,--certs-dir}'=[path to certs directory]:directory:_directories' \
                        '--quiet[disable startup and info messages]' \
                        '--anonymous[hide sensitive information from logging]' \
                        '--json[output logs in JSON format]' \
                        '*:data directory:_directories'
                    ;;
                gateway)
                    local -a gateway_commands=(
                        'nas:start MinIO gateway for NAS backend'
                    )
                    _arguments -C \
                        '(- *)'{-h,--help}'[show help]' \
                        '1:gateway type:->gwcmd' \
                        '*::arg:->gwargs'
                    case $state in
                        gwcmd)
                            _describe -t gateway_commands 'gateway type' gateway_commands
                            ;;
                        gwargs)
                            _arguments -s -S \
                                '(- *)'{-h,--help}'[show help]' \
                                '--address=[bind to a specific ADDRESS:PORT]:address:' \
                                '--console-address=[bind console to a specific ADDRESS:PORT]:address:' \
                                '(-S --certs-dir)'{-S,--certs-dir}'=[path to certs directory]:directory:_directories' \
                                '--quiet[disable startup and info messages]' \
                                '--anonymous[hide sensitive information from logging]' \
                                '--json[output logs in JSON format]' \
                                '*:path:_directories'
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

_minio "$@"
