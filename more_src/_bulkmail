#compdef bulkmail bulkmaildev
# ============================================================================
# _bulkmail — zsh completion for kumarabhirup's bulk-mail-cli, a Node
#              email-marketing campaign sender (nodemailer ^6.4.2)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/kumarabhirup/bulk-mail-cli
#   Author     : Kumar Abhirup
#   License    : GPL-3.0
#   Language   : TypeScript
#   Package    : bulk-mail-cli v2.0.7
#   Binaries   : bulkmail, bulkmaildev  (both point to
#                ./dist/src/bin/global.js)
#   Last push  : 2020-03-01
#
# WHAT IT IS
#   bulk-mail-cli is "a small but very powerful tool for quick,
#   hassle-free email marketing" — Kumar Abhirup's commander.js CLI
#   that reads a single JSON configuration file (SMTP transport
#   options, sender identity, subject, body template, theme, and a
#   CSV recipient list with personalization columns) and dispatches
#   one nodemailer-built message per row.  A pause/resume facility
#   persists progress so an interrupted campaign can be restarted
#   from the last-sent index without re-sending earlier recipients.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/cli/start.ts commander.js
#                       `program.option(...)` builder)
#   bulkmail [OPTIONS] [SUBCOMMAND]
#   bulkmaildev [OPTIONS] [SUBCOMMAND]
#
#   Options:
#     -f, --file <FILE>      Attach a configuration JSON file
#                            (campaign definition: SMTP, recipients,
#                             subject, body, theme)
#     -r, --restart          Restart the paused campaign from the
#                            persisted progress index
#
#   Subcommands (positional keywords, not separate sub-binaries):
#     support                Print the help banner
#     demo                   Create a sample configuration file
#                            (with themes and a sample CSV recipient
#                             list)
#
#   Standard commander.js auto-flags:
#     -V, --version          Show version
#     -h, --help             Show help
#
#   Both `bulkmail` and `bulkmaildev` package.json bin entries
#   resolve to the same `./dist/src/bin/global.js` — `bulkmaildev`
#   is the development-mode alias and behaves identically.
#
# AXIS / CORPUS POSITION
#   Direct dependency on `nodemailer ^6.4.2` declared in
#   package.json — the canonical Node.js SMTP / email client
#   maintained by Andris Reinman (nodemailer/nodemailer).
#   nodemailer is the de-facto JavaScript email library:  typed
#   transport plugins (SMTP, sendmail, ses, stream), MIME
#   multipart message construction, attachment streaming, embedded
#   images, DKIM signing, OAuth-2 / XOAUTH2 / login / plain SASL
#   authentication, IDN / SMTPUTF8 envelope support, and a typed
#   `Transporter.sendMail({from, to, subject, html, text,
#                          attachments})` API.  bulk-mail-cli's
#   `src/cli/commands/file/` directory loads the configuration JSON,
#   constructs `nodemailer.createTransport(transportOptions)`, and
#   issues `transporter.sendMail({...})` per CSV row with the body
#   template rendered against the row's personalization columns.
#   Verified via:
#     gh api repos/kumarabhirup/bulk-mail-cli/contents/package.json
#       → "nodemailer": "^6.4.2"
#     gh api repos/kumarabhirup/bulk-mail-cli/contents/src/cli/start.ts
#       → program.version(...).option('-f, --file <type>', ...)
#                 .option('-r, --restart', ...)
#                 .option('support', ...).option('demo', ...)
#   This entry is the TS-Node=132 leader bump that CLOSES Axis 77
#   (SMTP / Email Client Library) at 1/1/1 three-language symmetry
#   — pairing Rust=lettre 0.11 (R897 _vigil), Go=wneessen/go-mail
#   v0.7.2 (R898 _paperboy), and TS-Node=nodemailer ^6.4.2 (this
#   entry).  Triple-132 landmark on commit.
#
#   No completion for `bulkmail` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_bulkmail() {
    _arguments -s \
        '(-f --file)'{-f+,--file=}'[attach a configuration JSON file]:config file:_files -g "*.{json,js}"' \
        '(-r --restart)'{-r,--restart}'[restart the paused campaign]' \
        '(- *)'{-V,--version}'[show version]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_bulkmail_commands' \
        '*::arg:_files'
}

(( $+functions[_bulkmail_commands] )) ||
_bulkmail_commands() {
    local -a commands
    commands=(
        'support:print the help banner'
        'demo:create a sample configuration file (themes + sample CSV)'
    )
    _describe -t commands 'bulkmail keyword' commands
}

_bulkmail "$@"
