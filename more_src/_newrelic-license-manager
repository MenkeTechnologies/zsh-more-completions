#compdef newrelic-license-manager
# Documentation: https://man.archlinux.org/search?q=newrelic-license-manager
# Reference accessed: 2026-05-16

# newrelic-license-manager: New Relic License Manager CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'configure:configure license key'
  'install:install license'
  'rotate:rotate license key'
  'status:show license status'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'newrelic-license-manager command' commands && ret=0 ;;
esac
return ret
