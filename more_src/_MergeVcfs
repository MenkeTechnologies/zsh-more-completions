#compdef MergeVcfs
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/vcf/MergeVcfs.java
# Picard: combine multiple VCF or BCF files into one

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-I,--INPUT}'=[VCF/BCF input file or .list of paths]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[merged VCF or BCF output file]:file:_files' \
  '(-D --SEQUENCE_DICTIONARY)'{-D,--SEQUENCE_DICTIONARY}'=[sequence dictionary to use]:file:_files' \
  '(-CO --COMMENT)'{-CO,--COMMENT}'=[header comment]:co:' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
