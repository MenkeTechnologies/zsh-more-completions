#compdef surge

_surge() {
    local line state
    local -a commands
    commands=(
        'server:Launch a headless background server'
        'connect:Connect TUI to a remote/local server'
        'add:Queue a download via CLI'
        'ls:List downloads or show details'
        'pause:Pause a download by ID or prefix'
        'resume:Resume a paused download'
        'rm:Remove a download'
        'token:Print the current API auth token'
        'service:Manage Surge as a system daemon'
    )

    _arguments -C \
        '--host[Target server for TUI/CLI actions]:host:' \
        '--token[Bearer token for API requests]:token:' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'surge command' commands
            ;;
        args)
            case $line[1] in
                add)
                    _arguments \
                        '--output[Output path]:file:_files' \
                        '*:url:'
                    ;;
                ls)
                    _arguments \
                        '--json[Output in JSON format]' \
                        '--watch[Watch for changes]' \
                        '*:id:'
                    ;;
                pause|resume|rm)
                    _arguments \
                        '--all[Apply to all downloads]' \
                        '*:id:'
                    ;;
                server)
                    _arguments \
                        '--port[Port to listen on]:port:' \
                        '--token[Auth token]:token:'
                    ;;
                service)
                    _arguments '1:subcommand:(install start stop)'
                    ;;
            esac
            ;;
    esac
}

_surge "$@"
