#compdef arm-none-eabi-readelf
# _arm-none-eabi-readelf — Arm Limited arm-none-eabi-readelf CLI for the bare-metal ARM cross-readelf displaying ELF header program-headers section-headers symbols string-tables relocations dynamic notes attributes DWARF debug info (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-readelf() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-a[show all]' \
        '--all[show all]' \
        '-H[show ELF header]' \
        '--file-header[show ELF header]' \
        '-l[show program headers]' \
        '--program-headers[show program headers]' \
        '--segments[show program headers]' \
        '-S[show section headers]' \
        '--section-headers[show section headers]' \
        '--sections[show section headers]' \
        '-e[headers]' \
        '--headers[headers]' \
        '-g[section groups]' \
        '--section-groups[section groups]' \
        '-t[section details]' \
        '--section-details[section details]' \
        '-s[symbol table]' \
        '--syms[symbol table]' \
        '--symbols[symbol table]' \
        '-S[show section headers]' \
        '-n[show notes]' \
        '--notes[show notes]' \
        '-r[show relocs]' \
        '--relocs[show relocs]' \
        '-u[show unwind]' \
        '--unwind[show unwind]' \
        '-d[show dynamic section]' \
        '--dynamic[show dynamic section]' \
        '-V[show version sections]' \
        '--version-info[show version sections]' \
        '-A[show ARM attributes]' \
        '--arch-specific[show ARM attributes]' \
        '-I[show histogram]' \
        '--histogram[show histogram]' \
        '-c[show archive index]' \
        '--archive-index[show archive index]' \
        '-D[show dynamic symbols]' \
        '--use-dynamic[show dynamic symbols]' \
        '-W[wide output]' \
        '--wide[wide output]' \
        '-x+[section]:str:' \
        '--hex-dump=+[section]:str:' \
        '-p+[section]:str:' \
        '--string-dump=+[section]:str:' \
        '-w+[debug section]:s:(info abbrev aranges macro frames str loc ranges pubnames pubtypes gdb_index trace_info trace_abbrev trace_aranges)' \
        '--debug-dump=+[debug section]:s:(info abbrev aranges macro frames str loc ranges pubnames pubtypes gdb_index trace_info trace_abbrev trace_aranges)' \
        '--dwarf-depth=+[N]:n:' \
        '--dwarf-start=+[N]:n:' \
        '*:object ELF:_files -g "*.o *.elf *.axf *.so *.a"'
}

_arm-none-eabi-readelf "$@"
