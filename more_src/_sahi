#compdef sahi
# ============================================================================
#  _sahi — SAHI: Slicing Aided Hyper Inference for large-image object detection
#
#  Source-direct extraction from
#    https://github.com/obss/sahi/blob/main/sahi/cli.py
#    https://github.com/obss/sahi/blob/main/sahi/predict.py
#    https://github.com/google/python-fire (Google Fire library)
#
#  Maintained by OBSS (Open Big Science Source) team (obss/sahi).
#  5324 GH stars.  SAHI (Slicing Aided Hyper Inference) is a
#  framework-agnostic object-detection inference + evaluation library
#  for LARGE IMAGES — slices large images (e.g. satellite imagery,
#  drone shots, high-resolution scans) into smaller tiles, runs
#  object detection on each tile (YOLO/Detectron2/MMDet/HuggingFace),
#  and merges overlapping detections back into the original image
#  coordinate space.  Used widely in remote sensing, drone imagery,
#  industrial inspection, and any scenario where objects are small
#  relative to image dimensions.  Sister tools: YOLO (in corpus via
#  _yolo), Ultralytics CLI (in corpus via _yolo), Detectron2 (in
#  corpus), MMDetection (OpenMMLab), Roboflow Supervision (in corpus).
#
#  CLI library taxonomy update: 6th Python CLI library — **Google
#  Fire** (google/python-fire).  Python ecosystem now has 6
#  documented CLI libraries.
#
#  Google Fire (google/python-fire) is Google's "automagic" Python
#  CLI library — generates CLIs from ANY Python object (function,
#  class, dict, module, instance) via runtime introspection.  No
#  decorators, no schema declaration, no boilerplate — just pass an
#  object to `fire.Fire()` and Fire derives the CLI surface from the
#  object's type and structure.  ~28k stars.  Used by SAHI (5324
#  stars, computer vision), aitextgen (1841 stars, GPT-2 text gen
#  library), big-sleep (2570 stars, text-to-image via CLIP+BigGAN),
#  gazoo-device (Google's smart device test framework), tons of
#  Google internal Python tooling, ML research code, and quick-and-
#  dirty CLI wrappers everywhere.
#
#  Google Fire API:
#    import fire
#
#    # 1) Function: each parameter becomes a flag
#    def greet(name, greeting="Hello", count=1):
#      for _ in range(count):
#        print(f"{greeting}, {name}!")
#    fire.Fire(greet)
#    # CLI: greet --name=World --greeting=Hi --count=3
#
#    # 2) Class: instance becomes subcommand group, methods become
#    #    subcommands, __init__ params become top-level flags
#    class Tool:
#      def __init__(self, verbose=False):
#        self.verbose = verbose
#      def add(self, a, b):
#        return a + b
#      def sub(self, a, b):
#        return a - b
#    fire.Fire(Tool)
#    # CLI: tool --verbose=True add 1 2  ⇒ prints 3
#    # CLI: tool sub 5 3                 ⇒ prints 2
#
#    # 3) Dict: keys become subcommands (recursive)
#    sahi_app = {
#      "predict": predict,
#      "coco": {
#        "evaluate": evaluate,
#        "slice": slicer
#      },
#      "version": __version__
#    }
#    fire.Fire(sahi_app)
#    # CLI: sahi predict ...
#    # CLI: sahi coco evaluate ...
#    # CLI: sahi version  ⇒ prints version string
#
#    # 4) Module: all functions and classes become subcommands
#    import mymodule
#    fire.Fire(mymodule)
#
#  Google Fire distinctive features:
#    - "AUTOMAGIC" — generates CLI from ANY Python object via runtime
#      introspection (function signature, class methods, dict keys,
#      module-level definitions); ZERO BOILERPLATE
#    - `fire.Fire(component)` — single entry point; `component` can be
#      a function, class, instance, dict, list, tuple, module, ANY
#      Python value
#    - FUNCTION → CLI: parameters become flags via Python's `inspect`
#      module reading signature, type annotations, and default values
#    - CLASS → SUBCOMMAND GROUP: `__init__` params become top-level
#      flags + methods become subcommands; `Tool --verbose=True add 1 2`
#    - DICT → SUBCOMMANDS: dict keys become subcommands (RECURSIVE —
#      nested dicts become nested subcommand groups)
#    - MODULE → SUBCOMMANDS: module-level functions/classes become
#      subcommands
#    - INSTANCE/OBJECT → ATTRIBUTE TRAVERSAL: nested attribute access
#      via positional `tool sub.attr method` syntax
#    - VALUE → PRINT-AND-EXIT: primitive value (str/int/etc.) just
#      prints when commanded
#    - FLAG SYNTAX: `--flag=value` OR `--flag value` OR `--flag VALUE`
#      OR positional ordering matches signature order
#    - BOOLEAN FLAGS: `--flag` enables (sets True), `--noflag` disables
#      (sets False), `--flag=True` / `--flag=False` explicit
#    - TYPE COERCION via Python type annotations + heuristic parsing
#      (e.g. `--n=42` → int 42, `--ratio=0.5` → float, `--name=Alice`
#      → str, `--items=[1,2,3]` → list, `--data={key: value}` → dict)
#    - HELP via `--help` or `-h` AT ANY LEVEL — Fire generates help
#      from docstrings + signature + nested structure
#    - `--` SEPARATOR for Fire flags vs subcommand: `cmd --flag -- arg1`
#    - INTERACTIVE MODE via `--interactive`: drops into Python REPL with
#      `component` and `result` pre-bound after command execution
#    - COMPLETION SCRIPT GENERATION via `--completion` flag — generates
#      Bash/Zsh/Fish completion script (separate from this _sahi
#      compdef, which is more authoritative)
#    - TRACE MODE via `--trace`: shows component traversal for debugging
#    - SEPARATOR via `--separator=CHAR`: change default `-` separator
#      for ambiguous parses (default `-`)
#    - VERBOSE MODE via `--verbose`: more detailed output
#  Distinct from R270 Python argparse (DECLARATIVE Parser + add_argument
#  with explicit type/help/choices/required/default; SUBPARSERS for
#  subcommands; ArgumentParser class), R277 Python click (DECORATOR-
#  DRIVEN with `@click.command`/`@click.option`/`@click.argument`),
#  R278 Python typer (CLICK-WRAPPER with Python type annotations for
#  schema; from typer.Typer), R345 Python cyclopts (modern type-
#  hint-driven by BrianPugh — closest analog to Fire's introspection
#  but with type-strict design), R352 Python docopt (HELP-TEXT-AS-SCHEMA
#  — usage string IS the spec).  Google Fire's approach: AUTOMAGIC
#  INTROSPECTION of ANY Python object + ZERO BOILERPLATE + DICT/CLASS/
#  MODULE-AS-SUBCOMMAND-GROUP + RECURSIVE NESTED DICTS + ATTRIBUTE
#  TRAVERSAL via positional args + INTERACTIVE/TRACE/COMPLETION
#  built-in modes — corpus's **first documented runtime-introspection-
#  of-any-Python-object CLI library**.  Brings cross-language CLI
#  library taxonomy variant count to 117; Python ecosystem now has 6
#  documented CLI libraries — tied for SECOND-MOST-DOCUMENTED CLI
#  language (after Rust 9 + Go 9, tied with future expansion).
#
#  Surface (verbatim from `cli.py` `sahi_app` dict + `predict.py`
#  function signatures; Fire auto-derives flags from parameter names):
#
#  Top-level subcommands:
#    sahi predict ...                  Run inference (sliced or whole-
#                                      image) on images / videos
#    sahi predict-fiftyone ...         Run inference + push to FiftyOne
#                                      visualization platform
#    sahi coco SUBCMD ...              COCO dataset utilities
#    sahi version                      Print SAHI version
#    sahi env                          Print environment info
#                                      (Python/PyTorch/MMDet/YOLO
#                                      versions)
#
#  COCO subcommands (sahi coco SUBCMD ...):
#    sahi coco evaluate ...            COCO evaluation (mAP, mAR)
#    sahi coco analyse ...             COCO error analysis (TP/FP/FN
#                                      breakdown by category)
#    sahi coco fiftyone ...            Convert COCO annotations →
#                                      FiftyOne format
#    sahi coco slice ...               Slice large COCO dataset into
#                                      tiled training set
#    sahi coco yolo ...                Convert COCO → YOLO format
#                                      (alias: yolov5)
#    sahi coco yolov5 ...              Convert COCO → YOLOv5 format
#
#  sahi predict flags (Fire auto-derives from predict() signature):
#    --model_type STR                  Model backend: ultralytics |
#                                      mmdet | huggingface | torchvision
#                                      (default: ultralytics)
#    --model_path PATH                 Model weights file path
#    --model_config_path PATH          Model config file path (mmdet)
#    --model_confidence_threshold FLT  Confidence threshold (default 0.25)
#    --model_device STR                Device: cpu | cuda:0 | mps
#    --source PATH                     Image/video/directory path
#    --no_standard_prediction          Skip whole-image inference
#    --no_sliced_prediction            Skip sliced inference
#    --image_size INT                  Image size for inference
#    --slice_height INT                Slice height (default 512)
#    --slice_width INT                 Slice width (default 512)
#    --overlap_height_ratio FLT        Slice overlap height ratio (0.2)
#    --overlap_width_ratio FLT         Slice overlap width ratio (0.2)
#    --postprocess_type STR            NMS type: GREEDYNMM | NMS | NMM
#                                      (default GREEDYNMM)
#    --postprocess_match_metric STR    Match metric: IOS | IOU
#    --postprocess_match_threshold FLT NMS match threshold (default 0.5)
#    --postprocess_class_agnostic      Class-agnostic NMS
#    --novisual                        Skip visual output generation
#    --view_video                      View video during processing
#    --frame_skip_interval INT         Video frame skip interval
#    --export_pickle                   Export predictions as .pickle
#    --export_crop                     Export crops of detected objects
#    --dataset_json_path PATH          Path to dataset JSON (COCO format)
#    --project STR                     Output project name (runs/predict)
#    --name STR                        Output run name (exp)
#    --visual_bbox_thickness INT       Bounding box line thickness
#    --visual_text_size FLT            Label text size
#    --visual_text_thickness INT       Label text thickness
#    --visual_hide_labels              Hide class labels in visualization
#    --visual_hide_conf                Hide confidence scores
#    --visual_export_format STR        Visual format: png | jpg
#    --verbose INT                     Verbose level (default 1)
#    --return_dict                     Return result as dict
#    --force_postprocess_type          Force postprocess type
#    --exclude_classes_by_name LIST    Exclude classes by name list
#    --exclude_classes_by_id LIST      Exclude classes by ID list
#    --progress_bar                    Show progress bar
#
#  Fire built-in flags (always present):
#    --help, -h                        Show help (works at any level)
#    --interactive                     Drop into Python REPL post-command
#    --trace                           Show component traversal trace
#    --separator=CHAR                  Default separator (default `-`)
#    --completion                      Generate Bash/Zsh/Fish completion
#                                      script (Fire's auto-generated;
#                                      THIS _sahi compdef is preferred)
#    --verbose                         Verbose Fire output
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also Fire-based or considered):
#    - aitextgen (minimaxir/aitextgen 1841 stars — uses Fire but
#      smaller surface; FUTURE candidate)
#    - big-sleep (lucidrains/big-sleep 2570 stars — uses Fire but
#      narrow text-to-image use case)
#    - gazoo-device (google/gazoo-device 28 stars — Google IoT test
#      framework, smaller community)
#    - aria2cli (FlashWingShadow — Fire wrapper for aria2, niche)
#    - slack-cli (IN CORPUS via _slack-cli)
#    - labelImg / image-annotation tools (use argparse, not Fire)
#    - Most Hugging Face / PyTorch / Keras research scripts use Fire
#      but aren't shipped as distributable CLI binaries
# ============================================================================

_sahi() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '--interactive[drop into Python REPL post-command]' \
    '--trace[show component traversal trace]' \
    '--separator=[default separator (default -)]:char' \
    '--completion[generate Bash/Zsh/Fish completion script]' \
    '--verbose[verbose Fire output]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs=(
        'predict:run inference (sliced or whole-image) on images/videos'
        'predict-fiftyone:run inference and push to FiftyOne'
        'coco:COCO dataset utilities'
        'version:print SAHI version'
        'env:print environment info'
      )
      _describe -t commands 'sahi subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        predict|predict-fiftyone)
          _arguments -s -S \
            '--model_type=[model backend]:type:(ultralytics mmdet huggingface torchvision)' \
            '--model_path=[model weights file path]:file:_files' \
            '--model_config_path=[model config file path (mmdet)]:file:_files' \
            '--model_confidence_threshold=[confidence threshold (default 0.25)]:float' \
            '--model_device=[device]:device:(cpu cuda:0 cuda:1 mps)' \
            '--source=[image/video/directory path]:path:_files' \
            '--no_standard_prediction[skip whole-image inference]' \
            '--no_sliced_prediction[skip sliced inference]' \
            '--image_size=[image size for inference]:size' \
            '--slice_height=[slice height (default 512)]:px' \
            '--slice_width=[slice width (default 512)]:px' \
            '--overlap_height_ratio=[slice overlap height ratio (default 0.2)]:ratio' \
            '--overlap_width_ratio=[slice overlap width ratio (default 0.2)]:ratio' \
            '--postprocess_type=[NMS type]:type:(GREEDYNMM NMS NMM)' \
            '--postprocess_match_metric=[match metric]:metric:(IOS IOU)' \
            '--postprocess_match_threshold=[NMS match threshold (default 0.5)]:threshold' \
            '--postprocess_class_agnostic[class-agnostic NMS]' \
            '--novisual[skip visual output generation]' \
            '--view_video[view video during processing]' \
            '--frame_skip_interval=[video frame skip interval]:n' \
            '--export_pickle[export predictions as .pickle]' \
            '--export_crop[export crops of detected objects]' \
            '--dataset_json_path=[path to dataset JSON (COCO)]:file:_files -g "*.json"' \
            '--project=[output project name (runs/predict)]:name' \
            '--name=[output run name (exp)]:name' \
            '--visual_bbox_thickness=[bbox line thickness]:px' \
            '--visual_text_size=[label text size]:float' \
            '--visual_text_thickness=[label text thickness]:px' \
            '--visual_hide_labels[hide class labels in visualization]' \
            '--visual_hide_conf[hide confidence scores]' \
            '--visual_export_format=[visual format]:format:(png jpg)' \
            '--verbose=[verbose level (default 1)]:n' \
            '--return_dict[return result as dict]' \
            '--force_postprocess_type[force postprocess type]' \
            '--exclude_classes_by_name=[exclude classes by name]:names' \
            '--exclude_classes_by_id=[exclude classes by ID]:ids' \
            '--progress_bar[show progress bar]' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        coco)
          _arguments -C \
            '1: :->cocosub' \
            '*:: :->cocoargs'
          case $state in
            cocosub)
              local -a coco_verbs=(
                'evaluate:COCO evaluation (mAP, mAR)'
                'analyse:COCO error analysis (TP/FP/FN breakdown)'
                'fiftyone:convert COCO annotations to FiftyOne format'
                'slice:slice large COCO dataset into tiled training set'
                'yolo:convert COCO to YOLO format'
                'yolov5:convert COCO to YOLOv5 format'
              )
              _describe -t commands 'sahi coco subcommand' coco_verbs
              ;;
            cocoargs)
              _arguments -s -S \
                '*:argument or flag:_files'
              ;;
          esac
          ;;
        version|env)
          ;;
      esac
      ;;
  esac
}

_sahi "$@"
