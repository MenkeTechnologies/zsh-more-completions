#compdef FilterAlignmentArtifacts
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/realignmentfilter/FilterAlignmentArtifacts.java
# GATK4: filter Mutect2 calls that are alignment artifacts via realignment

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --variant)'{-V,--variant}'[input VCF of variants to filter]:file:_files -g "*.(vcf|vcf.gz)"' \
  '(-I --input)'{-I,--input}'[input BAM/CRAM file]:file:_files -g "*.(bam|cram|sam)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-O --output)'{-O,--output}'[output filtered VCF file]:file:_files -g "*.(vcf|vcf.gz)"' \
  '--indel-start-tolerance=[max distance between indel start of aligned read and variant in the vcf]:n:' \
  '--kmer-size=[kmer size for reassembly]:n:' \
  '--dont-skip-filtered-variants[try to realign all variants, even already-filtered ones]' \
  '(-bamout --bam-output)'{-bamout,--bam-output}'[file to which assembled haplotypes should be written]:file:_files -g "*.bam"' \
  '--smith-waterman=[Smith-Waterman implementation to use]:impl:' \
  '*:options:_files' && ret=0

return ret
