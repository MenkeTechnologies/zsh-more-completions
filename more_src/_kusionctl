#compdef kusionctl
# Documentation: https://www.kusionstack.io/docs/v0.12/reference/commands/kusion-destroy
# Kusion CLI (kusionctl binary) for managing intent-driven infrastructure stacks

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-w --workdir)'{-w,--workdir}'=[the work directory to run Kusion CLI]:dir:_files -/' \
  '--workspace=[name of target workspace to operate in]:workspace' \
  '*:command:((
    init\:"initialize KCL file structure for a new project"
    compile\:"compile KCL into YAML"
    check\:"check if KCL configurations are okay to compile"
    ls\:"list all project and stack information"
    deps\:"show KCL file dependency information"
    preview\:"preview resource changes within the stack"
    apply\:"apply a configuration stack to resources"
    destroy\:"destroy a configuration stack of resources"
    env\:"print Kusion environment information"
    completion\:"generate shell autocompletion script"
    version\:"print the kusion version info"
  ))' && ret=0

return ret
