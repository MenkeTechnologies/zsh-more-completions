#compdef eix

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --compact)'{-c,--compact}'[compact output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-V --versionlines)'{-V,--versionlines}'[show version lines]' \
  '(-l --versionlines-verbose)'{-l,--versionlines-verbose}'[verbose version lines]' \
  '(-C --care)'{-C,--care}'[only print packages in portage tree]' \
  '(-e --exact)'{-e,--exact}'[exact category/name match]' \
  '(-f --fuzzy)'{-f,--fuzzy}'[fuzzy matching]' \
  '(-r --regex)'{-r,--regex}'[use regular expressions]' \
  '(-p --pattern)'{-p,--pattern}'[use wildcards/glob patterns]' \
  '(-s --name)'{-s,--name}'[match in package name only]' \
  '(-S --description)'{-S,--description}'[match in description]' \
  '(-H --homepage)'{-H,--homepage}'[match in homepage]' \
  '(-A --category)'{-A,--category}'[match in category]' \
  '-I[match only installed packages]' \
  '-i[match only installed packages in tree]' \
  '-U[match only packages with update available]' \
  '-u[match only upgradable packages]' \
  '-D[match packages with inapplicable DEPEND]' \
  '-d[match only packages with uninstalled DEPEND]' \
  '--world[match only world packages]' \
  '--world-all[match world and system packages]' \
  '--system[match only system packages]' \
  '--selected[match only selected packages]' \
  '--selected-sets[match only packages from selected sets]' \
  '--binary[match only binary packages]' \
  '--stable[match only stable packages]' \
  '--testing[match only testing packages]' \
  '--non-masked[match only non-masked packages]' \
  '--installed-unstable[match installed unstable packages]' \
  '--installed-testing[match installed testing packages]' \
  '--installed-masked[match installed masked packages]' \
  '--upgrade[match packages where upgrade is available]' \
  '--format+[custom output format]:format:' \
  '--pure-packages[only print package names]' \
  '--xml[output as XML]' \
  '--json[output as JSON]' \
  '-n[do not use colors]' \
  '*:search pattern:' && ret=0

return ret
