#compdef flint

# Zsh completion for flint contributor checklist (codegangsta/cli v1)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--skip-readme[skip README check]' \
  '--skip-contributing[skip CONTRIBUTING check]' \
  '--skip-license[skip LICENSE check]' \
  '--skip-bootstrap[skip bootstrap script check]' \
  '--skip-test-script[skip package.json test script check]' \
  '--skip-scripts[skip all script checks]' \
  '--no-color[disable ANSI colors]' \
  '--skip-changelog[skip changelog check]' \
  '--skip-code-of-conduct[skip CoC check]' \
  '(-g --github)'{-g,--github}'[GitHub repo owner/name]:repo' \
  '(-t --token)'{-t,--token}'[GitHub API token]:token' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && ret=0

return ret
