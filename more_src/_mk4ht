#compdef mk4ht
# Documentation: https://www.tug.org/applications/tex4ht/mn-commands.html
# Documentation: mk4ht perl script @options table (Eitan M. Gurari, TeX4ht)
# Reference accessed: 2026-05-27
# Verified: upstream @options array in /Library/TeX/texbin/mk4ht (texlive)

# Zsh completion for mk4ht (TeX4ht driver).
# Usage: mk4ht command file.tex ["tex4ht.sty op."] ["tex4ht op."] ["t4ht op"] ["latex op"]
# Each command is <variant><dialect>, where:
#   variants: ht xh uxh xhm mz oo es js jm tei teim db dbm w jh
#   dialects: latex tex texi context xelatex xetex

local curcontext="$curcontext" state line ret=1
local -a _mk4ht_commands

_mk4ht_commands=(
  'htlatex:LaTeX to HTML (htf fonts, validate html)'
  'httex:plain TeX to HTML'
  'httexi:Texinfo to HTML'
  'htcontext:ConTeXt to HTML'
  'htxetex:XeTeX to HTML'
  'htxelatex:XeLaTeX to HTML'
  'xhlatex:LaTeX to XHTML'
  'xhtex:plain TeX to XHTML'
  'xhtexi:Texinfo to XHTML'
  'xhcontext:ConTeXt to XHTML'
  'xhxelatex:XeLaTeX to XHTML'
  'xhxetex:XeTeX to XHTML'
  'uxhlatex:LaTeX to XHTML with unicode (uni-html4)'
  'uxhtex:plain TeX to XHTML with unicode'
  'uxhtexi:Texinfo to XHTML with unicode'
  'uxhcontext:ConTeXt to XHTML with unicode'
  'uxhxelatex:XeLaTeX to XHTML with unicode'
  'uxhxetex:XeTeX to XHTML with unicode'
  'xhmlatex:LaTeX to XHTML with MathML'
  'xhmtex:plain TeX to XHTML with MathML'
  'xhmtexi:Texinfo to XHTML with MathML'
  'xhmcontext:ConTeXt to XHTML with MathML'
  'xhmxelatex:XeLaTeX to XHTML with MathML'
  'xhmxetex:XeTeX to XHTML with MathML'
  'mzlatex:LaTeX to XHTML+MathML for Mozilla browsers'
  'mztex:plain TeX to XHTML+MathML for Mozilla'
  'mztexi:Texinfo to XHTML+MathML for Mozilla'
  'mzcontext:ConTeXt to XHTML+MathML for Mozilla'
  'mzxelatex:XeLaTeX to XHTML+MathML for Mozilla'
  'mzxetex:XeTeX to XHTML+MathML for Mozilla'
  'oolatex:LaTeX to OpenOffice (sxw/odt) format'
  'ootex:plain TeX to OpenOffice format'
  'ootexi:Texinfo to OpenOffice format'
  'oocontext:ConTeXt to OpenOffice format'
  'ooxelatex:XeLaTeX to OpenOffice format'
  'ooxetex:XeTeX to OpenOffice format'
  'eslatex:LaTeX to Emacspeak-friendly XHTML'
  'estex:plain TeX to Emacspeak XHTML'
  'estexi:Texinfo to Emacspeak XHTML'
  'escontext:ConTeXt to Emacspeak XHTML'
  'esxelatex:XeLaTeX to Emacspeak XHTML'
  'esxetex:XeTeX to Emacspeak XHTML'
  'jslatex:LaTeX to XHTML with JsMath (jsml)'
  'jstex:plain TeX to XHTML with JsMath'
  'jstexi:Texinfo to XHTML with JsMath'
  'jscontext:ConTeXt to XHTML with JsMath'
  'jsxelatex:XeLaTeX to XHTML with JsMath'
  'jsxetex:XeTeX to XHTML with JsMath'
  'jmlatex:LaTeX to XHTML with jsMath script'
  'jmtex:plain TeX to XHTML with jsMath'
  'jmtexi:Texinfo to XHTML with jsMath'
  'jmcontext:ConTeXt to XHTML with jsMath'
  'jmxelatex:XeLaTeX to XHTML with jsMath'
  'jmxetex:XeTeX to XHTML with jsMath'
  'teilatex:LaTeX to TEI XML'
  'teitex:plain TeX to TEI XML'
  'teitexi:Texinfo to TEI XML'
  'teicontext:ConTeXt to TEI XML'
  'teixelatex:XeLaTeX to TEI XML'
  'teixetex:XeTeX to TEI XML'
  'teimlatex:LaTeX to TEI XML with MathML'
  'teimtex:plain TeX to TEI XML with MathML'
  'teimtexi:Texinfo to TEI XML with MathML'
  'teimcontext:ConTeXt to TEI XML with MathML'
  'dblatex:LaTeX to DocBook XML'
  'dbtex:plain TeX to DocBook XML'
  'dbtexi:Texinfo to DocBook XML'
  'dbcontext:ConTeXt to DocBook XML'
  'dbxelatex:XeLaTeX to DocBook XML'
  'dbxetex:XeTeX to DocBook XML'
  'dbmlatex:LaTeX to DocBook XML with MathML'
  'dbmtex:plain TeX to DocBook XML with MathML'
  'dbmtexi:Texinfo to DocBook XML with MathML'
  'dbmcontext:ConTeXt to DocBook XML with MathML'
  'wlatex:LaTeX to WML (Wireless Markup Language)'
  'wtex:plain TeX to WML'
  'wtexi:Texinfo to WML'
  'wcontext:ConTeXt to WML'
  'wxelatex:XeLaTeX to WML'
  'wxetex:XeTeX to WML'
  'jhlatex:LaTeX to JavaHelp HTML'
  'jhtex:plain TeX to JavaHelp HTML'
  'jhtexi:Texinfo to JavaHelp HTML'
  'jhcontext:ConTeXt to JavaHelp HTML'
  'jhxelatex:XeLaTeX to JavaHelp HTML'
  'jhxetex:XeTeX to JavaHelp HTML'
)

_arguments -C \
  '1: :->cmd' \
  '2: :->file' \
  '3: :->styopts' \
  '4: :->t4htopts' \
  '5: :->t4topts' \
  '6: :->latexopts' && ret=0

case $state in
  cmd)
    _describe -t commands 'mk4ht command' _mk4ht_commands && ret=0
    ;;
  file)
    _files -g '*.(tex|ltx|texi|TEX|LTX)(-.)' && ret=0
    ;;
  styopts|t4htopts|t4topts|latexopts)
    _message 'quoted option string (may be empty)' && ret=0
    ;;
esac

return ret
