#compdef bibutils xml2bib xml2ris xml2end xml2word xml2ads xml2isi xml2nbib copac2xml end2xml endx2xml isi2xml ebi2xml ads2xml wordbib2xml
# _bibutils — Chris Putnam bibutils CLI suite umbrella around bib2xml ris2xml med2xml end2xml endx2xml ads2xml isi2xml copac2xml wordbib2xml + xml2bib xml2ris xml2end xml2word xml2ads xml2isi xml2nbib pivoting reference formats through canonical MODS XML representation (Chris Putnam team, C); getopt
# upstream: https://sourceforge.net/projects/bibutils/

_bibutils() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[debug level]:l:(0 1 2 3 4 5)' \
        '-i+[input encoding]:e:(utf8 latin1 cp1250 cp1251 cp1252 koi8-r euc-jp gb2312 big5 shift-jis iso-8859-1 iso-8859-2 iso-8859-15)' \
        '--input-encoding=+[enc]:str:' \
        '-o+[output encoding]:e:(utf8 latin1 cp1252 iso-8859-1 iso-8859-2 iso-8859-15)' \
        '--output-encoding=+[enc]:str:' \
        '-u[input UTF-8 with BOM]' \
        '-un[input UTF-8 no BOM]' \
        '-x[output XML]' \
        '-nb[no BOM]' \
        '-w[wrap output]' \
        '-s[output single entry mode]' \
        '-c+[corporation tag]:str:' \
        '-a[assemble all to single MODS]' \
        '-nl[no latex output]' \
        '-nb[no BOM]' \
        '-fc[final cleanup]' \
        '-sd[output safe-doctype]' \
        '-b+[brackets style]:str:' \
        '*:input file:_files'
}

_bibutils "$@"
