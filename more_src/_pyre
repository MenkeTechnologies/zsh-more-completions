#compdef pyre

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--source-directory=[directory with source files]:directory:_directories' \
  '*--search-path=[additional directories for module lookup]:directory:_directories' \
  '--typeshed=[path to typeshed stubs]:directory:_directories' \
  '--noninteractive[disable interactive logging]' \
  '--output=[output format]:format:(text json sarif)' \
  '--verbose[enable verbose logging]' \
  '--log-directory=[directory for logs]:directory:_directories' \
  '--local-configuration=[path to local pyre configuration]:file:_files' \
  '--dot-pyre-directory=[path to .pyre directory]:directory:_directories' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'check:run a full type check'
      'start:start the pyre server'
      'stop:stop the pyre server'
      'restart:restart the pyre server'
      'incremental:run an incremental type check'
      'initialize:set up pyre for a project'
      'init:set up pyre for a project'
      'analyze:run an analysis'
      'query:query the pyre server'
      'rage:collect debugging information'
      'kill:force stop all running pyre servers'
      'persistent:run as a language server'
      'servers:list running pyre servers'
    )
    _describe -t commands 'pyre command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (check|incremental)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--source-directory=[directory with source files]:directory:_directories' \
          '*--search-path=[additional directories for module lookup]:directory:_directories' \
          '--output=[output format]:format:(text json sarif)' \
          '--noninteractive[disable interactive logging]' && ret=0
        ;;
      (start|restart)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--source-directory=[directory with source files]:directory:_directories' \
          '--terminal[run in the foreground]' \
          '--store-type-check-resolution[store extra information for type check resolution]' \
          '--no-watchman[do not use watchman]' && ret=0
        ;;
      (query)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:query' && ret=0
        ;;
      (analyze)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--analysis=[analysis to run]:analysis' \
          '--save-results-to=[save results to file]:file:_files' \
          '--no-verify[do not verify models]' && ret=0
        ;;
      (initialize|init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--local[create a local configuration]' && ret=0
        ;;
      (stop|kill|rage|persistent|servers)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
