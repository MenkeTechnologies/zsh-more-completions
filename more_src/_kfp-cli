#compdef kfp-cli kfp
# Documentation: https://man.archlinux.org/search?q=kfp-cli
# Reference accessed: 2026-05-16

# kfp: Kubeflow Pipelines CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'pipeline:manage pipelines'
  'run:manage runs'
  'recurring-run:manage recurring runs'
  'experiment:manage experiments'
  'job:manage jobs (deprecated)'
  'diagnose-me:diagnose kfp config'
  'components:component commands'
  'dsl-compile:compile a DSL pipeline'
  'dsl-compile-deprecated:compile (deprecated DSL)'
  'output:configure output'
  'k8s:k8s helpers'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--endpoint=[Kubeflow Pipelines endpoint]:url:' \
  '--iap-client-id=[IAP client id]:id:' \
  '--namespace=[k8s namespace]:ns:' \
  '--other-client-id=[other client id]:id:' \
  '--other-client-secret=[other client secret]:secret:' \
  '--output=[output format]:fmt:(table json)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'kfp command' commands && ret=0 ;;
esac
return ret
