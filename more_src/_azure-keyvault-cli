#compdef azure-keyvault-cli az-keyvault akv-cli
# _azure-keyvault-cli — Microsoft Azure azure-keyvault-cli CLI alternative ergonomic command-line frontend wrapping the Azure Key Vault Azure Managed HSM service managing secrets keys certificates create get list backup restore purge recover rotate import export key-versions authentication-via-managed-identity service-principal device-code (Microsoft team, Go); cobra
# upstream: https://learn.microsoft.com/en-us/azure/key-vault/

_azure-keyvault-cli() {
    local -a sub=(
        'create:create a vault'
        'delete:delete a vault'
        'list:list vaults'
        'show:show vault details'
        'secret:secret operations'
        'key:key operations'
        'certificate:certificate operations'
        'storage:storage account operations'
        'role:RBAC role operations'
        'network-rule:network rule operations'
        'security-domain:security domain operations'
        'purge:purge a deleted vault'
        'recover:recover a deleted vault'
        'backup:backup vault'
        'restore:restore vault'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--subscription=+[id]:str:' \
        '--resource-group=+[rg]:str:' \
        '-g+[resource group]:str:' \
        '--name=+[vault name]:str:' \
        '-n+[name]:str:' \
        '--location=+[loc]:str:' \
        '-l+[location]:str:' \
        '--sku=+[sku]:s:(standard premium)' \
        '--enable-soft-delete=+[bool]:s:(true false)' \
        '--enable-rbac-authorization=+[bool]:s:(true false)' \
        '--enable-purge-protection=+[bool]:s:(true false)' \
        '--retention-days=+[N]:n:' \
        '--tenant-id=+[id]:str:' \
        '-o+[output]:f:(json yaml table jsonc tsv)' \
        '--output=+[format]:f:(json yaml table jsonc tsv)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'azure-keyvault-cli subcommand' sub ;;
        args)
            case $words[1] in
                secret|key|certificate) _arguments \
                    '1:op:(set show list backup restore download import delete purge recover)' \
                    '--vault-name=+[name]:str:' \
                    '--id=+[uri]:str:' \
                    '*:resource name:' ;;
                show|delete|backup|restore|purge|recover) _arguments '*:vault name:' ;;
            esac
            ;;
    esac
}

_azure-keyvault-cli "$@"
