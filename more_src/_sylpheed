#compdef sylpheed
# Documentation: https://manpages.debian.org/testing/sylpheed/sylpheed.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian man page at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable verbose console output]' \
  '--safe-mode[run without loading plugins]' \
  '--receive[retrieve new messages]' \
  '--receive-all[retrieve new messages on all accounts]' \
  '--compose=[open composition window with optional mailto URL]:mailto:' \
  '*--attach=[attach file(s) to message]:file:_files' \
  '--send[send queued messages]' \
  '--status[display total message count]' \
  '*--status-full=[show status of specified folder]:folder:' \
  '--open=[open existing message id or RFC822 file URL]:open:' \
  '--configdir=[configuration directory]:dir:_files -/' \
  '--exit[terminate running instance]' \
  '*:url_or_file:_files' && ret=0

return ret
