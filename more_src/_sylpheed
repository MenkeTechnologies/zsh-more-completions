#compdef sylpheed
# Documentation: https://man.archlinux.org/search?q=sylpheed
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug[run in debug mode]' \
  '--receive[receive new messages]' \
  '--receive-all[receive new messages on all accounts]' \
  '--compose=[start composer with TO address]:to:' \
  '--attach=[attach files to message]:file:_files' \
  '--send[send queued messages]' \
  '--status[print folder status]' \
  '--status-full=[print folder status (full)]:folder:' \
  '--open=[open message ID]:id:' \
  '--configdir=[configuration directory]:dir:_files -/' \
  '--exit[exit running instance]' \
  '*:url_or_file:_files' && ret=0

return ret
