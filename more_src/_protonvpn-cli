#compdef protonvpn-cli protonvpn

# Zsh completion for protonvpn-cli - ProtonVPN CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:login to ProtonVPN'
  'logout:logout from ProtonVPN'
  'connect:connect to ProtonVPN'
  'c:connect to ProtonVPN'
  'disconnect:disconnect from ProtonVPN'
  'd:disconnect from ProtonVPN'
  'status:show connection status'
  's:show connection status'
  'reconnect:reconnect to ProtonVPN'
  'r:reconnect to ProtonVPN'
  'configure:configure ProtonVPN settings'
  'refresh:refresh server data'
  'examples:show usage examples'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'protonvpn command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      connect|c)
        _arguments \
          '(-f --fastest)'{-f,--fastest}'[connect to fastest server]' \
          '(-r --random)'{-r,--random}'[connect to random server]' \
          '--cc[connect to specific country]:country code' \
          '--sc[connect to Secure Core server]' \
          '--p2p[connect to P2P server]' \
          '--tor[connect to Tor server]' \
          '-p[set protocol]:protocol:(udp tcp)' \
          '1:server name' && ret=0
        ;;
      configure)
        _arguments \
          '--dns[configure DNS]:mode:(automatic custom)' \
          '--protocol[set default protocol]:protocol:(udp tcp)' \
          '--killswitch[configure kill switch]:state:(0 1)' \
          '--split-tunnel[configure split tunneling]' && ret=0
        ;;
    esac
    ;;
esac

return ret
