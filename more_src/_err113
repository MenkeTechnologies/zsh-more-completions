#compdef err113
# Documentation: https://github.com/Djarvur/go-err113
# Go 1.13 error wrapping/comparison checker (singlechecker)

local ret=1

_arguments -s -S \
  '-V[print version and exit]' \
  '-c=[display offending line with this many lines of context]:n:' \
  '-cpuprofile=[write CPU profile to file]:file:_files' \
  '-debug=[debug flags, any subset of fpstv]:flags:' \
  '-fix[apply all suggested fixes]' \
  '-flags[print analyzer flags in JSON]' \
  '-json[emit JSON output]' \
  '-memprofile=[write memory profile to file]:file:_files' \
  '-trace=[write trace log to file]:file:_files' \
  '*:packages:_files' && ret=0

return ret
