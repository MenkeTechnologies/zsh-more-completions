#compdef hgLoadOut
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: load RepeatMasker .out files into the database

local ret=1

_arguments -s -S \
  '-tabFile=[generate tab file without loading database]:file:_files' \
  '-nosplit[treat input as single rmsk table rather than chrN_rmsk]' \
  '-split[load chrN_rmsk tables even when single file provided]' \
  '-table=[custom table suffix instead of default rmsk]:name' \
  '1:database:' \
  '*:out file:_files -g "*.out"' && ret=0

return ret
