#compdef bloodhound-py
# Documentation: https://man.archlinux.org/search?q=bloodhound-py
# Reference accessed: 2026-05-16

# bloodhound-py: BloodHound AD ingestor (Python rewrite of SharpHound)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '-u[domain user]:user:' \
  '--username=[domain user]:user:' \
  '-p[password]:pass:' \
  '--password=[password]:pass:' \
  '-d[domain]:domain:' \
  '--domain=[domain]:domain:' \
  '-c[collection method]:method:(All DCOnly Group LocalAdmin RDP DCOM ObjectProps ACL Session LoggedOn Container GPOLocalGroup Trusts ComputerOnly)' \
  '--collectionmethod=[collection method]:method:(All DCOnly Group LocalAdmin RDP DCOM ObjectProps ACL Session LoggedOn Container GPOLocalGroup Trusts ComputerOnly)' \
  '--dns-tcp[force DNS TCP]' \
  '--dns-timeout=[DNS timeout (sec)]:seconds:' \
  '-ns[name server]:host:_hosts' \
  '-w[number of workers]:n:' \
  '--workers=[number of workers]:n:' \
  '-W[output to zip]:zip:' \
  '--zip[zip output files]' \
  '--cachefile=[cache file]:file:_files' \
  '-dc[domain controller]:host:_hosts' \
  '--computerfile=[file with computer names]:file:_files' \
  '--use-ldaps[use LDAP over SSL]' \
  '--no-pass[do not prompt for password]' \
  '--hashes=[LM:NT hashes]:hashes:' \
  '-aesKey=[Kerberos AES key]:hex:' \
  '--kerberos[use Kerberos authentication]' \
  '-ts[print timestamps]' \
  '-v[verbose]' \
  '*::bloodhound-py args:_files' && ret=0
return ret
