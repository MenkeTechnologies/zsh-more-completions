#compdef tailwindcss

# Zsh completion for Tailwind CSS CLI

_tailwindcss() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '(-i --input)'{-i,--input}'[input file]:input file:_files -g "*.css"' \
    '(-o --output)'{-o,--output}'[output file]:output file:_files -g "*.css"' \
    '(-w --watch)'{-w,--watch}'[watch for changes and rebuild as needed]' \
    '(-p --poll)'{-p,--poll}'[use polling instead of filesystem events when watching]' \
    '--content=[content paths for detecting class usage]:content paths:_files' \
    '(-m --minify)'{-m,--minify}'[minify the output]' \
    '(-c --config)'{-c,--config}'[path to tailwind config file]:config file:_files -g "*.{js,ts,mjs,cjs}"' \
    '--postcss=[path to postcss config file]:postcss config:_files -g "*.{js,ts,mjs,cjs}"' \
    '--no-autoprefixer[disable autoprefixer]' \
    '(-h --help)'{-h,--help}'[display help]' \
    '--version[display version]' \
    '1:command:(init build)' \
    && ret=0

  return ret
}

_tailwindcss "$@"
