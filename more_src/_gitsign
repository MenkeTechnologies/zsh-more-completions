#compdef gitsign

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--fulcio-url=[Fulcio server URL]:url' \
  '--rekor-url=[Rekor server URL]:url' \
  '--oidc-issuer=[OIDC issuer URL]:url' \
  '--oidc-client-id=[OIDC client ID]:client id' \
  '--oidc-redirect-url=[OIDC redirect URL]:url' \
  '--connector-id=[OIDC connector ID]:connector id' \
  '--timestamp-server-url=[timestamp server URL]:url' \
  '--timestamp-cert-chain=[timestamp certificate chain]:file:_files' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'attest:Attest a commit or tag'
      'show:Show signature details'
      'verify:Verify a commit or tag signature'
      'version:Print version information'
    )
    _describe -t commands 'gitsign command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      verify)
        _arguments -s -S \
          '--certificate-identity=[certificate identity to verify]:identity' \
          '--certificate-oidc-issuer=[certificate OIDC issuer to verify]:issuer' \
          '*:commit:' && ret=0
        ;;
    esac
    ;;
esac

return ret
