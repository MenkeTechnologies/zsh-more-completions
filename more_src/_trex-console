#compdef trex-console
# Documentation: https://trex-tgn.cisco.com/trex/doc/trex_console.html
# Cisco TRex interactive console client

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --server)'{-s,--server}'[TRex server (default localhost)]:server:_hosts' \
  '(-p --port)'{-p,--port}'[TRex server port (default 4501)]:port' \
  '--async_port[TRex async publisher port (default 4500)]:port' \
  '(-u --user)'{-u,--user}'[user name]:user:_users' \
  '(-v --verbose)'{-v,--verbose}'[switch on verbose output]' \
  '--timeout[timeout for ZMQ connection in seconds]:seconds' \
  '(-a --acquire)'{-a,--acquire}'[acquire ports on connect]:ports' \
  '(-r --readonly)'{-r,--readonly}'[start console in read-only mode]' \
  '--emu[run emulation client on startup]' \
  '--emu-server[emulation client server address]:server:_hosts' \
  '--emu-server-port[emu server port (default 4510)]:port' \
  '--emu-only-server[EMU-only mode proxy server address]:server' \
  '(-f --force)'{-f,--force}'[force acquire requested ports]' \
  '--batch[run console in batch mode with file]:file:_files' \
  '(-t --tui)'{-t,--tui}'[start with TUI mode]' \
  '(-x --xtui)'{-x,--xtui}'[start with XTERM TUI mode]' \
  '--top[set window as always on top]' \
  '(-q --quiet)'{-q,--quiet}'[start with all outputs suppressed]' && ret=0

return ret
