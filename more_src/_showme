#compdef showme
# Documentation: https://www.cs.cmu.edu/~quake/showme.html
# Show Me: graphical viewer for Triangle/TetGen meshes, PSLGs and partitions

local ret=1

_arguments -s -S \
  '-h[display help instructions]' \
  '-b[make all PostScript output black and white]' \
  '-f[fill partitioned triangles with color rather than coloring edges]' \
  '-w+[line width used in all images]:width:' \
  '-Q[quiet: suppress explanation of what Show Me is doing]' \
  '*:mesh file:_files -g "*.(node|poly|ele|edge|part|adj)"' && ret=0

return ret
