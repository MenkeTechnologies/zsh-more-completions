#compdef esoctl
# _esoctl — External Secrets Operator CLI (external-secrets/external-secrets)
# upstream: https://github.com/external-secrets/external-secrets
# Subcommands + flags from cmd/esoctl/{root,bootstrap,template,generator}.go on tip.

_esoctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                bootstrap:'scaffold new generator or provider resources'
                template:'render an ExternalSecret template offline'
            )
            _describe -t commands 'esoctl command' cmds
            ;;
        args)
            case $words[1] in
                bootstrap)
                    local -a sub=(
                        generator:'scaffold a new ESO generator'
                    )
                    _describe -t subcommands 'esoctl bootstrap subcommand' sub
                    if [[ $words[2] == generator ]]; then
                        _arguments \
                            '--name=[generator name (e.g. MyGenerator)]:name:' \
                            '--description=[generator description]:text:' \
                            '--package=[Go package name (default = lowercase of --name)]:pkg:'
                    fi
                    ;;
                template)
                    _arguments \
                        '--source-templated-object=[file with templated object]:file:_files' \
                        '--source-secret-data-file=[file with map[string][]byte secret data]:file:_files' \
                        '--template-from-config-map=[file with ConfigMap data for TemplateFrom]:file:_files' \
                        '--template-from-secret=[file with Secret data for TemplateFrom]:file:_files' \
                        '--output=[write result to file instead of stdout]:file:_files'
                    ;;
            esac
            ;;
    esac
}

_esoctl "$@"
