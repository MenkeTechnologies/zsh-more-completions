#compdef sixten
# ============================================================================
# _sixten — zsh completion for the Sixten programming language compiler
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/ollef/sixten
#   Author     : Olle Fredriksson (fredriksson.olle@gmail.com)
#   License    : BSD-3-Clause
#   Stars      : 783
#   Language   : Haskell (compiler) / Sixten (.vix source files)
#   Last push  : 2020-08-20
#
# WHAT IT IS
#   Sixten is "functional programming with fewer indirections" — Olle
#   Fredriksson's experimental dependently-typed programming language with
#   a focus on direct, indirection-free data layout.  Sixten compiles
#   programs to LLVM IR via a multi-stage backend (.vix source → typed
#   AST → core IR → LLVM), supports first-class polymorphism with size-
#   polymorphic representations (the language's namesake — at most "six-ten"
#   indirections fewer than ML/Haskell for unboxed user-defined data
#   types), and exposes a fully bidirectional Hindley-Milner-with-
#   dependent-types elaborator.  The compiler stack uses optparse-applicative
#   for argument parsing, fsnotify for `--watch` mode, and LLVM for native
#   code generation;  intermediate assembly can be saved with -S/--save-
#   assembly for inspection.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/Command.hs subparser chain +
#                       src/Command/{Check,Compile,Run,Test}.hs option blocks)
#   sixten <command> [OPTIONS] [FILES...]
#
#   Commands (subparser):
#     compile                 Compile a Sixten program
#     run                     Run a Sixten program
#     check                   Type check a Sixten program
#     test                    Test a Sixten program
#     language-server         Start the Sixten language server (LSP)
#
#   Shared check-time options (Check.Options — accepted by check/compile/run/test):
#     <FILES...>              Input source FILES or directories (repeatable;
#                             .vix files inside directories are picked up
#                             recursively)
#     -v, --verbose <PREFIX>  Log categories that start with PREFIX
#                             (repeatable; suggested values: tc, tc.whnf,
#                             tc.unify, tc.subtype, tc.metavar, forall,
#                             tc.def, tc.gen)
#         --log-file <FILE>   Write logs to FILE instead of stdout
#         --watch             Watch files for changes, re-typechecking as
#                             needed (check only;  uses fsnotify)
#
#   Compile / Run / Test additional options  (Compile.Options):
#     -o, --output <FILE>           Write output to FILE
#     -t, --target <TARGET>         Compile for CPU architecture TARGET
#                                   (completion from Backend.Target.architectures)
#     -O, --optimise <LEVEL>        Optimisation level: 0 | 1 | 2 | 3
#     -S, --save-assembly <DIR>     Save intermediate assembly files to DIR
#         --llvm-config <PATH>      Path to the llvm-config binary
#         --extra-lib-dir <DIR>     Extra library directory (gc-lib.lib etc.)
#                                   (repeatable)
#
#   Run-specific:
#         --args <ARGS>             Command-line options passed verbatim to
#                                   the compiled Sixten program
#
#   Test-specific:
#     -e, --expected <FILE>         Compare program output to FILE contents
#         --expect-type-error       The program should FAIL to typecheck
#         --expect-syntax-error     The program should yield a syntax error
#
# LANGUAGE-CORPUS POSITION
#   Sixten is the 140th programming language entry in this completion corpus
#   — a ROUND-NUMBER LANGUAGE MILESTONE — closing the 3+1 micro-cycle that
#   began at R829 (_coap-client/coap-lite Rust=115 opens Axis 60) and
#   continued through R830 (_ingress-coap-client/plgd-dev/go-coap Go=115)
#   and R831 (_coap/mcollina/node-coap TS-Node=115 CLOSES Axis 60 CoAP IoT
#   Protocol Library at 1/1/1 — COMPLETED THE THREE-SCORE AXIS LANDMARK +
#   triple-115 landmark + 53 axes at 1/1/1).  Sixten joins the roster of
#   exotic languages already in the corpus including Imba (R828 139th), Tao
#   (R824 138th), Dada (R820 137th), Acton (R816 136th), Stanza (R812
#   135th), Rune, Egel, Mlatu, Gwion, Silq (quantum), Mirth, Lawvere/bill,
#   Cognac/Cognate, and Scrapscript.
#
#   No completion for `sixten` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_sixten() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '1: :_sixten_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                compile)            _sixten_compile  && ret=0 ;;
                run)                _sixten_run      && ret=0 ;;
                check)              _sixten_check    && ret=0 ;;
                test)               _sixten_test     && ret=0 ;;
                language-server)    _sixten_lsp      && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_sixten_commands] )) ||
_sixten_commands() {
    local -a commands
    commands=(
        'compile:compile a Sixten program (LLVM-backed native code)'
        'run:compile and run a Sixten program'
        'check:type check a Sixten program (no codegen)'
        'test:test a Sixten program (compare output, expect type/syntax errors)'
        'language-server:start the Sixten LSP server'
    )
    _describe -t commands 'sixten command' commands
}

# Shared check-time flags
_sixten_check_flags() {
    print -- \
        '*'{-v+,--verbose=}'[log categories starting with PREFIX (repeatable)]:log prefix:(tc tc.whnf tc.unify tc.subtype tc.metavar forall tc.def tc.gen)' \
        '--log-file=[write logs to FILE]:log file:_files'
}

# Shared compile flags (also include check flags)
_sixten_compile_flags() {
    print -- \
        $(_sixten_check_flags) \
        '(-o --output)'{-o+,--output=}'[write output to FILE]:output file:_files' \
        '(-t --target)'{-t+,--target=}'[compile for CPU architecture TARGET]:target:' \
        '(-O --optimise)'{-O+,--optimise=}'[optimisation level]:level:(0 1 2 3)' \
        '(-S --save-assembly)'{-S+,--save-assembly=}'[save intermediate assembly to DIR]:asm dir:_files -/' \
        '--llvm-config=[path to llvm-config binary]:llvm-config:_files' \
        '*--extra-lib-dir=[extra library directory (repeatable)]:lib dir:_files -/'
}

(( $+functions[_sixten_compile] )) ||
_sixten_compile() {
    _arguments \
        $(_sixten_compile_flags) \
        '(- *)--help[help for compile]' \
        '*:source file:_files -g "*.vix"'
}

(( $+functions[_sixten_run] )) ||
_sixten_run() {
    _arguments \
        $(_sixten_compile_flags) \
        '--args=[command-line options passed to the compiled Sixten program]:program args:' \
        '(- *)--help[help for run]' \
        '*:source file:_files -g "*.vix"'
}

(( $+functions[_sixten_check] )) ||
_sixten_check() {
    _arguments \
        $(_sixten_check_flags) \
        '--watch[watch files for changes, re-typechecking as needed]' \
        '(- *)--help[help for check]' \
        '*:source file:_files -g "*.vix"'
}

(( $+functions[_sixten_test] )) ||
_sixten_test() {
    _arguments \
        $(_sixten_compile_flags) \
        '(-e --expected)'{-e+,--expected=}'[compare program output to FILE contents]:expected output file:_files' \
        '--expect-type-error[program should fail to typecheck]' \
        '--expect-syntax-error[program should yield a syntax error]' \
        '(- *)--help[help for test]' \
        '*:source file:_files -g "*.vix"'
}

(( $+functions[_sixten_lsp] )) ||
_sixten_lsp() {
    _arguments \
        '(- *)--help[help for language-server]'
}

_sixten "$@"
