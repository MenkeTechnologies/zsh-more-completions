#compdef pt-deadlock-logger
# Documentation: https://docs.percona.com/percona-toolkit/pt-deadlock-logger.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--buffer-stdout[enable STDOUT buffering (default)]' \
  '--no-buffer-stdout[disable STDOUT buffering]' \
  '(-A --charset)'{-A+,--charset=}'[default character set]:charset' \
  '--clear-deadlocks=[create small deadlock in table to clear large ones]:table' \
  '*--columns=[deadlock details to display]:columns' \
  '*--config=[comma-separated config files]:file:_files' \
  '--create-dest-table[create destination table if missing]' \
  '--no-create-dest-table[do not create destination table]' \
  '--daemonize[fork to background]' \
  '(-D --database)'{-D+,--database=}'[database name]:database' \
  '(-F --defaults-file)'{-F+,--defaults-file=}'[MySQL defaults file]:file:_files' \
  '--dest=[destination DSN for storing deadlocks]:DSN' \
  '(-h --host)'{-h+,--host=}'[MySQL host]:host:_hosts' \
  '--interval=[check interval (default 30s)]:duration' \
  '--iterations=[number of iterations]:count' \
  '--log=[output file when daemonized]:file:_files' \
  '(-s --mysql_ssl)'{-s+,--mysql_ssl=}'[create SSL MySQL connection]:int' \
  '--numeric-ip[express IPs as integers]' \
  '(-p --password)'{-p+,--password=}'[MySQL password]:password' \
  '--pid=[PID file path]:file:_files' \
  '(-P --port)'{-P+,--port=}'[MySQL port]:port' \
  '--quiet[suppress deadlock output; errors only]' \
  '--run-time=[max run time before exit]:duration' \
  '*--set-vars=[set MySQL variables]:vars' \
  '(-S --socket)'{-S+,--socket=}'[MySQL socket file]:file:_files' \
  '--tab[use tab separators]' \
  '(-u --user)'{-u+,--user=}'[MySQL username]:user:_users' \
  '--version-check[check for software updates (default)]' \
  '--no-version-check[skip version update check]' \
  '*:DSN:' && ret=0

return ret
