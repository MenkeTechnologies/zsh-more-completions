#compdef pt-deadlock-logger

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--charset=[default character set]:charset:' \
  '--clear-deadlocks=[clear deadlocks using table]:table:' \
  '--columns=[output columns]:columns:' \
  '--config=[config file]:config file:_files' \
  '--[no]create-dest-table[create destination table if needed]' \
  '--daemonize[run as daemon]' \
  '--database=[database name]:database:' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--dest=[store deadlocks in DSN]:DSN:' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--interval=[check interval]:seconds:' \
  '--iterations=[number of iterations]:count:' \
  '--log=[log file]:log file:_files' \
  '--numeric-ip[convert IPs to numbers]' \
  '--password=[MySQL password]:password:' \
  '--pid=[PID file]:pid file:_files' \
  '--port=[MySQL port]:port:' \
  '--run-time=[max run time]:duration:' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--tab[tab-separated output]' \
  '--user=[MySQL user]:username:' \
  '*:DSN:' && ret=0

return ret
