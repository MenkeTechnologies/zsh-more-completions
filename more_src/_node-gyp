#compdef node-gyp

# Zsh completion for node-gyp (Node.js native addon build tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:Invoke make/msbuild.exe to build the native addon'
  'clean:Remove the build directory'
  'configure:Generate build system files for the current platform'
  'install:Install the node development headers'
  'list:Print the currently installed node development headers'
  'rebuild:Run clean, configure, and build all in a row'
  'remove:Remove the installed node development headers'
)

local -a global_flags=(
  '--debug[Build in debug mode]'
  '--release[Build in release mode]'
  '(-j --jobs)'{-j,--jobs}'=[Number of parallel make jobs]:jobs'
  '--silly[Set log level to silly]'
  '--verbose[Set log level to verbose]'
  '--silent[Set log level to silent]'
  '--loglevel=[Set the log level]:level:(silly verbose info warn error silent)'
  '--directory=[Run command in different directory]:dir:_files -/'
  '--make=[Override make command]:make command'
  '--thin=[Set thin static library mode]:mode:(yes no)'
  '--arch=[Set target architecture]:arch:(ia32 x64 arm arm64)'
  '--tarball=[Get headers from a tarball]:tarball:_files -g "*.tar.gz"'
  '--target=[Set the node version to install for]:version'
  '--nodedir=[Set the path to the node source code]:dir:_files -/'
  '--python=[Set path to Python executable]:python:_files'
  '--devdir=[Set the development directory]:dir:_files -/'
  '--ensure[Do not reinstall headers if present]'
  '--dist-url=[Set the URL for downloading headers]:url'
)

_arguments -s -S -C \
  $global_flags \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'node-gyp command' commands && ret=0
    ;;
  args)
    _arguments -s -S $global_flags && ret=0
    ;;
esac

return ret
