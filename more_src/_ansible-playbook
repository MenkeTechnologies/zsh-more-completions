#compdef ansible-playbook
# _ansible-playbook — Ansible playbook runner (executes one or more YAML playbooks against an inventory; --syntax-check parse-only, --list-tasks, --list-hosts, --list-tags, --start-at-task, --step interactive, --flush-cache; identical inventory/become/extravars/tags surface as ansible)
# upstream: https://github.com/ansible/ansible (lib/ansible/cli/playbook.py)
# Flags from ansible cli/playbook.py on tip.

_ansible-playbook() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '--help[show help]' \
        '*-v[verbose (repeat for more)]' \
        '-i+[inventory]:inventory:_files' \
        '-l+[limit hosts]:limit:' \
        '-f+[parallel forks]:forks:' \
        '-T+[connection timeout]:seconds:' \
        '-u+[remote user]:user:_users' \
        '-c+[connection type]:connection:(local ssh paramiko docker kubectl)' \
        '-b[become]' \
        '-K[ask become pass]' \
        '-k[ask remote ssh pass]' \
        '--become-method+[method]:method:(sudo su pbrun pfexec doas dzdo ksu runas machinectl)' \
        '--become-user+[user]:user:_users' \
        '-C[check mode]' \
        '--check[check mode]' \
        '--diff[show diffs]' \
        '-D[show diffs]' \
        '*-e+[extra vars]:key=value:' \
        '--vault-id+[vault id]:vault_id:' \
        '--vault-password-file+[file]:file:_files' \
        '--ask-vault-pass[ask vault pass]' \
        '--syntax-check[only parse playbook]' \
        '--list-tasks[list tasks]' \
        '--list-hosts[list hosts]' \
        '--list-tags[list tags]' \
        '--start-at-task+[task name]:task:' \
        '--step[interactive step]' \
        '--flush-cache[clear cache before run]' \
        '*--tags+[only run tags]:tags:' \
        '*--skip-tags+[skip tags]:tags:' \
        '--force-handlers[run handlers even if task fails]' \
        '*:playbook:_files -g "*.(yml|yaml)"'
}

_ansible-playbook "$@"
