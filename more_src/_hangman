#compdef hangman
# Documentation: man hangman(6)
# Source: openbsd/src games/hangman/main.c — guess the word (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '(-k)-d+[dictionary file]:file:_files' \
    '(-d)-k[use kernel symbol table as dictionary]' \
    && ret=0

return ret
