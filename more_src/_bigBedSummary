#compdef bigBedSummary bigWigSummary
# _bigBedSummary — UCSC Kent Lab bigBedSummary and bigWigSummary summary statistics from an indexed bigBed or bigWig file (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/goldenPath/help/bigBed.html

_bigBedSummary() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-type=+[type]:t:(coverage mean min max std)' \
        '-udcDir=+[UDC cache dir]:dir:_files -/' \
        '*:bigBed chrom start end dataPoints:_files -g "*.bb *.bigbed *.bw *.bigwig"'
}

_bigBedSummary "$@"
