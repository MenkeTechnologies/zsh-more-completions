#compdef abidump bootnode keeper
# Documentation: upstream cmd/{abidump,bootnode,keeper}/main.go at
# github.com/ethereum/go-ethereum and github.com/maticnetwork/bor
# Reference accessed: 2026-05-30 via gh api inspection of every
# flag.String/Bool/Int declaration.
# Ethereum geth-family R81 — 3-stem multi-binary harvest covering
# the geth-companion utilities not previously covered.
# NOTE: bootnode was REMOVED from upstream go-ethereum after
# Sourcify/Sepolia consolidation; Polygon Bor retained it in
# cmd/bootnode for L2 discovery purposes. abidump and keeper are
# present in both upstream geth and bor.

case $service in

  abidump)
    # Parse hex ABI data via the fourbyte signer database.
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '*:hex data (with or without 0x prefix):'
    ;;

  bootnode)
    # Standalone discovery v4/v5 bootnode (P2P discovery).
    _arguments -s -S \
      '-addr=[listen address (default :30301)]:host\:port:' \
      '-genkey=[generate a node key to file]:file:_files' \
      '-writeaddress[write out the node public key and quit]' \
      '-nodekey=[private key filename]:file:_files' \
      '-nodekeyhex=[private key as hex (for testing)]:hex:' \
      '-nat=[port mapping mechanism]:nat:(any none upnp pmp pmp\:<IP> extip\:<IP>)' \
      '-netrestrict=[restrict network communication to CIDR list]:cidrs:' \
      '-v5[run a v5 topic discovery bootnode]' \
      '-verbosity=[log verbosity (0-5, default 3)]:level:(0 1 2 3 4 5)' \
      '-vmodule=[log verbosity pattern]:pattern:' \
      '(- *)'{-h,--help}'[show help]'
    ;;

  keeper)
    # Stateless workload tester. Reads RLP-encoded Payload (chainID +
    # block + witness) from stdin or file argument and executes
    # stateless block validation.
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '*:RLP payload file (or omit for stdin):_files -g "*.rlp"'
    ;;

esac
