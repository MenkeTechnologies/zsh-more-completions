#compdef corosync
# Documentation: https://manpages.debian.org/testing/corosync/corosync.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream man page at the URL above lists only -c, -f, -l, -t, -v.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[start application in foreground]' \
  '-t[test configuration and then exit]' \
  '-v[display version, git revision, and compiled features then exit]' \
  '-c+[fully qualified path to the corosync configuration file]:config file:_files' \
  '-l+[fully qualified path to the corosync pid lock file]:pid file:_files' && ret=0

return ret
