#compdef corosync

# Zsh completion for corosync (cluster engine daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[Start in foreground]' \
  '-p[Do not set realtime scheduling priority]' \
  '-t[Test configuration and exit]' \
  '-r[Set the core dump resource limit]' \
  '-v[Display version and exit]' \
  '-c+[Use the specified config file]:config file:_files' \
  '-L+[Set syslog log level]:level:(alert crit debug emerg err info notice warning)' \
  '-l+[Set logfile log level]:level:(alert crit debug emerg err info notice warning)' && ret=0

return ret
