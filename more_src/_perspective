#compdef perspective
# =============================================================================
# perspective — finos/perspective's
#   PERSPECTIVE.JS CLI — a Node.js command-
#   line interface for FINOS Perspective, a
#   streaming column-oriented data
#   visualization + analytics engine
#   originally built by J.P. Morgan and now
#   stewarded by the Fintech Open Source
#   Foundation (FINOS).  Perspective uses
#   APACHE ARROW as its NATIVE INTERCHANGE
#   FORMAT for column batches — every
#   `table()` constructor accepts Arrow IPC
#   bytes, and every `view.to_arrow()`
#   serialises results back to Arrow IPC.
#   This CLI provides two thin commands that
#   wrap the Perspective core: `convert` for
#   FORMAT CONVERSION (Arrow ↔ CSV ↔
#   JSON ↔ columns) and `host` for a LOCAL
#   WEBSOCKET + HTTP SERVER that streams
#   Perspective state to a browser-side
#   viewer.  TS-Node=109 leader bump CLOSING
#   Axis 54 (Apache Arrow Columnar Format)
#   at 1/1/1 three-language symmetry.
#
# AXIS 54 — APACHE ARROW COLUMNAR FORMAT — CLOSES @ R807
# =======================================================
# Closes the three-language Apache-Arrow
# columnar-format axis at 1/1/1 symmetry:
#   * Rust       (R805): arrow 58.1
#                — bundled in `csv2arrow`
#                  (focused CSV → Arrow IPC
#                  converter from
#                  domoritz/arrow-tools)
#   * Go         (R806): apache/arrow-go/v18
#                v18.3.0 — bundled in
#                  `gigapi` (timeseries
#                  lakehouse with Arrow
#                  FlightSQL gRPC server)
#   * TS-Node    (R807, THIS ROUND):
#                apache-arrow (via the
#                @perspective-dev/client
#                workspace dep, which
#                consumes apache-arrow as
#                its data interchange
#                substrate) — bundled in
#                this round's `perspective`
#                (Perspective.js CLI for
#                Arrow ↔ CSV ↔ JSON
#                conversion + browser-
#                streaming dashboard
#                hosting)
#
# Distinguishing perspective from sibling
# corpus tooling:
#   - ARROW2CSV (`_arrow2csv`, in corpus):
#     official Apache Arrow JS package's
#     bundled CLI that dumps Arrow IPC to
#     human-readable CSV-like output.
#     Single-direction (Arrow → text).
#     `perspective convert` is the
#     BIDIRECTIONAL equivalent — Arrow ↔
#     CSV ↔ JSON ↔ columns
#   - CSV2ARROW (`_csv2arrow`, in corpus,
#     R805): Rust analogue at the Rust
#     pole of this same Axis 54.  CSV-
#     only input, Arrow IPC output
#   - JQ-LIKE TOOLS (`_jq`, `_dasel`,
#     `_yq`, `_dyff`): pipeline-friendly
#     JSON/YAML/TOML transformers.  Don't
#     speak Arrow
#   - DUCKDB (`_duckdb`): can READ Arrow
#     via `SELECT * FROM 'data.arrow'`
#     and EXPORT via `COPY ... TO
#     'out.arrow'`.  Different scope —
#     duckdb is a full SQL engine
#   - VEGA / VEGA-LITE: declarative
#     visualization, not column
#     interchange
#   - PANDAS (`_pandas`-adjacent
#     tooling): Python-only.  perspective
#     is the JS-native equivalent of
#     "DataFrame in a webgl-rendered
#     dashboard"
#
# KEY PERSPECTIVE FEATURES:
#   - WASM CORE — the heavy column-store
#     + pivot-table + aggregate engine
#     is a Rust+C++ WASM module
#     (`@perspective-dev/client` ships
#     this).  Browser, Node, and worker
#     contexts all consume the same WASM
#   - APACHE ARROW NATIVE — `table(bytes)`
#     constructor recognises Arrow IPC
#     stream + file variants.
#     `view.to_arrow()` round-trips back
#     to Arrow IPC.  Zero-copy data
#     interchange with Pandas, Polars,
#     DuckDB, BigQuery, R, MATLAB
#   - INCREMENTAL VIEWS — once a `view`
#     is opened over a `table`, all
#     subsequent `update()` calls flow
#     into the view as INCREMENTAL diff
#     events.  Live-streaming dashboard
#     model
#   - EXPRESSION COLUMNS — virtual
#     columns expressed in Perspective's
#     ExprTK-derived expression DSL (a
#     branch of the C++ ExprTK math
#     parser).  Evaluated incrementally
#     as rows arrive
#   - GROUP BY + SPLIT BY PIVOTS — multi-
#     level row and column pivots
#     materialised in WASM at column-
#     batch granularity
#   - VIEWER-DATAGRID + VIEWER-CHARTS —
#     two interchangeable rendering
#     layers (`@perspective-dev/viewer-
#     datagrid` for the spreadsheet
#     view; `@perspective-dev/viewer-
#     charts` for d3fc-based charts).
#     The CLI's `host` subcommand
#     serves both via WebSocket
#   - WORKSPACE — `@perspective-dev/
#     workspace` is a Golden-Layout-
#     style multi-pane container for
#     arranging multiple viewers in a
#     single browser window
#
# CLI ARGUMENT PARSER — `commander ^2.19`
# (one of the oldest pinned commander
# versions in modern Node ecosystem,
# preserved for backward compatibility).
# Two subcommands, no global flags
# beyond `--version` + `--help`.
#
# SUBCOMMANDS:
#   * `convert [filename]`     Convert a
#                              file between
#                              Perspective-
#                              supported
#                              formats.
#                              Reads from
#                              STDIN if
#                              filename
#                              omitted
#                              Flags:
#                              -f / --format
#                              <arrow|csv|
#                              columns|json>
#                              (default
#                              arrow);
#                              -o / --output
#                              <filename>
#                              (default
#                              stdout)
#   * `host [filename]`        Host a file
#                              on a local
#                              WebSocket/
#                              HTTP server
#                              for a
#                              browser-side
#                              Perspective
#                              viewer.
#                              Reads from
#                              STDIN if
#                              filename
#                              omitted
#                              Flags:
#                              -p / --port
#                              <port>
#                              (default
#                              8080);
#                              -a / --assets
#                              <path>
#                              (extra
#                              asset dir);
#                              -o / --open
#                              (auto-launch
#                              browser via
#                              puppeteer)
#
# CRITICAL DIRECT DEPENDENCIES (from
# packages/cli/package.json):
#   - @perspective-dev/client (workspace)
#                              — WASM
#                                Perspective
#                                core +
#                                client
#                                bindings;
#                                speaks
#                                Apache
#                                Arrow IPC
#                                natively
#                                [AXIS 54 LIBRARY]
#                                (apache-
#                                arrow as
#                                transitive
#                                interchange
#                                substrate)
#   - @perspective-dev/viewer (workspace)
#                              — Web
#                                Component
#                                <perspective-
#                                viewer>
#                                custom
#                                element
#   - @perspective-dev/viewer-charts (workspace)
#                              — d3fc-based
#                                chart
#                                renderer
#                                plugin
#   - @perspective-dev/viewer-datagrid (workspace)
#                              — regular-
#                                table-based
#                                spreadsheet
#                                renderer
#                                plugin
#   - @perspective-dev/viewer-openlayers (workspace)
#                              — OpenLayers
#                                map
#                                renderer
#                                plugin
#   - @perspective-dev/workspace (workspace)
#                              — multi-pane
#                                container
#                                for
#                                multiple
#                                viewers
#   - commander ^2.19          — CLI parser
#   - puppeteer ^23            — headless
#                                Chrome
#                                for the
#                                `host -o`
#                                auto-launch
#
# Node 18+ MSRV (per `@finos/perspective-
# cli` engines).  Runs on Linux + macOS +
# Windows.  The Node binary is invoked
# with `--max-old-space-size=8192` via
# the shebang shim in `bin/perspective`
# so larger Arrow files don't OOM the
# default Node heap
#
# UPSTREAM:
#   * Source             : https://github.com/finos/perspective
#   * Subdir             : https://github.com/finos/perspective/tree/main/packages/cli
#   * Site               : https://perspective.finos.org
#   * Apache Arrow JS    : https://github.com/apache/arrow-js
#   * License            : Apache-2.0
#   * Steward            : FINOS (Fintech Open Source Foundation)
#   * Origin             : J.P. Morgan Chase 2017
#
# INSTALL:
#   # Global npm install
#   npm install -g @finos/perspective-cli
#
#   # Or npx (no install)
#   npx @finos/perspective-cli convert data.arrow -f csv
#
# USAGE EXAMPLES:
#
#   # Top-level help
#   perspective --help
#   perspective help
#
#   # Convert Arrow IPC to CSV
#   perspective convert data.arrow -f csv -o data.csv
#
#   # Convert CSV to Arrow IPC (default
#   # format is arrow)
#   perspective convert data.csv -o data.arrow
#
#   # Convert Arrow to JSON (row-oriented)
#   perspective convert data.arrow -f json -o data.json
#
#   # Convert Arrow to column-oriented JSON
#   perspective convert data.arrow -f columns -o data.cols.json
#
#   # Pipe from stdin (Arrow IPC bytes →
#   # CSV on stdout)
#   cat data.arrow | perspective convert -f csv
#
#   # Pipe to stdout (CSV → Arrow IPC bytes)
#   perspective convert data.csv -f arrow | \
#       cat > data.arrow
#
#   # Host a dashboard on port 8080
#   # (default)
#   perspective host data.arrow
#
#   # Custom port
#   perspective host data.arrow -p 4000
#
#   # Host + auto-open browser via
#   # puppeteer
#   perspective host data.arrow -o
#
#   # Host with extra static assets
#   # directory (e.g. custom HTML
#   # template / plugins)
#   perspective host data.arrow \
#       --assets ./my-dashboard \
#       --port 3000 \
#       --open
#
#   # Pipe stdin into the host server
#   cat data.arrow | perspective host -p 4000 -o
#
#   # Version (commander default)
#   perspective --version
#   perspective -V
#
# OPTIONS (sourced directly from
# https://github.com/finos/perspective/blob/main/packages/cli/src/js/index.js commander chain):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _perspective_commands
_perspective_commands=(
    'convert:Convert a file between Perspective-supported formats (Arrow / CSV / JSON / columns)'
    'host:Host a file on a local WebSocket+HTTP server with a browser-side Perspective viewer'
    'help:Print help for a subcommand'
)

local -a _perspective_formats
_perspective_formats=(
    'arrow:Apache Arrow IPC binary (default)'
    'csv:CSV text'
    'json:Row-oriented JSON'
    'columns:Column-oriented JSON'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'perspective command' _perspective_commands && ret=0
        ;;
    args)
        case $line[1] in
            convert)
                _arguments \
                    '(- *)'{-h,--help}'[show help for convert]' \
                    '(-f --format)'{-f+,--format=}'[output format (default arrow)]:format:->format' \
                    '(-o --output)'{-o+,--output=}'[output filename (default stdout)]:file:_files' \
                    '*:input file (stdin if omitted):_files -g "*.(arrow|feather|ipc|csv|tsv|json)"' \
                    && ret=0
                ;;
            host)
                _arguments \
                    '(- *)'{-h,--help}'[show help for host]' \
                    '(-p --port)'{-p+,--port=}'[bind port (default 8080)]:port: ' \
                    '(-a --assets)'{-a+,--assets=}'[host from a working directory]:dir:_files -/' \
                    '(-o --open)'{-o,--open}'[auto-open the dashboard in a browser via puppeteer]' \
                    '*:input file (stdin if omitted):_files -g "*.(arrow|feather|ipc|csv|tsv|json)"' \
                    && ret=0
                ;;
            help)
                _arguments \
                    '1:subcommand:(convert host)' \
                    && ret=0
                ;;
        esac
        ;;
esac

case $state in
    format)
        _describe -t formats 'output format' _perspective_formats && ret=0 ;;
esac

return ret
