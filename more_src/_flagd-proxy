#compdef flagd-proxy
# _flagd-proxy — OpenFeature flagd in-cluster sync proxy
# upstream: https://github.com/open-feature/flagd
# Subcommands + flags from flagd-proxy/cmd/start.go on tip.

_flagd-proxy() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-x --debug)'{-x,--debug}'[verbose logging]' \
        '--config=[config file (default \$HOME/.agent.yaml)]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'start:start the flagd-proxy sync server'
                'version:print flagd-proxy version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                start)
                    _arguments \
                        '(-p --port)'{-p,--port=}'[sync server listen port]:port:' \
                        '(-m --management-port)'{-m,--management-port=}'[management port]:port:' \
                        '(-z --log-format)'{-z,--log-format=}'[log format]:fmt:(console json)'
                    ;;
            esac
            ;;
    esac
}

_flagd-proxy "$@"
