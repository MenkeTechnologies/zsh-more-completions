#compdef app-store-connect
# Documentation: https://github.com/codemagic-ci-cd/cli-tools/blob/master/docs/app-store-connect/README.md
# Codemagic CLI tools - interact with Apple services via App Store Connect API

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-s --silent)'{-s,--silent}'[suppress log output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--no-color[disable colored output]' \
  '--log-stream=[log output destination]:stream:(stderr stdout)' \
  '1:command:(fetch-signing-files get-latest-app-store-build-number get-latest-build-number get-latest-testflight-build-number publish app-store-version-localizations app-store-version-phased-releases app-store-version-submissions app-store-versions apps beta-app-review-submissions beta-build-localizations beta-groups builds bundle-ids certificates devices profiles review-submission-items review-submissions)' \
  '*::args:->args' && ret=0

return ret
