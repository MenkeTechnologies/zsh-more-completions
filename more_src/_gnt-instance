#compdef gnt-instance
# Documentation: https://man.archlinux.org/search?q=gnt-instance
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'activate-disks:activate instance disks'
  'add:add a new instance'
  'add-tags:add tags to an instance'
  'batch-create:batch-create instances'
  'change-group:change instance node group'
  'console:connect to instance console'
  'deactivate-disks:deactivate instance disks'
  'failover:fail over an instance'
  'grow-disk:grow an instance disk'
  'info:show instance information'
  'list:list instances'
  'list-tags:list instance tags'
  'migrate:migrate an instance'
  'modify:modify an instance'
  'move:move an instance'
  'reboot:reboot an instance'
  'recreate-disks:recreate instance disks'
  'reinstall:reinstall an instance'
  'remove:remove an instance'
  'remove-tags:remove instance tags'
  'rename:rename an instance'
  'replace-disks:replace instance disks'
  'restart:restart an instance'
  'shutdown:shutdown an instance'
  'startup:startup an instance'
  'snapshot:snapshot instance disks'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gnt-instance command' commands && ret=0 ;;
esac

return ret
