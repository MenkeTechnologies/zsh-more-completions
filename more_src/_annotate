#compdef annotate
# Documentation: https://man.archlinux.org/search?q=annotate
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:input image:_files -g "*.(jpg|jpeg|png|gif)"' \
  '2:output image:_files -g "*.(jpg|jpeg|png|gif)"' && ret=0

return ret
