#compdef pdfcrop
# Documentation: pdfcrop --help (PDFCROP 1.42)
# Source: TeX pdfcrop — calculate and remove PDF page margins (auto-crop).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(--verbose --noverbose)--verbose[verbose printing]' \
    '(--verbose --noverbose)--noverbose[silence verbose]' \
    '(--quiet --noquiet)--quiet[silence normal output]' \
    '(--quiet --noquiet)--noquiet[verbose output]' \
    '(--debug --nodebug)--debug[debug information]' \
    '(--debug --nodebug)--nodebug[no debug]' \
    '--gscmd=[Ghostscript command]:cmd:_command_names -e' \
    '(--pdftex --xetex --luatex)--pdftex[use pdfTeX]' \
    '(--pdftex --xetex --luatex)--xetex[use XeTeX]' \
    '(--pdftex --xetex --luatex)--luatex[use LuaTeX]' \
    '--pdftexcmd=[pdfTeX command]:cmd:_command_names -e' \
    '--xetexcmd=[XeTeX command]:cmd:_command_names -e' \
    '--luatexcmd=[LuaTeX command]:cmd:_command_names -e' \
    '--margins=[extra margins (left top right bottom, bp)]:margins:' \
    '(--clip --noclip)--clip[clipping support (if margins set)]' \
    '(--clip --noclip)--noclip[no clipping]' \
    '(--hires --nohires)--hires[use %%HiResBoundingBox]' \
    '(--hires --nohires)--nohires[use %%BoundingBox]' \
    '(--ini --noini)--ini[use iniTeX variant]' \
    '(--ini --noini)--noini[regular TeX]' \
    '--restricted[restricted mode]' \
    '--papersize=[gs -sPAPERSIZE=]:size:(letter legal A4 A3)' \
    '--resolution=[gs -r resolution]:res:' \
    '--bbox=[override bounding box (left bottom right top)]:bbox:' \
    '--bbox-odd=[bbox for odd pages]:bbox:' \
    '--bbox-even=[bbox for even pages]:bbox:' \
    '--pdfversion=[PDF version (x.y / auto / none)]:version:' \
    '--uncompress[create uncompressed PDF]' \
    '1:input PDF:_files -g "*.pdf"' \
    '2:output PDF:_files -g "*.pdf"' \
    && ret=0

return ret
