#compdef segyio-cath
# Documentation: https://github.com/equinor/segyio/blob/main/applications/segyio-cath.c
# segyio: concatenate SEG-Y textual headers to standard output

local ret=1

_arguments -s -S \
  '(-n --num)'{-n,--num=}'[textual header to show, starts at 0]:num' \
  '(-a --all)'{-a,--all}'[print all textual headers]' \
  '(-s --strict)'{-s,--strict}'[abort if a header or file is not found]' \
  '(-S --nonstrict)'{-S,--nonstrict}'[ignore missing headers (default)]' \
  '--version[output version information and exit]' \
  '--help[display this help and exit]' \
  '*:SEG-Y file:_files' && ret=0

return ret
