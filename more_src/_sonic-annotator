#compdef sonic-annotator
# Documentation: https://github.com/sonic-visualiser/sonic-annotator
# Batch tool for feature extraction and annotation of audio files using Vamp plugins

local ret=1

_arguments -s -S \
  '*'{-h,--help}'[show help, optionally for a named writer type]' \
  '(- *)'{-l,--list}'[list available Vamp plugin outputs]' \
  '*'{-t,--transform}'[apply transform described in an XML file]:transform file:_files' \
  '*--transforms-from[read transform XML filenames from a list file]:list file:_files' \
  '*'{-d,--default}'[apply named transform in its default configuration]:transform id' \
  '(-s --skeleton)'{-s,--skeleton}'[write a skeleton transform description for a plugin]:transform id' \
  '(-r --recursive)'{-r,--recursive}'[process audio files in directories recursively]' \
  '(-w --writer)'{-w,--writer}'[select output writer module]:writer:(audiodb csv lab rdf json midi default)' \
  '-S[summary type to compute]:summary:(min max mean median mode sum variance sd count)' \
  '--summary-only[produce only the summary, not the individual features]' \
  '--segments[comma-separated list of times bounding segments]:times' \
  '--segments-from[read segment boundaries from a file]:segment file:_files' \
  '--normalise[normalise input audio]' \
  '--multiplexed[multiplex channels of all inputs into a single input]' \
  '--sample-rate[resample input to the given sample rate]:rate' \
  '--force[continue with subsequent files after an error]' \
  '*:audio file:_files' && ret=0

return ret
