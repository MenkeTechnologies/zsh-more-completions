#compdef kubectl-strimzi

local -a _strimzi_commands
_strimzi_commands=(
  'drain:drain Kafka node'
  'help:display help'
  'version:show version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig[kubeconfig file]:file:_files' \
  '--context[kubeconfig context]:context' \
  '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]:namespace' \
  '-o[output format]:format:(json yaml)' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'strimzi commands' _strimzi_commands
    ;;
  args)
    case "$words[1]" in
      drain)
        _arguments \
          '--timeout[timeout in milliseconds]:ms' \
          '--delete[delete the pod after draining]' \
          '1:pod name'
        ;;
    esac
    ;;
esac
