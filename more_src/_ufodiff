#compdef ufodiff ufolint
# Documentation: upstream READMEs at github.com/source-foundry/ufodiff
# and github.com/source-foundry/ufolint
# Reference accessed: 2026-05-30 via WebFetch.
# Source Foundry UFO tools R115 — 2-stem multi-binary harvest:
# ufodiff (UFO source diff for typeface git workflows) and
# ufolint (UFO source linter for CI).

local curcontext="$curcontext" state line ret=1

case $service in

  ufodiff)
    # UFO source file diff tool for git workflows. Subcommand
    # syntax: ufodiff <sub> [all] [commits:N | branch:name] [filter]
    local -a _subcmds
    _subcmds=(
      'delta:report file changes in plain text ([A]/[D]/[M])'
      'deltajson:report file changes in JSON format'
      'deltamd:report file changes in GitHub-flavored Markdown'
      'diff:colored text diff for modified UFO files (ANSI)'
      'diffnc:uncolored text diff for modified UFO files'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd) _describe -t commands 'ufodiff subcommand' _subcmds && ret=0 ;;
      subcmd_args)
        # Scope-selector: "all" or "commits:N" or "branch:NAME"
        _arguments \
          '1:scope:(all commits\:1 commits\:5 commits\:10 branch\:main branch\:master branch\:develop)' \
          '*:UFO filter (file name):_files' && ret=0
        ;;
    esac
    ;;

  ufolint)
    # UFO source linter — static analysis of UFO directory contents
    # (UFO version/mandatory files/path naming/XML validity/plist
    # formatting/GLIF compliance/PNG specs (UFO v3+)/lib import
    # compatibility). Exits 0 on pass, 1 on any failure.
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:UFO source directory:_files -g "*.ufo"' \
      && ret=0
    ;;

esac

return ret
