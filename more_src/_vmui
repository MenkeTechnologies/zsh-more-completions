#compdef vmui
# _vmui — VictoriaMetrics vmui CLI standalone launcher for the VictoriaMetrics Web UI vmui browser-based PromQL MetricsQL exploration query-trace visual-trend-comparison-cardinality-explorer-graph-view-table-view-LRU-stats helper integrated into vmselect and standalone victoria-metrics single-node binaries (VictoriaMetrics team, Go); pflag
# upstream: https://docs.victoriametrics.com/

_vmui() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--httpListenAddr=+[host:port]:str:' \
        '--httpAuth.username=+[user]:str:' \
        '--httpAuth.password=+[password]:str:' \
        '--vmuiPort=+[port]:n:' \
        '--vmui.serverURL=+[url]:str:' \
        '--vmui.relativeTime=+[s]:s:(true false)' \
        '--vmui.theme=+[t]:t:(light dark system)' \
        '--vmui.basicAuth.user=+[user]:str:' \
        '--vmui.basicAuth.password=+[password]:str:' \
        '--vmui.proxyURL=+[url]:str:' \
        '--vmui.maxSeriesLimit=+[N]:n:' \
        '--vmui.defaultSeriesLimit=+[N]:n:' \
        '--vmui.defaultStep=+[duration]:str:' \
        '--vmui.defaultTime=+[time]:str:' \
        '--vmui.allowedFrequency=+[duration]:str:' \
        '--vmui.timezone=+[tz]:str:' \
        '--vmui.tenantID=+[id]:str:' \
        '--vmui.disableAutocomplete[disable autocomplete]' \
        '--vmui.disableCache[disable cache]' \
        '*::'
}

_vmui "$@"
