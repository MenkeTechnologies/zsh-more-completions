#compdef ftrbnrmf
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftrbnrmf.html
# Compress RMF datasets in channel and/or energy space

local ret=1

_arguments -s -S \
  'infile=[input FITS RMF file to compress]:infile:_files' \
  'ebdfile=[input EBOUNDS file, defaults to infile]:ebdfile:_files' \
  'cmpmode=[channel compression mode]:cmpmode:(binfile phafile linear faint2bright bright2linear)' \
  'binfile=[ASCII channel binning file]:binfile:_files' \
  'phafile=[PHA file with grouping for binning]:phafile:_files' \
  'nchan=[number of channels in compressed RMF]:nchan:' \
  'ecmpmode=[energy compression mode]:ecmpmode:(linear ebinfile optimal)' \
  'ebinfile=[ASCII energy binning file]:ebinfile:_files' \
  'ebfact=[energy binning compression factor]:ebfact:' \
  'outfile=[output compressed RMF file]:outfile:_files' \
  'inarffile=[ARF file to be rebinned]:inarffile:_files' \
  'outarffile=[output compressed ARF file]:outarffile:_files' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:file:_files' && ret=0

return ret
