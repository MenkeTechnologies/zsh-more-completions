#compdef xmore
# Documentation: https://manpages.debian.org/bookworm/x11-apps/xmore.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: Debian manpage lists no options beyond [filename]; xmore inherits standard
# X Toolkit options (-display, -geometry, -bg, -fg, -fn) which are not documented
# in the xmore(1) manpage proper.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:file:_files' && ret=0
return ret
