#compdef xmore
# Documentation: https://man.archlinux.org/search?q=xmore
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-display+[X server display]:display:' \
  '-geometry+[geometry]:geometry:' \
  '-fn+[font]:font:' \
  '-bg+[background color]:color:' \
  '-fg+[foreground color]:color:' \
  '*:file:_files' && ret=0

return ret
