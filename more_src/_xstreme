#compdef xstreme
# Documentation: https://meme-suite.org/meme/doc/xstreme.html
# MEME Suite: comprehensive motif discovery and enrichment pipeline

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--o=[output directory (default xstreme_out), fail if exists]:dir:_files -/' \
  '--oc=[output directory (default xstreme_out), overwrite if exists]:dir:_files -/' \
  '--p=[primary sequence file]:file:_files' \
  '--n=[control sequence file]:file:_files' \
  '--order=[order of the Markov background model]:m:' \
  '--bfile=[background model file]:file:_files' \
  '--seed=[random number seed]:seed:' \
  '*--m=[database of known motifs]:file:_files' \
  '--evt=[E-value threshold for reporting motifs]:evt:' \
  '--time=[maximum runtime in minutes]:minutes:' \
  '--minw=[minimum motif width]:width:' \
  '--maxw=[maximum motif width]:width:' \
  '--w=[exact motif width]:width:' \
  '--mea-only[run only the motif enrichment analysis step]' \
  '--ctrim=[trim sequences to this central region size]:size:' \
  '--align=[alignment of sequences for the site histogram]:align:(left center right)' \
  '--group-thresh=[motif clustering threshold]:gthr:' \
  '--group-weak=[secondary clustering threshold]:wthr:' \
  '--verbosity=[verbosity level]:level:(0 1 2 3 4 5)' \
  '--streme-evt=[STREME E-value threshold]:E-value:' \
  '--streme-nmotifs=[number of motifs STREME should find]:count:' \
  '--streme-totallength=[STREME maximum total sequence length]:totallength:' \
  '--meme-evt=[MEME E-value threshold]:E-value:' \
  '--meme-nmotifs=[number of motifs MEME should find]:num:' \
  '--meme-searchsize=[MEME search size]:searchsize:' \
  '--meme-p=[number of parallel processors for MEME]:np:' \
  '--meme-brief=[MEME output reduction threshold]:nbrief:' \
  '--meme-mod=[MEME site distribution model]:mod:(oops zoops anr)' \
  '--sea-noseqs[do not output the SEA sequences file]' \
  '--fimo-skip[skip the FIMO analysis]' \
  '*:sequence file:_files' && ret=0

return ret
