#compdef kirimase
# Documentation: https://github.com/nicoalbanese/kirimase
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.
# Full-stack Next.js scaffolding CLI. Expanded from prior bare stub to
# the real commands (init, add, generate) and documented init/add flags.

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'init:initialise and configure kirimase'
  'add:initialise and configure packages for the project'
  'generate:scaffold models, controllers and views'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'kirimase command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      init|add)
        _arguments \
          '(-h --headless)'{-h,--headless}'=[run without UI]:yesno:(yes no)' \
          '(-sf --src-folder)'{-sf,--src-folder}'=[use a src folder]:yesno:(yes no)' \
          '(-pm --package-manager)'{-pm,--package-manager}'=[package manager]:pm:(npm yarn pnpm bun)' \
          '(-cl --component-lib)'{-cl,--component-lib}'=[component library]:lib:' \
          '(-o --orm)'{-o,--orm}'=[ORM to use]:orm:(prisma drizzle)' \
          '(-db --db)'{-db,--db}'=[database driver]:db:(pg mysql sqlite)' \
          '(-dbp --db-provider)'{-dbp,--db-provider}'=[database provider]:provider:' \
          '(-a --auth)'{-a,--auth}'=[authentication package]:auth:' \
          '*'{-ap,--auth-providers}'=[auth providers (if using next-auth)]:providers:' \
          '*'{-mp,--misc-packages}'=[additional packages]:packages:' \
          '(-ie --include-example)'{-ie,--include-example}'=[include example]:yesno:(yes no)' && ret=0
        ;;
    esac
    ;;
esac

return ret
