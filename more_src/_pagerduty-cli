#compdef pd
# _pagerduty-cli — PagerDuty CLI (martindstone/pagerduty-cli)
# upstream: https://github.com/martindstone/pagerduty-cli

_pagerduty-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--token=[PagerDuty API token]:token:' \
        '(-o --output)'{-o,--output}'=[output format]:format:(json text table)' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_pd_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                incident)
                    local -a inc_subs=(
                        'list:list incidents'
                        'create:create an incident'
                        'ack:acknowledge incidents'
                        'resolve:resolve incidents'
                        'update:update an incident'
                        'notes:manage incident notes'
                        'alerts:manage incident alerts'
                        'log:show incident log'
                        'open:open incident in browser'
                        'set:set incident fields'
                        'analytics:show incident analytics'
                    )
                    _describe -t cmds 'incident subcommand' inc_subs && ret=0 ;;
                service)
                    local -a svc_subs=(
                        'list:list services'
                        'create:create a service'
                        'set:set service fields'
                        'disable:disable a service'
                        'enable:enable a service'
                        'open:open service in browser'
                    )
                    _describe -t cmds 'service subcommand' svc_subs && ret=0 ;;
                user)
                    local -a user_subs=(
                        'list:list users'
                        'create:create a user'
                        'set:set user fields'
                        'contact:manage contact methods'
                        'oncall:show on-call users'
                        'session:manage user sessions'
                        'log:show user log'
                    )
                    _describe -t cmds 'user subcommand' user_subs && ret=0 ;;
                schedule)
                    local -a sched_subs=(
                        'list:list schedules'
                        'show:show a schedule'
                        'create:create a schedule'
                        'open:open schedule in browser'
                        'oncall:show who is on call'
                        'override:manage schedule overrides'
                        'copy:copy a schedule'
                        'render:render a schedule'
                    )
                    _describe -t cmds 'schedule subcommand' sched_subs && ret=0 ;;
                ep)
                    local -a ep_subs=(
                        'list:list escalation policies'
                        'show:show an escalation policy'
                        'create:create an escalation policy'
                        'open:open EP in browser'
                        'oncall:show who is on call'
                        'copy:copy an escalation policy'
                    )
                    _describe -t cmds 'ep subcommand' ep_subs && ret=0 ;;
                auth)
                    local -a auth_subs=(
                        'login:log in'
                        'logout:log out'
                        'get:get current auth'
                        'set:set auth token'
                        'web:log in via browser'
                    )
                    _describe -t cmds 'auth subcommand' auth_subs && ret=0 ;;
                rest|update|log|tag|analytics) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_pd_commands] )) ||
_pd_commands() {
    local -a commands
    commands=(
        'incident:manage incidents'
        'service:manage services'
        'user:manage users'
        'schedule:manage schedules'
        'ep:manage escalation policies'
        'auth:manage authentication'
        'rest:make PagerDuty REST API calls'
        'update:update the CLI'
        'log:manage log entries'
        'tag:manage tags'
        'analytics:view analytics'
    )
    _describe -t commands 'pd command' commands
}

_pagerduty-cli "$@"
