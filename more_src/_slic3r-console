#compdef slic3r-console
# Documentation: https://manual.slic3r.org/advanced/command-line
# Slic3r console-mode CLI (slice and export from the command line)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-options[show all config options]' \
  '(-g --export-gcode)'{-g,--export-gcode}'[slice and export G-code]' \
  '--export-stl[export models as STL]' \
  '--export-amf[export models as AMF]' \
  '--export-3mf[export models as 3MF]' \
  '--export-obj[export models as OBJ]' \
  '--export-pov[export models as POV-Ray]' \
  '--export-svg[slice and export SVG slices]' \
  '(--export-sla-svg --sla)'{--export-sla-svg,--sla}'[export SLA SVG slices]' \
  '--info[output model information]' \
  '--save=[save config to file]:config:_files' \
  '(-m --merge)'{-m,--merge}'[arrange and merge models into one]' \
  '--dont-arrange[use original model coordinates]' \
  '--center=[center around X,Y]:point:' \
  '--align-xy=[align to X,Y]:point:' \
  '--scale=[scale by factor or percentage]:factor:' \
  '--scale-to-fit=[scale to fit X,Y,Z]:size:' \
  '--rotate=[rotate around Z by angle]:angle:' \
  '--rotate-x=[rotate around X by angle]:angle:' \
  '--rotate-y=[rotate around Y by angle]:angle:' \
  '--duplicate=[number of copies]:count:' \
  '--duplicate-grid=[grid of copies X,Y]:grid:' \
  '--duplicate-distance=[grid spacing]:dist:' \
  '--cut=[cut model at Z height]:z:' \
  '--cut-x=[cut along X]:x:' \
  '--cut-y=[cut along Y]:y:' \
  '--cut-grid=[cut by grid X,Y]:grid:' \
  '--split[split unconnected parts]' \
  '--repair[repair non-manifold meshes]' \
  '(-o --output)'{-o,--output}'=[output file path]:output:_files' \
  '--output-filename-format=[output naming pattern]:format:' \
  '--layer-height=[set layer height]:value:' \
  '--load=[load config from .ini]:config:_files' \
  '--ignore-nonexistent-config[ignore missing config files]' \
  '--autosave=[auto-export config to file]:config:_files' \
  '--datadir=[configuration directory]:dir:_files -/' \
  '*:model file:_files -g "*.(stl|STL|obj|OBJ|amf|AMF|3mf|3MF)"' && ret=0

return ret
