#compdef bee
# Documentation: https://github.com/ethersphere/bee
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Ethswarm bee Swarm client

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:file:_files -g "*.(yaml|yml)(-.)"' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'start:start the Bee node'
      'init:initialize Bee configuration'
      'deploy:deploy smart contracts'
      'db:database management operations'
      'split:chunk splitting functionality'
      'configurate-options:configuration options management'
      'version:print version information'
    )
    _describe -t commands 'bee command' commands && ret=0
    ;;
esac

return ret
