#compdef zettlr Zettlr
# Documentation: https://www.zettlr.com/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: Zettlr is an Electron GUI markdown editor with no documented stable
#   CLI flags. Provide file completion only; no fabricated flag table.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '*:file:_files -g "*.md *.markdown *.mdown *.mkd *.txt"' && ret=0
return ret
