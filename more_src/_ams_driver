#compdef ams_driver
# Documentation: https://github.com/hypre-space/hypre/blob/master/src/test/ams_driver.c
# hypre AMS (Auxiliary-space Maxwell Solver) test driver

local ret=1

_arguments -s -S \
  '-help[print usage and exit]' \
  '-solver[solver ID]:id' \
  '-maxit[maximum number of iterations]:num' \
  '-pcg_maxit[maximum number of PCG iterations]:num' \
  '-tol[convergence tolerance]:num' \
  '-rtol[relative residual tolerance]:num' \
  '-dim[space dimension]:num' \
  '-type[3-level cycle type (0-8,11-14)]:num' \
  '-theta[BoomerAMG strength threshold]:num' \
  '-ctype[BoomerAMG coarsening type]:num' \
  '-agg[levels of BoomerAMG aggressive coarsening]:num' \
  '-amgrlx[BoomerAMG relaxation type]:num' \
  '-itype[BoomerAMG interpolation type]:num' \
  '-pmax[BoomerAMG interpolation truncation]:num' \
  '-rlx[relaxation type]:num' \
  '-rlxn[number of relaxation sweeps]:num' \
  '-rlxw[damping parameter]:num' \
  '-rlxo[SOR parameter]:num' \
  '-crlx[coarse relaxation flag]:num' \
  '-coord[use coordinate vectors]' \
  '-h1[use block-diagonal Poisson solves]' \
  '-sing[curl-curl only (singular) problem]' \
  '-zc[zero-conductivity region flag]:num' \
  '-rr[relative residual reporting]:num' \
  '-bsize[number of eigenvalues to compute]:num' \
  '*:file:_files' && ret=0

return ret
