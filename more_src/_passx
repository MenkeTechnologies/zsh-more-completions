# ════════════════════════════════════════════════════════════════
# § SSH SMART PICKER  (passx ssh — jump straight to key action menu)
# ════════════════════════════════════════════════════════════════
cmd_ssh() {
  _cmd="ssh"
  command -v fzf >/dev/null 2>&1 || err "fzf required"
  # List only stored SSH keys
  local keys; keys="$(list_entries | grep '^ssh/.*-pub$' | sed 's/-pub$//' || true)"
  [ -z "${keys:-}" ] && {
    info "No SSH keys stored.  Add one: passx ssh-add"
    return 0
  }
  local chosen
  chosen="$(printf "%s\n" "$keys" \
    | _fzf_pick "ssh" "Your SSH keys — pick one")" || return 0
  [ -z "${chosen:-}" ] && return 0

  local action
  action="$(printf "restore to ~/.ssh/ + agent\ncopy public key\nshow public key\nshow fingerprint\ninstall to remote\nremove from store" \
    | _fzf_pick "ssh: $chosen" "Action" 30%)" || return 0

  case "$action" in
    "restore to ~/.ssh/ + agent")   cmd_ssh_set  "$chosen" ;;
    "copy public key")
      pass show "${chosen}-pub" 2>/dev/null | copy_clipboard \
        && ok "Public key copied" ;;
    "show public key")
      pass show "${chosen}-pub" 2>/dev/null; echo "" ;;
    "show fingerprint")
      pass show "${chosen}-pub" 2>/dev/null \
        | ssh-keygen -l -f /dev/stdin 2>/dev/null || warn "ssh-keygen failed" ;;
    "install to remote")
      printf "  Remote (user@host): " >&2; read -r remote </dev/tty
      [ -n "${remote:-}" ] && cmd_ssh_copy_id "$chosen" "$remote" ;;
    "remove from store") cmd_ssh_rm "$chosen" ;;
  esac
}

