  command -v fzf >/dev/null 2>&1 || err "fzf required"
  local keys; keys="$(list_entries | grep '^gpg/.*-pub$' | sed 's/-pub$//' || true)"
  [ -z "${keys:-}" ] && {
    info "No GPG keys stored.  Add one: passx gpg-add"
    return 0
  }
  local chosen
  chosen="$(printf "%s\n" "$keys" \
    | _fzf_pick "gpg" "Your GPG keys — pick one")" || return 0
  [ -z "${chosen:-}" ] && return 0

  local action
  action="$(printf "restore to keyring\ncopy public key\nshow public key\nremove from store" \
    | _fzf_pick "gpg: $chosen" "Action" 25%)" || return 0

  case "$action" in
    "restore to keyring") cmd_gpg_set "$chosen" ;;
    "copy public key")
      pass show "${chosen}-pub" 2>/dev/null | copy_clipboard && ok "Public key copied" ;;
    "show public key")
      pass show "${chosen}-pub" 2>/dev/null; echo "" ;;
    "remove from store") cmd_gpg_rm "$chosen" ;;
  esac
}

# ════════════════════════════════════════════════════════════════
# § USER-DEFINED TEMPLATES  (passx template-new)
# ════════════════════════════════════════════════════════════════
cmd_template_new() {
  _cmd="template-new"
  _banner "Create User Template"
  printf "  Template name (e.g. vpn, aws-iam): " >&2; read -r tname </dev/tty || tname=""
  [ -z "${tname:-}" ] && { dim "Aborted"; return 0; }
  local tfile="$PASSX_TEMPLATES_DIR/${tname}"
  if [ -f "$tfile" ]; then
    printf "  Template '%s' exists. Overwrite? [y/N] " "$tname" >&2
    read -r yn </dev/tty || yn=""; [ "${yn,,}" != "y" ] && { dim "Aborted"; return 0; }
  fi
  info "Define fields (one per line: 'field_name: prompt text')"
  info "First field is always the password. Use 'password: label' to customise."
  info "Example lines:"
  dim "  username: AWS IAM username"
  dim "  url: Console URL"
  dim "  notes: Account purpose"
  printf "\n  Enter fields (Ctrl-D when done):\n" >&2
  local fields; fields="$(cat)"
  [ -z "${fields:-}" ] && { dim "No fields entered"; return 0; }
  mkdir -p "$PASSX_TEMPLATES_DIR"
  printf "%s\n" "$fields" > "$tfile"
  ok "Template saved: $tfile"
  info "Use it: passx template $tname"
}

# ════════════════════════════════════════════════════════════════
# § METADATA CACHE COMMAND  (passx meta-build)
# ════════════════════════════════════════════════════════════════
cmd_meta_build() {
  _cmd="meta-build"
  _banner "Building Metadata Cache"
  info "Decrypting all entries to build URL/OTP/DB index..."
  info "This runs once; subsequent searches will be instant."
  local count=0 total
  total="$(list_entries | wc -l)"
  # Remove existing to force rebuild
  rm -f "$(_meta_cache_file)"
  while IFS= read -r e; do
    [ -z "$e" ] && continue
    count=$((count+1))
    printf "  ${C_DIM}[%d/%d] %s${C_RESET}\r" "$count" "$total" "$e" >&2
    local content; content="$(pass show "$e" 2>/dev/null)" || continue
    local has_host=0 has_db=0 has_otp=0 url=""
    printf "%s\n" "$content" | grep -qE "^host:"        && has_host=1
    printf "%s\n" "$content" | grep -qE "^database:"    && has_db=1
    printf "%s\n" "$content" | grep -qE "^otp:|^otpauth://" && has_otp=1
    url="$(printf "%s\n" "$content" | grep -m1 "^url:" | sed "s/^url: *//")"
    printf "%s\t%s\t%s\t%s\t%s\n" "$e" "$has_host" "$has_db" "$has_otp" "$url" \
      >> "$(_meta_cache_file)"
  done < <(list_entries)
  printf "%-70s\r" "" >&2
  ok "Metadata cache built ($count entries)"
  info "Re-run after adding entries with URLs/DBs:  passx meta-build"
}

# ════════════════════════════════════════════════════════════════
# § ALIAS SYSTEM
# ════════════════════════════════════════════════════════════════
_alias_file() { printf "%s/aliases" "$PASSX_CONF_DIR"; }

_resolve_alias() {
  local name="$1"
  local file; file="$(_alias_file)"
  [ -f "$file" ] || { printf "%s" "$name"; return; }
  local resolved; resolved="$(grep -m1 "^${name}=" "$file" 2>/dev/null | cut -d= -f2- || true)"
  [ -n "$resolved" ] && printf "%s" "$resolved" || printf "%s" "$name"
}

cmd_alias() {
  _cmd="alias"
  case "${1:-list}" in
    add)
      [ -z "${2:-}" ] || [ -z "${3:-}" ] && err "Usage: passx alias add <name> <path>"
      local file; file="$(_alias_file)"
      grep -v "^${2}=" "$file" 2>/dev/null > "${file}.tmp" && mv "${file}.tmp" "$file" || true
      printf "%s=%s\n" "$2" "$3" >> "$file"; ok "Alias: $2 → $3" ;;
    rm)
      [ -z "${2:-}" ] && err "Usage: passx alias rm <name>"
      local file; file="$(_alias_file)"
      local tmp; tmp="$(mktemp)"
      grep -v "^${2}=" "$file" 2>/dev/null > "$tmp" && mv "$tmp" "$file" || true
      ok "Alias '$2' removed" ;;
    list)
      local file; file="$(_alias_file)"
      [ -f "$file" ] || { info "No aliases defined."; return 0; }
      _banner "Aliases"
      while IFS='=' read -r name target; do
        printf "  ${C_CYAN}%-20s${C_RESET} → %s\n" "$name" "$target"
      done < "$file"; echo "" ;;
    *) err "Usage: passx alias [add <name> <path> | rm <name> | list]" ;;
  esac
}

# ════════════════════════════════════════════════════════════════
# § PIN SYSTEM
# ════════════════════════════════════════════════════════════════
cmd_pin() {
  _cmd="pin"
  case "${1:-list}" in
    add)
      [ -z "${2:-}" ] && err "Usage: passx pin add <path>"
      local file; file="$(_pin_file)"
      grep -qxF "$2" "$file" 2>/dev/null && { info "Already pinned: $2"; return 0; }
      printf "%s\n" "$2" >> "$file"; ok "Pinned: $2" ;;
    rm)
      [ -z "${2:-}" ] && err "Usage: passx pin rm <path>"
      local file; file="$(_pin_file)"
      local tmp; tmp="$(mktemp)"
      grep -vxF "$2" "$file" > "$tmp" 2>/dev/null && mv "$tmp" "$file" || true
      ok "Unpinned: $2" ;;
    list)
      local file; file="$(_pin_file)"
      [ -f "$file" ] || { info "No pinned entries."; return 0; }
      _banner "Pinned Entries"
      while IFS= read -r e; do printf "  📌  %s\n" "$e"; done < "$file"; echo "" ;;
    *) err "Usage: passx pin [add <path> | rm <path> | list]" ;;
  esac
}

# ════════════════════════════════════════════════════════════════
# § FRECENCY COMMAND
# ════════════════════════════════════════════════════════════════
cmd_frecency() {
  _cmd="frecency"
  case "${1:-list}" in
    list)
      _banner "Frecency Rankings"
      local file; file="$(_frecency_file)"
      [ -f "$file" ] || { info "No frecency data yet."; return; }
      local i=1
      while IFS=$'\t' read -r epoch count entry; do
        local score; score="$(_frecency_score "$epoch" "$count")"
        printf "  ${C_CYAN}%3d${C_RESET}  ${C_BOLD}%-38s${C_RESET}  accesses:%-4s  score:%.2f\n" \
          "$i" "$entry" "$count" "$score"
        i=$((i+1)); [ $i -gt 30 ] && break
      done < <(sort -t$'\t' -k1 -rn "$file" 2>/dev/null) ;;
    reset)
      if [ -n "${2:-}" ]; then
        local file; file="$(_frecency_file)"; local tmp; tmp="$(mktemp)"
        grep -v "	${2}$" "$file" > "$tmp" 2>/dev/null && mv "$tmp" "$file" || true
        ok "Reset frecency for $2"
      else
        rm -f "$(_frecency_file)"; ok "Frecency data cleared"
      fi ;;
    *) err "Usage: passx frecency [list|reset [path]]" ;;
  esac
}

# ════════════════════════════════════════════════════════════════
# § WHERE — reverse domain lookup
# ════════════════════════════════════════════════════════════════
cmd_where() {
  _cmd="where"
  local query="${1:-}" do_copy=false do_fill=false
  shift 2>/dev/null || true
  while [ "$#" -gt 0 ]; do
    case "$1" in --copy|-c) do_copy=true ;; --fill|-f) do_fill=true ;; esac; shift
  done
  [ -z "$query" ] && { printf "  Search domain or keyword: " >&2; read -r query </dev/tty; }
  [ -z "${query:-}" ] && err "No search query"
  local domain; domain="$(printf "%s" "$query" | sed 's|https\?://||; s|/.*||')"
  local -a results=()
  local mcache; mcache="$(_meta_cache_file)"
  if [ -f "$mcache" ]; then
    # Fast path: scan URL column in metadata cache
    while IFS=$'\t' read -r entry _ _ _ url; do
      [[ "$url" == *"$domain"* ]] && results+=("$entry")
    done < "$mcache"
  else
    info "Building URL index (first run)..."
    while IFS= read -r entry; do
      [ -z "$entry" ] && continue
      local content; content="$(pass show "$entry" 2>/dev/null)" || continue
      local url; url="$(printf "%s\n" "$content" | grep -m1 "^url:" | sed "s/^url: *//" || true)"
      [[ "$url" == *"$domain"* ]] && results+=("$entry")
    done < <(list_entries)
  fi
  if [ ${#results[@]} -eq 0 ]; then info "No entries matching '${domain}'"; return 0; fi
  printf "\n  ${C_BOLD}Found %d match(es):${C_RESET}\n\n" "${#results[@]}"
  for r in "${results[@]}"; do
    local url; url="$(_meta_lookup "$r" url 2>/dev/null || pass show "$r" 2>/dev/null | grep -m1 "^url:" | sed "s/^url: *//"; true)"
    printf "  ${C_CYAN}%-38s${C_RESET}  ${C_DIM}%s${C_RESET}\n" "$r" "$url"
  done; echo ""
  if $do_copy || $do_fill; then
    local chosen="${results[0]}"
    [ ${#results[@]} -gt 1 ] && chosen="$(printf "%s\n" "${results[@]}" | _fzf_pick "where" "Select entry")" || true
    [ -z "${chosen:-}" ] && return 0
    $do_copy && { extract_field "$chosen" password | tr -d '\n' | copy_clipboard --silent
      _clip_log "$chosen" password; ok "Password copied"; }
    $do_fill && cmd_fill "$chosen"
  fi
}

# ════════════════════════════════════════════════════════════════
# § FIND — full-text search across decrypted content
# ════════════════════════════════════════════════════════════════
cmd_find() {
  _cmd="find"
  local query="" field=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --field|-f) field="${2:-}"; shift ;;
      --url)      field="url" ;;
      --help|-h)
        printf "\n${C_BOLD}passx find${C_RESET} <query> [--field <field>]\n\n"
        printf "  Full-text search across all decrypted entries.\n\n"; return 0 ;;
      -*) err "Unknown flag: $1" ;;
      *) query="$1" ;;
    esac; shift
  done
  [ -z "$query" ] && err "Usage: passx find <query> [--field <field>]"
  info "Searching all entries (requires decryption)..."
  local results=0 total=0
  while IFS= read -r entry; do
    [ -z "$entry" ] && continue; total=$((total+1))
    local content; content="$(pass show "$entry" 2>/dev/null)" || continue
    local hit=false
    if [ -n "$field" ]; then
      local val; val="$(printf "%s\n" "$content" | grep -m1 "^${field}:" | sed "s/^${field}: *//")"
      [[ "$val" == *"$query"* ]] && hit=true
    else
      [[ "$content" == *"$query"* ]] && hit=true
    fi
    if $hit; then
      results=$((results+1))
      local matched; matched="$(printf "%s\n" "$content" | grep -m1 "$query" | head -c 60 || true)"
      printf "  ${C_CYAN}%-38s${C_RESET}  ${C_DIM}%s${C_RESET}\n" "$entry" "$matched"
    fi
    [ $((total % 10)) -eq 0 ] && printf "  ${C_DIM}Scanned %d...${C_RESET}\r" "$total" >&2
  done < <(list_entries)
  printf "%-60s\r" "" >&2; echo ""
  [ $results -eq 0 ] && info "No matches for '$query'" \
                      || info "Found $results / $total entries"
}

# ════════════════════════════════════════════════════════════════
# § HISTORY — per-entry git log
# ════════════════════════════════════════════════════════════════
cmd_history() {
  _cmd="history"; _need_git
  local path="${1:-}"
  path="$(_resolve_alias "${path:-}")"
  [ -z "$path" ] && path="$(list_entries | _fzf_pick "history" "Select entry")" || true
  [ -z "${path:-}" ] && err "No entry selected"
  _banner "History: $path"
  cd "$PASSWORD_STORE_DIR" && git log --follow \
    --format="%C(dim)%ai%Creset  %s" -- "${path}.gpg" 2>/dev/null \
    | sed 's/ +[^ ]*//' | sed 's/^/  /'
  echo ""
}

# ════════════════════════════════════════════════════════════════
# § STALE WARNING ON COPY
# ════════════════════════════════════════════════════════════════
_warn_stale() {
  [ "$PASSX_WARN_STALE" = "true" ] || return 0
  local entry="$1"; [ -d "$PASSWORD_STORE_DIR/.git" ] || return 0
  local lc days
  lc="$(cd "$PASSWORD_STORE_DIR" && git log -1 --format="%ct" -- "${entry}.gpg" 2>/dev/null || echo 0)"
  [ "${lc:-0}" -eq 0 ] && return 0
  days=$(( ($(date +%s) - lc) / 86400 ))
  [ "$days" -gt "$PASSX_MAX_AGE" ] && \
    warn "Last rotated ${days} days ago — consider: passx rotate ${entry}"
}

# ════════════════════════════════════════════════════════════════
# § SNIP — single-decryption structured output for scripting
# ════════════════════════════════════════════════════════════════
cmd_snip() {
  _cmd="snip"
  local path="${1:-}" format="${2:-export}"
  path="$(_resolve_alias "${path:-}")"
  [ -z "$path" ] && path="$(list_entries | _fzf_pick "snip" "Select entry")" || true
  [ -z "${path:-}" ] && err "No entry selected"
  local e; e="$(pass show "$path" 2>/dev/null)" || err "Cannot decrypt: $path"
  local pw user email host port db token url
  pw="$(printf "%s\n" "$e"    | sed -n '1p')"
  user="$(printf "%s\n" "$e"  | grep -m1 "^username:" | sed "s/^username: *//")"
  email="$(printf "%s\n" "$e" | grep -m1 "^email:"    | sed "s/^email: *//")"
  host="$(printf "%s\n" "$e"  | grep -m1 "^host:"     | sed "s/^host: *//")"
  port="$(printf "%s\n" "$e"  | grep -m1 "^port:"     | sed "s/^port: *//")"
  db="$(printf "%s\n" "$e"    | grep -m1 "^database:" | sed "s/^database: *//")"
  token="$(printf "%s\n" "$e" | grep -m1 "^token:"    | sed "s/^token: *//")"
  url="$(printf "%s\n" "$e"   | grep -m1 "^url:"      | sed "s/^url: *//")"
  local pfx; pfx="$(printf "%s" "${path}" | tr '[:lower:]/' '[:upper:]_')_"
  case "$format" in
    dotenv)
      [ -n "$pw"    ] && printf "PASSWORD=%s\n"   "$pw"
      [ -n "$user"  ] && printf "USERNAME=%s\n"   "$user"
      [ -n "$email" ] && printf "EMAIL=%s\n"      "$email"
      [ -n "$host"  ] && printf "HOST=%s\n"       "$host"
      [ -n "$port"  ] && printf "PORT=%s\n"       "$port"
      [ -n "$db"    ] && printf "DATABASE=%s\n"   "$db"
      [ -n "$token" ] && printf "TOKEN=%s\n"      "$token"
      [ -n "$url"   ] && printf "URL=%s\n"        "$url" ;;
    *)
      [ -n "$pw"    ] && printf "export PASSX_PASSWORD='%s'\n"  "$pw"
      [ -n "$user"  ] && printf "export PASSX_USERNAME='%s'\n"  "$user"
      [ -n "$email" ] && printf "export PASSX_EMAIL='%s'\n"     "$email"
      [ -n "$host"  ] && printf "export PASSX_HOST='%s'\n"      "$host"
      [ -n "$port"  ] && printf "export PASSX_PORT='%s'\n"      "$port"
      [ -n "$db"    ] && printf "export PASSX_DATABASE='%s'\n"  "$db"
      [ -n "$token" ] && printf "export PASSX_TOKEN='%s'\n"     "$token"
      [ -n "$url"   ] && printf "export PASSX_URL='%s'\n"       "$url"
      [ -n "$pw"    ] && printf "export %sPASSWORD='%s'\n"  "$pfx" "$pw"
      [ -n "$user"  ] && printf "export %sUSERNAME='%s'\n"  "$pfx" "$user"
      [ -n "$token" ] && printf "export %sTOKEN='%s'\n"     "$pfx" "$token" ;;
  esac
}

# ════════════════════════════════════════════════════════════════
# § DATABASE MODE
# ════════════════════════════════════════════════════════════════
# ── Metadata cache: stores has_db, has_otp, url per entry ────────
_meta_cache_file() { printf "%s/metadata" "$PASSX_CACHE_DIR"; }

_build_meta_cache() {
  local mcache; mcache="$(_meta_cache_file)"
  # Only rebuild if entry cache is newer than meta cache
  local ecache; ecache="$(_cache_file)"
  if [ -f "$mcache" ] && [ -f "$ecache" ] && [ "$mcache" -nt "$ecache" ]; then
    return 0
  fi
  mkdir -p "$PASSX_CACHE_DIR"
  : > "$mcache"
  while IFS= read -r e; do
    [ -z "$e" ] && continue
    local content; content="$(pass show "$e" 2>/dev/null)" || continue
    local has_host=0 has_db=0 has_otp=0 url=""
    printf "%s\n" "$content" | grep -qE "^host:"     && has_host=1
    printf "%s\n" "$content" | grep -qE "^database:" && has_db=1
    printf "%s\n" "$content" | grep -qE "^otp:|^otpauth://" && has_otp=1
    url="$(printf "%s\n" "$content" | grep -m1 "^url:" | sed "s/^url: *//")"
    printf "%s\t%s\t%s\t%s\t%s\n" "$e" "$has_host" "$has_db" "$has_otp" "$url" >> "$mcache"
  done < <(list_entries)
}

_meta_lookup() {
  # _meta_lookup <entry> <field: has_host|has_db|has_otp|url>
  local entry="$1" field="$2"
  local mcache; mcache="$(_meta_cache_file)"
  [ -f "$mcache" ] || return 1
  local row; row="$(grep -m1 "^${entry}	" "$mcache" 2>/dev/null || true)"
  [ -z "$row" ] && return 1
  case "$field" in
    has_host) printf "%s" "$(printf "%s" "$row" | cut -f2)" ;;
    has_db)   printf "%s" "$(printf "%s" "$row" | cut -f3)" ;;
    has_otp)  printf "%s" "$(printf "%s" "$row" | cut -f4)" ;;
    url)      printf "%s" "$(printf "%s" "$row" | cut -f5)" ;;
  esac
}

_db_entries() {
  # Fast path: use metadata cache if available
  local mcache; mcache="$(_meta_cache_file)"
  if [ -f "$mcache" ]; then
    awk -F'\t' '($2=="1" || $3=="1") {print $1}' "$mcache" 2>/dev/null
    return
  fi
  # Slow path: decrypt each entry (and build cache for next time)
  while IFS= read -r e; do
    [ -z "$e" ] && continue
    local content; content="$(pass show "$e" 2>/dev/null)" || continue
    printf "%s\n" "$content" | grep -qE "^(host|database):" && printf "%s\n" "$e" || true
  done < <(list_entries)
}

_db_detect_type() {
  local port="${1:-}" type_field="${2:-}"
  case "${type_field,,}" in
    postgres*|pg|postgresql) printf "postgres"; return ;;
    mysql*|mariadb*)         printf "mysql";    return ;;
    redis*)                  printf "redis";    return ;;
    mongo*)                  printf "mongo";    return ;;
    sqlite*)                 printf "sqlite";   return ;;
  esac
  case "$port" in
    5432)  printf "postgres" ;;
    3306)  printf "mysql"    ;;
    6379)  printf "redis"    ;;
    27017) printf "mongo"    ;;
    *)     printf "unknown"  ;;
  esac
}

_db_client_for() {
  local dbtype="$1"
  [ "$PASSX_DB_CLIENT" != "auto" ] && { printf "%s" "$PASSX_DB_CLIENT"; return; }
  case "$dbtype" in
    postgres) for c in pgcli psql;      do command -v "$c" >/dev/null 2>&1 && { printf "%s" "$c"; return; }; done ;;
    mysql)    for c in mycli mysql mariadb; do command -v "$c" >/dev/null 2>&1 && { printf "%s" "$c"; return; }; done ;;
    redis)    command -v redis-cli >/dev/null 2>&1 && printf "redis-cli" ;;
    mongo)    for c in mongosh mongo;   do command -v "$c" >/dev/null 2>&1 && { printf "%s" "$c"; return; }; done ;;
    sqlite)   command -v sqlite3 >/dev/null 2>&1 && printf "sqlite3" ;;
  esac
}

cmd_db() {
  _cmd="db"
  local subcmd="${1:-list}"; shift 2>/dev/null || true

  case "$subcmd" in
    list|"")
      _banner "Database Entries"
      local found=false
      while IFS= read -r e; do
        [ -z "$e" ] && continue
        # Decrypt only this one entry for display
        local entry; entry="$(pass show "$e" 2>/dev/null)" || continue
        local host db port type_field
        host="$(printf "%s\n" "$entry" | grep -m1 "^host:"     | sed "s/^host: *//")"
        db="$(printf "%s\n"   "$entry" | grep -m1 "^database:" | sed "s/^database: *//")"
        port="$(printf "%s\n" "$entry" | grep -m1 "^port:"     | sed "s/^port: *//")"
        type_field="$(printf "%s\n" "$entry" | grep -m1 "^type:" | sed "s/^type: *//")"
        local dbtype; dbtype="$(_db_detect_type "${port:-}" "${type_field:-}")"
        printf "  ${C_CYAN}%-38s${C_RESET}  ${C_BOLD}%-10s${C_RESET}  %s%s%s\n" \
          "$e" "$dbtype" "$host" "${port:+:$port}" "${db:+/$db}"
        found=true
      done < <(_db_entries)
      $found || info "No database entries. Add one:  passx template database"
      echo "" ;;

    connect|shell)
      local path="${1:-}"
      path="$(_resolve_alias "${path:-}")"
      if [ -z "$path" ]; then
        local _dbl; _dbl="$(_db_entries)"
        [ -z "${_dbl:-}" ] && err "No database entries found"
        path="$(printf "%s\n" "$_dbl" | _fzf_pick "db" "Select database")" || return 0
      fi
      [ -z "${path:-}" ] && err "No entry selected"
      local e; e="$(pass show "$path" 2>/dev/null)" || err "Cannot decrypt"
      local pw user host port db type_field
      pw="$(printf "%s\n" "$e"         | sed -n '1p')"
      user="$(printf "%s\n" "$e"       | grep -m1 "^username:" | sed "s/^username: *//")"
      host="$(printf "%s\n" "$e"       | grep -m1 "^host:"     | sed "s/^host: *//")"
      port="$(printf "%s\n" "$e"       | grep -m1 "^port:"     | sed "s/^port: *//")"
      db="$(printf "%s\n" "$e"         | grep -m1 "^database:" | sed "s/^database: *//")"
      type_field="$(printf "%s\n" "$e" | grep -m1 "^type:"     | sed "s/^type: *//")"
      [ -z "$host" ] && err "No host field in $path"
      local dbtype; dbtype="$(_db_detect_type "${port:-5432}" "${type_field:-}")"
      local client; client="$(_db_client_for "$dbtype")"
      [ -z "$client" ] && err "No client found for $dbtype. Install: pgcli/psql/mycli/mysql/redis-cli/mongosh"
      info "Connecting: ${user:+${user}@}${host}${port:+:$port}${db:+/$db}  [${dbtype}/${client}]"
      case "$dbtype" in
        postgres) PGPASSWORD="$pw" "$client" \
            -h "$host" ${port:+-p "$port"} ${user:+-U "$user"} ${db:+-d "$db"} ;;
        mysql)
          if [[ "$client" == "mycli" ]]; then
            mycli -h "$host" ${port:+-P "$port"} ${user:+-u "$user"} --password="$pw" ${db:-}
          else
            mysql -h "$host" ${port:+-P "$port"} ${user:+-u "$user"} -p"$pw" ${db:-}
          fi ;;
        redis)
          [ -n "$pw" ] && redis-cli -h "${host:-127.0.0.1}" ${port:+-p "$port"} -a "$pw" \
                       || redis-cli -h "${host:-127.0.0.1}" ${port:+-p "$port"} ;;
        mongo)
          local mongo_url="mongodb://${user:+${user}:${pw}@}${host}${port:+:$port}${db:+/$db}"
          "$client" "$mongo_url" ;;
        sqlite) sqlite3 "${db:-$host}" ;;
        *) err "Unsupported database type: $dbtype" ;;
      esac ;;

    query)
      local path="${1:-}"; shift 2>/dev/null || true
      path="$(_resolve_alias "${path:-}")"
      local sql="${1:-}"
      [ -z "$path" ] && err "Usage: passx db query <path> <SQL>"
      [ -z "$sql" ] && { printf "  SQL: " >&2; read -r sql </dev/tty; }
      [ -z "${sql:-}" ] && err "No SQL provided"
      local e; e="$(pass show "$path" 2>/dev/null)" || err "Cannot decrypt"
      local pw user host port db type_field
      pw="$(printf "%s\n" "$e"         | sed -n '1p')"
      user="$(printf "%s\n" "$e"       | grep -m1 "^username:" | sed "s/^username: *//")"
      host="$(printf "%s\n" "$e"       | grep -m1 "^host:"     | sed "s/^host: *//")"
      port="$(printf "%s\n" "$e"       | grep -m1 "^port:"     | sed "s/^port: *//")"
      db="$(printf "%s\n" "$e"         | grep -m1 "^database:" | sed "s/^database: *//")"
      type_field="$(printf "%s\n" "$e" | grep -m1 "^type:"     | sed "s/^type: *//")"
      local dbtype; dbtype="$(_db_detect_type "${port:-5432}" "${type_field:-}")"
      case "$dbtype" in
        postgres) PGPASSWORD="$pw" psql -h "$host" ${port:+-p "$port"} \
                    ${user:+-U "$user"} ${db:+-d "$db"} -c "$sql" ;;
        mysql)    mysql -h "$host" ${port:+-P "$port"} ${user:+-u "$user"} \
                    -p"$pw" ${db:-} -e "$sql" ;;
        sqlite)   sqlite3 "${db:-$host}" "$sql" ;;
        *) err "passx db query not supported for $dbtype" ;;
      esac ;;

    tunnel)
      local path="${1:-}"
      [ -z "$path" ] && path="$(_db_entries | _fzf_pick "db tunnel" "Select DB")" || true
      [ -z "${path:-}" ] && err "No entry"
      local e; e="$(pass show "$path" 2>/dev/null)" || err "Cannot decrypt"
      local host port
      host="$(printf "%s\n" "$e" | grep -m1 "^host:" | sed "s/^host: *//")"
      port="$(printf "%s\n" "$e" | grep -m1 "^port:" | sed "s/^port: *//")"
      printf "  SSH jump host (user@host): " >&2; read -r jump </dev/tty
      [ -z "${jump:-}" ] && err "No jump host"
      local local_port=$(( ${port:-5432} + 10000 ))
      step "SSH tunnel: localhost:${local_port} → ${host}:${port:-5432}  (Ctrl-C to close)"
      ssh -NL "${local_port}:${host}:${port:-5432}" "$jump" ;;

    --help|-h) printf "\n${C_BOLD}passx db${C_RESET} [list|connect|query|tunnel] [path]\n\n"
      printf "  Manages database entries with auto-detected clients.\n"
      printf "  Supports: postgres, mysql, redis, mongo, sqlite\n\n"
      printf "  Clients used (auto-detect or PASSX_DB_CLIENT):\n"
      printf "    postgres → pgcli or psql\n    mysql    → mycli or mysql\n"
      printf "    redis    → redis-cli\n    mongo    → mongosh or mongo\n\n" ;;
    *) err "Usage: passx db [list|connect|query|tunnel] [path]" ;;
  esac
}

# ════════════════════════════════════════════════════════════════
# § ATTACHMENTS
# ════════════════════════════════════════════════════════════════
cmd_attach() {
  _cmd="attach"
  local subcmd="${1:-ls}"; shift 2>/dev/null || true
  case "$subcmd" in
    add)
      local path="${1:-}" file="${2:-}"
      [ -z "$path" ] && path="$(list_entries | _fzf_pick "attach" "Select entry")" || true
      [ -z "${path:-}" ] && err "No entry"
      [ -z "$file" ] && { printf "  File to attach: " >&2; read -r file </dev/tty; }
      file="${file/#\~/$HOME}"; [ ! -f "$file" ] && err "File not found: $file"
      local fname; fname="$(basename "$file")"
      local gpg_id; gpg_id="$(head -1 "$PASSWORD_STORE_DIR/.gpg-id" 2>/dev/null)"
      [ -z "${gpg_id:-}" ] && err "Cannot read .gpg-id from store"
      _gpg_env
      gpg --encrypt --recipient "$gpg_id" \
        --output "$PASSWORD_STORE_DIR/${path}.attach.${fname}.gpg" "$file" 2>/dev/null \
        || err "Encryption failed"
      [ -d "$PASSWORD_STORE_DIR/.git" ] && {
        cd "$PASSWORD_STORE_DIR"
        git add "${path}.attach.${fname}.gpg" 2>/dev/null
        git commit -m "attach: ${fname} to ${path}" 2>/dev/null || true
      }
      ok "Attached: $fname → $path"; _autosync ;;
    get)
      local path="${1:-}" fname="${2:-}"
      [ -z "$path" ] && path="$(list_entries | _fzf_pick "attach get" "Select entry")" || true
      [ -z "${path:-}" ] && err "No entry"
      if [ -z "$fname" ]; then
        local -a attachments=()
        while IFS= read -r f; do
          attachments+=("$(basename "$f" .gpg | sed "s/^${path}.attach.//")")
        done < <(find "$PASSWORD_STORE_DIR" -name "${path}.attach.*.gpg" 2>/dev/null)
        [ ${#attachments[@]} -eq 0 ] && err "No attachments for $path"
        fname="$(printf "%s\n" "${attachments[@]}" | _fzf_pick "attach get" "Select attachment")"
      fi
      [ -z "${fname:-}" ] && err "No attachment"
      gpg --decrypt "$PASSWORD_STORE_DIR/${path}.attach.${fname}.gpg" 2>/dev/null \
        || err "Decryption failed" ;;
    ls)
      local path="${1:-}"
      [ -z "$path" ] && path="$(list_entries | _fzf_pick "attach ls" "Select entry")" || true
      [ -z "${path:-}" ] && err "No entry"
      local found=false
      while IFS= read -r f; do
        printf "  📎  %s\n" "$(basename "$f" .gpg | sed "s/^.*\.attach\.//")"
        found=true
      done < <(find "$PASSWORD_STORE_DIR" -name "${path}.attach.*.gpg" 2>/dev/null)
      $found || info "No attachments for $path" ;;
    rm)
      local path="${1:-}" fname="${2:-}"
      [ -z "$path" ] || [ -z "$fname" ] && err "Usage: passx attach rm <path> <filename>"
      local f="$PASSWORD_STORE_DIR/${path}.attach.${fname}.gpg"
      [ -f "$f" ] || err "Not found: $fname"
      printf "  Remove '%s' from '%s'? [y/N] " "$fname" "$path" >&2
      read -r yn </dev/tty || yn=""; [ "${yn,,}" != "y" ] && { dim "Aborted"; return 0; }
      rm -f "$f"
      [ -d "$PASSWORD_STORE_DIR/.git" ] && {
        cd "$PASSWORD_STORE_DIR"
        git rm -f "${path}.attach.${fname}.gpg" 2>/dev/null
        git commit -m "rm-attach: ${fname} from ${path}" 2>/dev/null || true
      }
      ok "Removed: $fname"; _autosync ;;
    *) err "Usage: passx attach [add|get|ls|rm] <path> [file]" ;;
  esac
}


# ════════════════════════════════════════════════════════════════
# § VAULT — multiple independent password stores
# ════════════════════════════════════════════════════════════════
# Each vault = ~/.config/passx/vaults/NAME  containing:
#   export PASSWORD_STORE_DIR="/path/to/store"
# Sourced at startup. Clean, no exec-self tricks.
# ════════════════════════════════════════════════════════════════
_vault_dir()   { printf "%s/vaults" "$PASSX_CONF_DIR"; }
_active_file() { printf "%s/active_vault" "$PASSX_CACHE_DIR"; }

_vault_store_dir() {
  # Read store path from vault config without sourcing it
  local vfile; vfile="$(_vault_dir)/${1}"
  [ -f "$vfile" ] || { printf ""; return; }
  awk -F= '/^export PASSWORD_STORE_DIR=/{
    v=$2; gsub(/^[ \t"'"'"']+|[ \t"'"'"']+$/, "", v)
    home=ENVIRON["HOME"]; sub(/^~/, home, v)
    print v; exit
  }' "$vfile" 2>/dev/null || true
}

cmd_vault() {
  _cmd="vault"
  local subcmd="${1:-list}"; shift 2>/dev/null || true
  local vdir; vdir="$(_vault_dir)"
  mkdir -p "$vdir"

  case "$subcmd" in
    list)
      _banner "Password Vaults"
      local active; active="$(cat "$(_active_file)" 2>/dev/null || true)"
      local marker; marker=""
      [ -z "$active" ] && marker="  ${C_GREEN}(active)${C_RESET}"
      printf "  ${C_CYAN}%-20s${C_RESET}  %-38s%b\n" \
        "default" "${PASSWORD_STORE_DIR:-$HOME/.password-store}" "$marker"
      for f in "$vdir"/*; do
        [ -f "$f" ] || continue
        local vname; vname="$(basename "$f")"
        local vstore; vstore="$(_vault_store_dir "$vname")"
        marker=""
        [ "$vname" = "$active" ] && marker="  ${C_GREEN}(active)${C_RESET}"
        local cnt; cnt=""
        if [ -d "${vstore:-}" ]; then
          cnt=$(find "$vstore" -name "*.gpg" 2>/dev/null | wc -l)
          cnt="  ${C_DIM}(${cnt} entries)${C_RESET}"
        fi
        printf "  ${C_CYAN}%-20s${C_RESET}  %-38s%b%b\n" \
          "$vname" "${vstore:-?}" "$marker" "$cnt"
      done
      echo "" ;;

    add|create|new)
      local vname="${1:-}"
      [ -z "$vname" ] && { printf "  Vault name (e.g. work, personal): " >&2
        read -r vname </dev/tty; }
      [ -z "${vname:-}" ] && err "No vault name"
      [[ "$vname" =~ ^[a-zA-Z0-9_-]+$ ]] \
        || err "Name must be alphanumeric / dash / underscore only"
      [ -f "$vdir/$vname" ] && { warn "Vault '$vname' already exists"; return 0; }
      local vdef="$HOME/.password-store-${vname}"
      printf "  Store path [%s]: " "$vdef" >&2; read -r vstore </dev/tty
      vstore="${vstore:-$vdef}"; vstore="${vstore/#\~/$HOME}"
      # Write vault config — plain shell, sourced at startup
      {
        printf "# passx vault: %s\n" "$vname"
        printf "export PASSWORD_STORE_DIR=\"%s\"\n" "$vstore"
        printf "# Uncomment to override per-vault:\n"
        printf "# export PASSX_CLIP_TIMEOUT=30\n"
        printf "# export PASSX_AUTOSYNC=true\n"
      } > "$vdir/$vname"
      ok "Vault config created: $vdir/$vname"
      printf "  Initialize password store now? [Y/n] " >&2
      read -r yn </dev/tty || yn="y"
      if [ "${yn,,}" != "n" ]; then
        printf "  GPG key ID(s) (space-separated): " >&2
        read -r gpg_keys </dev/tty
        [ -z "${gpg_keys:-}" ] && err "GPG key required"
        mkdir -p "$vstore"
        PASSWORD_STORE_DIR="$vstore" pass init $gpg_keys \
          && ok "Store initialized: $vstore" \
          || err "pass init failed — check your GPG key ID"
        printf "  Set up git remote? [y/N] " >&2; read -r yn </dev/tty || yn="n"
        if [ "${yn,,}" = "y" ]; then
          printf "  Git remote SSH URL: " >&2; read -r remote </dev/tty
          if [ -n "${remote:-}" ]; then
            PASSWORD_STORE_DIR="$vstore" pass git init
            PASSWORD_STORE_DIR="$vstore" pass git remote add origin "$remote"
            ok "Git remote: $remote"
          fi
        fi
      fi
      printf "  Switch to this vault now? [y/N] " >&2; read -r yn </dev/tty || yn="n"
      [ "${yn,,}" = "y" ] && cmd_vault switch "$vname" ;;

    switch|activate)
      local vname="${1:-}"
      if [ -z "$vname" ]; then
        local opts; opts="default"
        for f in "$vdir"/*; do [ -f "$f" ] && opts+=$'\n'"$(basename "$f")"; done
        vname="$(printf "%s" "$opts" \
          | _fzf_pick "vault" "Switch to vault" 30%)" || return 0
      fi
      if [ -z "$vname" ] || [ "$vname" = "default" ]; then
        rm -f "$(_active_file)"
        ok "Switched to default vault  (${HOME}/.password-store)"
      else
        [ -f "$vdir/$vname" ] \
          || err "Vault '$vname' not found. List: passx vault list"
        local vstore; vstore="$(_vault_store_dir "$vname")"
        [ -d "${vstore:-}" ] \
          || warn "Store directory missing: $vstore  (run: passx vault add $vname)"
        printf "%s" "$vname" > "$(_active_file)"
        ok "Switched to: ${C_BOLD}${vname}${C_RESET}  (${vstore})"
        dim "Active in new shells. For this shell:"
        dim "  export PASSWORD_STORE_DIR=\"${vstore}\""
      fi
      _invalidate_cache ;;

    env)
      # Print export statements: eval \$(passx vault env) or source <(passx vault env)
      local vname="${1:-$(cat "$(_active_file)" 2>/dev/null || true)}"
      if [ -z "$vname" ]; then
        printf "export PASSWORD_STORE_DIR='%s'\n" "${HOME}/.password-store"
        return 0
      fi
      [ -f "$vdir/$vname" ] || err "Vault '$vname' not found"
      grep "^export " "$vdir/$vname" ;;

    use)
      # One-off: run a passx command in a specific vault without switching
      # Usage: passx vault use VAULTNAME [--] COMMAND [ARGS...]
      local vname="${1:-}"; shift 2>/dev/null || true
      [ -z "$vname" ] \
        && err "Usage: passx vault use <n> [--] <command> [args...]"
      [ "${1:-}" = "--" ] && shift
      [ -z "${1:-}" ] && err "No command specified"
      local vstore
      if [ "$vname" = "default" ]; then
        vstore="${HOME}/.password-store"
      else
        [ -f "$vdir/$vname" ] \
          || err "Vault '$vname' not found. Run: passx vault list"
        vstore="$(_vault_store_dir "$vname")"
        [ -n "${vstore:-}" ] \
          || err "Cannot read PASSWORD_STORE_DIR from: $vdir/$vname"
      fi
      PASSWORD_STORE_DIR="$vstore" exec "$0" "$@" ;;

    rm|remove|delete)
      local vname="${1:-}"
      [ -z "$vname" ] && vname="$(ls "$vdir" 2>/dev/null \
        | _fzf_pick "vault rm" "Select vault to remove" 30%)" || true
      [ -z "${vname:-}" ] && err "No vault selected"
      [ "$vname" = "default" ] && err "Cannot remove the default vault"
      local vstore; vstore="$(_vault_store_dir "$vname")"
      printf "\n  ${C_YELLOW}Remove vault config '%s'?${C_RESET} [y/N]\n" "$vname" >&2
      printf "  ${C_DIM}Store at %s is NOT touched.${C_RESET}\n  " "${vstore:-?}" >&2
      read -r yn </dev/tty || yn=""
      [ "${yn,,}" != "y" ] && { dim "Aborted"; return 0; }
      rm -f "$vdir/$vname"
      local cur; cur="$(cat "$(_active_file)" 2>/dev/null || true)"
      [ "$cur" = "$vname" ] && rm -f "$(_active_file)"
      ok "Vault config '$vname' removed (store files untouched)" ;;

    status)
      _banner "Vault Sync Status"
      local active; active="$(cat "$(_active_file)" 2>/dev/null || echo default)"
      local all; all="default"
      for f in "$vdir"/*; do
        [ -f "$f" ] && all+=" $(basename "$f")"
      done
      for vname in $all; do
        local vstore
        if [ "$vname" = "default" ]; then
          vstore="${HOME}/.password-store"
        else
          vstore="$(_vault_store_dir "$vname")"
        fi
        local bullet; bullet="  "
        [ "$vname" = "$active" ] && bullet="${C_GREEN}▶${C_RESET} "
        printf "  %b${C_BOLD}%-20s${C_RESET}  " "$bullet" "$vname"
        if [ ! -d "${vstore:-}" ]; then
          printf "${C_RED}store missing${C_RESET}\n"
        elif [ -d "${vstore}/.git" ]; then
          local branch ahead behind
          branch="$(cd "$vstore" \
            && git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
          ahead="$(cd "$vstore" \
            && git rev-list --count "@{u}..HEAD" 2>/dev/null || echo '?')"
          behind="$(cd "$vstore" \
            && git rev-list --count "HEAD..@{u}" 2>/dev/null || echo '?')"
          if [ "$ahead" = "?" ]; then
            printf "${C_DIM}%s (no remote)${C_RESET}\n" "$branch"
          elif [ "$ahead" = "0" ] && [ "$behind" = "0" ]; then
            printf "${C_GREEN}%s up to date${C_RESET}\n" "$branch"
          else
            printf "${C_YELLOW}%s  ahead:%s  behind:%s${C_RESET}\n" \
              "$branch" "$ahead" "$behind"
          fi
        else
          printf "${C_DIM}no git${C_RESET}\n"
        fi
      done
      echo "" ;;

    prompt)
      local active; active="$(cat "$(_active_file)" 2>/dev/null || true)"
      [ -n "$active" ] && printf "[%s] " "$active" ;;

    edit)
      local vname="${1:-$(cat "$(_active_file)" 2>/dev/null || true)}"
      [ -z "$vname" ] \
        && err "No active vault. Usage: passx vault edit <name>"
      [ -f "$vdir/$vname" ] || err "Vault '$vname' not found"
      local ed; ed="${EDITOR:-${VISUAL:-vi}}"
      "$ed" "$vdir/$vname" ;;

    --help|-h)
      printf "\n${C_BOLD}passx vault${C_RESET} -- manage multiple password stores\n\n"
      printf "  ${C_BOLD}SUBCOMMANDS${C_RESET}\n"
      printf "    list                 show all vaults\n"
      printf "    add  <name>          create vault + initialize store\n"
      printf "    switch <name>        set active vault (persists)\n"
      printf "    switch default       return to main store\n"
      printf "    use <name> -- <cmd>  run ONE command in vault (no side effects)\n"
      printf "    env [name]           print export statements for current shell\n"
      printf "    rm <name>            remove vault config (store files untouched)\n"
      printf "    status               git sync status for all vaults\n"
      printf "    edit [name]          edit vault config in EDITOR\n"
      printf "    prompt               print [name] for shell PS1\n"
      printf "\n  ${C_BOLD}HOW IT WORKS${C_RESET}\n"
      printf "    Vault config: ~/.config/passx/vaults/NAME\n"
      printf "    Contains:     export PASSWORD_STORE_DIR=/path/to/store\n"
      printf "    Sourced at startup; cleanly sets store for that session.\n"
      printf "\n  ${C_BOLD}EXAMPLES${C_RESET}\n"
      printf "    passx vault add work\n"
      printf "    passx vault switch work\n"
      printf "    passx copy github          # uses work store\n"
      printf "    passx vault use personal -- copy netflix\n"
      printf "    passx vault switch default\n"
      printf "    # Apply in current shell:\n"
      printf "    eval \$(passx vault env work)\n\n"
      ;;

    *) err "Usage: passx vault [list|add|switch|use|env|rm|status|edit|prompt]" ;;
  esac
}



# ════════════════════════════════════════════════════════════════
# § TEAM  — shared vault with multiple GPG recipients
# ════════════════════════════════════════════════════════════════
_team_meta_file() {
  printf "%s/teams/%s" "$PASSX_CONF_DIR" "${1:-default}"
}

cmd_team() {
  _cmd="team"
  local subcmd="${1:-status}"; shift 2>/dev/null || true

  case "$subcmd" in
    init)
      local name="${1:-}"
      [ -z "$name" ] && { printf "  Team vault name: " >&2
        read -r name </dev/tty; }
      [ -z "${name:-}" ] && err "No team name"
      [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] \
        || err "Name must be alphanumeric / dash / underscore"
      local vaults_dir; vaults_dir="$(_vault_dir)"
      [ -f "$vaults_dir/$name" ] \
        && err "A vault named '$name' already exists"
      local tdef="$HOME/.password-store-team-${name}"
      printf "  Store path [%s]: " "$tdef" >&2; read -r tstore </dev/tty
      tstore="${tstore:-$tdef}"; tstore="${tstore/#\~/$HOME}"
      printf "  GPG key IDs (space-separated):\n  > " >&2
      read -r keys </dev/tty
      [ -z "${keys:-}" ] && err "At least one GPG key required"
      local kcount; kcount=$(echo $keys | wc -w)
      mkdir -p "$tstore"
      # shellcheck disable=SC2086
      PASSWORD_STORE_DIR="$tstore" pass init $keys \
        || err "pass init failed -- check your GPG key IDs"
      [ "$kcount" -lt 2 ] \
        && warn "Only 1 key -- for a shared vault you usually want multiple keys"
      printf "  Set up git remote? [Y/n] " >&2; read -r yn </dev/tty || yn="y"
      if [ "${yn,,}" != "n" ]; then
        printf "  Git remote SSH URL: " >&2; read -r remote </dev/tty
        PASSWORD_STORE_DIR="$tstore" pass git init
        if [ -n "${remote:-}" ]; then
          PASSWORD_STORE_DIR="$tstore" pass git remote add origin "$remote"
          ok "Git remote: $remote"
        fi
      fi
      mkdir -p "$PASSX_CONF_DIR/teams"
      {
        printf "# Team: %s  created %s by %s@%s\n" \
          "$name" "$(date '+%Y-%m-%d')" \
          "$USER" "$(hostname -s 2>/dev/null || echo local)"
        for k in $keys; do printf "member=%s\n" "$k"; done
      } > "$(_team_meta_file "$name")"
      mkdir -p "$vaults_dir"
      {
        printf "# passx team vault: %s\n" "$name"
        printf "export PASSWORD_STORE_DIR=\"%s\"\n" "$tstore"
      } > "$vaults_dir/$name"
      ok "Team vault '$name' ready at $tstore"
      printf "\n  Next:\n"
      printf "    passx vault switch %s\n" "$name"
      printf "    passx team add-member <gpg-key-id>   # for each teammate\n\n" ;;

    add-member)
      local keyid="${1:-}"
      [ -z "$keyid" ] && { printf "  New member GPG key ID: " >&2
        read -r keyid </dev/tty; }
      [ -z "${keyid:-}" ] && err "No key ID"
      gpg --list-keys "$keyid" >/dev/null 2>&1 \
        || err "Key not in keyring -- import first: gpg --import pubkey.asc"
      local existing
      existing="$(grep -v '^#' "$PASSWORD_STORE_DIR/.gpg-id" 2>/dev/null \
        | tr '\012' ' ')"
      case "$existing" in
        *"$keyid"*) info "Already a member: $keyid"; return 0 ;;
      esac
      step "Re-encrypting all entries for new member..."
      # shellcheck disable=SC2086
      pass init $existing $keyid || err "Re-encryption failed"
      local active; active="$(cat "$(_active_file)" 2>/dev/null || true)"
      [ -n "$active" ] \
        && printf "member=%s\n" "$keyid" >> "$(_team_meta_file "$active")" \
        || true
      ok "Added: $keyid" ;;

    rm-member)
      local keyid="${1:-}"
      if [ -z "$keyid" ]; then
        local metafile
        metafile="$(_team_meta_file \
          "$(cat "$(_active_file)" 2>/dev/null || echo default)")"
        if [ -f "$metafile" ]; then
          keyid="$(grep '^member=' "$metafile" | cut -d= -f2 \
            | _fzf_pick "rm-member" "Select member to remove" 30%)" \
            || return 0
        else
          printf "  Member GPG key ID to remove: " >&2
          read -r keyid </dev/tty
        fi
      fi
      [ -z "${keyid:-}" ] && err "No key ID"
      local remaining
      remaining="$(grep -v "^${keyid}$" "$PASSWORD_STORE_DIR/.gpg-id" \
        2>/dev/null | grep -v '^#' | tr '\012' ' ' | xargs)"
      [ -z "${remaining:-}" ] && err "Cannot remove the last team member"
      printf "  Remove %s and re-encrypt all entries? [y/N] " "$keyid" >&2
      read -r yn </dev/tty || yn=""
      [ "${yn,,}" != "y" ] && { dim "Aborted"; return 0; }
      step "Re-encrypting without $keyid..."
      # shellcheck disable=SC2086
      pass init $remaining || err "Re-encryption failed"
      ok "Removed: $keyid" ;;

    members)
      _banner "Team Members"
      [ -f "$PASSWORD_STORE_DIR/.gpg-id" ] \
        || err "Not a team vault (.gpg-id missing)"
      while IFS= read -r rid; do
        [ -z "$rid" ] || [[ "$rid" == '#'* ]] && continue
        local uid
        uid="$(gpg --list-keys --with-colons "$rid" 2>/dev/null \
          | awk -F: '/^uid/{print $10; exit}')" \
          || uid="${C_RED}(not in keyring)${C_RESET}"
        printf "  ${C_CYAN}%-42s${C_RESET}  %b\n" "$rid" "$uid"
      done < "$PASSWORD_STORE_DIR/.gpg-id"
      local cnt
      cnt="$(grep -vc '^#' "$PASSWORD_STORE_DIR/.gpg-id" 2>/dev/null \
        || echo 0)"
      echo ""
      dim "$cnt recipient(s) -- every entry is encrypted for all of them" ;;

    log)
      _need_git
      local path="${1:-}"
      _banner "Team Activity"
      if [ -n "$path" ]; then
        cd "$PASSWORD_STORE_DIR" \
          && git log --follow \
               --format="%C(dim)%ai%Creset  %s" -- "${path}.gpg" 2>/dev/null \
          | sed 's/ +[^ ]*//' | sed 's/^/  /'
      else
        cd "$PASSWORD_STORE_DIR" \
          && git log --oneline --color=always -40 \
               --format="%C(dim)%ai%Creset  %C(yellow)%h%Creset  %s" 2>/dev/null \
          | sed 's/ +[^ ]*//' | sed 's/^/  /'
      fi
      echo "" ;;

    audit)
      _banner "Team Audit"
      local not_rotated=0 total=0
      while IFS= read -r e; do
        [ -z "$e" ] && continue
        [[ "$e" == *-pub || "$e" == *-pvt ]] && continue
        total=$((total+1))
        if [ -d "$PASSWORD_STORE_DIR/.git" ]; then
          local lc days
          lc="$(cd "$PASSWORD_STORE_DIR" \
            && git log -1 --format="%ct" -- "${e}.gpg" 2>/dev/null \
            || echo 0)"
          days=$(( ($(date +%s) - ${lc:-0}) / 86400 ))
          [ "$days" -gt "$PASSX_MAX_AGE" ] && {
            not_rotated=$((not_rotated+1))
            printf "  ${C_YELLOW}%4dd${C_RESET}  %s\n" "$days" "$e"
          }
        fi
      done < <(list_entries | grep -v '\-pub$\|-pvt$')
      echo ""
      printf "  %d entries scanned\n" "$total"
      [ $not_rotated -eq 0 ] \
        && ok "All rotated within ${PASSX_MAX_AGE}d" \
        || warn "$not_rotated entries overdue" ;;

    sync)
      _need_git
      step "Pulling..."
      pass git pull && ok "Pulled" || warn "Pull failed"
      step "Pushing..."
      pass git push && ok "Pushed" || warn "Push failed" ;;

    status) cmd_vault status ;;

    --help|-h)
      printf "\n${C_BOLD}passx team${C_RESET} -- shared vault with multiple GPG recipients\n\n"
      printf "  init <n>           create team vault\n"
      printf "  members            list all GPG recipients\n"
      printf "  add-member <key>   add recipient + re-encrypt entire store\n"
      printf "  rm-member [key]    remove recipient + re-encrypt entire store\n"
      printf "  log [path]         git history\n"
      printf "  audit              rotation status\n"
      printf "  sync               git pull + push\n"
      printf "  status             vault sync overview\n\n"
      printf "  A team vault has multiple keys in .gpg-id.\n"
      printf "  Every add/edit/rotate re-encrypts for ALL members.\n\n" ;;

    *) err "Usage: passx team [init|members|add-member|rm-member|log|audit|sync|status]" ;;
  esac
}



# ════════════════════════════════════════════════════════════════
# § OPEN — context-aware smart launch
# ════════════════════════════════════════════════════════════════
cmd_open() {
  _cmd="open"
  local path="${1:-}"
  path="$(_resolve_alias "${path:-}")"
  [ -z "$path" ] && path="$(list_entries_ranked | _fzf_pick "open" "Select entry")" || true
  [ -z "${path:-}" ] && err "No entry"
  local e; e="$(pass show "$path" 2>/dev/null)" || err "Cannot decrypt: $path"
  local url host port db type_field
  url="$(printf "%s\n"        "$e" | grep -m1 "^url:"      | sed "s/^url: *//")"
  host="$(printf "%s\n"       "$e" | grep -m1 "^host:"     | sed "s/^host: *//")"
  port="$(printf "%s\n"       "$e" | grep -m1 "^port:"     | sed "s/^port: *//")"
  db="$(printf "%s\n"         "$e" | grep -m1 "^database:" | sed "s/^database: *//")"
  type_field="$(printf "%s\n" "$e" | grep -m1 "^type:"     | sed "s/^type: *//")"
  # User hook first
  _hook "open-${type_field:-auto}" "$path" 2>/dev/null && return 0 || true
  if   [ -n "$url" ];              then xdg-open "$url" >/dev/null 2>&1 & ok "Opening: $url"
  elif [ -n "$host" ] && [ -n "$db" ]; then cmd_db connect "$path"
  elif [ -n "$host" ];             then
    info "Opening SSH: ${host}"
    local user; user="$(printf "%s\n" "$e" | grep -m1 "^username:" | sed "s/^username: *//") "
    user="${user%% }"
    "${PASSX_SSH_TERMINAL:-xterm}" -e "ssh ${user:+${user}@}${host}${port:+ -p $port}" &
  else
    warn "Cannot determine how to open this entry"
    info "Add a url:, host:, or database: field, or define a hook: $PASSX_HOOKS_DIR/open-TYPE.sh"
  fi
}

# ════════════════════════════════════════════════════════════════
# § CONFIG — interactive config editor
# ════════════════════════════════════════════════════════════════
cmd_config() {
  _cmd="config"
  local conf_file="$PASSX_CONF_DIR/passx.conf"
  case "${1:-interactive}" in
    get)
      [ -z "${2:-}" ] && err "Usage: passx config get <KEY>"
      [ -f "$conf_file" ] \
        && grep -m1 "^${2}=" "$conf_file" | cut -d= -f2- | tr -d '"' \
        || eval "printf \"%s\\n\" \"\${${2}:-}\""
      return 0 ;;
    set)
      [ -z "${2:-}" ] || [ -z "${3:-}" ] && err "Usage: passx config set <KEY> <value>"
      mkdir -p "$PASSX_CONF_DIR"; touch "$conf_file"
      if grep -q "^${2}=" "$conf_file" 2>/dev/null; then
        sed -i "s|^${2}=.*|${2}=\"${3}\"|" "$conf_file"
      else
        printf '%s="%s"\n' "$2" "$3" >> "$conf_file"
      fi
      ok "Set ${2}=\"${3}\""; return 0 ;;
    reset)
      printf "  Delete config and restore defaults? [y/N] " >&2
      read -r yn </dev/tty || yn=""; [ "${yn,,}" != "y" ] && { dim "Aborted"; return 0; }
      rm -f "$conf_file"; ok "Config reset to defaults" ;;
    show)
      [ -f "$conf_file" ] \
        && { _banner "Current Config"; cat "$conf_file" | sed 's/^/  /'; echo ""; } \
        || info "No config file — using all defaults"
      return 0 ;;
    interactive|"")
      command -v fzf >/dev/null 2>&1 || err "fzf required"
      local -a vars=(
        "PASSX_AUTOSYNC:Auto-push to git after writes (true/false)"
        "PASSX_CLIP_TIMEOUT:Clipboard auto-clear timeout (seconds)"
        "PASSX_MAX_AGE:Password age warning threshold (days)"
        "PASSX_NOTIFY:Desktop notifications (true/false)"
        "PASSX_THEME:Color theme (catppuccin/nord/gruvbox/dracula/solarized)"
        "PASSX_GEN_LENGTH:Default generated password length"
        "PASSX_GEN_CHARS:Generated password character set"
        "PASSX_FRECENCY:Frecency-ranked pickers (true/false)"
        "PASSX_WARN_STALE:Warn when copying stale password (true/false)"
        "PASSX_AUTOFILL_DELAY:Autofill countdown seconds"
        "PASSX_PARALLEL_JOBS:Parallel GPG jobs for audit/search"
        "PASSX_TOMBSTONE:Record deletions (true/false)"
        "PASSX_DB_CLIENT:Database client (auto/pgcli/psql/mycli/...)"
        "PASSX_COLOR:Color output (auto/always/never)"
        "PASSX_DEBUG:Debug logging (0/1)"
      )
      local menu_items=""
      for item in "${vars[@]}"; do
        local key="${item%%:*}" desc="${item#*:}"
        local current; current="$(eval "printf \"%s\" \"\${$key:-}\"")"
        menu_items+="$(printf "%-32s  %-38s  %s\n" "$key" "$desc" "${current:-(default)}")"$'\n'
      done
      local chosen; chosen="$(printf "%s" "$menu_items" | _fzf_pick "config" "Select variable to edit" 60%)" || return 0
      [ -z "${chosen:-}" ] && return 0
      local chosen_key; chosen_key="$(printf "%s" "$chosen" | awk '{print $1}')"
      local cur_val; cur_val="$(eval "printf \"%s\" \"\${$chosen_key:-}\"")"
      printf "  %s" "$chosen_key" >&2
      [ -n "$cur_val" ] && printf " [current: %s]" "$cur_val" >&2
      printf " = " >&2; read -r new_val </dev/tty || new_val=""
      [ -z "${new_val:-}" ] && { dim "Unchanged"; return 0; }
      cmd_config set "$chosen_key" "$new_val" ;;
    --help|-h) printf "\n${C_BOLD}passx config${C_RESET} [get|set|reset|show|interactive]\n\n"
      printf "  ${C_DIM}Examples:${C_RESET}\n"
      printf "    passx config                          # interactive editor\n"
      printf "    passx config get PASSX_CLIP_TIMEOUT  # print value\n"
      printf "    passx config set PASSX_CLIP_TIMEOUT 30\n"
      printf "    passx config show                     # all current values\n\n" ;;
    *) err "Usage: passx config [get|set|reset|show|interactive]" ;;
  esac
}

# ════════════════════════════════════════════════════════════════
# § SETUP WIZARD  (passx setup [gpg|store|keys|git|config|comp|check])
# ════════════════════════════════════════════════════════════════
_setup_pm() {
  command -v apt-get >/dev/null 2>&1 && { printf "apt";    return; }
  command -v pacman  >/dev/null 2>&1 && { printf "pacman"; return; }
  command -v dnf     >/dev/null 2>&1 && { printf "dnf";    return; }
  command -v zypper  >/dev/null 2>&1 && { printf "zypper"; return; }
  command -v brew    >/dev/null 2>&1 && { printf "brew";   return; }
  printf "unknown"
}

_setup_pkg_name() {
  local PM="$1" tool="$2"
  case "$PM" in
    apt)    case "$tool" in gpg) echo gnupg;; oathtool) echo oathtool;; zbarimg) echo zbar-tools;;
              notify-send) echo libnotify-bin;; wl-clipboard) echo wl-clipboard;; *) echo "$tool";; esac ;;
    pacman) case "$tool" in gpg) echo gnupg;; oathtool) echo oath-toolkit;; zbarimg) echo zbar;;
              notify-send) echo libnotify;; *) echo "$tool";; esac ;;
    *) echo "$tool" ;;
  esac
}

_setup_install_pkg() {
  local PM="$1" tool="$2" label="${3:-$2}"
  local pkg; pkg="$(_setup_pkg_name "$PM" "$tool")"
  [ -z "$pkg" ] && { dim "  skipping $label (n/a on $PM)"; return 0; }
  step "Installing $label..."
  case "$PM" in
    apt)    sudo apt-get install -y "$pkg" >/dev/null 2>&1 && ok "$label installed" || warn "Failed: $label" ;;
    pacman) sudo pacman -S --noconfirm "$pkg" >/dev/null 2>&1 && ok "$label installed" || warn "Failed: $label" ;;
    dnf)    sudo dnf install -y "$pkg" >/dev/null 2>&1 && ok "$label installed" || warn "Failed: $label" ;;
    zypper) sudo zypper install -y "$pkg" >/dev/null 2>&1 && ok "$label installed" || warn "Failed: $label" ;;
    brew)   brew install "$pkg" >/dev/null 2>&1 && ok "$label installed" || warn "Failed: $label" ;;
    *)      warn "Cannot auto-install $label — install it manually" ;;
  esac
}


_setup_deps() {
  _banner "Step 1 — Dependencies"
  local -a required=(pass gpg git curl)
  local -a optional=(fzf xdotool oathtool qrencode zbarimg wl-clipboard xclip notify-send sshpass jq bat)
  local missing_req=(); local missing_opt=()
  for t in "${required[@]}"; do command -v "$t" >/dev/null 2>&1 || missing_req+=("$t"); done
  for t in "${optional[@]}"; do command -v "$t" >/dev/null 2>&1 || missing_opt+=("$t"); done
  if [ ${#missing_req[@]} -eq 0 ]; then ok "All required tools present"
  else
    warn "Missing required: ${missing_req[*]}"
    [ "$PM" = "unknown" ] && err "Cannot auto-install — install manually: ${missing_req[*]}"
    for t in "${missing_req[@]}"; do _setup_install_pkg "$PM" "$t"; done
    for t in "${required[@]}"; do
      command -v "$t" >/dev/null 2>&1 || err "$t still missing after install"
    done
  fi
  if [ ${#missing_opt[@]} -gt 0 ]; then
    printf "\n  ${C_YELLOW}Optional tools not installed:${C_RESET}\n"
    for t in "${missing_opt[@]}"; do printf "    ${C_DIM}%s${C_RESET}\n" "$t"; done
    printf "\n  Install optional tools? [y/N] " >&2; read -r yn </dev/tty || yn=""
    [ "${yn,,}" = "y" ] && for t in "${missing_opt[@]}"; do _setup_install_pkg "$PM" "$t"; done
  else ok "All optional tools present"; fi
}

_setup_gpg() {
  _banner "Step 2 — GPG Key"
  printf "  ${C_DIM}pass encrypts every entry with your GPG key.${C_RESET}\n\n"
  local -a fprs=(); local -a uids=()
  while IFS=: read -r fpr uid; do fprs+=("$fpr"); uids+=("$uid"); done < <(
    gpg --list-secret-keys --with-colons 2>/dev/null \
      | awk -F: '/^sec/{f=""}/^fpr/{if(!f)f=$10}/^uid/{if(!u)u=$10}/^ssb/{if(f&&u){print f":"u;f="";u=""}}' 2>/dev/null || true
  )
  if [ ${#fprs[@]} -gt 0 ]; then
    printf "  ${C_GREEN}Existing GPG keys:${C_RESET}\n\n"
    for i in "${!fprs[@]}"; do
      printf "    ${C_CYAN}[%d]${C_RESET}  %s  ${C_DIM}(%s)${C_RESET}\n" \
        $((i+1)) "${uids[$i]}" "${fprs[$i]: -16}"
    done; printf "\n"
    printf "  Use existing [number] or [n]ew or [s]kip: " >&2; read -r choice </dev/tty || choice="s"
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#fprs[@]}" ]; then
      info "Using: ${uids[$((choice-1))]}"
      printf "%s" "${fprs[$((choice-1))]}" > "$PASSX_CACHE_DIR/setup_gpg_key"
    elif [ "${choice,,}" = "n" ]; then _setup_create_gpg_key
    else info "Skipping GPG setup"
    fi
  else
    printf "  No GPG keys found.\n"
    printf "  Create a new key? [Y/n] " >&2; read -r yn </dev/tty || yn="y"
    [ "${yn,,}" != "n" ] && _setup_create_gpg_key || info "Skipping"
  fi
}

_setup_create_gpg_key() {
  local name email
  printf "  Your name: " >&2; read -r name </dev/tty
  printf "  Your email: " >&2; read -r email </dev/tty
  [[ "$email" == *@* ]] || err "Invalid email"
  local _stty; _stty="$(stty -g </dev/tty 2>/dev/null || true)"
  printf "  Passphrase (Enter for none): " >&2
  stty -echo </dev/tty 2>/dev/null || true; read -r gpg_pass </dev/tty || gpg_pass=""
  [ -n "$_stty" ] && stty "$_stty" </dev/tty 2>/dev/null || true; printf "\n" >&2
  mkdir -p "$HOME/.gnupg"; chmod 700 "$HOME/.gnupg"
  touch "$HOME/.gnupg/gpg-agent.conf"
  grep -q "allow-loopback-pinentry" "$HOME/.gnupg/gpg-agent.conf" 2>/dev/null \
    || printf "allow-loopback-pinentry\n" >> "$HOME/.gnupg/gpg-agent.conf"
  gpgconf --kill gpg-agent 2>/dev/null || true; sleep 0.4
  export GPG_TTY; GPG_TTY="$(tty 2>/dev/null)" || GPG_TTY=""
  local batch; batch="$(mktemp)"; chmod 600 "$batch"
  if [ -n "$gpg_pass" ]; then
    printf "Key-Type: EDDSA\nKey-Curve: ed25519\nSubkey-Type: ECDH\nSubkey-Curve: cv25519\nName-Real: %s\nName-Email: %s\nExpire-Date: 2y\nPassphrase: %s\n%%commit\n" \
      "$name" "$email" "$gpg_pass" > "$batch"
  else
    printf "Key-Type: EDDSA\nKey-Curve: ed25519\nSubkey-Type: ECDH\nSubkey-Curve: cv25519\nName-Real: %s\nName-Email: %s\nExpire-Date: 2y\n%%no-protection\n%%commit\n" \
      "$name" "$email" > "$batch"
  fi
  step "Generating Ed25519 key..."
  gpg --batch --pinentry-mode loopback --gen-key "$batch" 2>/dev/null; rm -f "$batch"
  local fpr; fpr="$(gpg --list-secret-keys --with-colons "$email" 2>/dev/null \
    | awk -F: '/^fpr/{print $10;exit}')"
  [ -n "${fpr:-}" ] || err "Key created but fingerprint not found"
  ok "Key created: ${fpr: -16}"
  printf "%s" "$fpr" > "$PASSX_CACHE_DIR/setup_gpg_key"
  info "Backup: gpg --export-secret-keys --armor $fpr > passx-key-backup.asc"
}

_setup_store() {
  _banner "Step 3 — Password Store"
  local gpg_key; gpg_key="$(cat "$PASSX_CACHE_DIR/setup_gpg_key" 2>/dev/null || true)"
  if [ -f "$PASSWORD_STORE_DIR/.gpg-id" ]; then
    info "Store already exists at $PASSWORD_STORE_DIR"
    [ -n "$gpg_key" ] && {
      local existing; existing="$(head -1 "$PASSWORD_STORE_DIR/.gpg-id")"
      [ "$existing" != "$gpg_key" ] && {
        printf "  Re-init with new key? [y/N] " >&2; read -r yn </dev/tty || yn=""
        [ "${yn,,}" = "y" ] && pass init "$gpg_key" && ok "Store re-initialized"
      }
    }
  else
    printf "\n  1) Clone existing git repo  2) Start fresh  3) Skip\n  Choice: " >&2
    read -r choice </dev/tty || choice="3"
    case "$choice" in
      1)
        printf "  Git SSH URL: " >&2; read -r git_url </dev/tty
        [ -z "${git_url:-}" ] && { warn "No URL, skipping"; return 0; }
        [ -d "$PASSWORD_STORE_DIR" ] && rm -rf "$PASSWORD_STORE_DIR"
        git clone "$git_url" "$PASSWORD_STORE_DIR" && ok "Cloned to $PASSWORD_STORE_DIR" \
          || err "Clone failed — check SSH key and URL" ;;
      2)
        [ -n "$gpg_key" ] && {
          pass init "$gpg_key" && ok "Store initialized at $PASSWORD_STORE_DIR"
        } || warn "No GPG key selected — run: pass init <key-id>" ;;
      *) info "Skipping store setup" ;;
    esac
  fi
  # Git remote setup
  if [ -d "$PASSWORD_STORE_DIR" ] && [ ! -d "$PASSWORD_STORE_DIR/.git" ]; then
    printf "\n  Initialize git in store? [y/N] " >&2; read -r yn </dev/tty || yn=""
    [ "${yn,,}" = "y" ] && pass git init && ok "git initialized"
  fi
  if [ -d "$PASSWORD_STORE_DIR/.git" ]; then
    local remote; remote="$(cd "$PASSWORD_STORE_DIR" && git remote get-url origin 2>/dev/null || true)"
    [ -z "$remote" ] && {
      printf "  Add git remote? [y/N] " >&2; read -r yn </dev/tty || yn=""
      [ "${yn,,}" = "y" ] && {
        printf "  SSH URL: " >&2; read -r rurl </dev/tty
        [ -n "${rurl:-}" ] && {
          pass git remote add origin "$rurl"
          printf "  Push now? [y/N] " >&2; read -r yn </dev/tty || yn=""
          [ "${yn,,}" = "y" ] && pass git push -u origin master 2>/dev/null \
            || pass git push -u origin main 2>/dev/null || warn "Push failed"
        }
      }
    }
  fi
}

_setup_git_identity() {
  _banner "Step 4 — Git Identity"
  printf "  ${C_DIM}pass commits every change. Git needs a name + email.${C_RESET}\n\n"
  local gname; gname="$(git config --global user.name  2>/dev/null || true)"
  local gemail; gemail="$(git config --global user.email 2>/dev/null || true)"
  if [ -n "$gname" ] && [ -n "$gemail" ]; then
    ok "Git identity already set: $gname <$gemail>"
  else
    [ -z "$gname"  ] && { printf "  Name:  " >&2; read -r gname  </dev/tty; }
    [ -z "$gemail" ] && { printf "  Email: " >&2; read -r gemail </dev/tty; }
    [ -n "$gname"  ] && git config --global user.name  "$gname"
    [ -n "$gemail" ] && git config --global user.email "$gemail"
    ok "Git identity saved: $gname <$gemail>"
  fi
}

_setup_config_step() {
  _banner "Step 5 — Configuration"
  local conf="$PASSX_CONF_DIR/passx.conf"
  if [ -f "$conf" ]; then dim "Config already exists: $conf"
  else cmd_gen_conf; fi
}

_setup_completions_step() {
  _banner "Step 6 — Shell Completions"
  local shell; shell="$(basename "${SHELL:-bash}")"
  info "Shell: $shell"
  case "$shell" in
    zsh)
      local zdir="${HOME}/.local/share/zsh/site-functions"; mkdir -p "$zdir"
      "$0" completions zsh > "$zdir/_passx" 2>/dev/null && ok "zsh completions: $zdir/_passx"
      local rc="$HOME/.zshrc"
      grep -q "passx.*site-functions" "$rc" 2>/dev/null || {
        printf '\n# passx completions\nfpath=($HOME/.local/share/zsh/site-functions $fpath)\nautoload -Uz compinit && compinit\n' >> "$rc"
        ok "fpath updated in $rc"
      }
      grep -q "source <(passx completions zsh)" "$rc" 2>/dev/null && {
        sed -i '/source <(passx completions zsh)/d' "$rc"
        dim "Removed old broken source <() line"
      } ;;
    bash)
      local bdir="${HOME}/.local/share/bash-completion/completions"; mkdir -p "$bdir"
      "$0" completions bash > "$bdir/passx" 2>/dev/null && ok "bash completions: $bdir/passx" ;;
    fish)
      local fdir="${XDG_CONFIG_HOME:-$HOME/.config}/fish/completions"; mkdir -p "$fdir"
      "$0" completions fish > "$fdir/passx.fish" 2>/dev/null && ok "fish completions: $fdir/passx.fish" ;;
    *) warn "Unknown shell '$shell' — run: passx completions bash|zsh|fish" ;;
  esac
}

_setup_check() {
  _banner "Setup Check"
  "$0" doctor
}

cmd_setup() {
  _cmd="setup"
  local subcmd="${1:-all}"; shift 2>/dev/null || true
  local PM; PM="$(_setup_pm)"
  info "Package manager: ${PM}"

  case "$subcmd" in
    all)
      _setup_deps
      _setup_gpg
      _setup_store
      _setup_git_identity
      _setup_config_step
      _setup_completions_step
      _banner "Setup Complete"
      printf "  ${C_BOLD}Quick start:${C_RESET}\n\n"
      printf "    ${C_CYAN}passx doctor${C_RESET}                      # verify everything\n"
      printf "    ${C_CYAN}passx add github user@mail.com${C_RESET}    # first entry\n"
      printf "    ${C_CYAN}passx show${C_RESET}                         # interactive picker\n"
      printf "    ${C_CYAN}passx --help${C_RESET}                       # all commands\n\n"
      info "Restart your shell to activate completions." ;;
    deps)         _setup_deps ;;
    gpg)          _setup_gpg ;;
    store)        _setup_store ;;
    git)          _setup_git_identity ;;
    config)       _setup_config_step ;;
    comp|completions) _setup_completions_step ;;
    check)        _setup_check ;;
    --help|-h)
      printf "\n${C_BOLD}passx setup${C_RESET} [all|deps|gpg|store|git|config|comp|check]\n\n"
      printf "  Full interactive setup wizard. Each step is idempotent — safe to re-run.\n\n"
      printf "  ${C_DIM}Subcommands:${C_RESET}\n"
      printf "    all    — full wizard (default)\n    deps   — install dependencies\n"
      printf "    gpg    — GPG key setup\n    store  — password store + git remote\n"
      printf "    git    — git identity (name + email)\n    config — generate passx.conf\n"
      printf "    comp   — shell completions\n    check  — run doctor\n\n" ;;
    *) err "Usage: passx setup [all|deps|gpg|store|git|config|comp|check]" ;;
  esac
}


# ════════════════════════════════════════════════════════════════
# § EXPORT-AGE
# ════════════════════════════════════════════════════════════════
cmd_export_age() {
  _cmd="export-age"
  local out="${1:-}"; [ -z "$out" ] && err "Usage: passx export-age <file.tar.age>"
  command -v age >/dev/null 2>&1 || err "age not installed — see: https://age-encryption.org"
  _banner "Export with age encryption"
  local tmp; tmp="$(mktemp -d)"
  step "Archiving..."
  tar -C "$(dirname "$PASSWORD_STORE_DIR")" -czf "$tmp/store.tar.gz" \
    "$(basename "$PASSWORD_STORE_DIR")" || { rm -rf "$tmp"; err "tar failed"; }
  step "Encrypting with age passphrase..."
  age -p -o "$out" "$tmp/store.tar.gz" || { rm -rf "$tmp"; err "age encryption failed"; }
  rm -rf "$tmp"
  [ -s "$out" ] || err "Output file is empty"
  ok "age-encrypted export → $out"
  dim "Restore: age -d $out | tar -xz -C ~"
}

