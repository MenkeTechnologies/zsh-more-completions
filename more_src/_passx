#compdef passx
# Documentation: https://github.com/mtdb/passx
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_passx() {
    local curcontext="$curcontext" state line
    local -a commands

    commands=(
        'append:add new key/value pair to a password file'
        'show:display password entry (optional clipboard copy)'
        'edit:modify existing key values'
    )

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            _describe -t commands 'passx command' commands
            ;;
        args)
            case $line[1] in
                show)
                    _arguments \
                        '-c[copy field value to clipboard]' \
                        '*:pass entry:_files'
                    ;;
                append|edit)
                    _arguments '*:pass entry:_files'
                    ;;
            esac
            ;;
    esac
}

_passx "$@"
