(( $+functions[_rigg_commands] )) ||
_rigg_commands() {
    local commands; commands=(
'init:Initialize a new rigg project for Azure AI Search and/or Foundry' \
'config:View and modify project configuration (rigg.yaml)' \
'env:Manage deployment environments' \
'auth:Manage Azure authentication' \
'pull:Download resource definitions from Azure to local JSON files' \
'push:Upload local JSON files to Azure, creating or updating resources' \
'new:Create a new resource file from a template (no network calls)' \
'copy:Copy a resource locally under a new name (no network calls)' \
'delete:Delete a resource from Azure or remove local files' \
'diff:Compare local resource files against the live Azure service' \
'validate:Validate local JSON files for structural and referential integrity' \
'pull-watch:Poll the server for changes and pull updates automatically' \
'describe:Show a unified summary of all local resource definitions' \
'status:Show sync status and local resource summary' \
'completion:Generate shell completions for bash, zsh, fish, or PowerShell' \
'version:Show version information' \
'ai:Manage AI features (shows status when run without a subcommand)' \
'mcp:MCP (Model Context Protocol) server for AI agent integration' \
'logo:🏗️' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'rigg commands' commands "$@"
}
