#compdef dh_apparmor
# _dh_apparmor — debhelper to install AppArmor profiles (Debian/apparmor)
# upstream: https://gitlab.com/apparmor/apparmor
# Flags from dh_apparmor(1) man page.

_dh_apparmor() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--profile-name=[AppArmor profile name]:name:' \
        '--manifest=[manifest file (calls aa-easyprof)]:file:_files' \
        '*-p+[act on this package]:package:' \
        '*-N+[skip this package]:package:'
}

_dh_apparmor "$@"
