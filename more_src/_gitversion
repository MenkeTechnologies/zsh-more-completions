#compdef gitversion dotnet-gitversion

_arguments -s \
  '/version[show version]' \
  '/h[show help]' \
  '/?[show help]' \
  '/help[show help]' \
  '/diag[show diagnostic info]' \
  '/l=[log file or console]:dest:' \
  '*/output=[output format]:format:(json file buildserver dotenv)' \
  '/outputfile=[output file]:file:_files' \
  '/showvariable=[show single variable]:name:' \
  '/format=[format string]:format:' \
  '/config=[config file]:file:_files -g "*.(yml|yaml)"' \
  '/showconfig[show effective config]' \
  '/overrideconfig=[override config key=value]:override:' \
  '/nocache[do not cache]' \
  '/nofetch[do not fetch]' \
  '/nonormalize[do not normalize]' \
  '/allowshallow[allow shallow clones]' \
  '/verbosity=[verbosity]:level:(Quiet Minimal Normal Verbose Diagnostic)' \
  '/updateassemblyinfo=[update AssemblyInfo files]:files:_files' \
  '/updateprojectfiles[update project files]' \
  '/ensureassemblyinfo[ensure AssemblyInfo exists]' \
  '/updatewixversionfile[update WiX version file]' \
  '/targetpath=[target path]:dir:_files -/' \
  '/url=[remote URL]:url:' \
  '/b=[branch]:branch:' \
  '/u=[user]:user:_users' \
  '/p=[password]:password:' \
  '/c=[commit-ish]:commit:' \
  '/dynamicRepoLocation=[dynamic repo location]:dir:_files -/' \
  ':path:_files -/'
