#compdef pypistats
# _pypistats — query PyPI download statistics (hugovk/pypistats)
# upstream: https://github.com/hugovk/pypistats
# Subcommands from src/pypistats/cli.py (argparse subparsers).

_pypistats() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'recent:recent downloads (last day/week/month)'
                'overall:overall download counts (with/without mirrors)'
                'python_major:downloads broken down by Python major version'
                'python_minor:downloads broken down by Python minor version'
                'system:downloads broken down by OS'
            )
            _describe -t commands command cmds
            ;;
        args)
            _arguments \
                '(-p --period)'{-p+,--period=}'[time period]:period:(day week month)' \
                '(-f --format)'{-f+,--format=}'[output format]:fmt:(html json markdown rst tsv pretty)' \
                '(-j --json)'{-j,--json}'[output JSON]' \
                '-d+[start date YYYY-MM-DD]:date:' \
                '-e+[end date YYYY-MM-DD]:date:' \
                '-m+[month YYYY-MM (or name)]:month:' \
                '-l+[last N months]:n:' \
                '--mirrors=[show mirrors-only or all]:mode:(true false)' \
                '-t[total]' \
                '-T[no total]' \
                '1:package:'
            ;;
    esac
}

_pypistats "$@"
