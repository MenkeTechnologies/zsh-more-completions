#compdef sfrtm
# Documentation: http://www.ahay.org/RSF/sfrtm.html
# Madagascar: Rice HPCSS reverse time migration

local ret=1

_arguments -s \
  'source=[source wavelet input file]:file:_files' \
  'receiver=[receiver data input file]:file:_files' \
  'nt=[number of time steps]:nt' \
  'dt=[time step]:dt' \
  'nm=[number of image samples]:nm' \
  'isz=[source z index]:isz' \
  'isxbeg=[first source x index]:isxbeg' \
  'isxend=[last source x index]:isxend' \
  'iskip=[source x index increment]:iskip' \
  'igz=[receiver z index]:igz' \
  'igxbeg=[first receiver x index]:igxbeg' \
  'igxend=[last receiver x index]:igxend' \
  'fpeak=[peak frequency of source wavelet]:fpeak' \
  'ihmax=[max horizontal subsurface offset index]:ihmax' \
  'imbeg=[first image x index]:imbeg' \
  'imend=[last image x index]:imend' \
  'imskip=[image x index increment]:imskip' \
  '*:rsf file:_files' && ret=0

return ret
