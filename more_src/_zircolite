#compdef zircolite
# Documentation: https://github.com/wagga40/Zircolite (zircolite.py argparse)
# Reference accessed: 2026-05-29
# Sigma-based detection of compromise on EVTX/JSON/Auditd/Sysmon logs.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-e --evtx --events)'{-e,--evtx,--events=}'[path to log file or directory]:path:_files' \
  '(-s --select)'{-s,--select=}'[process only files matching string]:pattern:' \
  '(-a --avoid)'{-a,--avoid=}'[skip files matching string]:pattern:' \
  '(-f --fileext)'{-f,--fileext=}'[file extension of log files]:ext:' \
  '(-fp --file-pattern)'{-fp,--file-pattern=}'[glob pattern for file selection]:glob:' \
  '--no-recursion[search only in specified directory]' \
  '--archive-password=[password for encrypted archives]:password:' \
  '(-A --after)'{-A,--after=}'[process events after timestamp (UTC)]:timestamp:' \
  '(-B --before)'{-B,--before=}'[process events before timestamp (UTC)]:timestamp:' \
  '--no-event-filter[disable early event filtering]' \
  '(-j --json-input --json-array-input -D --db-input -S --sysmon-linux-input -AU --auditd-input -x --xml-input --evtxtract-input --csv-input)'{-j,--json-input}'[JSON lines format input]' \
  '(-j --json-input --json-array-input -D --db-input -S --sysmon-linux-input -AU --auditd-input -x --xml-input --evtxtract-input --csv-input)--json-array-input[JSON array format input]' \
  '(-j --json-input --json-array-input -D --db-input -S --sysmon-linux-input -AU --auditd-input -x --xml-input --evtxtract-input --csv-input)'{-D,--db-input}'[use saved database file]' \
  '(-j --json-input --json-array-input -D --db-input -S --sysmon-linux-input -AU --auditd-input -x --xml-input --evtxtract-input --csv-input)'{-S,--sysmon-linux-input}'[Sysmon for Linux logs]' \
  '(-j --json-input --json-array-input -D --db-input -S --sysmon-linux-input -AU --auditd-input -x --xml-input --evtxtract-input --csv-input)'{-AU,--auditd-input}'[Auditd logs]' \
  '(-j --json-input --json-array-input -D --db-input -S --sysmon-linux-input -AU --auditd-input -x --xml-input --evtxtract-input --csv-input)'{-x,--xml-input}'[EVTX converted to XML]' \
  '(-j --json-input --json-array-input -D --db-input -S --sysmon-linux-input -AU --auditd-input -x --xml-input --evtxtract-input --csv-input)--evtxtract-input[EVTXtract extracted logs]' \
  '(-j --json-input --json-array-input -D --db-input -S --sysmon-linux-input -AU --auditd-input -x --xml-input --evtxtract-input --csv-input)--csv-input[CSV format logs]' \
  '*'{-r,--ruleset=}'[Sigma ruleset JSON or YAML]:file:_files -g "*.(json|yaml|yml)"' \
  '(-sr --save-ruleset)'{-sr,--save-ruleset=}'[save converted ruleset]:file:_files' \
  '(-p --pipeline)'{-p,--pipeline=}'[pipeline for native Sigma rulesets]:pipeline:' \
  '(-pl --pipeline-list)'{-pl,--pipeline-list}'[list installed pipelines]' \
  '*'{-R,--rulefilter=}'[remove rules by title match]:pattern:' \
  '--test-rules=[JSON file with rule test cases]:file:_files -g "*.json"' \
  '(-o --outfile)'{-o,--outfile=}'[output file for detections]:file:_files' \
  '--csv[CSV output format]' \
  '--csv-delimiter=[CSV delimiter character]:char:' \
  '--keepflat[save flattened events as JSON]' \
  '--profile-rules[time rule execution]' \
  '(-d --dbfile)'{-d,--dbfile=}'[save logs to SQLite database]:file:_files' \
  '(-l --logfile)'{-l,--logfile=}'[log file name]:file:_files' \
  '--hashes[add xxhash64 to events]' \
  '(-L --limit)'{-L,--limit=}'[discard results exceeding limit]:n:' \
  '(-c --config)'{-c,--config=}'[field mappings and exclusions file]:file:_files' \
  '(-LE --logs-encoding)'{-LE,--logs-encoding=}'[log file encoding]:encoding:(utf-8 utf-16 latin-1 cp1252)' \
  '(-q --quiet)'{-q,--quiet}'[suppress banner and progress]' \
  '--debug[enable debug logging]' \
  '(-n --nolog)'{-n,--nolog}'[do not create output files]' \
  '(-RE --remove-events)'{-RE,--remove-events}'[delete processed files]' \
  '(-U --update-rules)'{-U,--update-rules}'[update rulesets]' \
  '--timefield=[specify time field name]:field:' \
  '--unified-db[single database for all files]' \
  '--no-auto-mode[disable automatic mode selection]' \
  '--no-auto-detect[disable log type detection]' \
  '--strict[strict EVTX parsing]' \
  '--add-index[create database index]' \
  '--remove-index[drop index]' \
  '--auto-index[auto-create indices on top columns]' \
  '--all-transforms[enable all transforms]' \
  '*--transform-category=[enable transforms by category]:category:' \
  '--transform-list[list categories and exit]' \
  '(-Y --yaml-config)'{-Y,--yaml-config=}'[YAML configuration file]:file:_files -g "*.(yaml|yml)"' \
  '--generate-config[generate default config file]' \
  '(-P --no-parallel)'{-P,--no-parallel}'[disable parallel processing]' \
  '(-w --parallel-workers)'{-w,--parallel-workers=}'[maximum parallel workers]:n:' \
  '--parallel-memory-limit=[memory threshold percentage]:pct:' \
  '(-t --template)'{-t,--template=}'[Jinja2 template]:file:_files -g "*.j2"' \
  '(-T --templateOutput)'{-T,--templateOutput=}'[template output file]:file:_files' \
  '--template-append[append to template output]' \
  '--timesketch[Timesketch template shortcut]' \
  '--navigator-output=[ATT&CK Navigator output]:file:_files' \
  '(-G --package)'{-G,--package}'[create ZircoGui package]' \
  '--package-dir=[package directory]:dir:_directories' && ret=0

return ret
