#compdef release-it-cli
# Documentation: https://man.archlinux.org/search?q=release-it-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

(( $+functions[_release-it] )) || autoload -Uz _release-it 2>/dev/null
if (( $+functions[_release-it] )); then
  _release-it "$@"
  return
fi

_arguments \
  '*::release-it arg:_files' && ret=0

return ret
