  '(-output -ou -OutputFile)'{-output,-ou,-OutputFile}'[Output file for transformed volume]:file:_files' \
  '(-inverse -inv -InverseFile)'{-inverse,-inv,-InverseFile}'[Output file in which to write the inverse of the combined...]:file:_files' \
  '(-tempdir -t -TemporaryDirectory)'{-tempdir,-t,-TemporaryDirectory}'[Directory to use for temporary files. The default is that...]:value' \
  '(-size -s -OutputSizeXYZ)'{-size,-s,-OutputSizeXYZ}'[X, Y, Z dimensions of the output file (Default is size of...]:value' \
  '(-center -ce -CenterXYZ)'{-center,-ce,-CenterXYZ}'[X, Y, Z index coordinates of the center of the region to...]:value' \
  '(-xffile -x -TransformFile)'{-xffile,-x,-TransformFile}'[Name of file with 3D transform to apply. Multiple transforms]:file:_files' \
  '(-3dxform -3 -3DTransform)'{-3dxform,-3,-3DTransform}'[Multiple floats]' \
