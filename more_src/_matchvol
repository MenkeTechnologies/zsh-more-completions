  '(-chunk -ch -ChunkSizesForHDF)'{-chunk,-ch,-ChunkSizesForHDF}'[Size of chunks in X, Y, and Z for output to an HDF file...]:value' \
  '(-memory -m -MemoryLimit)'{-memory,-m,-MemoryLimit}'[Amount of memory to allocate for the major arrays needed by...]:value' \
  '(-verbose -v -VerboseOutput)'{-verbose,-v,-VerboseOutput}'[1 for diagnostic output]:value' \
  '(-param -p -ParameterFile)'{-param,-p,-ParameterFile}'[Parameter file]' \
  '-StandardInput[read parameters from standard input]' \
