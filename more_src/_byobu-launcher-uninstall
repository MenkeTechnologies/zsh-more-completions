#compdef byobu-launcher-uninstall
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/byobu-launcher-uninstall.1.html
# byobu: remove the byobu launcher from a shell profile file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:profile file:_files' && ret=0

return ret
