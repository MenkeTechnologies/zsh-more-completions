#compdef ansible-navigator

_ansible-navigator_subcommands() {
  local -a subcmds=(
    'collections:Explore available collections'
    'config:Explore the current Ansible configuration'
    'doc:Review documentation for a module or plugin'
    'exec:Run a command within an execution environment'
    'images:Explore execution environment images'
    'inventory:Explore an inventory'
    'lint:Lint a file or directory'
    'log:Review the current log file'
    'open:Open current page in the editor'
    'quit:Quit the application'
    'replay:Explore a previous run using a playbook artifact'
    'run:Run a playbook'
    'settings:Review the current ansible-navigator settings'
    'welcome:Start at the welcome page'
  )
  _describe -t commands 'ansible-navigator subcommand' subcmds
}

_ansible-navigator() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '--version[Show version]' \
    '--rad[Enable log to file]' \
    '--rac[Specify the path to the ansible.cfg file]:file:_files' \
    '--rt[Specify the run-time timeout]:timeout:' \
    '--ce[Use container engine]:engine:(auto podman docker)' \
    '--co[Extra parameters for the container engine command]:options:' \
    '--dc[Disable playbook artifact creation]' \
    '--ecmd[Specify the editor command]:command:' \
    '--econ[Specify the editor console]:console:(true false)' \
    '--ee[Enable or disable execution environment]:toggle:(true false)' \
    '--eei[Specify the execution environment image]:image:' \
    '--la[Specify the log append mode]:mode:(true false)' \
    '--lf[Specify the log file]:file:_files' \
    '--ll[Specify the log level]:level:(debug info warning error critical)' \
    '--m[Specify the user-interface mode]:mode:(stdout interactive)' \
    '--pa[Specify the playbook artifact file]:file:_files' \
    '--penv[Specify environment variables to pass]:vars:' \
    '--pp[Specify the pull policy for the EE image]:policy:(always missing never tag)' \
    '--senv[Specify environment variables to set]:vars:' \
    '1:subcommand:_ansible-navigator_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      _files
      ;;
  esac
}

_ansible-navigator "$@"
