#compdef pngout
# Documentation: http://www.advsys.net/ken/util/pngout.htm
# Ken Silverman PNG optimizer (DEFLATE recompressor)

local ret=1

_arguments -s \
  '-c+[select the color type {0,2,3,4,6}]:type:(0 2 3 4 6)' \
  '-f+[select the filter type {0,1,2,3,4,5,6}]:filter:(0 1 2 3 4 5 6)' \
  '-d+[select the color bit depth {0(minimize),1,2,4,8}]:depth:(0 1 2 4 8)' \
  '-s+[select strategy {0(default),1,2,3,4}]:strategy:(0 1 2 3 4)' \
  '-k+[keep or remove ancillary chunks]:chunks:' \
  '-b+[block split threshold]:threshold:' \
  '-n+[explicitly specify the number of block splits]:n:' \
  '-r[compress using randomized initial Huffman tables]' \
  '-mincodes+[ensure Huffman tables have a minimum number of codes {0,1,2}]:n:(0 1 2)' \
  '-i[accept Windows clipboard bitmap as input source]' \
  '-v[verbose mode: list chunks to keep and remove]' \
  '-q[suppress all output]' \
  '-l[display autodetected options from input file then exit]' \
  '-y[assume Yes at the overwrite file prompt]' \
  '-force[overwrite output even if compression did not reduce file size]' \
  '-kt[preserve the original file date and time]' \
  '*:file:_files' && ret=0

return ret
