#compdef ssl_mail_client
# Documentation: https://github.com/Mbed-TLS/mbedtls/blob/development/programs/ssl/ssl_mail_client.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
#
# All param= names verified against strcmp() calls in programs/ssl/ssl_mail_client.c.

local curcontext="$curcontext" state line ret=1
local -a params

params=(
  'server_name=:SMTP server hostname'
  'server_addr=:SMTP server address'
  'server_port=:SMTP server port'
  'mail_from=:sender address'
  'mail_to=:recipient address'
  'user_name=:authentication username'
  'user_pwd=:authentication password'
  'authentication=:enable SMTP authentication (0/1)'
  'debug_level=:debug level'
  'mode=:0=SMTPS, 1=STARTTLS'
)

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    if compset -P 'authentication='; then
      _values flag 0 1 && ret=0
    elif compset -P 'mode='; then
      _values 'mode' 0 1 && ret=0
    else
      _describe -t params 'param' params -S '' && ret=0
    fi
    ;;
esac

return ret
