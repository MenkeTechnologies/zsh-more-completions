#compdef flawz
# Documentation: https://github.com/orhun/flawz
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# flawz: TUI CVE browser using NIST NVD feeds (orhun/flawz, clap).
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--url=[NIST CVE JSON feed base URL]:url:' \
  '*'{-f,--feeds}'=[feed ids or year ranges]:feed:' \
  '(-d --db)'{-d,--db}'=[SQLite CVE cache path]:file:_files' \
  '(-u --force-update)'{-u,--force-update}'[always fetch feeds]' \
  '(-o --offline)'{-o,--offline}'[do not fetch feeds]' \
  '(-q --query)'{-q,--query}'=[initial TUI search query]:query:' \
  '(-t --theme)'{-t,--theme}'=[UI theme]:theme:(dracula nord one-dark solarized-dark gruvbox-light gruvbox-material-dark-hard catppuccin)'
