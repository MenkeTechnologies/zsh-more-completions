#compdef ristosds
# Documentation: https://manpages.debian.org/testing/hdf4-tools/ristosds.1.en.html
# Convert RIS8 HDF files into a single 3-D SDS HDF file

local ret=1

_arguments -s \
  '-o+[write the output to outfile]:output file:_files -g "*.(hdf|h4)"' \
  '*:input hdf file:_files -g "*.(hdf|h4)"' && ret=0

return ret
