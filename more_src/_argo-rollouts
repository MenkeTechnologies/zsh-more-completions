#compdef kubectl-argo-rollouts

# Zsh completion for Argo Rollouts kubectl plugin

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_argo_rollouts_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '--loglevel=[log level]:level:(debug info warn error)'
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:'
  '--kloglevel=[Kubernetes log level]:level:'
  '--kube-context=[Kubernetes context]:context:'
  '--as=[username to impersonate]:user:'
  '--as-group=[group to impersonate]:group:'
  '--as-uid=[UID to impersonate]:uid:'
  '--certificate-authority=[path to CA certificate]:ca file:_files -g "*.{pem,crt}"'
  '--client-certificate=[path to client certificate]:cert file:_files -g "*.{pem,crt}"'
  '--client-key=[path to client key]:key file:_files -g "*.{pem,key}"'
  '--cluster=[cluster name]:cluster:'
  '--insecure-skip-tls-verify[skip TLS certificate verification]'
  '--kubeconfig=[path to kubeconfig file]:kubeconfig:_files'
  '(-s --server)'{-s+,--server=}'[Kubernetes API server address]:server:'
  '--tls-server-name=[server name for TLS verification]:name:'
  '--token=[bearer token for authentication]:token:'
  '--user=[kubeconfig user]:user:'
)

_argo_rollouts_rollouts() {
  local -a rollouts
  rollouts=(${(f)"$(kubectl-argo-rollouts list rollouts -n ${opt_args[-n]:-${opt_args[--namespace]:-default}} 2>/dev/null | tail -n +2 | awk '{print $1}')"})
  [[ -n "$rollouts" ]] && compadd -a rollouts
}

_argo_rollouts_experiments() {
  local -a experiments
  experiments=(${(f)"$(kubectl-argo-rollouts list experiments -n ${opt_args[-n]:-${opt_args[--namespace]:-default}} 2>/dev/null | tail -n +2 | awk '{print $1}')"})
  [[ -n "$experiments" ]] && compadd -a experiments
}

_arguments -s -S -C \
  "${_argo_rollouts_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'abort:Abort a rollout'
      'create:Create a resource'
      'dashboard:Start the Argo Rollouts dashboard'
      'get:Get details about a rollout or experiment'
      'lint:Lint and validate a rollout or experiment resource'
      'list:List rollouts or experiments'
      'notifications:Manage notifications'
      'pause:Pause a rollout'
      'promote:Promote a rollout'
      'retry:Retry a rollout'
      'set:Set values on a rollout'
      'status:Show the status of a rollout'
      'terminate:Terminate an experiment'
      'undo:Undo a rollout'
      'version:Print version information'
    )
    _describe -t commands 'argo-rollouts commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      abort)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '1:rollout name:_argo_rollouts_rollouts' && ret=0
        ;;
      create)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '(-f --filename)'{-f+,--filename=}'[file to use to create the resource]:file:_files -g "*.{yaml,yml,json}"' \
          '--from-file=[create from file]:file:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      dashboard)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '--port=[dashboard port]:port:' \
          '--root-path=[root path for dashboard]:path:' && ret=0
        ;;
      get)
        _arguments -s -S -C \
          "${_argo_rollouts_global_flags[@]}" \
          '1:resource type:(rollout experiment)' \
          '2:name:->get_name' \
          '(-w --watch)'{-w,--watch}'[watch for changes]' \
          '--no-color[disable color output]' && ret=0
        case "$state" in
          get_name)
            case "${line[1]}" in
              rollout) _argo_rollouts_rollouts ;;
              experiment) _argo_rollouts_experiments ;;
            esac
            ;;
        esac
        ;;
      lint)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '(-f --filename)'{-f+,--filename=}'[file to lint]:file:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      list)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '1:resource type:(rollouts experiments)' \
          '--all-namespaces[list across all namespaces]' \
          '--name=[filter by name]:name:' \
          '--timestamps[print timestamps]' && ret=0
        ;;
      notifications)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '1:subcommand:(template trigger)' && ret=0
        ;;
      pause)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '1:rollout name:_argo_rollouts_rollouts' && ret=0
        ;;
      promote)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '--full[perform a full promotion]' \
          '1:rollout name:_argo_rollouts_rollouts' && ret=0
        ;;
      retry)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '1:resource type:(rollout experiment)' \
          '2:name:->retry_name' && ret=0
        case "$state" in
          retry_name)
            case "${line[1]}" in
              rollout) _argo_rollouts_rollouts ;;
              experiment) _argo_rollouts_experiments ;;
            esac
            ;;
        esac
        ;;
      set)
        _arguments -s -S -C \
          "${_argo_rollouts_global_flags[@]}" \
          '1:subcommand:(image)' \
          '*::arg:->set_args' && ret=0
        case "$state" in
          set_args)
            case "${line[1]}" in
              image)
                _arguments -s -S \
                  "${_argo_rollouts_global_flags[@]}" \
                  '1:rollout name:_argo_rollouts_rollouts' \
                  '2:container=image:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      status)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '(-w --watch)'{-w,--watch}'[watch for changes]' \
          '--timeout=[timeout for watch]:duration:' \
          '1:rollout name:_argo_rollouts_rollouts' && ret=0
        ;;
      terminate)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '1:experiment name:_argo_rollouts_experiments' && ret=0
        ;;
      undo)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '--to-revision=[revision to rollback to]:revision:' \
          '1:rollout name:_argo_rollouts_rollouts' && ret=0
        ;;
      version)
        _arguments -s -S \
          "${_argo_rollouts_global_flags[@]}" \
          '--short[print short version]' && ret=0
        ;;
    esac
    ;;
esac

return ret
