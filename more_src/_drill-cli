#compdef drill-cli
# _drill-cli — NLnet Labs ldns drill DNS lookup CLI alias (NLnetLabs team, C); custom argparse
# upstream: https://github.com/NLnetLabs/ldns

_drill-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-D[enable DNSSEC]' \
        '-T[trace from root]' \
        '-S[chase DNSSEC]' \
        '-V+[verbosity 0-5]:n:' \
        '-Q[quiet mode]' \
        '-f+[query file]:file:_files' \
        '-i+[query file with IDN]:file:_files' \
        '-w+[output file]:file:_files' \
        '-q+[query name]:str:' \
        '-4[ipv4]' \
        '-6[ipv6]' \
        '-a[fall back to TCP]' \
        '-b+[buffer size]:n:' \
        '-c+[class]:c:(IN CH HS)' \
        '-k+[trusted key file]:file:_files' \
        '-o+[options]:str:' \
        '-p+[port]:port:' \
        '-r+[hint file]:file:_files' \
        '-s+[server]:host:_hosts' \
        '-t[force TCP]' \
        '-u[force UDP]' \
        '-x[reverse mapping]' \
        '-y+[tsig keyspec]:str:' \
        '-z[do not include trust anchor]' \
        '*:name type class server:'
}

_drill-cli "$@"
