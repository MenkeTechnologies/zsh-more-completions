#compdef black

# zsh completions for 'black'
local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  '--check[do not write back files, just return status]'
  '--diff[print diff instead of writing back files]'
  '--color[show colored diff]'
  '--no-color[do not show colored diff]'
  '--fast[skip temporary sanity checks]'
  '--safe[do not skip temporary sanity checks]'
  '--required-version[require a specific version of Black]:version:'
  '(-q --quiet)'{-q,--quiet}'[do not emit non-error messages]'
  '(-v --verbose)'{-v,--verbose}'[emit extra messages for debugging]'
  '(-l --line-length)'{-l,--line-length}'[how many characters per line to allow]:length:'
  '(-t --target-version)'{-t,--target-version}'[Python version to target]:version:(py33 py34 py35 py36 py37 py38 py39 py310 py311 py312)'
  '(-S --skip-string-normalization)'{-S,--skip-string-normalization}'[do not normalize string quotes or prefixes]'
  '(-C --skip-magic-trailing-comma)'{-C,--skip-magic-trailing-comma}'[do not use trailing commas as a reason to split lines]'
  '--preview[enable potentially disruptive style changes]'
  '--config[read configuration from FILE]:config file:_files'
  '--include[regular expression for files and directories to include]:pattern:'
  '--exclude[regular expression for files and directories to exclude]:pattern:'
  '--extend-exclude[additional regular expression for exclusion on top of --exclude]:pattern:'
  '--force-exclude[regular expression for files and directories that will always be excluded]:pattern:'
  '--stdin-filename[the name of the file when reading from stdin]:filename:'
  '(-W --workers)'{-W,--workers}'[number of parallel workers]:workers:'
  '--pyi[format all input files as pyi stubs]'
  '--ipynb[format all input files as Jupyter Notebooks]'
  '--python-cell-magics[add the given magic to the list of known python-cell magics]:magics:'
  '*:file or directory:_files'
)

_arguments -s -S $arguments
