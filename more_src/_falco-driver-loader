#compdef falco-driver-loader
# Documentation: https://falco.org/docs/setup/packages/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# falco-driver-loader: load the Falco kernel module / eBPF probe
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--clean[clean compiler/cache]' \
  '--source-only[only download source, do not build]' \
  '--compile[recompile driver locally]' \
  '--download[only download prebuilt driver]' \
  '*:driver kind:(module bpf modern-bpf)' && ret=0
return ret
