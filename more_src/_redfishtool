#compdef redfishtool
# _redfishtool — DMTF redfishtool reference command-line client for the Redfish DMTF server-management REST API (DMTF team, Python); argparse
# upstream: https://github.com/DMTF/Redfishtool

_redfishtool() {
    local -a sub=(
        'about:show about info'
        'versions:show service versions'
        'discover:SSDP discover Redfish services'
        'hello:basic hello check'
        'Systems:Systems collection'
        'Chassis:Chassis collection'
        'Managers:Managers collection'
        'AccountService:account service'
        'SessionService:session service'
        'EventService:event service'
        'CertificateService:certificate service'
        'UpdateService:update service'
        'TaskService:task service'
        'JobService:job service'
        'Registries:registries'
        'odata:odata service doc'
        'Tasks:tasks'
        'Jobs:jobs'
        'TelemetryService:telemetry service'
        'Fabrics:fabrics'
        'raw:invoke raw HTTP'
        'helper:helper subcommands'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-r+[rhost ip or url]:host:_hosts' \
        '--rhost=+[rhost ip or url]:host:_hosts' \
        '-u+[username]:user:_users' \
        '--user=+[username]:user:_users' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '-A+[auth method]:a:(None Basic Session)' \
        '--Auth=+[auth method]:a:(None Basic Session)' \
        '-S+[secure mode]:s:(Never IfSendingCredentials IfLoginOrAuthenticatedApi Always)' \
        '--Secure=+[secure mode]:s:(Never IfSendingCredentials IfLoginOrAuthenticatedApi Always)' \
        '-T+[timeout sec]:n:' \
        '--Timeout=+[timeout sec]:n:' \
        '-W+[wait sec]:n:' \
        '--Wait=+[wait sec]:n:' \
        '-M+[retries]:n:' \
        '--Retries=+[retries]:n:' \
        '-v[verbose]' \
        '-s[status]' \
        '--status[status]' \
        '-c+[config file]:file:_files -g "*.cfg *.ini"' \
        '--config=+[config file]:file:_files -g "*.cfg *.ini"' \
        '-o+[output format]:f:(json csv text Yaml table)' \
        '--Format=+[output format]:f:(json csv text Yaml table)' \
        '-I+[id]:str:' \
        '--Id=+[id]:str:' \
        '-1[one shot]' \
        '--One-shot[one shot]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-H+[header]:str:' \
        '--Headers=+[header]:str:' \
        '-X+[http method]:m:(GET POST PATCH PUT DELETE HEAD)' \
        '--Method=+[http method]:m:(GET POST PATCH PUT DELETE HEAD)' \
        '-d+[data file or string]:str:' \
        '--data=+[data file or string]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'redfishtool subcommand' sub ;;
    esac
}

_redfishtool "$@"
