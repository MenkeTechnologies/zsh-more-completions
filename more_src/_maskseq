#compdef maskseq
# Documentation: https://man.archlinux.org/search?q=maskseq
# Reference accessed: 2026-05-16

# EMBOSS maskseq: mask specified regions of sequence(s)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-regions=[regions to mask (start..end,start..end)]:regions:' \
  '-tolower[mask by lowercasing instead of replacement]' \
  '-maskchar=[character to use for hard masking]:char:' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output format]:format:(fasta embl genbank swiss gcg pir raw msf text)' \
  '*:sequence USA:_files' && ret=0
return ret
