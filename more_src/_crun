#compdef crun
# _crun — OCI container runtime in C (containers/crun)
# upstream: https://github.com/containers/crun
# Global flags from src/crun.c argp options; commands from src/crun.c commands[] on tip.

_crun() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print version and exit]' \
        '--debug[verbose output (= --log-level=debug)]' \
        '--cgroup-manager=[cgroup manager]:mgr:(cgroupfs systemd disabled)' \
        '--systemd-cgroup[use systemd cgroups]' \
        '--log=[log destination (FILE / journald\:ID / syslog\:ID)]:dest:' \
        '--log-format=[log format]:fmt:(text json)' \
        '--log-level=[log level]:level:(error warning debug)' \
        '--root=[OCI state directory]:dir:_files -/' \
        '--rootless=[rootless mode]:val:(auto true false)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                create:'create a container without starting it'
                delete:'remove a container and its state'
                exec:'exec a process inside a running container'
                list:'list running containers'
                kill:'send a signal to a container'
                ps:'list processes in a container'
                run:'create and immediately start a container'
                spec:'generate an OCI runtime spec template'
                start:'start a previously created container'
                state:'show the OCI state of a container'
                update:'update container resource limits'
                pause:'pause all processes in a container'
                resume:'resume paused processes'
                features:'print supported OCI features'
                checkpoint:'checkpoint a running container (CRIU)'
                restore:'restore a container from a checkpoint'
                mounts:'manage extra mounts inside a running container'
            )
            _describe -t commands 'crun command' cmds
            ;;
        args)
            case $words[1] in
                create|run)
                    _arguments \
                        '(-b --bundle)'{-b,--bundle=}'[OCI bundle path]:dir:_files -/' \
                        '--config=[runtime spec file relative to bundle]:file:_files' \
                        '--console-socket=[abstract socket for terminal master]:path:' \
                        '--pid-file=[write container PID to file]:file:_files' \
                        '--preserve-fds=[extra fds inherited into container]:n:' \
                        '--no-new-keyring[do not create a new session keyring]' \
                        '--no-pivot[do not use pivot_root]' \
                        ':container-id:'
                    ;;
                exec)
                    _arguments \
                        '(-d --detach)'{-d,--detach}'[detach from container]' \
                        '--cwd=[working directory]:dir:_files -/' \
                        '*--env=[set environment variable]:var:' \
                        '--tty[allocate pseudo-TTY]' \
                        '(-u --user)'{-u,--user=}'[uid:gid]:user:' \
                        '--process=[exec process spec JSON]:file:_files' \
                        '*--cap-add=[add capability]:cap:'
                    ;;
                kill)
                    _arguments \
                        ':container-id:' \
                        ':signal:_signals'
                    ;;
            esac
            ;;
    esac
}

_crun "$@"
