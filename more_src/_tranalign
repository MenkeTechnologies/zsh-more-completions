#compdef tranalign
# Documentation: https://man.archlinux.org/search?q=tranalign
# Reference accessed: 2026-05-16

# EMBOSS tranalign: align nucleic acid from protein alignment
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' '-outfile=[output]:file:_files' \
  '-asequence=[nucleic acid sequences]:file:_files' \
  '-bsequence=[aligned protein sequences]:file:_files' \
  '-table=[genetic code]:code:(0 1 2 3 4 5 6 9 10 11 12 13 14 15 16 21 22 23)' \
  '*:sequence:_files' && ret=0

return ret
