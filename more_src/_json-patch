#compdef json-patch
# Source: cargo binstall json-patch-cli@0.1.5
# Probed via: completions zsh
# Repository: https://github.com/kellpossible/json-patch-cli

autoload -U is-at-least

_json-patch() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_json-patch_commands" \
"*::: :->json-patch" \
&& ret=0
    case $state in
    (json-patch)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:json-patch-command-$line[1]:"
        case $line[1] in
            (diff)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':from:_files' \
':to:_files' \
&& ret=0
;;
(apply)
_arguments "${_arguments_options[@]}" : \
'-p+[]:PATCH:_files' \
'--patch=[]:PATCH:_files' \
'-h[Print help]' \
'--help[Print help]' \
':input:_files' \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
'-p+[Path to JSON patch file]:PATCH:_files' \
'--patch=[Path to JSON patch file]:PATCH:_files' \
'-e+[]:EDITOR:_default' \
'--editor=[]:EDITOR:_default' \
'-w[Enable live editing of the patch file]' \
'--watch[Enable live editing of the patch file]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':input:_files' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_json-patch__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:json-patch-help-command-$line[1]:"
        case $line[1] in
            (diff)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(apply)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_json-patch_commands] )) ||
_json-patch_commands() {
    local commands; commands=(
'diff:Calculate the difference between two json files to create a JSON (RFC 6902) patch' \
'apply:Apply a JSON (RFC 6902) patch' \
'edit:Edit or create a JSON (RFC 6902) patch, by editing a patched version of the input using a text editor' \
'completions:Generate command line completions script' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'json-patch commands' commands "$@"
}
(( $+functions[_json-patch__apply_commands] )) ||
_json-patch__apply_commands() {
    local commands; commands=()
    _describe -t commands 'json-patch apply commands' commands "$@"
}
(( $+functions[_json-patch__completions_commands] )) ||
_json-patch__completions_commands() {
    local commands; commands=()
