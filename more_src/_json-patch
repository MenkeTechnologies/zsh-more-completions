    )
    _describe -t commands 'json-patch help commands' commands "$@"
}
(( $+functions[_json-patch__help__apply_commands] )) ||
_json-patch__help__apply_commands() {
    local commands; commands=()
    _describe -t commands 'json-patch help apply commands' commands "$@"
}
(( $+functions[_json-patch__help__completions_commands] )) ||
_json-patch__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'json-patch help completions commands' commands "$@"
}
(( $+functions[_json-patch__help__diff_commands] )) ||
_json-patch__help__diff_commands() {
    local commands; commands=()
    _describe -t commands 'json-patch help diff commands' commands "$@"
}
(( $+functions[_json-patch__help__edit_commands] )) ||
_json-patch__help__edit_commands() {
    local commands; commands=()
    _describe -t commands 'json-patch help edit commands' commands "$@"
}
(( $+functions[_json-patch__help__help_commands] )) ||
_json-patch__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'json-patch help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_json-patch" ]; then
    _json-patch "$@"
else
    compdef _json-patch json-patch
fi
