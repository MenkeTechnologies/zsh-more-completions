#compdef ansible-creator
# Documentation: https://github.com/ansible/ansible-creator
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ansible/ansible-creator — argparse root (see src/ansible_creator/arg_parser.py)

local curcontext="$curcontext" state line ret=1

local -a common=(
  '--version[show version and exit]'
  '--na --no-ansi[disable ANSI color]'
  '--lf --log-file=[log file path]:file:_files'
  '--ll --log-level=[file log level]:level:(notset debug info warning error critical)'
  '--la --log-append=[append to log file]:bool:(true false)'
  '--json[machine-readable JSON messages]'
  '*'{-v,--verbosity}'[increase verbosity (repeatable)]'
)

_arguments -s -S \
  $common \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd)
    _describe -t commands 'ansible-creator command' '(init add schema)' && ret=0
    ;;
  (rest)
    _arguments -s -S $common '*:arguments:_default' && ret=0
    ;;
esac

return ret
