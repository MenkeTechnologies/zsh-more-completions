#compdef enfuse
# Documentation: https://man.archlinux.org/search?q=enfuse
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'+[verbosity level]:level:' \
  '(-w --wrap)'{-w,--wrap}'+[wrap mode]:mode:(NONE HORIZONTAL VERTICAL BOTH)' \
  '(-l --levels)'{-l,--levels}'+[pyramid levels]:n:' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '(-d --depth)'{-d,--depth}'+[output bit depth]:depth:(8 16 32 r32 r64)' \
  '(-c --ciecam)'{-c,--ciecam}'[CIECAM02 colorspace]' \
  '(--exposure-weight)--exposure-weight=+[exposure weight 0-1]:w:' \
  '(--saturation-weight)--saturation-weight=+[saturation weight 0-1]:w:' \
  '(--contrast-weight)--contrast-weight=+[contrast weight 0-1]:w:' \
  '(--entropy-weight)--entropy-weight=+[entropy weight 0-1]:w:' \
  '(--exposure-mu)--exposure-mu=+[exposure mu 0-1]:mu:' \
  '(--exposure-sigma)--exposure-sigma=+[exposure sigma]:sigma:' \
  '(--exposure-cutoff)--exposure-cutoff=+[exposure cutoff lo:hi]:cutoff:' \
  '(--contrast-window-size)--contrast-window-size=+[contrast window]:n:' \
  '(--contrast-edge-scale)--contrast-edge-scale=+[edge scale]:n:' \
  '(--contrast-min-curvature)--contrast-min-curvature=+[min curvature]:val:' \
  '(--entropy-window-size)--entropy-window-size=+[entropy window]:n:' \
  '(--entropy-cutoff)--entropy-cutoff=+[entropy cutoff lo:hi]:cutoff:' \
  '(--hard-mask)--hard-mask[hard mask mode]' \
  '(--soft-mask)--soft-mask[soft mask mode]' \
  '(--gray-projector)--gray-projector=+[gray projector]:proj:(average lightness value luminance pl-star)' \
  '(--blend-colorspace)--blend-colorspace=+[blend colorspace]:cs:(identity lab luv ciecam)' \
  '*:input_files:_files -g "*.{tif,tiff,jpg,jpeg,png}"' && ret=0

return ret
