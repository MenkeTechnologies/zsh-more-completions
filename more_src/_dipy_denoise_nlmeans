#compdef dipy_denoise_nlmeans
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_denoise_nlmeans.html
# DIPY: non-local means (NLMEANS) denoising

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--sigma=[noise parameter; auto-estimates if 0]:sigma' \
  '--patch_radius=[patch dimensions as 2*radius+1]:radius' \
  '--block_radius=[block dimensions as 2*radius+1]:radius' \
  '--num_threads=[OpenMP threads for parallel processing]:n' \
  '--method=[algorithm selection]:method:(classic blockwise)' \
  '--rician[assume Rician noise; otherwise Gaussian]' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_denoised=[output filename]:file:_files' \
  '*:input volumes:_files' && ret=0

return ret
