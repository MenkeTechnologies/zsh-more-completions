#compdef bcache-cli bcache make-bcache bcache-super-show bcache-register
# _bcache-cli — Linux bcache block-cache tooling CLI alias (Kent Overstreet / bcache team, C); custom argparse
# upstream: https://git.kernel.org/pub/scm/linux/kernel/git/colyli/bcache-tools.git

_bcache-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--bdev[backing device]' \
        '-B[backing device]' \
        '--cache[cache device]' \
        '-C[cache device]' \
        '--writeback[writeback]' \
        '-w[writeback]' \
        '--bucket=+[bucket size]:str:' \
        '--block=+[block size]:str:' \
        '--discard[issue discards]' \
        '--cache-replacement-policy=+[policy]:p:(lru fifo random)' \
        '-p+[policy]:p:(lru fifo random)' \
        '--data-offset=+[data offset]:n:' \
        '-o+[data offset]:n:' \
        '--cset-uuid=+[cset uuid]:str:' \
        '-u+[cset uuid]:str:' \
        '--label=+[label]:str:' \
        '-l+[label]:str:' \
        '--super[show superblock]' \
        '-S[show superblock]' \
        '--register[register device]' \
        '-R[register device]' \
        '--unregister[unregister device]' \
        '--force[force]' \
        '-f[force]' \
        '*:device:_files'
}

_bcache-cli "$@"
