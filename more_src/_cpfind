#compdef cpfind

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files -g "*.pto"' \
  '(--prealigned)--prealigned[use prealigned info]' \
  '(--multirow)--multirow[multi-row mode]' \
  '(--celeste)--celeste[run celeste]' \
  '(--linearmatch)--linearmatch[linear match]' \
  '(--linearmatchlen)--linearmatchlen=+[linear match length]:n:' \
  '(--ransacthreshold)--ransacthreshold=+[RANSAC threshold]:val:' \
  '(--ransaciter)--ransaciter=+[RANSAC iterations]:n:' \
  '(--minmatches)--minmatches=+[min matches]:n:' \
  '(--ncores)--ncores=+[number of cores]:n:' \
  '(--cache)--cache[cache keypoints]' \
  '(--clean)--clean[clean unmatched control points]' \
  '(--keypath)--keypath=+[keypoint cache path]:dir:_files -/' \
  '(--sieve1width)--sieve1width=+[sieve1 width]:n:' \
  '(--sieve1height)--sieve1height=+[sieve1 height]:n:' \
  '(--sieve1size)--sieve1size=+[sieve1 size]:n:' \
  '(--kdtreesteps)--kdtreesteps=+[kdtree steps]:n:' \
  '(--kdtreeseconddist)--kdtreeseconddist=+[kdtree 2nd distance]:val:' \
  '(--fullscale)--fullscale[full scale]' \
  '(--projection)--projection=+[projection]:proj:' \
  '(--minmatches)--minmatches=+[min matches per pair]:n:' \
  '(--test)--test[test mode]' \
  '(--verbose)--verbose[verbose]' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
