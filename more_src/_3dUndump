#compdef 3dUndump
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dUndump.html
# AFNI: create a dataset from an ASCII list of coordinates

local ret=1

_arguments -s -S \
  '-prefix[output dataset prefix]:prefix:' \
  '-master[master dataset for output geometry]:dataset:_files' \
  '-dimen[output dimensions I J K voxels]:I:' \
  '-mask[mask dataset to control settable voxels]:dataset:_files' \
  '-datum[voxel data type]:type:(byte short float)' \
  '-dval[default value for set voxels]:value:' \
  '-fval[fill value for unlisted voxels]:value:' \
  '-ijk[input coords are (i,j,k) index triples]' \
  '-xyz[input coords are (x,y,z) mm]' \
  '-srad[sphere radius to fill around each point]:radius:' \
  '-cubes[fill cubes instead of spheres]' \
  '-orient[coordinate order for -xyz]:orient:' \
  '-head_only[create only the .HEAD file]' \
  '-ROImask[assign voxels using a dataset]:dataset:_files' \
  '-allow_NaN[permit NaN values in input]' \
  '*:file:_files' && ret=0

return ret
