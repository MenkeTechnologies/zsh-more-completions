#compdef colabfold_batch
# Documentation: https://github.com/sokrypton/ColabFold/blob/main/colabfold/batch.py
# LocalColabFold AlphaFold2 batch structure prediction

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--msa-only[query and store MSAs without structure prediction]' \
  '--msa-mode=[databases for MSA creation]:mode:(mmseqs2_uniref_env mmseqs2_uniref single_sequence)' \
  '--pair-mode=[multimer MSA pairing mode]:mode:(unpaired paired unpaired_paired)' \
  '--pair-strategy=[sequence pairing method for complex prediction]:strategy:(greedy complete)' \
  '--templates[query PDB templates from the MSA server]' \
  '--custom-template-path=[directory with PDB files as custom templates]:dir:_files -/' \
  '--custom-template-cache-path=[directory for temporary HHsearch databases]:dir:_files -/' \
  '--max-template-date=[maximum release date YYYY-MM-DD for templates]:date:' \
  '--max-template-hits=[maximum number of template hits to consider]:n:' \
  '--pdb-hit-file=[BLAST-m8 formatted PDB hit file]:file:_files' \
  '--local-pdb-path=[directory of a local mirror of the PDB mmCIF database]:dir:_files -/' \
  '--num-recycle=[number of prediction recycles]:n:' \
  '--recycle-early-stop-tolerance=[convergence criteria threshold]:tol:' \
  '--num-ensemble=[number of ensembles]:n:' \
  '--num-seeds=[number of seeds to try]:n:' \
  '--random-seed=[seed for the random number generator]:n:' \
  '--num-models=[number of models to use for structure prediction]:n:(1 2 3 4 5)' \
  '--model-type=[model to predict structure/complex]:type:(auto alphafold2 alphafold2_ptm alphafold2_multimer_v1 alphafold2_multimer_v2 alphafold2_multimer_v3 deepfold_v1)' \
  '--model-order=[order of models to use]:order:' \
  '--initial-guess=[starting model for the prediction]:file:_files' \
  '--use-dropout[activate dropouts during inference to sample uncertainty]' \
  '--max-seq=[number of sequence clusters to use]:n:' \
  '--max-extra-seq=[number of extra sequences to use]:n:' \
  '--max-msa=[max-seq:max-extra-seq number of sequences]:val:' \
  '--disable-cluster-profile[disable cluster profiles for multimer models]' \
  '--calc-extra-ptm[calculate pairwise ipTM and actifpTM metrics]' \
  '--no-use-probs-extra[use binary contacts instead of contact probabilities]' \
  '--data=[path to AlphaFold2 weights directory]:dir:_files -/' \
  '--amber[enable OpenMM/Amber for structure relaxation]' \
  '--num-relax=[how many top ranked structures to relax]:n:' \
  '--relax-max-iterations=[maximum iterations for relaxation]:n:' \
  '--relax-tolerance=[tolerance threshold for relaxation]:tol:' \
  '--relax-stiffness=[stiffness parameter for relaxation]:val:' \
  '--relax-max-outer-iterations=[maximum outer iterations for relaxation]:n:' \
  '--use-gpu-relax[run OpenMM/Amber on GPU instead of CPU]' \
  '--rank=[metric to rank the predicted models]:metric:(auto plddt ptm iptm multimer)' \
  '--stop-at-score=[stop when pLDDT or pTM-score exceeds threshold]:score:' \
  '--jobname-prefix=[prefix jobname with given string and running number]:prefix:' \
  '--save-all[save all raw outputs to a pickle file]' \
  '--save-recycles[save intermediate predictions at each recycle iteration]' \
  '--save-single-representations[save the single representation embeddings]' \
  '--save-pair-representations[save the pair representation embeddings]' \
  '--skip-output=[comma-separated output types to skip]:types:' \
  '--overwrite-existing-results[do not recompute already predicted results]' \
  '--zip[zip all results and delete original files]' \
  '--sort-queries-by=[sort input queries by]:by:(none length msa_depth random)' \
  '--host-url=[which MSA server should be queried]:url:' \
  '--disable-unified-memory[disable unified memory on TensorFlow/Jax errors]' \
  '--recompile-padding=[padding length to avoid model recompilation]:n:' \
  '--use-pallas[use Pallas/Triton kernels for faster prediction]' \
  '--debug-logging[enable debug message logging]' \
  '--af3-json[generate input JSON for AlphaFold3 from FASTA/A3M]' \
  '1:input:_files' \
  '2:results dir:_files -/' && ret=0

return ret
