#compdef lact-cli
# _lact-cli — Linux GPU Configuration Tool LACT CLI alias (ilya-zlobintsev / LACT team, Rust); clap-rs
# upstream: https://github.com/ilya-zlobintsev/LACT

_lact-cli() {
    local -a sub=(
        'daemon:run lact daemon'
        'gui:start GUI'
        'cli:command-line operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lact subcommand' sub ;;
        args)
            case $words[1] in
                cli) _arguments \
                    '1:cmd:(list-gpus get-power-cap set-power-cap reset-power-cap get-clocks-info set-fixed-clocks-info set-clocks-info reset-clocks-info get-fan-control set-fan-curve reset-fan-curve set-amdgpu-overdrive show-info dump)' \
                    '--gpu=+[gpu index]:n:' \
                    '*:arg:' ;;
                daemon) _arguments \
                    '--config=+[config file]:file:_files' \
                    '--socket=+[socket path]:file:_files' \
                    '--no-systemd[no systemd]' ;;
                gui) _arguments \
                    '--use-system-server[use system server]' ;;
            esac
            ;;
    esac
}

_lact-cli "$@"
