#compdef slipd
# Documentation: https://man.archlinux.org/search?q=slipd
# Reference accessed: 2026-05-16
# Source: https://github.com/pasberth/slipd/blob/12d4a98c574216a07dbb896614e18e860f8d56e0/functions/_slipd
# Repository: pasberth/slipd (functions/_slipd)

local signal
signal=${words[2]}

function _slipd_complete_all () {
  local paths
  if [ -z "$signal" ]; then
    paths=($(_slipd_enumerate))
  else
    paths=($(_slipd_complete "$signal"))
  fi

  # TODO: order
  _describe -t upper_directory "upper directory" paths
}

_slipd_complete_all
