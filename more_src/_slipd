#compdef slipd
# Documentation: https://github.com/pasberth/slipd
# Reference accessed: 2026-05-21
# Verified: upstream functions/_slipd matches verbatim.

local signal
signal=${words[2]}

function _slipd_complete_all () {
  local paths
  if [ -z "$signal" ]; then
    paths=($(_slipd_enumerate))
  else
    paths=($(_slipd_complete "$signal"))
  fi

  # TODO: order
  _describe -t upper_directory "upper directory" paths
}

_slipd_complete_all
