#compdef doctl
# _doctl-bin — DigitalOcean doctl CLI (DigitalOcean, Go); manage Droplets/k8s/spaces from the command line
# upstream: https://github.com/digitalocean/doctl

_doctl-bin() {
    local -a sub=(
        '1-click:1-click apps'
        'account:account info'
        'apps:platform apps'
        'auth:authenticate'
        'balance:billing balance'
        'billing-history:billing history'
        'completion:print shell completion'
        'compute:compute commands (droplets, ssh, etc)'
        'databases:managed databases'
        'help:show help'
        'invoice:invoices'
        'kubernetes:k8s clusters'
        'monitoring:monitoring'
        'projects:projects'
        'registry:container registry'
        'serverless:DigitalOcean serverless'
        'sandbox:functions sandbox (legacy)'
        'tags:tag management'
        'uptime:uptime checks'
        'version:show version'
        'vpcs:VPCs'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '-t+[API token]:str:' \
        '--access-token+[API token]:str:' \
        '--api-url+[API URL]:url:_urls' \
        '-u+[API URL]:url:_urls' \
        '--config+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--context+[auth context]:str:' \
        '-o+[output format]:fmt:(json text)' \
        '--output+[output format]:fmt:' \
        '--trace[trace api calls]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'doctl subcommand' sub ;;
        args)
            case $words[1] in
                auth) _arguments '1:auth cmd:(init list remove switch)' '*:context:' ;;
                compute) _arguments '1:compute cmd:(action certificate cdn domain droplet droplet-action firewall floating-ip image load-balancer reserved-ip snapshot ssh ssh-key tag region size volume volume-action)' '*:args:' ;;
                kubernetes) _arguments '1:k8s cmd:(1-click cluster options node-pool)' '*:args:' ;;
                databases) _arguments '1:db cmd:(backups connection db firewalls maintenance-window migrations options pool replica resize sql-mode user)' '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_doctl-bin "$@"
