#compdef wmaker
# Documentation: https://man.archlinux.org/man/wmaker.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--global_defaults_path[print default config file path and exit]' \
  '--no-dock[do not show the application dock]' \
  '--no-clip[do not show the workspace clip]' \
  '--no-autolaunch[do not autolaunch applications]' \
  '--no-drawer[do not use drawers in the dock]' \
  '--dont-restore[do not restore saved session]' \
  '--replace[request current WM to yield to Window Maker]' \
  '-display[X display to use]:display:' \
  '--visual-id[specify visual id to use]:visual id:' \
  '--static[do not update or save configurations]' \
  '--locale[specify locale]:locale:'
