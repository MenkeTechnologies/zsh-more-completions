#compdef samply

# Zsh completion for samply - command-line sampling profiler

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'record:record a profile of a command or process'
      'load:load a previously saved profile'
      'setup:set up prerequisites for profiling'
    )
    _describe -t commands 'samply command' commands && ret=0
    ;;
  args)
    case $line[1] in
      record)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --pid)'{-p,--pid}'=[attach to a running process]:pid' \
          '(-r --rate)'{-r,--rate}'=[sampling rate in Hz]:rate' \
          '--duration=[recording duration in seconds]:seconds' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '--save-only[save profile without opening viewer]' \
          '--no-open[do not open profile in browser]' \
          '--port=[port for the profiler server]:port' \
          '--reuse-threads[reuse threads from a previous profile]' \
          '--iteration-count=[number of iterations]:count' \
          '*:command:_command_names -e' \
          && ret=0
        ;;
      load)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--port=[port for the profiler server]:port' \
          '1:profile file:_files' \
          && ret=0
        ;;
      setup)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
