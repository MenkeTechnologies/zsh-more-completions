#compdef antora-cli antora2
# _antora-cli — OpenDevise antora-cli CLI multi-repo Asciidoctor documentation site generator command-line frontend taking site.yml playbook spec consuming content sources from multiple git repositories producing static HTML JSON UI bundle for technical documentation publishing similar to ReadTheDocs Hugo Sphinx (OpenDevise team, JavaScript); commander
# upstream: https://antora.org/

_antora-cli() {
    local -a sub=(
        'generate:generate the site'
        'show:show site config'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '--silent[silent]' \
        '--stacktrace[show stack trace]' \
        '--log-level=+[l]:l:(all fatal error warn info debug trace silent)' \
        '--log-failure-level=+[l]:l:(none fatal error warn info debug trace)' \
        '--log-file=+[file]:file:_files' \
        '--log-format=+[fmt]:f:(pretty json)' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--clean[clean output dir]' \
        '--to-dir=+[dir]:dir:_files -/' \
        '--url=+[url]:str:' \
        '--title=+[title]:str:' \
        '--key-val=+[k=v]:str:' \
        '--asciidoc-attribute=+[k=v]:str:' \
        '--attribute=+[k=v]:str:' \
        '--ui-bundle-url=+[url]:str:' \
        '--ui-bundle-snapshot[treat bundle as snapshot]' \
        '--pull[pull repositories]' \
        '--git-credentials-path=+[file]:file:_files' \
        '--fetch[fetch updates]' \
        '--worktrees[use worktrees]' \
        '--no-redirect-facility[no redirect facility]' \
        '--redirect-facility=+[type]:t:(static nginx netlify gitlab httpd)' \
        '--generator=+[pkg]:str:' \
        '--extension=+[pkg]:str:' \
        '--require=+[pkg]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'antora-cli subcommand' sub ;;
        args)
            _arguments '*:playbook:_files -g "*.yml *.yaml"'
            ;;
    esac
}

_antora-cli "$@"
