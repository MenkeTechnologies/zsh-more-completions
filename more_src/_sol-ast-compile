#compdef sol-ast-compile
# Documentation: https://github.com/Consensys/solc-typed-ast/blob/master/README.md
# sol-ast-compile - solc-typed-ast CLI to generate and inspect the Solidity AST

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--stdin[read source from standard input]' \
  '--mode=[input mode]:mode:(sol)' \
  '--compiler-kind=[switch between native and wasm solc]:kind:(native wasm)' \
  '--tree[output the AST in tree format]' \
  '--locate-compiler-cache[print the compiler cache location]' \
  '--download-compilers=[pre-download compilers of a kind]:kind:(native wasm)' \
  '*:solidity file:_files -g "*.sol"' && ret=0

return ret
