#compdef spacefm
# Documentation: https://manpages.debian.org/bookworm/spacefm/spacefm.1.en.html
# Reference accessed: 2026-05-30
# spacefm — SpaceFM file manager (Ignorantguru's PCManFM fork with
# multi-panel + integrated terminal). GTK+ app with an active CLI for
# tab/panel/wallpaper/daemon control.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help summary]' \
  '(- *)--version[show version details]' \
  '(-t --new-tab -r --reuse-tab -w --new-window)'{-t,--new-tab}'[open folders in new tab of last window (default)]' \
  '(-t --new-tab -r --reuse-tab -w --new-window)'{-r,--reuse-tab}'[open folder in current tab of last window]' \
  '(-t --new-tab -r --reuse-tab -w --new-window)'{-w,--new-window}'[open folders in new window]' \
  '(-n --no-saved-tabs)'{-n,--no-saved-tabs}'[do not load saved tabs]' \
  '(-p --panel)'{-p,--panel=}'[open folders in panel (1-4)]:panel:(1 2 3 4)' \
  '--no-desktop[no function (compatibility)]' \
  '--desktop[launch desktop-manager daemon]' \
  '--desktop-pref=[show Preferences (optional tab number)]:tab:' \
  '(-d --daemon-mode)'{-d,--daemon-mode}'[run as a daemon]' \
  '(-c --config-dir)'{-c,--config-dir=}'[use DIR as configuration directory]:dir:_files -/' \
  '(-f --find-files)'{-f,--find-files}'[show file-search dialog]' \
  '--set-wallpaper=[set desktop wallpaper]:image:_files -g "*.(jpg|jpeg|png|gif|bmp|svg|webp|tif|tiff)"' \
  '(-g --dialog)'{-g,--dialog}'[show a custom dialog (see help)]' \
  '(-s --socket-cmd)'{-s,--socket-cmd}'[send a socket command (see help)]' \
  '--profile=[no function (compatibility)]:profile:' \
  '--display=[X display to use]:display:' \
  '*:folder:_files -/' \
  && ret=0

return ret
