#compdef slather
# _slather — Slather Xcode code-coverage reporter (Ruby); generates Cobertura/HTML/SonarQube/Gutter reports from Xcode coverage profdata
# upstream: https://github.com/SlatherOrg/slather

_slather() {
    local -a sub=(
        'coverage:generate coverage report'
        'setup:add cov flags to project'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'slather subcommand' sub ;;
        args)
            _arguments \
                '--build-directory+[derived data dir]:dir:_files -/' \
                '--source-directory+[source dir]:dir:_files -/' \
                '--output-directory+[output dir]:dir:_files -/' \
                '--scheme+[scheme]:scheme:' \
                '--workspace+[xcworkspace]:file:_files -g "*.xcworkspace"' \
                '--configuration+[config]:name:(Debug Release)' \
                '--binary-basename+[binary basename]:name:' \
                '--binary-file+[binary file]:file:_files' \
                '--source-files+[source glob]:glob:' \
                '--arch+[architecture]:arch:(arm64 x86_64)' \
                '--llvm-cov[use llvm-cov]' \
                '--cobertura-xml[Cobertura XML output]' \
                '--html[HTML output]' \
                '--simple-output[plain text]' \
                '--json[JSON output]' \
                '--teamcity[TeamCity format]' \
                '--gutter-json[gutter JSON for Vim]' \
                '--coveralls[upload to Coveralls]' \
                '--sonarqube-xml[SonarQube XML]' \
                '--show[open HTML in browser]' \
                '--verbose[verbose log]' \
                '--input-format+[input]:fmt:(profdata gcov auto)' \
                '--ignore+[ignore glob]:glob:' \
                '1:project:_files -g "*.xcodeproj"'
            ;;
    esac
}

_slather "$@"
