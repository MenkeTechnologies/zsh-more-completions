#compdef sdrmsd
# Documentation: https://rdock.github.io/documentation/html_docs/reference-guide/programs.html
# sdrmsd - rDock compute RMSD between docked poses and a reference.

local ret=1

_arguments -s -S \
  '(-o --out)'{-o+,--out=}'[output SD file with RMSD field]:file:_files' \
  '*:file:_files' && ret=0

return ret
