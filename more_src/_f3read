#compdef f3read
# Documentation: https://man.archlinux.org/search?q=f3read
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--start-at=+[first file num]:n:' \
  '--end-at=+[last file num]:n:' \
  '--max-read-rate=+[max rate KB/s]:rate:' \
  '--show-progress[show progress]' \
  '--no-show-progress[no progress]' \
  '*:directory:_files -/' && ret=0

return ret
