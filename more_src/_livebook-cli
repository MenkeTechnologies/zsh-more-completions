#compdef livebook
# _livebook-cli — interactive Elixir notebook (livebook-dev/livebook)
# upstream: https://github.com/livebook-dev/livebook
# Flags from lib/livebook_cli/server.ex (OptionParser switches).

_livebook-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'server:start the Livebook web app'
                'deploy:deploy a notebook to Livebook Teams'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                server)
                    _arguments \
                        '--cookie=[Erlang distributed-node cookie]:cookie:' \
                        '--ip=[bind IP address]:addr:' \
                        '--name=[distributed-node name]:name:' \
                        '(-p --port)'{-p+,--port=}'[HTTP port]:port:' \
                        '--home=[home directory]:dir:_files -/' \
                        '*:open-target (@home/@new/URL/file/dir):_files'
                    ;;
                deploy)
                    _arguments '*:.livemd notebook:_files -g "*.livemd"'
                    ;;
            esac
            ;;
    esac
}

_livebook-cli "$@"
