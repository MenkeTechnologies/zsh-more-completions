#compdef suattributes
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/attributes_parameter_estimation/suattributes.c
# Instantaneous trace attributes of SU data

local ret=1

_arguments -s -S \
  'mode=[attribute to compute]:mode:(amp phase uphase freq freqw thin bandwidth normamp fdenv sdenv q)' \
  'unwrap=[phase unwrapping control]:unwrap' \
  'wint=[windowing for freqw and thin modes]:wint' \
  '*:file:_files' && ret=0

return ret
