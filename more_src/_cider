#compdef cider
# Documentation: https://cidertool.github.io/cider/commands/commands/
# Cider - submit your builds to the Apple App Store

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug[enable debug mode]' \
  '(-f --config)'{-f,--config}'=[configuration file]:file:_files' \
  '1:command:(init release check completions docs)' \
  '*::args:->args' && ret=0

return ret
