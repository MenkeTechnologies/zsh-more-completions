#compdef abi3audit
# Documentation: https://pypi.org/project/abi3audit/
# auditing Python extensions for abi3 violations and tag mismatches

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--debug[emit debug statements; overrides ABI3AUDIT_LOGLEVEL]' \
  '(-v --verbose)'{-v,--verbose}'[give more output, pretty-printed results per audit step]' \
  '(-R --report)'{-R,--report}'[generate a JSON report; uses --output]' \
  '(-o --output)'{-o,--output}'+[path to write the JSON report to]:output:_files' \
  '(-s --summary)'{-s,--summary}'[always output a summary even without violations]' \
  '(-S --strict)'{-S,--strict}'[fail the entire audit if an individual audit step fails]' \
  '--assume-minimum-abi3=[assumed abi3 version if it cannot be detected]:version' \
  '*:spec:_files' && ret=0

return ret
