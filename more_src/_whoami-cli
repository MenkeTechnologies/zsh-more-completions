#compdef whoami-cli logname-cli arch-cli hostid-cli
# _whoami-cli — GNU coreutils whoami/logname/arch/hostid print user info CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_whoami-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]'
}

_whoami-cli "$@"
