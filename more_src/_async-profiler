#compdef asprof

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-d --duration)'{-d,--duration}'[Profiling duration in seconds]:seconds:' \
  '(-f --file)'{-f,--file}'[Output file name]:file:_files' \
  '(-o --output)'{-o,--output}'[Output format]:format:(flat traces collapsed flamegraph tree jfr)' \
  '(-e --event)'{-e,--event}'[Profiling event]:event:(cpu alloc lock wall itimer)' \
  '(-i --interval)'{-i,--interval}'[Sampling interval]:interval:' \
  '(-j --jstackdepth)'{-j,--jstackdepth}'[Maximum Java stack depth]:depth:' \
  '--alloc[Allocation profiling threshold]:bytes:' \
  '--lock[Lock profiling threshold]:nanoseconds:' \
  '--total[Accumulate total value instead of samples]' \
  '--chunksize[Approximate chunk size for JFR output]:bytes:' \
  '--chunktime[Chunk time limit for JFR output]:seconds:' \
  '--loop[Continuous profiling loop with given period]:period:' \
  '--cstack[C stack walking mode]:mode:(fp dwarf lbr no)' \
  '--begin[Start profiling trigger]:function:' \
  '--end[Stop profiling trigger]:function:' \
  '(-t --threads)'{-t,--threads}'[Profile different threads separately]' \
  '(-s --simple)'{-s,--simple}'[Simple class names instead of FQN]' \
  '(-g --sig)'{-g,--sig}'[Print method signatures]' \
  '(-a --ann)'{-a,--ann}'[Annotate Java methods]' \
  '--title[Flamegraph title]:title:' \
  '--width[Flamegraph width in pixels]:pixels:' \
  '--height[Flamegraph frame height in pixels]:pixels:' \
  '--minwidth[Minimum frame width in percent]:percent:' \
  '--reverse[Generate reverse flamegraph]' \
  '(-I --include)'{-I,--include}'[Include only matching stack traces]:pattern:' \
  '(-X --exclude)'{-X,--exclude}'[Exclude matching stack traces]:pattern:' \
  '--lib[Prepend library names to symbols]' \
  '(- *)'{-v,--version}'[Show version]' \
  '(- *)--help[Show help]' \
  '1:action or PID:->action' \
  '2:PID (Java process):->pid' \
  && ret=0

case $state in
  action)
    local -a actions=(
      'start:Start profiling'
      'stop:Stop profiling'
      'resume:Resume profiling'
      'check:Check if profiling is available'
      'status:Show profiling status'
      'meminfo:Show memory info'
      'list:List available events'
      'collect:Profile and output results'
    )
    _alternative \
      'actions:action:_describe -t actions "action" actions' \
      'pids:PID:_pids' \
      && ret=0
    ;;
  pid)
    _pids && ret=0
    ;;
esac

return ret
