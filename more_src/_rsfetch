#compdef rsfetch
# Documentation: https://github.com/Phate6660/rsfetch
# rsfetch - an INCREDIBLY fast fetch program

local ret=1

_arguments -s -S \
  '--help[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '-c[display the model of the CPU]' \
  '-D[display the name of the device]' \
  '-d[display the name of the distro]' \
  '-E[display the name of the user editor]' \
  '-e[display the user environment]' \
  '-h[display the hostname of the device]' \
  '-k[display the name of the kernel]' \
  '-m[display free/total memory]' \
  '-M[display currently playing music]' \
  '-s[display the name of the user shell]' \
  '-t[display the name of the user terminal]' \
  '-u[display the uptime]' \
  '-U[display the name of the user]' \
  '(-C --corner)'{-C,--corner}'=[set the corner character]:char:' \
  '(-p --packages)'{-p,--packages}'=[display package count]:manager:' \
  '(-T --temperature)'{-T,--temperature}'=[display CPU temperature]:unit:(C F)' && ret=0

return ret
