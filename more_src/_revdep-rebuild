#compdef revdep-rebuild
# Documentation: https://wiki.gentoo.org/wiki/Revdep-rebuild
# Gentoo reverse dependency rebuilder

_arguments -s -S \
  '(-C --nocolor)'{-C,--nocolor}'[turn off colored output]' \
  '(-d --debug)'{-d,--debug}'[print debug output]' \
  '(-e --exact)'{-e,--exact}'[rebuild packages with exact version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --ignore)'{-i,--ignore}'[ignore temporary files from previous runs]' \
  '(-k --keep-temp)'{-k,--keep-temp}'[do not delete temporary files on exit]' \
  '(-L --library)'{-L,--library}'[search for specified library]:library:' \
  '(-l --no-ld-path)'{-l,--no-ld-path}'[do not set LD_LIBRARY_PATH]' \
  '(-o --no-order)'{-o,--no-order}'[do not check build order]' \
  '(-p --pretend)'{-p,--pretend}'[show what would be rebuilt]' \
  '(-P --no-progress)'{-P,--no-progress}'[turn off progress meter]' \
  '(-q --quiet)'{-q,--quiet}'[less output]' \
  '(-v --verbose)'{-v,--verbose}'[more output]' \
  '--ignore-default-opts[ignore REVDEP_REBUILD_DEFAULT_OPTS]' \
  && return 0
