#compdef pkg_admin

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'audit:vulnerability check installed pkgs'
  'audit-pkg:vulnerability check named pkgs'
  'audit-batch:vulnerability check from file'
  'audit-history:print all vulnerabilities for base'
  'check:verify file checksums'
  'check-license:verify license condition'
  'check-pkg-vulnerabilities:validate pkg-vulnerabilities file'
  'check-signature:verify signed package'
  'check-single-license:validate license name'
  'config-var:print config variable value'
  'digest:SHA256 digest'
  'dump:dump package DB'
  'fetch-pkg-vulnerabilities:fetch pkg-vulnerabilities'
  'findbest:find best matching pkg'
  'gpg-sign-package:GPG-sign binary package'
  'lsall:list all matching packages'
  'lsbest:list best matching package'
  'pmatch:pattern match test'
  'rebuild:rebuild pkg DB'
  'rebuild-tree:rebuild +REQUIRED_BY files'
  'set:set installed-pkg variable'
  'unset:remove install variable'
  'x509-sign-package:X.509-sign binary package'
)

_arguments -C \
  '-b[base names only]' \
  '-C+[config file]:file:_files' \
  '-d+[lsdir]:dir:_files -/' \
  '-K+[pkg DB dir]:dir:_files -/' \
  '-q[quiet]' \
  '-S[null suffix glob]' \
  '-s+[suffix glob]:pattern:' \
  '(- *)-V[show version]' \
  '-v[verbose]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pkg_admin subcommand' subcommands && ret=0
    ;;
esac

return ret
