#compdef mcp-cli

# Zsh completion for mcp-cli
# https://github.com/philschmid/mcp-cli

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'info:Show all tools and parameters for a specific server or tool'
  'grep:Search for tools across all servers using a glob pattern'
  'call:Execute a tool with provided JSON arguments'
)

_arguments -s -S \
  '-d[list all servers and tools with full descriptions]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'mcp-cli command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (info)
        _arguments -s -S \
          '1:server:' \
          '2:tool:' && ret=0
        ;;
      (grep)
        _arguments -s -S \
          '1:pattern:' && ret=0
        ;;
      (call)
        _arguments -s -S \
          '1:server:' \
          '2:tool:' \
          '3:json:' && ret=0
        ;;
    esac
    ;;
esac

return ret
