#compdef mcp-cli
# Documentation: https://github.com/philschmid/mcp-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mcp-cli (philschmid)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'info:show tools and parameters for a specific server or tool'
  'grep:search for tools across all servers using a glob pattern'
  'call:execute a tool with provided JSON arguments'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --with-descriptions)'{-d,--with-descriptions}'[include tool descriptions in output]' \
  '(-c --config)'{-c,--config}'+[custom config file]:file:_files' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'mcp-cli command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (info)
        _arguments -s -S \
          '1:server:' \
          '2:tool:' && ret=0
        ;;
      (grep)
        _arguments -s -S \
          '1:pattern:' && ret=0
        ;;
      (call)
        _arguments -s -S \
          '1:server:' \
          '2:tool:' \
          '3:json:' && ret=0
        ;;
    esac
    ;;
esac

return ret
