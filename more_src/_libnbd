#compdef libnbd
# _libnbd — Red Hat libnbd Network Block Device client library CLI alias (libguestfs team, C); custom argparse — nbdinfo/nbdsh/nbdcopy
# upstream: https://gitlab.com/nbdkit/libnbd

_libnbd() {
    local -a sub=(
        'nbdinfo:show NBD server info'
        'nbdcopy:copy between NBD servers/files'
        'nbdsh:interactive nbd shell'
        'nbddump:dump NBD content'
        'nbdfuse:mount NBD as FUSE'
        'nbdublk:expose NBD via ublk'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'libnbd subcommand' sub ;;
        args)
            case $words[1] in
                nbdinfo) _arguments \
                    '--json[json output]' \
                    '--list[list exports]' \
                    '-L[list exports]' \
                    '--map=+[meta context]:str:' \
                    '--no-content[skip content metadata]' \
                    '--size[show size only]' \
                    '--totals[show totals]' \
                    '--uri[show uri]' \
                    '*:source:' ;;
                nbdcopy) _arguments \
                    '1:source:' \
                    '2:destination:' \
                    '--allocated[allocate dest]' \
                    '--connections=+[n]:n:' \
                    '-C+[n]:n:' \
                    '--destination-is-zero[dest is zero]' \
                    '--flush[flush on close]' \
                    '--no-extents[no extents]' \
                    '--progress[show progress]' \
                    '-p[show progress]' \
                    '--queue-size=+[bytes]:n:' \
                    '-q+[bytes]:n:' \
                    '--requests=+[n]:n:' \
                    '-R+[n]:n:' \
                    '--sparse=+[bytes]:n:' \
                    '-S+[bytes]:n:' \
                    '--threads=+[n]:n:' \
                    '-T+[n]:n:' \
                    '--verbose[verbose]' \
                    '-v[verbose]' ;;
                nbdsh) _arguments \
                    '--base-allocation[use base:allocation]' \
                    '-c+[python expression]:str:' \
                    '--command=+[python expression]:str:' \
                    '--connect=+[uri]:str:' \
                    '-u+[uri]:str:' \
                    '--opt-mode[opt mode]' \
                    '-n[no connect]' \
                    '--no-connect[no connect]' ;;
                nbddump) _arguments \
                    '*:source:' \
                    '--length=+[bytes]:n:' \
                    '-n+[bytes]:n:' \
                    '--offset=+[bytes]:n:' \
                    '-o+[bytes]:n:' \
                    '--strict[strict]' \
                    '-v[verbose]' ;;
            esac
            ;;
    esac
}

_libnbd "$@"
