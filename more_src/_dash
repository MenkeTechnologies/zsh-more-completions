#compdef dash dash-qt
# _dash — Dash Core dash-qt GUI desktop client CLI for the X11 PrivateSend InstantSend masternode-governance Bitcoin fork running the network wallet masternode-staking sporks chainlocks llmq quorum with optional Qt arguments for testnet regtest devnet reset wallet rescan reindex (dashpay team, C++/Qt); custom argparse
# upstream: https://github.com/dashpay/dash

_dash() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf dash.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-printtoconsole[print to console]' \
        '-debug=+[category]:c:(net mempool http bench zmq rpc walletdb estimatefee addrman selectcoins reindex cmpctblock rand prune libevent coindb leveldb chainlocks gobject instantsend llmq masternode mnpayments mnsync privatesend spork all)' \
        '-testnet[use testnet]' \
        '-devnet=+[name]:str:' \
        '-regtest[use regtest]' \
        '-rest[enable REST]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcport=+[port]:n:' \
        '-rpcbind=+[addr]:str:' \
        '-rpcallowip=+[cidr]:str:' \
        '-listen[enable inbound]' \
        '-port=+[port]:n:' \
        '-bind=+[host]:str:' \
        '-externalip=+[ip]:str:' \
        '-onion=+[host:port]:str:' \
        '-proxy=+[host:port]:str:' \
        '-maxconnections=+[N]:n:' \
        '-paytxfee=+[DASH/kB]:f:' \
        '-reindex[reindex]' \
        '-rescan[rescan]' \
        '-wallet=+[name]:str:' \
        '-masternode=+[b]:b:(0 1)' \
        '-masternodeblsprivkey=+[key]:str:' \
        '-llmqtype=+[t]:t:(llmq_50_60 llmq_400_60 llmq_400_85 llmq_5_60 llmq_test llmq_devnet llmq_25_67)' \
        '-disablegovernance[disable governance]' \
        '-privatesendrounds=+[N]:n:' \
        '-privatesendamount=+[N]:n:' \
        '-min[start minimized]' \
        '-resetguisettings[reset GUI settings]' \
        '-splash[show splash]' \
        '-style=+[Qt style]:s:(fusion windows windowsvista gtk2 macintosh)' \
        '-lang=+[locale]:str:' \
        '-uiplatform=+[platform]:p:(xcb wayland cocoa windows direct2d)'
}

_dash "$@"
