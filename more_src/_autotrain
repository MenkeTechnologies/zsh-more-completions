#compdef autotrain
# _autotrain — HuggingFace AutoTrain Advanced (huggingface/autotrain-advanced)
# upstream: https://github.com/huggingface/autotrain-advanced
# Subcommands from src/autotrain/cli/autotrain.py (argparse).

_autotrain() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-v --version)'{-v,--version}'[show AutoTrain version]' \
        '--config=[optional AutoTrain YAML configuration file]:file:_files -g "*.(yaml|yml)"' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_autotrain_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                llm|text-classification|image-classification|tabular|seq2seq|token-classification|text-regression|object-detection|sentence-transformers|image-regression|extractive-qa)
                    _arguments \
                        '--train[train the model]' \
                        '--data-path=[dataset path or hub id]:dataset:_files -/' \
                        '--model=[base model name (HuggingFace hub id or path)]:model:' \
                        '--project-name=[project name (output dir under ./<name>/)]:name:' \
                        '--token=[HuggingFace API token]:token:' \
                        '--push-to-hub[push the trained model to the hub]' \
                        '--username=[HuggingFace hub username]:user:' \
                        '--repo-id=[hub repository to push to (user/name)]:repo:' \
                        '--lr=[learning rate]:lr:' \
                        '--epochs=[number of training epochs]:n:' \
                        '--batch-size=[per-device batch size]:n:' \
                        '--warmup-ratio=[warmup ratio]:ratio:' \
                        '--gradient-accumulation=[gradient accumulation steps]:n:' \
                        '--optimizer=[optimizer]:optim:(adamw_torch adamw_torch_fused adamw_hf paged_adamw_8bit paged_adamw_32bit sgd adafactor)' \
                        '--scheduler=[lr scheduler]:scheduler:(linear cosine constant cosine_with_restarts polynomial)' \
                        '--weight-decay=[weight decay]:wd:' \
                        '--max-grad-norm=[max gradient norm]:norm:' \
                        '--seed=[random seed]:seed:' \
                        '--logging-steps=[steps between logs]:n:' \
                        '--save-total-limit=[max number of checkpoints to keep]:n:' \
                        '--mixed-precision=[mixed precision mode]:dtype:(no fp16 bf16)' \
                        '--quantization=[load model with quantization]:qmode:(4bit 8bit none)' \
                        '--peft[use PEFT / LoRA]' \
                        '--lora-r=[LoRA rank]:n:' \
                        '--lora-alpha=[LoRA alpha]:n:' \
                        '--lora-dropout=[LoRA dropout]:p:' && ret=0 ;;
                api)
                    _arguments \
                        '--host=[bind host]:host:' \
                        '--port=[bind port]:port:' && ret=0 ;;
                app)
                    _arguments \
                        '--host=[bind host]:host:' \
                        '--port=[bind port]:port:' && ret=0 ;;
                spacerunner)
                    _arguments \
                        '--project-name=[project name]:name:' \
                        '--script-path=[path to the training script]:file:_files' \
                        '--username=[HuggingFace user]:user:' \
                        '--token=[HuggingFace token]:token:' \
                        '--backend=[space hardware]:backend:(local spaces-cpu spaces-t4-small spaces-t4-medium spaces-a10g-small spaces-a10g-large spaces-a100-large)' && ret=0 ;;
                setup|tools)
                    _arguments \
                        '--update-torch[update torch to the latest compatible version]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_autotrain_commands] )) ||
_autotrain_commands() {
    local -a commands
    commands=(
        'llm:fine-tune large language models (causal-LM SFT/DPO/ORPO/Reward)'
        'text-classification:train a text-classification model'
        'image-classification:train an image-classification model'
        'tabular:train tabular classification / regression models'
        'seq2seq:train a sequence-to-sequence model'
        'token-classification:train a token-classification (NER) model'
        'text-regression:train a text-regression model'
        'object-detection:train an object-detection model'
        'sentence-transformers:train sentence-transformer / embedding models'
        'image-regression:train an image-regression model'
        'extractive-qa:train an extractive question-answering model'
        'app:launch the AutoTrain Gradio web UI'
        'api:launch the AutoTrain API server'
        'spacerunner:launch a training run on a HuggingFace Space'
        'setup:install / update AutoTrain runtime dependencies'
        'tools:miscellaneous helper tools'
    )
    _describe -t commands 'autotrain command' commands
}

_autotrain "$@"
