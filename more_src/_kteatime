# Documentation: https://invent.kde.org/utilities/kteatime/-/blob/master/src/main.cpp
# Reference accessed: 2026-05-16
# Verified: src/main.cpp lines 61-69 (QCommandLineParser + addOption(timeOption,nameOption))
# plus KAboutData::setupCommandLine standard set.
# Removed from prior file: --help-qt, --help-kde (KDE3/4-era; not in KF6 Qt6 parser).

# KTeaTime: KDE tea-steeping countdown
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '--desktopfile=[load specified desktop file]:file:_files -g "*.desktop"' \
  '(-t --time)'{-t,--time=}'[start a new tea with this time]:seconds:' \
  '(-n --tea-name)'{-n,--tea-name=}'[name for the tea started with --time]:name:' && ret=0
return ret
