#compdef kcmshell5 kcmshell6 kcmshell
# _kcmshell5 — KDE kcmshell (run a KConfigModule outside System Settings; --list enumerates installed KCMs, positional module is the .desktop name (e.g. kcm_keyboard, kcm_kded, fonts), trailing args are forwarded)
# upstream: https://invent.kde.org/plasma/plasma-workspace (libkworkspace/kcmshell.cpp)
# Flags from plasma-workspace src/kcmshell/kcmshell.cpp on tip.

_kcmshell5() {
    _arguments \
        '--help[show help]' \
        '--list[list installed KCM modules]' \
        '--lang+[language]:lang:' \
        '--icon+[window icon]:icon:' \
        '--caption+[window caption]:caption:' \
        '--silent[no error dialogs]' \
        '--args+[forward args to module]:args:' \
        '1:module:(kcm_keyboard kcm_mouse kcm_displayconfiguration kcm_kded kcm_powerdevilprofilesconfig kcm_notifications kcm_users kcm_clock kcm_fonts kcm_screenlocker kcm_landingpage kcm_componentchooser kcm_solid_actions kcm_workspace)'
}

_kcmshell5 "$@"
