#compdef argocd-account
# Documentation: https://argo-cd.readthedocs.io/en/stable/user-guide/commands/argocd_account/
# Argo CD account: manage account settings

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--auth-token=[authentication token]:token:' \
  '--server=[Argo CD server address]:server:' \
  '--insecure[skip server certificate and domain verification]' \
  '--grpc-web[enable gRPC-web protocol]' \
  '--config=[path to Argo CD config]:file:_files' \
  '--plaintext[disable TLS]' \
  '--port-forward[connect to a random argocd-server port using port forwarding]' \
  '--port-forward-namespace=[namespace name used for port forwarding]:namespace:' \
  '--core[CLI talks directly to Kubernetes instead of the Argo CD API server]' \
  '*::subcommand:(bcrypt can-i delete-token generate-token get get-user-info list session-token update-password)' && ret=0

return ret
