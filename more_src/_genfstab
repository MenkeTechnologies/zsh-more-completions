#compdef genfstab
# Documentation: https://man.archlinux.org/man/genfstab.8
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for genfstab - Arch Linux fstab generator

local -a arguments

arguments=(
  '-f+[restrict output to mountpoints matching prefix]:filter:_files -/'
  '-L[use LABEL= for source identifiers (shortcut for -t LABEL)]'
  '-p[exclude pseudofs mounts (default)]'
  '-P[include pseudofs mounts]'
  '-t+[tag to use for source identifiers]:tag:(LABEL UUID PARTLABEL PARTUUID)'
  '-U[use UUID= for source identifiers (shortcut for -t UUID)]'
  '-h[show help]'
  '1:root directory:_files -/'
)

_arguments -s $arguments
