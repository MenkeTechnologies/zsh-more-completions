#compdef genfstab

# Zsh completion for genfstab - Arch Linux fstab generator

local -a arguments

arguments=(
  '-f[filter root before generating]:root:_files -/'
  '-L[use LABEL= for source identifiers]'
  '-p[exclude pseudofs mounts]'
  '-P[include pseudofs mounts]'
  '-t[filter by filesystem type]:type:(ext2 ext3 ext4 xfs btrfs zfs vfat ntfs)'
  '-U[use UUID= for source identifiers]'
  '-u[use device paths for source identifiers]'
  '-h[show help information]'
  '1:root directory:_files -/'
)

_arguments -s $arguments
