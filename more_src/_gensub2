#compdef gensub2
# UCSC kent/parasol: generate condor submission file from template and file lists

local ret=1

_arguments -s -S \
  '-group1[order Aa Ab Ac Ba Bb Bc Ca Cb Cc]' \
  '-group2[order Aa Ba Ca Ab Bb Cb Ac Bc Cc]' \
  '1:file list 1:_files' \
  '2:file list 2 (or single, selfPair):_files' \
  '3:template file:_files' \
  '4:output file:_files' && ret=0

return ret
