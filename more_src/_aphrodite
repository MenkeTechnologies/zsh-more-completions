#compdef aphrodite
# Documentation: https://github.com/PygmalionAI/aphrodite-engine
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for aphrodite - high-throughput LLM serving engine (PygmalionAI)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'aphrodite command' \
      'run[launch a model with OpenAI-compatible API on port 2242]' && ret=0
    ;;
  args)
    _arguments \
      '--gpu-memory-utilization[GPU VRAM allocation fraction]:frac:' \
      '--port[server port]:port:' \
      '--host[server host]:host:' && ret=0
    ;;
esac

return ret
