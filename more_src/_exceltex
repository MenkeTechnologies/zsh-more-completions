#compdef exceltex

local -a arguments

arguments=(
    '-c[Clean auxiliary files]'
    '-h[Show help]'
    '-o[Output file]:output file:_files'
    '-r[Rerun on every LaTeX run]'
    '-s[Spreadsheet file]:spreadsheet:_files -g "*.{xls,xlsx,ods}"'
    '-v[Verbose output]'
    '*:TeX file:_files -g "*.tex"'
)

_arguments -s -S $arguments
