#compdef northflank nf

local curcontext="$curcontext" state line ret=1

_northflank_commands() {
  local -a commands=(
    'login:Login to Northflank'
    'logout:Logout from Northflank'
    'context:Manage contexts'
    'projects:Manage projects'
    'services:Manage services'
    'addons:Manage addons'
    'jobs:Manage jobs'
    'forward:Forward a port to a local port'
    'exec:Execute a command in a service container'
    'logs:View logs'
    'create:Create a resource'
    'scale:Scale a service'
  )
  _describe -t commands 'northflank command' commands
}

_northflank_resource_subcommands() {
  local -a subcmds=(
    'list:List resources'
    'get:Get a resource'
    'create:Create a resource'
    'update:Update a resource'
    'delete:Delete a resource'
  )
  _describe -t commands 'subcommand' subcmds
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)'{-V,--version}'[Show version]' \
  {-o,--output}'[Output format]:format:(json yaml table)' \
  '--project-id[Project ID]:project-id' \
  '--service-id[Service ID]:service-id' \
  '--api-key[API key]:api-key' \
  '1:command:_northflank_commands' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    case "$words[1]" in
      login)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--api-key[API key]:api-key' \
          && ret=0
        ;;
      logout)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          && ret=0
        ;;
      context)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:((set\:"Set context" get\:"Get current context" list\:"List contexts"))' \
          && ret=0
        ;;
      projects|services|addons|jobs)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '--project-id[Project ID]:project-id' \
          '1:subcommand:_northflank_resource_subcommands' \
          '*:name' \
          && ret=0
        ;;
      forward)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--project-id[Project ID]:project-id' \
          '--service-id[Service ID]:service-id' \
          '--port[Remote port]:port' \
          '--local-port[Local port]:port' \
          && ret=0
        ;;
      exec)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--project-id[Project ID]:project-id' \
          '--service-id[Service ID]:service-id' \
          '*:command' \
          && ret=0
        ;;
      logs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--project-id[Project ID]:project-id' \
          '--service-id[Service ID]:service-id' \
          '--follow[Follow log output]' \
          '--tail[Number of lines to show]:lines' \
          && ret=0
        ;;
      create)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--project-id[Project ID]:project-id' \
          && ret=0
        ;;
      scale)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--project-id[Project ID]:project-id' \
          '--service-id[Service ID]:service-id' \
          '--replicas[Number of replicas]:replicas' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
