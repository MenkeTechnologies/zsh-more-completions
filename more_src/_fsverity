#compdef fsverity

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'digest:compute file digest'
  'dump_metadata:dump fs-verity metadata'
  'enable:enable fs-verity on file'
  'measure:print fs-verity digest'
  'sign:sign a file'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'fsverity command' commands && ret=0 ;;
esac

return ret
