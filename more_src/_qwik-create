#compdef create-qwik qwik-create
# _qwik-create — Qwik / QwikCity scaffolder (Misko Hevery + Builder.io); resumable-component framework with zero-hydration
# upstream: https://github.com/QwikDev/qwik

_qwik-create() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--name+[project name]:name:' \
        '--starter+[starter template]:starter:(playground empty website blog auth-helpers tutorial library)' \
        '--no-install[skip install]' \
        '--install[install deps]' \
        '--git[init git]' \
        '--no-git[skip git init]' \
        '--ci[ci mode (no prompts)]' \
        '--it[interactive prompts]' \
        '--dry-run[dry run]' \
        '--package-manager+[pkg manager]:pm:(npm yarn pnpm bun)' \
        '1:dir or starter:_files -/'
}

_qwik-create "$@"
