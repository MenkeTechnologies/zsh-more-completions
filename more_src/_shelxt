#compdef shelxt
# Documentation: http://shelx.uni-goettingen.de/shelxt_keywords.php
# SHELXT dual-space structure solution (invoked as: shelxt name).

local ret=1

_arguments -s -S \
  '-L+[Laue group N (SADABS code)]:N:' \
  '-t+[number of threads for P1 stage]:n:' \
  '-d+[highest resolution to employ]:d:' \
  '-e+[fill out missing data to resolution]:d:' \
  '-q+[structure factors Go=EqFo(1-q)]:q:' \
  '-i+[NGo-(N-1)Gc map iterations]:N:' \
  '-o[switch off Patterson superposition]' \
  '-k+[apply random omit every kth cycle]:k:' \
  '-f+[randomly omit fraction X of atoms]:X:' \
  '-z+[sigma threshold for P1 peak-search]:z:' \
  '-u+[tangent expansion for E>X after random omit]:X:' \
  '-v+[atomic volume threshold in Angstroms]:v:' \
  '-m+[initial P1 dual space iterations]:m:' \
  '-b+[spread factor for atom masks]:b:' \
  '-j+[CFOM calculation coefficient]:j:' \
  '-y[alternative CFOM using chemical figure of merit]' \
  '-x+[accept if CFOM > X]:X:' \
  '-s+[space group name (use _ for /)]:sg:' \
  '-c[restrict to Sohncke space groups]' \
  '-n[restrict to non-centrosymmetric space groups]' \
  '-w+[worst alpha gap for a possible solution]:w:' \
  '-p+[max atoms in full matrix]:n:' \
  '-g+[smallest gap in R1 to best centric]:g:' \
  '-h+[halt if R1 less than this]:R1:' \
  '-r+[radius around peak for density integration]:r:' \
  '-a[search ALL space groups in given Laue group]' \
  '*:name:_files' && ret=0

return ret
