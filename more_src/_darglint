#compdef darglint
# Documentation: https://github.com/terrencepreilly/darglint
# darglint - a Python docstring argument linter

local ret=1

_arguments -s -S \
  '(-v --verbosity)'{-v,--verbosity}'[set verbosity level (default 1)]:level:(1 2)' \
  '-m[message template python format string]:template:' \
  '(-s --docstring-style)'{-s,--docstring-style}'[docstring style to parse]:style:(sphinx numpy google)' \
  '--log-level[logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '*:file:_files -g "*.py"' && ret=0

return ret
