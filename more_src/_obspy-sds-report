#compdef obspy-sds-report
# ObsPy: generate HTML report on latency/availability of an SDS archive

local ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-r --sds-root)'{-r,--sds-root}'+[root folder of SDS archive]:dir:_files -/' \
  '(-o --output)'{-o,--output}'+[output path prefix without suffix]:file:_files' \
  '(-u --update)'{-u,--update}'[only update latency information]' \
  '*'{-l,--location}'=[location code to look for]:location' \
  '*'{-c,--channel}'=[channel code to look for]:channel' \
  '*'{-i,--id}'=[additional SEED ID to include]:id' \
  '*--skip=[network or station to skip]:id' \
  '(-f --format)'{-f,--format}'+[waveform format of SDS archive]:format' \
  '--check-backwards-days=[check latency backwards this many days]:days' \
  '--check-quality-days=[compute availability/gaps over this many days]:days' \
  '--latency-warn=[latency warning threshold in seconds]:seconds' \
  '--latency-warn-color=[latency warning colour]:color' \
  '--latency-error=[latency error threshold in seconds]:seconds' \
  '--latency-error-color=[latency error colour]:color' \
  '--percentage-warn=[data availability percentage warning threshold]:percent' \
  '--gaps-warn=[gap/overlap number warning threshold]:count' \
  '--data-quality-warn-color=[data quality warning colour]:color' \
  '--outdated-color=[colour for streams with no data in range]:color' \
  '--ok-color=[colour for streams passing all checks]:color' \
  '--background-color=[page background colour]:color' && ret=0

return ret
