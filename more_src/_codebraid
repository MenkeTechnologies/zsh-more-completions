#compdef codebraid
# Documentation: https://github.com/gpoore/codebraid
# Codebraid: execute code blocks in Pandoc Markdown and embed the output

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)--version[show version and exit]' \
  '--live-output[display code stdout/stderr live during execution]' \
  '--no-execute[do not execute code; use cached output only]' \
  '--only-code-output=[write code output as JSON Lines to stdout]:format:(codebraid_preview)' \
  '--cache-dir=[set the cache directory]:dir:_files -/' \
  '--no-cache[disable caching]' \
  '--overwrite[overwrite existing output files]' \
  '1:subcommand:(pandoc)' \
  '*::pandoc args:_files' && ret=0

return ret
