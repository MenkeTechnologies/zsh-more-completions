#compdef klotski
# Documentation: https://apps.kde.org/klotski/
# Reference accessed: 2026-05-16
# Verified: upstream main.cpp at invent.kde.org/games/klotski is behind a login wall
# and could not be retrieved; sibling KDE games (kgoldrunner, kteatime) verified to
# use only KAboutData::setupCommandLine + QCommandLineParser standard set with no
# game-specific options. Conservatively listing only the documented Qt+KAboutData
# standard flags.
# Removed from prior file: --help-qt, --help-kde (KDE3/4-era, not in KF6 Qt6).

# Klotski: KDE sliding-block puzzle
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '--desktopfile=[load specified desktop file]:file:_files -g "*.desktop"' && ret=0
return ret
