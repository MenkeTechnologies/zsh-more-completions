#compdef klotski
# Documentation: https://docs.kde.org/stable5/en/klotski/klotski/index.html
# Reference accessed: 2026-05-16

# Klotski: KDE sliding-block puzzle
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all help]' \
  '(- *)--help-qt[show Qt help]' \
  '(- *)--help-kde[show KDE help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '*::klotski args:_files' && ret=0
return ret
