#compdef xinference
# Documentation: https://inference.readthedocs.io/en/latest/getting_started/using_xinference.html
# Xorbits Inference: serve and manage local LLM/embedding/image models

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-e --endpoint)'{-e,--endpoint}'=[supervisor endpoint URL]:url:' \
  '(-H --host)'{-H,--host}'=[host to bind]:host:' \
  '(-p --port)'{-p,--port}'=[port to bind]:port:' \
  '--log-level=[logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '1:command:((
    launch\:"launch a model instance"
    list\:"list running models"
    terminate\:"terminate a running model"
    register\:"register a custom model"
    unregister\:"remove a custom model registration"
    registrations\:"list model registrations"
    cached\:"list cached models"
    remove-cache\:"remove cached model files"
    cal-model-mem\:"calculate model memory requirements"
    engine\:"query inference engine parameters"
    chat\:"start an interactive chat"
    generate\:"generate text completions"
    login\:"authenticate user"
    vllm-models\:"list vLLM-supported models"
    stop-cluster\:"stop the cluster"
  ))' \
  '*::arg:->args' && ret=0

return ret
