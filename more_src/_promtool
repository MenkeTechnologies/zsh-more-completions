#compdef promtool

# Zsh completion for promtool - Prometheus tooling utility

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:check the resources for validity'
  'query:run queries against a Prometheus server'
  'test:unit testing'
  'tsdb:run TSDB commands'
)

_arguments -s -S \
  '1:command:->command' \
  '--version[show version]' \
  '--help[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'promtool command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (check)
        local -a check_cmds=(
          'config:check if the config files are valid'
          'rules:check if the rule files are valid'
          'metrics:check if metric names are valid'
          'web-config:check if the web config files are valid'
          'healthy:check health of Prometheus server'
          'ready:check readiness of Prometheus server'
        )
        _arguments -s -S \
          '1:subcommand:->check_cmd' \
          '*:: :->check_args' && ret=0
        case $state in
          (check_cmd)
            _describe -t commands 'check subcommand' check_cmds && ret=0
            ;;
          (check_args)
            case $words[1] in
              (config)
                _arguments '1:config file:_files' && ret=0
                ;;
              (rules)
                _arguments \
                  '--lint[linting settings]:setting:(all duplicate-rules none)' \
                  '--lint-fatal[make lint errors fatal]' \
                  '*:rule file:_files' && ret=0
                ;;
              (web-config)
                _arguments '1:web config file:_files' && ret=0
                ;;
              (metrics)
                _arguments '*:metric name' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (query)
        local -a query_cmds=(
          'instant:run instant query'
          'range:run range query'
          'series:query series'
          'labels:query label values'
        )
        _arguments -s -S \
          '1:subcommand:->query_cmd' \
          '*:: :->query_args' && ret=0
        case $state in
          (query_cmd)
            _describe -t commands 'query subcommand' query_cmds && ret=0
            ;;
          (query_args)
            case $words[1] in
              (instant)
                _arguments -s -S \
                  '--time[evaluation timestamp]:time' \
                  '--url[Prometheus server URL]:url' \
                  '--http.config.file[HTTP client config file]:file:_files' \
                  '1:query expression' && ret=0
                ;;
              (range)
                _arguments -s -S \
                  '--start[query range start]:time' \
                  '--end[query range end]:time' \
                  '--step[query step size]:duration' \
                  '--url[Prometheus server URL]:url' \
                  '--http.config.file[HTTP client config file]:file:_files' \
                  '1:query expression' && ret=0
                ;;
              (series)
                _arguments -s -S \
                  '--match[series selector]:selector' \
                  '--start[start time]:time' \
                  '--end[end time]:time' \
                  '--url[Prometheus server URL]:url' \
                  '--http.config.file[HTTP client config file]:file:_files' && ret=0
                ;;
              (labels)
                _arguments -s -S \
                  '--match[series selector]:selector' \
                  '--start[start time]:time' \
                  '--end[end time]:time' \
                  '--url[Prometheus server URL]:url' \
                  '--http.config.file[HTTP client config file]:file:_files' \
                  '1:label name' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (test)
        local -a test_cmds=(
          'rules:unit tests for rules'
        )
        _arguments -s -S \
          '1:subcommand:->test_cmd' \
          '*:: :->test_args' && ret=0
        case $state in
          (test_cmd)
            _describe -t commands 'test subcommand' test_cmds && ret=0
            ;;
          (test_args)
            case $words[1] in
              (rules)
                _arguments \
                  '--run[test name regex filter]:regex' \
                  '--diff[show diff on failure]' \
                  '*:test file:_files' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (tsdb)
        local -a tsdb_cmds=(
          'bench:run benchmarks'
          'analyze:analyze TSDB block'
          'list:list TSDB blocks'
          'dump:dump TSDB block samples'
          'create-blocks-from:create TSDB blocks from input'
          'compact:compact TSDB blocks'
        )
        _arguments -s -S \
          '1:subcommand:->tsdb_cmd' \
          '*:: :->tsdb_args' && ret=0
        case $state in
          (tsdb_cmd)
            _describe -t commands 'tsdb subcommand' tsdb_cmds && ret=0
            ;;
          (tsdb_args)
            case $words[1] in
              (analyze)
                _arguments \
                  '--block[block id]:block' \
                  '--limit[limit number of items]:number' \
                  '--extended[show extended statistics]' \
                  '1:db path:_directories' && ret=0
                ;;
              (list)
                _arguments \
                  '--human-readable[print human readable values]' \
                  '1:db path:_directories' && ret=0
                ;;
              (dump)
                _arguments \
                  '--min-time[minimum timestamp]:timestamp' \
                  '--max-time[maximum timestamp]:timestamp' \
                  '--match[series selector]:selector' \
                  '1:db path:_directories' && ret=0
                ;;
              (compact)
                _arguments '1:db path:_directories' && ret=0
                ;;
              (create-blocks-from)
                local -a cb_cmds=(
                  'openmetrics:create blocks from OpenMetrics input'
                  'rules:create blocks from recording rules'
                )
                _arguments -s -S \
                  '1:subcommand:->cb_cmd' \
                  '*:: :->cb_args' && ret=0
                case $state in
                  (cb_cmd) _describe -t commands 'create-blocks-from subcommand' cb_cmds && ret=0 ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
