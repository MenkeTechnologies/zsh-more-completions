#compdef promtool

# Zsh completion for promtool - Prometheus CLI utility

local -a subcommands
subcommands=(
  'check:Check resources for validity'
  'query:Run queries against a Prometheus server'
  'debug:Fetch debug information'
  'push:Push metrics to a push gateway'
  'test:Unit test rule files'
  'tsdb:Run tsdb commands'
  'unittest:Unit test rule files (deprecated, use test rules)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:subcommand:->subcmd' \
  '*:: :->args'

case $state in
  subcmd)
    _describe -t subcommands 'promtool subcommand' subcommands
    ;;
  args)
    case $words[1] in
      check)
        local -a check_cmds
        check_cmds=(
          'config:Check if a config file is valid'
          'rules:Check if a rule file is valid'
          'metrics:Check if metric names follow best practices'
          'web-config:Check if a web config file is valid'
          'service-discovery:Check service discovery configurations'
          'healthy:Check if a Prometheus server is healthy'
          'ready:Check if a Prometheus server is ready'
        )
        _arguments -C \
          '1:check subcommand:->check_sub' \
          '*:: :->check_args'
        case $state in
          check_sub)
            _describe -t check_cmds 'check subcommand' check_cmds
            ;;
          check_args)
            case $words[1] in
              config)
                _arguments '*:config file:_files'
                ;;
              rules)
                _arguments '*:rules file:_files'
                ;;
              web-config)
                _arguments '*:web config file:_files'
                ;;
              *)
                _arguments '*:arguments'
                ;;
            esac
            ;;
        esac
        ;;
      query)
        local -a query_cmds
        query_cmds=(
          'instant:Run an instant query'
          'range:Run a range query'
          'labels:Run a labels query'
          'series:Run a series query'
        )
        _arguments -C \
          '1:query subcommand:->query_sub' \
          '*:: :->query_args'
        case $state in
          query_sub)
            _describe -t query_cmds 'query subcommand' query_cmds
            ;;
        esac
        ;;
      debug)
        local -a debug_cmds
        debug_cmds=(
          'pprof:Fetch profiling debug information'
          'metrics:Fetch metrics debug information'
          'all:Fetch all debug information'
        )
        _arguments -C \
          '1:debug subcommand:->debug_sub' \
          '*:: :->debug_args'
        case $state in
          debug_sub)
            _describe -t debug_cmds 'debug subcommand' debug_cmds
            ;;
        esac
        ;;
      push)
        local -a push_cmds
        push_cmds=(
          'metrics:Push metrics to a push gateway'
        )
        _arguments -C \
          '1:push subcommand:->push_sub' \
          '*:: :->push_args'
        case $state in
          push_sub)
            _describe -t push_cmds 'push subcommand' push_cmds
            ;;
        esac
        ;;
      test)
        local -a test_cmds
        test_cmds=(
          'rules:Unit test rule files'
        )
        _arguments -C \
          '1:test subcommand:->test_sub' \
          '*:: :->test_args'
        case $state in
          test_sub)
            _describe -t test_cmds 'test subcommand' test_cmds
            ;;
          test_args)
            _arguments '*:rules file:_files'
            ;;
        esac
        ;;
      tsdb)
        local -a tsdb_cmds
        tsdb_cmds=(
          'bench:Run benchmarks against storage'
          'analyze:Analyze TSDB blocks'
          'list:List TSDB blocks'
          'dump:Dump samples from a TSDB'
          'create-blocks-from:Create TSDB blocks from input'
        )
        _arguments -C \
          '1:tsdb subcommand:->tsdb_sub' \
          '*:: :->tsdb_args'
        case $state in
          tsdb_sub)
            _describe -t tsdb_cmds 'tsdb subcommand' tsdb_cmds
            ;;
        esac
        ;;
      unittest)
        _arguments '*:rules file:_files'
        ;;
      *)
        _arguments '*:arguments'
        ;;
    esac
    ;;
esac
