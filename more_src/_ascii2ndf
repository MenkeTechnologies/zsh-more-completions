#compdef ascii2ndf
# Documentation: https://starlink.eao.hawaii.edu/docs/sun55.htx/sun55ss1.html
# CONVERT ASCII2NDF - convert a text file to an NDF

local ret=1

_arguments -C \
  'IN=[input text file containing array data]:text file:_files' \
  'OUT=[output NDF data structure]:NDF file:_files' \
  'COMP=[NDF component to create]:component:(Data Quality Variance)' \
  'FITS=[initial records contain a FITS header]:flag:(TRUE FALSE)' \
  'MAXLEN=[maximum record length in bytes]:length:' \
  'SHAPE=[NDF dimensions e.g. [40,30,20]]:shape:' \
  'SKIP=[number of header records to skip]:count:' \
  'TYPE=[output data type]:type:(_REAL _INTEGER _DOUBLE _WORD _UWORD _BYTE _UBYTE)' \
  '*:text file:_files' && ret=0

return ret
