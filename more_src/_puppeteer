#compdef puppeteer
# Documentation: https://man.archlinux.org/search?q=puppeteer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install a browser binary'
  'launch:launch an installed browser'
  'list:list installed browsers'
  'clear:remove installed browsers'
  'help:show help'
  'version:show version'
)

local -a browsers=(
  'chrome:Chrome (Chrome for Testing)'
  'chrome-headless-shell:headless shell'
  'chromium:Chromium'
  'firefox:Firefox'
  'chromedriver:ChromeDriver'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--path=[install path]:dir:_files -/' \
  '--platform=[target platform]:platform:(linux mac mac_arm win64 win32)' \
  '--base-url=[base URL for downloads]:url:' \
  '--system[install system-wide]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'puppeteer command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '--path=[install path]:dir:_files -/' \
          '--platform=[target platform]:platform:(linux mac mac_arm win64 win32)' \
          '--base-url=[base URL for downloads]:url:' \
          '--install-deps[install required system dependencies]' \
          '*::browser:browsers' && ret=0 ;;
      (launch)
        _arguments \
          '--path=[install path]:dir:_files -/' \
          '--detached[launch detached]' \
          '--system[use system-wide install]' \
          '*::browser:browsers' && ret=0 ;;
      (list|clear)
        _arguments \
          '--path=[install path]:dir:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
