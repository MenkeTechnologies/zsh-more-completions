#compdef vykar
# ---------------------------------------------------------------------------
# vykar — BorgBase's "Fast, encrypted, deduplicated backups in Rust":
#         next-generation borg-compatible-philosophy backup CLI with
#         content-defined chunking + BLAKE2b keyed chunk-IDs + AEAD
#         encryption + lz4/zstd compression + retention-policy-driven
#         pruning + SFTP/local/repository-mode backends.  The Rust
#         answer to borgbackup (Python) and restic (Go) — same
#         architectural pattern (chunk store + encrypted blob layer +
#         snapshot metadata layer) but with Rust's memory safety +
#         single-binary deployment.  Released by BorgBase, the hosted-
#         backup service company that has run borgbackup as a SaaS
#         for years and is investing in the Rust rewrite for next-
#         generation performance (Rust, 630★)
#
# upstream: https://github.com/borgbase/vykar
#           (binary at crates/vykar-cli/ in the workspace)
# author : BorgBase — the hosted backup service that also operates
#          the borgbase.com SaaS managed-borgbackup offering, and
#          maintains the broader vykar ecosystem (vykar-types,
#          vykar-common, vykar-crypto, vykar-storage, vykar-core,
#          vykar-protocol, vykar-server, vykar-gui)
# license: GPL-3.0-only
#
# Source-direct completion: every subcommand below is verbatim from
# crates/vykar-cli/src/cli.rs on the borgbase/vykar tip — clap
# `#[derive(Subcommand)]` Commands enum variants parsed exactly as
# declared, with per-variant flags (-R/--repo selector, -S/--source
# filter, -l/--label, --compression, --connections, --threads, -n/
# --dry-run, --list, --compact, --verify, --verify-data, --distrust-
# server, --repair, etc) preserved.
#
# Direct deps from crates/vykar-cli + workspace Cargo.toml (selected):
#   zstd                 ^0.13     ← canonical Rust Zstandard
#                                     compression library (this axis)
#                                     — by Alexandre Bury (gyscos/
#                                     zstd-rs); Rust bindings for the
#                                     reference zstd C library by
#                                     Yann Collet (Facebook/Meta;
#                                     the same author who created
#                                     LZ4).  Provides `Encoder` /
#                                     `Decoder` streams with the
#                                     full zstd compression-level
#                                     range (-22..=22, where 0 is
#                                     default level 3, negative
#                                     values are ultra-fast modes,
#                                     and 22 is "long-mode" with
#                                     larger windows for better
#                                     ratio at the cost of memory).
#                                     The `experimental` feature
#                                     exposes the dictionary-training
#                                     APIs (DICTIONARY_BUILDER /
#                                     CDictBuilder) that enable
#                                     per-collection dictionaries —
#                                     critical for small-blob
#                                     workloads where the per-blob
#                                     overhead of a stand-alone
#                                     compression context would dwarf
#                                     the compressed payload.  THE
#                                     Rust answer to "compress with
#                                     zstd from a Rust process" —
#                                     used by every Rust backup /
#                                     archive / database tool that
#                                     ships compression: vykar (this
#                                     CLI), restic-rs experiments,
#                                     allenai/dolma (OLMo training-
#                                     data tools), phiresky/sqlite-
#                                     zstd (row-level SQLite
#                                     compression), vortex-data/
#                                     vortex (columnar framework),
#                                     onecodex/needletail
#                                     (bioinformatics).  vykar uses
#                                     it inside vykar-storage's
#                                     blob-pack layer — every backup
#                                     chunk written to the
#                                     repository is optionally
#                                     compressed with the algorithm
#                                     selected by --compression
#                                     (`lz4` / `zstd` / `none`)
#                                     before being encrypted with
#                                     AEAD.  zstd is the recommended
#                                     algorithm for most workloads
#                                     because it achieves ~3x better
#                                     compression ratios than lz4 at
#                                     comparable decompression speeds
#                                     for typical backup content.
#   clap (with derive + env)        (CLI parser)
#   blake2 + zeroize + rand         (cryptographic primitives — BLAKE2b
#                                     for content-defined chunking +
#                                     chunk IDs, zeroize for secret-
#                                     memory hygiene, rand for AEAD
#                                     nonces)
#   tokio + crossbeam-channel       (async runtime + cross-thread
#                                     channels for parallel upload /
#                                     verify / compaction)
#   comfy-table                     (terminal table rendering for
#                                     `vykar list` / `vykar info`
#                                     output)
#   serde + serde_yaml + serde_json + rmp-serde
#                                   (config + protocol serialization;
#                                     rmp-serde is the on-disk
#                                     binary format for blob metadata)
#   croner                          (cron-expression parser for the
#                                     `vykar daemon` scheduled-backup
#                                     mode)
#   ureq + tiny_http                (HTTP client + tiny built-in
#                                     server for the `vykar mount`
#                                     WebDAV browsing mode)
#   chrono                          (timestamp handling for snapshot
#                                     creation + retention policy
#                                     comparisons)
#
# vykar's design lineage: borg (Python) introduced content-defined-
# chunking + deduplicating-encrypted backups in 2010s, restic (Go)
# refined the model with snapshot-based history in mid-2010s, and
# vykar brings the same architecture to Rust with single-binary
# deployment + memory safety + faster cryptographic primitives.  The
# operational workflow mirrors borg/restic closely: `vykar init -R
# /path/to/repo` initializes a repository, `vykar backup -R repo
# path1 path2` creates a new snapshot, `vykar list -R repo` lists
# snapshots, `vykar restore -R repo <snap> <dest>` restores files,
# `vykar prune -R repo` enforces retention policies, `vykar check -R
# repo --repair` verifies integrity (and optionally fixes corruption).
# The differentiator vs restic: vykar's `daemon` mode runs scheduled
# backups via the embedded croner cron parser without needing
# external scheduling (no systemd timer / cron entry / launchd plist),
# and `vykar mount` exposes a WebDAV server so snapshots can be
# browsed in any file manager that speaks WebDAV instead of needing
# a FUSE driver like restic mount.
#
# ============================================================================
# === AXIS 194 OPENS — Zstandard compression libraries =====================
# === Rust=249 OPENS at slot 1/0/0 ========================================
# ============================================================================
# Axis position: Rust=249 OPENS Axis 194 at slot 1/0/0 — the first of the
# three lanes for the canonical Zstandard compression library trio.  The
# axis anchors on a single pure-host-language wrapper (or rewrite) of
# Yann Collet's reference zstd C library, exposing the full compression
# level range (-22..=22), streaming encoder/decoder, and dictionary-
# training APIs for per-collection optimization:
#
#     Rust    : zstd                       by Alexandre Bury (gyscos/
#                                              zstd-rs); Rust bindings
#                                              for the reference zstd
#                                              C library by Yann Collet
#                                              (Facebook/Meta).
#                                              Default-on cdylib FFI to
#                                              the upstream C; the
#                                              `pure` feature switches
#                                              to a pure-Rust port
#                                              (zstd-safe) at some
#                                              perf cost.
#                 → vykar (BorgBase — "Fast, encrypted, deduplicated
#                           backups in Rust"; Rust answer to borg
#                           (Python) and restic (Go) — same content-
#                           defined-chunking + AEAD + retention-policy
#                           architecture but with single-binary
#                           Rust deployment; zstd compression layer
#                           inside vykar-storage's blob-pack layer;
#                           14 subcommands; 630★ GPL-3.0)
#                 _vykar           [Rust=249 OPENS Axis 194, 1/0/0]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#
#     Go      : (next round — Go=249, slot 2/0/0)
#                Canonical Go zstd: `github.com/klauspost/compress/
#                zstd` by Klaus Post — pure-Go Zstandard implementation
#                without CGO, part of the broader klauspost/compress
#                umbrella that also ships pure-Go gzip / s2 (LZ4-
#                compatible) / flate.  THE Go answer to "compress
#                with zstd from a Go process without CGO" — used by
#                Caddy, Cloudflare's quiche-go, every Go server that
#                ships compressed HTTP responses, every Go data store
#                that compresses on disk.  Alternative is valyala/
#                gozstd (CGO bindings to the C library, faster but
#                requires libzstd available at compile + runtime).
#                [TBD next-round consumer]
#
#     JS/Node : (Axis 194 CLOSES at TS-Node=249, slot 1/1/1)
#                Canonical JS zstd: `@bokuweb/zstd-wasm` by bokuweb
#                or `fzstd` by 101arrowz (the same author behind
#                fflate, the canonical pure-JS gzip).  WASM-backed
#                wrappers around either the reference C library
#                (zstd-wasm) or a pure-JS port (fzstd).  [TBD closer
#                consumer]
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=249     ← THIS FILE          (axis 194 OPENS, slot 1/0/0)
#   Go=249       ← next round         (axis 194 continues, slot 2/0/0)
#   TS-Node=249  ← round after        (axis 194 CLOSES at triple-249, 1/1/1)
# ============================================================================

_vykar() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'init:initialize a new repository at the given path / label'
                'backup:back up files to a new snapshot (ad-hoc paths or configured sources)'
                'list:list snapshots in a repository (optionally filtered by source label or recency)'
                'snapshot:inspect snapshot contents and metadata (nested subcommands)'
                'restore:restore files from a snapshot to a destination directory'
                'delete:delete an entire repository permanently (irreversible)'
                'prune:prune snapshots according to retention policy (--dry-run, --compact, --list, --source filter)'
                'check:verify repository integrity (-r/--repair to fix issues, --verify-data for slow but thorough, --distrust-server for client-side crypto verification)'
                'info:show repository statistics and snapshot totals'
                'config:generate a minimal configuration file'
                'mount:browse snapshots via a local WebDAV server (alternative to FUSE-based restic mount)'
                'break-lock:remove stale repository locks left by killed processes'
                'daemon:run scheduled backups as a foreground daemon (uses embedded croner cron-expression parser; no external systemd timer / crontab needed)'
                'compact:free repository space by compacting pack files (reclaim orphaned blobs after prune)'
                'help:show CLI help (or help for a specific subcommand)'
            )
            _describe -t commands 'vykar command' subcmds && ret=0
            ;;
        args)
            local -a common_repo_opt=(
                '(-R --repo)'{-R,--repo}'=[select repository by label (from config) or path]:repo:'
            )
            case $words[1] in
                init|info|config|break-lock|compact|daemon)
                    _arguments $common_repo_opt && ret=0
                    ;;
                backup)
                    _arguments \
                        $common_repo_opt \
                        '(-l --label)'{-l,--label}'=[label for the snapshot (sets source_label for ad-hoc backups)]:label:' \
                        '--compression=[compression algorithm override]:algo:(lz4 zstd none)' \
                        '*'{-S,--source}'=[filter which configured sources to back up (by label; repeat for multiple)]:source:' \
                        '--connections=[parallel backend connections 1-16 (overrides config)]:n:' \
                        '--threads=[CPU worker threads (0 = auto, 1-128 explicit)]:n:' \
                        '*:path to back up:_files' && ret=0
                    ;;
                list)
                    _arguments \
                        $common_repo_opt \
                        '*'{-S,--source}'=[filter displayed snapshots by source label]:source:' \
                        '--last=[show only the N most recent snapshots]:n:' && ret=0
                    ;;
                snapshot)
                    _arguments \
                        '1: :->scmds' && ret=0
                    case $state in
                        scmds)
                            local -a ssubs
                            ssubs=(
                                'list:list files inside a snapshot'
                                'info:show metadata for a specific snapshot'
                                'diff:diff two snapshots'
                                'delete:delete a single snapshot (use prune for retention-policy-driven cleanup)'
                            )
                            _describe -t snapshot-commands 'snapshot subcommand' ssubs && ret=0
                            ;;
                    esac
                    ;;
                restore)
                    _arguments \
                        $common_repo_opt \
                        '--pattern=[only restore paths matching this glob pattern]:glob:' \
                        '--verify[recompute keyed BLAKE2b chunk IDs after decryption (defense-in-depth against writer-side bugs)]' \
                        '1:snapshot name (or `latest`):' \
                        '2:destination directory:_files -/' && ret=0
                    ;;
                delete)
                    _arguments \
                        $common_repo_opt \
                        '--yes-delete-this-repo[skip interactive confirmation (for scripting)]' && ret=0
                    ;;
                prune)
                    _arguments \
                        $common_repo_opt \
                        '(-n --dry-run)'{-n,--dry-run}'[show what would be pruned without actually pruning]' \
                        '--list[show detailed list of kept/pruned snapshots with reasons]' \
                        '*'{-S,--source}'=[apply retention only to snapshots matching these source labels]:source:' \
                        '--compact[run compact after pruning to reclaim space from orphaned blobs]' && ret=0
                    ;;
                check)
                    _arguments \
                        $common_repo_opt \
                        '--verify-data[read and verify all data chunks (slow but thorough)]' \
                        '--distrust-server[force client-side download + crypto verification even when server supports server-side pack verification]' \
                        '--repair[detect and fix integrity issues]' \
                        '(-n --dry-run)'{-n,--dry-run}'[show repair plan without applying (requires --repair)]' \
                        '--yes[skip interactive confirmation (requires --repair; for scripting)]' && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(init backup list snapshot restore delete prune check info config mount break-lock daemon compact)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_vykar "$@"
