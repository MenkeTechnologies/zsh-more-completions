#compdef tfproviderlintx
# Documentation: https://github.com/bflad/tfproviderlint
# tfproviderlintx - Terraform Provider lint tool with extra checks

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-fix[apply automated fixes for checks that support them]' \
  '*:package:_files' && ret=0

return ret
