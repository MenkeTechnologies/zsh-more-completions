#compdef virt-ls
# _virt-ls — libguestfs virt-ls (list files inside a libvirt VM image; -a disk, -d domain, -c URI, -m mount spec, -l long ls -l output, -R recursive, --uids/--xattrs/--checksum extra columns, --csv csv output, --time-days/--time-relative format mtime; positional path inside guest)
# upstream: https://github.com/libguestfs/libguestfs (cat)
# Flags from libguestfs cat/cat.ml (ls variant) on tip.

_virt-ls() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '*-m+[mount spec]:mountspec:' \
        '-l[long ls -l output]' \
        '-R[recursive]' \
        '--uids[include uid column]' \
        '--xattrs[include xattrs column]' \
        '--checksum=*[checksum]:algo:(md5 sha1 sha224 sha256 sha384 sha512)' \
        '--csv[CSV output]' \
        '--time-days[mtime in days]' \
        '--time-relative[mtime relative]' \
        '--time-t[mtime as time_t]' \
        '--format=*[disk format]:fmt:(raw qcow2 vmdk vdi)' \
        '*:path in guest:'
}

_virt-ls "$@"
