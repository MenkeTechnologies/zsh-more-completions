#compdef lemon

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-?[show help]' \
  '-h[show help]' \
  '-b[print debug info]' \
  '-c[do not compress action table]' \
  '-d+[output dir]:dir:_files -/' \
  '-D+[define macro]:macro:' \
  '-E[print non-terminals]' \
  '-f+[options]:opts:' \
  '-g[generate report]' \
  '-l[no line numbers]' \
  '-m[output makeheaders]' \
  '-p[show conflicts]' \
  '-q[quiet mode]' \
  '-r[no resort states]' \
  '-s[show parser stats]' \
  '-S[strict mode]' \
  '-T+[template file]:file:_files' \
  '-W[print warnings]' \
  '-x[show version]' \
  '*: :_files -g "*.y *.yacc *.lemon"' && ret=0

return ret
