#compdef zopfli zopflipng
# _zopfli-bin — Google Zopfli deflate compressor (C); produces smaller zlib/gzip/deflate streams than gzip -9 at much higher CPU
# upstream: https://github.com/google/zopfli

_zopfli-bin() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-c[stdout]' \
        '--gzip[gzip wrapper output]' \
        '--zlib[zlib wrapper output]' \
        '--deflate[raw deflate output]' \
        '--i+[iteration count]:n:' \
        '--lossy_transparent[zopflipng: lossy transparent pixel changes]' \
        '--lossy_8bit[zopflipng: lossy 8-bit alpha]' \
        '--filters=+[zopflipng filter strategies]:strategy:(0 1 2 3 4 m e p b)' \
        '--keepchunks=+[zopflipng keep chunks]:chunks:' \
        '--always_zopflify[force re-encode]' \
        '-y[overwrite without prompt]' \
        '-m[more iterations]' \
        '*:file:_files'
}

_zopfli-bin "$@"
