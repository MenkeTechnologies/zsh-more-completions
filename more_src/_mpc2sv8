#compdef mpc2sv8
# Documentation: https://www.musepack.net/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (verified locally via `mpc2sv8`
#   built-in usage string: "mpc2sv8 <infile.mpc> <outfile.mpc>" or
#   "mpc2sv8 <infile_1.mpc> [...] <outdir>").

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '*:input file or output:_files -g "*.mpc"' && ret=0

return ret
