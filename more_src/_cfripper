#compdef cfripper
# Documentation: https://man.archlinux.org/search?q=cfripper
# Reference accessed: 2026-05-16

# Skyscanner/cfripper — click cfripper/cli.py

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--version[show version]' \
  '*'--resolve'[resolve CloudFormation functions]' \
  '*'--no-resolve'[disable resolution]' \
  '--resolve-parameters=[JSON/YAML parameters for Ref resolution]:file:_files' \
  '--format=[output format]:format:(json txt)' \
  '--output-folder=[write results under directory]:dir:_files -/' \
  '--logging=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '--rules-config-file=[Python rules config]:file:_files' \
  '--rules-filters-folder=[folder of rule filter modules]:dir:_files -/' \
  '--aws-account-id=[12-digit AWS account id]:id:' \
  '--aws-principals=[comma-separated principal ARNs/ids]:principals:' \
  '*:CloudFormation template:_files' && ret=0

return ret
