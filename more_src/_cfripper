#compdef cfripper
# Documentation: https://github.com/Skyscanner/cfripper
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--resolve[enable resolution mode (also detect monitored issues)]' \
  '--format=[output format]:format:(txt json)' \
  '--output-folder=[directory to write result files]:dir:_files -/' \
  '--rules-config-file=[Python file with custom rule configurations]:file:_files' \
  '--rules-filters-folder=[directory containing rule filter modules]:dir:_files -/' \
  '*:CloudFormation template:_files' && ret=0

return ret
