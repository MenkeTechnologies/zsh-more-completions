#compdef moonpick
# Documentation: https://github.com/nilnor/moonpick
# moonpick - an alternative linter for MoonScript

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show moonpick version]' \
  '--filename[filename used when linting from stdin]:filename:_files' \
  '*:moon file:_files -g "*.moon"' && ret=0

return ret
