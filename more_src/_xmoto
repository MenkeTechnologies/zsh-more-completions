#compdef xmoto
# Documentation: https://github.com/xmoto/xmoto
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: upstream README defers to "xmoto --help" and provides no enumerated
# flag list. Prior file had many specific flags that cannot be verified from
# any public manpage / docs source.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:file:_files' && ret=0
return ret
