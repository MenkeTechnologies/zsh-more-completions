#compdef xmoto

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-l --level)'{-l,--level}'+[level id]:level:' \
  '(-r --replay)'{-r,--replay}'+[replay file]:file:_files -g "*.rpl"' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-f --fps)'{-f,--fps}'[show fps]' \
  '(-w --windowed)'{-w,--windowed}'[windowed mode]' \
  '(-R --resolution)'{-R,--resolution}'+[WxH]:res:' \
  '(-b --bpp)'{-b,--bpp}'+[bpp]:n:(16 32)' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '--testTheme=+[test theme]:theme:' \
  '--profile=+[profile]:name:' \
  '--noLog[no log]' \
  '--config=+[config file]:file:_files' \
  '--noMusic[no music]' \
  '--noSound[no sound]' \
  '--listLevels[list levels]' \
  '--listReplays[list replays]' \
  '--replayInfos=+[replay info]:file:_files' && ret=0

return ret
