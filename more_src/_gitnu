#compdef gitnu
# Documentation: https://github.com/nguyenvukhang/gitnu
# Source: nguyenvukhang/gitnu — enumerates git status; reference files by number.
# Reference accessed: 2026-06-02
# Invoked as `git nu <command> ...` (git subcommand). Passes through to git after expanding numbers.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _gn_cmds
_gn_cmds=(
    'status:enumerate git status (numbered file list)'
    'add:git add by number (eg `gitnu add 2 5-7`)'
    'reset:git reset by number'
    'checkout:git checkout by number'
    'diff:git diff by number'
    'rm:git rm by number'
    'log:git log (passthrough)'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'gitnu command' _gn_cmds && _message 'or any git subcommand' && ret=0
        ;;
    args)
        _arguments -s -S '*:files or numbers (e.g. 2 5-7):_default' && ret=0
        ;;
esac

return ret
