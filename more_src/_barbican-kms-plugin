#compdef barbican-kms-plugin
# _barbican-kms-plugin — OpenStack Barbican KMS plugin for Kubernetes envelope-encryption
# upstream: https://github.com/kubernetes/cloud-provider-openstack
# Flags from cmd/barbican-kms-plugin/main.go on tip.

_barbican-kms-plugin() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--socketpath=[Barbican KMS plugin Unix socket]:path:_files' \
        '--cloud-config=[cloud configuration file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_barbican-kms-plugin "$@"
