#compdef terraform-validator
# Documentation: https://github.com/GoogleCloudPlatform/terraform-validator/blob/main/cmd/validate.go
# Validate Terraform plans against Google Cloud policy constraints

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    validate\:"validate a terraform plan against policies"
    convert\:"convert a terraform plan to CAI assets"
    list-supported-resources\:"list supported terraform resources"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      validate)
        _arguments -s -S \
          '--policy-path=[path to directory containing validation policies]:dir:_files -/' \
          '--project=[provider project override]:project' \
          '--ancestry=[override the ancestry location of the project]:ancestry' \
          '--offline[do not make network requests]' \
          '--output-json[print violations as JSON]' \
          '*:plan json:_files' && ret=0
        ;;
      convert)
        _arguments -s -S \
          '--project=[provider project override]:project' \
          '--ancestry=[override the ancestry location of the project]:ancestry' \
          '--offline[do not make network requests]' \
          '*:plan json:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
