#compdef ne

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--ansi[use ANSI sequences for display]' \
  '--no-ansi[do not use ANSI sequences]' \
  '--no-config[do not read config files]' \
  '--no-syntax[disable syntax highlighting]' \
  '--binary[load files as binary]' \
  '--read-only[open files as read-only]' \
  '--utf8[assume UTF-8 encoding]' \
  '--no-utf8[disable UTF-8 support]' \
  '--keys=[custom key bindings file]:key file:_files' \
  '--menus=[custom menu file]:menu file:_files' \
  '--macro=[execute macro]:macro file:_files' \
  '--prefs=[preferences directory]:directory:_directories' \
  '--syntax=[syntax highlighting file]:syntax file:_files' \
  '+[go to line number]:line number:' \
  '*:files:_files' && ret=0

return ret
