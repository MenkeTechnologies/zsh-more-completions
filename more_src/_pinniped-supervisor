#compdef pinniped-supervisor
# _pinniped-supervisor — Pinniped Supervisor federated OIDC/LDAP issuer (vmware-tanzu/pinniped)
# upstream: https://github.com/vmware-tanzu/pinniped
# Flags from internal/supervisor/server/server.go addCommandlineFlagsToCommand() on tip.

_pinniped-supervisor() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-c --config)'{-c,--config=}'[Supervisor configuration file]:file:_files -g "*.(yml|yaml)(-.)"' \
        '--downward-api-path=[directory containing Kubernetes Downward API files]:dir:_files -/' \
        '-v[klog verbosity level]:n:'
}

_pinniped-supervisor "$@"
