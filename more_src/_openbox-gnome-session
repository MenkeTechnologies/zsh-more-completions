#compdef openbox-gnome-session
# Documentation: https://man.archlinux.org/search?q=openbox-gnome-session
# Reference accessed: 2026-05-16

# openbox-gnome-session: launch Openbox inside a GNOME session
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::openbox-gnome-session args:_files' && ret=0
return ret
