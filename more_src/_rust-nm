#compdef rust-nm
# Documentation: https://llvm.org/docs/CommandGuide/llvm-nm.html
# rust-nm: cargo-binutils proxy for llvm-nm to list symbols in object files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --debug-syms)'{-a,--debug-syms}'[display all symbols including debugger-only]' \
  '(-U --defined-only)'{-U,--defined-only}'[display only defined symbols]' \
  '(-u --undefined-only)'{-u,--undefined-only}'[display only undefined symbols]' \
  '(-g --extern-only)'{-g,--extern-only}'[display only external symbols]' \
  '(-W --no-weak)'{-W,--no-weak}'[exclude weak symbols]' \
  '--special-syms[do not filter special symbols]' \
  '(-f --format)'{-f,--format}'=[output format]:format:(bsd sysv posix darwin just-symbols)' \
  '-j[alias for --format=just-symbols]' \
  '(-A -o --print-file-name)'{-A,-o,--print-file-name}'[precede each symbol with file name]' \
  '(-S --print-size)'{-S,--print-size}'[print symbol size]' \
  '(-t --radix)'{-t,--radix}'=[address radix]:radix:(d o x)' \
  '(-l --line-numbers)'{-l,--line-numbers}'[use debug info for file and line]' \
  '(-n -v --numeric-sort)'{-n,-v,--numeric-sort}'[sort by address]' \
  '(-r --reverse-sort)'{-r,--reverse-sort}'[reverse sort order]' \
  '--size-sort[sort by size]' \
  '(-p --no-sort)'{-p,--no-sort}'[do not sort symbols]' \
  '(-C --demangle)'{-C,--demangle}'[demangle symbol names]' \
  '--no-demangle[do not demangle symbol names]' \
  '(-D --dynamic)'{-D,--dynamic}'[display dynamic symbols]' \
  '--print-armap[print archive symbol table]' \
  '--quiet[suppress diagnostics]' \
  '--export-symbols[print sorted symbols with visibility]' \
  '*:cargo args:_default' && ret=0

return ret
