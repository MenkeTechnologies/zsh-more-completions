#compdef go-jsonnet

_arguments \
  '-e[evaluate a string]:code' \
  '-J[add library search directory]:directory:_directories' \
  '--jpath[add library search directory]:directory:_directories' \
  '-o[output file]:file:_files' \
  '--output-file[output file]:file:_files' \
  '-m[multi-file output directory]:directory:_directories' \
  '--multi[multi-file output directory]:directory:_directories' \
  '-y[output YAML instead of JSON]' \
  '--yaml-stream[output YAML stream]' \
  '-S[output as raw string]' \
  '--string[output as raw string]' \
  '-s[same as -S]' \
  '--max-stack[maximum stack size]:size' \
  '--max-trace[maximum number of stack frames in trace]:count' \
  '-V[external variable]:var=value' \
  '--ext-str[external string variable]:var=value' \
  '--ext-code[external code variable]:var=code' \
  '--ext-str-file[external variable from file]:var=file' \
  '--ext-code-file[external code from file]:var=file' \
  '-A[top-level argument]:var=value' \
  '--tla-str[top-level string argument]:var=value' \
  '--tla-code[top-level code argument]:var=code' \
  '--tla-str-file[top-level string argument from file]:var=file' \
  '--tla-code-file[top-level code argument from file]:var=file' \
  '--version[display version]' \
  '-h[display help]' \
  '--help[display help]' \
  '*:jsonnet file:_files -g "*.jsonnet"'
