#compdef jtbl
# Documentation: https://github.com/kellyjonbrazil/jtbl/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jtbl - print JSON and JSON Lines data as a table (kellyjonbrazil/jtbl)

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help information]' \
  '(- *)'{-v,--version}'[print version information]' \
  '--cols=[manually configure the terminal width]:int:' \
  '(-c --csv)'{-c,--csv}'[CSV table output]' \
  '(-d --dokuwiki)'{-d,--dokuwiki}'[Dokuwiki table output]' \
  '(-f --fancy)'{-f,--fancy}'[fancy table output]' \
  '(-H --html)'{-H,--html}'[HTML table output]' \
  '(-m --markdown)'{-m,--markdown}'[Markdown table output]' \
  '(-n --no-wrap)'{-n,--no-wrap}'[no data wrapping if too long for the terminal width]' \
  '(-q --quiet)'{-q,--quiet}'[do not print error messages to STDERR]' \
  '(-r --rotate)'{-r,--rotate}'[rotate the data into key/value pair tables]' \
  '(-t --truncate)'{-t,--truncate}'[truncate data instead of wrapping]' \
  '*:json file:_files' && ret=0

return ret
