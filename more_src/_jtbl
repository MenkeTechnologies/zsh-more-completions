#compdef jtbl

# jtbl — JSON pretty tables (https://github.com/paulgreenhall/jtbl). stdin/JSON + column options per `jtbl -h`.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-c,--cols}"=[max columns]:int" \
  {-t,--truncate}"=[truncate width]:int" \
  {-n,--no-color}'[disable ANSI colors]' \
  '*:json file:_files' && ret=0

return ret
