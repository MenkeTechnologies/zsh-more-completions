#compdef fontc
# Documentation: https://github.com/googlefonts/fontc
# Source: googlefonts/fontc fontc/src/args.rs — Rust font compiler (oxidized fontmake).
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-s --source)'{-s+,--source=}'[DEPRECATED: old positional input file]:file:_files' \
    '(-e --emit-ir)'{-e,--emit-ir}'[write IR to disk]' \
    '(-o --output-file)'{-o+,--output-file=}'[output file name (default build/font.ttf)]:file:_files' \
    '--emit-debug[write additional debug files to disk]' \
    '--prefer-simple-glyphs=[convert mixed component/contour glyphs to contours]:bool:(true false)' \
    '--flatten-components=[flatten nested components to simple glyphs]:bool:(true false)' \
    '--erase-open-corners=[erase open corners (Glyphs feature)]:bool:(true false)' \
    '--propagate-anchors=[propagate anchors from components to composites]:bool:(true false)' \
    '--decompose-transformed-components[decompose components with non-identity 2x2 transforms]' \
    '--decompose-components[decompose all components]' \
    '--emit-timing[emit timing data for threadpool execution]' \
    '(-b --build-dir)'{-b+,--build-dir=}'[working directory for the build process]:dir:_files -/' \
    '(-g --glyph-name-filter)'{-g+,--glyph-name-filter=}'[regex glyph names must match to be processed]:regex:_default' \
    '--skip-features[skip compilation of OpenType Layout features]' \
    '--emit-lookup-debug-info[emit a Debg table with source-level lookup debug info]' \
    '--keep-direction[keep the original glyph contour direction (TTF only)]' \
    '--no-production-names[do not rename glyphs with production names]' \
    '--vv[print verbose version information for debugging]' \
    '--log=[set the log level globally or per module]:level:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1::input-source:_files -g "*.(designspace|ufo|glyphs)"' \
    && ret=0

return ret
