#compdef guild

local -a arguments

arguments=(
    '--help[Show help]'
    '--version[Show version]'
    '1:command:->cmds'
    '*:: :->args'
)

local -a commands
commands=(
    'compile:Compile Scheme source files'
    'disassemble:Disassemble a compiled .go file'
    'doc:Display documentation'
    'environment:Display information about the Guile environment'
    'guild:Run a guild script'
    'lint:Detect common mistakes in Scheme code'
    'repl:Start a REPL'
    'run:Run a Scheme script'
    'snarf:Extract annotations from C source files'
    'texinfo:Generate texinfo documentation'
)

_arguments -s -S $arguments && return

case "$state" in
    cmds)
        _describe -t commands 'guild commands' commands
        ;;
    args)
        case ${words[1]} in
            compile)
                _arguments \
                    '-o[Specify output file]:output file:_files' \
                    '-W[Warning level]:level:(0 1 2 3)' \
                    '-O[Optimization level]:level:(0 1 2 3)' \
                    '-L[Add directory to load path]:directory:_directories' \
                    '--from[Specify source language]:language' \
                    '--to[Specify target language]:language' \
                    '*:scheme files:_files -g "*.scm"'
                ;;
            disassemble)
                _arguments '*:compiled files:_files -g "*.go"'
                ;;
            lint)
                _arguments '*:scheme files:_files -g "*.scm"'
                ;;
            *)
                _files
                ;;
        esac
        ;;
esac
