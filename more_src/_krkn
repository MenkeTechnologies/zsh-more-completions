#compdef krkn
# Documentation: https://github.com/krkn-chaos/krkn
# Krkn (Kraken): chaos and resiliency testing for Kubernetes

local ret=1
local curcontext="$curcontext" state line

_arguments -s -C \
  '(-c --config)'{-c,--config}'=[config location]:file:_files' \
  '(-o --output)'{-o,--output}'=[output report location]:file:_files' \
  '--junit-testcase=[junit test case description]:desc' \
  '--junit-testcase-path=[junit test case path]:path:_files' \
  '--junit-testcase-version=[junit test case version]:version' \
  '(-r --run_uuid)'{-r,--run_uuid}'=[run UUID to filter rollback operations]:uuid' \
  '(-s --scenario_type)'{-s,--scenario_type}'=[scenario type to filter rollback operations]:type' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*:: :_default' && ret=0

case $state in
  cmds)
    _values 'command' \
      'list-rollback[list available rollback operations]' \
      'execute-rollback[execute a rollback operation]' && ret=0
    ;;
esac

return ret
