#compdef zsh-bench
# Documentation: https://github.com/romkatv/zsh-bench
# Reference accessed: 2026-05-21
# Verified: README USAGE block — flags -h/-i/-l/-g/-c/-d/-I/-s/-r
# match (long forms --help/--iters/--login/--git/--config-dir/
# --scratch-dir/--isolation/--standalone/--raw).

_zsh-bench() {
    local -a args
    args=(
        '(-h --help)'{-h,--help}'[Show help message]'
        '(-i --iters)'{-i,--iters}'[Number of iterations]:iterations'
        '(-l --login)'{-l,--login}'[Benchmark login shell]:login:(yes no)'
        '(-g --git)'{-g,--git}'[Initialize git repo in scratch dir]:git:(yes no empty)'
        '(-c --config-dir)'{-c,--config-dir}'[Directory containing configurations]:directory:_directories'
        '(-d --scratch-dir)'{-d,--scratch-dir}'[Directory for temporary data]:directory:_directories'
        '(-I --isolation)'{-I,--isolation}'[Isolation mode]:mode:(docker user)'
        '(-s --standalone)'{-s,--standalone}'[Run in standalone mode]'
        '(-r --raw)'{-r,--raw}'[Print raw results]'
        '*:config'
    )

    _arguments -s -S $args
}

_zsh-bench "$@"
