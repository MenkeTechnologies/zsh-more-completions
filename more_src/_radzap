#compdef radzap
# _radzap — FreeRADIUS radzap (remove stale session records from the radacct/sessions database; -d data dir, -f session file, -h help, -v version, -N do not write back; positional argument is the NAS-Identifier whose stale sessions should be removed)
# upstream: https://github.com/FreeRADIUS/freeradius-server
# Flags from FreeRADIUS/freeradius-server src/main/radzap.c on tip.

_radzap() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-d+[data dir]:dir:_files -/' \
        '-f+[session file]:file:_files' \
        '-N[no write back]' \
        '1:NAS-Identifier:'
}

_radzap "$@"
