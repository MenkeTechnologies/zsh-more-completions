#compdef pydoctor
# Documentation: https://pydoctor.readthedocs.io/en/latest/help.html
# Generate API documentation for Python packages and modules

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[display program version number]' \
  '(-c --config)'{-c,--config}'[load settings from a configuration file]:file:_files' \
  '--project-name=[display name shown at top of HTML pages]:name' \
  '--project-version=[project version for generated docs]:version' \
  '--project-url=[project URL in HTML output]:url' \
  '--project-base-dir=[base directory for computing source links]:dir:_directories' \
  '--make-html[generate HTML output]' \
  '--make-intersphinx[produce only the objects.inv intersphinx file]' \
  '--html-output=[directory for saving HTML files]:dir:_directories' \
  '--html-writer=[dotted class name for HTML writer]:writer' \
  '--docformat=[docstring parsing format]:format:(numpy restructuredtext plaintext google epytext)' \
  '--theme=[theme selection]:theme:(base readthedocs classic)' \
  '*--template-dir=[directory with custom HTML templates]:dir:_directories' \
  '--process-types[add links and markup to type fields automatically]' \
  '--sidebar-expand-depth=[expandable nesting levels in sidebar]:depth' \
  '--sidebar-toc-depth=[nested titles in docstring TOC]:depth' \
  '--no-sidebar[disable sidebar generation entirely]' \
  '--cls-member-order=[class member order]:order:(alphabetical source)' \
  '--mod-member-order=[module member order]:order:(alphabetical source)' \
  '*--privacy=[set object privacy levels using patterns]:pattern' \
  '--prepend-package=[treat all packages as nested within package]:package' \
  '*--intersphinx=[use Sphinx inventory URLs for external links]:url' \
  '*--intersphinx-file=[use local Sphinx inventory files]:file:_files' \
  '--disable-intersphinx-cache[skip intersphinx caching]' \
  '--intersphinx-cache-path=[directory for cached inventory files]:dir:_directories' \
  '--clear-intersphinx-cache[clear existing cache]' \
  '--introspect-c-modules[import and analyze C modules]' \
  '--html-base-url=[canonical base URL for search engines]:url' \
  '--testing[suppress warnings about empty documentation runs]' \
  '--pdb[enable debugger on errors]' \
  '*'{-v,--verbose}'[increase output verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[decrease output verbosity]' \
  '(-W --warnings-as-errors)'{-W,--warnings-as-errors}'[exit with code 3 on warnings]' \
  '--system-class=[dotted class name for custom system implementation]:class' \
  '--use-hardlinks[copy files instead of symlinking]' \
  '*:source path:_files' && ret=0

return ret
