#compdef influx3
# Documentation: https://github.com/InfluxCommunity/influxdb3-python-cli
# influx3 - interactive CLI for InfluxDB 3 (influxdb3-python-cli)

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'influx3 command' \
      'config[manage named configurations]' \
      'sql[execute a SQL query]' \
      'query[execute a query]' \
      'write[write line protocol data]' \
      'write_file[write data from a CSV/file]' \
      'chatgpt[query using ChatGPT (alpha)]' && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _values 'config subcommand' \
          'create[create a new configuration]' \
          'update[modify an existing configuration]' \
          'use[set the active configuration]' \
          'delete[remove a configuration]' \
          'list[list all configurations]' && ret=0
        _arguments -s \
          '--name=[configuration name]:name:' \
          '--host=[InfluxDB host URL]:host:' \
          '--token=[authentication token]:token:' \
          '--database=[database name]:database:' \
          '--org=[organization]:org:' \
          '--active[set as active configuration]' && ret=0
        ;;
      write_file)
        _arguments -s \
          '--file=[path to the CSV/data file]:file:_files' \
          '--measurement=[measurement name]:measurement:' \
          '--time=[timestamp column name]:column:' \
          '--tags=[comma-separated tag column names]:tags:' && ret=0
        ;;
      query|sql)
        _arguments -s \
          '(-d --database)'{-d,--database}'=[database to query]:database:' && ret=0
        ;;
    esac
    ;;
esac

return ret
