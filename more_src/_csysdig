#compdef csysdig
# Documentation: source-direct extraction from upstream
# draios/sysdig userspace/sysdig/csysdig.cpp `long_options[]`
# table + the getopt_long argstring `"AB::d:Ehk:K:jlm:n:p:Rr:s:v:X"`
# decoded by reading every case-arm in the switch(op) block.
# Reference accessed: 2026-05-30 via gh api.
# draios sysdig R159a — csysdig is the ncurses-based interactive
# system inspection / live-process / live-fd / live-syscall viewer
# (the curses sister to the sysdig CLI already covered in the
# corpus). Sister to the heavily-covered tracing family (bpftrace,
# bpftool, sysdig, falco, falcoctl, tetragon, hubble, tracee,
# kubectl-trace, inspektor-gadget).

_arguments -s -S \
  '(-A --print-ascii)'{-A,--print-ascii}'[only print event data printable ASCII chars]' \
  '(-B --bpf)'{-B-,--bpf=-}'[run with eBPF probe (optional probe path)]::probe path:_files' \
  '(-d --delay)'{-d+,--delay=}'[refresh delay in milliseconds (>=100)]:ms:' \
  '(-E --exclude-users)'{-E,--exclude-users}'[do not import users/groups on startup]' \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '(-j --json)'{-j,--json}'[emit output as JSON]' \
  '(-l --list)'{-l-,--list=-}'[list available fields (optional source filter)]::source:' \
  '(-n --numevents)'{-n+,--numevents=}'[exit after N captured events]:n:' \
  '(-p --print)'{-p+,--print=}'[per-event Sysdig print format string]:fmt:' \
  '(-R --resolve-ports)'{-R,--resolve-ports}'[resolve port numbers to service names]' \
  '(-r --readfile)'{-r+,--readfile=}'[read events from scap file]:scap file:_files -g "*.scap"' \
  '(-s --snaplen)'{-s+,--snaplen=}'[event-data snap length in bytes]:bytes:' \
  '(-v --view)'{-v+,--view=}'[start with the named view (e.g. procs threads files)]:view:' \
  '(-X --print-hex-ascii)'{-X,--print-hex-ascii}'[print event data as hex+ASCII]' \
  '--cpus-for-each-buffer=[(modern-bpf) CPUs per ring buffer]:n:' \
  '--from=[absolute or relative start time]:time:' \
  '--interactive=-[force interactive UI mode]::on|off:(on off)' \
  '--large-environment[enable large-environment support]' \
  '--list-views[list all built-in views and exit]' \
  '--modern-bpf[run with the modern eBPF probe (no kernel module)]' \
  '--page-faults[capture page-fault events]' \
  '--raw[emit raw event payloads]' \
  '--logfile=[append log lines to FILE]:file:_files' \
  '--force-term-compat[force terminal compatibility mode]' \
  '--sortingcol=[start sorted on column N]:col:' \
  '--to=[absolute or relative end time]:time:' \
  '--version[print version and exit]'
