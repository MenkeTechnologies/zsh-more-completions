#compdef qrencode
# _qrencode — qrencode2 (libqrencode QR encoder; -o output file (PNG/EPS/SVG/UTF8/ANSIUTF8), -t output type, -s pixel size, -l error correction level (L|M|Q|H), -v version (1-40), -m margin, -d DPI, -i case-insensitive, -k Kanji, -8 8-bit, --inline output to stdout)
# upstream: https://github.com/fukuchi/libqrencode
# Flags from libqrencode qrencode.c on tip.

_qrencode2() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-i[case-insensitive (default)]' \
        '-c[case-sensitive]' \
        '-k[Kanji mode]' \
        '-M[mask 0-7]' \
        '-S[structured mode]' \
        '-8[8-bit mode]' \
        '-o+[output file]:file:_files' \
        '-r+[read text from file]:file:_files' \
        '-s+[pixel size]:px:' \
        '-l+[error correction]:level:(L M Q H)' \
        '-v+[QR version]:version:' \
        '-m+[margin]:cells:' \
        '-d+[DPI]:dpi:' \
        '-t+[output type]:type:(PNG PNG32 EPS SVG XPM ANSI ANSI256 ASCII ASCIIi UTF8 UTF8i ANSIUTF8 ANSIUTF8i ANSI256UTF8 UTF8i)' \
        '--foreground=[fg color RRGGBB]:hex:' \
        '--background=[bg color RRGGBB]:hex:' \
        '--rle[run-length encode]' \
        '--strict-version[strict version]' \
        '--inline[output to stdout]' \
        '*:text:'
}

_qrencode2 "$@"
