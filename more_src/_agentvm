# ---------------------------------------------------------------------------
# Subcommand: history — show the lifecycle journal
# ---------------------------------------------------------------------------
cmd_history() {
  local n=50 event=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n) n="$2"; shift 2 ;;
      -e|--event) event="$2"; shift 2 ;;
      *) die "Unknown flag '$1' for history" ;;
    esac
  done
  [[ -f "$AGENTVM_JOURNAL" ]] || { dim "No history yet."; return 0; }
  printf "${BOLD}%-20s %-8s %-20s %s${RESET}\n" "WHEN (UTC)" "EVENT" "AGENT" "DETAIL"
  printf '%s\n' "$(printf '%0.s─' {1..90})"
  local tailed
  tailed="$(tail -n "$n" "$AGENTVM_JOURNAL")"
  if [[ -n "$event" ]]; then
    tailed="$(printf '%s\n' "$tailed" | awk -F'\t' -v e="$event" '$2==e')"
  fi
  printf '%s\n' "$tailed" | awk -F'\t' '{printf "%-20s %-8s %-20s %s\n", $1, $2, $3, $4}'
}

# ---------------------------------------------------------------------------
# Subcommand: stats — aggregate counts across all agents (alive + history)
# ---------------------------------------------------------------------------
cmd_stats() {
  init_dirs

  local env_files=() f
  while IFS= read -r -d '' f; do env_files+=("$f"); done \
    < <(find "$AGENTVM_STATE" -maxdepth 1 -name '*.env' -print0 2>/dev/null | sort -z)

  local total="${#env_files[@]}" running=0 dead=0
  for f in "${env_files[@]+"${env_files[@]}"}"; do
    AGENT_SESSION=""
    # shellcheck source=/dev/null
    source "$f"
    if session_running "$AGENT_SESSION"; then running=$((running+1)); else dead=$((dead+1)); fi
  done

  # Aggregate workspace and log sizes
  local total_ws_bytes=0 total_log_bytes=0
  if [[ -d "$AGENTVM_WORKSPACES" ]]; then
    total_ws_bytes=$(du -sk "$AGENTVM_WORKSPACES" 2>/dev/null | awk '{print $1 * 1024}')
  fi
  local log_file
  for log_file in "$AGENTVM_STATE"/*.log; do
    [[ -f "$log_file" ]] || continue
    local s
    if stat -f '%z' "$log_file" &>/dev/null; then
      s=$(stat -f '%z' "$log_file")
    else
      s=$(stat -c '%s' "$log_file" 2>/dev/null || echo 0)
    fi
    total_log_bytes=$((total_log_bytes + s))
  done

  # History counts
  local hist_spawns=0 hist_kills=0 hist_cleans=0 hist_purges=0
  if [[ -f "$AGENTVM_JOURNAL" ]]; then
    hist_spawns=$(awk -F'\t' '$2=="spawn"' "$AGENTVM_JOURNAL" | wc -l | tr -d ' ')
    hist_kills=$(awk -F'\t' '$2=="kill"' "$AGENTVM_JOURNAL" | wc -l | tr -d ' ')
    hist_cleans=$(awk -F'\t' '$2=="clean"' "$AGENTVM_JOURNAL" | wc -l | tr -d ' ')
    hist_purges=$(awk -F'\t' '$2=="purge"' "$AGENTVM_JOURNAL" | wc -l | tr -d ' ')
  fi

  printf "${BOLD}agentvm stats${RESET}\n\n"
  printf "  ${CYAN}Current${RESET}\n"
  printf "    agents:      %d  (${GREEN}%d running${RESET}, ${RED}%d dead${RESET})\n" "$total" "$running" "$dead"
  printf "    workspaces:  %s\n" "$(awk -v b="$total_ws_bytes" 'BEGIN{
    if (b<1024) printf "%dB", b;
    else if (b<1024*1024) printf "%.1fK", b/1024;
    else if (b<1024*1024*1024) printf "%.1fM", b/1024/1024;
    else printf "%.2fG", b/1024/1024/1024;
  }')"
  printf "    logs:        %s\n" "$(awk -v b="$total_log_bytes" 'BEGIN{
    if (b<1024) printf "%dB", b;
    else if (b<1024*1024) printf "%.1fK", b/1024;
    else if (b<1024*1024*1024) printf "%.1fM", b/1024/1024;
    else printf "%.2fG", b/1024/1024/1024;
  }')"
  printf "\n  ${CYAN}Lifetime (journal)${RESET}\n"
  printf "    spawns:      %d\n" "$hist_spawns"
  printf "    kills:       %d\n" "$hist_kills"
  printf "    cleans:      %d\n" "$hist_cleans"
  printf "    purges:      %d\n" "$hist_purges"
}

# ---------------------------------------------------------------------------
# Subcommand: diff — show workspace changes since spawn
# ---------------------------------------------------------------------------
cmd_diff() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "Usage: agentvm diff <name>"
  validate_name "$name"
  load_state "$name"

  [[ -d "$AGENT_WORKSPACE" ]] || die "Workspace missing: $AGENT_WORKSPACE"

  # If workspace is a git repo, prefer git diff (shows staged + unstaged + untracked)
  if [[ -d "$AGENT_WORKSPACE/.git" ]]; then
    info "git status + diff in workspace:"
    ( cd "$AGENT_WORKSPACE" && git -c color.ui=always status --short && echo && git -c color.ui=always diff HEAD ) || true
    return 0
  fi

  # Otherwise enumerate files and mtimes newer than the state file's ctime
  local state_file
  state_file="$(state_file "$name")"
  info "Files changed since spawn (workspace is not a git repo):"
  find "$AGENT_WORKSPACE" -type f -newer "$state_file" 2>/dev/null | head -200 | \
    sed "s|^$AGENT_WORKSPACE/||"
}

# ---------------------------------------------------------------------------
# Subcommand: grid — open a single tmux session with a window per running agent
# ---------------------------------------------------------------------------
cmd_grid() {
  require_tmux
  init_dirs

  local env_files=() f
  while IFS= read -r -d '' f; do env_files+=("$f"); done \
    < <(find "$AGENTVM_STATE" -maxdepth 1 -name '*.env' -print0 2>/dev/null | sort -z)

  local -a agents=()
  for f in "${env_files[@]+"${env_files[@]}"}"; do
    AGENT_NAME="" AGENT_SESSION=""
    # shellcheck source=/dev/null
    source "$f"
    session_running "$AGENT_SESSION" || continue
    agents+=("$AGENT_NAME")
  done

  [[ ${#agents[@]} -gt 0 ]] || die "No running agents to grid. Spawn something first."

  local grid_session="agentvm-grid"
  tmux kill-session -t "$grid_session" 2>/dev/null || true
  # Window 0: attach-session to first agent
  tmux new-session -d -s "$grid_session" -n "${agents[0]}" \
    "tmux attach -t $(tmux_session "${agents[0]}")"

  # One window per remaining agent
  local i
  for (( i=1; i<${#agents[@]}; i++ )); do
    tmux new-window -t "$grid_session" -n "${agents[i]}" \
      "tmux attach -t $(tmux_session "${agents[i]}")"
  done

  info "Grid session '${grid_session}' has ${#agents[@]} window(s). Switch windows with Ctrl-b n/p."
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$grid_session"
  else
    tmux attach-session -t "$grid_session"
  fi
}

# ---------------------------------------------------------------------------
# Subcommand: open — open agent's workspace in the OS file manager
# ---------------------------------------------------------------------------
cmd_open() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "Usage: agentvm open <name>"
  validate_name "$name"
  load_state "$name"
  [[ -d "$AGENT_WORKSPACE" ]] || die "Workspace missing: $AGENT_WORKSPACE"

  if command -v open &>/dev/null; then
    open "$AGENT_WORKSPACE"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$AGENT_WORKSPACE"
  else
    echo "$AGENT_WORKSPACE"
  fi
}

# ---------------------------------------------------------------------------
# Subcommand: keys
# ---------------------------------------------------------------------------
cmd_keys() {
  init_dirs

  # Curated list of provider env vars commonly used by coding-agent CLIs.
  # Agents inherit whatever's in the host env (shell + ~/.agentvm/env), so this
  # is just a status snapshot, not a forwarding list.
  local -a all_vars=(
    ANTHROPIC_API_KEY ANTHROPIC_BASE_URL CLAUDE_API_KEY
    OPENAI_API_KEY OPENAI_BASE_URL OPENAI_ORG_ID OPENAI_MODEL CLAUDE_CODE_USE_OPENAI
    GEMINI_API_KEY GOOGLE_API_KEY GOOGLE_CLOUD_PROJECT GEMINI_MODEL
    OPENROUTER_API_KEY DEEPSEEK_API_KEY GROQ_API_KEY
    FIRECRAWL_API_KEY AIDER_MODEL
  )

  printf "${BOLD}Key file:${RESET} %s\n\n" "$AGENTVM_ENV_FILE"

  local var any_set=false
  for var in "${all_vars[@]}"; do
    if [[ -n "${!var:-}" ]]; then
      local masked="${!var:0:12}..."
      printf "  ${GREEN}✓${RESET} %-28s ${DIM}%s${RESET}\n" "$var" "$masked"
      any_set=true
    fi
  done

  if ! $any_set; then
    dim "  No provider keys set. Edit ${AGENTVM_ENV_FILE} to add some."
  fi

  printf "\n${DIM}Edit: \$EDITOR %s${RESET}\n" "$AGENTVM_ENV_FILE"
}

