  # Agent with its own gitlawb DID (isolated identity)
  agentvm spawn claude-1 --profile claude-code --gitlawb

  # Swarm: spawn 5 parallel workers with the same prompt
  agentvm swarm crawler 5 -p claude-code --prompt /tmp/task.md

  # One-shot: run a command, capture output, auto-cleanup
  agentvm run -p codex --timeout 300 --prompt /tmp/task.md

  # Observe
  agentvm list --tag task=X
  agentvm ps
  agentvm watch
  agentvm logs claude-1 -f

  # Manage
  agentvm attach claude-1
  agentvm exec claude-1 "ls /workspace"
  agentvm restart claude-1
  agentvm clone claude-1 claude-1-fork
  agentvm rename claude-1 claude-main
  agentvm killall --tag task=X
  agentvm clean
  agentvm purge

  # Keys & config
  agentvm env set ANTHROPIC_API_KEY=sk-ant-...
  agentvm env list
  agentvm doctor

${BOLD}PROFILES${RESET}
  Profiles declare which CLI to run, what binary paths the sandbox needs, and
  which host state dirs to seed into the agent's per-spawn HOME.
  See profiles/ directory. Create your own as profiles/<name>.env.

  Profile variables:
    PROFILE_LABEL       Human-readable name
    PROFILE_CMD         Default command (overridden by -- cmd...)
    PROFILE_RO_PATHS    Colon-separated paths to mount read-only in sandbox
    PROFILE_RW_PATHS    Colon-separated paths to mount read-write (rare)
    PROFILE_STATE_DIRS  Colon-separated paths (relative to \$HOME) seeded into
                        <workspace>/.home/ at spawn — gives the agent its own
                        copy of e.g. ~/.claude, ~/.codex.

${BOLD}GITLAWB IDENTITY${RESET}
  Each spawned agent gets a fresh Ed25519 DID by default (auto mode), provided
  the ${BOLD}gl${RESET} binary is installed. The identity lives in <workspace>/.home/.gitlawb/
  and is registered with the gitlawb network. The agent's ~/.gitconfig is
  pre-populated with user.name=<agent-name> and user.email=<DID>@gitlawb so
  any commits/PRs are attributable to the agent.

  Flags:
    ${CYAN}--gitlawb${RESET}      Force-provision (fail if gl is not installed)
    ${CYAN}--no-gitlawb${RESET}   Skip identity provisioning entirely
  Config: set ${BOLD}AGENTVM_GITLAWB_DEFAULT=false${RESET} in ~/.agentvm/config to flip the
  default to off (requires explicit --gitlawb to opt in).
  Install gl from gitlawb.com.

${BOLD}API KEYS${RESET}
  Place provider keys in ${BOLD}\$AGENTVM_HOME/env${RESET} (created automatically on first run).
  Anything exported there (or in your shell rc) is inherited by the agent sandbox.

  Example ~/.agentvm/env:
    ANTHROPIC_API_KEY=sk-ant-...
    OPENAI_API_KEY=sk-proj-...

  Run ${CYAN}agentvm keys${RESET} to see which keys are set.

${BOLD}ENVIRONMENT${RESET}
  AGENTVM_HOME   Workspace root (default: ~/.agentvm)

${BOLD}SANDBOX TYPES${RESET}
  macos          macOS sandbox-exec (Seatbelt) — used automatically on macOS
  bwrap          Linux bubblewrap — used when bwrap(1) is found
  none           No sandbox — runs in workspace dir (with a warning)

${BOLD}STATE${RESET}
  Workspaces:  \$AGENTVM_HOME/workspaces/<name>/
  State files: \$AGENTVM_HOME/state/<name>.env
  SB profiles: \$AGENTVM_HOME/state/<name>.sb  (macOS only)
EOF
}

# ---------------------------------------------------------------------------
# Main dispatcher
# ---------------------------------------------------------------------------
main() {
  # Load config defaults first, then user API keys so keys can reference config values
  load_config_file
  load_env_file

  if [[ $# -eq 0 ]]; then
    cmd_help
    exit 0
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    spawn)      cmd_spawn "$@" ;;
    list|ls)    cmd_list "$@" ;;
    ps)         cmd_ps "$@" ;;
    attach)     cmd_attach "$@" ;;
    exec)       cmd_exec "$@" ;;
    send)       cmd_send "$@" ;;
    broadcast)  cmd_broadcast "$@" ;;
    wait)       cmd_wait "$@" ;;
    logs)       cmd_logs "$@" ;;
    kill)       cmd_kill "$@" ;;
    killall)    cmd_killall "$@" ;;
    clean)      cmd_clean "$@" ;;
    purge)      cmd_purge "$@" ;;
    info)       cmd_info "$@" ;;
    profiles)   cmd_profiles "$@" ;;
    keys)       cmd_keys "$@" ;;
    env)        cmd_env "$@" ;;
    config)     cmd_config "$@" ;;
    doctor)     cmd_doctor "$@" ;;
    run)        cmd_run "$@" ;;
    watch)      cmd_watch "$@" ;;
    swarm)      cmd_swarm "$@" ;;
    restart)    cmd_restart "$@" ;;
    rename|mv)  cmd_rename "$@" ;;
    clone|cp)   cmd_clone "$@" ;;
    diff)       cmd_diff "$@" ;;
    grid)       cmd_grid "$@" ;;
    open)       cmd_open "$@" ;;
    history)    cmd_history "$@" ;;
    stats)      cmd_stats "$@" ;;
    root)       cmd_root "$@" ;;
    upgrade)    cmd_upgrade "$@" ;;
    completion) cmd_completion "$@" ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) echo "agentvm v${VERSION}" ;;
    *)
      error "Unknown command '${cmd}'."
      echo "Run 'agentvm help' for usage." >&2
      exit 1
      ;;
  esac
}

main "$@"
