    'profiles:List profiles'
    'keys:Show API key status'
    'env:Manage env file'
    'doctor:Diagnose installation'
    'run:Ephemeral one-shot agent'
    'watch:Live dashboard'
    'swarm:Spawn N agents'
    'restart:Restart an agent'
    'rename:Rename an agent'
    'clone:Clone a workspace'
    'root:Print $AGENTVM_HOME'
    'upgrade:Self-upgrade (git pull)'
    'completion:Emit shell completion'
    'help:Show help'
    'version:Print version'
  )
  if (( CURRENT == 2 )); then
    _describe -t commands 'agentvm command' commands
    return
  fi
  case "$words[2]" in
    attach|exec|send|logs|kill|info|restart|rename|clone|wait|diff|open)
      agents=("${(@f)$(agentvm list -q 2>/dev/null)}")
      _values 'agent' $agents ;;
    spawn|run|swarm)
      _arguments \
        '(-p --profile)'{-p,--profile}'[profile]:profile:->profiles' \
        '(-P --prompt)'{-P,--prompt}'[prompt file]:file:_files' \
