#compdef asp

# Zsh completion for asp - Arch Build Source Package management tool

local -a commands=(
  'checkout:create a mutable copy of a package'
  'difflog:show changelog since last build'
  'export:export package sources to current directory'
  'list-all:list all known packages'
  'list-arches:list architectures for a package'
  'list-local:list locally tracked packages'
  'list-repos:list repos a package exists in'
  'log:show revision log of a package'
  'ls-files:list files of a package'
  'set-git-protocol:configure git protocol'
  'shortlog:show condensed log of a package'
  'show:show PKGBUILD of a package'
  'untrack:remove local tracking of a package'
  'update:update local copies of tracked packages'
)

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --force)'{-f,--force}'[overwrite existing files]' \
  '1:command:->commands' \
  '*:package' && return 0

case $state in
  commands)
    _describe -t commands 'asp command' commands
    ;;
esac
