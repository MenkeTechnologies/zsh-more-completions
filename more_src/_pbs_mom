#compdef pbs_mom

# pbs_mom: PBS/TORQUE per-node MoM daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-a[alarm seconds]:s:' \
  '-c[config file]:file:_files' \
  '-C[checkpoint dir]:dir:_files -/' \
  '-d[home dir]:dir:_files -/' \
  '-D[run in foreground]' \
  '-h[hot start]' \
  '-L[log file]:file:_files' \
  '-M[mom port]:port:' \
  '-p[node spec port]:port:' \
  '-r[recover]:val:(all recover purge)' \
  '-R[resource manager port]:port:' \
  '-s[server hostname]:host:_hosts' \
  '-x[debug]' \
  '-q[quiet]' \
  '*::pbs_mom args:_files' && ret=0
return ret
