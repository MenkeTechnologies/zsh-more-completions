#compdef pbs_mom
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man8/pbs_mom.8B.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pbs_mom: PBS/TORQUE per-node MoM daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-a[alarm timeout in seconds]:sec:' \
  '-c[alternate configuration file]:file:_files' \
  '-C[checkpoint directory (Cray only)]:dir:_files -/' \
  '-d[home directory (PBS_HOME)]:dir:_files -/' \
  '-H[hostname]:host:_hosts' \
  '-L[log file path]:file:_files' \
  '-M[port for batch requests]:port:' \
  '-R[port for resource monitor requests]:port:' \
  '-S[port pbs_server is listening on]:port:' \
  '-p[preserve running jobs on restart]' \
  '-P[terminate and remove all jobs on restart]' \
  '-q[requeue jobs without terminating processes]' \
  '-r[terminate processes and requeue jobs]' \
  '-x[disable privilege port verification (testing)]' \
  '*::pbs_mom args:_files' && ret=0
return ret
