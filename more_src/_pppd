#compdef pppd

local -a arguments

arguments=(
    'updetach[Detach from terminal after connection established]'
    'nodetach[Do not detach from controlling terminal]'
    'silent[Wait for LCP packet from peer]'
    'passive[Wait for valid LCP packet from peer]'
    'holdoff[Wait time before re-initiating link]:seconds'
    'maxfail[Max connection attempts before giving up]:count'
    'persist[Reopen connection after it terminates]'
    'nopersist[Exit after connection is made and terminated]'
    'demand[Initiate link only on demand]'
    'idle[Disconnect if idle for specified seconds]:seconds'
    'logfile[Append log messages to file]:log file:_files'
    'logfd[Send log messages to file descriptor]:fd'
    'debug[Enable debug logging]'
    'kdebug[Set kernel debugging level]:level'
    'show-password[Show password in log messages]'
    'noauth[Do not require peer to authenticate]'
    'auth[Require peer to authenticate]'
    'require-pap[Require PAP authentication]'
    'require-chap[Require CHAP authentication]'
    'require-mschap[Require MS-CHAP authentication]'
    'require-mschap-v2[Require MS-CHAPv2 authentication]'
    'require-eap[Require EAP authentication]'
    'refuse-pap[Refuse PAP authentication]'
    'refuse-chap[Refuse CHAP authentication]'
    'refuse-mschap[Refuse MS-CHAP authentication]'
    'refuse-mschap-v2[Refuse MS-CHAPv2 authentication]'
    'refuse-eap[Refuse EAP authentication]'
    'name[Set local system name for authentication]:name'
    'user[Set username for authenticating with peer]:username'
    'password[Set password for authenticating with peer]:password'
    'remotename[Set assumed name of remote system]:name'
    'usehostname[Use hostname for authentication]'
    'login[Use system password database for PAP]'
    'enable-session[Enable session accounting via PAM]'
    'default-asyncmap[Disable asyncmap negotiation]'
    'asyncmap[Set async character map]:map'
    'noasyncmap[Disable async character map]'
    'default-mru[Disable MRU negotiation]'
    'mru[Set MRU value]:mru'
    'mtu[Set MTU value]:mtu'
    'multilink[Enable multilink]'
    'mp[Enable multilink]'
    'nomp[Disable multilink]'
    'nomultilink[Disable multilink]'
    'plugin[Load specified plugin]:plugin name'
    'connect[Use specified command to set up serial line]:command'
    'disconnect[Run specified command after disconnecting]:command'
    'init[Run specified command to initialize serial line]:command'
    'lock[Create UUCP-style lock file for serial device]'
    'nolock[Do not create lock file]'
    'nodeflate[Disable deflate compression]'
    'nobsdcomp[Disable BSD-Compress compression]'
    'novj[Disable Van Jacobson TCP/IP header compression]'
    'novjccomp[Disable VJ connection-ID compression]'
    'noipdefault[Disable default IP address]'
    'defaultroute[Add default route through interface]'
    'nodefaultroute[Disable default route]'
    'replacedefaultroute[Replace existing default route]'
    'proxyarp[Enable proxy ARP]'
    'noproxyarp[Disable proxy ARP]'
    'usepeerdns[Ask peer for DNS server addresses]'
    'netmask[Set interface netmask]:netmask'
    'ipcp-accept-local[Accept peer idea of local IP]'
    'ipcp-accept-remote[Accept peer idea of remote IP]'
    'noip[Disable IPCP and IP]'
    'noipv6[Disable IPv6CP and IPv6]'
    'nosendip[Do not send IP packets]'
    'norecvip[Do not accept IP packets]'
    'crtscts[Use hardware flow control]'
    'nocrtscts[Disable hardware flow control]'
    'xonxoff[Use software flow control]'
    'modem[Use modem control lines]'
    'local[Do not use modem control lines]'
    'sync[Use synchronous HDLC serial encoding]'
    '*:serial device or speed:'
)

_arguments -s -S $arguments
