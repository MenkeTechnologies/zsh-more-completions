#compdef btrfs-corrupt-block
# Documentation: https://github.com/kdave/btrfs-progs/blob/master/btrfs-corrupt-block.c
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(-l --logical)'{-l+,--logical=}'[logical extent to corrupt]:bytenr:' \
  '(-c --copy)'{-c+,--copy=}'[copy of the extent (default 0)]:n:' \
  '(-b --bytes)'{-b+,--bytes=}'[number of bytes to corrupt]:n:' \
  '(-e --extent-record)'{-e,--extent-record}'[corrupt the extent record]' \
  '(-E --extent-tree)'{-E,--extent-tree}'[corrupt the whole extent tree]' \
  '(-u --chunk-record)'{-u,--chunk-record}'[corrupt given chunk]' \
  '(-U --chunk-tree)'{-U,--chunk-tree}'[corrupt the whole chunk tree]' \
  '(-i --inode)'{-i+,--inode=}'[inode number to corrupt]:n:' \
  '(-x --file-extent)'{-x+,--file-extent=}'[file extent item]:n:' \
  '(-m --metadata-block)'{-m+,--metadata-block=}'[metadata block to corrupt]:n:' \
  '(-K --key)'{-K+,--key=}'[corrupt the given key (u64,u8,u64)]:key:' \
  '(-f --field)'{-f+,--field=}'[field name to corrupt]:field:' \
  '(-r --root)'{-r+,--root=}'[operate on this root]:rootid:' \
  '(-C --csum)'{-C+,--csum=}'[delete csum for bytenr]:bytenr:' \
  '(-k --keys)'{-k,--keys}'[corrupt block keys]' \
  '(-I --item)'{-I,--item}'[corrupt item]' \
  '(-D --dir-item)'{-D,--dir-item}'[corrupt dir item]' \
  '(-d --delete)'{-d,--delete}'[delete item]' \
  '--block-group=[corrupt given block group]:bg:' \
  '--value=[value for corrupting data]:value:' \
  '--offset=[offset for corrupting data]:offset:' \
  '*:device:_files' && ret=0

return ret
