#compdef btrfs-corrupt-block
# Documentation: https://man.archlinux.org/search?q=btrfs-corrupt-block
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-l+[logical address]:n:' \
  '-c+[copy number]:n:' \
  '-b+[bytes]:n:' \
  '-e[eb mode]' \
  '-E[no eb]' \
  '-f+[fields to corrupt]:fields:' \
  '-i+[inode]:n:' \
  '-K+[keyed inode]:n:' \
  '-m+[mirror]:n:' \
  '-X+[extent]:n:' \
  '*:device:_files' && ret=0

return ret
