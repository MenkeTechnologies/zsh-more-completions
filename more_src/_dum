#compdef dum

# egoist/dum — npm script runner (`src/args.rs`)

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '-c+[change working directory first]:dir:_files -/' \
  '-i[interactive script picker]' \
  '-s[silent: suppress script info output]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'dum command' compadd -- run install i add remove uninstall t test
  ;;
rest)
  case $line[1] in
    run|install|i|add|remove|uninstall|t|test)
      _arguments '*::script args:_default' && ret=0
      ;;
    *)
      _arguments '*::args:_default' && ret=0
      ;;
  esac
  ;;
esac

return ret
