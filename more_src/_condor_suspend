#compdef condor_suspend
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_suspend.html
# suspend jobs from the HTCondor queue

local ret=1

_arguments -s -S \
  '-help[display usage information]' \
  '-version[display version information]' \
  '-long[display result ClassAd]' \
  '-totals[display success/failure totals]' \
  '-pool[specify a pool by central manager host name and optional port]:hostname:_hosts' \
  '-name[send the command to the named schedd]:scheddname' \
  '-addr[send the command to the machine at the given address]:address' \
  '-debug[send debugging information to stderr]' \
  '-constraint[suspend all jobs which match the constraint]:expression' \
  '-all[suspend all the jobs in the queue]' \
  '*:job or user:_default' && ret=0

return ret
