#compdef csmooth
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/csmooth.html
# Adaptively smooth a 2-D image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[raw 2-D image input file with integer counts]:file:_files' \
  'sclmap=[optional smoothing scale map]:file:_files' \
  'outfile=[output adaptively smoothed image]:file:_files' \
  'outsigfile=[output map of signal significance]:file:_files' \
  'outsclfile=[output image of kernel sizes]:file:_files' \
  'conmeth=[convolution method (sliding cell or FFT)]:conmeth:(slide fft)' \
  'conkerneltype=[kernel type]:conkerneltype:(gauss tophat)' \
  'sigmin=[minimum signal-to-noise threshold for smoothing]:sigmin:' \
  'sigmax=[maximum signal-to-noise threshold]:sigmax:' \
  'sclmin=[initial minimum smoothing scale in pixels]:sclmin:' \
  'sclmax=[maximum allowable smoothing scale in pixels]:sclmax:' \
  'sclmode=[controls automatic scale computation or user map]:sclmode:' \
  'stepzero=[initial step size for increasing smoothing scale]:stepzero:' \
  'bkgmode=[background computation method]:bkgmode:' \
  'bkgmap=[external background image file]:file:_files' \
  'bkgerr=[external background error image file]:file:_files' \
  'clobber=[overwrite existing output files]:clobber:(yes no)' \
  'verbose=[verbosity level for progress reporting]:verbose:(0 1 2 3 4 5)' && ret=0

return ret
