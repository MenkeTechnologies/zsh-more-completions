#compdef kube-ovn-controller
# _kube-ovn-controller — Kube-OVN cluster controller
# upstream: https://github.com/kubeovn/kube-ovn
# Flags from pkg/controller/config.go ParseFlags() pflag bindings on tip.

_kube-ovn-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--ovn-nb-addr=[ovn-nb address]:addr:' \
        '--ovn-sb-addr=[ovn-sb address]:addr:' \
        '--ovn-timeout=[ovn command timeout (s)]:s:' \
        '--ovsdb-con-timeout=[ovsdb connect timeout (s)]:s:' \
        '--ovsdb-con-maxretry=[max retries connecting to ovsdb]:n:' \
        '--ovsdb-inactivity-timeout=[ovsdb inactivity check timeout (s)]:s:' \
        '--cust-crd-retry-min-delay=[min delay between custom CRD retries (s)]:s:' \
        '--cust-crd-retry-max-delay=[max delay between custom CRD retries (s)]:s:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--default-ls=[default logical switch name]:name:' \
        '--default-cidr=[default CIDR for namespaces without LS annotation]:cidr:' \
        '--default-gateway=[default gateway for default-cidr]:ip:' \
        '--default-gateway-check=[check default subnet gateway]:bool:(true false)' \
        '--default-logical-gateway=[create logical gateway for default subnet]:bool:(true false)' \
        '--default-exclude-ips=[exclude IPs in default switch]:ips:' \
        '--default-u2o-interconnection=[underlay-to-overlay interconnection]:bool:(true false)' \
        '--cluster-router=[cluster router name]:name:' \
        '--node-switch=[node gateway switch name]:name:' \
        '--node-switch-cidr=[node switch CIDR]:cidr:' \
        '--node-switch-gateway=[node switch gateway IP]:ip:' \
        '--service-cluster-ip-range=[Kubernetes Service ClusterIP range]:cidr:' \
        '--worker-num=[worker parallelism]:n:' \
        '--enable-pprof[enable pprof endpoint]' \
        '--pprof-port=[pprof port]:port:' \
        '--secure-serving[enable secure serving for pprof]' \
        '--network-type=[OVN network type]:type:(geneve vlan vxlan)' \
        '--default-provider-name=[default provider interface name]:name:' \
        '--default-interface-name=[default host interface name]:name:' \
        '--default-vlan-name=[default vlan name]:name:' \
        '--default-vlan-id=[default vlan id]:n:' \
        '--pod-nic-type=[default pod NIC implementation]:type:(veth-pair internal-port)' \
        '--enable-lb=[enable load balancer]:bool:(true false)' \
        '--enable-np=[enable NetworkPolicy support]:bool:(true false)' \
        '--np-enforcement=[NetworkPolicy enforcement]:mode:(standard lax)' \
        '--enable-eip-snat=[enable EIP and SNAT]:bool:(true false)' \
        '--enable-external-vpc=[enable external VPC support]:bool:(true false)' \
        '--enable-ecmp=[enable ECMP route for centralized subnets]:bool:(true false)' \
        '--keep-vm-ip=[keep IP for kubevirt pod on rebuild]:bool:(true false)' \
        '--enable-lb-svc=[support loadbalancer Service]:bool:(true false)' \
        '--enable-ovn-lb-prefer-local=[enable OVN LB prefer-local]:bool:(true false)' \
        '--enable-metrics=[enable metrics endpoint]:bool:(true false)' \
        '--enable-anp=[enable AdminNetworkPolicy/BANP]:bool:(true false)' \
        '--enable-dns-name-resolver=[enable DNSNameResolver]:bool:(true false)' \
        '--enable-ovn-ipsec=[enable OVN IPSec]:bool:(true false)' \
        '--cert-manager-ipsec-cert=[use cert-manager for IPSec certs]:bool:(true false)' \
        '--enable-live-migration-optimize=[enable kubevirt live-migration optimization]:bool:(true false)' \
        '--external-gateway-config-ns=[external-gateway-config configmap namespace]:ns:' \
        '--external-gateway-switch=[external gateway switch name]:name:' \
        '--external-gateway-net=[external network name]:name:' \
        '--external-gateway-vlanid=[external gateway vlan id]:n:'
}

_kube-ovn-controller "$@"
