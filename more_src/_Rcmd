#compdef Rcmd
# Documentation: https://stat.ethz.ch/R-manual/R-devel/library/utils/html/PkgUtils.html
# Rcmd: front-end dispatcher that runs R CMD subcommands

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print short help message and exit]' \
  '(-v --version)'{-v,--version}'[print version info and exit]' \
  '1:command:(BATCH COMPILE SHLIB INSTALL REMOVE build check Rd2pdf Rdconv Rprof Sweave Stangle config javareconf rtags LINK Rdiff)' \
  '*::args:_files' && ret=0

return ret
