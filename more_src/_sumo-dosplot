#compdef sumo-dosplot
# Documentation: https://smtg-bham.github.io/sumo/sumo-dosplot.html
# sumo density of states plotting tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --filename)'{-f,--filename}'[VASP XML file to analyze]:file:_files' \
  '(-c --code)'{-c,--code}'[input format]:code:(vasp questaal)' \
  '(-p --prefix)'{-p,--prefix}'[prefix for generated output files]:prefix:' \
  '(-d --directory)'{-d,--directory}'[output directory for results]:dir:_files -/' \
  '(-e --elements)'{-e,--elements}'[elemental orbitals to include]:elements:' \
  '(-o --orbitals)'{-o,--orbitals}'[split orbitals into lm-decomposed contributions]:orbitals:' \
  '(-a --atoms)'{-a,--atoms}'[atoms to include in plot]:atoms:' \
  '--spin=[select spin channel]:spin:(up down 1 -1)' \
  '(-s --subplot)'{-s,--subplot}'[plot elements on separate subplots]' \
  '(-g --gaussian)'{-g,--gaussian}'[standard deviation for Gaussian broadening]:sigma:' \
  '--columns=[number of legend columns]:columns:' \
  '--legend-cutoff=[DOS percentage threshold for legend labels]:pct:' \
  '--no-legend[hide the legend]' \
  '--legend-frame[display box around legend]' \
  '--no-shift[do not shift Fermi level to zero]' \
  '--zero-energy=[reference energy for shifting]:energy:' \
  '--total-only[plot only total density of states]' \
  '--no-total[exclude total DOS from plot]' \
  '--height=[graph height dimension]:height:' \
  '--width=[graph width dimension]:width:' \
  '--xmin=[minimum x-axis energy value]:xmin:' \
  '--xmax=[maximum x-axis energy value]:xmax:' \
  '--config=[custom color configuration file]:file:_files' \
  '--style=[matplotlib style specifications]:style:' \
  '--no-base-style[disable default sumo styling]' \
  '--xlabel=[energy axis label text]:label:' \
  '--ylabel=[DOS axis label text]:label:' \
  '--yscale=[y-axis scaling factor]:scale:' \
  '--zero-line[plot vertical line at zero energy]' \
  '--format=[output format]:format:(pdf svg jpg png)' \
  '--dpi=[image pixel density]:dpi:' \
  '--font=[font selection for plots]:font:' && ret=0

return ret
