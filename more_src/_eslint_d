#compdef eslint_d
# Documentation: https://github.com/mantoni/eslint_d.js
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# eslint_d: drop-in eslint replacement with a background daemon.
# Inherits all eslint CLI flags plus management commands and --fix-to-stdout.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--cache[only check changed files]' \
  '--cache-location=[path to cache file or directory]:cache location:_files' \
  '--cache-strategy=[cache strategy]:strategy:(metadata content)' \
  '(-c --config)'{-c,--config}'=[config file]:config file:_files' \
  '--env=[specify environments]:environment' \
  '--ext=[specify file extensions]:extensions' \
  '(-f --format)'{-f,--format}'=[output format]:format:(stylish compact tab unix visualstudio json json-with-metadata junit jslint-xml checkstyle html codeframe table)' \
  '--fix[automatically fix problems]' \
  '--fix-dry-run[show fixes without applying]' \
  '--fix-to-stdout[print fixed file to stdout (requires --stdin)]' \
  '--fix-type=[types of fixes to apply]:fix type:(directive problem suggestion layout)' \
  '--global=[define global variables]:globals' \
  '--ignore-path=[path to ignore file]:ignore file:_files' \
  '--ignore-pattern=[patterns to ignore]:pattern' \
  '--no-eslintrc[disable use of eslintrc]' \
  '--no-ignore[disable ignore patterns]' \
  '--no-inline-config[disable inline configuration comments]' \
  '(-o --output-file)'{-o,--output-file}'=[output file]:output file:_files' \
  '--parser=[parser module]:parser' \
  '--parser-options=[parser options]:options' \
  '--plugin=[plugins to use]:plugin' \
  '--quiet[report errors only]' \
  '--resolve-plugins-relative-to=[directory for plugin resolution]:directory:_directories' \
  '--rule=[specify rules]:rule' \
  '--rulesdir=[additional rules directory]:directory:_directories' \
  '--stdin[lint code from stdin]' \
  '--stdin-filename=[filename for stdin]:filename' \
  '--max-warnings=[max warnings before failure]:count' \
  '--color[force color output]' \
  '--no-color[disable color output]' \
  '--init[generate config file]' \
  '--debug[enable debug output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*:file or directory:_files' && ret=0

case $state in
  cmd)
    local -a daemon_cmds=(
      'start:start the eslint_d daemon'
      'stop:stop the eslint_d daemon'
      'restart:restart the daemon'
      'status:show daemon status (pid, eslint version)'
    )
    _describe -t commands 'eslint_d command' daemon_cmds && ret=0
    _files && ret=0
    ;;
esac

return ret
