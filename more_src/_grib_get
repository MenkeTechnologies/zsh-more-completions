#compdef grib_get
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_get
# Source: ecmwf/eccodes tools/grib_get.dox — read key values from GRIB messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[force, do not fail on error]' \
    '-p+[keys to print (key[:s/d/i],...)]:keys:_default' \
    '-F+[C-style float format]:format:_default' \
    '-l+[value close to latitude,longitude[,mode,file]]:latlon:_default' \
    '-P+[append keys to default print list]:keys:_default' \
    '-w+[where clause filter]:filter:_default' \
    '-n+[print all keys in namespace]:namespace:_default' \
    '-s+[key=value pairs to set]:kvs:_default' \
    '(- *)-V[show version]' \
    '-W+[minimum column width (default 10)]:n:_default' \
    '-m[print MARS keys]' \
    '-M[turn off multi-field support]' \
    '-g[copy GTS header]' \
    '-G[GRIBEX compatibility mode]' \
    '-T+[message type]:type:(T B M A)' \
    '-7[do not fail on wrong message length]' \
    '-X+[input file offset in bytes]:offset:_default' \
    '-i+[data value at given index]:index:_default' \
    '*:grib file:_files' \
    && ret=0

return ret
