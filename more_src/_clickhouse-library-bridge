#compdef clickhouse-library-bridge
# Documentation: https://man.archlinux.org/search?q=clickhouse-library-bridge
# Reference accessed: 2026-05-16

# clickhouse-library-bridge: dictionary library bridge
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config-file=[config file]:file:_files' \
  '--log-file=[log file]:file:_files' \
  '--errorlog-file=[error log file]:file:_files' \
  '--log-level=[log level]:level:(none fatal critical error warning notice information debug trace)' \
  '--listen-host=[bind host]:host:' \
  '--http-port=[HTTP port]:port:' \
  '--http-timeout=[HTTP timeout]:seconds:' \
  '--max-server-connections=[max connections]:n:' \
  '--keep-alive-timeout=[keep-alive timeout]:seconds:' \
  '--http-max-field-value-size=[max field size]:bytes:' \
  '--http-max-field-name-size=[max field name size]:bytes:' \
  '--http-max-fields=[max headers]:n:' \
  '--stacktrace[print stack trace on error]' \
  '*::clickhouse-library-bridge args:_files' && ret=0
return ret
