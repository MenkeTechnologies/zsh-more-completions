#compdef fcoeplumb
# Documentation: https://man.archlinux.org/search?q=fcoeplumb
# Reference accessed: 2026-05-16

# fcoeplumb: plumb FCoE on a network interface (DCB/lldpad backend)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-i[interface]:ifname:' \
  '-c[create FCoE]:ifname:' \
  '-d[destroy FCoE]:ifname:' \
  '-r[reset FCoE]:ifname:' \
  '-v[verbose]' \
  '*::fcoeplumb args:_files' && ret=0
return ret
