#compdef lookatme

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-t+[theme]:theme:(dark light)' \
  '--theme=[theme]:theme:(dark light)' \
  '-s+[style]:style:' \
  '--style=[code style]:style:' \
  '--live[enable live reloading]' \
  '--single[single slide mode]' \
  '--no-ext-warn[no warnings for missing extensions]' \
  '-l[list available styles]' \
  '--list-styles[list available styles]' \
  '--exts=[load extensions]:extensions:' \
  '-e+[load extensions]:extensions:' \
  '--no-slide-numbers[hide slide numbers]' \
  '--title=[presentation title]:title:' \
  '1:markdown file:_files -g "*.md"' && ret=0

return ret
