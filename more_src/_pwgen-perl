#compdef pwgen-perl

# pwgen-perl: Perl reimplementation of pwgen
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-c[at least one capital]' \
  '--capitalize[at least one capital]' \
  '-A[no capitals]' \
  '--no-capitalize[no capitals]' \
  '-n[at least one number]' \
  '--numerals[at least one number]' \
  '-0[no numbers]' \
  '--no-numerals[no numbers]' \
  '-y[include symbols]' \
  '--symbols[include symbols]' \
  '-s[fully random (no human-friendly form)]' \
  '--secure[fully random (no human-friendly form)]' \
  '-B[no ambiguous chars]' \
  '--ambiguous[no ambiguous chars]' \
  '-1[one password per line]' \
  '-N[number of passwords]:n:' \
  '--num-passwords=[number of passwords]:n:' \
  '-H[hide tty]:fd:' \
  '*::pwgen-perl args:_files' && ret=0
return ret
