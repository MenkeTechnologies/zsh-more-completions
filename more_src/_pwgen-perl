#compdef pwgen-perl
# Documentation: https://man.cx/pwgen
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pwgen-perl: Perl reimplementation of pwgen
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --capitalize -A --no-capitalize)'{-c,--capitalize}'[at least one capital]' \
  '(-c --capitalize -A --no-capitalize)'{-A,--no-capitalize}'[no capitals]' \
  '(-n --numerals -0 --no-numerals)'{-n,--numerals}'[at least one number]' \
  '(-n --numerals -0 --no-numerals)'{-0,--no-numerals}'[no numbers]' \
  '(-y --symbols)'{-y,--symbols}'[include symbols]' \
  '(-s --secure)'{-s,--secure}'[fully random passwords]' \
  '(-B --ambiguous)'{-B,--ambiguous}'[no ambiguous characters]' \
  '-1[one password per line]' \
  '-C[print in columns]' \
  '(-v --no-vowels)'{-v,--no-vowels}'[no vowels]' \
  '(-a --alt-phonics)'{-a,--alt-phonics}'[alt-phonics (backwards compat)]' \
  '(-r --remove-chars)'{-r+,--remove-chars=}'[remove characters]:chars:' \
  '(-N --num-passwords)'{-N+,--num-passwords=}'[number of passwords]:n:' \
  '(-H --sha1)'{-H+,--sha1=}'[SHA1 of file as seed]:file[\#seed]:' \
  '*::pwgen-perl args:_files' && ret=0
return ret
