#compdef xray-checker
# Documentation: https://xray-checker.kutovoy.dev/usage/cli/
# xray-checker - Prometheus exporter for monitoring Xray proxies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display version information]' \
  '--config-file=[configuration file path]:file:_files' \
  '--config-folder=[folder with configuration files]:dir:_files -/' \
  '*--subscription-url=[subscription URL]:url' \
  '--subscription-update[enable automatic subscription updates]' \
  '--subscription-update-interval=[interval to refresh subscriptions (seconds)]:seconds' \
  '--proxy-check-interval=[how often to check proxy status (seconds)]:seconds' \
  '--proxy-check-method=[method for checking proxies]:method:(ip status download)' \
  '--proxy-timeout=[timeout for proxy operations (seconds)]:seconds' \
  '--proxy-ip-check-url=[URL for IP verification checks]:url' \
  '--proxy-status-check-url=[URL for connectivity status checks]:url' \
  '--proxy-download-url=[URL for download speed testing]:url' \
  '--proxy-download-timeout=[timeout for download tests (seconds)]:seconds' \
  '--proxy-download-min-size=[minimum bytes for download validation]:bytes' \
  '--proxy-resolve-domains[enable domain resolution]' \
  '--simulate-latency[enable latency simulation]' \
  '--run-once[execute single check cycle then exit]' \
  '--start-delay=[initial delay before starting checks]:seconds' \
  '--xray-start-port=[base port for Xray instances]:port' \
  '--xray-log-level=[Xray logging verbosity level]:level' \
  '--metrics-host=[metrics server host address]:host' \
  '--metrics-port=[metrics server port]:port' \
  '--metrics-protected[enable authentication on metrics]' \
  '--metrics-username=[username for metrics authentication]:username' \
  '--metrics-password=[password for metrics authentication]:password' \
  '--metrics-instance=[instance identifier for metrics]:instance' \
  '--metrics-push-url=[URL for metrics export]:url' \
  '--metrics-base-path=[base path for metrics endpoints]:path' \
  '--web-show-details[display detailed information in web UI]' \
  '--web-public[make web interface publicly accessible]' \
  '--log-level=[application logging level]:level' && ret=0

return ret
