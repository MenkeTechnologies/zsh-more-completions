#compdef hydra
# _hydra — Ory Hydra OAuth 2.0 / OpenID Connect server (admin CLI + serve subcommand for the OAuth2 provider)
# upstream: https://github.com/ory/hydra
# Subcommands from cmd/root.go on tip; shared --config/--dev flags from configx.RegisterFlags.

_hydra() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[YAML config file (repeatable)]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'serve:run public + admin OAuth2/OIDC HTTP APIs (subcommands: all|public|admin)'
                'create:create OAuth2 clients or JWK sets (subcommands: client|jwks)'
                'get:retrieve OAuth2 clients or JWK sets (subcommands: client|jwks)'
                'list:list OAuth2 clients (subcommand: clients)'
                'update:update OAuth2 clients (subcommand: client)'
                'delete:delete clients, JWK sets, or access tokens (subcommands: client|jwks|access-tokens)'
                'import:import OAuth2 clients or JWKs (subcommands: client|jwk)'
                'perform:perform an OAuth2 flow against the server (subcommands: client-credentials|authorization-code|device-code)'
                'revoke:revoke an OAuth2 token (subcommand: token)'
                'introspect:introspect an OAuth2 token (subcommand: token)'
                'migrate:database migration helpers (subcommands: sql|status)'
                'janitor:purge stale rows from the OAuth2/consent database'
                'version:show version'
                'help:show help for any subcommand'
            )
            _describe -t commands 'hydra command' subs
            ;;
        args)
            case $line[1] in
                serve)
                    _arguments \
                        '--dev[disable critical security checks for development]' \
                        '*--config=[YAML config file]:file:_files' \
                        '1: :->serveCmd'
                    case $state in
                        serveCmd) _describe -t commands 'serve target' '(all:both APIs admin:admin only public:public only)' ;;
                    esac
                    ;;
                janitor)
                    _arguments \
                        '--keep-if-younger=[do not delete rows newer than this]:dur:' \
                        '--access-lifespan=[access-token lifespan threshold]:dur:' \
                        '--refresh-lifespan=[refresh-token lifespan threshold]:dur:' \
                        '--consent-request-lifespan=[consent request lifespan threshold]:dur:' \
                        '*--config=[YAML config file]:file:_files' \
                        '-e[read DSN from environment instead of arg]' \
                        '*:dsn:'
                    ;;
                migrate)
                    _arguments '1: :->migCmd'
                    case $state in
                        migCmd) _describe -t commands 'migrate target' '(sql:run SQL migrations status:show migration status)' ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

_hydra "$@"
