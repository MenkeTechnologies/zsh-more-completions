#compdef storm-conv
# Documentation: https://github.com/moves-rwth/storm/tree/master/src/storm-conv-cli
# Reference accessed: 2026-05-27
# Verified: upstream moves-rwth/storm option registrations in
#   src/storm-conv/settings/modules/{ConversionGeneralSettings,
#   ConversionInputSettings,ConversionOutputSettings,JaniExportSettings,
#   PrismExportSettings}.cpp
#
# Coverage: full Conv-CLI option set (general + input + output + JANI export +
# PRISM export).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show available options]:filter (optional):' \
  '--version[print version information]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--debug[enable debug-level logging]' \
  '--trace[enable trace-level logging]' \
  '(-c --config)'{-c+,--config=}'[read additional options from config file]:file:_files' \
  '--prism=[PRISM input file]:file:_files -g "*.(nm|pm|sm|prism)"' \
  '(-pc --prismcompat)'{-pc,--prismcompat}'[PRISM compatibility mode]' \
  '--jani=[JANI input file]:file:_files -g "*.jani"' \
  '(-prop --prop)'{-prop+,--prop=}'[property/properties to include]:property:' \
  '(-const --constants)'{-const+,--constants=}'[constant definitions, e.g. N=5,K=2]:assignments:' \
  '(-jprop --janiproperty)'{-jprop+,--janiproperty=}'[JANI property filter]:filter:' \
  '--tojani=[export model as JANI file]:file:_files' \
  '--toprism=[export model as PRISM file]:file:_files' \
  '--location-variables=[automaton.location variables to expose]:list:' \
  '--edge-assignments[allow edge assignments in JANI export]' \
  '--flatten[flatten composition to a single module/automaton]' \
  '--globalvars[force global variables in JANI export]' \
  '--localvars[force local variables in JANI export]' \
  '--compactjson[emit compact JSON in JANI export]' \
  '--remove-arrays[eliminate arrays during JANI export]' \
  '--remove-functions[eliminate functions during JANI export]' \
  '--replace-unassigned-vars[replace unassigned variables]' \
  '--simplify-composition[simplify parallel composition]' \
  '--location-elimination=[eliminate locations during JANI export]:max-locs max-edges:' \
  '--simplify[apply static analysis to simplify PRISM output]' \
  '*:input model:_files' && ret=0

return ret
