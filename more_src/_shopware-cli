#compdef shopware-cli
# _shopware-cli — Shopware e-commerce platform CLI alias (FriendsOfShopware/shopware, Go); cobra
# upstream: https://github.com/FriendsOfShopware/shopware-cli

_shopware-cli() {
    local -a sub=(
        'account:login:login to account'
        'account:logout:logout'
        'account:company:list:list companies'
        'account:company:use:use company'
        'account:producer:extension:list:list extensions'
        'account:producer:extension:upload:upload extension'
        'completion:generate completion'
        'extension:build:build extension'
        'extension:zip:zip extension'
        'extension:create:scaffold new extension'
        'extension:prepare:prepare extension'
        'extension:validate:validate extension'
        'extension:get-changelog:generate changelog'
        'extension:upload:upload extension'
        'project:admin-build:build admin'
        'project:storefront-build:build storefront'
        'project:create:create new project'
        'project:dump:dump project'
        'project:config:pull:pull config'
        'project:config:push:push config'
        'project:dispatch:dispatch action'
        'project:extension:list:list installed extensions'
        'project:extension:install:install extension'
        'project:extension:uninstall:uninstall extension'
        'project:extension:upgrade:upgrade extension'
        'project:worker:run worker'
        'project:browser-build:browser build'
        'project:configure:configure project'
        'project:console:run console cmd'
        'project:ci:run ci checks'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'shopware-cli subcommand' sub ;;
        args)
            case $words[1] in
                extension:build|extension:zip|extension:validate|extension:prepare|extension:upload|extension:get-changelog) _arguments \
                    '1:extension path:_files -/' \
                    '--config=+[config file]:file:_files' \
                    '--shopware-version=+[version]:str:' ;;
                project:create) _arguments \
                    '1:path:_files -/' \
                    '--version=+[shopware version]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_shopware-cli "$@"
