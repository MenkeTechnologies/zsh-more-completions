#compdef nvidia-detector
# Documentation: https://man.archlinux.org/search?q=nvidia-detector
# Reference accessed: 2026-05-16

# nvidia-detector: detect NVIDIA card and recommended driver
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::nvidia-detector args:_files' && ret=0
return ret
