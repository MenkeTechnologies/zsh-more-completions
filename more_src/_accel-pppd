#compdef accel-pppd
# Documentation: https://github.com/accel-ppp/accel-ppp/blob/master/accel-pppd/main.c
# Reference accessed: 2026-05-16
# Verified: upstream accel-pppd/main.c.

# accel-pppd: high-performance PPP/PPTP/PPPoE/L2TP/SSTP daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[config file (required)]:file:_files' \
  '(-p --pid)'{-p,--pid=}'[PID file]:file:_files' \
  '(-d --daemon)'{-d,--daemon}'[daemon mode]' && ret=0
return ret
