#compdef emissary-cli emissary edgectl
# _emissary-cli — Ambassador Labs Emissary emissary-cli CLI command-line frontend wrapping the Emissary-Ingress formerly Ambassador API Gateway CNCF Incubating open-source Kubernetes-native Envoy-based API gateway written in Go and Python managing Listeners Hosts Mappings TLSContext Filter RateLimitService TracingService LogService Module ConsulResolver MS-AmbassadorListener CRDs login deploy install upgrade telepresence connect Edge Stack DevPortal API-Catalog (Ambassador Labs CNCF team Richard Li Flynn, Go/Python); cobra
# upstream: https://www.getambassador.io/products/api-gateway

_emissary-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'install:install Emissary-ingress'
        'upgrade:upgrade Emissary-ingress'
        'uninstall:uninstall Emissary-ingress'
        'cluster-list:list clusters'
        'edge-stack:Edge Stack operations'
        'configure:configure CLI'
        'cluster:cluster operations'
        'connect:connect operations'
        'license:license operations'
        'cert-manager:cert-manager operations'
        'devportal:DevPortal operations'
        'apply:apply manifests'
        'get:get resources'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files -g "kubeconfig *.yaml *.yml"' \
        '-n+[namespace]:str:' \
        '--namespace=+[ns]:str:' \
        '--context=+[name]:str:' \
        '--license-key=+[key]:str:' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '--no-banner[no banner]' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '--output=+[fmt]:f:(yaml json table wide)' \
        '-o+[output]:f:(yaml json table wide)' \
        '--enable-ambient[ambient mode]' \
        '--version-flag=+[v]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'emissary subcommand' sub ;;
        args)
            case $words[1] in
                install|upgrade|uninstall) _arguments '*:arg:' ;;
                get) _arguments '1:type:(mapping host listener filter tlscontext ratelimit tracingservice logservice consulresolver module ambassadorlistener)' '*:name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_emissary-cli "$@"
