#compdef gotags

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --verbose)'{-v,--verbose}'[Verbose]' \
  '(-f)-f+[Read list of file names from file]:file:_files' \
  '(-R)'-R'[Recurse into directories]' \
  '(-silent)'--silent'[Silent mode]' \
  '(-sort)'--sort'[Sort tags]' \
  '*:go paths:_files -g "*.go(-.)"'
