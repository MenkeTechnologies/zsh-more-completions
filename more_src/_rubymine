#compdef rubymine
# Documentation: https://www.jetbrains.com/help/ruby/opening-files-from-command-line.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--wait[wait for files to be closed before returning]' \
  '--line[line number to position caret at]:line number' \
  '--column[column number to position caret at]:column number' \
  '--nosplash[do not show splash screen]' \
  '--dontReopenProjects[do not reopen projects; show welcome screen]' \
  '--disableNonBundledPlugins[launch without loading manually installed plugins]' \
  '*:files or directories:_files' && ret=0

return ret
