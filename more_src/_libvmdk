#compdef vmdkinfo vmdkmount
# _libvmdk — libvmdk tools (libyal VMware VMDK parser; vmdkinfo prints VMDK metadata for split + monolithic flat/sparse images, vmdkmount FUSE-mounts a VMDK chain read-only; -h help, -V version, -v verbose, -o image offset, -p password, -B bytes-per-sector, -X exclusive lock; positional argument is the .vmdk descriptor file)
# upstream: https://github.com/libyal/libvmdk
# Flags from libyal/libvmdk vmdktools/vmdkinfo.c on tip.

_libvmdk() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-p+[password]:password:' \
        '-B+[bytes per sector]:bytes:' \
        '-X[exclusive lock]' \
        '*:VMDK file:_files -g "*.vmdk"'
}

_libvmdk "$@"
