#compdef solargraph

# Zsh completion for solargraph (Ruby language server and linter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'bundle:generate documentation cache for bundled gems'
      'clear:delete all cached documentation'
      'config:create or check config file'
      'download-core:download Ruby core documentation'
      'reporters:list diagnostics reporters'
      'scan:scan workspace for problems'
      'socket:start a Solargraph socket server'
      'stdio:start a Solargraph stdio server'
      'typecheck:run type checking'
    )
    _describe -t commands 'solargraph command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (config)
        _arguments \
          '1:action:(create check)' && ret=0
        ;;
      (socket)
        _arguments \
          '--host[listen host]:host' \
          '--port[listen port]:port' && ret=0
        ;;
      (scan)
        _arguments \
          '--directory[workspace directory]:directory:_files -/' \
          '*:file:_files -g "*.rb"' && ret=0
        ;;
      (typecheck)
        _arguments \
          '--directory[workspace directory]:directory:_files -/' \
          '--level[type checking level]:level:(typed strict strong)' \
          '*:file:_files -g "*.rb"' && ret=0
        ;;
    esac
    ;;
esac

return ret
