#compdef casashell
# Documentation: https://casadocs.readthedocs.io/en/v6.4.3/api/configuration.html
# CASA interactive shell (modular CASA / casashell entry point)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--logfile=[path to log file]:logfile:_files' \
  '--log2term[direct output to terminal]' \
  '--nologger[do not start CASA logger]' \
  '--nologfile[do not create a log file]' \
  '--nogui[avoid starting GUI tools]' \
  '--rcdir=[location for startup files, internal working files]:dir:_files -/' \
  '--norc[do not load user config.py]' \
  '--colors=[prompt color]:color:(Neutral NoColor Linux LightBG)' \
  '--pipeline[load CASA pipeline modules on startup]' \
  '--agg[startup without graphical backend]' \
  '--iplog[create ipython log]' \
  '--notelemetry[disable telemetry collection]' \
  '--nocrashreport[do not submit an online report when CASA crashes]' \
  '--datapath=[data path(s) (colon separated)]:datapath:_files -/' \
  '--user-site[include user local site-packages lib in path]' \
  '-c[execute Python eval string or script]:script:_files' \
  '*:script:_files' && ret=0

return ret
