#compdef pcm-core
# Documentation: https://raw.githubusercontent.com/intel/pcm/master/src/pcm-core.cpp
# Intel PCM custom core performance event monitor

local ret=1

_arguments -s -S \
  '(-h --help /h)'{-h,--help,/h}'[show help]' \
  '--version[print version]' \
  '-silent[suppress informational output]' \
  '(-c /c)'{-c,/c}'[print CPU model name]' \
  '-csv[output compact CSV to screen]' \
  '-csv=[output compact CSV to file]:file:_files' \
  '*-e[specify custom performance event]:event' \
  '(-yc --yescores /yc)'{-yc=,--yescores=,/yc=}'[enable output for specific cores]:cores' \
  '(-i /i)'{-i=,/i=}'[number of iterations]:count' \
  '-txn[set transaction rate value]:rate' \
  '*::delay or external program:_normal' && ret=0

return ret
