#compdef qsub
# Documentation: https://docs.adaptivecomputing.com/torque/4-0-2/Content/topics/commands/qsub.htm
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '-N[job name]:name' \
  '-q[destination queue]:queue' \
  '*-l[resource list]:resource' \
  '-e[path for standard error]:path:_files' \
  '-o[path for standard output]:path:_files' \
  '-j[join stdout and stderr]:join type:(oe eo n)' \
  '-m[mail notification]:events:(a b e n)' \
  '-M[mail address]:address' \
  '-V[export all environment variables]' \
  '-v[export specified environment variables]:variables' \
  '-d[working directory]:directory:_directories' \
  '-W[additional attributes]:attributes' \
  '-A[account string]:account' \
  '-S[shell to use]:shell:_files' \
  '-r[job is rerunnable]:rerunnable:(y n)' \
  '-p[job priority]:priority' \
  '-I[interactive job]' \
  '-t[job array]:array range' \
  '-h[place hold on job]' \
  '-a[defer execution until datetime]:datetime' \
  '-k[keep stdout/stderr on execution host]:keep:(o e oe n)' \
  '-c[checkpoint options]:checkpoint' \
  '-C[directive prefix]:prefix' \
  '-f[fault tolerant]' \
  ':job script:_files' && ret=0

return ret
