#compdef ncl ncargpath nclnewfile ncargcc
# _ncl — NCAR Command Language interpreted scripting language for analysis and visualization of climate atmospheric data (UCAR team, C); custom argparse
# upstream: https://github.com/NCAR/ncl

_ncl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-n[no debug]' \
        '-x[trace]' \
        '-Q[quiet]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output file]:file:_files' \
        '-p+[plot driver]:p:(x11 ps eps epsi pdf png cgm)' \
        '-wks+[workstation]:w:(x11 ps eps epsi pdf png cgm)' \
        '-d+[data dir]:dir:_files -/' \
        '-s+[stack size]:n:' \
        '-no-stdin[no stdin]' \
        '-debug-level=+[level]:n:' \
        '-debug[debug mode]' \
        '-wkBackgroundColor=+[color]:color:' \
        '-wkForegroundColor=+[color]:color:' \
        '-wkColorMap=+[colormap]:str:' \
        '-NumWorkStations=+[N]:n:' \
        '-NumOpenFiles=+[N]:n:' \
        '*:script file:_files -g "*.ncl"'
}

_ncl "$@"
