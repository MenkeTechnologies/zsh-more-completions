#compdef qpid-printevents
# Documentation: https://qpid.apache.org/releases/qpid-cpp-1.39.0/cpp-broker/book/chapter-Managing-CPP-Broker.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. Connects to broker(s) and
# prints management events one-per-line; default broker localhost:5672.

local ret=1
_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '--heartbeats[print heartbeats]' \
  '--sasl-mechanism=[SASL mechanism]:mech:' \
  '--sasl-service-name=[SASL service name]:name:' \
  '--ssl-certificate=[SSL certificate file]:file:_files' \
  '--ssl-key=[SSL key file]:file:_files' \
  '--ha-admin[connect to HA backup broker]' \
  '*:broker address [user/pass@]host[:port]:' && ret=0
return ret
