#compdef qpid-printevents
# Documentation: https://qpid.apache.org/components/messaging-api/index.html
# Reference accessed: 2026-05-17
# Verified: Apache Qpid Proton qpid-printevents(1) — connect to
# broker(s) and print management events one-per-line. Real flags:
# -h/--help, --heartbeats, --sasl-mechanism, --sasl-service-name,
# --ssl-certificate, --ssl-key, --ha-admin. Default broker
# localhost:5672.
# Removed from prior file: bogus man.archlinux.org search URL.

local ret=1
_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '--heartbeats[print heartbeats]' \
  '--sasl-mechanism=[SASL mechanism]:mech:' \
  '--sasl-service-name=[SASL service name]:name:' \
  '--ssl-certificate=[SSL certificate file]:file:_files' \
  '--ssl-key=[SSL key file]:file:_files' \
  '--ha-admin[HA admin mode]' \
  '*:broker (user/pass@host[:port]):' && ret=0
return ret
