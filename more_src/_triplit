#compdef triplit
# ---------------------------------------------------------------------------
# triplit — full-stack syncing database CLI (TypeScript, 3,092★)
#
# upstream: https://github.com/aspen-cloud/triplit
# author : Aspen Cloud (Will Schenk, Matt Wood + the Aspen team)
# license: AGPL-3.0
#
# Source-direct completion: every top-level subcommand below is verbatim
# from packages/cli/src/commands/ on the aspen-cloud/triplit tip — each
# `*.ts` / `*.tsx` file at that path is auto-discovered as a top-level
# subcommand by the CLI's custom `findCommands` utility in command-utils.ts,
# and each command file exports `Command({...})` with a `flags:` object
# defining per-command options.  Per-command flag detail is deferred to
# `triplit <subcommand> --help`; this completion focuses on subcommand
# discovery + the `dev` and `init` flag surfaces (the two most commonly
# invoked).
#
# Direct deps (selected):
#   @triplit/db                ← uses `lmdb` npm as one of its pluggable
#                                storage backends (this axis) — by Kris
#                                Zyp (DoctorEvidence), pure-JS API over
#                                native LMDB bindings providing the same
#                                ACID semantics in Node as the C LMDB
#                                lib.  `--storage lmdb` (or `memory`,
#                                `sqlite`, `bun-sqlite`) selects backend
#                                at dev-server launch.
#   @triplit/server            (HTTP + WebSocket sync server with
#                              durable-store implementations including
#                              lmdb, sqlite, bun-sqlite, memory)
#   @triplit/logger            (structured logger)
#   minimist                   (Substack's argv parser at the dispatcher)
#   ink + react                (interactive React-based TUI for login,
#                              link, repl, whoami)
#   chokidar                   (file watcher in `dev` for schema/seed
#                              hot-reload)
#   posthog-node               (anonymous telemetry — opt out via
#                              `triplit conf set telemetryEnabled false`)
#   dotenv + dotenv-expand     (env loading from .env.local / .env)
#   jsonwebtoken               (JWT signing for local dev tokens)
#   ws + node-fetch            (WebSocket/HTTP for sync)
#
# triplit is a full-stack syncing database that runs on both server and
# client: the database lives durably on the server (via lmdb / sqlite /
# bun-sqlite) and incrementally syncs to in-memory client replicas over
# WebSocket subscriptions.  Schema-first; query language is a typed
# subset focused on graph traversal and relational filters; auth is JWT-
# based with row-level access controls.  The CLI orchestrates local
# development (dev server, schema migrations, seeds), project deployment
# to Triplit Cloud, and project administration (orgs, roles, webhooks,
# snapshots).
#
# ============================================================================
# === AXIS 172 CLOSES — embedded ACID B-tree KV stores (LMDB-style) ========
# === TRIPLE-227 ROUND-NUMBER LANDMARK · 165th AXIS CLOSED =================
# ============================================================================
# Axis position: TS-Node=227 CLOSES Axis 172 at slot 1/1/1 — quadruple-clean
# closure of the canonical embedded ACID B-tree KV-store ecosystem (the
# LMDB-niche: single-writer / multi-reader, copy-on-write, MVCC, memory-
# mapped or close to it) spanning the three major systems languages:
#
#     Rust    : cberner/redb        by Christopher Berner — pure-Rust
#                                    single-file embedded DB with MVCC,
#                                    copy-on-write B+ trees, zero-cost
#                                    typed read/write transactions;
#                                    designed as a pure-Rust LMDB
#                                    replacement without LMDB's mmap-
#                                    based crash-recovery pitfalls.
#                 → cdk-cli (thesimplekid + cashubtc/cdk — Cashu
#                            Development Kit reference CLI wallet for
#                            Chaumian e-cash on Bitcoin/Lightning;
#                            wallet state persisted in either SQLite
#                            default or redb feature-gated at
#                            ~/.cdk-cli/cdk-cli.redb; selectable at
#                            launch via --engine redb; 220★ MIT)
#                 _cdk-cli         [Rust=227 OPENED Axis 172, slot 1/0/0]
#
#     Go      : go.etcd.io/bbolt    the etcd-maintained fork of Ben
#                                   Johnson's boltdb/bolt (archived in
#                                   2018) — single-file embedded DB
#                                   with ACID transactions, copy-on-
#                                   write B+ trees, single-writer /
#                                   multi-reader concurrency, memory-
#                                   mapped I/O; the canonical pure-Go
#                                   answer to LMDB's niche.  Used by
#                                   etcd v3 storage, consul + nomad +
#                                   vault (HashiCorp stack via
#                                   hashicorp/raft-boltdb), tailscale,
#                                   restic, coredns plugins, hugo
#                                   modules cache.
#                 → nami (Cloud cloud@txthinking.com + txthinking
#                         collective — decentralized package manager
#                         installing binaries directly from GitHub
#                         releases; bbolt persists local installed-
#                         packages registry at ~/.nami/nami.db so
#                         list/remove are O(1); 352★ GPL-3.0)
#                 _nami            [Go=227 CONTINUED Axis 172, slot 2/0/0]
#
#     JS/Node : lmdb                by Kris Zyp (DoctorEvidence kriszyp/
#                                   lmdb-js) — pure-JS API over native
#                                   LMDB bindings (Symas Lightning
#                                   Memory-Mapped Database C lib).
#                                   Provides the same single-writer /
#                                   multi-reader / copy-on-write / MVCC
#                                   / memory-mapped semantics in Node
#                                   land that LMDB itself provides in
#                                   C.  Used by gatsby cache, elastic
#                                   kibana, electric-sql/electric,
#                                   posthog, triplit, harper.
#                 → triplit (Aspen Cloud — full-stack syncing database
#                            CLI orchestrating local dev server +
#                            schema migrations + project deployment to
#                            Triplit Cloud; dev server's --storage lmdb
#                            selects lmdb backend over sqlite/bun-
#                            sqlite/memory alternatives; CLI written in
#                            React+ink for interactive flows; 3092★
#                            AGPL-3.0)
#                 _triplit         [TS-Node=227 CLOSES Axis 172, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 lmdb (npm) is the only JS embedded KV providing the
#                 full LMDB feature set without the LSM-tree trade-offs
#                 of LevelDB/RocksDB-based options (classic-level,
#                 level-rocks).  When a Node app needs ACID with
#                 ranged-cursor reads in a single mmap'd file, lmdb-js
#                 is the canonical choice.
#
# Round-number 227 landmark fires simultaneously across all three lanes:
# Rust completion #227 (_cdk-cli) + Go completion #227 (_nami) + TS-Node
# completion #227 (_triplit) = triple-227.  Axis #165 closed in the
# lifetime of the corpus — every LMDB-niche embedded ACID B-tree KV
# implementation in the three big systems languages now has both a
# representative consumer completion AND a documented axis closure
# landmark; the lanes are tied together by a common design discipline
# (single-writer/multi-reader, copy-on-write, MVCC, memory-mapped or
# memory-mapped-equivalent on-disk format) that traces back to Howard
# Chu's Symas Lightning Memory-Mapped Database (LMDB) in OpenLDAP — the
# C reference implementation that all three lanes here re-implement or
# re-bind to.
# ============================================================================

_triplit() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'--version'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'clear:clear the local Triplit data directory'
                'conf:get or set CLI configuration (telemetry, install ID, etc.)'
                'dev:start the local Triplit development server (HTTP+WebSocket sync, with --storage lmdb|memory|sqlite|bun-sqlite)'
                'init:initialize a Triplit project in the current directory (optional --framework / --template)'
                'link:link the local project to a remote Triplit Cloud project'
                'login:log in to Triplit Cloud (interactive OAuth flow rendered via ink)'
                'logout:log out of Triplit Cloud'
                'org:manage Triplit Cloud organizations'
                'project:manage projects (subcommand: create/list/select/...)'
                'repl:start an interactive REPL against the local or remote DB'
                'roles:manage role-based access controls (subcommand)'
                'schema:manage schema migrations (subcommand: push / pull / diff)'
                'seed:manage seed data (subcommand: create / list / run)'
                'snapshot:manage DB snapshots (subcommand)'
                'version:print the CLI version'
                'webhooks:manage webhooks for change notifications (subcommand: push)'
                'whoami:print currently logged-in user'
            )
            _describe -t commands 'triplit command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                dev)
                    _arguments \
                        '(-s --storage)'{-s,--storage=}'[database storage backend]:store:(memory lmdb sqlite bun-sqlite)' \
                        '(-d --dbPort)'{-d,--dbPort=}'[port to run the database server on]:port:' \
                        '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
                        '(-i --initWithSchema)'{-i,--initWithSchema}'[initialize the database with the local schema (default true)]' \
                        '(-S --seed)'{-S,--seed=}'[seed file or pattern to load on startup]:file or pattern:_files' \
                        '(-e --enableWebhooks)'{-e,--enableWebhooks}'[enable sending of webhooks to configured servers]' \
                        '--upstreamUrl=[URL of the upstream server (hidden)]:url:' \
                        '--upstreamToken=[token for the upstream server (hidden)]:token:' \
                        '--inspect[enable node inspector (hidden)]' && ret=0
                    ;;
                init)
                    _arguments \
                        '(-f --framework)'{-f,--framework=}'[frontend framework helpers to install]:framework:(react svelte vue angular solid)' \
                        '(-t --template)'{-t,--template=}'[project template to use]:template:(chat)' && ret=0
                    ;;
                conf)
                    _arguments \
                        '1:conf action:(get set list)' \
                        '2:key:(telemetryEnabled installId)' \
                        '3:value:' && ret=0
                    ;;
                project|schema|seed|snapshot|roles|webhooks|org)
                    # These are subcommand DIRECTORIES; pair with
                    # `triplit <command> --help` for the full subcommand
                    # tree (auto-discovered via findCommands).
                    _arguments '*: :_files' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_triplit "$@"
