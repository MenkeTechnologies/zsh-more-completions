#compdef rojo

local curcontext="$curcontext" state line ret=1

_rojo_commands() {
  local -a commands=(
    'build:build a project into a Roblox file'
    'doc:open Rojo documentation'
    'fmt:format Rojo project files'
    'init:initialize a new Rojo project'
    'open:open a place in Roblox Studio'
    'plugin:manage the Rojo Studio plugin'
    'serve:start a live sync server'
    'sourcemap:generate a sourcemap'
    'upload:upload a built project to Roblox'
    'version:show version'
  )
  _describe -t commands 'rojo command' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--color[colorize output]:when:(auto always never)' \
  '1:command:_rojo_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      build)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '--watch[rebuild on changes]' \
          '*:project file:_files' && ret=0
        ;;
      init)
        _arguments -s -S \
          '--kind[project kind]:kind:(place model)' \
          '*:directory:_directories' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '--address[server address]:address' \
          '--port[server port]:port' \
          '*:project file:_files' && ret=0
        ;;
      sourcemap)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '--include-non-scripts[include non-script instances]' \
          '*:project file:_files' && ret=0
        ;;
      upload)
        _arguments -s -S \
          '--api-key[Roblox API key]:key' \
          '--asset-id[asset ID to upload to]:id' \
          '--cookie[Roblox cookie]:cookie' \
          '*:project file:_files' && ret=0
        ;;
      plugin)
        _arguments -s -S \
          '1:action:(install)' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
