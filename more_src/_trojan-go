#compdef trojan-go
# _trojan-go — Trojan proxy in Go (p4gefau1t/trojan-go)
# upstream: https://github.com/p4gefau1t/trojan-go
# Flags from proxy/option.go, url/option.go, easy/easy.go, version/version.go (flag).

_trojan-go() {
    _arguments \
        '(- *)-h[show help]' \
        '-config=[config file (.yaml/.yml/.json)]:file:_files -g "*.(yml|yaml|json)"' \
        '-stdin-format=[read from stdin instead]:fmt:(disabled yaml json)' \
        '-stdin-suppress-hint[suppress hint text on stdin]' \
        '-version[print version info]' \
        '-url=[client setup via URL link]:url:' \
        '-url-option=[URL-mode key=val options]:opts:' \
        '-server[run as server (easy mode)]' \
        '-client[run as client (easy mode)]' \
        '-password=[password (easy mode)]:pass:' \
        '-remote=[remote address (easy mode)]:addr:' \
        '-local=[local address (easy mode)]:addr:' \
        '-key=[server TLS key]:file:_files -g "*.(pem|key)"' \
        '-cert=[server TLS cert]:file:_files -g "*.(pem|crt)"'
}

_trojan-go "$@"
