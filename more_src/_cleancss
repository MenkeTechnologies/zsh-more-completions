#compdef cleancss clean-css

# Zsh completion for cleancss - clean-css CSS optimizer CLI

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-o,--output}'=[output file]:file:_files' \
  {-f,--format}'=[output format]:format:(keep-breaks beautify)' \
  '--source-map[generate source map]' \
  '--source-map-inline-sources[include sources in source map]' \
  '--input-source-map=[input source map file]:file:_files' \
  '--batch[process input files one by one]' \
  '--batch-suffix=[output file suffix for batch mode]:suffix' \
  '--inline=[inline import rules]:rules:(all local remote none)' \
  '--compatibility=[compatibility mode]:mode:(ie7 ie8 ie9 \*)' \
  '-O+[optimization level]:level:(0 1 2)' \
  '--with-rebase[enable URL rebasing]' \
  '--remove-inlined-files[remove inlined files]' \
  '--skip-rebase[skip URL rebasing]' \
  {-d,--debug}'[show debug information]' \
  '*:files:_files -g "*.css"'
