#compdef sftimecont
# Documentation: https://raw.githubusercontent.com/ahay/src/master/user/fomels/Mtimecont.c
# Madagascar: Forward or reverse time continuation using fast marching

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'forwd=[continue forward or backward (y/n)]:flag:(y n)' \
  'vel=[input is velocity (y) or slowness squared (n)]:flag:(y n)' \
  'order=[accuracy order]:order:(1 2)' \
  '*:RSF file:_files' && ret=0

return ret
