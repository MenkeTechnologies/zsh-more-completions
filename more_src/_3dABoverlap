#compdef 3dABoverlap
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dABoverlap.html
# AFNI count overlap of automasks of datasets A and B

local ret=1

_arguments -s -S \
  '-no_automask[treat inputs as existing masks, not automasks]' \
  '-quiet[minimize program output]' \
  '-verb[progress reports to stderr]' \
  '*:dataset:_files' && ret=0

return ret
