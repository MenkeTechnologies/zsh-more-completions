#compdef mtpaint
# Documentation: https://manpages.debian.org/bookworm/mtpaint/mtpaint.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm mtpaint(1) manpage OPTIONS.
# Removed from prior file: fabricated -h flag (uses --help only) and bogus
# man.archlinux.org search URL.

# mtpaint: simple painting program for creating icons and pixel art
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show usage information]' \
  '--version[show version information]' \
  '-s[grab a screenshot]' \
  '-v[start in viewer mode]' \
  '*:image file:_files' && ret=0
return ret
