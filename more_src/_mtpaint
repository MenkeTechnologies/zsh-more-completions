#compdef mtpaint
# Documentation: https://mtpaint.sourceforge.net/handbook/en_GB/chap_A.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mtpaint: simple painting program for creating icons and pixel art.
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show usage information]' \
  '--version[show version information]' \
  '--flist=[read a list of files from a file]:file:_files' \
  '--sort[sort files passed as arguments]' \
  '--cmd[start in commandline scripting mode without GUI]' \
  '-s[grab a screenshot]' \
  '-v[start in viewer mode]' \
  '*:image file:_files' && ret=0
return ret
