#compdef nbdev_export
# Documentation: https://nbdev.fast.ai/api/doclinks.html
# nbdev_export: export notebooks in a path to Python modules

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--path=[path or filename]:path:_files' \
  '--procs=[space-separated module:name processors to use]:procs:' \
  '--symlinks[follow symlinks]' \
  '--file_glob=[only include files matching glob]:glob:' \
  '--file_re=[only include files matching regex]:regex:' \
  '--folder_re=[only enter folders matching regex]:regex:' \
  '--skip_file_glob=[skip files matching glob]:glob:' \
  '--skip_file_re=[skip files matching regex]:regex:' \
  '--skip_folder_re=[skip folders matching regex]:regex:' && ret=0

return ret
