#compdef netscanner
# Documentation: https://man.archlinux.org/search?q=netscanner
# Reference accessed: 2026-05-16

_arguments -s \
  '(-t --tick-rate)'{-t,--tick-rate=}'[ticks per second]:rate:' \
  '(-f --frame-rate)'{-f,--frame-rate=}'[frames per second]:rate:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
