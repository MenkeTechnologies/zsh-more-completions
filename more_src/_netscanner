#compdef netscanner
# Documentation: https://github.com/Chleba/netscanner
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-t --tick-rate)'{-t,--tick-rate=}'[ticks per second]:rate:' \
  '(-f --frame-rate)'{-f,--frame-rate=}'[frames per second]:rate:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
