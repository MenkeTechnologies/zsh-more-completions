#compdef glam2
# Documentation: https://meme-suite.org/meme/doc/glam2.html
# MEME Suite: discover gapped motifs (Gapped Local Alignment of Motifs)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output directory (default glam2_out), fail if exists]:dir:_files -/' \
  '-O[output directory, overwrite if exists]:dir:_files -/' \
  '-2[examine both strands of nucleotide sequences]' \
  '-z[minimum number of sequences in the alignment]:minimum sites:' \
  '-a[minimum number of aligned columns]:minimum aligned:' \
  '-b[maximum number of aligned columns]:maximum aligned:' \
  '-d[Dirichlet mixture file]:file:_files' \
  '-D[deletion pseudocount]:pseudocount:' \
  '-E[no-deletion pseudocount]:pseudocount:' \
  '-I[insertion pseudocount]:pseudocount:' \
  '-J[no-insertion pseudocount]:pseudocount:' \
  '-q[residue abundance weighting]:weight:' \
  '-r[number of alignment replicates]:num:' \
  '-n[end each replicate after this many iterations]:n:' \
  '-w[initial alignment width]:columns:' \
  '-t[starting temperature for simulated annealing]:temperature:' \
  '-c[cooling factor per iteration]:cooling factor:' \
  '-u[minimum (final) temperature]:minimum temperature:' \
  '-m[column-sampling vs site-sampling ratio]:probability:' \
  '-x[site sampling algorithm]:algorithm:(0 1 2)' \
  '-s[random number seed]:seed:' \
  '-p[print progress information]' \
  '-Q[suppress non-essential messages]' \
  '*:alphabet/sequence file:_files' && ret=0

return ret
