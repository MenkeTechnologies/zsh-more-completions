#compdef crawley

_arguments -s -S \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '-depth[maximum crawl depth]:depth:' \
    '-user-agent[custom user agent string]:user-agent:' \
    '-all[include subdomains in crawl]' \
    '-timeout[request timeout duration]:duration:' \
    '-skip-ssl[skip SSL certificate verification]' \
    '-delay[delay between requests]:duration:' \
    '-max-size[maximum response body size in bytes]:size:' \
    '-robots[respect robots.txt]' \
    '-sitemap[print sitemap XML]' \
    '-silent[suppress output except results]' \
    '-no-head[skip HEAD requests]' \
    '-follow-sitemap[follow sitemap.xml links]' \
    '1:url:'
