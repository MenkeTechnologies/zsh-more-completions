#compdef go-mod-upgrade
# Documentation: https://github.com/oligot/go-mod-upgrade
# go-mod-upgrade: update outdated Go module dependencies interactively

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --pagesize)'{-p,--pagesize}'=[number of modules per page]:size' \
  '(-f --force)'{-f,--force}'[force update all modules in non-interactive mode]' \
  '(-l --list)'{-l,--list}'[list available updates without interactivity]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '--hook=[command to execute for each updated module]:hook' \
  '(-i --ignore)'{-i,--ignore}'=[ignore modules matching the regular expression]:regex' \
  '--version[print the version]' && ret=0

return ret
