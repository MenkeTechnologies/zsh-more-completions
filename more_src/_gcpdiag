#compdef gcpdiag
# Documentation: https://man.archlinux.org/search?q=gcpdiag
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--project=[GCP project ID]:project:' \
  '--auth-adc[Use application default credentials]' \
  '1: : _default' \
  '*::args: _default'
