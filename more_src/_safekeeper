#compdef safekeeper
# _safekeeper — Neon serverless Postgres safekeeper (Paxos-replicated WAL acceptor + S3 WAL offloader serving the pageserver and compute nodes)
# upstream: https://github.com/neondatabase/neon
# Flags from safekeeper/src/bin/safekeeper.rs on tip (clap-derive).

_safekeeper() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '(-D --datadir)'{-D+,--datadir=}'[safekeeper data directory]:dir:_files -/' \
        '--id=[safekeeper node id]:n:' \
        '--init[initialize with --id and exit]' \
        '(-l --listen-pg)'{-l+,--listen-pg=}'[Postgres WAL endpoint (host:port)]:hostport:' \
        '--listen-pg-tenant-only=[Postgres WAL endpoint accepting tenant-scoped tokens only (host:port)]:hostport:' \
        '--listen-http=[HTTP management/metrics endpoint (host:port)]:hostport:' \
        '--listen-https=[HTTPS management/metrics endpoint (host:port)]:hostport:' \
        '--advertise-pg=[advertised Postgres WAL endpoint]:hostport:' \
        '--availability-zone=[availability zone label]:az:' \
        '(-n --no-sync)'{-n,--no-sync}'[do not fsync — UNSAFE]' \
        '--dump-control-file=[dump control file to this path and exit]:file:_files' \
        '--broker-endpoint=[storage broker URI (http[s]://host:port)]:url:_urls' \
        '--broker-keepalive-interval=[broker keepalive interval]:dur:' \
        '--heartbeat-timeout=[peer dead-after duration]:dur:' \
        '--peer-recovery=[enable peer recovery]:bool:(true false)' \
        '--remote-storage=[TOML inline-table WAL backup config]:toml:' \
        '--max-offloader-lag=[max bytes lag before disabling backup election]:bytes:' \
        '--wal-backup-parallel-jobs=[max parallel WAL segment uploads]:n:' \
        '--disable-wal-backup[disable WAL backup to S3]' \
        '--pg-auth-public-key-path=[.pem file for --listen-pg JWT validation]:file:_files' \
        '--pg-tenant-only-auth-public-key-path=[.pem file for tenant-only JWT validation]:file:_files' \
        '--http-auth-public-key-path=[.pem file for HTTP JWT validation]:file:_files' \
        '--current-thread-runtime[use current-thread tokio runtime]' \
        '--walsenders-keep-horizon[keep walsender horizon on disconnect]' \
        '--partial-backup-timeout=[partial-segment backup timeout]:dur:' \
        '--max-timeline-disk-usage-bytes=[per-timeline disk usage limit in bytes (0=off)]:bytes:'
}

_safekeeper "$@"
