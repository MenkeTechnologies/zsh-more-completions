#compdef fpp pathpicker

# Zsh completion for fpp (Facebook PathPicker) - interactive file picker from command output

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --record)'{-r,--record}'[record input and output]' \
  '(-c --command)'{-c,--command}'=[command to execute on selected files]:command:' \
  '(-e --execute-only)'{-e,--execute-only}'=[execute command without interactive selection]:command:' \
  '-nfc[skip file existence checks]' \
  '--no-file-checks[skip file existence checks]' \
  '(-ko --keep-open)'{-ko,--keep-open}'[keep PathPicker open after executing command]' \
  '(-ni --non-interactive)'{-ni,--non-interactive}'[non-interactive mode]' \
  '(-ai --all-input)'{-ai,--all-input}'[consider all input lines as file candidates]'
