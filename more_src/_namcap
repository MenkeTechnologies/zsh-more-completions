#compdef namcap
# Documentation: https://man.archlinux.org/search?q=namcap
# Reference accessed: 2026-05-16

# Zsh completion for namcap - Arch Linux package analysis utility

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(-e --exclude)'{-e,--exclude}'[exclude rules]:rules' \
  '(-i --info)'{-i,--info}'[show informational messages]' \
  '(-m --machine-readable)'{-m,--machine-readable}'[machine-readable output]' \
  '(-r --rules)'{-r,--rules}'[only apply specified rules]:rules' \
  '(-t --tags)'{-t,--tags}'[show available tags]' \
  '*:PKGBUILD or package file:_files -g "*.(pkg.tar.*|PKGBUILD)"'
