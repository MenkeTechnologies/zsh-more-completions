#compdef sslscan
# _sslscan — rbsec sslscan (SSL/TLS cipher + cert + protocol scanner; lists supported ciphers, certificate chain, signature algorithms, group/curve list, with STARTTLS support)
# upstream: https://github.com/rbsec/sslscan
# Flags from sslscan.c argv parser on tip.

_sslscan() {
    _arguments \
        '--help[show help]' \
        '--version[show version and exit]' \
        '--verbose[verbose output]' \
        '--no-colour[disable colored output]' \
        '--no-color[disable colored output]' \
        '--targets=[file with one target per line]:file:_files' \
        '--show-certificate[show certificate details]' \
        '--show-certificates[show certificate chain]' \
        '--no-check-certificate[skip certificate strength checks]' \
        '--show-ciphers[show supported client ciphers]' \
        '--show-cipher-ids[print numeric cipher IDs]' \
        '--show-times[show handshake times]' \
        '--show-client-cas[list CAs accepted for client-auth]' \
        '--show-sigs[show signature algorithms]' \
        '--iana-names[show IANA/RFC cipher names]' \
        '--xml=[write XML output]:file:_files' \
        '--no-cipher-details[suppress curve + EDH key-length detail]' \
        '--certs=[client certificate file]:file:_files' \
        '--pk=[client private key file]:file:_files' \
        '--pkpass=[client private-key password]:pwd:' \
        '--no-ciphersuites[skip cipher-suite enumeration]' \
        '--no-fallback[skip TLS_FALLBACK_SCSV check]' \
        '--no-renegotiation[skip renegotiation check]' \
        '--no-compression[skip compression (CRIME) check]' \
        '--no-heartbleed[skip Heartbleed check]' \
        '--no-groups[skip key-exchange group enumeration]' \
        '--ocsp[check OCSP stapling]' \
        '--starttls-ftp[STARTTLS for FTP]' \
        '--starttls-imap[STARTTLS for IMAP]' \
        '--starttls-irc[STARTTLS for IRC]' \
        '--starttls-ldap[STARTTLS for LDAP]' \
        '--starttls-pop3[STARTTLS for POP3]' \
        '--starttls-smtp[STARTTLS for SMTP]' \
        '--starttls-mysql[STARTTLS for MySQL]' \
        '--starttls-xmpp[STARTTLS for XMPP]' \
        '--starttls-psql[STARTTLS for PostgreSQL]' \
        '--xmpp-server[server-to-server XMPP handshake]' \
        '--ssl2[probe SSLv2 only]' \
        '--ssl3[probe SSLv3 only]' \
        '--tls10[probe TLSv1.0 only]' \
        '--tls11[probe TLSv1.1 only]' \
        '--tls12[probe TLSv1.2 only]' \
        '--tls13[probe TLSv1.3 only]' \
        '--tlsall[probe all TLS versions]' \
        '--bugs[enable OpenSSL bug workarounds]' \
        '--timeout=[socket timeout (sec)]:sec:' \
        '--connect-timeout=[connect timeout (sec)]:sec:' \
        '--sleep=[sleep between requests (ms)]:ms:' \
        '--rdp[RDP preamble before TLS]' \
        '(-4 --ipv4)'{-4,--ipv4}'[force IPv4]' \
        '(-6 --ipv6)'{-6,--ipv6}'[force IPv6]' \
        '--sni-name=[override SNI server name]:sni:' \
        '1:host[:port]:_hosts'
}

_sslscan "$@"
