#compdef pdnsutil

# Zsh completion for pdnsutil - PowerDNS authoritative server utility

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'activate-tsig-key:activate TSIG key for a zone'
  'activate-zone-key:activate DNSKEY in zone'
  'add-record:add a record'
  'add-autoprimary:add a trusted autoprimary'
  'remove-autoprimary:remove a trusted autoprimary'
  'list-autoprimaries:list autoprimaries'
  'add-zone-key:add a DNSKEY to a zone'
  'backend-cmd:perform backend specific command'
  'bench-db:benchmark the database backend'
  'b2b-migrate:migrate zones from backend1 to backend2'
  'change-slave-zone-master:change slave zone master'
  'check-zone:check zone integrity'
  'check-all-zones:check integrity of all zones'
  'clear-zone:clear all records of a zone'
  'create-bind-db:create DNSSEC database for Bind backend'
  'create-secondary-zone:create a secondary zone'
  'create-zone:create an empty zone'
  'deactivate-tsig-key:deactivate TSIG key'
  'deactivate-zone-key:deactivate DNSKEY in a zone'
  'delete-rrset:delete an RRset from a zone'
  'delete-tsig-key:delete TSIG key'
  'delete-zone:delete a zone'
  'disable-dnssec:disable DNSSEC for a zone'
  'edit-zone:edit a zone in your $EDITOR'
  'export-zone-dnskey:export the public DNSKEY'
  'export-zone-ds:export the DS record for a zone'
  'export-zone-key:export the private key for a zone'
  'export-zone-key-pem:export private key for zone in PEM'
  'generate-tsig-key:generate a new TSIG key'
  'generate-zone-key:generate a zone key and print it'
  'get-meta:get zone metadata'
  'hash-password:hash a password for config files'
  'hash-zone-record:hash a record name for NSEC3'
  'hsm:hardware security module operations'
  'increase-serial:increase serial by one for a zone'
  'import-tsig-key:import TSIG key'
  'import-zone-key:import private key into a zone'
  'import-zone-key-pem:import private key in PEM format'
  'ipdecrypt:decrypt an IP address'
  'ipencrypt:encrypt an IP address'
  'list-algorithms:list available DNSSEC algorithms'
  'list-keys:list DNSSEC keys in a zone'
  'list-zone:list all records in a zone'
  'list-all-zones:list all zones'
  'list-member-zones:list zones of a catalog'
  'list-tsig-keys:list all TSIG keys'
  'load-zone:load a zone from a file'
  'lmdb-get-backend-version:get backend version'
  'publish-zone-key:publish DNSKEY for a zone'
  'rectify-zone:rectify a zone'
  'rectify-all-zones:rectify all zones'
  'remove-zone-key:remove DNSKEY from a zone'
  'replace-rrset:replace all records of an RRset'
  'secure-all-zones:secure all zones with DNSSEC'
  'secure-zone:add DNSSEC to a zone'
  'set-kind:set zone kind (master/slave/native)'
  'set-options-zone:set zone options'
  'set-meta:set zone metadata'
  'set-presigned:set zone as presigned'
  'set-publish-cdnskey:set publication of CDNSKEY'
  'set-publish-cds:set publication of CDS'
  'show-zone:show DNSSEC info for a zone'
  'test-schema:test DB schema for errors'
  'unpublish-zone-key:unpublish DNSKEY'
  'unset-presigned:unset zone as presigned'
  'unset-publish-cdnskey:unset CDNSKEY publication'
  'unset-publish-cds:unset CDS publication'
  'zonemd-verify-file:verify ZONEMD in zone file'
  'view-list-zones:list zones in a view'
  'view-add-zone:add a zone to a view'
  'view-del-zone:remove a zone from a view'
  'views-list:list views'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--force[force potentially dangerous actions]' \
  '--config-name=[name of configuration]:name:' \
  '--config-dir=[location of configuration]:dir:_files -/' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pdnsutil command' commands && ret=0
    ;;
esac

return ret
