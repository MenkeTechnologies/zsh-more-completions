#compdef jaegerctl jaeger-cli jaeger-all-in-one jaeger-agent jaeger-collector jaeger-query jaeger-ingester
# _jaegerctl — Jaeger Tracing jaegerctl CLI command-line frontend wrapping the Jaeger CNCF open-source end-to-end distributed tracing system providing all-in-one agent collector query ingester remote-storage Cassandra Elasticsearch Kafka Badger memory OpenTelemetry-OTLP Zipkin-compat Grafana Tempo trace-spans baggage sampling-rate strategy adaptive head-tail (Jaeger CNCF team Yuri Shkuro, Go); cobra
# upstream: https://www.jaegertracing.io/

_jaegerctl() {
    local -a sub=(
        'all-in-one:run all-in-one'
        'agent:run agent'
        'collector:run collector'
        'query:run query service'
        'ingester:run ingester'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--config-file=+[file]:file:_files -g "*.yml *.yaml"' \
        '--log-level=+[level]:l:(debug info warn error)' \
        '--log-encoding=+[fmt]:f:(console json)' \
        '--span-storage.type=+[t]:t:(memory cassandra elasticsearch kafka badger grpc-plugin opensearch)' \
        '--dependency-storage.type=+[t]:t:(memory cassandra elasticsearch grpc-plugin opensearch)' \
        '--cassandra.servers=+[hosts]:_hosts' \
        '--cassandra.keyspace=+[name]:str:' \
        '--es.server-urls=+[url]:str:' \
        '--es.index-prefix=+[name]:str:' \
        '--kafka.consumer.brokers=+[hosts]:_hosts' \
        '--kafka.producer.brokers=+[hosts]:_hosts' \
        '--kafka.topic=+[name]:str:' \
        '--badger.directory-value=+[dir]:dir:_files -/' \
        '--badger.directory-key=+[dir]:dir:_files -/' \
        '--collector.zipkin.host-port=+[host:port]:_hosts' \
        '--collector.otlp.grpc.host-port=+[host:port]:_hosts' \
        '--collector.otlp.http.host-port=+[host:port]:_hosts' \
        '--collector.grpc-server.host-port=+[host:port]:_hosts' \
        '--collector.http-server.host-port=+[host:port]:_hosts' \
        '--agent.tags=+[tags]:str:' \
        '--query.base-path=+[path]:str:' \
        '--query.host-port=+[host:port]:_hosts' \
        '--query.bearer-token-propagation[propagate bearer token]' \
        '--admin.http.host-port=+[host:port]:_hosts' \
        '--sampling.strategies-file=+[file]:file:_files -g "*.json"' \
        '--sampling.strategies-reload-interval=+[d]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'jaeger subcommand' sub ;;
        args) _arguments '*:arg:' ;;
    esac
}

_jaegerctl "$@"
