#compdef idevicerestore
# _idevicerestore — restore / upgrade iOS firmware (libimobiledevice/idevicerestore)
# upstream: https://github.com/libimobiledevice/idevicerestore
# Flags from src/idevicerestore.c.

_idevicerestore() {
    local -a args
    args=(
        '(-i --ecid)'{-i+,--ecid=}'[target a specific device by ECID]:ecid:'
        '(-u --udid)'{-u+,--udid=}'[target a specific device by UDID]:udid:'
        '(-l --latest)'{-l,--latest}'[use the latest available firmware (download on demand)]'
        '(-e --erase)'{-e,--erase}'[full restore (erases all data) instead of update]'
        '(-y --no-input)'{-y,--no-input}'[non-interactive mode (do not prompt)]'
        '(-n --no-action)'{-n,--no-action}'[do not perform any restore action]'
        '(-c --custom)'{-c,--custom}'[restore with a custom firmware (requires bootrom exploit)]'
        '(-s --server)'{-s+,--server=}'[override default signing server URL]:url:'
        '(-x --exclude)'{-x,--exclude}'[exclude NOR / baseband upgrade (legacy devices)]'
        '(-t --shsh)'{-t,--shsh}'[fetch TSS record, save to .shsh, then exit]'
        '(-z --no-restore)'{-z,--no-restore}'[do not restore; stop after booting to the ramdisk]'
        '(-k --keep-pers)'{-k,--keep-pers}'[write personalized components to files for debugging]'
        '--ipsw-info[print info about the IPSW at PATH and exit]'
        '--logfile=[write logging output to FILE (- for stdout)]:file:_files'
        '--variant=[match build identity by this variant]:variant:'
        '--ignore-errors[continue the restore process after certain errors]'
        '(-d --debug)'{-d,--debug}'[print additional debug output]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '1:IPSW firmware file:_files -g "*.ipsw"'
    )
    _arguments -s -S $args
}

_idevicerestore "$@"
