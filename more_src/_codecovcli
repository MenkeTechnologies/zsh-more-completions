#compdef codecovcli codecov-cli

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'do-upload:upload coverage data to Codecov'
  'create-commit:notify Codecov of a new commit'
  'create-report:create a coverage report'
  'create-report-results:create report results'
  'get-report-results:get report results'
  'send-notifications:send PR comment / status notifications'
  'empty-upload:upload an empty coverage report'
  'pr-base-picking:select a PR base'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--auto-load-params-from=[CI platform to load params from]:platform:(github_actions circleci gitlab_ci jenkins bitbucket buildkite drone codebuild semaphore appveyor wercker)' \
  '--codecov-yml-path=[Codecov YAML path]:file:_files' \
  '--enterprise-url=[Codecov Enterprise URL]:url:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'codecovcli subcommand' subcommands && ret=0
    ;;
esac

return ret
