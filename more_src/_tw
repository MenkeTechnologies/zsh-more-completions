#compdef tw
# Documentation: https://man.archlinux.org/search?q=tw
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'info:show system information and health status'
  'credentials:manage workspace credentials'
  'compute-envs:manage compute environments'
  'datasets:manage datasets'
  'data-links:manage data links'
  'labels:manage workspace labels'
  'secrets:manage secrets'
  'pipelines:manage pipelines'
  'pipeline-schemas:store pipeline schemas'
  'launch:launch a pipeline'
  'runs:manage pipeline runs'
  'actions:manage pipeline actions'
  'organizations:manage organizations'
  'workspaces:manage workspaces'
  'teams:manage teams'
  'members:manage organization members'
  'participants:manage workspace participants'
  'collaborators:manage organization collaborators'
  'studios:manage interactive studio sessions'
  'help:show help'
  'completion:generate shell completion'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-t --access-token)'{-t+,--access-token=}'[Seqera access token]:token:' \
  '(-u --url)'{-u+,--url=}'[Seqera API URL]:url:' \
  '(-w --workspace)'{-w+,--workspace=}'[workspace name or id]:workspace:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(json yaml table)' \
  '--insecure[disable TLS verification]' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

local -a crud_subs=(
  'list:list resources'
  'view:show resource details'
  'add:add a resource'
  'update:update a resource'
  'delete:delete a resource'
  'export:export configuration to JSON'
  'import:import configuration from JSON'
)

case $state in
  (cmd) _describe -t cmds 'tw command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (workspaces|organizations|teams|members|participants|collaborators)
        _arguments '*::sub:(list view add update delete leave)' && ret=0 ;;
      (credentials|compute-envs|datasets|data-links|labels|secrets|pipelines|pipeline-schemas|actions|studios)
        _describe -t cs 'subcommand' crud_subs && ret=0 ;;
      (runs)
        _arguments '*::sub:(list view delete relaunch dump cancel)' && ret=0 ;;
      (launch)
        _arguments \
          '(-n --name)'{-n+,--name=}'[run name]:name:' \
          '(-r --revision)'{-r+,--revision=}'[git revision]:rev:' \
          '--params-file=[params file]:file:_files' \
          '--config=[Nextflow config]:file:_files' \
          '--profile=[Nextflow profile]:profile:' \
          '--work-dir=[work directory]:dir:' \
          '--compute-env=[compute env name or id]:env:' \
          '--label=[run label]:label:' \
          '*::pipeline:' && ret=0 ;;
      (info)
        _arguments \
          '--health[show health-check JSON]' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
