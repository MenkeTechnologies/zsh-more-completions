#compdef lessc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-s --silent)'{-s,--silent}'[suppress output of error messages]' \
  '--no-color[disable colorized output]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '--no-ie-compat[disable IE compatibility checks]' \
  '(-x --compress)'{-x,--compress}'[compress output by removing whitespace]' \
  '--clean-css[compress output with clean-css]' \
  '--insecure[allow imports from insecure HTTPS hosts]' \
  '(-M --depends)'{-M,--depends}'[output a makefile import dependency list]' \
  '--no-js[disable inline JavaScript in less files]' \
  '(-l --lint)'{-l,--lint}'[syntax check only]' \
  '--strict-imports[force evaluation of imports]' \
  '--allow-imports[allow imports from insecure hosts]' \
  '--include-path=[set include paths]:paths:_dir_list' \
  '--rewrite-urls=[rewrite URLs in imported files]:mode:(all local off)' \
  '--math=[set math processing]:mode:(always strict parens-division parens strict-legacy)' \
  '--strict-math=[turn on strict math]:option:(on off)' \
  '--strict-units=[turn on strict unit checking]:option:(on off)' \
  '--global-var=[define a global variable]:name=value' \
  '--modify-var=[modify a variable]:name=value' \
  '--url-args=[add URL query parameter]:query string' \
  '--plugin=[load a plugin]:plugin name' \
  '--source-map=[generate source map file]:source map file:_files -g "*.map"' \
  '--source-map-rootpath=[set rootpath for source map]:rootpath' \
  '--source-map-basepath=[set basepath for source map]:basepath:_files -/' \
  '--source-map-include-source[include Less source in source map]' \
  '--source-map-inline[include source map inline in CSS output]' \
  '--source-map-url=[set URL for source map]:URL' \
  '1:input Less file:_files -g "*.less"' \
  '2::output CSS file:_files -g "*.css"' && ret=0

return ret
