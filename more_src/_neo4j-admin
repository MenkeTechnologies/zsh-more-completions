#compdef neo4j-admin

# Zsh completion for neo4j-admin - Neo4j database administration

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dump:dump a database to a file'
  'load:load a database from a dump file'
  'database:manage databases'
  'server:manage the Neo4j server'
  'dbms:manage the DBMS'
  'import:import data into a database'
  'set-initial-password:set the initial password for the neo4j user'
  'set-default-admin:set the default admin user'
  'check-consistency:check the consistency of a database'
  'report:produce a diagnostics report'
  'store-info:print information about a store'
  'memrec:print memory recommendations'
  'unbind:remove cluster state from a database'
  'migrate:migrate a database store format'
  'copy:copy a database'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '--verbose[verbose output]' \
  '--expand-commands[allow property value expansion]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'neo4j-admin command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (dump)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--database=[database name]:database' \
          '--to-path=[destination directory]:directory:_files -/' \
          '--to-stdout[write dump to stdout]' \
          '--overwrite-destination[overwrite existing dump]' && ret=0
        ;;
      (load)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--database=[database name]:database' \
          '--from-path=[source directory]:directory:_files -/' \
          '--from-stdin[read dump from stdin]' \
          '--overwrite-destination[overwrite existing database]' \
          '--info[only print info about the dump]' && ret=0
        ;;
      (import)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--database=[database name]:database' \
          '--nodes=[node CSV files]:files:_files -g "*.csv"' \
          '--relationships=[relationship CSV files]:files:_files -g "*.csv"' \
          '--id-type=[type of IDs]:type:(STRING INTEGER ACTUAL)' \
          '--input-encoding=[character encoding]:encoding' \
          '--delimiter=[CSV delimiter character]:delimiter' \
          '--array-delimiter=[array delimiter character]:delimiter' \
          '--quote=[CSV quote character]:character' \
          '--multiline-fields=[allow multiline fields]:enable:(true false)' \
          '--trim-strings=[trim strings]:enable:(true false)' \
          '--skip-bad-entries-logging=[skip bad entries logging]:enable:(true false)' \
          '--skip-bad-relationships=[skip bad relationships]:enable:(true false)' \
          '--skip-duplicate-nodes=[skip duplicate nodes]:enable:(true false)' \
          '--ignore-empty-strings=[ignore empty strings]:enable:(true false)' \
          '--ignore-extra-columns=[ignore extra columns]:enable:(true false)' \
          '--bad-tolerance=[maximum bad entries]:count' \
          '--threads=[number of threads]:count' \
          '--max-off-heap-memory=[maximum off-heap memory]:size' \
          '--high-parallel-io=[use parallel I/O]:enable:(true false)' \
          '--read-buffer-size=[read buffer size]:size' \
          '--force[overwrite existing database]' \
          '--verbose[enable verbose output]' && ret=0
        ;;
      (set-initial-password)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--require-password-change[require password change on first login]' \
          '1:password' && ret=0
        ;;
      (set-default-admin)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:username' && ret=0
        ;;
      (check-consistency)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--database=[database name]:database' \
          '--report-dir=[directory for report]:directory:_files -/' \
          '--verbose[verbose output]' \
          '--check-graph[check graph consistency]' \
          '--check-indexes[check index consistency]' \
          '--check-counts[check count store consistency]' && ret=0
        ;;
      (report)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--database=[database name]:database' \
          '--to=[output directory]:directory:_files -/' \
          '--list[list what would be included]' \
          '--force[ignore disk space checks]' && ret=0
        ;;
      (store-info)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--structured[produce structured output]' \
          '1:path to store:_files -/' && ret=0
        ;;
      (memrec)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--database=[database name]:database' \
          '--memory=[total memory]:size' && ret=0
        ;;
      (server)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(console start stop restart status report memory-recommendation migrate-configuration unbind)' && ret=0
        ;;
      (database)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(info check migrate copy)' && ret=0
        ;;
      (dbms)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(set-initial-password set-default-admin unbind)' && ret=0
        ;;
      (copy)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--from-database=[source database]:database' \
          '--to-database=[destination database]:database' \
          '--force[overwrite existing destination]' \
          '--compact-node-store[compact the node store]' && ret=0
        ;;
      (unbind)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--database=[database name]:database' && ret=0
        ;;
      (migrate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--database=[database name]:database' \
          '--to-format=[target store format]:format' \
          '--force-btree-indexes-to-range[convert btree to range indexes]' && ret=0
        ;;
    esac
    ;;
esac

return ret
