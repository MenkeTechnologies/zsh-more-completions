#compdef yaml2json

# Zsh completion for yaml2json - YAML to JSON converter

_arguments -s -S \
  '(-i --indent)'{-i,--indent}'[indent output with given number of spaces]:spaces:' \
  '(-p --pretty)'{-p,--pretty}'[pretty print output]' \
  '(-s --sort-keys)'{-s,--sort-keys}'[sort object keys]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:file:_files -g "*.(yaml|yml)"'
