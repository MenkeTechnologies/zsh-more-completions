#compdef EvtxECmd
# Documentation: https://github.com/EricZimmerman/evtx
# EvtxECmd - Windows EVTX event log parser

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[file to process]:file:_files' \
  '-d[directory to recursively process]:directory:_directories' \
  '--csv=[directory to save CSV results to]:directory:_directories' \
  '--csvf=[file name for CSV results]:filename' \
  '--json=[directory to save JSON results to]:directory:_directories' \
  '--jsonf=[file name for JSON results]:filename' \
  '--xml=[directory to save XML results to]:directory:_directories' \
  '--xmlf=[file name for XML results]:filename' \
  '--dt=[custom date/time format]:format' \
  '--inc=[event IDs to process]:ids' \
  '--exc=[event IDs to ignore]:ids' \
  '--sd=[start date (UTC), older dropped]:date' \
  '--ed=[end date (UTC), newer dropped]:date' \
  '--fj=[export all data when using --json]:bool:(true false)' \
  '--tdt=[seconds for time discrepancy detection]:seconds' \
  '--met=[show metrics about processed log]:bool:(true false)' \
  '--maps=[path where event maps are located]:directory:_directories' \
  '--vss=[process Volume Shadow Copies]:bool:(true false)' \
  '--dedupe=[deduplicate based on SHA-1]:bool:(true false)' \
  '--sync=[download latest maps from GitHub]:bool:(true false)' \
  '--debug=[show debug information]:bool:(true false)' \
  '--trace=[show trace information]:bool:(true false)' && ret=0

return ret
