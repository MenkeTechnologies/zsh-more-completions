#compdef honggfuzz hfuzz-cc hfuzz-clang hfuzz-clang++ hfuzz-gcc hfuzz-g++
# Documentation: https://man.archlinux.org/search?q=honggfuzz
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (honggfuzz)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(--help-full)--help-full[show full help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-i --input)'{-i+,--input=}'[input dir]:dir:_files -/' \
      '(-o --output)'{-o+,--output=}'[output dir]:dir:_files -/' \
      '(-w --workspace)'{-w+,--workspace=}'[workspace]:dir:_files -/' \
      '(-z --instrument)'{-z,--instrument}'[hardware instrument]' \
      '(--no-instrument)--no-instrument[no instrument]' \
      '(-S --persistent)'{-S,--persistent}'[persistent mode]' \
      '(-P --persistent)'{-P,--persistent}'[persistent mode]' \
      '(-C --noaffinity)'{-C,--noaffinity}'[no CPU affinity]' \
      '(-q --quiet)'{-q,--quiet}'[quiet]' \
      '(-t --timeout)'{-t+,--timeout=}'[timeout s]:s:' \
      '(-T --tmout-sigvtalrm)'{-T,--tmout-sigvtalrm}'[SIGVTALRM on tmout]' \
      '(-N --iterations)'{-N+,--iterations=}'[iterations]:n:' \
      '(-n --threads)'{-n+,--threads=}'[threads]:n:' \
      '(--jobs --num-tasks)'{--jobs,--num-tasks}'+[parallel tasks]:n:' \
      '(-F --max_file_size)'{-F+,--max_file_size=}'[max file size]:n:' \
      '(-r --mutations_per_run)'{-r+,--mutations_per_run=}'[mutations per run]:n:' \
      '(-c --command_line)'{-c+,--command_line=}'[command line]:cmd:' \
      '(-e --extension)'{-e+,--extension=}'[file extension]:ext:' \
      '(-W --crashdir)'{-W+,--crashdir=}'[crash dir]:dir:_files -/' \
      '(-R --report)'{-R+,--report=}'[report file]:file:_files' \
      '(-x --no_unsafe)'{-x,--no_unsafe}'[no unsafe]' \
      '(-k --keep_aslr)'{-k,--keep_aslr}'[keep ASLR]' \
      '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
      '(-d --debug_level)'{-d+,--debug_level=}'[debug level]:n:(0 1 2 3 4)' \
      '(-Q --debug)'{-Q,--debug}'[debug logs]' \
      '(-y --dynamic_input)'{-y+,--dynamic_input=}'[dynamic input dir]:dir:_files -/' \
      '(--dict)--dict=[dictionary file]:file:_files' \
      '(--symbol_blacklist)--symbol_blacklist=[symbol blacklist]:file:_files' \
      '(--symbol_whitelist)--symbol_whitelist=[symbol whitelist]:file:_files' \
      '(--socket_fuzzer)--socket_fuzzer[socket fuzzing]' \
      '(--netdriver)--netdriver[net driver]' \
      '*: :' && ret=0 ;;
  (hfuzz-cc|hfuzz-clang|hfuzz-clang++|hfuzz-gcc|hfuzz-g++)
    _arguments -C \
      '*-I+[include]:dir:_files -/' \
      '*-L+[lib path]:dir:_files -/' \
      '*-l+[lib]:lib:' \
      '*-D+[define]:macro:' \
      '*-U+[undef]:macro:' \
      '-O+[opt level]:lvl:(0 1 2 3 g s)' \
      '-g[debug]' \
      '-Wall[all warnings]' \
      '-c[compile only]' \
      '-S[asm only]' \
      '-E[preprocess only]' \
      '-o+[output]:file:_files' \
      '*: :_files -g "*.c *.cpp *.cc *.cxx *.h *.hpp *.o"' && ret=0 ;;
esac

return ret
