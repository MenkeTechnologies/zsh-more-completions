#compdef honggfuzz hfuzz-cc hfuzz-clang hfuzz-clang++ hfuzz-gcc hfuzz-g++
# Documentation: https://github.com/google/honggfuzz/blob/master/docs/USAGE.md
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (honggfuzz)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-i --input)'{-i+,--input=}'[input dir]:dir:_files -/' \
      '--output=[output corpus dir]:dir:_files -/' \
      '(-P --persistent)'{-P,--persistent}'[persistent fuzzing mode]' \
      '(-z --instrument)'{-z,--instrument}'[compile-time instrumentation (default)]' \
      '(-M --minimize)'{-M,--minimize}'[minimize input corpus]' \
      '(-x --noinst)'{-x,--noinst}'[disable instrumentation (static mode)]' \
      '(-Q --keep_output)'{-Q,--keep_output}"[don't close children's stdio]" \
      '(-t --timeout)'{-t+,--timeout=}'[timeout seconds]:s:' \
      '(-n --threads)'{-n+,--threads=}'[concurrent threads]:n:' \
      '(-s --stdin_input)'{-s,--stdin_input}'[input via STDIN]' \
      '(-r --mutations_per_run)'{-r+,--mutations_per_run=}'[max mutations per run]:n:' \
      '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
      '(-v --verbose)'{-v,--verbose}'[disable ANSI console]' \
      '(-V --verifier)'{-V,--verifier}'[enable crashes verifier]' \
      '(-d --debug)'{-d,--debug}'[show debug messages]' \
      '(-q --quiet)'{-q,--quiet}'[show only warnings]' \
      '(-e --extension)'{-e+,--extension=}'[input file extension]:ext:' \
      '(-W --workspace)'{-W+,--workspace=}'[workspace dir]:dir:_files -/' \
      '--crashdir=[crash directory]:dir:_files -/' \
      '--covdir_new=[new-coverage dir]:dir:_files -/' \
      '(-w --dict)'{-w+,--dict=}'[dictionary file]:file:_files' \
      '(-B --stackhash_bl)'{-B+,--stackhash_bl=}'[stackhashes blacklist file]:file:_files' \
      '(-c --mutate_cmd)'{-c+,--mutate_cmd=}'[external mutator command]:cmd:' \
      '--pprocess_cmd=[postprocess command]:cmd:' \
      '--ffmutate_cmd=[feedback-effective mutator command]:cmd:' \
      '--run_time=[seconds the session lasts]:s:' \
      '(-N --iterations)'{-N+,--iterations=}'[fuzzing iterations]:n:' \
      '--rlimit_as=[RLIMIT_AS MiB]:mib:' \
      '--rlimit_rss=[RLIMIT_RSS MiB]:mib:' \
      '--rlimit_data=[RLIMIT_DATA MiB]:mib:' \
      '--rlimit_core=[RLIMIT_CORE MiB]:mib:' \
      '(-R --report)'{-R+,--report=}'[report file]:file:_files' \
      '(-F --max_file_size)'{-F+,--max_file_size=}'[max file size bytes]:n:' \
      '--clear_env[clear env before exec]' \
      '*'{-E+,--env=}'[pass env var]:KEY=VAL:' \
      '(-u --save_all)'{-u,--save_all}'[save all test-cases]' \
      '(-U --save_smaller)'{-U,--save_smaller}'[save smaller test-cases]' \
      '(-T --tmout_sigvtalrm)'{-T,--tmout_sigvtalrm}'[use SIGVTALRM on timeout]' \
      '(-S --sanitizers)'{-S,--sanitizers}'[enable sanitizer settings]' \
      '--monitor_sigabrt=[monitor SIGABRT]:bool:(true false)' \
      '--no_fb_timeout=[skip feedback if timeout]:bool:(true false)' \
      '--exit_upon_crash[exit on first crash]' \
      '--socket_fuzzer[instrument external fuzzer via socket]' \
      '--netdriver[use netdriver]' \
      '--only_printable[only printable inputs]' \
      '--linux_symbols_bl=[symbols blacklist file]:file:_files' \
      '--linux_symbols_wl=[symbols whitelist file]:file:_files' \
      '--linux_addr_low_limit=[address low limit]:n:' \
      '--linux_keep_aslr[keep ASLR randomization]' \
      '--linux_perf_ignore_above=[ignore perf IPs above]:n:' \
      '--linux_perf_instr[use PERF_COUNT_HW_INSTRUCTIONS]' \
      '--linux_perf_branch[use PERF_COUNT_HW_BRANCH_INSTRUCTIONS]' \
      '--linux_perf_bts_edge[Intel BTS unique edges]' \
      '--linux_perf_ipt_block[Intel PT unique blocks]' \
      '--linux_perf_kernel_only[kernel-only coverage]' \
      '--linux_ns_net[NET namespace isolation]' \
      '--linux_ns_pid[PID namespace isolation]' \
      '--linux_ns_ipc[IPC namespace isolation]' \
      '*: :' && ret=0 ;;
  (hfuzz-cc|hfuzz-clang|hfuzz-clang++|hfuzz-gcc|hfuzz-g++)
    _arguments -C \
      '*-I+[include]:dir:_files -/' \
      '*-L+[lib path]:dir:_files -/' \
      '*-l+[lib]:lib:' \
      '*-D+[define]:macro:' \
      '*-U+[undef]:macro:' \
      '-O+[opt level]:lvl:(0 1 2 3 g s)' \
      '-g[debug]' \
      '-Wall[all warnings]' \
      '-c[compile only]' \
      '-S[asm only]' \
      '-E[preprocess only]' \
      '-o+[output]:file:_files' \
      '*: :_files -g "*.c *.cpp *.cc *.cxx *.h *.hpp *.o"' && ret=0 ;;
esac

return ret
