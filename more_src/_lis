#compdef lis
# ============================================================================
# _lis — zsh completion for Lisette, Iván Ovejero's Rust-inspired
#         programming language that compiles to Go (153rd language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/ivov/lisette
#   Website    : https://lisette.run
#   Author     : Iván Ovejero  <ivov.src@gmail.com>
#   License    : MIT
#   Stars      : 1231
#   Language   : Rust (compiler) / Lisette (.lis source files,
#                compiles to Go)
#   Crate      : lisette v0.2.16  (workspace member under crates/cli)
#   Binary     : lis  (crates/cli/Cargo.toml [[bin]] name = "lis",
#                      path = "src/main.rs")
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   Lisette is "a little language inspired by Rust that compiles to
#   Go" — Iván Ovejero's small functional/imperative hybrid that
#   takes Rust's algebraic data types, ownership-light borrow rules,
#   match expressions, and `?` error propagation, then lowers each
#   module to idiomatic Go for execution.  The `lis` driver wraps a
#   Cargo-like project lifecycle (new / build / run / format /
#   check) plus dependency management (add / sync), a documentation
#   browser (doc / doc --search), a Go bindings generator (bindgen),
#   an LSP server (lsp), an interactive tutorial (learn), and
#   shell-completion generation.
#
# CLI ARGUMENT GRAMMAR  (verbatim from crates/cli/src/command.rs
#                       Command enum + Command::parse hand-rolled
#                       parser)
#   lis [<COMMAND> [args...]]
#
#   With no arguments, `lis` prints the project overview and exits.
#
#   Commands:
#     new <NAME>                Create a new Lisette project
#
#     build | b [<PATH>]        Build the project
#         --debug                 Emit debug-level info
#
#     run | r [<TARGET>] [-- <ARGS>...]
#                               Run the built program
#         --debug                 Emit debug-level info
#         --                      Separator;  everything after is
#                                 passed verbatim to the running
#                                 program
#
#     format | f [<PATH>]       Auto-format Lisette source files
#         --check                 Exit non-zero if files are not
#                                 already formatted (CI mode)
#
#     check | c [<PATH>]        Type-check without building
#         --errors-only           Show only error-level diagnostics
#                                 (mutually exclusive with
#                                 --warnings-only)
#         --warnings-only         Show only warning-level diagnostics
#                                 (mutually exclusive with
#                                 --errors-only)
#         --format <unix>         Diagnostic output format (graphical
#                                 default; `unix` for machine-
#                                 parseable one-line-per-diagnostic)
#
#     add <DEPENDENCY>          Add a single dependency to the
#                               project (accepts only one positional
#                               at a time)
#
#     sync                      Sync project dependencies (no args)
#
#     lsp                       Start the Lisette language server
#                               (LSP over stdio)
#
#     learn                     Launch the interactive tutorial
#
#     doc [<QUERY>]             Open documentation for an item
#                               (`lis doc foo.bar`)
#       -s, --search <QUERY>      Run a doc search instead of an
#                                 exact-item lookup
#
#     bindgen <PACKAGE> [<VERSION>]
#                               Generate Lisette bindings for a Go
#                               package
#       -o, --output <PATH>       Output directory for generated
#                                 bindings (also `-o=PATH` /
#                                 `--output=PATH`)
#       -v, --verbose             Verbose output
#
#     complete [<SHELL>]        Generate shell completion script for
#                               the named shell (bash/zsh/fish/...)
#
#     help [<COMMAND>]          Show help (also `--help`, `-h` after
#                               any command)
#     version | --version       Show version
#
# LANGUAGE-CORPUS POSITION
#   Lisette is the 153rd programming language entry in this completion
#   corpus, closing the 3+1 micro-cycle that began at R881 (_bsky-cli
#   / atrium-rs bsky-sdk + atrium-api Rust=128 OPENS Axis 73 AT
#   Protocol / Bluesky SDK) and continued through R882 (_atr /
#   bluesky-social/indigo Go=128) and R883 (_bam / @atproto/api
#   ^0.14.19 TS-Node=128 CLOSES Axis 73 at 1/1/1 three-language
#   symmetry — triple-128 landmark and 66th axis closed).  Lisette
#   joins Bril (R880 152nd), Vyxal (R876 151st), EYG (R872 150th —
#   round-number language milestone), Roto (R868 149th), Pipefish
#   (R864 148th), Mochi (R860 147th), Oden (R856 146th), Hop (R852
#   145th), Lustre via Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ
#   (R840 142nd), Granule (R836 141st), Sixten (R832 140th), Imba
#   (R828 139th), Tao (R824 138th), Dada (R820 137th), Acton (R816
#   136th), and Stanza (R812 135th).
#
#   No completion for `lis` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_lis() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help,help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_lis_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                new)
                    _arguments \
                        ':project name:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                build|b)
                    _arguments \
                        '--debug[emit debug-level info]' \
                        ':path:_files -/' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                run|r)
                    _arguments \
                        '--debug[emit debug-level info]' \
                        ':target:' \
                        '*: :_normal' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                format|f)
                    _arguments \
                        '--check[exit non-zero if files are not formatted]' \
                        ':path:_files' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                check|c)
                    _arguments \
                        '(--warnings-only)--errors-only[show only error-level diagnostics]' \
                        '(--errors-only)--warnings-only[show only warning-level diagnostics]' \
                        '--format=[diagnostic output format]:format:(unix)' \
                        ':path:_files' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                add)
                    _arguments \
                        ':dependency:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                doc)
                    _arguments \
                        '(-s --search)'{-s,--search}'[run a doc search instead of exact-item lookup]' \
                        ':query:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                bindgen)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[output directory for generated bindings]:dir:_files -/' \
                        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
                        ':Go package:' \
                        ':version:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                complete)
                    _arguments \
                        ':shell:(bash zsh fish powershell)' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                sync|lsp|learn|version)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
                help)
                    _arguments ':command:_lis_commands' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_lis_commands] )) ||
_lis_commands() {
    local -a commands
    commands=(
        'new:create a new Lisette project'
        'build:build the project'
        'b:build (alias)'
        'run:run the built program'
        'r:run (alias)'
        'format:auto-format Lisette source files'
        'f:format (alias)'
        'check:type-check without building'
        'c:check (alias)'
        'add:add a single dependency'
        'sync:sync project dependencies'
        'lsp:start the Lisette language server (LSP over stdio)'
        'learn:launch the interactive tutorial'
        'doc:open documentation for an item (-s/--search for search)'
        'bindgen:generate Lisette bindings for a Go package'
        'complete:generate shell completion script'
        'help:show help for a command'
        'version:show version'
    )
    _describe -t commands 'lis command' commands
}

_lis "$@"
