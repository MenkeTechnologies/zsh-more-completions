#compdef nx-cli2 nx2
# _nx-cli2 — Nrwl Nx nx-cli2 CLI command-line frontend wrapping the Nx open-source smart fast and extensible build system originally based on tools-used-at-Google-and-Facebook a Smart Monorepo Tool with smart caching dependency-graph computation cloud distributed task execution providing fast monorepo and CI tooling open-source written in TypeScript Node and Rust generate g run build test lint serve e2e affected workspace report list init reset login logout cache nx-cloud release migrate import view migrate-init list-projects show-projects deps repair connect graph dep-graph init-cloud (Nrwl Nx team Victor Savkin Jeff Cross, TypeScript/Rust); commander
# upstream: https://nx.dev/

_nx-cli2() {
    local -a sub=(
        'add:add a Nx plugin'
        'affected:run target for affected projects'
        'affected:e2e:run e2e for affected'
        'affected:test:run test for affected'
        'affected:lint:run lint for affected'
        'affected:build:run build for affected'
        'build:build a project'
        'completion:generate shell completion'
        'connect-to-nx-cloud:connect to Nx Cloud'
        'create:create from preset'
        'daemon:Nx daemon ops'
        'dep-graph:open dependency graph'
        'deps:print direct deps'
        'docs:open docs'
        'e2e:run e2e tests'
        'exec:run a command'
        'format:format files'
        'g:generate code (alias)'
        'generate:generate code from schematic'
        'graph:open graph viewer'
        'help:show help'
        'import:import a project'
        'init:initialize Nx'
        'install:install Nx plugin'
        'list:list installed plugins'
        'login:authenticate to Nx Cloud'
        'logout:revoke Nx Cloud session'
        'migrate:migrate Nx'
        'migrate-init:initialize migration'
        'new:create new workspace'
        'release:run release ops'
        'repair:auto repair'
        'report:show env info'
        'reset:reset cache'
        'run:run a target'
        'run-many:run a target for many projects'
        'show:show projects info'
        'serve:serve a project'
        'sync:sync changes'
        'test:run tests'
        'view:view files'
        'watch:watch projects'
        'workspace-generator:run workspace generator'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--silent[silent]' \
        '-s[silent]' \
        '--skip-nx-cache[skip cache]' \
        '--prod[production mode]' \
        '--ci[CI mode]' \
        '--head=+[ref]:str:' \
        '--base=+[ref]:str:' \
        '--parallel=+[N]:n:' \
        '--max-parallel=+[N]:n:' \
        '--runner=+[r]:str:' \
        '--projects=+[names]:str:' \
        '-p+[projects]:str:' \
        '*-p+[project]:str:' \
        '--exclude=+[names]:str:' \
        '--exclude-task-dependencies[exclude task deps]' \
        '--targets=+[targets]:str:' \
        '-t+[targets]:str:' \
        '*-t+[target]:str:' \
        '--configuration=+[name]:str:' \
        '-c+[config]:str:' \
        '--watch[watch]' \
        '--graph[graph]' \
        '--cloud=+[v]:v:(true false)' \
        '--all[all projects]' \
        '--dry-run[dry run]' \
        '-d[dry run]' \
        '--no-install[no install]' \
        '--package-manager=+[m]:m:(npm pnpm yarn bun)' \
        '--from-ref=+[ref]:str:' \
        '--to-ref=+[ref]:str:' \
        '--output-style=+[s]:s:(dynamic static stream stream-without-prefixes compact)' \
        '--output-path=+[path]:_files' \
        '--watch-mode=+[m]:m:(all changed)' \
        '--with-deps[with deps]' \
        '--type=+[t]:t:(app lib e2e)' \
        '--projectType=+[t]:t:(application library)' \
        '--name=+[name]:str:' \
        '--preset=+[name]:str:' \
        '--style=+[s]:s:(css scss sass less none)' \
        '--routing[routing]' \
        '--directory=+[dir]:dir:_files -/' \
        '--linter=+[l]:l:(eslint none)' \
        '--unitTestRunner=+[r]:r:(jest vitest mocha none)' \
        '--e2eTestRunner=+[r]:r:(playwright cypress none)' \
        '--standaloneConfig[standalone config]' \
        '--workspaceConfig=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nx subcommand' sub ;;
        args)
            case $words[1] in
                run|build|test|lint|e2e|serve|exec) _arguments '1:project:' '2:target:' '*:arg:' ;;
                generate|g) _arguments '1:schematic:' '*:arg:' ;;
                show) _arguments '1:type:(projects project)' '*:arg:' ;;
                release) _arguments '1:op:(version changelog publish plan)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_nx-cli2 "$@"
