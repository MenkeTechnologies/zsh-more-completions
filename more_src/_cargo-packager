#compdef cargo-packager
# _cargo-packager — package Rust binaries into native installers (crabnebula-dev/cargo-packager)
# upstream: https://github.com/crabnebula-dev/cargo-packager
# Flags from crates/packager/src/cli/mod.rs + signer/*.rs (clap).

_cargo-packager() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '*'{-v,--verbose}'[increase logging verbosity (repeatable)]' \
        '(-q --quite)'{-q,--quite}'[disable logging]' \
        '(-f --formats)'{-f+,--formats=}'[package formats to build (comma-separated)]:formats:(app dmg deb rpm appimage pacman wix nsis pkg msi)' \
        '(-c --config)'{-c+,--config=}'[config file or raw JSON]:config:' \
        '(-k --private-key)'{-k+,--private-key=}'[private key file or string for signing]:key:' \
        '--password=[password for the signing private key]:password:' \
        '(-p --packages)'{-p+,--packages=}'[workspace packages to package (comma-separated)]:packages:' \
        '(-o --out-dir --out)'{-o+,--out-dir=,--out=}'[output directory]:dir:_files -/' \
        '--binaries-dir=[directory where binaries live (defaults to --out-dir)]:dir:_files -/' \
        '(-r --release)'{-r,--release}'[package the release build]' \
        '--profile=[cargo profile to use]:profile:' \
        '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"' \
        '--target=[Rust target triple]:triple:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_cargo-packager_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                signer)
                    _arguments '1:signer subcommand:(sign generate)'
                    [[ "$words[2]" == sign ]] && \
                        _arguments \
                            '(-k --private-key)'{-k+,--private-key=}'[private key file or string]:key:' \
                            '--password=[private-key password]:password:' \
                            '1:file to sign:_files'
                    [[ "$words[2]" == generate ]] && \
                        _arguments \
                            '--password=[password for the new key]:password:' \
                            '--path=[output path for the private key]:file:_files' \
                            '(-f --force)'{-f,--force}'[overwrite the private key if it exists]' \
                            '--ci[skip interactive prompts]'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_cargo-packager_commands] )) ||
_cargo-packager_commands() {
    local -a commands
    commands=(
        'signer:sign a file or generate a new signing key'
    )
    _describe -t commands 'cargo-packager command' commands
}

_cargo-packager "$@"
