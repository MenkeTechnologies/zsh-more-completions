#compdef doctl

# Zsh completion for doctl (DigitalOcean CLI)

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'account:Display commands that retrieve account details'
  'apps:Display commands for working with apps'
  'auth:Display commands for authenticating doctl with an account'
  'balance:Display commands for retrieving your account balance'
  'billing-history:Display commands for billing history'
  'completion:Modify the default output format for completion'
  'compute:Display commands that manage infrastructure'
  'databases:Display commands that manage databases'
  'domains:Display commands that manage domains'
  'invoice:Display commands for managing invoices'
  'kubernetes:Display commands to manage Kubernetes clusters and configurations'
  'monitoring:Display commands to manage monitoring'
  'projects:Manage projects and assign resources to them'
  'registry:Display commands for interacting with container registry'
  'serverless:Display commands for managing serverless resources'
  'spaces:Display commands to manage Spaces'
  'uptime:Display commands to manage uptime checks and alerts'
  'version:Show the current version'
  'vpcs:Display commands that manage VPCs'
)

_arguments -C \
  {-t,--access-token}'=[API V2 access token]:token:' \
  {-u,--api-url}'=[Override default API endpoint]:url:' \
  {-c,--config}'=[Specify a custom config file]:file:_files' \
  '--context=[Specify a custom authentication context name]:context:' \
  {-h,--help}'[Help for doctl]' \
  '--interactive[Enable interactive behavior]' \
  {-o,--output}'=[Desired output format]:format:(text json)' \
  '--trace[Show a log of network activity while performing a command]' \
  {-v,--verbose}'[Enable verbose output]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'doctl command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      auth)
        local -a auth_cmds
        auth_cmds=(
          'init:Initialize doctl to use a specific account'
          'list:List available authentication contexts'
          'remove:Remove an authentication context'
          'switch:Switch between authentication contexts'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t auth_cmds 'auth subcommand' auth_cmds && ret=0 ;;
        esac
        ;;
      compute)
        local -a compute_cmds
        compute_cmds=(
          'action:Display commands for retrieving resource action history'
          'cdn:Display commands that manage CDN endpoints'
          'certificate:Display commands that manage SSL certificates'
          'domain:Display commands that manage domains'
          'droplet:Manage virtual machines (Droplets)'
          'droplet-action:Display Droplet action commands'
          'firewall:Display commands to manage firewalls'
          'floating-ip:Display commands to manage floating IP addresses'
          'floating-ip-action:Display commands to associate floating IP addresses with Droplets'
          'image:Display commands to manage images'
          'image-action:Display commands to perform actions on images'
          'load-balancer:Display commands to manage load balancers'
          'region:Display commands to list datacenter regions'
          'reserved-ip:Display commands to manage reserved IP addresses'
          'reserved-ip-action:Display commands for reserved IP actions'
          'size:Display commands to list available Droplet sizes'
          'snapshot:Access snapshot commands'
          'ssh:Access a Droplet using SSH'
          'ssh-key:Display commands to manage SSH keys'
          'tag:Display commands to manage tags'
          'volume:Display commands to manage block storage volumes'
          'volume-action:Display commands to perform actions on a volume'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t compute_cmds 'compute subcommand' compute_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              droplet)
                local -a droplet_cmds
                droplet_cmds=(
                  '1password:Access 1Password integration for Droplets'
                  'actions:Display Droplet action history'
                  'backups:List backups for a Droplet'
                  'create:Create a new Droplet'
                  'delete:Permanently delete a Droplet'
                  'get:Display information about a Droplet'
                  'kernels:List available kernels for a Droplet'
                  'list:List Droplets on your account'
                  'neighbors:List a Droplets neighbors'
                  'snapshots:List all snapshots for a Droplet'
                  'tag:Add a tag to a Droplet'
                  'untag:Remove a tag from a Droplet'
                )
                _arguments -C \
                  '1:subcommand:->subcmd2' \
                  '*::arg:->subargs2' && ret=0
                case "$state" in
                  subcmd2) _describe -t droplet_cmds 'droplet subcommand' droplet_cmds && ret=0 ;;
                  subargs2)
                    case "${line[1]}" in
                      create)
                        _arguments \
                          '--backup[Enable automatic backups]' \
                          '--droplet-agent=[Enable or disable the Droplet agent]:value:(true false)' \
                          '--enable-ipv6[Enable IPv6]' \
                          '--enable-monitoring[Install the DigitalOcean agent]' \
                          '--enable-private-networking[Enable private networking]' \
                          '--image=[Droplet image]:image:' \
                          '--monitoring[Enable monitoring]' \
                          '--project-id=[Project ID]:id:' \
                          '--region=[Droplet region]:region:(nyc1 nyc2 nyc3 sfo1 sfo2 sfo3 ams2 ams3 sgp1 lon1 fra1 tor1 blr1 syd1)' \
                          '--size=[Droplet size]:size:(s-1vcpu-512mb-10gb s-1vcpu-1gb s-1vcpu-2gb s-2vcpu-2gb s-2vcpu-4gb s-4vcpu-8gb s-8vcpu-16gb)' \
                          '--ssh-keys=[SSH key fingerprints or IDs]:keys:' \
                          '--tag-name=[Tag name]:tag:' \
                          '--user-data=[User data to provide]:data:' \
                          '--user-data-file=[Path to user data file]:file:_files' \
                          '--volumes=[Comma-separated list of volume IDs]:volumes:' \
                          '--vpc-uuid=[VPC UUID]:uuid:' \
                          '--wait[Wait for Droplet creation to complete]' \
                          '1:name:' && ret=0
                        ;;
                      list)
                        _arguments \
                          '--format=[Columns for output]:columns:' \
                          '--no-header[Hide output header]' \
                          '--region=[Filter by region]:region:' \
                          '--tag-name=[Filter by tag]:tag:' && ret=0
                        ;;
                      delete)
                        _arguments \
                          {-f,--force}'[Delete without confirmation prompt]' \
                          '--tag-name=[Delete by tag]:tag:' \
                          '*:droplet ID:' && ret=0
                        ;;
                      get)
                        _arguments \
                          '--format=[Columns for output]:columns:' \
                          '--no-header[Hide output header]' \
                          '--template=[Go template format]:template:' \
                          '1:droplet ID:' && ret=0
                        ;;
                    esac
                    ;;
                esac
                ;;
              volume)
                local -a volume_cmds
                volume_cmds=(
                  'create:Create a block storage volume'
                  'delete:Delete a block storage volume'
                  'get:Retrieve a block storage volume'
                  'list:List block storage volumes'
                  'snapshot:Access volume snapshot commands'
                )
                _arguments -C \
                  '1:subcommand:->subcmd2' \
                  '*::arg:->subargs2' && ret=0
                case "$state" in
                  subcmd2) _describe -t volume_cmds 'volume subcommand' volume_cmds && ret=0 ;;
                esac
                ;;
              load-balancer)
                local -a lb_cmds
                lb_cmds=(
                  'add-droplets:Add Droplets to a load balancer'
                  'add-forwarding-rules:Add forwarding rules to a load balancer'
                  'create:Create a new load balancer'
                  'delete:Permanently delete a load balancer'
                  'get:Retrieve a load balancer'
                  'list:List load balancers'
                  'remove-droplets:Remove Droplets from a load balancer'
                  'remove-forwarding-rules:Remove forwarding rules from a load balancer'
                  'update:Update a load balancer'
                )
                _arguments -C \
                  '1:subcommand:->subcmd2' \
                  '*::arg:->subargs2' && ret=0
                case "$state" in
                  subcmd2) _describe -t lb_cmds 'load-balancer subcommand' lb_cmds && ret=0 ;;
                esac
                ;;
              firewall)
                local -a fw_cmds
                fw_cmds=(
                  'add-droplets:Add Droplets to a firewall'
                  'add-rules:Add rules to a firewall'
                  'add-tags:Add tags to a firewall'
                  'create:Create a new firewall'
                  'delete:Permanently delete a firewall'
                  'get:Retrieve a firewall'
                  'list:List firewalls'
                  'list-by-droplet:List firewalls by Droplet'
                  'remove-droplets:Remove Droplets from a firewall'
                  'remove-rules:Remove rules from a firewall'
                  'remove-tags:Remove tags from a firewall'
                  'update:Update a firewall'
                )
                _arguments -C \
                  '1:subcommand:->subcmd2' \
                  '*::arg:->subargs2' && ret=0
                case "$state" in
                  subcmd2) _describe -t fw_cmds 'firewall subcommand' fw_cmds && ret=0 ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
      kubernetes)
        local -a k8s_cmds
        k8s_cmds=(
          'cluster:Display commands for managing Kubernetes clusters'
          'options:List possible option values for use inside Kubernetes commands'
          '1-click:Display commands that manage 1-Click applications'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t k8s_cmds 'kubernetes subcommand' k8s_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              cluster)
                local -a cluster_cmds
                cluster_cmds=(
                  'create:Create a Kubernetes cluster'
                  'delete:Delete Kubernetes clusters'
                  'get:Retrieve details about a Kubernetes cluster'
                  'get-upgrades:Retrieve a list of available Kubernetes version upgrades'
                  'kubeconfig:Display commands for managing your local kubeconfig'
                  'list:Retrieve the list of Kubernetes clusters'
                  'list-associated-resources:Retrieve resources associated with a cluster'
                  'node-pool:Display commands for managing node pools'
                  'registry:Display commands for managing integration with container registry'
                  'update:Update a Kubernetes cluster'
                  'upgrade:Upgrade a Kubernetes cluster'
                )
                _arguments -C \
                  '1:subcommand:->subcmd2' \
                  '*::arg:->subargs2' && ret=0
                case "$state" in
                  subcmd2) _describe -t cluster_cmds 'cluster subcommand' cluster_cmds && ret=0 ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
      databases)
        local -a db_cmds
        db_cmds=(
          'backups:Display commands for managing database backups'
          'connection:Display connection details for a database cluster'
          'create:Create a database cluster'
          'db:Display commands for managing individual databases'
          'delete:Delete a database cluster'
          'events:Display events for a database cluster'
          'firewalls:Display commands for managing firewall rules'
          'fork:Create a database by forking an existing cluster'
          'get:Get details for a database cluster'
          'list:List your database clusters'
          'maintenance-window:Display commands for scheduling maintenance windows'
          'migrate:Migrate a database cluster to a new region'
          'options:Display available database options'
          'pool:Display commands for managing connection pools'
          'replica:Display commands for managing read-only database replicas'
          'resize:Resize a database cluster'
          'sql-mode:Display commands for managing SQL mode'
          'topics:Display commands for managing topics'
          'user:Display commands for managing database users'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t db_cmds 'databases subcommand' db_cmds && ret=0 ;;
        esac
        ;;
      apps)
        local -a apps_cmds
        apps_cmds=(
          'create:Create an app'
          'create-deployment:Create a deployment'
          'delete:Deletes an app'
          'get:Get an app'
          'get-deployment:Get a deployment'
          'list:Lists all apps'
          'list-alerts:List alerts on an app'
          'list-buildpacks:List available buildpacks'
          'list-deployments:List all deployments'
          'list-regions:List all app platform regions'
          'logs:Get logs'
          'propose:Propose an app spec'
          'spec:Display commands for managing app specs'
          'tier:Display commands for app tiers'
          'update:Updates an app'
          'update-alert-destinations:Update alert destinations'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t apps_cmds 'apps subcommand' apps_cmds && ret=0 ;;
        esac
        ;;
      registry)
        local -a reg_cmds
        reg_cmds=(
          'create:Create a container registry'
          'delete:Delete a container registry'
          'docker-config:Generate a docker auth configuration'
          'garbage-collection:Display commands for garbage collection'
          'get:Retrieve details about a container registry'
          'kubernetes-manifest:Generate a Kubernetes secret manifest'
          'login:Log in to a container registry'
          'logout:Log out of a container registry'
          'options:List available options for a container registry'
          'repository:Display commands for managing repositories'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t reg_cmds 'registry subcommand' reg_cmds && ret=0 ;;
        esac
        ;;
      domains)
        local -a domain_cmds
        domain_cmds=(
          'create:Create a domain'
          'delete:Permanently delete a domain'
          'get:Retrieve a domain'
          'list:List all domains'
          'records:Manage domain records'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t domain_cmds 'domains subcommand' domain_cmds && ret=0 ;;
        esac
        ;;
      vpcs)
        local -a vpc_cmds
        vpc_cmds=(
          'create:Create a VPC'
          'delete:Permanently delete a VPC'
          'get:Retrieve a VPC'
          'list:List VPCs'
          'members:List members of a VPC'
          'peerings:Display commands for managing VPC Peerings'
          'update:Update a VPC'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t vpc_cmds 'vpcs subcommand' vpc_cmds && ret=0 ;;
        esac
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
      account)
        local -a acct_cmds
        acct_cmds=(
          'get:Retrieve account profile details'
          'ratelimit:Show your API usage and the remaining quota'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t acct_cmds 'account subcommand' acct_cmds && ret=0 ;;
        esac
        ;;
    esac
    ;;
esac

return ret
