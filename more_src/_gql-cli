#compdef gql-cli
# Documentation: https://github.com/graphql-python/gql
# Reference accessed: 2026-05-23
# Verified: gql-cli --help (gql PyPI package).

# Zsh completion for gql-cli - send GraphQL queries from the command line

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --variables)'{-V+,--variables=}'[query variables key:json_value]:var:' \
  '*-V[query variables]:var:' \
  '(-H --headers)'{-H+,--headers=}'[HTTP headers key:value]:header:' \
  '*-H[HTTP headers]:header:' \
  '--version[show version]' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '(-v --verbose)'{-v,--verbose}'[info logging]' \
  '(-o --operation-name)'{-o+,--operation-name=}'[GraphQL operation name]:name:' \
  '--print-schema[introspect and print schema]' \
  '--schema-download[schema download options]:opts:' \
  '--execute-timeout[query timeout seconds]:seconds:' \
  '--transport[transport backend]:transport:(auto aiohttp httpx phoenix websockets aiohttp_websockets appsync_http appsync_websockets)' \
  '(--jwt)--api-key[API key]:key:' \
  '(--api-key)--jwt[JWT token]:token:' \
  ':server URL:_urls' && ret=0

return ret
