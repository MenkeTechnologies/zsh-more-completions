#compdef maketx
# _maketx — make texture / MIP-map files from images (AcademySoftwareFoundation/OpenImageIO)
# upstream: https://github.com/AcademySoftwareFoundation/OpenImageIO
# Flags from src/maketx/maketx.cpp (ArgParse ap.arg).

_maketx() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-v[verbose output]' \
        '-o+[output file name]:file:_files' \
        '--threads=[number of worker threads]:n:' \
        '-u[update mode (skip if up to date)]' \
        '--format=[output file format]:fmt:' \
        '--nchannels=[number of output channels]:n:' \
        '--chnames=[output channel names (comma list)]:names:' \
        '-d+[data format]:type:(uint8 sint8 uint16 sint16 half float double)' \
        '--tile=[tile WIDTH HEIGHT]:width:' \
        '--separate[separate planes (RRR.GGG.BBB)]' \
        '--compression=[compression scheme name]:name:(none rle zip zips piz pxr24 b44 b44a dwaa dwab lzw deflate)' \
        '--fovcot=[FoV cotangent metadata]:float:' \
        '--wrap=[wrap mode]:wrap:(black clamp periodic mirror)' \
        '--swrap=[S wrap mode]:wrap:(black clamp periodic mirror)' \
        '--twrap=[T wrap mode]:wrap:(black clamp periodic mirror)' \
        '--resize[resize to power of two]' \
        '--keepaspect[keep aspect ratio when resizing]' \
        '--filter=[reconstruction filter]:name:(box triangle gaussian sharp-gaussian catmull-rom blackman-harris sinc lanczos3 mitchell bspline cubic keys simon rifman radial-lanczos3 nuke-lanczos6)' \
        '--hicomp[high-light compensation]' \
        '--sharpen=[output sharpen strength]:float:' \
        '--nomipmap[disable MIP generation]' \
        '--checknan[check for NaN/Inf pixels]' \
        '--fixnan=[NaN handling strategy]:strat:(none black box3)' \
        '--fullpixels[set full area to pixel data window]' \
        '--prman-metadata[add metadata for PRMan]' \
        '*--attrib=[set NAME VALUE attribute]:name:' \
        '*--sattrib=[set NAME VALUE string attribute]:name:' \
        '--sansattrib[strip attribs from input]' \
        '--history[record build-history metadata]' \
        '--no-history[do not record history metadata]' \
        '--constant-color-detect[detect constant-color images]' \
        '--monochrome-detect[detect monochrome images]' \
        '--opaque-detect[detect fully opaque images]' \
        '--no-compute-average[skip average-color computation]' \
        '--ignore-unassoc[ignore associated-alpha metadata]' \
        '--runstats[print runtime statistics]' \
        '*:image file:_files'
}

_maketx "$@"
