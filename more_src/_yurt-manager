#compdef yurt-manager
# _yurt-manager — OpenYurt centralized controller manager (openyurtio/openyurt)
# upstream: https://github.com/openyurtio/openyurt
# Flags from cmd/yurt-manager/app/options/generic.go (pflag).

_yurt-manager() {
    _arguments \
        '--version[print version and exit]' \
        '--metrics-addr=[metrics bind address]:host\:port:' \
        '--health-probe-addr=[healthz/readyz bind address]:host\:port:' \
        '--webhook-port=[webhook server port]:port:' \
        '--rest-config-qps=[REST config QPS]:n:' \
        '--rest-config-burst=[REST config burst]:n:' \
        '--working-namespace=[working namespace]:ns:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_yurt-manager "$@"
