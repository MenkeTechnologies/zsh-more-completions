#compdef sfdivn
# Documentation: https://www.reproducibility.org/blog/2015/12/22/program-of-the-month-sfdivn/
# Madagascar: smooth division

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'niter=[number of iterations]:niter:' \
  'eps=[regularization]:eps:' \
  'rect1=[smoothing radius on first axis]:rect1:' \
  'rect2=[smoothing radius on second axis]:rect2:' \
  'verb=[verbosity (y/n)]:verb:(y n)' \
  '*: :_files' && ret=0

return ret
