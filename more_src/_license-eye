#compdef license-eye
# Documentation: https://github.com/apache/skywalking-eyes
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'header:manage SPDX/license headers in sources'
  'dep:report and check third-party licenses'
  'help:help about any command'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-v --verbosity)'{-v+,--verbosity=}'[log level]:level:(panic fatal error warning info debug trace)' \
  '--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'license-eye command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      header)
        local -a header_sub=(
          'check:verify license headers exist'
          'fix:add or update license headers'
        )
        _arguments \
          '1:subcommand:->headersub' \
          '*:path:_files' && ret=0
        if [[ $state == headersub ]]; then
          _describe -t commands 'header subcommand' header_sub && ret=0
        fi
        ;;
      dep)
        local -a dep_sub=(
          'resolve:identify and output dependency licenses'
          'check:verify dependency license compatibility'
        )
        _arguments \
          '1:subcommand:->depsub' \
          '--summary=[summary template file]:file:_files' \
          '-o[output directory]:directory:_files -/' \
          '--output=[output directory]:directory:_files -/' \
          '*:path:_files' && ret=0
        if [[ $state == depsub ]]; then
          _describe -t commands 'dep subcommand' dep_sub && ret=0
        fi
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
