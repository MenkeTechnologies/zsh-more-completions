#compdef msmtp
# Documentation: https://manpages.ubuntu.com/manpages/jammy/en/man1/msmtp.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. msmtp SMTP client.

_arguments -s -S \
  '--version[show version]' \
  '--help[show help]' \
  '(-P --pretend)'{-P,--pretend}'[print configuration and exit]' \
  '(-v -d --debug)'{-v,-d,--debug}'[print debug info including SMTP conversation]' \
  '--configure=[generate config for given mail address]:address:' \
  '(-S --serverinfo)'{-S,--serverinfo}'[print info about SMTP server]' \
  '--rmqs=[Remote Message Queue Starting request]:host|@domain|#queue:' \
  '(-C --file)'{-C+,--file=}'[use specified config file]:config file:_files' \
  '(-a --account)'{-a+,--account=}'[use specified account]:account:' \
  '--host=[SMTP server hostname]:host:_hosts' \
  '--port=[SMTP port]:port:' \
  '--source-ip=[bind socket to IP]:ip:' \
  '--proxy-host=[SOCKS proxy host]:host:_hosts' \
  '--proxy-port=[proxy port]:port:' \
  '--socket=[local unix socket]:socket:_files' \
  '--timeout=[network timeout]:off|seconds:' \
  '--protocol=[choose protocol]:protocol:(smtp lmtp)' \
  '--domain=[argument for SMTP EHLO/LHLO]:domain:' \
  '--auth=[choose authentication method]:method:(on off plain login cram-md5 gssapi external oauthbearer xoauth2 scram-sha-1 scram-sha-256)' \
  '--user=[username for authentication]:user:' \
  '--passwordeval=[evaluate command to get password]:command:' \
  '--tls=[enable/disable TLS]:mode:(on off)' \
  '--tls-starttls=[enable/disable STARTTLS]:mode:(on off)' \
  '--tls-trust-file=[trust file]:file:_files' \
  '--tls-crl-file=[CRL file (deprecated)]:file:_files' \
  '--tls-fingerprint=[trusted certificate fingerprint]:fingerprint:' \
  '--tls-key-file=[TLS key file]:file:_files' \
  '--tls-cert-file=[TLS certificate file]:file:_files' \
  '--tls-certcheck=[enable/disable server cert checks]:mode:(on off)' \
  '--tls-priorities=[TLS priorities]:priorities:' \
  '--tls-host-override=[override TLS host verification]:host:' \
  '(-f --from)'{-f+,--from=}'[set envelope-from address]:address:' \
  '(-N --dsn-notify)'{-N+,--dsn-notify=}'[DSN notify conditions]:conditions:' \
  '(-R --dsn-return)'{-R+,--dsn-return=}'[DSN return amount]:amount:(headers full)' \
  '--set-from-header=[control From header]:mode:(auto on off)' \
  '--set-date-header=[control Date header]:mode:(auto off)' \
  '--set-msgid-header=[control Message-ID header]:mode:(auto off)' \
  '--remove-bcc-headers=[remove Bcc headers]:mode:(on off)' \
  '--undisclosed-recipients=[replace To/Cc/Bcc with undisclosed]:mode:(on off)' \
  '(-X --logfile)'{-X+,--logfile=}'[set log file]:file:_files' \
  '--logfile-time-format=[log file time format]:fmt:' \
  '--syslog=[enable syslog logging]:facility:(on off LOG_MAIL LOG_USER LOG_LOCAL0 LOG_LOCAL1 LOG_LOCAL2 LOG_LOCAL3 LOG_LOCAL4 LOG_LOCAL5 LOG_LOCAL6 LOG_LOCAL7)' \
  '(-t --read-recipients)'{-t,--read-recipients}'[read recipients from message headers]' \
  '--read-envelope-from[read envelope-from from message headers]' \
  '--aliases=[aliases file]:file:_files' \
  '-F+[full name for From header]:name:' \
  '*:recipient address:'
