#compdef msmtp

# Zsh completion for msmtp - SMTP client

_arguments -s -S \
  '(-C --file)'{-C+,--file=}'[use specified config file]:config file:_files' \
  '(-a --account)'{-a+,--account=}'[use specified account]:account:' \
  '--host=[set SMTP server]:host:_hosts' \
  '--port=[set SMTP port]:port:' \
  '--timeout=[set network timeout]:seconds:' \
  '--proxy-host=[set proxy host]:host:_hosts' \
  '--proxy-port=[set proxy port]:port:' \
  '--auth=[choose authentication method]:method:(on off plain login cram-md5 gssapi external oauthbearer xoauth2)' \
  '--user=[set user name for authentication]:user:' \
  '--passwordeval=[evaluate command to get password]:command:' \
  '--tls=[enable/disable TLS]:mode:(on off)' \
  '--tls-starttls=[enable/disable STARTTLS]:mode:(on off)' \
  '--tls-trust-file=[set trust file]:file:_files' \
  '--tls-crl-file=[set CRL file]:file:_files' \
  '--tls-fingerprint=[set certificate fingerprint]:fingerprint:' \
  '--tls-key-file=[set TLS key file]:file:_files' \
  '--tls-cert-file=[set TLS certificate file]:file:_files' \
  '(-f --from)'{-f+,--from=}'[set envelope-from address]:address:' \
  '--maildomain=[set domain for SMTP EHLO]:domain:' \
  '--dsn-notify=[set DSN notify conditions]:conditions:' \
  '--dsn-return=[set DSN return amount]:amount:(headers full)' \
  '--set-from-header=[control From header]:mode:(auto on off)' \
  '--set-date-header=[control Date header]:mode:(auto off)' \
  '--set-msgid-header=[control Message-ID header]:mode:(auto off)' \
  '--remove-bcc-headers=[remove Bcc headers]:mode:(on off)' \
  '--undisclosed-recipients=[replace To with undisclosed]:mode:(on off)' \
  '--logfile=[set log file]:file:_files' \
  '--syslog=[enable syslog logging]:facility:(LOG_MAIL LOG_USER LOG_LOCAL0 LOG_LOCAL1 LOG_LOCAL2 LOG_LOCAL3 LOG_LOCAL4 LOG_LOCAL5 LOG_LOCAL6 LOG_LOCAL7)' \
  '(-t --read-recipients)'{-t,--read-recipients}'[read recipients from message headers]' \
  '--read-envelope-from[read envelope-from from message headers]' \
  '(-P --pretend)'{-P,--pretend}'[print configuration and exit]' \
  '--serverinfo[print info about SMTP server]' \
  '--rmqs=[set RMQS argument]:argument:' \
  '(-d --debug)'{-d,--debug}'[print debug info]' \
  '--version[show version]' \
  '--help[show help]' \
  '*:recipient address:'
