#compdef klee-stats

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--print-all[print all available stats]' \
  '--print-rel-times[print relative times]' \
  '--print-more[print extended stats]' \
  '--table-format=[table format]:fmt:(plain simple github grid fancy_grid pipe orgtbl jira presto pretty psql rst mediawiki moinmoin youtrack html unsafehtml latex latex_raw latex_booktabs latex_longtable textile tsv readable-csv klee csv)' \
  '--to-csv[output as CSV]' \
  '--compare-by=[compare metric]:metric:(instructions wallclock branches cov icov bcov tsolver memmax)' \
  '--compare-against=[compare against dir]:dir:_files -/' \
  '--sort-by=[sort by column]:col:' \
  '--print-rel-pct[show relative percentages]' \
  '--print-abs-cov[absolute coverage values]' \
  '*:KLEE output dir:_files -/' && ret=0

return ret
