#compdef xdg-icon-resource
# _xdg-icon-resource — XDG xdg-icon-resource (install/uninstall icons into system or user icon theme; --context selects icon namespace, --size required for non-svg, --theme overrides default 'hicolor', --mode user|system)
# upstream: https://gitlab.freedesktop.org/xdg/xdg-utils
# Subcommands from xdg-utils scripts/xdg-icon-resource.in on tip.

_xdg-icon-resource() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--manual[show full manual]' \
        '--version[show version]' \
        '--noupdate[do not refresh icon caches]' \
        '--novendor[allow no-vendor names]' \
        '--theme+[icon theme]:theme:(hicolor Adwaita oxygen breeze)' \
        '--context+[context]:context:(actions animations apps categories devices emblems emotes filesystems intl mimetypes places status stock)' \
        '--size+[size px]:size:(16 22 24 32 48 64 96 128 256 512)' \
        '--mode+[scope]:scope:(user system)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'subcommand' '(install uninstall forceupdate)' ;;
        args)
            case $line[1] in
                install) _arguments '1:icon-file:_files -g "*.(png|svg|xpm)"' '2:icon-name:' ;;
                uninstall) _arguments '1:icon-name:' ;;
            esac
            ;;
    esac
}

_xdg-icon-resource "$@"
