#compdef i3lock-color
# _i3lock-color — i3lock-color enhanced i3 screen locker (C); adds color customization, blur, clock display, indicator config
# upstream: https://github.com/Raymo111/i3lock-color

_i3lock-color() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose log]' \
        '(-n --nofork)'{-n,--nofork}'[stay in foreground]' \
        '(-b --beep)'{-b,--beep}'[beep on wrong password]' \
        '(-u --no-unlock-indicator)'{-u,--no-unlock-indicator}'[disable unlock indicator]' \
        '(-i --image)'{-i,--image}'+[background image]:file:_files' \
        '(-r --raw)'{-r,--raw}'+[raw image format]:fmt:' \
        '(-c --color)'{-c,--color}'+[background color hex]:rrggbb:' \
        '(-t --tiling)'{-t,--tiling}'[tile background]' \
        '(-p --pointer)'{-p,--pointer}'+[pointer style]:style:(default win)' \
        '(-e --ignore-empty-password)'{-e,--ignore-empty-password}'[ignore empty pw enter]' \
        '(-f --show-failed-attempts)'{-f,--show-failed-attempts}'[show failed attempts]' \
        '-S+[screen]:n:' \
        '--insidever-color+[inside-verify ring color]:rrggbbaa:' \
        '--insidewrong-color+[inside-wrong ring color]:rrggbbaa:' \
        '--inside-color+[inside ring color]:rrggbbaa:' \
        '--ringver-color+[ring-verify color]:rrggbbaa:' \
        '--ringwrong-color+[ring-wrong color]:rrggbbaa:' \
        '--ring-color+[ring color]:rrggbbaa:' \
        '--line-color+[line color]:rrggbbaa:' \
        '--text-color+[text color]:rrggbbaa:' \
        '--separator-color+[separator color]:rrggbbaa:' \
        '--keyhl-color+[key highlight color]:rrggbbaa:' \
        '--bshl-color+[backspace highlight color]:rrggbbaa:' \
        '--clock[show clock]' \
        '--indicator[force indicator]' \
        '--time-format+[time format]:fmt:' \
        '--date-format+[date format]:fmt:' \
        '--time-font+[time font]:font:' \
        '--date-font+[date font]:font:' \
        '--ring-width+[ring width]:n:' \
        '--blur+[blur strength]:n:' \
        '--pass-media-keys[pass media keys]' \
        '--pass-screen-keys[pass screen keys]' \
        '--pass-volume-keys[pass volume keys]'
}

_i3lock-color "$@"
