#compdef deBGA
# Documentation: https://github.com/HongzheGuo/deBGA
# deBGA: de Bruijn graph-based seed-and-extension read aligner

local ret=1

local -a subcmds
subcmds=(
  'index:index reference in RdBG-Index format'
  'aln:align read to its primitive location in reference'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-k+[k-mer length of the vertices of RdBG / minimum Uni-MEM seed length]:int:' \
  '-s+[number of re-seeding iterations]:int:' \
  '-i+[minimum interval of seeding]:int:' \
  '-n+[maximum allowed hits per seed]:int:' \
  '-c+[edit distance threshold for early stopping]:num:' \
  '--cl+[adjusted edit distance threshold for divergent reads]:num:' \
  '--local[enable local alignment for confident alignments]' \
  '--local-match+[score for matched base]:int:' \
  '--local-mismatch+[penalty for mismatched base]:int:' \
  '--local-gap-open+[gap open penalty]:int:' \
  '--local-gap-extension+[gap extension penalty]:int:' \
  '--stdout[output alignments to standard output]' \
  '-u+[upper limit of insert size]:int:' \
  '-f+[lower limit of insert size]:int:' \
  '-o+[maximum alignment outputs]:int:' \
  '-x+[maximum outputs for anchoring alignment]:int:' \
  '-l+[maximum read length]:int:' \
  '-e+[budget for single-end alignment]:int:' \
  '-p+[number of threads]:int:' \
  '1:command:(($subcmds))' \
  '*:file:_files' && ret=0

return ret
