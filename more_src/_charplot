#compdef charplot
# Documentation: https://adobe-type-tools.github.io/afdko/AFDKO-Overview.html
# AFDKO: produce a PDF showing each glyph with nodes and control points

local ret=1

_arguments -s -S \
  '-g[show only the specified comma-delimited glyph list]:glyphs:' \
  '-gf[use glyph list contained in the specified file]:file:_files' \
  '-gpp[number of glyphs per page]:count:' \
  '-o[output pdf file path (must end in pdf)]:output:_files' \
  '-dno[do not open the PDF file when done]' \
  '-do[do open the PDF file when done]' \
  '-pt[point size for the glyphs]:size:' \
  '-black[set all colors to black]' \
  '-lf[path name to CID layout file]:file:_files' \
  '-help_params[show help about the low level parameters]' \
  '-q[quiet mode]' \
  '-h[print help]' \
  '-u[print usage]' \
  '*:font:_files' && ret=0

return ret
