#compdef certyaml
# Documentation: https://github.com/tsaarni/certyaml
# declarative way to create x509 certificates for test environments

local ret=1

_arguments -s -S \
  '(-d -destination)'{-d,-destination}'[destination directory for certificates and keys]:dir:_files -/' \
  '*:manifest file:_files -g "*.yaml"' && ret=0

return ret
