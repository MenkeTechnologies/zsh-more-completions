#compdef devpulse
# Documentation: https://man.archlinux.org/search?q=devpulse
# Reference accessed: 2026-05-16
# Source: cargo binstall dev-pulse@0.1.0
# Probed via: completions zsh
# Repository: https://github.com/deelo-ai/devpulse

autoload -U is-at-least

_devpulse() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--sort=[Sort projects by\: activity (most stale first), name, or status]:SORT:((activity\:"Sort by last commit time, most stale first"
name\:"Sort by project name alphabetically"
status\:"Sort by status (dirty first, then clean)"))' \
'--format=[Output format\: table, json, csv, markdown (or md)]:FORMAT:((table\:"Terminal table with colors (default)"
json\:"JSON output"
csv\:"Comma-separated values"
markdown\:"Markdown table"
md\:"Markdown table (alias)"))' \
'-i+[Watch interval in seconds \[default\: 60\]]:INTERVAL:_default' \
'--interval=[Watch interval in seconds \[default\: 60\]]:INTERVAL:_default' \
'*-f+[Filter projects by criteria. Can be specified multiple times. Values\: dirty, clean, stale, unpushed, name\:<substring>]:FILTER:_default' \
'*--filter=[Filter projects by criteria. Can be specified multiple times. Values\: dirty, clean, stale, unpushed, name\:<substring>]:FILTER:_default' \
'-d+[How many directory levels deep to scan for git projects \[default\: 1\] 0 = check only the target directory itself 1 = immediate children (default) 2+ = recursive scanning]:DEPTH:_default' \
'--depth=[How many directory levels deep to scan for git projects \[default\: 1\] 0 = check only the target directory itself 1 = immediate children (default) 2+ = recursive scanning]:DEPTH:_default' \
'-o+[Write output to a file instead of stdout. Works with all formats; table output strips ANSI colors when writing to file]:PATH:_files' \
'--output=[Write output to a file instead of stdout. Works with all formats; table output strips ANSI colors when writing to file]:PATH:_files' \
'--since=[Only show projects with commits within the given time window. Format\: <number><unit> where unit is d (days), w (weeks), or m (months). Examples\: 7d, 2w, 1m]:DURATION:_default' \
'--theme=[Color theme\: default, dracula, catppuccin-mocha, nord. Can also be set via \`theme\` in .devpulse.toml]:THEME:_default' \
'--json[Output results as JSON instead of a table (shorthand for --format json)]' \
'-w[Watch mode\: re-run at a regular interval]' \
'--watch[Watch mode\: re-run at a regular interval]' \
'--tui[Launch interactive TUI mode]' \
'-g[Group projects by their parent directory. Each group gets a sub-header and per-group summary stats]' \
'--group[Group projects by their parent directory. Each group gets a sub-header and per-group summary stats]' \
'--include-empty[Include projects with no commits when using --since. By default, projects with no commit history are excluded]' \
'--no-color[Disable colored output. Also respects the NO_COLOR environment variable and \`color = false\` in .devpulse.toml. Priority\: --no-color flag > NO_COLOR env > config > default (colors on)]' \
'--no-ci[Skip CI status checks (faster, no network requests). By default, devpulse queries GitHub Actions for projects with GitHub remotes]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::path -- Directory to scan for projects \[default\: current directory\]:_files' \
":: :_devpulse_commands" \
"*::: :->devpulse" \
&& ret=0
    case $state in
    (devpulse)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:devpulse-command-$line[2]:"
        case $line[2] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- Target shell\: bash, zsh, or fish:((bash\:"Bourne Again SHell"
zsh\:"Z Shell"
fish\:"Friendly Interactive SHell"))' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_devpulse__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:devpulse-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_devpulse_commands] )) ||
_devpulse_commands() {
    local commands; commands=(
'completions:Generate shell completions for bash, zsh, or fish' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'devpulse commands' commands "$@"
}
(( $+functions[_devpulse__completions_commands] )) ||
_devpulse__completions_commands() {
    local commands; commands=()
    _describe -t commands 'devpulse completions commands' commands "$@"
}
(( $+functions[_devpulse__help_commands] )) ||
_devpulse__help_commands() {
    local commands; commands=(
'completions:Generate shell completions for bash, zsh, or fish' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'devpulse help commands' commands "$@"
}
(( $+functions[_devpulse__help__completions_commands] )) ||
_devpulse__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'devpulse help completions commands' commands "$@"
}
(( $+functions[_devpulse__help__help_commands] )) ||
_devpulse__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'devpulse help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_devpulse" ]; then
    _devpulse "$@"
else
    compdef _devpulse devpulse
fi
