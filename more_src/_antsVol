#compdef antsVol
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsVol.cxx — VTK volume renderer for an ANTs image (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input-image)'{-i+,--input-image=}'[input image (or [image,<lowerClipxupperClip=0.0x1.0>])]:spec:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '(-x --mask-image)'{-x+,--mask-image=}'[mask image]:file:_files -g "*.{nii,nii.gz}"' \
    '*'{-f+,--functional-overlay=}'[overlay (rgbImage or [rgbImage,maskImage])]:spec:_default' \
    '(-d --display)'{-d+,--display=}'[doWindowDisplay or filename]:spec:_default' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
