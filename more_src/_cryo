_cryo() {
    local datatypes=(
        blocks transactions receipts logs traces vm_traces native_transfers
        block_author block_signatures balances code_diffs state_diffs
        storage_diffs nonces contracts trace_calls 4byte_counts opcode_counts
        eth_calls codes slots erc20_balances erc20_supplies erc20_metadata
        erc20_transfers erc20_approvals erc721_metadata erc721_transfers
        erc721_approvals address_appearances external_balances
        external_balance_diffs javascript_traces
    )

    _arguments -s -S \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-b --blocks)*'{-b,--blocks}'=[block numbers]:blocks:' \
        '*--timestamps=[timestamps in unix]:ts:' \
        '(-t --txs)*'{-t,--txs}'=[transaction hashes]:hash:' \
        '(-a --align)'{-a,--align}'[align chunk boundaries to regular intervals]' \
        '--reorg-buffer=[save blocks only when this old (default 0)]:n:' \
        '(-i --include-columns)*'{-i,--include-columns}'=[columns to include alongside defaults]:col:' \
        '(-e --exclude-columns)*'{-e,--exclude-columns}'=[columns to exclude from defaults]:col:' \
        '*--columns=[columns to use instead of defaults]:col:' \
        '*--u256-types=[output dtype(s) of U256 integers]:dtype:(binary string f64)' \
        '--hex[hex string encoding for binary columns]' \
        '(-s --sort)*'{-s,--sort}'=[columns to sort by (none for unordered)]:col:' \
        '--exclude-failed[exclude items from failed transactions]' \
        '(-r --rpc)'{-r,--rpc}'=[RPC URL (default MESC then ETH_RPC_URL)]:url:' \
        '--network-name=[network name (default eth_getChainId)]:name:' \
        '(-l --requests-per-second)'{-l,--requests-per-second}'=[ratelimit on requests/sec]:limit:' \
        '--max-retries=[max retries for provider errors (default 5)]:n:' \
        '--initial-backoff=[initial retry backoff in ms (default 500)]:ms:' \
        '--compute-units-per-second=[compute units per second (default 50)]:n:' \
        '--max-concurrent-requests=[global concurrent request cap]:n:' \
        '--max-concurrent-chunks=[concurrent chunks cap]:n:' \
        '--chunk-order=[chunk collection order]:order:(normal reverse random)' \
        '(-d --dry)'{-d,--dry}'[dry run, collect no data]' \
        '--remember[remember current command for future use]' \
        '(-v --verbose)'{-v,--verbose}'[extra verbosity]' \
        '--no-verbose[run quietly]' \
        '(-c --chunk-size)'{-c,--chunk-size}'=[blocks per file (default 1000)]:n:' \
        '--n-chunks=[number of files (alternative to --chunk-size)]:n:' \
        '*--partition-by=[dimensions to partition by]:dim:' \
        '(-o --output-dir)'{-o,--output-dir}'=[directory for output files]:dir:_files -/' \
        '*--subdirs=[output subdirs (datatype|network|custom)]:subdir:(datatype network)' \
        '--label=[label to add to each filename]:label:' \
        '--overwrite[overwrite existing files instead of skipping]' \
        '--csv[save as CSV instead of parquet]' \
        '--json[save as JSON instead of parquet]' \
        '--row-group-size=[rows per parquet row group]:n:' \
        '--n-row-groups=[number of parquet row groups]:n:' \
        '--no-stats[do not write statistics to parquet]' \
        '*--compression=[compression algorithm + level]:name:(none snappy lz4 zstd brotli gzip)' \
        '--report-dir=[directory for summary report]:dir:_files -/' \
        '--no-report[avoid saving a summary report]' \
        '*--address=[address(es)]:addr:' \
        '*--to-address=[to address(es)]:addr:' \
        '*--from-address=[from address(es)]:addr:' \
        '*--call-data=[call data(s) for eth_calls]:data:' \
        '*--function=[function(s) for eth_calls]:fn:' \
        '*--inputs=[input(s) for eth_calls]:input:' \
        '*--slot=[storage slot(s)]:slot:' \
        '*--contract=[contract address(es)]:addr:' \
        '*--topic0=[log topic0 / event signature(s)]:topic:' \
        '*--event=[log topic0 / event signature(s) (alias)]:topic:' \
        '*--topic1=[log topic1(s)]:topic:' \
        '*--topic2=[log topic2(s)]:topic:' \
        '*--topic3=[log topic3(s)]:topic:' \
        "*:datatype:($datatypes)"
