#compdef jellex
# Documentation: https://github.com/kellyjonbrazil/jellex
# Jello Explorer: TUI to filter JSON and JSON Lines data with Python syntax

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[version information]' \
  '1:JSON or JSON Lines file:_files' && ret=0

return ret
