#compdef routedns
# _routedns — DNS stub resolver, proxy and router (folbricht/routedns)
# upstream: https://github.com/folbricht/routedns
# Flags from cmd/routedns/main.go (cobra).

_routedns() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-l --log-level)'{-l+,--log-level=}'[log level 1-6]:level:(1 2 3 4 5 6)' \
        '*:config file:_files -g "*.(toml|json|yaml|yml)"'
}

_routedns "$@"
