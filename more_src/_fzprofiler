#compdef fzprofiler
# GMT supplements/gsfml — plot fracture zone cross-profiles and analysis results

local ret=1

_arguments -s \
  '-H+[plot height of individual profiles]:height:_default' \
  '-I+[select single profile by number]:n:_default' \
  '-L+[plot every inc profile]:inc:_default' \
  '-N+[spread profiles across multiple columns]:n:_default' \
  '-T+[file name prefix for input files]:prefix:_default' \
  '-W+[plot width of individual profiles]:width:_default' \
  '*-V[verbose (stackable)]' \
  '*:input file:_files' \
  && ret=0

return ret
