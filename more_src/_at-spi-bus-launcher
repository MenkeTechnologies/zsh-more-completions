#compdef at-spi-bus-launcher
# Documentation: https://man.archlinux.org/search?q=at-spi-bus-launcher
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--launch-immediately[launch immediately]' \
  '--a11y=+[accessibility]:flag:(0 1)' && ret=0

return ret
