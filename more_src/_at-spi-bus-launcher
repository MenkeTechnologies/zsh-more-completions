#compdef at-spi-bus-launcher
# Documentation: https://github.com/GNOME/at-spi2-core/blob/main/bus/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--launch-immediately[launch immediately]' \
  '--a11y=+[accessibility]:flag:(0 1)' && ret=0

return ret
