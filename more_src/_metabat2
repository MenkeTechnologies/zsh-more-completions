#compdef metabat2
# Documentation: https://bitbucket.org/berkeleylab/metabat/src/master/README.md
# MetaBAT2 - metagenome binning based on TNF and coverage

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --inFile)'{-i,--inFile}'=[input contigs fasta (required)]:file:_files' \
  '(-o --outFile)'{-o,--outFile}'=[base name for output bins (required)]:path:_files' \
  '(-a --abdFile)'{-a,--abdFile}'=[coverage depth file]:file:_files' \
  '(-m --minContig)'{-m,--minContig}'=[minimum contig size (default 2500)]:size' \
  '--maxP=[percent of good contigs (default 95)]:percent' \
  '--minS=[minimum edge score 1-99 (default 60)]:score' \
  '--maxEdges=[maximum edges per node (default 200)]:edges' \
  '--pTNF=[TNF probability threshold, 0=auto]:threshold' \
  '--noAdd[disable additional binning for small contigs]' \
  '--cvExt[use coverage file without variance]' \
  '--fullHeader[preserve complete fasta headers]' \
  '--noSampleDepths[omit per-sample depths in output headers]' \
  '(-x --minCV)'{-x,--minCV}'=[minimum mean coverage per library (default 1)]:cov' \
  '--minCVSum=[minimum total coverage across libraries (default 1)]:cov' \
  '(-s --minClsSize)'{-s,--minClsSize}'=[minimum output bin size (default 200000)]:size' \
  '(-t --numThreads)'{-t,--numThreads}'=[number of threads, 0=all]:threads' \
  '(-l --onlyLabel)'{-l,--onlyLabel}'[output sequence names only]' \
  '--saveCls[save cluster assignments as matrix]' \
  '--unbinned[generate file for unbinned contigs]' \
  '--noBinOut[skip individual bin file output]' \
  '--seed=[random seed, 0=random]:seed' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' && ret=0

return ret
