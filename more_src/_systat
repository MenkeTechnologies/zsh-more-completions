#compdef systat
# _systat — OpenBSD systat (curses-based system statistics; many views: cpu/iostat/vmstat/sensors/swap/netstat/ifstat/states/sources/rules/tcp/udp/uvm/malloc/pf/pftop/pool/uvm)
# upstream: https://github.com/openbsd/src (usr.bin/systat)
# Flags + views from usr.bin/systat/systat.1 on tip.

_systat() {
    _arguments \
        '-a[show all sensors]' \
        '-B[print one screen + exit]' \
        '-b[no header]' \
        '-h[show help]' \
        '-i[interactive]' \
        '-N[no DNS]' \
        '-n[numeric ports/services]' \
        '-d+[stop after N updates]:count:' \
        '-s+[update delay (seconds)]:seconds:' \
        '-w+[width]:cols:' \
        '1:view:(pigs vmstat iostat swap mbufs ifstat netstat states sources rules pf queues sensors uvm malloc pool cpu)' \
        '2:delay:'
}

_systat "$@"
