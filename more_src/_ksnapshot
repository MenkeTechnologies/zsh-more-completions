#compdef ksnapshot
# Documentation: https://github.com/KDE/ksnapshot
# Reference accessed: 2026-05-16
# Verified: upstream KDE ksnapshot main.cpp + ksnapshot_options.h.
# Obsolete; replaced by Spectacle in Plasma 5+.
# Removed from prior file: bogus man.archlinux.org search URL.

# ksnapshot: KDE screenshot tool (obsolete; use spectacle in Plasma 5+)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '(--fullscreen --region --freeregion --child)--current[capture window under cursor]' \
  '(--current --region --freeregion --child)--fullscreen[capture entire screen]' \
  '(--current --fullscreen --freeregion --child)--region[capture user-selected region]' \
  '(--current --fullscreen --region --child)--freeregion[capture free-form region]' \
  '(--current --fullscreen --region --freeregion)--child[capture child window]' && ret=0
return ret
