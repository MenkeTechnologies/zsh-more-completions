#compdef skrooge
# Documentation: https://invent.kde.org/office/skrooge
# Reference accessed: 2026-05-16
# Verified: upstream KDE skrooge repo. KDE GUI app with only standard
# KAboutData/QCommandLineParser flags plus positional file arg.
# Removed from prior file: bogus man.archlinux.org search URL.

# skrooge: KDE personal finance manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' \
  '*:skg file:_files -g "*.(skg|sks)(-.)"' && ret=0
return ret
