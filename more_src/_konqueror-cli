#compdef konqueror-cli konq-cli
# Documentation: https://man.archlinux.org/search?q=konqueror-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--profile=[profile name]:profile:' \
  '--profiles[list profiles]' \
  '--mimetype=[file MIME type]:mime:' \
  '--silent[suppress output]' \
  '--select[show file in containing folder]' \
  '--tempfile[file is temporary]' \
  '*:url_or_file:_files' && ret=0

return ret
