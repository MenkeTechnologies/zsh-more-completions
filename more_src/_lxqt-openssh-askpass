#compdef lxqt-openssh-askpass
# Documentation: https://github.com/lxqt/lxqt-openssh-askpass/blob/master/src/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: source declares no custom QCommandLineOption; only built-in help and
# version are available. The prompt text is passed to the GUI as a positional
# argument by ssh-add / ssh via the SSH_ASKPASS contract.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:prompt:' && ret=0

return ret
