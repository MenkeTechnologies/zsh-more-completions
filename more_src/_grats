#compdef grats
# _grats — extract a GraphQL schema from a TypeScript project (captbaritone/grats)
# upstream: https://github.com/captbaritone/grats
# Subcommands & flags from src/cli.ts (commander).

_grats() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--tsconfig=[path to tsconfig.json]:file:_files -g "tsconfig*.json"' \
        '--watch[watch and rebuild schema on changes]' \
        '--fix[automatically fix fixable diagnostics]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'locate:locate a GraphQL entity in source (e.g. User or User.id)'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                locate)
                    _arguments \
                        '--tsconfig=[path to tsconfig.json]:file:_files -g "tsconfig*.json"' \
                        '1:entity:'
                    ;;
            esac
            ;;
    esac
}

_grats "$@"
