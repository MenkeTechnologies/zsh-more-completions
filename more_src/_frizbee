#compdef frizbee
# Documentation: https://man.archlinux.org/search?q=frizbee
# Reference accessed: 2026-05-16

# Zsh completion for frizbee — OCI referrers / supply chain

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:subcommand:(list lint pull trace version)' \
  '*::args:{ _message "registry ref or options" }' && ret=0

return ret
