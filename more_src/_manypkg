#compdef manypkg
# Documentation: https://github.com/Thinkmill/manypkg
# Reference accessed: 2026-05-19
# Verified: Thinkmill/manypkg README. Subcommands: check, fix, run, exec.
# Per-subcommand flag surface is not documented upstream.
# Removed from prior file: fabricated --cwd/--filter flags on subcommands
# and bogus man.archlinux.org URL.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:check monorepo for issues'
      'fix:fix monorepo issues'
      'run:run a script in packages'
      'exec:execute a command in packages'
    )
    _describe -t commands 'manypkg command' commands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments \
          '1:package name or directory:' \
          '2:script:' && ret=0
        ;;
      exec)
        _arguments \
          '*:command:' && ret=0
        ;;
    esac
    ;;
esac

return ret
