#compdef manypkg

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:check monorepo for issues'
      'fix:fix monorepo issues'
      'run:run a script in packages'
      'exec:execute a command in packages'
    )
    _describe -t commands 'manypkg command' commands && ret=0
    ;;
  args)
    case $line[1] in
      check|fix)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--cwd=[working directory]:directory:_directories' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--cwd=[working directory]:directory:_directories' \
          '--filter=[filter packages]:filter pattern' \
          '1:script name' && ret=0
        ;;
      exec)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--cwd=[working directory]:directory:_directories' \
          '--filter=[filter packages]:filter pattern' \
          '1:command' \
          '*:arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
