#compdef ledgerutil
# Documentation: upstream docs at hyperledger-fabric.readthedocs.io/en/latest/commands/ledgerutil.html
# Reference accessed: 2026-05-30
# Hyperledger Fabric multi-binary harvest R46. ledgerutil is a Fabric
# peer-side block-store + ledger-integrity tool. Ships alongside the
# previously-covered _configtxgen/_configtxlator/_cryptogen (R44) and
# _osnadmin/_peer (R45) binaries.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'compare:compare channel snapshots from two different peers'
  'identifytxs:identify potentially divergent transactions'
  'verify:verify the integrity of a ledger'
)

_arguments -C -s -S \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'ledgerutil subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      compare)
        _arguments \
          '(-o --outputDir)-o+[output directory (default cwd)]:directory:_directories' \
          '(-o --outputDir)--outputDir=[output directory (default cwd)]:directory:_directories' \
          '(-f --firstDiffs)-f+[max differences by height (default 10, 0=disable)]:N:' \
          '(-f --firstDiffs)--firstDiffs=[max differences by height (default 10, 0=disable)]:N:' \
          '--help[show help]' \
          '1:first snapshot path:_directories' \
          '2:second snapshot path:_directories' && ret=0
        ;;
      identifytxs)
        _arguments \
          '(-o --outputDir)-o+[output directory (default cwd)]:directory:_directories' \
          '(-o --outputDir)--outputDir=[output directory (default cwd)]:directory:_directories' \
          '--help[show help]' \
          '1:blockStorePath (default /var/hyperledger/production):_directories' && ret=0
        ;;
      verify)
        _arguments \
          '(-o --outputDir)-o+[output directory (default cwd)]:directory:_directories' \
          '(-o --outputDir)--outputDir=[output directory (default cwd)]:directory:_directories' \
          '--help[show help]' \
          '1:blockStorePath (default /var/hyperledger/production):_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
