#compdef cyrus-squatter
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/squatter.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org squatter(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-squatter: build and compact Cyrus search index
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --incremental)'{-i,--incremental}'[incremental indexing]' \
  '(-a --squat-annot)'{-a,--squat-annot}'[only mailboxes with squat annotation]' \
  '(-r --recursive)'{-r,--recursive}'[recursive]' \
  '(-N --name)'{-N+,--name=}'[limit to mailboxes beginning with name]:name:' \
  '(-R --rolling)'{-R,--rolling}'[rolling daemon mode]' \
  '(-d --nodaemon)'{-d,--nodaemon}'[do not background in rolling mode]' \
  '(-n --channel)'{-n+,--channel=}'[sync log channel]:channel:' \
  '(-f --synclog)'{-f+,--synclog=}'[sync log file mode]:file:_files' \
  '(-t --srctier)'{-t+,--srctier=}'[compact source tiers]:tiers:' \
  '(-z --compact)'{-z+,--compact=}'[compact destination tier]:tier:' \
  '(-X --reindex)'{-X,--reindex}'[reindex before compact]' \
  '(-F --filter)'{-F,--filter}'[filter expunged messages]' \
  '(-T --reindex-tier)'{-T+,--reindex-tier=}'[subset of tiers to reindex]:tiers:' \
  '(-o --copydb)'{-o,--copydb}'[copy database instead of compact]' \
  '(-B --skip-locked)'{-B,--skip-locked}'[skip locked mailboxes]' \
  '(-U --only-upgrade)'{-U,--only-upgrade}'[compact only if reindexing]' \
  '(-u --user)'{-u,--user}'[arguments are usernames]' \
  '(-S --sleep)'{-S+,--sleep=}'[sleep N seconds between mailboxes]:seconds:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-s --squat-skip)'{-s+,--squat-skip=}'[skip unmodified-since delta]:delta:' \
  '(-Z --internalindex)'{-Z,--internalindex}'[use Xapian internal cyrusid]' \
  '(-p --allow-partials)'{-p,--allow-partials}'[allow partial indexing on attachment fail]' \
  '(-P --reindex-partials)'{-P,--reindex-partials}'[reindex partials]' \
  '(-L --reindex-minlevel)'{-L+,--reindex-minlevel=}'[index by level threshold]:level:' \
  '(-A --audit)'{-A,--audit}'[audit for unindexed messages]' \
  '*:mailbox or username:' && ret=0
return ret
