#compdef vineflower fernflower quiltflower
# _vineflower — Vineflower modern Java decompiler (fernflower fork) CLI alias (vineflower team, Java); custom argparse
# upstream: https://github.com/Vineflower/vineflower

_vineflower() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--rbr=+[bool 1/0]:n:' \
        '--rsy=+[bool 1/0]:n:' \
        '--din=+[bool 1/0]:n:' \
        '--dc4=+[bool 1/0]:n:' \
        '--das=+[bool 1/0]:n:' \
        '--hes=+[bool 1/0]:n:' \
        '--hdc=+[bool 1/0]:n:' \
        '--dgs=+[bool 1/0]:n:' \
        '--ner=+[bool 1/0]:n:' \
        '--esm=+[bool 1/0]:n:' \
        '--den=+[bool 1/0]:n:' \
        '--rgn=+[bool 1/0]:n:' \
        '--lit=+[bool 1/0]:n:' \
        '--bto=+[bool 1/0]:n:' \
        '--asc=+[bool 1/0]:n:' \
        '--nns=+[bool 1/0]:n:' \
        '--uto=+[bool 1/0]:n:' \
        '--udv=+[bool 1/0]:n:' \
        '--ump=+[bool 1/0]:n:' \
        '--rer=+[bool 1/0]:n:' \
        '--fdi=+[bool 1/0]:n:' \
        '--ind=+[indent string]:str:' \
        '--mpm=+[max time per method seconds]:n:' \
        '--ren=+[bool 1/0]:n:' \
        '--urc=+[user-renamer class]:str:' \
        '--cps=+[bool 1/0]:n:' \
        '--crp=+[bool 1/0]:n:' \
        '--cmpinit=+[bool 1/0]:n:' \
        '--obfu=+[bool 1/0]:n:' \
        '--log=+[level]:l:(error warn info debug trace)' \
        '--mpd=+[max processing depth]:n:' \
        '--ren=+[bool 1/0]:n:' \
        '--win=+[bool 1/0]:n:' \
        '--bsm=+[bool 1/0]:n:' \
        '--iib=+[bool 1/0]:n:' \
        '--vac=+[bool 1/0]:n:' \
        '--tcs=+[bool 1/0]:n:' \
        '--swe=+[bool 1/0]:n:' \
        '--pam=+[bool 1/0]:n:' \
