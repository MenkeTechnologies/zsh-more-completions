#compdef ldap2pg
# ============================================================================
# _ldap2pg — zsh completion for ldap2pg, LDAP-driven PostgreSQL role sync
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/dalibo/ldap2pg
#   Author     : Dalibo  (PostgreSQL consultancy)
#   License    : PostgreSQL
#   Stars      : 232
#   Language   : Go
#   Module     : github.com/dalibo/ldap2pg/v6  (Go workspace, current major v6)
#   Binary     : ldap2pg  (root main.go → internal/cmd.Main)
#   Last push  : 2026-04-13
#
# WHAT IT IS
#   ldap2pg is "manage PostgreSQL roles and privileges from YAML or LDAP" —
#   a Go pflag+koanf-based CLI that reads a YAML configuration describing
#   LDAP searches and the desired Postgres role/privilege mappings, queries
#   the LDAP directory for the actual user list, inspects the connected
#   Postgres instance for the currently-provisioned roles and privileges,
#   and either prints the diff (dry-run, the default) or applies the
#   CREATE / DROP / GRANT / REVOKE statements (--real).  Dalibo uses it in
#   production to drive RBAC for PostgreSQL clusters from corporate
#   directories;  it also doubles as a CI guard (`--check` exits 1 when
#   instance state diverges from the LDAP source of truth).
#
# CLI ARGUMENT GRAMMAR  (verbatim from internal/cmd/flags.go pflag declarations)
#   ldap2pg [OPTIONS] [DBNAME]
#
#   Positional:
#     [DBNAME]               PostgreSQL database name, conninfo string, or
#                            URI (same shapes accepted by psql).  Optional;
#                            when omitted, libpq env vars are consulted.
#
#   Options  (long / short flag pairs; pflag.<Type>P registers short alias):
#     --check                Exit 1 if Postgres state diverges (CI guard)
#     --color                Force colored output
#     -c, --config <FILE>    Path to YAML config file (use `-` for stdin)
#     -C, --directory <DIR>  Path to directory containing config files
#     -R, --real             Real mode — apply changes to Postgres
#                            (default is dry-run; nothing is mutated)
#     -P, --skip-privileges  Turn off privilege synchronisation
#     -?, --help             Show help message and exit
#     -V, --version          Show version and exit
#     -q, --quiet            Decrease log verbosity (repeatable count)
#     -v, --verbose          Increase log verbosity (repeatable count)
#     -y, --ldappassword-file <FILE>
#                            Path to LDAP password file
#
#   Environment:
#     LDAP2PG_*              koanf env provider auto-binds every flag
#                            with this prefix (dashes → underscores;
#                            e.g. LDAP2PG_CONFIG, LDAP2PG_REAL)
#     NO_COLOR               disables colored output
#     PG*                    libpq connection env (PGHOST/PGPORT/PGUSER/...)
#     LDAPURI / LDAPHOST     consumed by github.com/go-ldap/ldap/v3 client
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/go-ldap/ldap/v3 v3.4.11` declared in
#   go.mod — the canonical Go LDAP v3 client library (2440 stars), the same
#   crate used in production by the bulk of Go-ecosystem LDAP tooling.
#   ldap2pg's `internal/ldap` package wraps go-ldap/ldap/v3 to perform the
#   directory searches whose results drive the Postgres role mappings.
#   Verified via:
#     gh api repos/dalibo/ldap2pg/contents/go.mod
#       → github.com/go-ldap/ldap/v3 v3.4.11
#   This entry is the Go=114 leader bump that continues Axis 59
#   (LDAP Directory Service Library) opened at R825 with
#   Rust=ldap3_proto 0.4 (rvben/yamldap, kanidm/ldap3 protocol crate).
#
#   No completion for `ldap2pg` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.  Stock zsh
#   ships `_ldap` (for OpenLDAP `ldapsearch` / `ldapadd` / etc. — already
#   represented in this corpus via the `man_src/_ldap*` man-page-derived
#   completions) but no `_ldap2pg`.
# ============================================================================

_ldap2pg() {
    _arguments -s \
        '--check[exit 1 if Postgres instance state diverges from LDAP source]' \
        '--color[force colored output]' \
        '(-c --config)'{-c+,--config=}'[path to YAML config file (use - for stdin)]:config file:_files -g "*.(yaml|yml)"' \
        '(-C --directory)'{-C+,--directory=}'[path to directory containing config files]:config dir:_files -/' \
        '(-R --real)'{-R,--real}'[real mode — apply changes to Postgres (default dry-run)]' \
        '(-P --skip-privileges)'{-P,--skip-privileges}'[turn off privilege synchronisation]' \
        '(- *)'{-\?,--help}'[show help and exit]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '*'{-q,--quiet}'[decrease log verbosity (repeatable)]' \
        '*'{-v,--verbose}'[increase log verbosity (repeatable)]' \
        '(-y --ldappassword-file)'{-y+,--ldappassword-file=}'[path to LDAP password file]:password file:_files' \
        ':postgres dbname/conninfo/URI:'
}

_ldap2pg "$@"
