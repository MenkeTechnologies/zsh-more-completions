#compdef bkcrack

# https://github.com/kimci86/bkcrack — readme.md examples / --help long opts
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-L --list)'{-L,--list}'[list ZipCrypto entries]' \
  '-C+[zip with ciphertext]:file:_files' \
  '-c+[zip entry or cipher file]:path:' \
  '-P+[zip with known plaintext]:file:_files' \
  '-p+[plaintext entry or file]:path:' \
  '-o+[plaintext offset]:n:' \
  '-x+[hex bytes at offset]:offset hex:' \
  '-d+[write deciphered bytes]:file:_files' \
  '-k+[internal keys hex]:k0 k1 k2:' \
  '-D+[decrypted zip output]:file:_files' \
  '-U[change password]:zip newpw:' \
  '--change-keys[re-encrypt with new keys]' \
  '-b+[password charset]:set:' \
  '-l+[password length or range]:spec:' \
  '-r+[mask shortcut]:len charset:' \
  '-m+[mask string]:mask:' \
  '-s+[custom charset name and chars]:name chars:' \
  '*:archive or data:_files'
