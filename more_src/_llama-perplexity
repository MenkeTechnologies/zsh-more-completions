#compdef llama-perplexity

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-m+[model path]:model file:_files -g "*.gguf"' \
  '--model=[model path]:model file:_files -g "*.gguf"' \
  '-f+[input file]:input file:_files' \
  '--file=[input file]:input file:_files' \
  '-c+[context size]:size' \
  '--ctx-size=[context size]:size' \
  '-b+[batch size]:size' \
  '--batch-size=[batch size]:size' \
  '-t+[number of threads]:threads' \
  '--threads=[number of threads]:threads' \
  '-ngl+[number of GPU layers]:layers' \
  '--gpu-layers=[number of GPU layers]:layers' \
  '--chunks=[number of chunks]:chunks' \
  '--stride=[stride]:stride' \
  '--ppl-output-type=[output type]:type:(0 1)' \
  '--ppl-stride=[stride for perplexity calculation]:stride' \
  '--hellaswag[compute HellaSwag score]' \
  '--hellaswag-tasks=[number of HellaSwag tasks]:count' \
  '--winogrande[compute WinoGrande score]' \
  '--winogrande-tasks=[number of WinoGrande tasks]:count' \
  '--multiple-choice[multiple choice evaluation]' \
  '--multiple-choice-tasks=[number of MC tasks]:count' \
  '--kl-divergence[compute KL divergence]' \
  '--no-mmap[do not memory-map model]' \
  '--mlock[force system to keep model in RAM]' \
  '--seed=[RNG seed]:seed' \
  '--verbose-prompt[print prompt before generation]' && ret=0

return ret
