#compdef fakedata

_fakedata_generators() {
  local -a generators=(
    'name' 'nameFirst' 'nameLast' 'email' 'username' 'password'
    'domain' 'url' 'ipv4' 'ipv6' 'mac' 'useragent'
    'phone' 'country' 'city' 'state' 'zip' 'street'
    'lat' 'long' 'color' 'hex' 'rgb'
    'int' 'float' 'date' 'noun' 'verb' 'adjective'
    'sentence' 'paragraph' 'uuid' 'file' 'dir' 'emoji'
    'animal' 'beer' 'car' 'currency' 'industry' 'job'
    'product' 'company' 'creditcard' 'ssn' 'enum'
  )
  _describe 'generator' generators
}

_arguments \
  '-l[limit number of rows]:count' \
  '-t[output format (csv, tab, sql, json)]:format:(csv tab sql json)' \
  '-s[separator for output]:separator' \
  '-T[SQL table name]:name' \
  '-H[include header row]' \
  '-h[display help]' \
  '-v[display version]' \
  '*:generator:_fakedata_generators'
