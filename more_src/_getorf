#compdef getorf
# Documentation: https://man.archlinux.org/search?q=getorf
# Reference accessed: 2026-05-16

# EMBOSS getorf: find and extract open reading frames
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s)]:DNA USA:_files' \
  '-table=[genetic code]:code:(0 1 2 3 4 5 6 9 10 11 12 13 14 15 16 21 22 23)' \
  '-minsize=[minimum ORF size in nucleotides]:n:' \
  '-maxsize=[maximum ORF size in nucleotides]:n:' \
  '-find=[ORF output type]:type:(0 1 2 3 4 5)' \
  '-methionine[require M start]' \
  '-circular[treat as circular sequence]' \
  '-reverse[also search reverse strand]' \
  '-flanking=[bases of flanking sequence to include]:n:' \
  '-outseq=[output sequence file (ORFs)]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
