#compdef bpflist bpflist-bpfcc
# _bpflist — display processes currently using BPF programs / maps (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/bpflist.py (argparse).

_bpflist() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '*'{-v,--verbosity}'[also count/display kprobes/uprobes (repeatable)]'
    )
    _arguments $args
}

_bpflist "$@"
