local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _copywrite_cmds
_copywrite_cmds=(
    'init:generate a .copywrite.hcl config for a new project'
    'dispatch:dispatch audit jobs for a list of repos'
    'debug:print env-specific debug information about copywrite'
    'headers:add missing copyright headers + update year info in source files'
    'license:validate that a LICENSE file is present + remediate'
    'report:perform reporting tasks (PRs / repos)'
    'help:show help for any command'
    'completion:generate shell completion script'
)

local -a _copywrite_report_subs
_copywrite_report_subs=(
    'prs:list all unmerged compliance pull requests'
    'repos:report on GitHub repos matching specific criteria'
)

local -a _copywrite_pr_status _copywrite_log_levels
_copywrite_pr_status=(
    'open:open pull requests (default)'
    'closed:closed pull requests'
    'all:open + closed pull requests'
)
_copywrite_log_levels=(
    'trace:most verbose'
    'debug:debug-level logging'
    'info:informational logging (default)'
    'warn:warnings only'
    'error:errors only'
    'off:no logging'
)

_arguments -C \
    '--config=[path to .copywrite.hcl config (default .copywrite.hcl)]:config file:_files -g "*.hcl"' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'copywrite subcommand' _copywrite_cmds && ret=0
        ;;
    args)
        case $words[1] in
            init)
                _arguments \
                    '(-f --force)'{-f,--force}'[overwrite existing .copywrite.hcl]' \
                    '(-y --year)'{-y+,--year=}'[copyright year]:year:_default' \
                    '(-s --spdx)'{-s+,--spdx=}'[SPDX license identifier (e.g. MPL-2.0)]:spdx:(MPL-2.0 Apache-2.0 MIT BSD-3-Clause BSD-2-Clause GPL-3.0-only GPL-2.0-only LGPL-3.0-only LGPL-2.1-only ISC Unlicense)' \
                    && ret=0
                ;;
            dispatch)
                _arguments \
                    '--plan[dry-run: print repo names that would be audited]' \
                    '--max-attempts=[worker poll attempts before timeout (default 15)]:n:_default' \
                    '(-s --sleep)'{-s+,--sleep=}'[seconds between polls (default 10)]:seconds:_default' \
                    '(-w --workers)'{-w+,--workers=}'[concurrent jobs (default 2)]:n:_default' \
                    '(-b --branch)'{-b+,--branch=}'[GitHub branch (default main)]:branch:_default' \
                    '(-i --batch-id)'{-i+,--batch-id=}'[unique batch identifier (default auto ULID)]:batch id:_default' \
                    && ret=0
                ;;
            debug)
                _arguments \
                    '(-d --dirPath)'{-d+,--dirPath=}'[directory to introspect (default .)]:dir:_directories' \
                    && ret=0
                ;;
            headers)
                _arguments \
                    '(-d --dirPath)'{-d+,--dirPath=}'[directory to validate headers in (default .)]:dir:_directories' \
                    '--plan[dry-run: print files missing headers]' \
                    '(-s --spdx)'{-s+,--spdx=}'[SPDX license identifier (e.g. MPL-2.0)]:spdx:(MPL-2.0 Apache-2.0 MIT BSD-3-Clause BSD-2-Clause GPL-3.0-only GPL-2.0-only LGPL-3.0-only LGPL-2.1-only ISC Unlicense)' \
                    '(-c --copyright-holder)'{-c+,--copyright-holder=}'[copyright holder (default IBM Corp.)]:holder:_default' \
                    && ret=0
                ;;
            license)
                _arguments \
                    '(-d --dirPath)'{-d+,--dirPath=}'[directory to validate LICENSE file in (default .)]:dir:_directories' \
                    '--plan[dry-run: non-zero exit if improperly licensed]' \
                    '(-y --year)'{-y+,--year=}'[copyright year]:year:_default' \
                    '(-s --spdx)'{-s+,--spdx=}'[SPDX license identifier]:spdx:(MPL-2.0 Apache-2.0 MIT BSD-3-Clause BSD-2-Clause GPL-3.0-only GPL-2.0-only LGPL-3.0-only LGPL-2.1-only ISC Unlicense)' \
                    '(-c --copyright-holder)'{-c+,--copyright-holder=}'[copyright holder (default IBM Corp.)]:holder:_default' \
                    && ret=0
                ;;
            report)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'report subcommand' _copywrite_report_subs && ret=0
                else
                    case $words[2] in
                        prs)
                            _arguments \
                                '--csv[output in CSV format]' \
                                '--author=[search for PRs by author (default app/hashicorp-copywrite)]:author:_default' \
                                '--status=[PR status filter (default open)]:status:(open closed all)' \
                                && ret=0
                            ;;
                        repos)
                            _arguments \
                                '(-f --fields)'{-f+,--fields=}'[repo attributes (default Name,License,HTMLURL)]:fields:_default' \
                                '--github-org=[GitHub org to audit (default hashicorp)]:org:_default' \
                                && ret=0
                            ;;
                    esac
                fi
                ;;
            help)
                _describe -t commands 'subcommand' _copywrite_cmds && ret=0
                ;;
            completion)
                _values 'shell' bash zsh fish powershell && ret=0
                ;;
        esac
        ;;
esac

return ret
