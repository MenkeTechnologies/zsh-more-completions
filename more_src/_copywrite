#
# WHAT IS hashicorp/go-hclog AND WHY IS IT THE 59TH GO CLI LIBRARY?
#
# go-hclog (https://github.com/hashicorp/go-hclog, 591+ stars) is
# **HashiCorp's in-house structured logger for Go** — released 2017
# as the foundational logging library for HashiCorp's massive open-
# source ecosystem: Terraform, Vault, Nomad, Consul, Boundary,
# Waypoint, Packer, Vagrant, plus the `go-plugin` RPC framework
# that all those tools depend on.
#
# go-hclog's distinguishing characteristics:
#
#   1. NATIVE go-plugin INTEGRATION — go-hclog was DESIGNED for
#      HashiCorp's go-plugin RPC framework.  When a Go binary
#      runs as a plugin under a host process (e.g. a Terraform
#      provider running under `terraform`), hclog auto-serializes
#      log lines to stderr in a format the host process can
#      RE-EMIT with proper plugin attribution:
#
#          // In the plugin process:
#          logger := hclog.New(&hclog.LoggerOptions{
#              Name:       "terraform-provider-foo",
#              Level:      hclog.Info,
#              JSONFormat: true,
#              Output:     os.Stderr,
#          })
#          logger.Info("creating resource", "id", resourceID)
#          // → stderr: {"@level":"info","@message":"creating resource",
#          //            "@module":"terraform-provider-foo",
#          //            "@timestamp":"...","id":"resource-123"}
#
#          // In the host process (terraform):
#          // Receives the JSON log line via go-plugin's stderr
#          // channel, re-emits with plugin attribution:
#          // 2026-06-01T14:32:18.123Z [INFO]
#          //   terraform-provider-foo: creating resource: id=resource-123
#
#      Compare:
#         * zap: no plugin protocol integration (general-purpose)
#         * zerolog: no plugin protocol integration
#         * logrus: no plugin protocol integration
#         * log/slog: no plugin protocol integration
#         * hclog: PURPOSE-BUILT for go-plugin's host/plugin
#                   bidirectional log forwarding
#      FIRST documented Go Axis 9 logger with go-plugin RPC
#      framework integration as a primary design goal.
#
#   2. HIERARCHICAL Named() SUBSYSTEM LOGGERS — go-hclog uses
#      `.Named("subsystem")` to create child loggers that
#      INHERIT parent configuration AND prefix their name:
#
#          rootLogger := hclog.Default()
#          rootLogger.SetLevel(hclog.Info)
#
#          cliLogger := rootLogger.Named("cli")
#          // Log output prefix: "namespace.cli"
#
#          headerLogger := cliLogger.Named("headers")
#          // Log output prefix: "namespace.cli.headers"
#
#          headerLogger.Info("processing file", "path", filename)
#          // → "[INFO] namespace.cli.headers: processing file: path=..."
#
#      The hierarchy is REFLECTED in the @module field of JSON
#      output AND in the human-readable text format prefix.
#      Compare:
#         * zap: zap.With(zap.Namespace("subsystem")) — fields
#                 only, no level inheritance
#         * zerolog: log.With().Str("subsystem", ...) — fields
#                     only, no hierarchical prefix
#         * logrus: WithField("subsystem", ...) — fields only
#         * log/slog: slog.With("group", ...) — group prefix
#                      but no level inheritance via Named() chain
#         * hclog: TRUE hierarchical inheritance via Named()
#      FIRST documented Go Axis 9 logger with proper
#      Named() hierarchical subsystem prefix inheritance.
#
#   3. AutoColor / ColorOff / ForceColor + JSONFormat MODES — hclog
#      LoggerOptions has a unified color/format axis:
#
#          opts := &hclog.LoggerOptions{
#              Name:        "cli",
#              Level:       hclog.LevelFromString(os.Getenv("LOG_LEVEL")),
#              Color:       hclog.AutoColor,   // detect TTY
#              // OR:        hclog.ColorOff,
#              // OR:        hclog.ForceColor,
#              JSONFormat:  false,             // human-readable text
#              // OR:        true,             // JSON-line output
#              Output:      os.Stdout,
#              TimeFn:      func() time.Time { return time.Now().UTC() },
#              IncludeLocation: true,         // file:line on every log
#          }
#
#      Compare:
#         * zap: separate zap.NewProduction() / zap.NewDevelopment()
#                 factories — no runtime color toggle
#         * zerolog: ConsoleWriter wrapper for pretty + auto-color
#         * logrus: Formatter interface; TextFormatter has ForceColors
#         * log/slog: NewTextHandler / NewJSONHandler — separate
#                      handlers, no color
#         * hclog: SINGLE LoggerOptions struct with Color + JSONFormat
#                   as independent toggles
#      FIRST documented Go Axis 9 logger with Color + JSONFormat as
#      independent unified toggles in a single LoggerOptions struct.
#
#   4. LEVEL-PREDICATE GUARD METHODS — hclog.Logger exposes
#      IsTrace/IsDebug/IsInfo/IsWarn/IsError predicate methods so
#      callers can SKIP expensive log-message construction when
#      the level wouldn't emit:
#
#          if logger.IsDebug() {
#              logger.Debug("expensive computation",
#                  "result", expensiveCompute(...))
#          }
#          // Without IsDebug(), expensiveCompute() runs even
#          // when debug-level wouldn't emit.
#
#      Compare:
#         * zap: zap.Logger.Check(zapcore.DebugLevel, "msg") — similar
#                 but more verbose
#         * zerolog: log.Debug().Enabled() — chained but exists
#         * logrus: log.IsLevelEnabled(logrus.DebugLevel) — exists
#         * log/slog: Logger.Enabled(ctx, slog.LevelDebug) — exists
#         * hclog: IsTrace/IsDebug/IsInfo/IsWarn/IsError — concise
#                   per-level predicates
#      FIRST documented Go Axis 9 logger with per-level predicate
#      methods (IsTrace() etc.) as the canonical API.
#
#   5. HASHICORP ECOSYSTEM PROVENANCE — hclog powers the ENTIRE
#      HashiCorp Go ecosystem since 2017:
#         * Terraform (infrastructure-as-code)
#         * Vault (secrets management)
#         * Nomad (workload orchestration)
#         * Consul (service mesh)
#         * Boundary (zero-trust access)
#         * Waypoint (application deploy)
#         * Packer (image builder)
#         * Vagrant (dev environments)
#         * go-plugin (RPC framework — used by ALL above)
#         * raft (Raft consensus algorithm impl)
#      Beyond HashiCorp's own stack, hclog is foundational dependency
#      of thousands of plugin authors who write providers/backends
#      for HashiCorp tools.  copywrite itself (THIS) is HashiCorp's
#      compliance tool eating its own dogfood.
#      FIRST documented Go Axis 9 logger with this specific
#      HashiCorp-Ecosystem maintainership + 8 years of
#      production-scale battle-testing across Terraform/Vault/
#      Nomad/Consul.
#
# go-hclog's relationship to other documented Go Axis 9 libraries:
#
#   * Unlike zap (R579) — zap is general-purpose high-performance;
#                          hclog is HashiCorp-ecosystem with go-
#                          plugin integration
#   * Unlike zerolog (R583) — zerolog is zero-allocation chained
#                              builder; hclog is LoggerOptions struct
#   * Unlike logrus (R587) — logrus is original pluggable Hooks +
#                             Formatters; hclog is built-in modes
#   * Unlike log/slog (R591) — slog is stdlib official; hclog is
#                                third-party with go-plugin features
#   * Closest cross-language analogs:
#         * Rust: tracing (R590) — both have hierarchical contextual
#                                    logging via spans/Named
#         * TS-Node: winston (R580) — both have configurable
#                                       Output/Format options
#         * Java: SLF4J + Logback — similar facade+backend pattern
#     hclog is the FIRST documented Go logger providing go-plugin
#     RPC framework integration + hierarchical Named() subsystem
#     prefix inheritance + Color/JSONFormat unified toggles + per-
#     level Is*() predicate methods.
#
# -----------------------------------------------------------------------------
#
# THE copywrite CLI — cobra + hclog + koanf HCL config + go-pretty
#
# copywrite's CLI is in cmd/root.go + cmd/*.go.  Uses cobra subcommand
# tree:
#
#     rootCmd
#       ├── init        Generate .copywrite.hcl config
#       ├── dispatch    Bulk-audit repos via GitHub Actions
#       ├── debug       Print env-specific debug info
#       ├── headers     Add/update copyright headers (recursive)
#       ├── license     Validate LICENSE file (+ remediate)
#       └── report      Reporting subcommand
#             ├── prs       List unmerged compliance PRs
#             └── repos     Report on GitHub repos
#
# Logger initialization (cmd/root.go initLogger):
#
#     cliLogger = hclog.New(&hclog.LoggerOptions{
#         Name:   "cli",                    // Named() prefix
#         Level:  logLevel,                  // hclog.LevelFromString(env)
#         Color:  hclog.AutoColor,           // detect TTY
#         Output: os.Stdout,
#     })
#
# Log level resolution priority:
#   1. COPYWRITE_LOG_LEVEL env-var (if set)
#   2. RUNNER_DEBUG=1 → hclog.Debug (GitHub Actions debug mode)
#   3. hclog.DefaultLevel
#
# Persistent flag: --config (path to .copywrite.hcl, default ".copywrite.hcl")
#
# Five-axis distinctness from every other documented Go Axis 9 logger:
#
#   1. NATIVE go-plugin RPC INTEGRATION — Every other documented Go
#      logger lacks built-in go-plugin host/plugin log forwarding.
#      hclog is purpose-built for it.
#
#   2. HIERARCHICAL Named() SUBSYSTEM INHERITANCE — Every other
#      documented Go logger uses fields-only namespacing.  hclog
#      uses Named() with true hierarchical prefix inheritance.
#
#   3. UNIFIED COLOR+JSONFORMAT TOGGLES IN LoggerOptions — Every
#      other documented Go logger requires separate factories /
#      formatters / handlers for color/JSON.  hclog has both as
#      independent LoggerOptions fields.
#
#   4. PER-LEVEL IsTrace()/IsDebug()/IsInfo()/IsWarn()/IsError()
#      PREDICATES — Every other documented Go logger requires more
#      verbose level checks (Logger.Check(), level.Enabled(), etc.).
#      hclog has concise per-level predicate methods.
#
#   5. HASHICORP-ECOSYSTEM PROVENANCE — Every other documented Go
#      Axis 9 logger has different provenance.  hclog is the in-
#      house logger of Terraform/Vault/Nomad/Consul/Boundary/
#      Waypoint/Packer + the entire go-plugin RPC ecosystem.
#
