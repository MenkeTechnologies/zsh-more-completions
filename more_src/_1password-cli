#compdef 1password-cli
# _1password-cli — 1Password desktop CLI integration alias (1Password team, Go); cobra wrapper for op
# upstream: https://1password.com/downloads/command-line

_1password-cli() {
    local -a sub=(
        'biometric-unlock:configure biometric unlock'
        'developer-tool:enable developer tooling'
        'integrate-with-ssh-agent:enable SSH agent integration'
        'inject-secret-references:inject secret references'
        'item-create:create item'
        'item-edit:edit item'
        'item-get:get item'
        'item-list:list items'
        'item-share:share item'
        'item-template-list:list item templates'
        'vault-list:list vaults'
        'whoami:show current account'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--account=+[account]:str:' \
        '--session=+[session]:str:' \
        '--format=+[output format]:f:(json plain)' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands '1password subcommand' sub ;;
        args)
            case $words[1] in
                biometric-unlock|integrate-with-ssh-agent) _arguments \
                    '--enable[enable]' \
                    '--disable[disable]' ;;
                item-get|item-edit) _arguments \
                    '1:item:' \
                    '--vault=+[vault]:str:' \
                    '--fields=+[fields]:str:' ;;
            esac
            ;;
    esac
}

_1password-cli "$@"
