#compdef carbonblack-cli cbc-cli carbon-black-cli cbapi
# _carbonblack-cli — VMware Carbon Black carbonblack-cli CLI command-line frontend wrapping the VMware Carbon Black Cloud formerly CB Defense Threat Hunter Predictive Security Cloud Enterprise EDR App Control Workload endpoint protection platform CLI providing login logout whoami device alert event process binary search audit policy hash reputation watchlist feed report ioc vulnerability live-response live-query osquery enterprise-edr (VMware Carbon Black team, Python); custom argparse
# upstream: https://www.vmware.com/products/carbon-black-cloud.html

_carbonblack-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'device:device operations'
        'alert:alert operations'
        'event:event operations'
        'process:process operations'
        'binary:binary operations'
        'search:search operations'
        'audit:audit operations'
        'policy:policy operations'
        'hash:hash operations'
        'reputation:reputation operations'
        'watchlist:watchlist operations'
        'feed:feed operations'
        'report:report operations'
        'ioc:IOC operations'
        'vulnerability:vulnerability operations'
        'live-response:live response operations'
        'live-query:live query operations'
        'osquery:osquery operations'
        'enterprise-edr:Enterprise EDR ops'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--api-id=+[id]:str:' \
        '--api-key=+[key]:str:' \
        '--org-key=+[key]:str:' \
        '--url=+[url]:str:' \
        '--profile=+[name]:str:' \
        '-p+[profile]:str:' \
        '-c+[config file]:file:_files -g "credentials.cbc credentials.psc *.ini"' \
        '--credentials-file=+[file]:file:_files' \
        '-o+[format]:f:(json yaml table csv)' \
        '--output=+[format]:f:(json yaml table csv)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cbc subcommand' sub ;;
        args)
            case $words[1] in
                device|alert|event|process|binary|policy|hash|reputation|watchlist|feed|report|ioc|vulnerability) _arguments '1:op:(list get create update delete quarantine unquarantine kill background-scan deny-list allow-list bypass)' '*:id:' ;;
                live-response|live-query|osquery) _arguments '1:op:(session command upload-script list)' '*:arg:' ;;
            esac
            ;;
    esac
}

_carbonblack-cli "$@"
