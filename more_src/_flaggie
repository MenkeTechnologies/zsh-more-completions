#compdef flaggie
# Gentoo package.use flag manager

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--strict[strict mode]' \
  '--destructive[enable destructive actions]' \
  '--no-backup[do not create backups]' \
  '--backup-suffix=[backup file suffix]:suffix:' \
  '--sort[sort output]' \
  '*:package and flags:' && ret=0

return ret
