#compdef gitrob
# Documentation: https://github.com/michenriksen/gitrob
# gitrob - reconnaissance tool for GitHub organizations to find sensitive files.

local ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '-bind-address[web server binding address]:address:' \
  '-commit-depth[number of repository commits to process]:depth:' \
  '-debug[enable debugging output]' \
  '-github-access-token[GitHub API authentication token]:token:' \
  '-load[import a saved session file]:session:_files' \
  '-no-expand-orgs[skip adding organization members to targets]' \
  '-port[web server port]:port:' \
  '-save[export session to a file]:file:_files' \
  '-silent[suppress output except errors]' \
  '-threads[concurrent thread count]:threads:' \
  '*:target:' && ret=0

return ret
