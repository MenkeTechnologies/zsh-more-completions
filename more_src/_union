#compdef union
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/union.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS union: concatenate multiple sequences into one
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' \
  '-auto[turn off prompts]' \
  '-stdout[write to standard output]' \
  '-filter[stdin/stdout]' \
  '-options[prompt for standard and additional values]' \
  '-debug[debug log]' \
  '-verbose[report command line options]' \
  '-warning[control warnings]' \
  '-error[control errors]' \
  '-fatal[control fatal]' \
  '-die[control die]' \
  '-version[show version]' \
  '-sequence[input sequence(s)]:file:_files' \
  '-outseq[output sequence file]:file:_files' \
  '-overlapfile[sequence overlaps output file]:file:_files' \
  '-feature[use feature information]' \
  '-source[create source features]' \
  '-findoverlap[look for overlaps when joining]' \
  '*:sequence:_files' && ret=0

return ret
