#compdef linuxkit

_linuxkit_commands() {
  local -a commands=(
    'build:Build a LinuxKit image'
    'push:Push an image to a registry or cloud'
    'run:Run a LinuxKit image'
    'serve:Serve LinuxKit images'
    'version:Print version'
    'help:Show help'
    'pkg:Package management'
    'cache:Manage the local cache'
  )
  _describe -t commands 'linuxkit command' commands
}

_linuxkit() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --version)'{-v,--version}'[Print version]' \
    '--verbose[Enable verbose output]' \
    '1:command:_linuxkit_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        build)
          _arguments \
            '--name[Output name]:name:' \
            '--dir[Output directory]:dir:_directories' \
            '--pull[Always pull images]' \
            '--docker[Use Docker for building]' \
            '--cache[Cache directory]:dir:_directories' \
            '-o[Output format]:format:(kernel+initrd iso-bios iso-efi aws gcp azure vhd vmdk qcow2 raw-bios raw-efi tar-kernel-initrd)' \
            '--size[Image size]:size:' \
            '--arch[Architecture]:arch:(amd64 arm64 s390x)' \
            '--no-sbom[Skip SBOM generation]' \
            '--sbom-output[SBOM output file]:file:_files' \
            '1:config file:_files -g "*.y(a|)ml"'
          ;;
        push)
          _arguments \
            '1:target:(aws gcp azure packet scaleway openstack)' \
            '--img-name[Image name]:name:' \
            '--bucket[Storage bucket]:bucket:' \
            '--timeout[Push timeout]:timeout:' \
            '*:image file:_files'
          ;;
        run)
          _arguments \
            '--cpus[Number of CPUs]:cpus:' \
            '--mem[Memory in MB]:mem:' \
            '--disk[Disk specification]:disk:' \
            '--data[Additional data]:data:_files' \
            '--networking[Networking mode]:mode:(default user bridge)' \
            '--publish[Port publishing]:port:' \
            '--acpi[Enable ACPI]' \
            '--gui[Enable GUI]' \
            '--fw[Firmware file]:file:_files' \
            '--uefi[Use UEFI boot]' \
            '--kernel[Override kernel]:file:_files' \
            '--initrd[Override initrd]:file:_files' \
            '1:image:_files'
          ;;
        pkg)
          local -a subcommands=(
            'build:Build a package'
            'push:Push a package'
            'show-tag:Show package tag'
          )
          _describe -t subcommands 'pkg subcommand' subcommands
          ;;
        cache)
          local -a subcommands=(
            'clean:Clean the cache'
            'ls:List cached items'
            'export:Export cached items'
          )
          _describe -t subcommands 'cache subcommand' subcommands
          ;;
      esac
      ;;
  esac
}

_linuxkit "$@"
