#compdef dmcontour
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmcontour.html
# Create a FITS region file from image contour levels

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input file name]:infile:_files' \
  'levels=[contour levels defining regions]:levels:' \
  'outfile=[output FITS region file]:outfile:_files' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:argument:_files' && ret=0

return ret
