#compdef fn

# https://github.com/fnproject/cli — urfave/cli v1 (`fn`)

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'build:build function'
  'build-server:build server'
  'bump:bump version'
  'watch:auto-rebuild on change'
  'invoke:invoke a function'
  'configure:configure client'
  'create:create apps/functions/triggers/context'
  'delete:delete resources'
  'deploy:deploy function'
  'get:get config'
  'init:init local function'
  'inspect:inspect resources'
  'list:list resources'
  'migrate:migrate data'
  'push:push image'
  'start:start function'
  'stop:stop function'
  'unset:unset config/context'
  'update:update resources'
  'use:switch context'
)

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[verbose client logs]' \
  '--context=[Fn context file]:file:_files' \
  '--registry=[container registry]:registry:' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'fn command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
