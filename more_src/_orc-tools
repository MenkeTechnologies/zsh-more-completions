#compdef orc-tools

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'check:check the index of the specified column'
  'convert:convert CSV/JSON/ORC files to ORC'
  'count:recursively find ORC files and print row count'
  'data:print ORC file data'
  'json-schema:determine schema of JSON documents'
  'key:print encryption key info'
  'merge:merge multiple ORC files'
  'meta:print ORC file metadata'
  'scan:scan data for benchmarking'
  'sizes:list size on disk per column'
  'version:show ORC tool version'
  'help:show help'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'orc-tools subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (convert)
        _arguments \
          '-b=[batch size]:n:' \
          '-e=[heading rows to skip]:n:' \
          '-h[show help]' \
          '-H=[heading row]:n:' \
          '-n=[null literal]:str:' \
          '-o=[output file]:file:_files' \
          '-O=[overwrite]:flag:(true false)' \
          '-q=[quote character]:char:' \
          '-s=[schema file]:file:_files' \
          '-S=[schema string]:schema:' \
          '-t=[timestamp format]:format:' \
          '*:input:_files' && ret=0
        ;;
      (data)
        _arguments \
          '-h[show help]' \
          '-n=[number of rows]:n:' \
          '*:input:_files' && ret=0
        ;;
      (meta)
        _arguments \
          '--backup-path=[backup path]:dir:_files -/' \
          '--column-type=[column type]:type:' \
          '-d[decompress]' \
          '-h[show help]' \
          '-j[output JSON]' \
          '-p[pretty print]' \
          '-r[recursive]' \
          '--recover[recover]' \
          '--skip-dump[skip dumping data]' \
          '-t[show types]' \
          '*:input:_files' && ret=0
        ;;
      (json-schema)
        _arguments \
          '-f=[input file]:file:_files' \
          '-h[show help]' \
          '-p[pretty print]' \
          '-t[type only]' && ret=0
        ;;
      (key)
        _arguments \
          '-h[show help]' \
          '-o=[output file]:file:_files' && ret=0
        ;;
      (scan)
        _arguments \
          '-h[show help]' \
          '-s=[schema]:schema:' \
          '-v[verbose]' \
          '*:input:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
