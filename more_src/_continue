#compdef continue

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'serve:run the Continue server'
  'login:authenticate with Continue'
  'logout:sign out'
  'status:show authentication status'
  'config:open/print the config file'
  'install:install a model or extension config'
  'doctor:diagnose installation'
  'plugin:plugin management'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[config file path]:file:_files -g "*.{json,yaml,yml}"' \
  '--data-dir=[data directory]:dir:_files -/' \
  '--log-level=[log level]:level:(trace debug info warn error)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'continue command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (serve)
        _arguments \
          '--port=[server port]:port:' \
          '--host=[bind host]:host:_hosts' && ret=0 ;;
      (config)
        _arguments \
          '--edit[open editor]' \
          '--print[print effective config]' && ret=0 ;;
      (plugin)
        _arguments '*::sub:(install uninstall list update)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
