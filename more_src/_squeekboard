#compdef squeekboard
# Documentation: https://gitlab.gnome.org/World/Phosh/squeekboard
# Reference accessed: 2026-05-16
# Verified: no documented custom CLI flags. Standard GTK options only.
# SQUEEKBOARD_DEBUG env var (e.g. force-show) is the only documented config.

# squeekboard: on-screen keyboard for Phosh/wlroots compositors
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '--display=[X display to use]:display:' && ret=0
return ret
