#compdef duplicacy

# Zsh completion for Duplicacy

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:initialize the storage and repository'
  'backup:save a snapshot of the repository'
  'restore:restore the repository to a previous revision'
  'list:list snapshots'
  'check:check integrity of snapshots'
  'cat:print a file in a snapshot'
  'diff:compare two snapshots or a snapshot and the repository'
  'history:show the history of a file'
  'prune:prune old snapshots'
  'password:change the storage password'
  'add:add an additional storage'
  'set:change repository preferences'
  'copy:copy snapshots between storages'
  'benchmark:benchmark the storage'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-log[enable log-style output]' \
  '-d[print debugging information]' \
  '-v[verbose output]' \
  '-stack+[specify the snapshot id]:name:' \
  '-storage+[specify the storage name]:name:' \
  '*:: :->subcmd' && ret=0

case $state in
  subcmd)
    if (( CURRENT == 1 )); then
      _describe -t commands 'duplicacy command' subcommands && ret=0
    fi
    ;;
esac

return ret
