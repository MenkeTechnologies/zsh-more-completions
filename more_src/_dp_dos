#compdef dp_dos
# Documentation: https://gitlab.com/dftbplus/dftbplus/-/raw/main/tools/dptools/src/dptools/scripts/dp_dos.py
# DFTB+ dptools: convolve band.out data into DOS/PDOS with broadening functions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-g --gridres)'{-g,--gridres}'+[grid separation (default 0.01)]:gridres:' \
  '(-w --weight-occ)'{-w,--weight-occ}'[create pdos or occupation weighted dos]' \
  '(-f --broadening-function)'{-f,--broadening-function}'+[broadening function (default gauss)]:func:(gauss fermi mp)' \
  '(-o --mporder)'{-o,--mporder}'+[order of mp function]:order:' \
  '(-b --broadening-width)'{-b,--broadening-width}'+[broadening width sigma]:sigma:' \
  '(-s --sigma-range)'{-s,--sigma-range}'+[number of sigmas after which broadening is zero]:range:' \
  '(-v --verbose)'{-v,--verbose}'[turn on verbose operation]' \
  '(-A --auto-align)'{-A,--auto-align}'[align half-occupation estimate to zero energy]' \
  '(-a --align)'{-a,--align}'+[manually define zero energy in eV]:energy:' \
  '1:input file:_files' \
  '2:output file:_files' && ret=0

return ret
