#compdef tsr
# Documentation: https://github.com/line/tsr
# tsr - TypeScript Remove: remove unused code from TypeScript projects

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --project)'{-p,--project}'=[path to tsconfig.json]:tsconfig:_files -g "*.json"' \
  '(-w --write)'{-w,--write}'[write fixable changes directly to files]' \
  '(-r --recursive)'{-r,--recursive}'[recursively process files until project is clean]' \
  '--include-d-ts[include unused code detection in .d.ts files]' \
  '*:entrypoint regex:_files' && ret=0

return ret
