#compdef bucardo
# _bucardo — PostgreSQL multi-master replication control script (bucardo/bucardo)
# upstream: https://github.com/bucardo/bucardo
# Verbs from bin/bucardo Perl source ($verb dispatch table).

_bucardo() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '--verbose[verbose output]' \
        '--debug[debug output]' \
        '--quiet[quiet output]' \
        '--dbhost=[Postgres host]:host:_hosts' \
        '--dbport=[Postgres port]:port:' \
        '--dbname=[Postgres database]:db:' \
        '--dbuser=[Postgres user]:user:_users' \
        '--dbpass=[Postgres password]:pass:' \
        '--piddir=[PID file directory]:dir:_files -/' \
        '--bucardorc=[bucardorc config file]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'install:install Bucardo schema into a Postgres DB'
                'upgrade:upgrade Bucardo schema'
                'status:show MCP/sync status'
                'start:start the Bucardo daemon (MCP)'
                'stop:stop the Bucardo daemon'
                'restart:restart the Bucardo daemon'
                'reload:reload config or a sync'
                'reopen:reopen log files'
                'ping:ping the Bucardo daemon'
                'list:list objects (db/sync/table/dbgroup/herd/relgroup/customcode)'
                'add:add an object'
                'remove:remove an object (alias: delete del)'
                'update:update an object'
                'inspect:inspect an object'
                'message:send a message to a sync'
                'config:show/set config (set, show, config)'
                'set:set a config value'
                'show:show a config value'
                'validate:validate a sync'
                'purge:purge delta/track rows'
                'clone:clone a sync'
                'delta:count delta rows (alias: deltas)'
                'activate:activate a sync'
                'deactivate:deactivate a sync'
                'kick:kick a sync into action'
                'pause:pause a sync'
                'resume:resume a paused sync'
                'help:show help'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                list|add|remove|delete|del|update|inspect)
                    _arguments \
                        '1:noun:(db sync table dbgroup herd relgroup customcode all)' \
                        '*:object name:'
                    ;;
                kick|activate|deactivate|pause|resume|reload|message|validate|clone)
                    _arguments '*:sync name:'
                    ;;
            esac
            ;;
    esac
}

_bucardo "$@"
