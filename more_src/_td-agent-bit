#compdef td-agent-bit fluent-bit
# Documentation: https://github.com/fluent/fluent-bit (src/fluent-bit.c getopt_long)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# td-agent-bit / fluent-bit (Treasure Data fluent-bit fork legacy & upstream)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-d --daemon)'{-d,--daemon}'[daemon mode]' \
  '(-D --dry-run)'{-D,--dry-run}'[dry run]' \
  '(-f --flush)'{-f+,--flush=}'[flush interval]:s:' \
  '(-H --http)'{-H,--http}'[enable HTTP server]' \
  '(-P --port)'{-P+,--port=}'[HTTP server port]:port:' \
  '(-C --custom)'{-C+,--custom=}'[load custom plugin]:plugin:' \
  '(-i --input)'{-i+,--input=}'[input plugin]:plugin:' \
  '(-r --processor)'{-r+,--processor=}'[processor]:processor:' \
  '(-F --filter)'{-F+,--filter=}'[filter plugin]:plugin:' \
  '(-o --output)'{-o+,--output=}'[output plugin]:plugin:' \
  '(-m --match)'{-m+,--match=}'[match for plugins]:pattern:' \
  '(-R --parser)'{-R+,--parser=}'[parsers file]:file:_files' \
  '(-p --prop)'{-p+,--prop=}'[plugin property]:prop:' \
  '(-e --plugin)'{-e+,--plugin=}'[load external plugin]:path:_files' \
  '(-t --tag)'{-t+,--tag=}'[tag for plugin]:tag:' \
  '(-T --sp-task)'{-T+,--sp-task=}'[stream processor task]:task:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-w --workdir)'{-w+,--workdir=}'[work directory]:dir:_directories' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-J --help-json)'{-J,--help-json}'[show help in JSON]' \
  '(-S --sosreport)'{-S,--sosreport}'[generate sosreport]' \
  '(-Y --enable-hot-reload)'{-Y,--enable-hot-reload}'[enable hot reload]' \
  '(-Z --enable-chunk-trace)'{-Z,--enable-chunk-trace}'[enable chunk trace]' \
  '--trace=[trace target]:target:' \
  '--trace-input=[trace input]:input:' \
  '--trace-output=[trace output]:output:' \
  '--trace-output-property=[trace output property]:prop:' \
  '(-W --disable-thread-safety-on-hot-reload)'{-W,--disable-thread-safety-on-hot-reload}'[disable thread safety on hot reload]' \
  '--supervisor[run under supervisor]' \
  '*::args:_files' && ret=0
return ret
