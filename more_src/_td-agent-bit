#compdef td-agent-bit
# Documentation: https://man.archlinux.org/search?q=td-agent-bit
# Reference accessed: 2026-05-16

# td-agent-bit: Treasure Data fluent-bit fork (legacy)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '-c[config file]:file:_files' \
  '-d[daemon]' \
  '-f[flush interval]:s:' \
  '-i[input plugin]:plugin:' \
  '-o[output plugin]:plugin:' \
  '-v[verbose]' \
  '*::td-agent-bit args:_files' && ret=0
return ret
