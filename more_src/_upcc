#compdef upcc
# Documentation: https://upc.lbl.gov/docs/user/upcc.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# upcc: Berkeley UPC compiler driver
local curcontext="$curcontext" ret=1
_arguments -C \
  '-c[compile without linking]' \
  '-E[preprocess to stdout]' \
  '-g[generate debug info]' \
  '-I+[add header search directory]:dir:_files -/' \
  '-L+[add library search path]:dir:_files -/' \
  '-l-[link with library]:lib:' \
  '-O[optimize]' \
  '-opt[enable experimental translator optimizations]' \
  '-o+[output file]:file:_files' \
  '-pg[generate profiling info]' \
  '-s[strip symbolic information]' \
  '-D+[define preprocessor symbol]:sym:' \
  '-U+[undefine preprocessor symbol]:sym:' \
  '-show-confs[show installed multiconf variations]' \
  '-bupc[select bupc translator]' \
  '-gupc[select gupc translator]' \
  '-cupc[select cupc translator]' \
  '-cupc2c[select cupc2c translator]' \
  '-trace[enable communication tracing]' \
  '-inst[enable GASP instrumentation]' \
  '-network=[network conduit]:conduit:(mpi udp smp ibv aries ofi ucx)' \
  '-shared-heap=[shared memory per thread]:size:' \
  '-T=[fixed thread count]:n:' \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '(- *)-?[show help]' \
  '-conf=[alternate configuration file]:file:_files' \
  '-norc[skip user configuration]' \
  '-smart-output[auto-generate output filename]' \
  '(- *)-V[show version]' \
  '(- *)-version[show version]' \
  '-v[verbose]' \
  '-vv[extra verbose]' \
  '-allow-deprecated[disable deprecation warnings]' \
  '-checks[enable build consistency checking]' \
  '-nochecks[disable build consistency checking]' \
  '-compress=[gzip compression level]:level:' \
  '-extern-main[main in non-UPC code]' \
  '-fast-symptr[use fast symmetric pointers]' \
  '-nofast-symptr[disable fast symmetric pointers]' \
  '-opt-enable=[enable optimizations]:list:' \
  '-opt-disable=[disable optimizations]:list:' \
  '-http-proxy=[HTTP proxy]:url:' \
  '-lines[insert line directives]' \
  '-nolines[no line directives]' \
  '-link-cache[enable pthread-link cache]' \
  '-nolink-cache[disable pthread-link cache]' \
  '-link-with[backend linker]:prog:' \
  '-nightly[select nightly translator build]' \
  '-stable[select stable translator build]' \
  '-yesterday[select yesterday translator build]' \
  '-nopthreads[disable pthreads]' \
  '-print-include-dir[show header directory]' \
  '-print-mpicc[show MPI compiler path]' \
  '-pthreads[enable pthreaded executable]' \
  '-pthreads=[enable pthreaded executable]:n:' \
  '-require-size[require minimum shared memory]' \
  '-norequire-size[do not require minimum shared memory]' \
  '-save-temps[save intermediate files]' \
  '-nosave-temps[do not save intermediate files]' \
  '-save-all-temps[save all intermediate files]' \
  '-nosave-all-temps[do not save all intermediate files]' \
  '-show-sizes[display platform sizes]' \
  '-size-warn[warn about shared memory size]' \
  '-nosize-warn[suppress shared memory size warnings]' \
  '-trans[stop after UPC-to-C translation]' \
  '-translator=[use specific translator]:path:_files' \
  '-uses-mpi[enable MPI interoperability]' \
  '*:files:_files' && ret=0
return ret
