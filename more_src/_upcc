#compdef upcc
# Documentation: https://upc.lbl.gov/docs/user/upcc.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# upcc: Berkeley UPC compiler driver
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-V[show version]' \
  '-v[verbose]' \
  '-c[compile only]' \
  '-o[output file]:file:_files' \
  '-I[include dir]:dir:_files -/' \
  '-L[library dir]:dir:_files -/' \
  '-l[library]:lib:' \
  '-T[set THREADS]:n:' \
  '-network=[network conduit]:conduit:(smp udp mpi ibv aries ofi gemini lapi shmem mxm ucx)' \
  '-pthreads[enable pthreads]' \
  '-nopthreads[disable pthreads]' \
  '-O[optimize]:level:(0 1 2 3)' \
  '-g[debug info]' \
  '-pg[profiling]' \
  '-shared[shared library]' \
  '-static[static library]' \
  '-uda[universal dynamic addressing]' \
  '*:files:_files' && ret=0
return ret
