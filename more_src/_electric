#compdef electric
# Documentation: https://man.archlinux.org/search?q=electric
# Reference accessed: 2026-05-16

# Electric VLSI: IC design editor (schematics + layout)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-h[show help]' \
  '-V[show version]' \
  '-c[run Java class]:class:' \
  '-debug[enable debug output]' \
  '-batch[batch mode]' \
  '-mdi[use MDI window mode]' \
  '-sdi[use SDI window mode]' \
  '-NOMINMEM[ignore minimum memory setting]' \
  '-server[run as server]:port:' \
  '-client[run as client]:host:port:' \
  '-version[show version]' \
  '*:Electric file (.elib/.delib/.jelib):_files -g "*.(elib|delib|jelib)"' && ret=0
return ret
