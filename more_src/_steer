#compdef steer
# Documentation: https://github.com/BrendanGraham14/steer
# Reference accessed: 2026-05-22
# Verified: README.md --help output and subcommand list.

# Zsh completion for steer - TUI AI coding agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--session[resume session by ID]:id:' \
  '(-d --directory)'{-d,--directory}'[working directory]:directory:_directories' \
  '(-m --model)'{-m,--model}'[model name]:model:' \
  '--remote[remote gRPC server URL]:url:' \
  '--session-config[session TOML config file]:file:_files' \
  '--theme[TUI theme]:theme:' \
  '--catalog[additional catalog TOML file]:file:_files' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'steer command' \
      'tui[interactive terminal UI default]' \
      'preferences[manage user preferences]' \
      'headless[non-interactive mode]' \
      'server[start gRPC server]' \
      'session[session management]' \
      'workspace[workspace management]' && ret=0
    ;;
  args)
    case $line[1] in
      headless)
        _arguments \
          '--messages-json[messages JSON file]:file:_files' \
          '--session-config[session config file]:file:_files' \
          '*:prompt:' && ret=0
        ;;
      server)
        _arguments \
          '--port[server port]:port:' \
          '--catalog[catalog TOML file]:file:_files' && ret=0
        ;;
      session)
        _values 'session command' list delete create && ret=0
        ;;
      workspace)
        _values 'workspace command' list status && ret=0
        ;;
      preferences)
        _values 'preferences command' show edit reset && ret=0
        ;;
    esac
    ;;
esac

return ret
