#compdef netcat-traditional
# Documentation: https://man.archlinux.org/search?q=netcat-traditional
# Reference accessed: 2026-05-16

# nc.traditional: GNU/Hobbit netcat
local curcontext="$curcontext" ret=1
_arguments -C \
  '-c[shell command]:cmd:' \
  '-e[program to exec]:program:_files' \
  '-b[allow broadcast]' \
  '-g[source-routing hop]:hop:' \
  '-G[source-routing pointer]:n:' \
  '-h[show help]' \
  '-i[delay between connects]:seconds:' \
  '-l[listen mode]' \
  '-n[no DNS]' \
  '-o[hex dump to file]:file:_files' \
  '-p[source port]:port:' \
  '-q[wait seconds then quit]:seconds:' \
  '-r[random source port]' \
  '-s[source address]:address:' \
  '-t[answer TELNET negotiation]' \
  '-u[UDP mode]' \
  '-v[verbose]' \
  '-w[timeout]:seconds:' \
  '-z[scan mode (no data sent)]' \
  '*::host port:_hosts' && ret=0
return ret
