#compdef netcat-traditional
# Documentation: https://manpages.debian.org/bookworm/netcat-traditional/nc.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nc.traditional: GNU/Hobbit netcat
local curcontext="$curcontext" ret=1
_arguments -C \
  '-c[shell command after connect]:cmd:' \
  '-e[program to exec after connect]:program:_files' \
  '-b[allow UDP broadcasts]' \
  '-C[send CRLF as line endings]' \
  '-g[source-routing hop]:hop:' \
  '-G[source-routing pointer]:n:' \
  '-h[show help]' \
  '-i[delay between lines sent or ports scanned]:seconds:' \
  '-l[listen mode]' \
  '-n[no DNS]' \
  '-o[hex dump to file]:file:_files' \
  '-p[local port]:port:' \
  '-q[wait seconds then quit after EOF]:seconds:' \
  '-r[randomize ports]' \
  '-s[local source address]:address:' \
  '-t[answer TELNET negotiation]' \
  '-T[set IP TOS flag]:tos:(Minimize-Delay Maximize-Throughput Maximize-Reliability Minimize-Cost)' \
  '-u[UDP mode]' \
  '-v[verbose (repeat for more)]' \
  '-w[timeout for connects and final net reads]:seconds:' \
  '-z[zero-I/O mode (scanning)]' \
  '*::host port:_hosts' && ret=0
return ret
