#compdef flower
# Documentation: https://flower.readthedocs.io/en/latest/config.html
# Reference accessed: 2026-06-04

# Zsh completion for Celery Flower monitoring tool

_arguments \
    '--port[run on the given port]:port number' \
    '--address[run on the given address]:address' \
    '--broker[broker URL]:broker URL' \
    '--broker_api[broker API URL for the management plugin]:broker API URL' \
    '--basic_auth[enable HTTP basic authentication]:user\:password' \
    '--auto_refresh[enable auto refresh]:enabled:(true false)' \
    '--debug[enable debug mode]' \
    '--inspect_timeout[timeout for inspect commands in seconds]:seconds' \
    '--auth[enable Google OAuth authentication]:email regex' \
    '--auth_provider[authentication provider]:provider' \
    '--url_prefix[URL prefix]:prefix' \
    '--persistent[enable persistent mode to save state]' \
    '--db[database file for persistent mode]:file:_files' \
    '--state_save_interval[state save interval in milliseconds]:milliseconds' \
    '--max_workers[maximum number of workers to keep in memory]:number' \
    '--max_tasks[maximum number of tasks to keep in memory]:number' \
    '--natural_time[display time in natural format]:enabled:(true false)' \
    '--conf[flower configuration file]:file:_files' \
    '--certfile[SSL certificate file]:file:_files' \
    '--keyfile[SSL key file]:file:_files' \
    '--ca_certs[CA certificates file]:file:_files' \
    '--xheaders[enable support of X-Real-IP and X-Scheme headers]' \
    '--purge_offline_workers[time in seconds after which offline workers are purged]:seconds' \
    '(- *)--help[show help message and exit]'
