#compdef whizard
# Documentation: https://gitlab.tp.nt.uni-siegen.de/whizard/public/-/blob/master/share/doc/manual.tex
# whizard - WHIZARD Monte-Carlo event generator for multi-particle processes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[list available options and exit]' \
  '(-V --version)'{-V,--version}'[print version information and exit]' \
  '--debug=[switch on debug output for AREA]:area:' \
  '--debug2=[switch on more verbose debug output for AREA]:area:' \
  '--single-event[only compute one phase-space point (debugging)]' \
  '(-e --execute)'{-e,--execute}'=[execute COMMANDS as a script before the script file]:commands:' \
  '(-f --file)'{-f,--file}'=[execute commands in CMDFILE before the main script]:cmdfile:_files' \
  '(-i --interactive)'{-i,--interactive}'[run WHIZARD interactively]' \
  '(-l --library)'{-l,--library}'=[preload process library LIB]:lib:' \
  '--localprefix=[search DIR for local models]:dir:_files -/' \
  '(-L --logfile)'{-L,--logfile}'=[write log to FILE]:file:_files' \
  '--logging[start logging on startup (default)]' \
  '(-m --model)'{-m,--model}'=[preload model MODEL]:model:' \
  '--no-banner[do not display banner at startup]' \
  '--no-library[do not preload a library]' \
  '--no-logfile[do not write a logfile]' \
  '--no-logging[do not issue information into the logfile]' \
  '--no-model[do not preload a specific physics model]' \
  '--no-rebuild[do not force a rebuild]' \
  '(-q --query)'{-q,--query}'=[display documentation of VARIABLE]:variable:' \
  '(-r --rebuild)'{-r,--rebuild}'[do all calculations from scratch]' \
  '--rebuild-library[rebuild the process library, even if code exists]' \
  '--rebuild-phase-space[rebuild the phase space setup]' \
  '--rebuild-grids[redo the integration, even if previous grids exist]' \
  '--rebuild-events[redo event generation, discarding previous event files]' \
  '--show-config[show build-time configuration]' \
  '--prefix=[actual location of the WHIZARD installation]:dir:_files -/' \
  '--exec-prefix=[actual location of machine-specific parts]:dir:_files -/' \
  '--bindir=[actual location of the executables]:dir:_files -/' \
  '--libdir=[actual location of the libraries]:dir:_files -/' \
  '--includedir=[actual location of the include files]:dir:_files -/' \
  '--datarootdir=[actual location of the data files]:dir:_files -/' \
  '--libtool=[location and name of the libtool script]:file:_files' \
  '--lhapdfdir=[location of the LHAPDF installation]:dir:_files -/' \
  '*:SINDARIN script:_files -g "*.sin"' && ret=0

return ret
