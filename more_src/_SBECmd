#compdef SBECmd
# Documentation: https://github.com/EricZimmerman/ShellBagsExplorer
# ShellBags Explorer Command line edition

local ret=1

_arguments -s -S \
  '-d[directory to look for registry hives]:directory:_files -/' \
  '-l[process live registry]' \
  '--csv[directory to save output to]:directory:_files -/' \
  '--dedupe[process all hives in -d and remove duplicates]' \
  '--dt[date/time format string]:format' \
  '--tz[time zone to use (default UTC)]:timezone' \
  '--nl[ignore transaction log files for dirty hives]' && ret=0

return ret
