#compdef web2disk
# Documentation: https://manual.calibre-ebook.com/generated/en/web2disk.html
# Save a web page and its links recursively to disk

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this help message and exit]' \
  '--version[show program version number and exit]' \
  '--verbose[show detailed output information]' \
  '(-d --base-dir)'{-d,--base-dir}'=[base folder into which URL is saved]:dir:_files -/' \
  '--delay=[minimum seconds between consecutive fetches]:seconds:' \
  '--dont-download-stylesheets[do not download CSS stylesheets]' \
  '--encoding=[character encoding for the websites]:encoding:' \
  '*--filter-regexp=[ignore links matching this regular expression]:regexp:' \
  '*--match-regexp=[only follow links matching this regular expression]:regexp:' \
  '(-n --max-files)'{-n,--max-files}'=[maximum number of files to download]:count:' \
  '(-r --max-recursions)'{-r,--max-recursions}'=[maximum levels to recurse]:depth:' \
  '(-t --timeout)'{-t,--timeout}'=[seconds to wait for a server response]:seconds:' \
  '*:url:_urls' && ret=0

return ret
