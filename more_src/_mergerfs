#compdef mergerfs

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-o+[mount options]:options:' \
  '-f[run in foreground]' \
  '-d[enable debug mode]' \
  '-s[run single-threaded]' \
  '*:branches\:mountpoint:_files -/' && ret=0

return ret
