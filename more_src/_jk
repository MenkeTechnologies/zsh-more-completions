#compdef jk
# Documentation: https://jkcfg.github.io/#/documentation/cli
# jk - data templating tool for writing structured configuration files in JavaScript

local ret=1
local -a commands

commands=(
  'generate:generate configuration files'
  'run:execute a jk program'
  'transform:transform configuration files'
  'validate:validate configuration files'
  'version:print the jk version'
  'help:show help for a command'
)

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input-directory)'{-i+,--input-directory=}'[where to find files read in the script]:dir:_files -/' \
  '*--lib=[use image in module search path, downloading it if necessary]:image:' \
  '--cache=[directory to use for caching downloaded images]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-o --output-directory)'{-o+,--output-directory=}'[where to output generated files]:dir:_files -/' \
  '*'{-p+,--parameter=}'[set input parameters]:param:' \
  '*'{-f+,--parameters=}'[load parameters from a JSON or YAML file]:file:_files' \
  '(-d --emit-dependencies)'{-d,--emit-dependencies}'[emit script dependencies]' \
  '--stdout[print the resulting values to stdout]' \
  '(-m --module)'{-m,--module}'[treat first argument as specifying a module to load]' \
  '(-c --exec)'{-c,--exec}'[treat first argument as specifying literal JavaScript to execute]' \
  '--overwrite[allow input file(s) to be overwritten by output file(s)]' \
  '1:command:->cmds' \
  '*::arg:_files' && ret=0

case $state in
  cmds)
    _describe -t commands 'jk command' commands && ret=0
    ;;
esac

return ret
