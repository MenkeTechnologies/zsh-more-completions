#compdef extractalign
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/extractalign.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# EMBOSS extractalign: extract regions from a sequence alignment.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[aligned sequence(s)]:alignment USA:_files' \
  '-regions=[regions to extract (start..end,start..end)]:regions:' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output format]:format:(fasta embl genbank gff swiss msf gcg pir nbrf raw)' \
  '*:alignment USA:_files' && ret=0
return ret
