#compdef sndfile-salvage
# Documentation: https://man.archlinux.org/search?q=sndfile-salvage
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '1:input sound file:_files -g "*.{wav,flac,ogg,aiff,aif,au,snd,w64,caf,rf64}"'
    '2:output sound file:_files'
)

_arguments -s -S $arguments
