#compdef vulkaninfo

# Zsh completion for vulkaninfo - Vulkan device/driver information

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--summary[only show a summary of Vulkan devices and their properties]' \
  '--json[produce JSON output]' \
  '(-o --output)'{-o,--output}'[direct output to a file]:file:_files' \
  '--show-tool-props[show VkPhysicalDeviceToolProperties]' \
  '--show-formats[show all supported image formats]' \
  '(-h --help)'{-h,--help}'[display help information]' \
  '--html[produce HTML output]' \
  '--text[produce human-readable text output (default)]' \
  '--devsim[produce DevSim JSON output]' \
  '--portability[enable portability enumeration on devices that support it]' \
  '--gpu=[specify GPU index to display information about]:GPU index' && ret=0

return ret
