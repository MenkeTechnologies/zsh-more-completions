#compdef fwupdtool
# Documentation: https://github.com/fwupd/fwupd
# Source: fwupd/fwupd src/fu-tool.c — debug firmware updates via fwupd daemon-less interface (C, GOption).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '--version[show version]' \
    '--allow-reinstall[allow reinstall of firmware]' \
    '--allow-older[allow older firmware downgrade]' \
    '--allow-branch-switch[allow switching to different firmware branch]' \
    '--force[force operation]' \
    '--ignore-checksum[ignore firmware checksum failures]' \
    '--ignore-vid-pid[ignore device VID/PID]' \
    '--ignore-requirements[ignore device requirements]' \
    '--no-reboot-check[do not require a reboot after update]' \
    '--no-search[do not search local cache]' \
    '--no-safety-check[do not require user confirmation]' \
    '--no-device-prompt[do not prompt for device]' \
    '--show-all[show all devices including hidden]' \
    '--show-all-devices[show all devices regardless of state]' \
    '*--plugins=-[only use specified plugins]:plugins:_default' \
    '*--plugin-whitelist=-[whitelist plugins]:plugins:_default' \
    '*--public-keys=-[public key file]:file:_files' \
    '*--prepare=-[shell command before update]:cmd:_command_names' \
    '*--cleanup=-[shell command after update]:cmd:_command_names' \
    '--disable-ssl-strict[disable strict SSL verification]' \
    '--filter=-[filter devices/releases by flags]:filter:_default' \
    '--filter-release=-[filter releases by flags]:filter:_default' \
    '(-y --assume-yes)'{-y,--assume-yes}'[assume yes to all prompts]' \
    '--json[output as JSON]' \
    '--destdir=-[output directory]:dir:_files -/' \
    '1:command:(activate attach bind-driver build-cabinet clean-remote clear-history crc crc-find detach disable-remote disable-test-devices efiboot-create efiboot-delete efiboot-hive efiboot-next efiboot-order efivar-list emulation-load emulation-save emulation-tag emulation-untag enable-remote enable-test-devices esp-list esp-mount esp-unmount export-hwids firmware-build firmware-convert firmware-dump firmware-export firmware-extract firmware-parse firmware-patch firmware-read firmware-sign get-details get-device-flags get-firmware-gtypes get-firmware-types install install-blob jcat-add-alias jcat-export jcat-import jcat-info jcat-remove-alias jcat-self-sign jcat-sign jcat-verify modify-config modify-remote monitor reboot-cleanup refresh reinstall reset-config search security security-fix security-undo self-sign set-bios-setting smbios-dump switch-branch tpm-eventlog unbind-driver vercmp verify-update watch)' \
    '*::command args:_default' \
    && ret=0

return ret
