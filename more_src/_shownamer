#compdef shownamer

_shownamer() {
    _arguments \
        '--dir[Specify directory containing media files]:directory:_files -/' \
        '(-m --movie)'{-m,--movie}'[Look for movie files instead of TV shows]' \
        '--api-key[Provide OMDb API key]:key:' \
        '--ext[Specify file extensions to consider]:extensions (comma-separated):' \
        '--dry-run[Preview changes without actually renaming]' \
        '--verbose[Show detailed logs]' \
        '--help[Show help]' \
        '*:file:_files'
}

_shownamer "$@"
