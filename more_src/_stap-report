#compdef stap-report
# Documentation: https://man.archlinux.org/search?q=stap-report
# Reference accessed: 2026-05-16

# stap-report: collect SystemTap diagnostic report
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*::stap-report args:_files' && ret=0
return ret
