#compdef mfsappendchunks
# Documentation: https://moosefs.com/manpages/mfsappendchunks
# Reference accessed: 2026-05-19
# Verified: upstream MooseFS man page at the URL above.
# mfsappendchunks: append a lazy copy of FILE(s) to SNAPSHOT_FILE.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-?[display short usage message]' \
  '-s+[slice of chunks (FROM:TO, Python slicing)]:from\:to:' \
  '1:snapshot file:_files' \
  '*:file:_files' && ret=0
return ret
