#compdef backupninja ninjabackup ninjahelper
# _backupninja — riseup.net backupninja CLI for handler-based Linux backup system delegating to tar mysql pgsql ldap maildir rdiff-backup rsync borg restic duplicity for daily-rotation cron-driven scheduled backups with handler dispatch (riseup team, Bash); getopt
# upstream: https://0xacab.org/riseuplabs/backupninja

_backupninja() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-f+[config file]:file:_files -g "*.conf backupninja.conf"' \
        '--conffile=+[config file]:file:_files -g "*.conf backupninja.conf"' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '-t[test config]' \
        '--test[test config]' \
        '-r+[run specific action]:file:_files -g "*.tar *.mysql *.pgsql *.rdiff *.rsync *.borg *.restic *.duplicity *.dup *.ldap *.maildir"' \
        '--run=+[run specific action]:file:_files' \
        '--no-mail[no mail]' \
        '--now[run now ignore time]' \
        '-i[interactive]' \
        '--immediate[run immediately]' \
        '*:action files:_files'
}

_backupninja "$@"
