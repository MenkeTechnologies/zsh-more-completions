#compdef qmail-command
# _qmail-command — qmail's mail-pipe contract (the protocol qmail-local(8) uses when piping a message to a user-supplied `|command` line in ~/.qmail; documents how stdin/exit-codes map to delivery results)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-command.8 on tip; not invoked directly — argv comes from the .qmail line itself.

_qmail-command() {
    _arguments '*::command:_command_names -e'
}

_qmail-command "$@"
