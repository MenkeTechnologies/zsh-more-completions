#compdef go-musicfox
# Documentation: https://github.com/go-musicfox/go-musicfox
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# go-musicfox/go-musicfox — cmd/musicfox.go registers gcli commands (player default), plus global --pprof --debug.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'player:interactive TUI player (default)'
  'config:configuration helpers'
  'migrate:migrate legacy INI → TOML'
)

_arguments -s -S -C \
  '--debug[enable debug logs]' \
  '(-p --pprof)'{-p,--pprof}'[enable pprof server]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'go-musicfox' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
