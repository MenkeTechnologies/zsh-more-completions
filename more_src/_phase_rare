#compdef phase_rare
# Documentation: https://gensoft.pasteur.fr/docs/shapeit5/5.1.1/phase_rare.html
# SHAPEIT5 phase_rare: phase rare variants onto a common-variant scaffold

local ret=1

_arguments -s -S \
  '--help[produce help message]' \
  '--seed=[seed of the random number generator]:int' \
  '(-T --thread)'{-T,--thread}'=[number of threads used]:int' \
  '--input=[genotypes to be phased in plain VCF/BCF format]:file:_files' \
  '--input-region=[region to be considered in input]:region' \
  '--scaffold=[scaffold of haplotypes in VCF/BCF format]:file:_files' \
  '--scaffold-region=[region to be considered in scaffold]:region' \
  '--map=[genetic map]:file:_files' \
  '--pedigree=[pedigree information (offspring father mother)]:file:_files' \
  '--haploids=[list of haploid samples]:file:_files' \
  '--pbwt-modulo=[storage frequency of PBWT indexes in cM]:float' \
  '--pbwt-depth-common=[depth of PBWT indexes at common sites]:int' \
  '--pbwt-depth-rare=[depth of PBWT indexes at rare sites]:int' \
  '--pbwt-mac=[minimal minor allele count at which PBWT is evaluated]:int' \
  '--pbwt-mdr=[maximal missing data rate at which PBWT is evaluated]:float' \
  '--effective-size=[effective size of the population]:int' \
  '(-O --output)'{-O,--output}'=[phased haplotypes in VCF/BCF format]:file:_files' \
  '--output-buffer=[print right and left buffers in output]:buffer' \
  '--log=[log file]:file:_files' && ret=0

return ret
