#compdef enc2xs
# Documentation: https://man.archlinux.org/search?q=enc2xs
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-C[Directory for C files]:directory:_directories'
    '-M[Module name]:module name:'
    '-N[Name for encoding]:name:'
    '-O[Output file]:output:_files'
    '-Q[Quiet mode]'
    '-S[Source directory]:directory:_directories'
    '-d[Debug mode]'
    '-f[Force overwrite]'
    '-h[Show help]'
    '-o[Output file]:output:_files'
    '--hierarchical-module[Hierarchical module]'
    '*:encoding file:_files -g "*.{enc,ucm}"'
)

_arguments -s -S $arguments
