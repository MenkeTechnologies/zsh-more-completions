#compdef dexed Dexed
# Documentation: https://github.com/asb2m10/dexed
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Dexed is a GUI FM synth plugin (closely modeled on the Yamaha DX7).
# It is built on JUCE and does not document command-line flags; accept a
# .syx patch bank as a positional argument.

local curcontext="$curcontext" ret=1

_arguments -C \
  '*:patch:_files -g "*.syx"' && ret=0

return ret
