#compdef TMalign
# Documentation: https://github.com/pylelab/USalign
# TMalign - protein structure alignment by TM-score rotation matrix

local ret=1

_arguments -s -S \
  '-L[normalise TM-score by an assigned length in aa]:length' \
  '-a[normalise TM-score by the average length of the two structures]' \
  '-b[normalise TM-score by the length of the shorter structure]' \
  '-c[normalise TM-score by the length of the longer structure]' \
  '-d[TM-score scaled by an assigned d0]:d0' \
  '-o[output the superposition to filename.sup and filename.sup_all]:file:_files' \
  '-m[output the rotation matrix to file]:file:_files' \
  '-i[start with an initial alignment from file]:file:_files' \
  '-I[stick to the input alignment from file]:file:_files' \
  '-fast[fast but slightly inaccurate fTM-align alignment]' \
  '*:structure:_files' && ret=0

return ret
