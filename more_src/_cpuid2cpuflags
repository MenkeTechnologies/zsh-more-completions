#compdef cpuid2cpuflags
# _cpuid2cpuflags — map x86 CPUID to Gentoo CPU_FLAGS_X86 USE flags (gentoo/cpuid2cpuflags)
# upstream: https://github.com/gentoo/cpuid2cpuflags
# Flags from src/main.c (getopt_long).

_cpuid2cpuflags() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

_cpuid2cpuflags "$@"
