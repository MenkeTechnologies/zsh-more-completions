#compdef atuin
# _atuin-bin — Atuin magical shell history (Ellie Huxtable, Rust); SQLite-backed search + sync server
# upstream: https://github.com/atuinsh/atuin

_atuin-bin() {
    local -a sub=(
        'history:history operations'
        'import:import existing shell history'
        'stats:show history stats'
        'search:search history'
        'sync:sync history with server'
        'login:login to sync server'
        'logout:logout from sync server'
        'register:register a new account'
        'key:show encryption key'
        'kv:key-value store'
        'store:low-level store ops'
        'status:show client status'
        'account:account commands'
        'gen-completions:print shell completion'
        'doctor:diagnose env'
        'wrapped:annual recap stats'
        'init:print shell integration script'
        'dotfiles:dotfiles commands'
        'daemon:run sync daemon'
        'info:print build info'
        'default-config:dump default config'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'atuin subcommand' sub ;;
        args)
            case $words[1] in
                history) _arguments '1:hist cmd:(start end list init-store)' '*:args:' ;;
                import) _arguments '1:shell:(auto bash fish zsh zsh-histdb resh xonsh xonsh-sqlite replxx nu)' ;;
                stats) _arguments \
                    '(-c --count)'{-c,--count}'+[top N]:n:' \
                    '(-n --ngram-size)'{-n,--ngram-size}'+[ngram size]:n:' \
                    '*:period:' ;;
                search) _arguments \
                    '(-c --cwd)'{-c,--cwd}'+[cwd filter]:dir:_files -/' \
                    '(-e --exclude-cwd)'{-e,--exclude-cwd}'+[exclude cwd]:dir:_files -/' \
                    '--exit+[exit code]:n:' \
                    '--exclude-exit+[exclude exit]:n:' \
                    '--before+[before time]:time:' \
                    '--after+[after time]:time:' \
                    '--limit+[result limit]:n:' \
                    '--offset+[offset]:n:' \
                    '--delete[delete matched]' \
                    '--delete-it-all[delete all]' \
                    '--reverse[reverse]' \
                    '(-f --format)'{-f,--format}'+[output format]:fmt:' \
                    '(-i --interactive)'{-i,--interactive}'[interactive search]' \
                    '--shell-up-key-binding[shell up-key style]' \
                    '--search-mode+[mode]:mode:(prefix fulltext fuzzy skim)' \
                    '--filter-mode+[filter mode]:mode:(global host session directory workspace)' \
                    '*:query:' ;;
                gen-completions) _arguments \
                    '(-s --shell)'{-s,--shell}'+[shell]:shell:(bash zsh fish elvish powershell nushell)' \
                    '(-o --out-dir)'{-o,--out-dir}'+[out dir]:dir:_files -/' ;;
                kv) _arguments '1:kv cmd:(set get delete list rebuild)' '*:args:' ;;
                store) _arguments '1:store cmd:(rebuild verify status purge push pull update-key)' '*:args:' ;;
                init) _arguments '1:shell:(bash zsh fish nu xonsh)' \
                    '--disable-up-arrow[disable up-arrow]' \
                    '--disable-ctrl-r[disable Ctrl-R]' ;;
                account) _arguments '1:account cmd:(login logout register change-password delete verify)' '*:args:' ;;
            esac
            ;;
    esac
}

_atuin-bin "$@"
