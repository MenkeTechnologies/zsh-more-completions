#compdef terminology

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-e --exec)'{-e+,--exec=}'[command to execute]:cmd:_command_names' \
  '(-d --current-directory)'{-d+,--current-directory=}'[current dir]:dir:_files -/' \
  '(-t --theme)'{-t+,--theme=}'[edje theme name or path]:theme:' \
  '(-b --background)'{-b+,--background=}'[background image]:file:_files' \
  '(-W --no-wm-decorations)'{-W,--no-wm-decorations}'[no WM decorations]' \
  '(-B --borderless)'{-B,--borderless}'[borderless]' \
  '(-T --title)'{-T+,--title=}'[window title]:title:' \
  '(-i --icon-name)'{-i+,--icon-name=}'[set icon name]:name:' \
  '(-g --geometry)'{-g+,--geometry=}'[geometry CxR]:geom:' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen]' \
  '(-I --iconic)'{-I,--iconic}'[start iconic]' \
  '(-M --maximized)'{-M,--maximized}'[start maximized]' \
  '(-r --role)'{-r+,--role=}'[window role]:role:' \
  '(-n --name)'{-n+,--name=}'[window name]:name:' \
  '(-s --no-split)'{-s,--no-split}'[disable splits]' \
  '(-S --split)'{-S+,--split=}'[start with splits hv]:layout:(h v)' \
  '(-2 --2byte)'{-2,--2byte}'[force 2-byte locale]' \
  '(-l --login)'{-l,--login}'[login shell]' \
  '(-w --window-id)'{-w+,--window-id=}'[parent window ID]:id:' \
  '(-N --nowm)'{-N,--nowm}'[no window manager]' \
  '(-H --hold)'{-H,--hold}'[hold open after exit]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-S --single-window)'{-S,--single-window}'[single window mode]' \
  '*: :' && ret=0

return ret
