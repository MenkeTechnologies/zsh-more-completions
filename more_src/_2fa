#compdef 2fa

# Zsh completion for 2fa - two-factor authentication from the command line

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '-add[add a new key]:name' \
  '-clip[copy code to clipboard]' \
  '-hotp[use event-based HOTP]' \
  '-7[generate 7-digit code]' \
  '-8[generate 8-digit code]' \
  '*:key name'
