#compdef mos
# Documentation: https://mongoose-os.com/docs/mongoose-os/userguide/mos-tool.md
# Mongoose OS command line tool

local ret=1

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--port=[device serial port or network endpoint]:port' \
  '--baud=[serial port baud rate]:baud' \
  '--platform=[target platform]:platform:(esp32 esp8266 cc3220 cc3200 stm32f4 stm32l4 stm32f7)' \
  '--build-var=[set a build variable]:var' \
  '--cert-file=[client certificate file for mutual TLS]:file:_files' \
  '--key-file=[client private key file for mutual TLS]:file:_files' \
  '1:command:(build flash flash-read console ls get put rm config-get config-set call wifi aws-iot-setup gcp-iot-setup azure-iot-setup update init ui ota debug-core-dump)' \
  '*::arg:->args' && ret=0

return ret
