#compdef mbed-tools
# Documentation: https://github.com/ARMmbed/mbed-tools
# Arm Mbed Tools - command-line tooling for Mbed OS projects

local ret=1
local context state line
typeset -A opt_args

_mbed_tools_cmds() {
  local -a cmds
  cmds=(
    'new:create a new Mbed project and fetch Mbed OS'
    'import:clone an Mbed project and resolve libraries'
    'deploy:check out library dependencies from .lib files'
    'compile:build an Mbed project'
    'configure:generate the Mbed OS config system'
    'sterm:open a serial terminal to a connected device'
    'detect:list connected Mbed devices'
  )
  _describe -t commands 'mbed-tools command' cmds
}

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show Mbed Tools package versions]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '(-t --traceback)'{-t,--traceback}'[show traceback on error]' \
  '1: :_mbed_tools_cmds' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $line[1] in
      compile)
        _arguments -s -S \
          '(-t --toolchain)'{-t,--toolchain}'[toolchain to use]:toolchain:(ARM GCC_ARM)' \
          '(-m --mbed-target)'{-m,--mbed-target}'[build target]:target:' \
          '(-b --profile)'{-b,--profile}'[build profile]:profile:(develop debug release)' \
          '(-c --clean)'{-c,--clean}'[perform a clean build]' \
          '(-p --program-path)'{-p,--program-path}'[path to the Mbed project]:dir:_files -/' \
          '--mbed-os-path=[path to the Mbed OS directory]:dir:_files -/' \
          '--custom-targets-json=[path to custom_targets.json]:file:_files' \
          '--app-config=[path to application config file]:file:_files' \
          '(-f --flash)'{-f,--flash}'[flash the built firmware onto the target]' \
          '(-s --sterm)'{-s,--sterm}'[open serial terminal after flashing]' \
          '--baudrate=[serial baud rate]:baud:' && ret=0
        ;;
      configure)
        _arguments -s -S \
          '--custom-targets-json=[path to custom_targets.json]:file:_files' \
          '(-t --toolchain)'{-t,--toolchain}'[toolchain to use]:toolchain:(ARM GCC_ARM)' \
          '(-m --mbed-target)'{-m,--mbed-target}'[build target]:target:' \
          '(-b --profile)'{-b,--profile}'[build profile]:profile:(develop debug release)' \
          '(-o --output-dir)'{-o,--output-dir}'[output directory]:dir:_files -/' \
          '(-p --program-path)'{-p,--program-path}'[path to the Mbed project]:dir:_files -/' \
          '--mbed-os-path=[path to the Mbed OS directory]:dir:_files -/' \
          '--app-config=[path to application config file]:file:_files' && ret=0
        ;;
      sterm)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[serial port to connect to]:port:' \
          '(-b --baudrate)'{-b,--baudrate}'[serial baud rate]:baud:' \
          '(-e --echo)'{-e,--echo}'[enable local echo]:echo:(on off)' \
          '(-m --mbed-target)'{-m,--mbed-target}'[target to detect serial port for]:target:' && ret=0
        ;;
      detect)
        _arguments -s -S \
          '--format=[output format]:format:(table json)' \
          '(-a --show-all)'{-a,--show-all}'[show all connected devices]' && ret=0
        ;;
      new)
        _arguments -s -S \
          '(-c --create-only)'{-c,--create-only}'[create a program without fetching mbed-os]' \
          '*:path:_files -/' && ret=0
        ;;
      import)
        _arguments -s -S \
          '(-s --skip-resolve-libs)'{-s,--skip-resolve-libs}'[skip resolving library dependencies]' \
          '*:url:' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[force checkout of all library repositories]' \
          '*:path:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
