#compdef docker-compose
# _docker-compose — Docker Compose v1 (manage multi-service stacks defined in compose.yaml; up/down/start/stop/restart/build/pull/push/ps/logs/exec/run/top/events/cp/scale; -f selects compose file, -p project name, --profile activates a profile)
# upstream: https://github.com/docker/compose
# Subcommands from compose cli/cmd.py on tip.

_docker-compose() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--version[show version]' \
        '-h[show help]' \
        '--help[show help]' \
        '--verbose[verbose]' \
        '--log-level+[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '--ansi+[ANSI mode]:mode:(never always auto)' \
        '*-f+[compose file]:file:_files -g "*.(yml|yaml)"' \
        '-p+[project name]:name:' \
        '*--profile+[profile]:profile:' \
        '--project-directory+[project directory]:dir:_files -/' \
        '--env-file+[env file]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'docker-compose command' \
                '(build bundle config create down events exec help images kill logs pause port ps pull push restart rm run scale start stop top unpause up version watch cp ls top events)'
            ;;
        args) _arguments '*:service:' ;;
    esac
}

_docker-compose "$@"
