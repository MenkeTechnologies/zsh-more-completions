#compdef docker-compose
# Documentation: https://github.com/docker/compose (cmd/compose/compose.go)
# Reference accessed: 2026-05-29
# Docker Compose v2 standalone binary. The Docker CLI's `docker compose` subcommand
# shares the same implementation; this completion targets the standalone binary.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'up:create and start containers'
  'down:stop and remove containers, networks, images, and volumes'
  'start:start existing services'
  'stop:stop services'
  'restart:restart services'
  'ps:list containers'
  'logs:view output from containers'
  'exec:execute a command in a running container'
  'run:run a one-off command on a service'
  'build:build or rebuild services'
  'push:push service images'
  'pull:pull service images'
  'config:parse, resolve, and render compose file'
  'kill:force-stop service containers'
  'rm:remove stopped service containers'
  'pause:pause services'
  'unpause:unpause services'
  'top:display the running processes'
  'events:receive real-time events from containers'
  'port:print the public port for a port binding'
  'images:list images used by the project'
  'create:create services'
  'attach:attach local stdio/stdout/stderr to a service container'
  'export:export a service container filesystem as a tar archive'
  'commit:create a new image from a service container'
  'cp:copy files/folders between a service container and the local filesystem'
  'wait:block until first service container stops'
  'scale:scale services'
  'stats:display a live stream of container resource usage'
  'watch:watch build context for service and rebuild/refresh on file changes'
  'ls:list running compose projects'
  'volumes:list volumes'
  'version:show the Docker Compose version'
  'help:show help for a subcommand'
)

local -a _global_flags
_global_flags=(
  '*-f[compose configuration file]:file:_files -g "(docker-)#compose*.(yml|yaml)"'
  '*--file=[compose configuration file]:file:_files -g "(docker-)#compose*.(yml|yaml)"'
  '(-p --project-name)'{-p,--project-name=}'[project name]:name:'
  '--project-directory=[path to alternate working directory]:dir:_directories'
  '*--profile=[specify a profile to enable]:profile:'
  '--env-file=[specify an alternate environment file]:file:_files'
  '--ansi=[control when to print ANSI control chars]:mode:(never always auto)'
  '--parallel=[max parallelism, -1 for unlimited]:n:'
  '--compatibility[run compose in backward compatibility mode]'
  '--dry-run[execute command in dry-run mode]'
  '--progress=[set type of progress output]:type:(auto tty plain json quiet)'
  '--verbose[show more output]'
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-v,--version}'[show version]'
)

_arguments -C \
  $_global_flags \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'docker-compose subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      up)
        _arguments \
          $_global_flags \
          '(-d --detach)'{-d,--detach}'[run containers in background]' \
          '--abort-on-container-exit[stop all containers if any container stops]' \
          '--abort-on-container-failure[stop all containers if any container exits non-zero]' \
          '--always-recreate-deps[recreate dependent containers]' \
          '--attach=[attach to specified service]:service:' \
          '--attach-dependencies[attach to dependent containers]' \
          '--build[build images before starting]' \
          '--exit-code-from=[return exit code of specified service]:service:' \
          '--force-recreate[recreate containers even if config unchanged]' \
          '--menu[enable the interactive menu]' \
          '--no-attach=[do not attach to specified service]:service:' \
          '--no-build[do not build images]' \
          '--no-color[produce monochrome output]' \
          '--no-deps[do not start linked services]' \
          '--no-log-prefix[do not print prefix in logs]' \
          '--no-recreate[do not recreate containers]' \
          '--no-start[do not start the services after creating them]' \
          '--pull=[pull image before running]:policy:(always missing never)' \
          '--quiet-pull[pull without printing progress]' \
          '*--remove-orphans[remove containers for services not in compose file]' \
          '*--renew-anon-volumes[recreate anonymous volumes]' \
          '*--scale=[scale SERVICE=NUM]:service\=num:' \
          '*--timeout=[shutdown timeout in seconds]:seconds:' \
          '--timestamps[show timestamps]' \
          '--wait[wait for services to be running|healthy]' \
          '--wait-timeout=[max wait for project to be running|healthy]:seconds:' \
          '*-w[wait for services]' \
          '*:service:' && ret=0
        ;;
      down)
        _arguments \
          $_global_flags \
          '--remove-orphans[remove orphan containers]' \
          '--rmi=[remove images]:type:(local all)' \
          '(-t --timeout)'{-t,--timeout=}'[shutdown timeout (seconds)]:seconds:' \
          '(-v --volumes)'{-v,--volumes}'[remove named volumes and anonymous volumes]' \
          '*:service:' && ret=0
        ;;
      build)
        _arguments \
          $_global_flags \
          '*--build-arg=[set build-time variables for services]:key\=value:' \
          '--builder=[set builder to use]:builder:' \
          '--check[check build configuration]' \
          '--dry-run[execute in dry-run mode]' \
          '-m=[memory limit]:bytes:' \
          '--memory=[memory limit]:bytes:' \
          '--no-cache[do not use cache when building]' \
          '--print=[print equivalent bake file]:type:(json yaml)' \
          '--provenance=[add provenance attestation]:value:(true false min max)' \
          '--pull[always pull base images]' \
          '--push[push images]' \
          '(-q --quiet)'{-q,--quiet}'[suppress build output]' \
          '--sbom=[generate SBOM attestation]:value:(true false)' \
          '*--ssh=[SSH agent socket or keys]:value:' \
          '--with-dependencies[also build dependencies]' \
          '*:service:' && ret=0
        ;;
      exec)
        _arguments \
          $_global_flags \
          '(-d --detach)'{-d,--detach}'[detached mode]' \
          '*-e[set environment variables]:env:' \
          '*--env=[set environment variables]:env:' \
          '--index=[index of the container to target]:n:' \
          '(-i --no-TTY)'{-i,--no-TTY}'[disable pseudo-TTY allocation]' \
          '(-T --no-tty)'{-T,--no-tty}'[disable pseudo-TTY allocation]' \
          '--privileged[give extended privileges]' \
          '(-u --user)'{-u,--user=}'[user/UID]:user:' \
          '(-w --workdir)'{-w,--workdir=}'[path to working directory]:path:' \
          '*:: :_files' && ret=0
        ;;
      logs)
        _arguments \
          $_global_flags \
          '(-f --follow)'{-f,--follow}'[follow log output]' \
          '--index=[index of container to target]:n:' \
          '--no-color[produce monochrome output]' \
          '--no-log-prefix[do not print prefix]' \
          '--since=[show logs since timestamp/duration]:timestamp:' \
          '--tail=[number of lines to show from end]:n:' \
          '(-t --timestamps)'{-t,--timestamps}'[show timestamps]' \
          '--until=[show logs before timestamp/duration]:timestamp:' \
          '*:service:' && ret=0
        ;;
      ps)
        _arguments \
          $_global_flags \
          '(-a --all)'{-a,--all}'[show all stopped containers (including dependencies)]' \
          '--filter=[filter services by property]:filter:(status source)' \
          '--format=[format output]:format:(table json)' \
          '--no-trunc[do not truncate output]' \
          '--orphans[include orphan containers]' \
          '(-q --quiet)'{-q,--quiet}'[only display container IDs]' \
          '--services[display services]' \
          '--status=[filter by status]:status:(paused restarting removing running dead created exited)' \
          '*:service:' && ret=0
        ;;
      run)
        _arguments \
          $_global_flags \
          '(-d --detach)'{-d,--detach}'[detached mode]' \
          '--build[build before starting]' \
          '*--cap-add=[add a Linux capability]:cap:' \
          '*--cap-drop=[drop a Linux capability]:cap:' \
          '*-e[environment variables]:env:' \
          '*--entrypoint=[override entrypoint]:entrypoint:' \
          '--env-from-file=[set environment variables from file]:file:_files' \
          '*-l[set meta data on container]:label:' \
          '*--label=[set meta data on container]:label:' \
          '--name=[assign a name]:name:' \
          '--no-deps[do not start linked services]' \
          '--no-TTY[disable pseudo-TTY]' \
          '--pull=[pull policy]:policy:(always missing never)' \
          '*-p[publish ports]:port:' \
          '*--publish=[publish ports]:port:' \
          '--quiet-pull[suppress pull progress]' \
          '--remove-orphans[remove containers for services not in compose file]' \
          '*-v[mount volumes]:volume:' \
          '*--volume=[mount volumes]:volume:' \
          '(-w --workdir)'{-w,--workdir=}'[working directory]:dir:' \
          '*:command:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
