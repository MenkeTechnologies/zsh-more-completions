#compdef 3dTrackID
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTrackID.html
# AFNI: deterministic and probabilistic white-matter tractography

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-mode[tracking mode (DET/MINIP/PROB)]:mode:(DET MINIP PROB)' \
  '-dti_in[DTI input parameter file prefix]:prefix:_files' \
  '-dti_extra[extra DTI parameter dataset]:dataset:_files' \
  '-dti_search_NO[disable auto search for DTI files]' \
  '-dti_list[file listing DTI parameter datasets]:file:_files' \
  '-hardi_gfa[HARDI GFA dataset]:dataset:_files' \
  '-hardi_dirs[HARDI direction datasets]:dataset:_files' \
  '-hardi_pars[HARDI parameter datasets]:dataset:_files' \
  '-netrois[network of target ROIs dataset]:dataset:_files' \
  '-prefix[output prefix]:prefix:_files' \
  '-mask[mask dataset]:mask:_files' \
  '-thru_mask[through-mask dataset]:mask:_files' \
  '-targ_surf_stop[stop tracts at target surface]' \
  '-targ_surf_twixt[keep tracts between target surfaces]' \
  '-logic[ROI inclusion logic (AND/OR)]:logic:(AND OR)' \
  '-mini_num[number of mini-probabilistic iterations]:n:' \
  '-bundle_thr[min tracts to keep a bundle]:n:' \
  '-uncert[uncertainty dataset]:dataset:_files' \
  '-unc_min_FA[min FA uncertainty]:val:' \
  '-unc_min_V[min direction uncertainty]:val:' \
  '-algopt[algorithm options file]:file:_files' \
  '-alg_Thresh_FA[FA threshold]:val:' \
  '-alg_Thresh_ANG[turning angle threshold (deg)]:val:' \
  '-alg_Thresh_Len[min tract length]:val:' \
  '-alg_Nseed_X[seeds per voxel along X]:n:' \
  '-alg_Nseed_Y[seeds per voxel along Y]:n:' \
  '-alg_Nseed_Z[seeds per voxel along Z]:n:' \
  '-alg_Thresh_Frac[fraction threshold for PROB]:val:' \
  '-alg_Nseed_Vox[seeds per voxel for PROB]:n:' \
  '-alg_Nmonte[Monte Carlo iterations for PROB]:n:' \
  '-extra_tr_par[output extra tract parameters]' \
  '-uncut_at_rois[do not cut tracts at ROIs]' \
  '-dump_rois[dump ROI masks (AFNI/DUMP/AFNI_MAP/BOTH)]:type:(AFNI DUMP AFNI_MAP BOTH)' \
  '-dump_no_labtab[omit label table from dumps]' \
  '-dump_lab_consec[use consecutive ROI labels]' \
  '-posteriori[output posteriori probability maps]' \
  '-rec_orig[record original coordinate origin]' \
  '-do_trk_out[output TrackVis .trk file]' \
  '-trk_opp_orient[flip orientation in .trk output]' \
  '-nifti[write NIFTI output]' \
  '-no_indipair_out[omit individual pair output]' \
  '-write_rois[write ROI label maps]' \
  '-write_opts[write options used to file]' \
  '-pair_out_power[output pair connections in power format]' \
  '-verb[verbosity level]:n:' \
  '*:dataset:_files' && ret=0

return ret
