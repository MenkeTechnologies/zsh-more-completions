#compdef uvu
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*'{-r,--require}'[require a module before tests]:module:' \
  '*'{-i,--ignore}'[ignore a pattern]:pattern:' \
  '1:test directory:_directories' \
  '2:file filter pattern:' && ret=0
return ret
