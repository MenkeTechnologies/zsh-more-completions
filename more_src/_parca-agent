#compdef parca-agent
# Documentation: https://github.com/parca-dev/parca-agent (flags/flags.go kong struct)
# Reference accessed: 2026-05-29
# parca-agent — eBPF continuous profiler agent (Polar Signals / Parca). Sends profiles to a Parca server.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show application version]' \
  '--http-address=[HTTP listen address (default 127.0.0.1\:7071)]:addr:' \
  '--config-path=[config file path]:file:_files -g "*.(yaml|yml)"' \
  '--node=[node name (default ${hostname})]:name:' \
  '--environment-type=[environment type (e.g. kubernetes, ec2)]:type:' \
  '--machine-id=[explicit machine identifier]:id:' \
  '*--include-env-var=[env var to include in target processes (repeatable)]:var:' \
  '--otel-tags=[OpenTelemetry tags (CSV key=value)]:tags:' \
  '--tracers=[which tracers to enable (default all)]:tracers:(all java python ruby go cuda)' \
  '--memlock-rlimit=[memlock rlimit (bytes)]:N:' \
  '--mutex-profile-fraction=[Go runtime mutex profile sample fraction (default 0)]:N:' \
  '--block-profile-rate=[Go runtime block profile sample rate (default 0)]:N:' \
  '--clock-sync-interval=[boot-time clock sync interval (default 3m)]:duration:' \
  '--python-unwinding-disable[disable Python stack unwinding]' \
  '--ruby-unwinding-disable[disable Ruby stack unwinding]' \
  '--java-unwinding-disable[disable Java stack unwinding (default disabled)]' \
  '--instrument-cuda-launch[instrument CUDA kernel launches]' \
  '--analytics-opt-out[opt out of anonymous usage analytics]' \
  '--off-cpu-threshold=[off-CPU sampling threshold (default 0)]:f:' \
  '--enable-oom-prof[enable OOM profiling]' \
  '--enable-oom-prof-allocs[enable OOM allocation profiling]' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--log-format=[log format]:format:(logfmt json)' \
  '--profiling-cpu-sampling-frequency=[CPU sampling frequency Hz]:hz:' \
  '--profiling-duration=[profiling round duration]:duration:' \
  '--metadata-disable-cache[disable metadata cache]' \
  '--metadata-container-runtime-socket-path=[container runtime socket path]:file:_files' \
  '--local-store-directory=[local store directory (writes profiles to disk)]:dir:_directories' \
  '--remote-store-address=[Parca server gRPC address]:addr:' \
  '--remote-store-bearer-token=[bearer token for remote store]:token:' \
  '--remote-store-bearer-token-file=[bearer token file]:file:_files' \
  '--remote-store-insecure[plaintext gRPC (no TLS)]' \
  '--remote-store-insecure-skip-verify[skip TLS verification on remote store]' \
  '--remote-store-batch-write-interval=[batch write interval to remote store]:duration:' \
  '--remote-store-rpc-logging-enable[log gRPC requests to remote store]' \
  '--debuginfo-directories=[debuginfo search directories (CSV)]:dirs:' \
  '--debuginfo-temp-dir=[debuginfo temp dir]:dir:_directories' \
  '--debuginfo-strip[strip debug info from binaries before upload]' \
  '--debuginfo-upload-disable[disable debuginfo upload]' \
  '--debuginfo-upload-max-parallel=[max parallel debuginfo uploads]:N:' \
  '--symbolizer-jit-symbols[symbolize JIT-compiled code]' \
  '--otlp-address=[OTLP traces endpoint]:addr:' \
  '--otlp-exporter=[OTLP exporter type]:type:(grpc http)' \
  '--object-file-pool-size=[object file pool size]:N:' \
  '--object-file-pool-eviction-policy=[eviction policy]:policy:(lru lfu)' \
  '--dwarf-unwinding-disable[disable DWARF-based stack unwinding]' \
  '--dwarf-unwinding-mixed[mix DWARF + frame-pointer unwinding]' \
  '--bpf-verbose-logging[verbose BPF verifier logging]' \
  '--offline-mode-storage-path=[offline mode local storage path]:dir:_directories' \
  '--offline-mode-rotation-interval=[offline mode file rotation interval]:duration:' \
  '--telemetry-disable[disable telemetry]' \
  && ret=0

return ret
