#compdef xdg-desktop-menu
# _xdg-desktop-menu — XDG xdg-desktop-menu (install/uninstall .desktop launcher entries (+ optional menu category XML) into the application menu; --mode user|system; --noupdate skips menu cache refresh)
# upstream: https://gitlab.freedesktop.org/xdg/xdg-utils
# Subcommands from xdg-utils scripts/xdg-desktop-menu.in on tip.

_xdg-desktop-menu() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--manual[show full manual]' \
        '--version[show version]' \
        '--noupdate[do not refresh menu caches]' \
        '--novendor[allow no-vendor names]' \
        '--mode+[scope]:scope:(user system)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'subcommand' '(install uninstall forceupdate)' ;;
        args)
            case $line[1] in
                install|uninstall) _arguments '*:desktop file:_files -g "*.(desktop|directory|menu)"' ;;
            esac
            ;;
    esac
}

_xdg-desktop-menu "$@"
