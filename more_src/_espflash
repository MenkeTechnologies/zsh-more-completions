#compdef espflash

# Zsh completion for espflash - ESP chip serial flasher utility

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'board-info:print information about a connected target device'
  'completions:generate shell completions'
  'erase-flash:erase the entire flash of a target device'
  'erase-parts:erase specified partitions'
  'erase-region:erase a region of flash'
  'flash:flash an application to a target device'
  'hold-in-reset:hold the target device in reset'
  'monitor:open a serial monitor'
  'partition-table:convert partition table to binary'
  'read-flash:read SPI flash content'
  'reset:reset the target device'
  'save-image:save a built image to disk'
  'write-bin:write a binary file to a target device'
  'checksum-md5:calculate MD5 checksum of flash region'
  'help:print help for subcommands'
)

local -a chips=(esp32 esp32c2 esp32c3 esp32c6 esp32h2 esp32s2 esp32s3 esp8266)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'espflash subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (flash)
        _arguments \
          '(-p --port)'{-p,--port}'[serial port]:port:_files -g "/dev/tty*"' \
          '(-b --baud)'{-b,--baud}'[baud rate]:baud:(115200 230400 460800 921600 1500000 2000000)' \
          '(-c --chip)'{-c,--chip}'[target chip]:chip:(${chips})' \
          '--bootloader[path to bootloader]:file:_files -g "*.bin"' \
          '--partition-table[path to partition table]:file:_files -g "*.bin *.csv"' \
          '--partition-table-offset[offset of partition table]:offset:' \
          '(-f --flash-freq)'{-f,--flash-freq}'[flash frequency]:freq:(20M 26M 40M 80M)' \
          '(-m --flash-mode)'{-m,--flash-mode}'[flash mode]:mode:(qio qout dio dout)' \
          '(-s --flash-size)'{-s,--flash-size}'[flash size]:size:(256KB 512KB 1MB 2MB 4MB 8MB 16MB 32MB 64MB 128MB)' \
          '--monitor[open serial monitor after flashing]' \
          '--monitor-baud[serial monitor baud rate]:baud:' \
          '--erase-parts[erase partitions by label]:labels:' \
          '--erase-data-parts[erase all data partitions]' \
          '--no-verify[skip flash verification]' \
          '--no-skip[do not skip unchanged regions]' \
          '--target-app-partition[target app partition]:partition:' \
          '--confirm-port[skip port confirmation prompt]' \
          '--log-format[log output format]:format:(serial defmt)' \
          '1:image file:_files -g "*.bin *.elf"' && ret=0
        ;;
      (monitor)
        _arguments \
          '(-p --port)'{-p,--port}'[serial port]:port:_files -g "/dev/tty*"' \
          '(-b --baud)'{-b,--baud}'[baud rate]:baud:(115200 230400 460800 921600)' \
          '(-c --chip)'{-c,--chip}'[target chip]:chip:(${chips})' \
          '--log-format[log output format]:format:(serial defmt)' \
          '(-e --elf)'{-e,--elf}'[ELF file for symbol resolution]:file:_files -g "*.elf"' && ret=0
        ;;
      (save-image)
        _arguments \
          '(-c --chip)'{-c,--chip}'[target chip]:chip:(${chips})' \
          '--bootloader[path to bootloader]:file:_files -g "*.bin"' \
          '--partition-table[path to partition table]:file:_files -g "*.bin *.csv"' \
          '(-f --flash-freq)'{-f,--flash-freq}'[flash frequency]:freq:(20M 26M 40M 80M)' \
          '(-m --flash-mode)'{-m,--flash-mode}'[flash mode]:mode:(qio qout dio dout)' \
          '(-s --flash-size)'{-s,--flash-size}'[flash size]:size:(256KB 512KB 1MB 2MB 4MB 8MB 16MB)' \
          '--merge[merge all parts into single binary]' \
          '--skip-padding[skip padding in merged binary]' \
          '1:image file:_files -g "*.bin *.elf"' \
          '2:output file:_files' && ret=0
        ;;
      (board-info|erase-flash|reset|hold-in-reset)
        _arguments \
          '(-p --port)'{-p,--port}'[serial port]:port:_files -g "/dev/tty*"' \
          '(-b --baud)'{-b,--baud}'[baud rate]:baud:(115200 230400 460800 921600)' \
          '(-c --chip)'{-c,--chip}'[target chip]:chip:(${chips})' && ret=0
        ;;
      (write-bin)
        _arguments \
          '(-p --port)'{-p,--port}'[serial port]:port:_files -g "/dev/tty*"' \
          '(-b --baud)'{-b,--baud}'[baud rate]:baud:(115200 230400 460800 921600)' \
          '(-c --chip)'{-c,--chip}'[target chip]:chip:(${chips})' \
          '1:address:' \
          '2:binary file:_files -g "*.bin"' && ret=0
        ;;
      (read-flash)
        _arguments \
          '(-p --port)'{-p,--port}'[serial port]:port:_files -g "/dev/tty*"' \
          '(-b --baud)'{-b,--baud}'[baud rate]:baud:(115200 230400 460800 921600)' \
          '(-c --chip)'{-c,--chip}'[target chip]:chip:(${chips})' \
          '1:address:' \
          '2:size:' \
          '3:output file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
