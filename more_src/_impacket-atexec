#compdef impacket-atexec

# Impacket atexec.py: command execution via Task Scheduler RPC
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-share[share for output]:share:' \
  '-mode[execution mode]:mode:(SHARE SERVER)' \
  '-codec[encoding]:codec:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-target-ip[target IP]:ip:' \
  '-keytab[Kerberos keytab]:file:_files' \
  '-silentcommand[do not capture output]' \
  '*:target user[:password]@host cmd:' && ret=0
return ret
