#compdef impacket-atexec
# Documentation: https://github.com/fortra/impacket/blob/master/examples/atexec.py
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# impacket-atexec: remote code execution via task scheduler
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "-debug[verbose debug output]" \
  "-ts[print timestamps in log]" \
  "-ts-utc[print timestamps in UTC]" \
  "-target-ip[target IP]:ip:" \
  "-dc-ip[domain controller IP]:ip:" \
  "-codec[codec for non-utf-8 strings]:codec:" \
  "-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:" \
  "-no-pass[do not ask for password]" \
  "-k[use Kerberos]" \
  "-aesKey[AES key in hex]:hex:" \
  "-cert-pem[pem certificate file]:file:_files" \
  "-cert-pfx[pkcs12 cert file]:file:_files" \
  "-pfx-pass[pkcs12 cert password]:pass:" \
  -share[share to use]:share: -file-uploader[output via share]:share: -mode[output mode]:mode:(SHARE SERVER) -keytab[keytab file]:file:_files -silentcommand[do not output command] \
  '*::impacket-atexec args:_files' && ret=0
return ret
