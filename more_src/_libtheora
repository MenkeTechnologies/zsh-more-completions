#compdef encoder_example example_encoder theoradec libtheora theora-tools
# _libtheora — Xiph.Org Theora video codec example encoder and decoder for the Theora open video format (xiph team, C); getopt
# upstream: https://github.com/xiph/theora

_libtheora() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[video quality 0-63]:n:' \
        '--video-quality=+[video quality 0-63]:n:' \
        '-V+[video bitrate kbps]:n:' \
        '--video-rate=+[video bitrate kbps]:n:' \
        '-a+[audio quality -1 to 10]:f:' \
        '--audio-quality=+[audio quality -1 to 10]:f:' \
        '-A+[audio bitrate kbps]:n:' \
        '--audio-rate=+[audio bitrate kbps]:n:' \
        '-z+[compression speed 0-2]:n:' \
        '--speed-level=+[compression speed 0-2]:n:' \
        '-k+[N frames]:n:' \
        '--keyframe-freq=+[N frames]:n:' \
        '-K+[mode]:m:(0 1 2 3)' \
        '--keyframe-mindistance=+[N frames]:n:' \
        '--soft-target[soft target]' \
        '--two-pass[two-pass]' \
        '--first-pass=+[file]:file:_files' \
        '--second-pass=+[file]:file:_files' \
        '-b+[buffer size frames]:n:' \
        '--buf-delay=+[buffer size frames]:n:' \
        '--vp3-compatible[VP3 compatible]' \
        '-d+[max bit-error rate]:n:' \
        '--dropframes-allowed[dropframes allowed]' \
        '-f+[FPS num/den]:str:' \
        '--frame-rate=+[FPS num/den]:str:' \
        '-F+[aspect num/den]:str:' \
        '--aspect-ratio=+[aspect num/den]:str:' \
        '-c+[chroma subsampling]:c:(420 422 444)' \
        '--chroma-format=+[chroma subsampling]:c:(420 422 444)' \
        '-D+[deblocking level]:n:' \
        '-T+[N threads]:n:' \
        '--threads=+[N threads]:n:' \
        '-o+[output file]:file:_files -g "*.ogv *.ogm *.ogg"' \
        '--output=+[output file]:file:_files -g "*.ogv *.ogm *.ogg"' \
        '*:input video:_files -g "*.y4m *.yuv *.ogg *.ogv"'
}

_libtheora "$@"
