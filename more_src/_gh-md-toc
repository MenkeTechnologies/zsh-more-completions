#compdef gh-md-toc
# Documentation: https://man.archlinux.org/search?q=gh-md-toc
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/github-markdown-toc — GitHub-compatible Markdown TOC generator

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
