#compdef celluloid
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/celluloid.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help,-\\?}'[show help]' \
  '(- *)--version[show release version]' \
  '--new-window[create a new window if there is already a running instance]' \
  '--enqueue[append given files or URIs to the playlist of running instance]' \
  '*--mpv-*=[set an mpv option (e.g. --mpv-vf=vflip)]:value:' \
  '--mpv-options=[deprecated; pass arbitrary mpv options]:options:' \
  '--role=[set the window role]:role:' \
  '--no-existing-session[do not connect to an existing instance]' \
  '*::file_or_url:_files' && ret=0

return ret
