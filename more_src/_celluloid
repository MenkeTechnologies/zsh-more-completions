#compdef celluloid
# Documentation: https://man.archlinux.org/search?q=celluloid
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help,-\\?}'[show help]' \
  '(- *)--version[show version]' \
  '--new-window[open in a new window if an instance is running]' \
  '--enqueue[append files to the playlist of running instance]' \
  '*--mpv-*=[pass an mpv option (e.g. --mpv-vf=vflip)]:value:' \
  '--mpv-options=[deprecated; pass arbitrary mpv options]:options:' \
  '--no-existing-session[do not connect to an existing instance]' \
  '*::file_or_url:_files' && ret=0

return ret
