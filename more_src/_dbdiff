#compdef dbdiff
# Source: cargo binstall dbdiff@0.2.1
# Probed via: completions zsh
# Repository: https://github.com/rekurt/dbdiff

autoload -U is-at-least

_dbdiff() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--schema=[Path to a .sql schema file to compare against (instead of a second DSN)]:FILE:_default' \
'--out=[Write generated migration SQL to a file]:FILE:_default' \
'--format=[Output format (overrides config file setting)]:FORMAT:(pretty json yaml sql ci)' \
'--config=[Path to config file]:FILE:_default' \
'--timeout=[Connection timeout in seconds]:SECONDS:_default' \
'--ssl-mode=[SSL mode for database connections (disable, prefer, require)]:SSL_MODE:((disable\:"Do not use SSL"
prefer\:"Use SSL if available, fall back to plaintext"
require\:"Require SSL, fail if unavailable"))' \
'--direction=[Migration direction\: up (forward), down (rollback), or both]:DIRECTION:((up\:"Generate forward migration only (default)"
down\:"Generate rollback migration only"
both\:"Generate both forward and rollback migrations"))' \
'--color=[Color output mode]:COLOR:((auto\:"Auto-detect based on terminal"
always\:"Always use colors"
never\:"Never use colors"))' \
'--profile=[UX preset for common workflows (dev, ci, safe-migrate)]:PROFILE:(dev ci safe-migrate)' \
'(--out)--emit=[Explicitly write migration SQL to this file (shortcut for --out FILE --write)]:FILE:_default' \
'--ci[CI mode\: exit with code 1 if schemas differ]' \
'--fail-on-blocking[Exit with code 3 if any blocking operations are detected (requires --ci)]' \
'--dry-run[Preview mode\: show diff and migration without writing any files (default when --out is set)]' \
'--write[Actually write the migration file (overrides safe-by-default dry-run)]' \
'--explain[Show explanation for each migration statement]' \
'--no-transaction[Disable transaction wrapping (BEGIN/COMMIT) around migration SQL]' \
'--concurrently[Use CREATE INDEX CONCURRENTLY for non-blocking index creation (PostgreSQL only, implies --no-transaction)]' \
'--detect-renames[Detect column/table renames instead of DROP+ADD (experimental)]' \
'--force[Force migration even when unique indexes would fail due to duplicate data (adds TRUNCATE TABLE)]' \
'--plan[Plan-only mode (alias for --dry-run)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':source -- Source database DSN (e.g. postgres\://user\:pass@host/db) or .sql file:_default' \
'::target -- Target database DSN to compare against:_default' \
":: :_dbdiff_commands" \
"*::: :->dbdiff" \
&& ret=0
    case $state in
    (dbdiff)
        words=($line[3] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dbdiff-command-$line[3]:"
        case $line[3] in
            (diff)
_arguments "${_arguments_options[@]}" : \
'--schema=[Path to a .sql schema file to compare against (instead of a second DSN)]:FILE:_default' \
'--out=[Write generated migration SQL to a file]:FILE:_default' \
'--format=[Output format (overrides config file setting)]:FORMAT:(pretty json yaml sql ci)' \
'--config=[Path to config file]:FILE:_default' \
'--timeout=[Connection timeout in seconds]:SECONDS:_default' \
'--ssl-mode=[SSL mode for database connections (disable, prefer, require)]:SSL_MODE:((disable\:"Do not use SSL"
prefer\:"Use SSL if available, fall back to plaintext"
require\:"Require SSL, fail if unavailable"))' \
'--direction=[Migration direction\: up (forward), down (rollback), or both]:DIRECTION:((up\:"Generate forward migration only (default)"
down\:"Generate rollback migration only"
both\:"Generate both forward and rollback migrations"))' \
'--color=[Color output mode]:COLOR:((auto\:"Auto-detect based on terminal"
always\:"Always use colors"
never\:"Never use colors"))' \
'--profile=[UX preset for common workflows (dev, ci, safe-migrate)]:PROFILE:(dev ci safe-migrate)' \
'(--out)--emit=[Explicitly write migration SQL to this file (shortcut for --out FILE --write)]:FILE:_default' \
'--ci[CI mode\: exit with code 1 if schemas differ]' \
'--fail-on-blocking[Exit with code 3 if any blocking operations are detected (requires --ci)]' \
'--dry-run[Preview mode\: show diff and migration without writing any files (default when --out is set)]' \
'--write[Actually write the migration file (overrides safe-by-default dry-run)]' \
'--explain[Show explanation for each migration statement]' \
'--no-transaction[Disable transaction wrapping (BEGIN/COMMIT) around migration SQL]' \
'--concurrently[Use CREATE INDEX CONCURRENTLY for non-blocking index creation (PostgreSQL only, implies --no-transaction)]' \
'--detect-renames[Detect column/table renames instead of DROP+ADD (experimental)]' \
'--force[Force migration even when unique indexes would fail due to duplicate data (adds TRUNCATE TABLE)]' \
'--plan[Plan-only mode (alias for --dry-run)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':source -- Source database DSN (e.g. postgres\://user\:pass@host/db) or .sql file:_default' \
'::target -- Target database DSN to compare against:_default' \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
'--timeout=[Connection timeout in seconds]:SECONDS:_default' \
'--ssl-mode=[SSL mode for database connections (disable, prefer, require)]:SSL_MODE:((disable\:"Do not use SSL"
prefer\:"Use SSL if available, fall back to plaintext"
require\:"Require SSL, fail if unavailable"))' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':dsn -- Database DSN to validate (e.g. postgres\://user\:pass@host/db):_default' \
&& ret=0
;;
(tables)
_arguments "${_arguments_options[@]}" : \
'--timeout=[Connection timeout in seconds]:SECONDS:_default' \
'--ssl-mode=[SSL mode for database connections (disable, prefer, require)]:SSL_MODE:((disable\:"Do not use SSL"
prefer\:"Use SSL if available, fall back to plaintext"
require\:"Require SSL, fail if unavailable"))' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':dsn -- Database DSN to list tables from:_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(snapshot)
_arguments "${_arguments_options[@]}" : \
'--out=[Output file (defaults to stdout)]:FILE:_default' \
'--timeout=[Connection timeout in seconds]:SECONDS:_default' \
'--ssl-mode=[SSL mode for database connections]:SSL_MODE:((disable\:"Do not use SSL"
prefer\:"Use SSL if available, fall back to plaintext"
require\:"Require SSL, fail if unavailable"))' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':dsn -- Database DSN to snapshot:_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_dbdiff__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dbdiff-help-command-$line[1]:"
        case $line[1] in
            (diff)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(tables)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(snapshot)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_dbdiff_commands] )) ||
_dbdiff_commands() {
    local commands; commands=(
'diff:Compare two database schemas and generate migration SQL (default command)' \
'validate:Test database connectivity and display server info' \
'tables:List tables in a database' \
'completions:Generate shell completions' \
'init:Create a default .dbdiff.yml configuration file' \
'snapshot:Export schema as JSON snapshot for offline comparison' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'dbdiff commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__completions_commands] )) ||
_dbdiff__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff completions commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__diff_commands] )) ||
_dbdiff__subcmd__diff_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff diff commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__help_commands] )) ||
_dbdiff__subcmd__help_commands() {
    local commands; commands=(
'diff:Compare two database schemas and generate migration SQL (default command)' \
'validate:Test database connectivity and display server info' \
'tables:List tables in a database' \
'completions:Generate shell completions' \
'init:Create a default .dbdiff.yml configuration file' \
'snapshot:Export schema as JSON snapshot for offline comparison' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'dbdiff help commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__help__subcmd__completions_commands] )) ||
_dbdiff__subcmd__help__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff help completions commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__help__subcmd__diff_commands] )) ||
_dbdiff__subcmd__help__subcmd__diff_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff help diff commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__help__subcmd__help_commands] )) ||
_dbdiff__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff help help commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__help__subcmd__init_commands] )) ||
_dbdiff__subcmd__help__subcmd__init_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff help init commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__help__subcmd__snapshot_commands] )) ||
_dbdiff__subcmd__help__subcmd__snapshot_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff help snapshot commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__help__subcmd__tables_commands] )) ||
_dbdiff__subcmd__help__subcmd__tables_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff help tables commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__help__subcmd__validate_commands] )) ||
_dbdiff__subcmd__help__subcmd__validate_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff help validate commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__init_commands] )) ||
_dbdiff__subcmd__init_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff init commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__snapshot_commands] )) ||
_dbdiff__subcmd__snapshot_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff snapshot commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__tables_commands] )) ||
_dbdiff__subcmd__tables_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff tables commands' commands "$@"
}
(( $+functions[_dbdiff__subcmd__validate_commands] )) ||
_dbdiff__subcmd__validate_commands() {
    local commands; commands=()
    _describe -t commands 'dbdiff validate commands' commands "$@"
}

if [ "$funcstack[1]" = "_dbdiff" ]; then
    _dbdiff "$@"
else
    compdef _dbdiff dbdiff
fi
