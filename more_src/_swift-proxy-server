#compdef swift-proxy-server
# Documentation: https://opendev.org/openstack/swift/raw/branch/master/swift/proxy/server.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# main() calls parse_options(test_config=True); standard daemon flags + CONFIG positional.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[log to console]' \
  '(-t --test-config)'{-t,--test-config}'[exit after loading and validating config; do not run the daemon]' \
  '*:CONFIG file:_files -g "*.conf"' && ret=0
return ret
