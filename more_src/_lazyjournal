#compdef lazyjournal
# Documentation: https://github.com/Lifailon/lazyjournal/blob/main/main.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Flag set derived from the flag.* calls in Lifailon/lazyjournal main.go.
# lazyjournal uses Go's stdlib flag package with single-dash flags for both
# short and long forms; both are completed below.
_lazyjournal() {
  _arguments -s \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '(- *)-v[show version]' \
    '(- *)-version[show version]' \
    '-g[print resolved config to stdout]' \
    '-config[print resolved config to stdout]' \
    '-a[run audit log mode]' \
    '-audit[run audit log mode]' \
    '-l[write executed commands to log file]' \
    '-logging[write executed commands to log file]' \
    '-d[disable tail/scroll mode]' \
    '-tail-mode-disable[disable tail/scroll mode]' \
    '-t[number of tail lines]:lines:' \
    '-tail-lines[number of tail lines]:lines:' \
    '-u[update interval in seconds]:seconds:' \
    '-update-interval[update interval in seconds]:seconds:' \
    '-F[minimum symbols for fuzzy filter]:n:' \
    '-min-symbols-filter[minimum symbols for fuzzy filter]:n:' \
    '-T[UTC timezone offset for date filtering]:offset:' \
    '-timezone-filter[UTC timezone offset for date filtering]:offset:' \
    '-m[disable mouse control]' \
    '-mouse-disable[disable mouse control]' \
    '-w[disable wrap mode]' \
    '-wrap-disable[disable wrap mode]' \
    '-C[color mode]:mode:' \
    '-color-mode[color mode]:mode:' \
    '-U[systemd unit type filter]:type:(service socket timer target mount automount path scope slice swap)' \
    '-unit-types[systemd unit type filter]:type:(service socket timer target mount automount path scope slice swap)' \
    '-j[journal field to group by]:field:' \
    '-journal-field[journal field to group by]:field:' \
    '-J[default journal priority]:priority:(emerg alert crit err warning notice info debug)' \
    '-journal-priority[default journal priority]:priority:(emerg alert crit err warning notice info debug)' \
    '-b[default journal boot selector]:boot:' \
    '-journal-boot[default journal boot selector]:boot:' \
    '-p[custom path to scan]:path:_files -/' \
    '-custom-path[custom path to scan]:path:_files -/' \
    '-o[only stream docker logs]' \
    '-docker-stream-only[only stream docker logs]' \
    '-D[docker context]:context:' \
    '-docker-context[docker context]:context:' \
    '-P[podman context]:context:' \
    '-podman-context[podman context]:context:' \
    '-K[kubernetes context]:context:' \
    '-kubernetes-context[kubernetes context]:context:' \
    '-n[kubernetes namespace]:namespace:' \
    '-kubernetes-namespace[kubernetes namespace]:namespace:' \
    '-c[colorize command-mode output]' \
    '-command-color[colorize command-mode output]' \
    '-f[fuzzy filter expression]:pattern:' \
    '-command-fuzzy[fuzzy filter expression]:pattern:' \
    '-r[regex filter expression]:pattern:' \
    '-command-regex[regex filter expression]:pattern:' \
    '-s[connect via SSH (passwordless sudo required)]:ssh-args:' \
    '-ssh[connect via SSH (passwordless sudo required)]:ssh-args:'
}

_lazyjournal "$@"
